# ============================================================
# Stage 2: Verification Self-Hosted Vitte Compiler
# ============================================================
# This is the second self-hosted compilation. Stage 2 is built
# using Stage 1 compiler and should produce identical output
# to Stage 1, verifying the bootstrap process is reproducible.

import vitte/bootstrap/toolchain/config
import vitte/bootstrap/toolchain/platform
import vitte/bootstrap/toolchain/compiler
import vitte/bootstrap/toolchain/build

const VERSION_TEXT: string = "vittec2 stage2-vitte 0.1.0"
const BANNER_TEXT: string = "vittec2 stage2 verification bootstrap"

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

# Stage 2 compiler metadata
