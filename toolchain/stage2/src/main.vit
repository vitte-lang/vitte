space vitte/bootstrap/stage2

const VERSION_TEXT: string = "vittec2 stage2-vitte 0.1.0"
const BANNER_TEXT: string = "vittec2 stage2 verification bootstrap"
const MAIN_RETURN: int = 0

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give MAIN_RETURN
}

export *
