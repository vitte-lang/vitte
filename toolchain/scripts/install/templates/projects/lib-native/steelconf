!muf 4

[workspace]
  .set name "app-lib-native"
  .set root "."
  .set target_dir "build"
  .set profile "debug"
..

[tool sh]
  .exec "sh"
..

[bake check-lib]
  [run sh]
    .set "-c" "vitte check src/lib.vit"
  ..
  .output marker "build/.check-lib.ok"
..

[bake build]
  [run sh]
    .set "-c" "vitte build src/main.vit"
  ..
  .output marker "build/.build.ok"
..
