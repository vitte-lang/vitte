!muf 4

[workspace]
  .set name "app-cli"
  .set root "."
  .set target_dir "build"
  .set profile "debug"
..

[tool sh]
  .exec "sh"
..

[bake check]
  [run sh]
    .set "-c" "vitte check src/main.vit"
  ..
  .output marker "build/.check.ok"
..

[bake build]
  [run sh]
    .set "-c" "vitte build src/main.vit"
  ..
  .output marker "build/.build.ok"
..
