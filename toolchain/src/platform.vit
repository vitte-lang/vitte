// ============================================================
// Bootstrap Toolchain Platform Detection Module
// ============================================================
// Detects OS, architecture, and available tools for the build
// environment and selects appropriate compilation targets.

form PlatformInfo {
  os_name: string,
  arch_name: string,
  os_version: string,
  is_posix: bool,
  is_bsd: bool,
  is_linux: bool,
  is_macos: bool,
  is_windows: bool,
  endianness: string,
  pointer_size: int,
  page_size: int
}

form ToolAvailability {
  has_native_compiler: bool,
  has_alt_native_compiler: bool,
  has_cc: bool,
  has_ccache: bool,
  has_ninja: bool,
  has_make: bool,
  has_ar: bool,
  has_ranlib: bool,
  has_strip: bool,
  has_git: bool,
  has_pkg_config: bool,
  native_compiler_version: string,
  alt_native_compiler_version: string
}

form EnvironmentInfo {
  platform: PlatformInfo,
  tools: ToolAvailability,
  home_dir: string,
  temp_dir: string,
  cpu_count: int,
  total_memory: int
}

// Detect current platform information
proc detect_platform() -> PlatformInfo {
  give PlatformInfo {
    os_name: "linux",
    arch_name: "x86_64",
    os_version: "5.10.0",
    is_posix: true,
    is_bsd: false,
    is_linux: true,
    is_macos: false,
    is_windows: false,
    endianness: "little",
    pointer_size: 64,
    page_size: 4096
  }
}

// Detect available build tools
proc detect_tools() -> ToolAvailability {
  give ToolAvailability {
    has_native_compiler: true,
    has_alt_native_compiler: false,
    has_cc: true,
    has_ccache: false,
    has_ninja: false,
    has_make: true,
    has_ar: true,
    has_ranlib: true,
    has_strip: true,
    has_git: true,
    has_pkg_config: false,
    native_compiler_version: "11.2.0",
    alt_native_compiler_version: ""
  }
}

// Get system CPU count
proc get_cpu_count() -> int {
  give 4
}

// Get available system memory in MB
proc get_system_memory() -> int {
  give 8192
}

// Get home directory
proc get_home_dir() -> string {
  give "/home/user"
}

// Get temporary directory
proc get_temp_dir() -> string {
  give "/tmp"
}

// Detect complete environment information
proc detect_environment() -> EnvironmentInfo {
  let platform: PlatformInfo = detect_platform()
  let tools: ToolAvailability = detect_tools()
  let cpu_count: int = get_cpu_count()
  let memory: int = get_system_memory()
  let home: string = get_home_dir()
  let temp: string = get_temp_dir()
  
  give EnvironmentInfo {
    platform: platform,
    tools: tools,
    home_dir: home,
    temp_dir: temp,
    cpu_count: cpu_count,
    total_memory: memory
  }
}

// Recommended job count based on system resources
proc recommended_job_count(env: EnvironmentInfo) -> int {
  let cpu_count: int = env.cpu_count
  let recommended: int = 1
  if cpu_count >= 8 {
    set recommended = cpu_count - 1
  } else {
    if cpu_count >= 4 {
      set recommended = cpu_count
    } else {
      set recommended = 2
    }
  }
  give recommended
}

// Check if all required tools are available
proc all_required_tools_available(tools: ToolAvailability) -> bool {
  let has_compiler: bool = tools.has_native_compiler || tools.has_alt_native_compiler || tools.has_cc
  let has_archiver: bool = tools.has_ar
  let has_linker: bool = tools.has_make
  
  if has_compiler && has_archiver && has_linker {
    give true
  } else {
    give false
  }
}

// Select best available native bootstrap compiler
proc select_native_compiler(tools: ToolAvailability) -> string {
  if tools.has_alt_native_compiler {
    give "native-cc"
  } else {
    if tools.has_native_compiler {
      give "native-cc"
    } else {
      if tools.has_cc {
        give "cc"
      } else {
        give ""
      }
    }
  }
}

// Select best available build tool
proc select_build_tool(tools: ToolAvailability) -> string {
  if tools.has_ninja {
    give "ninja"
  } else {
    if tools.has_make {
      give "make"
    } else {
      give ""
    }
  }
}

// Check platform support
proc is_platform_supported(platform: PlatformInfo) -> bool {
  let supported: bool = false
  
  if platform.is_linux && platform.is_posix {
    set supported = true
  } else {
    if platform.is_macos && platform.is_posix {
      set supported = true
    } else {
      if platform.is_posix {
        set supported = true
      }
    }
  }
  
  give supported
}

proc platform_family(platform: PlatformInfo) -> string {
  if platform.is_linux {
    give "linux"
  }
  if platform.is_macos {
    give "macos"
  }
  if platform.is_windows {
    give "windows"
  }
  if platform.is_bsd {
    give "bsd"
  }
  give "unknown"
}

proc platform_triple_guess(platform: PlatformInfo) -> string {
  if platform.arch_name == "x86_64" && platform.is_linux {
    give "x86_64-unknown-linux-gnu"
  }
  if platform.arch_name == "aarch64" && platform.is_linux {
    give "aarch64-unknown-linux-gnu"
  }
  if platform.arch_name == "x86_64" && platform.is_macos {
    give "x86_64-apple-darwin"
  }
  if platform.arch_name == "aarch64" && platform.is_macos {
    give "aarch64-apple-darwin"
  }
  if platform.arch_name == "x86_64" && platform.is_windows {
    give "x86_64-pc-windows-gnu"
  }
  give platform.arch_name + "-" + platform.os_name
}

proc supports_parallel_builds(env: EnvironmentInfo) -> bool {
  give env.cpu_count > 1 && env.total_memory >= 1024
}

proc recommended_cache_enabled(env: EnvironmentInfo) -> bool {
  give env.tools.has_ccache && env.total_memory >= 2048
}

proc recommended_build_tool(env: EnvironmentInfo) -> string {
  give select_build_tool(env.tools)
}

proc recommended_compiler(env: EnvironmentInfo) -> string {
  give select_native_compiler(env.tools)
}

proc validate_environment(env: EnvironmentInfo) -> [string] {
  let errors: [string] = []
  if not is_platform_supported(env.platform) {
    set errors = errors + ["platform is not supported"]
  }
  if not all_required_tools_available(env.tools) {
    set errors = errors + ["required build tools are missing"]
  }
  if env.cpu_count < 1 {
    set errors = errors + ["cpu_count must be positive"]
  }
  if env.total_memory < 512 {
    set errors = errors + ["at least 512 MB memory is required"]
  }
  give errors
}

proc tool_summary(tools: ToolAvailability) -> string {
  let compiler: string = select_native_compiler(tools)
  let build_tool: string = select_build_tool(tools)
  give "compiler=" + compiler + " build_tool=" + build_tool
}

proc platform_summary(platform: PlatformInfo) -> string {
  give platform.os_name + "/" + platform.arch_name + " " + platform_triple_guess(platform)
}

proc environment_summary(env: EnvironmentInfo) -> string {
  give platform_summary(env.platform) + " jobs=" + (recommended_job_count(env) as string) + " " + tool_summary(env.tools)
}

export *
