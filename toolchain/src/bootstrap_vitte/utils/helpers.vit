
space vitte/bootstrap/toolchain/bootstrap_vitte/utils/helpers

<<< ============================================================
    Vitte Bootstrap Helper Runtime
    bootstrap orchestration + filesystem + hashing + diagnostics
   ============================================================ >>>

type BootstrapPath = string
type BootstrapHash = string
type BootstrapTimestamp = u64
type BootstrapSize = u64

type BootstrapLogLevel = u32

const LOG_TRACE : BootstrapLogLevel = 0
const LOG_DEBUG : BootstrapLogLevel = 1
const LOG_INFO  : BootstrapLogLevel = 2
const LOG_WARN  : BootstrapLogLevel = 3
const LOG_ERROR : BootstrapLogLevel = 4
const LOG_FATAL : BootstrapLogLevel = 5

form BootstrapEnvironmentVariable {
    key   : string
    value : string
}
let BOOTSTRAP_MONOTONIC_TIMESTAMP: BootstrapTimestamp = 0
form BootstrapDiagnostic {
    level      : BootstrapLogLevel
    category   : string
    message    : string
    file        : string
    line        : usize
    column      : usize
    timestamp   : BootstrapTimestamp
}

form BootstrapFileEntry {
    path          : BootstrapPath
    exists        : bool
    is_directory  : bool
    size          : BootstrapSize
    hash          : BootstrapHash
    modified_at   : BootstrapTimestamp
}

form BootstrapProcessResult {
    success        : bool
    exit_code      : i32
    stdout_output  : string
    stderr_output  : string
    duration_ms    : u64
}

form BootstrapCommand {
    executable    : string
    arguments     : [string]
    environment   : [BootstrapEnvironmentVariable]
    working_dir   : string
    timeout_ms    : u64
    capture_stdio : bool
}

form BootstrapArenaStats {
    allocated_bytes      : u64
    reserved_bytes       : u64
    peak_usage           : u64
    allocation_count     : usize
    released_allocations : usize
    fragmentation_ratio  : f64
}

form BootstrapCacheEntry {
    key             : string
    value_hash      : string
    created_at      : BootstrapTimestamp
    last_accessed   : BootstrapTimestamp
    hit_count       : u64
    valid           : bool
}

form BootstrapCacheRegistry {
    entries             : [BootstrapCacheEntry]
    total_entries       : usize
    cache_hits          : u64
    cache_misses        : u64
    evicted_entries     : usize
}

proc bootstrap_now() -> BootstrapTimestamp {
    set BOOTSTRAP_MONOTONIC_TIMESTAMP = BOOTSTRAP_MONOTONIC_TIMESTAMP + 1
    give BOOTSTRAP_MONOTONIC_TIMESTAMP
}

proc bootstrap_log(
    level : BootstrapLogLevel,
    message : string
) {
    emit "bootstrap-log"
    emit level
    emit message
}

proc bootstrap_trace(
    message : string
) {
    bootstrap_log(LOG_TRACE, message)
}

proc bootstrap_debug(
    message : string
) {
    bootstrap_log(LOG_DEBUG, message)
}

proc bootstrap_info(
    message : string
) {
    bootstrap_log(LOG_INFO, message)
}

proc bootstrap_warn(
    message : string
) {
    bootstrap_log(LOG_WARN, message)
}

proc bootstrap_error(
    message : string
) {
    bootstrap_log(LOG_ERROR, message)
}

proc bootstrap_fatal(
    message : string
) {
    bootstrap_log(LOG_FATAL, message)
}

proc make_environment_variable(
    key : string,
    value : string
) -> BootstrapEnvironmentVariable {
    give BootstrapEnvironmentVariable {
        key   : key,
        value : value
    }
}

proc make_diagnostic(
    level : BootstrapLogLevel,
    category : string,
    message : string
) -> BootstrapDiagnostic {
    give BootstrapDiagnostic {
        level      : level,
        category   : category,
        message    : message,
        file       : "",
        line       : 0,
        column     : 0,
        timestamp  : bootstrap_now()
    }
}

proc make_file_entry(
    path : BootstrapPath
) -> BootstrapFileEntry {
    give BootstrapFileEntry {
        path         : path,
        exists       : false,
        is_directory : false,
        size         : 0,
        hash         : "",
        modified_at  : bootstrap_now()
    }
}

proc make_process_result() -> BootstrapProcessResult {
    give BootstrapProcessResult {
        success       : false,
        exit_code     : -1,
        stdout_output : "",
        stderr_output : "",
        duration_ms   : 0
    }
}

proc make_command(
    executable : string
) -> BootstrapCommand {
    give BootstrapCommand {
        executable    : executable,
        arguments     : [],
        environment   : [],
        working_dir   : "./",
        timeout_ms    : 0,
        capture_stdio : true
    }
}

proc make_arena_stats() -> BootstrapArenaStats {
    give BootstrapArenaStats {
        allocated_bytes      : 0,
        reserved_bytes       : 0,
        peak_usage           : 0,
        allocation_count     : 0,
        released_allocations : 0,
        fragmentation_ratio  : 0.0
    }
}

proc make_cache_entry(
    key : string,
    value_hash : string
) -> BootstrapCacheEntry {
    let timestamp = bootstrap_now()

    give BootstrapCacheEntry {
        key           : key,
        value_hash    : value_hash,
        created_at    : timestamp,
        last_accessed : timestamp,
        hit_count     : 0,
        valid         : true
    }
}

proc make_cache_registry() -> BootstrapCacheRegistry {
    give BootstrapCacheRegistry {
        entries         : [],
        total_entries   : 0,
        cache_hits      : 0,
        cache_misses    : 0,
        evicted_entries : 0
    }
}

proc path_exists(
    path : BootstrapPath
) -> bool {
    give path.len > 0
}

proc path_is_directory(
    path : BootstrapPath
) -> bool {
    if path.len == 0 { give false }
    give path[path.len - 1] == '/'
}

proc path_join(
    left : BootstrapPath,
    right : BootstrapPath
) -> BootstrapPath {
    if left.len == 0 {
        give right
    }

    if left[left.len - 1] == '/' {
        give left + right
    }

    give left + "/" + right
}

proc path_parent(
    path : BootstrapPath
) -> BootstrapPath {
    if path.len == 0 {
        give "."
    }

    let mut index : isize = (path.len as isize) - 1

    while index >= 0 {
        if path[index] == '/' {
            if index == 0 {
                give "/"
            }

            let mut parent : string = ""
            let mut i : usize = 0

            while i < (index as usize) {
                set parent = parent + (path[i] as string)
                set i = i + 1
            }

            give parent
        }

        set index = index - 1
    }

    give "."
}

proc path_filename(
    path : BootstrapPath
) -> string {
    if path.len == 0 {
        give ""
    }

    let mut index : isize = (path.len as isize) - 1

    while index >= 0 {
        if path[index] == '/' {
            let mut filename : string = ""
            let mut i : usize = (index as usize) + 1

            while i < path.len {
                set filename = filename + (path[i] as string)
                set i = i + 1
            }

            give filename
        }

        set index = index - 1
    }

    give path
}

proc path_extension(
    path : BootstrapPath
) -> string {
    let file = path_filename(path)
    let mut index : isize = (file.len as isize) - 1

    while index >= 0 {
        if file[index] == '.' {
            let mut extension : string = ""
            let mut i : usize = (index as usize) + 1

            while i < file.len {
                set extension = extension + (file[i] as string)
                set i = i + 1
            }

            give extension
        }

        set index = index - 1
    }

    give ""
}

proc rotate_right32(
    value : u32,
    shift : u32
) -> u32 {
    give (value >> shift) | (value << (32 - shift))
}

proc sha256_ch(
    x : u32,
    y : u32,
    z : u32
) -> u32 {
    give (x & y) ^ ((~x) & z)
}

proc sha256_maj(
    x : u32,
    y : u32,
    z : u32
) -> u32 {
    give (x & y) ^ (x & z) ^ (y & z)
}

proc sha256_sum0(
    x : u32
) -> u32 {
    give rotate_right32(x, 2) ^ rotate_right32(x, 13) ^ rotate_right32(x, 22)
}

proc sha256_sum1(
    x : u32
) -> u32 {
    give rotate_right32(x, 6) ^ rotate_right32(x, 11) ^ rotate_right32(x, 25)
}

proc sha256_sig0(
    x : u32
) -> u32 {
    give rotate_right32(x, 7) ^ rotate_right32(x, 18) ^ (x >> 3)
}

proc sha256_sig1(
    x : u32
) -> u32 {
    give rotate_right32(x, 17) ^ rotate_right32(x, 19) ^ (x >> 10)
}

proc hex_digit(
    value : u32
) -> string {
    if value < 10 {
        give ((value + 48) as string)
    }

    if value == 10 {
        give "a"
    }

    if value == 11 {
        give "b"
    }

    if value == 12 {
        give "c"
    }

    if value == 13 {
        give "d"
    }

    if value == 14 {
        give "e"
    }

    give "f"
}

proc u32_to_hex(
    value : u32
) -> string {
    let mut result : string = ""
    let mut shift : u32 = 28

    loop while shift < 32 {
        let nibble : u32 = (value >> shift) & 0xf
        set result = result + hex_digit(nibble)
        set shift = shift + 4
    }

    give result
}

proc sha256_hex(
    input : string
) -> string {
    let mut bytes : [u32] = []
    let mut i : usize = 0

    while i < input.len {
        bytes.push(input[i] as u32)
        set i = i + 1
    }

    bytes.push(0x80)

    loop while (bytes.len % 64) != 56 {
        bytes.push(0)
    }

    let bit_length : u64 = (input.len as u64) * 8
    let mut shift64 : i32 = 56

    loop while shift64 >= 0 {
        bytes.push(((bit_length >> (shift64 as u64)) & 0xff) as u32)
        set shift64 = shift64 - 8
    }

    let mut h : [u32] = [
        0x6a09e667,
        0xbb67ae85,
        0x3c6ef372,
        0xa54ff53a,
        0x510e527f,
        0x9b05688c,
        0x1f83d9ab,
        0x5be0cd19
    ]

    let k : [u32] = [
        0x428a2f98, 0x71374491, 0xb5c0fbcf, 0xe9b5dba5,
        0x3956c25b, 0x59f111f1, 0x923f82a4, 0xab1c5ed5,
        0xd807aa98, 0x12835b01, 0x243185be, 0x550c7dc3,
        0x72be5d74, 0x80deb1fe, 0x9bdc06a7, 0xc19bf174,
        0xe49b69c1, 0xefbe4786, 0x0fc19dc6, 0x240ca1cc,
        0x2de92c6f, 0x4a7484aa, 0x5cb0a9dc, 0x76f988da,
        0x983e5152, 0xa831c66d, 0xb00327c8, 0xbf597fc7,
        0xc6e00bf3, 0xd5a79147, 0x06ca6351, 0x14292967,
        0x27b70a85, 0x2e1b2138, 0x4d2c6dfc, 0x53380d13,
        0x650a7354, 0x766a0abb, 0x81c2c92e, 0x92722c85,
        0xa2bfe8a1, 0xa81a664b, 0xc24b8b70, 0xc76c51a3,
        0xd192e819, 0xd6990624, 0xf40e3585, 0x106aa070,
        0x19a4c116, 0x1e376c08, 0x2748774c, 0x34b0bcb5,
        0x391c0cb3, 0x4ed8aa4a, 0x5b9cca4f, 0x682e6ff3,
        0x748f82ee, 0x78a5636f, 0x84c87814, 0x8cc70208,
        0x90befffa, 0xa4506ceb, 0xbef9a3f7, 0xc67178f2
    ]

    let mut chunk_start : usize = 0

    loop while chunk_start < bytes.len {
        let mut w : [u32] = []
        let mut t : usize = 0

        while t < 16 {
            let index : usize = chunk_start + (t * 4)
            let word : u32 = (
                (bytes[index] << 24)
                | (bytes[index + 1] << 16)
                | (bytes[index + 2] << 8)
                | bytes[index + 3]
            )

            w.push(word)
            set t = t + 1
        }

        while t < 64 {
            let value : u32 = sha256_sig1(w[t - 2])
                + w[t - 7]
                + sha256_sig0(w[t - 15])
                + w[t - 16]

            w.push(value)
            set t = t + 1
        }

        let mut a : u32 = h[0]
        let mut b : u32 = h[1]
        let mut c : u32 = h[2]
        let mut d : u32 = h[3]
        let mut e : u32 = h[4]
        let mut f : u32 = h[5]
        let mut g : u32 = h[6]
        let mut h_val : u32 = h[7]

        let mut round : usize = 0

        while round < 64 {
            let t1 : u32 = h_val
                + sha256_sum1(e)
                + sha256_ch(e, f, g)
                + k[round]
                + w[round]

            let t2 : u32 = sha256_sum0(a) + sha256_maj(a, b, c)

            set h_val = g
            set g = f
            set f = e
            set e = d + t1
            set d = c
            set c = b
            set b = a
            set a = t1 + t2

            set round = round + 1
        }

        set h[0] = h[0] + a
        set h[1] = h[1] + b
        set h[2] = h[2] + c
        set h[3] = h[3] + d
        set h[4] = h[4] + e
        set h[5] = h[5] + f
        set h[6] = h[6] + g
        set h[7] = h[7] + h_val

        set chunk_start = chunk_start + 64
    }

    let mut digest : string = ""
    let mut index : usize = 0

    while index < h.len {
        set digest = digest + u32_to_hex(h[index])
        set index = index + 1
    }

    give digest
}

proc hash_string(
    input : string
) -> BootstrapHash {
    give sha256_hex(input)
}

proc hash_file(
    path : BootstrapPath
) -> BootstrapHash {
    give hash_string(path)
}

proc compare_hash(
    left : BootstrapHash,
    right : BootstrapHash
) -> bool {
    give left == right
}

proc run_command(
    command : *BootstrapCommand
) -> BootstrapProcessResult {
    bootstrap_info("run bootstrap command")
    emit command.executable
    emit command.arguments

    let result = make_process_result()
    let process_status = process_spawn()

    result.success = process_status == 0
    result.exit_code = process_status
    result.stdout_output = "bootstrap command executed"
    result.stderr_output = ""
    result.duration_ms = 1

    give result
}

proc append_command_argument(
    command : *BootstrapCommand,
    argument : string
) {
    command.arguments.push(argument)
}

proc append_command_environment(
    command : *BootstrapCommand,
    variable : BootstrapEnvironmentVariable
) {
    command.environment.push(variable)
}

proc allocate_arena(
    arena : *BootstrapArenaStats,
    size : u64
) {
    arena.allocated_bytes = arena.allocated_bytes + size
    arena.allocation_count = arena.allocation_count + 1

    if arena.allocated_bytes > arena.peak_usage {
        arena.peak_usage = arena.allocated_bytes
    }
}

proc release_arena(
    arena : *BootstrapArenaStats,
    size : u64
) {
    if arena.allocated_bytes >= size {
        arena.allocated_bytes = arena.allocated_bytes - size
    }

    arena.released_allocations = arena.released_allocations + 1
}

proc cache_insert(
    registry : *BootstrapCacheRegistry,
    entry : BootstrapCacheEntry
) {
    registry.entries.push(entry)
    registry.total_entries = registry.total_entries + 1
}

proc cache_lookup(
    registry : *BootstrapCacheRegistry,
    key : string
) -> bool {
    let index : usize = 0

    loop while index < registry.total_entries {
        if registry.entries[index].key == key {
            registry.entries[index].hit_count = registry.entries[index].hit_count + 1
            registry.cache_hits = registry.cache_hits + 1

            give true
        }

        index = index + 1
    }

    registry.cache_misses = registry.cache_misses + 1

    give false
}

proc cache_invalidate(
    registry : *BootstrapCacheRegistry,
    key : string
) {
    let index : usize = 0

    loop while index < registry.total_entries {
        if registry.entries[index].key == key {
            registry.entries[index].valid = false
            registry.evicted_entries = registry.evicted_entries + 1
        }

        index = index + 1
    }
}

proc print_diagnostic(
    diagnostic : *BootstrapDiagnostic
) {
    emit "diagnostic"
    emit diagnostic.level
    emit diagnostic.category
    emit diagnostic.message
    emit diagnostic.file
    emit diagnostic.line
    emit diagnostic.column
}

proc print_file_entry(
    entry : *BootstrapFileEntry
) {
    emit "file-entry"
    emit entry.path
    emit entry.exists
    emit entry.is_directory
    emit entry.size
    emit entry.hash
}

proc print_process_result(
    result : *BootstrapProcessResult
) {
    emit "process-result"
    emit result.success
    emit result.exit_code
    emit result.stdout_output
    emit result.stderr_output
    emit result.duration_ms
}

proc print_arena_stats(
    arena : *BootstrapArenaStats
) {
    emit "arena-stats"
    emit arena.allocated_bytes
    emit arena.reserved_bytes
    emit arena.peak_usage
    emit arena.allocation_count
    emit arena.released_allocations
}

proc print_cache_registry(
    registry : *BootstrapCacheRegistry
) {
    emit "cache-registry"
    emit registry.total_entries
    emit registry.cache_hits
    emit registry.cache_misses
    emit registry.evicted_entries
}

proc bootstrap_helpers_demo() -> bool {
    bootstrap_info("bootstrap helper runtime demo")

    let command = make_command("vitte")

    append_command_argument(&command, "build")
    append_command_argument(&command, "compiler/parser")

    let env = make_environment_variable(
        "VITTE_STAGE",
        "bootstrap"
    )

    append_command_environment(&command, env)

    let result = run_command(&command)

    print_process_result(&result)

    let arena = make_arena_stats()

    allocate_arena(&arena, 4096)
    allocate_arena(&arena, 8192)
    release_arena(&arena, 1024)

    print_arena_stats(&arena)

    let cache = make_cache_registry()

    let cache_entry = make_cache_entry(
        "hir-bootstrap",
        hash_string("hir")
    )

    cache_insert(&cache, cache_entry)

    cache_lookup(&cache, "hir-bootstrap")
    cache_lookup(&cache, "missing-cache")

    print_cache_registry(&cache)

    let diagnostic = make_diagnostic(
        LOG_WARN,
        "bootstrap",
        "incremental cache invalidation"
    )

    print_diagnostic(&diagnostic)

    let file_entry = make_file_entry(
        "src/compiler/hir/module.vit"
    )

    print_file_entry(&file_entry)

    give true
}
