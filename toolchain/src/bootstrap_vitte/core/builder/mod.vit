space vitte/bootstrap/toolchain/bootstrap_vitte/core/builder/mod

form Step {
  name: string,
  deps: [string]
}

form StepRunResult {
  name: string,
  ok: bool,
  message: string
}

proc ensure(step: Step) -> bool {
  if step.name == "" { give false }
  give true
}

proc execute(step: Step) -> StepRunResult {
  if not ensure(step) {
    give StepRunResult { name: step.name, ok: false, message: "invalid step" }
  }
  give StepRunResult { name: step.name, ok: true, message: "executed" }
}
