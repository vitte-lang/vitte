space vitte/compiler/middle/mir/mir

use vitte/compiler/frontend/ast/node.{ AstSpan, ast_span_empty }

export *

pick MirStatementKind {
  Assign,
  StorageLive,
  StorageDead,
  Drop,
  Call,
  Return,
  Assert,
  Assume,
  Asm,
  Nop,
}

pick MirRvalueKind {
  Use,
  Binary,
  Unary,
  BorrowShared,
  BorrowMut,
  AddressOf,
  Cast,
  Call,
  Aggregate,
  Tuple,
  Array,
  Struct,
  Len,
  Discriminant,
  Move,
  Copy,
}

pick MirTerminatorKind {
  Return,
  Goto,
  Branch,
  Switch,
  Call,
  Resume,
  Unreachable,
}

pick MirBorrowKind {
  Shared,
  Mut,
  Unique,
}

pick MirBinaryOperator {
  Add,
  Sub,
  Mul,
  Div,
  Rem,
  Eq,
  Ne,
  Lt,
  Le,
  Gt,
  Ge,
  BitAnd,
  BitOr,
  BitXor,
  ShiftLeft,
  ShiftRight,
  And,
  Or,
}

pick MirUnaryOperator {
  Neg,
  Not,
  Deref,
}

form MirPlace {
  local: string
  projection: string
  deref_depth: u64
  mutable: bool
  moved: bool
  valid: bool
}

form MirOperand {
  text: string
  place: MirPlace
  ty: string
  constant: bool
  move: bool
  valid: bool
}

form MirRvalue {
  kind: MirRvalueKind
  text: string
  operator: string
  binary_operator: MirBinaryOperator
  unary_operator: MirUnaryOperator
  borrow_kind: MirBorrowKind
  operands: [MirOperand]
  ty: string
  temporary: bool
  valid: bool
}

form MirStatement {
  id: u64
  span: AstSpan
  kind: MirStatementKind
  place: MirPlace
  rvalue: MirRvalue
  reachable: bool
  valid: bool
}

form MirTerminator {
  kind: MirTerminatorKind
  target_block: u64
  else_block: u64
  unwind_block: u64
  condition: MirOperand
  switch_values: [string]
  switch_targets: [u64]
  reachable: bool
  valid: bool
}

form MirBlock {
  id: u64
  label: string
  predecessors: [u64]
  statements: [MirStatement]
  terminator: MirTerminator
  sealed: bool
  reachable: bool
  valid: bool
}

form MirFunction {
  id: u64
  name: string
  entry_block: u64
  return_type: string
  local_count: u64
  temporary_count: u64
  blocks: [MirBlock]
  valid: bool
}

form MirModule {
  name: string
  functions: [MirFunction]
  valid: bool
}

form MirUnit {
  source_path: string
  module: MirModule
  function_count: u64
  block_count: u64
  instruction_count: u64
  lowered: bool
  valid: bool
}

proc mir_module_empty() -> MirModule {
  give MirModule {
    name: "",
    functions: [],
    valid: false
  };
}

proc mir_place(local: string, projection: string, deref_depth: u64, mutable: bool, moved: bool, valid: bool) -> MirPlace {
  give MirPlace {
    local: local,
    projection: projection,
    deref_depth: deref_depth,
    mutable: mutable,
    moved: moved,
    valid: valid
  };
}

proc mir_place_empty() -> MirPlace {
  give mir_place("", "", 0, false, false, false);
}

proc mir_operand(text: string, place: MirPlace, ty: string, constant: bool, move: bool, valid: bool) -> MirOperand {
  give MirOperand {
    text: text,
    place: place,
    ty: ty,
    constant: constant,
    move: move,
    valid: valid
  };
}

proc mir_operand_empty() -> MirOperand {
  give mir_operand("", mir_place_empty(), "unknown", false, false, false);
}

proc mir_rvalue(kind: MirRvalueKind, text: string, operator: string, binary_operator: MirBinaryOperator, unary_operator: MirUnaryOperator, borrow_kind: MirBorrowKind, operands: [MirOperand], ty: string, temporary: bool, valid: bool) -> MirRvalue {
  give MirRvalue {
    kind: kind,
    text: text,
    operator: operator,
    binary_operator: binary_operator,
    unary_operator: unary_operator,
    borrow_kind: borrow_kind,
    operands: operands,
    ty: ty,
    temporary: temporary,
    valid: valid
  };
}

proc mir_rvalue_use(text: string) -> MirRvalue {
  give mir_rvalue(
    MirRvalueKind.Use,
    text,
    "",
    MirBinaryOperator.Add,
    MirUnaryOperator.Not,
    MirBorrowKind.Shared,
    [mir_operand(text, mir_place_empty(), "unknown", true, false, true)],
    "unknown",
    false,
    true
  );
}

proc mir_statement(id: u64, span: AstSpan, kind: MirStatementKind, place: MirPlace, rvalue: MirRvalue, reachable: bool, valid: bool) -> MirStatement {
  give MirStatement {
    id: id,
    span: span,
    kind: kind,
    place: place,
    rvalue: rvalue,
    reachable: reachable,
    valid: valid
  };
}

proc mir_statement_assign(id: u64, span: AstSpan, place: MirPlace, rvalue: MirRvalue) -> MirStatement {
  give mir_statement(
    id,
    span,
    MirStatementKind.Assign,
    place,
    rvalue,
    true,
    place.valid and rvalue.valid
  );
}

proc mir_terminator(kind: MirTerminatorKind, target_block: u64, else_block: u64, unwind_block: u64, condition: MirOperand, switch_values: [string], switch_targets: [u64], reachable: bool, valid: bool) -> MirTerminator {
  give MirTerminator {
    kind: kind,
    target_block: target_block,
    else_block: else_block,
    unwind_block: unwind_block,
    condition: condition,
    switch_values: switch_values,
    switch_targets: switch_targets,
    reachable: reachable,
    valid: valid
  };
}

proc mir_terminator_return() -> MirTerminator {
  give mir_terminator(
    MirTerminatorKind.Return,
    0,
    0,
    0,
    mir_operand_empty(),
    [],
    [],
    true,
    true
  );
}

proc mir_terminator_goto(target_block: u64) -> MirTerminator {
  give mir_terminator(
    MirTerminatorKind.Goto,
    target_block,
    0,
    0,
    mir_operand_empty(),
    [],
    [],
    true,
    target_block > 0
  );
}

proc mir_terminator_branch(condition: MirOperand, target_block: u64, else_block: u64) -> MirTerminator {
  give mir_terminator(
    MirTerminatorKind.Branch,
    target_block,
    else_block,
    0,
    condition,
    [],
    [],
    true,
    condition.valid and target_block > 0 and else_block > 0
  );
}

proc mir_terminator_switch(condition: MirOperand, switch_values: [string], switch_targets: [u64], else_block: u64) -> MirTerminator {
  give mir_terminator(
    MirTerminatorKind.Switch,
    0,
    else_block,
    0,
    condition,
    switch_values,
    switch_targets,
    true,
    condition.valid
      and len(switch_values) == len(switch_targets)
      and else_block > 0
  );
}

proc mir_block(id: u64, label: string, predecessors: [u64], statements: [MirStatement], terminator: MirTerminator, sealed: bool, reachable: bool, valid: bool) -> MirBlock {
  give MirBlock {
    id: id,
    label: label,
    predecessors: predecessors,
    statements: statements,
    terminator: terminator,
    sealed: sealed,
    reachable: reachable,
    valid: valid
  };
}

proc mir_statement_empty() -> MirStatement {
  give mir_statement(
    0,
    ast_span_empty(),
    MirStatementKind.Nop,
    mir_place_empty(),
    mir_rvalue_use(""),
    false,
    false
  );
}

proc mir_block_empty(id: u64) -> MirBlock {
  give mir_block(
    id,
    "",
    [],
    [],
    mir_terminator_return(),
    false,
    false,
    false
  );
}

proc mir_function(name: string, entry_block: u64, return_type: string, local_count: u64, temporary_count: u64, blocks: [MirBlock], valid: bool) -> MirFunction {
  give MirFunction {
    id: 0,
    name: name,
    entry_block: entry_block,
    return_type: return_type,
    local_count: local_count,
    temporary_count: temporary_count,
    blocks: blocks,
    valid: valid
  };
}

proc mir_unit(source_path: string, module: MirModule, function_count: u64, block_count: u64, instruction_count: u64, lowered: bool, valid: bool) -> MirUnit {
  give MirUnit {
    source_path: source_path,
    module: module,
    function_count: function_count,
    block_count: block_count,
    instruction_count: instruction_count,
    lowered: lowered,
    valid: valid
  };
}

proc mir_binary_operator_name(op: MirBinaryOperator) -> string {
  if op == MirBinaryOperator.Add {
    give "add";
  } elif op == MirBinaryOperator.Sub {
    give "sub";
  } elif op == MirBinaryOperator.Mul {
    give "mul";
  } elif op == MirBinaryOperator.Div {
    give "div";
  } elif op == MirBinaryOperator.Rem {
    give "rem";
  } elif op == MirBinaryOperator.Eq {
    give "eq";
  } elif op == MirBinaryOperator.Ne {
    give "ne";
  } elif op == MirBinaryOperator.Lt {
    give "lt";
  } elif op == MirBinaryOperator.Le {
    give "le";
  } elif op == MirBinaryOperator.Gt {
    give "gt";
  } elif op == MirBinaryOperator.Ge {
    give "ge";
  } elif op == MirBinaryOperator.BitAnd {
    give "bitand";
  } elif op == MirBinaryOperator.BitOr {
    give "bitor";
  } elif op == MirBinaryOperator.BitXor {
    give "bitxor";
  } elif op == MirBinaryOperator.ShiftLeft {
    give "shl";
  } elif op == MirBinaryOperator.ShiftRight {
    give "shr";
  } elif op == MirBinaryOperator.And {
    give "and";
  } elif op == MirBinaryOperator.Or {
    give "or";
  }

  give "unknown";
}

proc mir_unary_operator_name(op: MirUnaryOperator) -> string {
  if op == MirUnaryOperator.Neg {
    give "neg";
  } elif op == MirUnaryOperator.Not {
    give "not";
  } elif op == MirUnaryOperator.Deref {
    give "deref";
  }

  give "unknown";
}

proc mir_statement_kind_name(kind: MirStatementKind) -> string {
  if kind == MirStatementKind.Assign {
    give "assign";
  } elif kind == MirStatementKind.StorageLive {
    give "storage-live";
  } elif kind == MirStatementKind.StorageDead {
    give "storage-dead";
  } elif kind == MirStatementKind.Drop {
    give "drop";
  } elif kind == MirStatementKind.Call {
    give "call";
  } elif kind == MirStatementKind.Return {
    give "return";
  } elif kind == MirStatementKind.Assert {
    give "assert";
  } elif kind == MirStatementKind.Assume {
    give "assume";
  } elif kind == MirStatementKind.Asm {
    give "asm";
  } elif kind == MirStatementKind.Nop {
    give "nop";
  }

  give "unknown";
}

proc mir_terminator_kind_name(kind: MirTerminatorKind) -> string {
  if kind == MirTerminatorKind.Return {
    give "return";
  } elif kind == MirTerminatorKind.Goto {
    give "goto";
  } elif kind == MirTerminatorKind.Branch {
    give "branch";
  } elif kind == MirTerminatorKind.Switch {
    give "switch";
  } elif kind == MirTerminatorKind.Call {
    give "call";
  } elif kind == MirTerminatorKind.Resume {
    give "resume";
  } elif kind == MirTerminatorKind.Unreachable {
    give "unreachable";
  }

  give "unknown";
}

proc mir_summary(unit: MirUnit) -> string {
  let function_count_text: string = unit.function_count as string;
  let block_count_text: string = unit.block_count as string;
  let instruction_count_text: string = unit.instruction_count as string;
  let lowered_text: string = unit.lowered as string;
  let valid_text: string = unit.valid as string;
  let out: string = "functions " + function_count_text;
  let with_blocks: string = out + " blocks " + block_count_text;
  let with_instructions: string = with_blocks + " instructions " + instruction_count_text;
  let with_lowered: string = with_instructions + " lowered " + lowered_text;
  give with_lowered + " valid " + valid_text;
}
