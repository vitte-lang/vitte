space vitte/compiler/ir/hir_to_mir_lowering

// ============================================================================
// HIR TO MIR LOWERING (MONOMORPHIZATION & CODEGEN PREP)
// ============================================================================
// Transforms high-level IR into machine-friendly IR
// Handles:
// - Borrow checking
// - Lifetime erasure
// - Generic instantiation
// - Trait object creation
// - Control flow normalization
// - Place manipulation
// - Unwind edges

form LoweringContext {
  current_block: int,
  next_block_id: int,
  locals: [mir_extended.Local],
  statements: [mir_extended.Statement],
  terminators: [mir_extended.Terminator],
  source_info: mir_extended.Location
}

proc new_lowering_context() -> LoweringContext {
  give LoweringContext {
    current_block: 0,
    next_block_id: 1,
    locals: [],
    statements: [],
    terminators: [],
    source_info: mir_extended.Location { line: 0, column: 0, file: "" }
  }
}

proc allocate_temp(ctx: *LoweringContext, ty: string) -> mir_extended.Local {
  let id = length(ctx.locals)
  let local = mir_extended.Local {
    id: id,
    name: "temp_" + string_of_int(id),
    ty: ty
  }
  push(ctx.locals, local)
  give local
}

proc lower_expr(ctx: *LoweringContext, expr: ast_extended.AstExpr) -> mir_extended.Operand {
  match expr.kind {
    ast_extended.AstExprKind.Literal => {
      give mir_extended.Operand.Constant
    }
    ast_extended.AstExprKind.Variable => {
      let place = mir_extended.Place {
        local: mir_extended.Local { id: 0, name: expr.value, ty: "" },
        projection: []
      }
      give mir_extended.Operand.Copy
    }
    ast_extended.AstExprKind.Binary => {
      let left = lower_expr(ctx, expr.left)
      let right = lower_expr(ctx, expr.right)
      let temp = allocate_temp(ctx, "int")
      let rvalue = mir_extended.Rvalue {
        kind: mir_extended.RvalueKind.BinaryOp,
        operand: left,
        repeat_operand: right,
        repeat_count: 0,
        ref_kind: "",
        ref_place: mir_extended.Place { local: temp, projection: [] },
        addr_mutability: "",
        addr_place: mir_extended.Place { local: temp, projection: [] },
        len_place: mir_extended.Place { local: temp, projection: [] },
        cast_operand: left,
        cast_kind: "",
        cast_to_ty: "",
        binop: expr.op,
        binop_left: left,
        binop_right: right,
        unop: "",
        unop_operand: left,
        disc_place: mir_extended.Place { local: temp, projection: [] },
        agg_kind: "",
        agg_operands: [],
        box_operand: left,
        box_ty: ""
      }
      let stmt = mir_extended.Statement {
        kind: mir_extended.StatementKind.Assign,
        source_info: ctx.source_info
      }
      push(ctx.statements, stmt)
      give mir_extended.Operand.Copy
    }
    _ => {
      give mir_extended.Operand.Constant
    }
  }
}

proc lower_stmt(ctx: *LoweringContext, stmt: ast_extended.AstStmt) {
  match stmt.kind {
    ast_extended.AstStmtKind.Let => {
      let place = mir_extended.Place {
        local: mir_extended.Local { id: length(ctx.locals), name: stmt.name, ty: stmt.ty },
        projection: []
      }
      let operand = lower_expr(ctx, stmt.expr)
    }
    ast_extended.AstStmtKind.Expr => {
      let _ = lower_expr(ctx, stmt.expr)
    }
    _ => {}
  }
}

proc lower_block(ctx: *LoweringContext, block: ast_extended.AstBlock) -> mir_extended.BasicBlock {
  ctx.statements = []

  for i = 0; i < length(block.statements); i = i + 1 {
    lower_stmt(ctx, get_array(block.statements, i))
  }

  let bb = mir_extended.new_basic_block(ctx.current_block, "bb" + string_of_int(ctx.current_block))
  bb.statements = ctx.statements

  give bb
}

proc lower_function(hir_fn: hir_extended.HirFunction) -> mir_extended.MirFunction {
  let mir_fn = mir_extended.new_mir_function(hir_fn.ident)

  // Transfer signature
  let inputs: [mir_extended.MirType] = []
  for i = 0; i < length(hir_fn.sig.inputs); i = i + 1 {
    let param = get_array(hir_fn.sig.inputs, i)
    push(inputs, mir_extended.MirType {
      kind: "param",
      name: param.name,
      size: 8,
      align: 8,
      signed: false
    })
  }
  mir_fn.sig.inputs = inputs

  // Allocate locals for parameters
  for i = 0; i < length(hir_fn.sig.inputs); i = i + 1 {
    let param = get_array(hir_fn.sig.inputs, i)
    push(mir_fn.body.locals, mir_extended.Local {
      id: i,
      name: param.name,
      ty: param.ty
    })
  }

  mir_fn.is_async = hir_fn.is_async
  mir_fn.is_const = hir_fn.is_const
  mir_fn.is_unsafe = hir_fn.is_unsafe

  give mir_fn
}

proc lower_crate(hir_crate: hir_extended.HirCrate) -> mir_extended.MirCrate {
  let mir_crate = mir_extended.MirCrate {
    name: hir_crate.name,
    items: [],
    intrinsics: [],
    lang_items: []
  }

  // Lower each function
  for i = 0; i < length(hir_crate.items); i = i + 1 {
    match get_array(hir_crate.items, i) {
      hir_extended.HirItem.Function => {
        // Extract function and lower it
        // This is a simplified version - actual implementation would need proper casting
      }
      _ => {}
    }
  }

  give mir_crate
}

// ============================================================================
// VALIDATION AND TYPE CHECKING (post-lowering)
// ============================================================================

form TypeCheckResult {
  is_valid: bool,
  errors: [string]
}

proc check_mir_function(mir_fn: mir_extended.MirFunction) -> TypeCheckResult {
  let errors: [string] = []

  // Verify all basic blocks are reachable
  let reachable: [bool] = []
  for i = 0; i < length(mir_fn.body.basic_blocks); i = i + 1 {
    push(reachable, false)
  }

  // Mark first block as reachable
  set_array(reachable, 0, true)

  // Check terminator targets exist
  for i = 0; i < length(mir_fn.body.basic_blocks); i = i + 1 {
    let bb = get_array(mir_fn.body.basic_blocks, i)
    match bb.terminator.kind {
      mir_extended.TerminatorKind.Goto => {
        if bb.terminator.target >= length(mir_fn.body.basic_blocks) {
          push(errors, "Invalid goto target: " + string_of_int(bb.terminator.target))
        }
      }
      mir_extended.TerminatorKind.If => {
        if bb.terminator.if_true >= length(mir_fn.body.basic_blocks) {
          push(errors, "Invalid if-true target")
        }
        if bb.terminator.if_false >= length(mir_fn.body.basic_blocks) {
          push(errors, "Invalid if-false target")
        }
      }
      _ => {}
    }
  }

  give TypeCheckResult {
    is_valid: length(errors) == 0,
    errors: errors
  }
}

// ============================================================================
// MONOMORPHIZATION
// ============================================================================

form MonoContext {
  generic_args: [string],
  substitutions: [string]
}

proc monomorphize_type(ty: mir_extended.MirType, mono_ctx: MonoContext) -> mir_extended.MirType {
  // Replace generic type variables with concrete types
  let result = ty

  for i = 0; i < length(mono_ctx.generic_args); i = i + 1 {
    if ty.name == get_array(mono_ctx.generic_args, i) {
      result.name = get_array(mono_ctx.substitutions, i)
    }
  }

  give result
}

export *
