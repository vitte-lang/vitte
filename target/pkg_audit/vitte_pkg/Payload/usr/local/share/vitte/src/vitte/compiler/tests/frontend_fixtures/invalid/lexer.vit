space vitte/compiler/tests/frontend_fixtures/invalid/lexer

proc invalid_char_source() -> string {
  give "proc main() { @ }\n";
}

proc invalid_number_source() -> string {
  give "proc main() { let broken = 0x_FF; }\n";
}

proc invalid_escape_source() -> string {
  give "proc main() { let broken = \"bad\\q\"; }\n";
}

proc invalid_char_literal_source() -> string {
  give "proc main() { let broken = 'ab'; }\n";
}

export *
