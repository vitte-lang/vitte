space vitte/compiler/ir/mir

// ============================================================================
// MIDDLE-LEVEL INTERMEDIATE REPRESENTATION (MIR)
// ============================================================================
// Machine-friendly IR after HIR lowering
// Corresponds to rustc::mir structure
//
// Features:
// - Control flow graph explicit
// - Assignments normalized
// - Type erasure for runtime
// - Ready for lowering to code generation
// - Suitable for optimizations (DCE, inlining, etc.)

// ============================================================================
// BASIC BLOCK STRUCTURE
// ============================================================================

form Location {
  line: int,
  column: int,
  file: string
}

form BasicBlock {
  id: int,
  label: string,
  statements: [Statement],
  terminator: Terminator,
  predecessors: [int],
  successors: [int],
  is_cleanup: bool
}

form Terminator {
  kind: TerminatorKind,
  source_info: Location,

  // Goto
  target: int,

  // SwitchInt
  switch_discr: Operand,
  switch_targets: [(int, int)],
  switch_otherwise: int,

  // If
  cond: Operand,
  if_true: int,
  if_false: int,

  // Call
  func: Operand,
  args: [Operand],
  destination: Place,
  target_block: int,
  cleanup: int,

  // Return
  return_value: Operand,

  // Resume (for unwinding)

  // Abort

  // Unreachable
}

pick TerminatorKind {
  Goto,
  SwitchInt,
  If,
  Call,
  Return,
  Resume,
  Abort,
  Unreachable,
  Drop,
  DropAndReplace
}

// ============================================================================
// STATEMENTS
// ============================================================================

form Statement {
  kind: StatementKind,
  source_info: Location
}

pick StatementKind {
  Assign,
  FakeRead,
  SetDiscriminant,
  StorageLive,
  StorageDead,
  Retag,
  AscribeUserType,
  Coverage,
  Intrinsic,
  Nop
}

form AssignStatement {
  place: Place,
  rvalue: Rvalue
}

form FakeReadStatement {
  cause: string,
  place: Place
}

form SetDiscriminantStatement {
  place: Place,
  variant_index: int
}

form StorageLiveStatement {
  local: Local
}

form StorageDeadStatement {
  local: Local
}

form RetagStatement {
  kind: string,
  place: Place
}

// ============================================================================
// PLACES AND OPERANDS
// ============================================================================

form Place {
  local: Local,
  projection: [PlaceElem]
}

pick PlaceElem {
  Deref,
  Field,
  Index,
  ConstantIndex,
  Subslice,
  Downcast
}

form Local {
  id: int,
  name: string,
  ty: string
}

pick Operand {
  Copy,
  Move,
  Constant
}

form CopyOperand {
  place: Place
}

form MoveOperand {
  place: Place
}

form ConstantOperand {
  value: string,
  ty: string
}

// ============================================================================
// RVALUES (Right-hand side of assignments)
// ============================================================================

pick RvalueKind {
  Use,
  Repeat,
  Ref,
  AddressOf,
  Len,
  Cast,
  BinaryOp,
  UnaryOp,
  Discriminant,
  Aggregate,
  ShallowInitBox,
  CopyForDeref
}

form Rvalue {
  kind: RvalueKind,

  // Use
  operand: Operand,

  // Repeat
  repeat_operand: Operand,
  repeat_count: int,

  // Ref
  ref_kind: string,
  ref_place: Place,

  // AddressOf
  addr_mutability: string,
  addr_place: Place,

  // Len
  len_place: Place,

  // Cast
  cast_operand: Operand,
  cast_kind: string,
  cast_to_ty: string,

  // BinaryOp
  binop: string,
  binop_left: Operand,
  binop_right: Operand,

  // UnaryOp
  unop: string,
  unop_operand: Operand,

  // Discriminant
  disc_place: Place,

  // Aggregate
  agg_kind: string,
  agg_operands: [Operand],

  // ShallowInitBox
  box_operand: Operand,
  box_ty: string
}

// ============================================================================
// FUNCTION BODY IN MIR
// ============================================================================

form MirBody {
  mir_phase: string,           // "built", "pass_name"
  source_scopes: [SourceScope],
  generator_kind: string,      // normal, async, coroutine
  promoted: [MirBody],
  locals: [Local],
  user_type_annotations: [UserTypeAnnotation],
  arg_count: int,
  spread_arg: int,
  span: Location,

  // CFG
  basic_blocks: [BasicBlock],

  // Constant evaluability
  is_polymorphic: bool,

  // Optimization
  var_debug_info: [VarDebugInfo]
}

form SourceScope {
  parent: int,
  inlined: string,
  inlined_parent_scope: int,
  span: Location
}

form UserTypeAnnotation {
  span: Location,
  user_ty: string,
  inferred_ty: string
}

form VarDebugInfo {
  name: string,
  source_info: Location,
  value: VarDebugInfoContents
}

pick VarDebugInfoContents {
  Place,
  Const,
  Composite
}

// ============================================================================
// FUNCTION DECLARATION IN MIR
// ============================================================================

form MirFunction {
  ident: string,
  sig: FunctionSignature,
  body: MirBody,
  generics: [string],
  where_predicates: [string],
  inline: string,             // "always", "never", "hint"
  is_async: bool,
  is_const: bool,
  is_unsafe: bool,
  abi: string
}

form FunctionSignature {
  inputs: [MirType],
  output: MirType,
  variadic: bool
}

form MirType {
  kind: string,
  name: string,
  size: int,
  align: int,
  signed: bool
}

// ============================================================================
// CONSTANT EVALUATION
// ============================================================================

form ConstValue {
  kind: ConstValueKind,
  ty: MirType,
  value: string,
  span: Location
}

pick ConstValueKind {
  Scalar,
  SliceLenMismatch,
  Indirect
}

// ============================================================================
// MIR CRATE (Full module in MIR form)
// ============================================================================

form MirCrate {
  name: string,
  items: [MirItem],
  intrinsics: [IntrinsicDef],
  lang_items: [LangItem]
}

pick MirItem {
  Function,
  Static,
  Const,
  Type,
  Trait,
  Impl,
  Use
}

form IntrinsicDef {
  name: string,
  inputs: [MirType],
  output: MirType,
  safety: string            // safe, unsafe
}

form LangItem {
  lang: string,
  path: string,
  ty: string
}

// ============================================================================
// BUILDER AND UTILITIES
// ============================================================================

proc new_basic_block(id: int, label: string) -> BasicBlock {
  give BasicBlock {
    id: id,
    label: label,
    statements: [],
    terminator: Terminator {
      kind: TerminatorKind.Unreachable,
      source_info: Location { line: 0, column: 0, file: "" },
      target: 0,
      switch_discr: Operand.Constant,
      switch_targets: [],
      switch_otherwise: 0,
      cond: Operand.Constant,
      if_true: 0,
      if_false: 0,
      func: Operand.Constant,
      args: [],
      destination: Place { local: Local { id: 0, name: "", ty: "" }, projection: [] },
      target_block: 0,
      cleanup: 0,
      return_value: Operand.Constant
    },
    predecessors: [],
    successors: [],
    is_cleanup: false
  }
}

proc new_mir_body() -> MirBody {
  give MirBody {
    mir_phase: "built",
    source_scopes: [],
    generator_kind: "normal",
    promoted: [],
    locals: [],
    user_type_annotations: [],
    arg_count: 0,
    spread_arg: -1,
    span: Location { line: 0, column: 0, file: "" },
    basic_blocks: [],
    is_polymorphic: false,
    var_debug_info: []
  }
}

proc new_mir_function(ident: string) -> MirFunction {
  give MirFunction {
    ident: ident,
    sig: FunctionSignature {
      inputs: [],
      output: MirType { kind: "void", name: "void", size: 0, align: 0, signed: false },
      variadic: false
    },
    body: new_mir_body(),
    generics: [],
    where_predicates: [],
    inline: "hint",
    is_async: false,
    is_const: false,
    is_unsafe: false,
    abi: "vitte"
  }
}

export *
