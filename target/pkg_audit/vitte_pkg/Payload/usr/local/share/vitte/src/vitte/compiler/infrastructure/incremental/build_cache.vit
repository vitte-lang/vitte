space vitte/compiler/infrastructure/incremental/build_cache

form BuildCacheKey {
  source_hash: string
  stdlib_hash: string
  mir_hash: string
}

form BuildCacheEntry {
  key: BuildCacheKey
  artifact_path: string
  valid: bool
}

form BuildCache {
  entries: [BuildCacheEntry]
}

proc hash_text(text: string) -> string {
  let acc: u64 = 2166136261;
  let i: u64 = 0;
  while i < len(text) {
    let ch: string = slice(text, i, i + 1);
    let acc_scaled: u64 = acc * 16777619;
    if ch == "a" or ch == "e" or ch == "i" or ch == "o" or ch == "u" {
      set acc = acc_scaled + 11 + i;
    } elif ch == "0" or ch == "1" or ch == "2" or ch == "3" or ch == "4" or ch == "5" or ch == "6" or ch == "7" or ch == "8" or ch == "9" {
      set acc = acc_scaled + 7 + i;
    } else {
      set acc = acc_scaled + 3 + i;
    }
    set i = i + 1;
  }
  give acc as string;
}

proc cache_key(source_text: string, stdlib_fingerprint: string, mir_text: string) -> BuildCacheKey {
  give BuildCacheKey {
    source_hash: hash_text(source_text),
    stdlib_hash: hash_text(stdlib_fingerprint),
    mir_hash: hash_text(mir_text)
  };
}

proc empty_cache() -> BuildCache {
  give BuildCache { entries: [] };
}

proc key_equals(left: BuildCacheKey, right: BuildCacheKey) -> bool {
  give left.source_hash == right.source_hash and left.stdlib_hash == right.stdlib_hash and left.mir_hash == right.mir_hash;
}

proc cache_lookup(cache: BuildCache, key: BuildCacheKey) -> BuildCacheEntry {
  let i: u64 = 0;
  while i < len(cache.entries) {
    if key_equals(cache.entries[i].key, key) {
      give cache.entries[i];
    }
    set i = i + 1;
  }
  give BuildCacheEntry { key: key, artifact_path: "", valid: false };
}

proc cache_store(cache: BuildCache, entry: BuildCacheEntry) -> BuildCache {
  let out: [BuildCacheEntry] = [];
  let replaced: bool = false;
  let i: u64 = 0;
  while i < len(cache.entries) {
    if key_equals(cache.entries[i].key, entry.key) {
      set out = out + [entry];
      set replaced = true;
    } else {
      set out = out + [cache.entries[i]];
    }
    set i = i + 1;
  }
  if not replaced {
    set out = out + [entry];
  }
  give BuildCache { entries: out };
}
