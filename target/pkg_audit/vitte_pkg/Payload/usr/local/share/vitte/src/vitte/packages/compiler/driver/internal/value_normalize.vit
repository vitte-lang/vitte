space compiler/driver/private/value_normalize

proc default_init_template() -> string {
  give "cli"
}

proc default_crash_dir() -> string {
  give ".vitte-crash"
}

proc default_output() -> string {
  give "a.out"
}

proc default_stdlib_profile() -> string {
  give "full"
}

proc default_syntax_profile() -> string {
  give "stable-v1"
}

proc default_opt_level() -> int {
  give 2
}

proc normalize_template(value: string) -> string {
  if value == "" {
    give default_init_template()
  }
  give value
}

proc normalize_crash_dir(value: string) -> string {
  if value == "" {
    give default_crash_dir()
  }
  give value
}

proc normalize_output(value: string) -> string {
  if value == "" {
    give default_output()
  }
  give value
}

proc normalize_stdlib_profile(value: string) -> string {
  if value == "" {
    give default_stdlib_profile()
  }
  if value == "core" {
    give "minimal"
  }
  give value
}

proc normalize_runtime_profile(value: string) -> string {
  give normalize_stdlib_profile(value)
}

proc normalize_syntax_profile(value: string) -> string {
  if value == "" {
    give default_syntax_profile()
  }
  give value
}

proc normalize_syntax_version(value: string) -> string {
  give normalize_syntax_profile(value)
}

proc default_stage(value: string) -> string {
  if value == "" {
    give "backend"
  }
  give value
}

proc clamp_non_negative_int(value: int) -> int {
  if value < 0 {
    give 0
  }
  give value
}

proc normalize_non_negative_int(value: int) -> int {
  give clamp_non_negative_int(value)
}

proc normalize_panic_budget(value: int) -> int {
  give normalize_non_negative_int(value)
}

proc normalize_panic_budget_notes(value: int) -> int {
  give normalize_non_negative_int(value)
}

proc normalize_strict_recovery(value: int) -> int {
  give normalize_non_negative_int(value)
}

proc normalize_max_imports(value: int) -> int {
  give value
}

proc normalize_lang(value: string) -> string {
  give value
}

proc normalize_target(value: string) -> string {
  give value
}

proc normalize_runtime_include(value: string) -> string {
  give value
}

proc normalize_mod_graph_from(value: string) -> string {
  give value
}

proc normalize_api_diff_old(value: string) -> string {
  give value
}

proc normalize_api_diff_new(value: string) -> string {
  give value
}

proc normalize_port(value: string) -> string {
  give value
}

proc normalize_fqbn(value: string) -> string {
  give value
}
