proc run_parse_ast_json_cli(source_path: string, source_text: string) -> CliReportResult {
    give run_parse_ast_json_with_config_cli(source_path, source_text, driver_compile_config_full("x86_64", "x86_64-linux", "enterprise-default", profile_opt_level("enterprise-default"), profile_packaging("enterprise-default"), true, true, profile_emit_debug_sections("enterprise-default", true), profile_lto_enabled("enterprise-default"), profile_pgo_mode("enterprise-default"), false, default_llvm_toolchain_paths()));
}

