space vitte/compiler/driver

use vitte/compiler/driver/compile.{ DriverCompileConfig, DriverCompileResult, DriverModuleInput, check_source, check_source_with_config, compile_source, compile_source_set, compile_source_set_with_config, compile_source_with_config, driver_compile_config_full, dump_ast_json, dump_diagnostics_json, dump_hir_json, dump_mir_json, profile_emit_debug_sections, profile_lto_enabled, profile_opt_level, profile_packaging, profile_pgo_mode }
use vitte/compiler/backends/llvm_bindings.{ LlvmToolchainPaths, default_llvm_toolchain_paths, llvm_toolchain_paths }
use vitte/compiler/driver/exit_status.{ exit_code }
use vitte/compiler/driver/pipeline.{ CompileReport, ModuleSetCompileReport, compile_report_json, module_set_compile_report_json, run_and_report, run_and_report_with_config, run_set_and_report, run_set_and_report_with_config }
use vitte/compiler/driver/result.{ CliReportResult, CliRunResult }

form CompileSetManifest {
    config: DriverCompileConfig
    inputs: [DriverModuleInput]
    valid: bool
}

proc bool_from_text(text: string) -> bool {
    give text == "true" or text == "1" or text == "yes" or text == "on";
}

proc decode_manifest_source(text: string) -> string {
    let decoded: string = "";
    let i: u64 = 0;
    while i < len(text) {
        let rest: string = slice(text, i, len(text));
        if starts_with(rest, "\\n") {
            set decoded = decoded + "\n";
            set i = i + 2;
        } elif starts_with(rest, "\\t") {
            set decoded = decoded + "\t";
            set i = i + 2;
        } elif starts_with(rest, "\\r") {
            set decoded = decoded + "\r";
            set i = i + 2;
        } elif starts_with(rest, "\\\\") {
            set decoded = decoded + "\\";
            set i = i + 2;
        } else {
            set decoded = decoded + slice(text, i, i + 1);
            set i = i + 1;
        }
    }
    give decoded;
}

proc cli_eq() -> string {
    give slice("a=b", 1, 2);
}

proc manifest_backend_prefix() -> string {
    give "@backend" + cli_eq();
}

proc manifest_target_prefix() -> string {
    give "@target" + cli_eq();
}

proc manifest_profile_prefix() -> string {
    give "@profile" + cli_eq();
}

proc manifest_opt_level_prefix() -> string {
    give "@opt-level" + cli_eq();
}

proc manifest_packaging_prefix() -> string {
    give "@packaging" + cli_eq();
}

proc manifest_deterministic_prefix() -> string {
