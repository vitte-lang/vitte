proc run_compile_report_cli(source_path: string, source_text: string) -> CliReportResult {
    let report: CompileReport = run_and_report("compile", source_path, source_text);

    give CliReportResult {
        code: report.exit_code,
        message: report.status,
        report_json: compile_report_json(report)
    };
}

