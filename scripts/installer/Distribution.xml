<?xml version="1.0" encoding="UTF-8"?>
<installer-gui-script minSpecVersion="1">
  <title>Vitte</title>
  <organization>vitte-lang</organization>
  <options customize="allow" require-scripts="false" rootVolumeOnly="true"/>

  <!-- License -->
  <license file="LICENSE.txt"/>

  <!-- Welcome -->
  <welcome mime-type="text/html" file="Welcome.html"/>

  <!-- ReadMe -->
  <readme mime-type="text/html" file="ReadMe.html"/>

  <!-- Installation types -->
  <installation-type default="easy">
    <easy-install-package file="Base.pkg"/>
  </installation-type>

  <!-- Allowed installations -->
  <allowed-os-versions>
    <os-version min="10.5"/>
  </allowed-os-versions>

  <!-- Language selection -->
  <choices-outline>
    <line choice="install.base">
      <line choice="install.lang.en"/>
      <line choice="install.lang.fr"/>
      <line choice="install.lang.de"/>
      <line choice="install.lang.es"/>
      <line choice="install.lang.it"/>
      <line choice="install.lang.ja"/>
      <line choice="install.lang.ko"/>
      <line choice="install.lang.zh-CN"/>
      <line choice="install.lang.nl"/>
      <line choice="install.lang.pl"/>
      <line choice="install.lang.pt-BR"/>
      <line choice="install.lang.ru"/>
      <line choice="install.lang.tr"/>
      <line choice="install.lang.uk"/>
      <line choice="install.lang.ar"/>
    </line>
  </choices-outline>

  <!-- Choice definitions -->
  <choice id="install.base"
    title="Vitte Base Installation"
    description="Core compiler and tools"
    start_selected="true"
    start_enabled="true"
    enabled="false">
    <pkg-ref id="com.vitte-lang.base.pkg"/>
  </choice>

  <!-- Language packs -->
  <choice id="install.lang.en"
    title="English"
    description="English language files"
    start_selected="true"
    start_enabled="true"
    enabled="false">
    <pkg-ref id="com.vitte-lang.lang.en.pkg"/>
  </choice>

  <choice id="install.lang.fr"
    title="Français (French)"
    description="French language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.fr.pkg"/>
  </choice>

  <choice id="install.lang.de"
    title="Deutsch (German)"
    description="German language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.de.pkg"/>
  </choice>

  <choice id="install.lang.es"
    title="Español (Spanish)"
    description="Spanish language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.es.pkg"/>
  </choice>

  <choice id="install.lang.it"
    title="Italiano (Italian)"
    description="Italian language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.it.pkg"/>
  </choice>

  <choice id="install.lang.ja"
    title="日本語 (Japanese)"
    description="Japanese language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.ja.pkg"/>
  </choice>

  <choice id="install.lang.ko"
    title="한국어 (Korean)"
    description="Korean language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.ko.pkg"/>
  </choice>

  <choice id="install.lang.zh-CN"
    title="中文 (Simplified Chinese)"
    description="Simplified Chinese language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.zh-CN.pkg"/>
  </choice>

  <choice id="install.lang.nl"
    title="Nederlands (Dutch)"
    description="Dutch language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.nl.pkg"/>
  </choice>

  <choice id="install.lang.pl"
    title="Polski (Polish)"
    description="Polish language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.pl.pkg"/>
  </choice>

  <choice id="install.lang.pt-BR"
    title="Português Brasileiro (Brazilian Portuguese)"
    description="Brazilian Portuguese language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.pt-BR.pkg"/>
  </choice>

  <choice id="install.lang.ru"
    title="Русский (Russian)"
    description="Russian language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.ru.pkg"/>
  </choice>

  <choice id="install.lang.tr"
    title="Türkçe (Turkish)"
    description="Turkish language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.tr.pkg"/>
  </choice>

  <choice id="install.lang.uk"
    title="Українська (Ukrainian)"
    description="Ukrainian language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.uk.pkg"/>
  </choice>

  <choice id="install.lang.ar"
    title="العربية (Arabic)"
    description="Arabic language files"
    start_selected="false"
    start_enabled="true">
    <pkg-ref id="com.vitte-lang.lang.ar.pkg"/>
  </choice>

  <!-- Package references -->
  <pkg-ref id="com.vitte-lang.base.pkg" installKBytes="0" version="0" auth="Root">base.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.en.pkg" installKBytes="0" version="0" auth="Root">languages/en.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.fr.pkg" installKBytes="0" version="0" auth="Root">languages/fr.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.de.pkg" installKBytes="0" version="0" auth="Root">languages/de.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.es.pkg" installKBytes="0" version="0" auth="Root">languages/es.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.it.pkg" installKBytes="0" version="0" auth="Root">languages/it.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.ja.pkg" installKBytes="0" version="0" auth="Root">languages/ja.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.ko.pkg" installKBytes="0" version="0" auth="Root">languages/ko.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.zh-CN.pkg" installKBytes="0" version="0" auth="Root">languages/zh-CN.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.nl.pkg" installKBytes="0" version="0" auth="Root">languages/nl.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.pl.pkg" installKBytes="0" version="0" auth="Root">languages/pl.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.pt-BR.pkg" installKBytes="0" version="0" auth="Root">languages/pt-BR.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.ru.pkg" installKBytes="0" version="0" auth="Root">languages/ru.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.tr.pkg" installKBytes="0" version="0" auth="Root">languages/tr.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.uk.pkg" installKBytes="0" version="0" auth="Root">languages/uk.pkg</pkg-ref>
  <pkg-ref id="com.vitte-lang.lang.ar.pkg" installKBytes="0" version="0" auth="Root">languages/ar.pkg</pkg-ref>
</installer-gui-script>
