{
  "schema_version": "1.0",
  "allowed_permissions": [
    "file:read",
    "file:write",
    "net:outbound",
    "process:exec"
  ],
  "default_deny": true,
  "commands": {
    "vitte-analyzer.completion": ["file:read"],
    "vitte-analyzer.hover": ["file:read"],
    "vitte-analyzer.signature": ["file:read"],
    "vitte-analyzer.refs": ["file:read"],
    "vitte-analyzer.goto": ["file:read"],
    "vitte-process.doctor": ["file:read", "process:exec"],
    "vitte-http.doctor": ["file:read", "net:outbound"],
    "vitte-security-lint.run": ["file:read", "net:outbound"],
    "vitte-lint.quickfix-config.preview": ["file:read"],
    "vitte-lint.quickfix-config.apply": ["file:read", "file:write"]
  }
}
