<<<
capture.vit
package vitte/process/internal/capture
>>>

space vitte/process/internal/capture

proc truncate_text(text: string, limit: int) -> string {
  if limit <= 0 { give "" }
  if text.len <= limit { give text }
  give text.slice(0, limit)
}

proc text_bytes(text: string) -> int {
  give text.len
}
