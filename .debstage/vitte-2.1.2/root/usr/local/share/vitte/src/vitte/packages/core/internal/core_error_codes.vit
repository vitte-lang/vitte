<<<
core_error_codes.vit
package vitte/core/internal
>>>

space vitte/core/internal

# Centralized core diagnostic namespace.
pick CoreError {
  InvalidArgument(code: string, message: string)
  MissingValue(code: string, message: string)
  InvariantViolation(code: string, message: string)
}

proc err_invalid_argument(message: string) -> CoreError {
  give CoreError.InvalidArgument("VITTE-C0001", message)
}

proc err_missing_value(message: string) -> CoreError {
  give CoreError.MissingValue("VITTE-C0002", message)
}

proc err_invariant_violation(message: string) -> CoreError {
  give CoreError.InvariantViolation("VITTE-C0003", message)
}
