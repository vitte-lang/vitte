<<<
rules.vit
package vitte/lint/internal/rules
>>>

space vitte/lint/internal/rules

form LintRule {
  id: string
  owner: string
  pack: string
  enabled: bool
  doc_url: string
  quickfix: string
}

proc default_rules() -> [LintRule] {
  give [
    LintRule("alias-pkg", "@vitte/qa", "core-pack", true, "docs/lint/alias_pkg.md", "rename alias to *_pkg"),
    LintRule("no-side-effects", "@vitte/qa", "security-pack", true, "docs/lint/no_side_effects.md", "remove entry/side-effect at import"),
    LintRule("sensitive-imports", "@vitte/security", "security-pack", true, "docs/lint/sensitive_imports.md", "add allowlist or remove import"),
    LintRule("export-naming", "@vitte/style", "style-pack", true, "docs/lint/export_naming.md", "rename symbol to naming convention"),
    LintRule("facade-thin", "@vitte/core", "compat-pack", true, "docs/lint/facade_thin.md", "move heavy logic to internal/*"),
    LintRule("diag-namespace", "@vitte/core", "compat-pack", true, "docs/lint/diag_namespace.md", "use owned VITTE-X**** namespace")
  ]
}

proc enable_rule(rules: [LintRule], id: string) -> [LintRule] {
  let out: [LintRule] = []
  let i: int = 0
  loop {
    if i >= rules.len { break }
    let r: LintRule = rules[i]
    if r.id == id {
      out = out.push(LintRule(r.id, r.owner, r.pack, true, r.doc_url, r.quickfix))
    } else {
      out = out.push(r)
    }
    i = i + 1
  }
  give out
}

proc disable_rule(rules: [LintRule], id: string) -> [LintRule] {
  let out: [LintRule] = []
  let i: int = 0
  loop {
    if i >= rules.len { break }
    let r: LintRule = rules[i]
    if r.id == id {
      out = out.push(LintRule(r.id, r.owner, r.pack, false, r.doc_url, r.quickfix))
    } else {
      out = out.push(r)
    }
    i = i + 1
  }
  give out
}
