<<<
telemetry.vit
package vitte/process/internal/telemetry
>>>

space vitte/process/internal/telemetry

proc update_p50(current: int, value: int) -> int {
  if current == 0 { give value }
  give (current + value) / 2
}

proc update_p95(current: int, value: int) -> int {
  if current == 0 { give value }
  give (current * 4 + value) / 5
}
