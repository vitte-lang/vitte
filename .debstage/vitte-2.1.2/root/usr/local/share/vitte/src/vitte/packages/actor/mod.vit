<<<
mod.vit
package vitte/actor
>>>

space vitte/actor

share all

pick ActorState {
  Idle
  Busy
  Stopped
}

pick MailboxPolicy {
  DropNewest
  DropOldest
  Reject
}

pick SupervisionStrategy {
  Resume
  Restart
  Stop
  Escalate
}

pick MessagePriority {
  High
  Normal
  Low
}

pick CircuitState {
  Closed
  Open
  HalfOpen
}

pick LifecycleHook {
  OnStart
  OnStop
  OnError
  OnRestart
}

pick DeliverySemantics {
  AtMostOnce
  AtLeastOnce
}

pick AckNack {
  Ack
  Nack
}

form ActorMessage {
  message_id: string
  kind: string
  payload: string
  trace_id: string
  span_id: string
  enqueued_tick: int
  priority: MessagePriority
}

form DeadLetter {
  message: ActorMessage
  reason: string
}

form PopResult {
  found: bool
  message: ActorMessage
  mailbox: [ActorMessage]
  next_lane: int
}

form AskRecord {
  request_id: string
  message_id: string
  deadline_tick: int
  canceled: bool
  completed: bool
  timed_out: bool
}

form AskSweepResult {
  asks: [AskRecord]
  timed_out_message_ids: [string]
}

form AskCompleteResult {
  asks: [AskRecord]
  completed_count: int
}

form RouteBinding {
  key: string
  shard_index: int
}

form ActorRouter {
  name: string
  workers: [Actor]
  sticky: [RouteBinding]
  min_workers: int
  max_workers: int
  scale_up_backlog: int
  scale_down_backlog: int
  semantics: DeliverySemantics
  retry_limit: int
  next_worker_id: int
  tenant_limits: [TenantLimit]
  tenant_counters: [TenantCounter]
  auth_rules: [AuthRule]
}

form ActorFamily {
  parent: Actor
  children: [Actor]
}

form InvariantReport {
  ok: bool
  checks: int
  injected: int
}

form TenantLimit {
  tenant_id: string
  mailbox_quota: int
  send_quota: int
  namespace_prefix: string
}

form TenantCounter {
  tenant_id: string
  sent: int
  denied: int
}

form AuthRule {
  from_ns: string
  to_ns: string
  allow: bool
}

form AdminActorInfo {
  name: string
  mailbox_depth: int
  last_error: string
}

form FuzzReport {
  ok: bool
  steps: int
  sends: int
  fails: int
  restarts: int
  closes: int
}

form BenchReport {
  p50: int
  p95: int
  p99: int
  throughput: int
  restart_cost: int
  supervision_cost: int
}

form Actor {
  id: int
  name: string
  state: ActorState
  mailbox: [ActorMessage]
  mailbox_capacity: int
  mailbox_policy: MailboxPolicy

  processed: int
  failures: int
  restarts: int
  dropped: int
  rejected: int
  dead_letters: [DeadLetter]

  supervision: SupervisionStrategy
  restart_limit: int

  backoff_base: int
  backoff_max: int
  backoff_jitter: int
  restart_ready_tick: int

  circuit_state: CircuitState
  circuit_failures: int
  circuit_threshold: int
  circuit_cooldown: int
  circuit_open_until: int

  dedup_window: int
  recent_message_ids: [string]

  scheduler_lane: int
  tick: int
  next_message_seq: int

  hooks: [LifecycleHook]
  hook_runs: int

  latency_total: int
  latency_max: int
  last_latency: int
  last_trace_id: string
  last_span_id: string

  asks: [AskRecord]
  events: [string]
  snapshots: [string]
  snapshot_interval: int
}

proc default_message() -> ActorMessage {
  give ActorMessage("", "", "", "", "", 0, MessagePriority.Normal)
}

proc make_message(kind: string, payload: string, trace_id: string) -> ActorMessage {
  give ActorMessage("", kind, payload, trace_id, "", 0, MessagePriority.Normal)
}

proc make_message_with_id(message_id: string, kind: string, payload: string, trace_id: string) -> ActorMessage {
  give ActorMessage(message_id, kind, payload, trace_id, "", 0, MessagePriority.Normal)
}

proc make_message_with_priority(kind: string, payload: string, trace_id: string, priority: MessagePriority) -> ActorMessage {
  give ActorMessage("", kind, payload, trace_id, "", 0, priority)
}

proc has_hook(a: Actor, hook: LifecycleHook) -> bool {
  let i: int = 0
  loop {
    if i >= a.hooks.len { break }
    if a.hooks[i] == hook { give true }
    i = i + 1
  }
  give false
}

proc run_hook(a: Actor, hook: LifecycleHook) -> Actor {
  if !has_hook(a, hook) { give a }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs + 1,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc contains_text(xs: [string], x: string) -> bool {
  let i: int = 0
  loop {
    if i >= xs.len { break }
    if xs[i] == x { give true }
    i = i + 1
  }
  give false
}

proc trim_recent(ids: [string], max_len: int) -> [string] {
  if ids.len <= max_len { give ids }
  let out: [string] = []
  let start = ids.len - max_len
  let i = start
  loop {
    if i >= ids.len { break }
    out = out.push(ids[i])
    i = i + 1
  }
  give out
}

proc drop_first(mailbox: [ActorMessage]) -> [ActorMessage] {
  let out: [ActorMessage] = []
  let i: int = 1
  loop {
    if i >= mailbox.len { break }
    out = out.push(mailbox[i])
    i = i + 1
  }
  give out
}

proc remove_at(mailbox: [ActorMessage], idx: int) -> [ActorMessage] {
  let out: [ActorMessage] = []
  let i: int = 0
  loop {
    if i >= mailbox.len { break }
    if i != idx {
      out = out.push(mailbox[i])
    }
    i = i + 1
  }
  give out
}

proc lane_for_priority(p: MessagePriority) -> int {
  when p is MessagePriority.High { give 0 }
  when p is MessagePriority.Normal { give 1 }
  give 2
}

proc find_index_for_lane(mailbox: [ActorMessage], lane: int) -> int {
  let i: int = 0
  loop {
    if i >= mailbox.len { break }
    if lane_for_priority(mailbox[i].priority) == lane { give i }
    i = i + 1
  }
  give -1
}

proc pop_by_fair_lane(mailbox: [ActorMessage], lane: int) -> PopResult {
  if mailbox.len == 0 { give PopResult(false, default_message(), mailbox, lane) }

  let pass: int = 0
  loop {
    if pass >= 3 { break }
    let target = lane + pass
    let t = target
    if t >= 3 { t = t - 3 }

    let idx = find_index_for_lane(mailbox, t)
    if idx >= 0 {
      give PopResult(true, mailbox[idx], remove_at(mailbox, idx), (t + 1) % 3)
    }

    pass = pass + 1
  }

  give PopResult(true, mailbox[0], drop_first(mailbox), (lane + 1) % 3)
}

proc pow2_clamped(exp: int) -> int {
  if exp <= 0 { give 1 }
  let out: int = 1
  let i: int = 0
  loop {
    if i >= exp { break }
    out = out * 2
    if out > 1_000_000 { give 1_000_000 }
    i = i + 1
  }
  give out
}

proc restart_backoff_ticks(a: Actor) -> int {
  let mult = pow2_clamped(a.restarts)
  let raw = a.backoff_base * mult
  let capped = raw
  if capped > a.backoff_max { capped = a.backoff_max }
  let jitter = 0
  if a.backoff_jitter > 0 {
    jitter = a.next_message_seq % (a.backoff_jitter + 1)
  }
  give capped + jitter
}

proc with_dead_letter(a: Actor, msg: ActorMessage, reason: string) -> Actor {
  let dl = a.dead_letters.push(DeadLetter(msg, reason))
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, dl,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc spawn(id: int, name: string) -> Actor {
  give Actor(
    id,
    name,
    ActorState.Idle,
    [],
    128,
    MailboxPolicy.DropOldest,

    0,
    0,
    0,
    0,
    0,
    [],

    SupervisionStrategy.Restart,
    3,

    2,
    60,
    3,
    0,

    CircuitState.Closed,
    0,
    3,
    20,
    0,

    256,
    [],

    0,
    0,
    1,

    [],
    0,

    0,
    0,
    0,
    "",
    "",
    [],
    [],
    [],
    8
  )
}

proc actor_new(id: int, name: string) -> Actor {
  give spawn(id, name)
}

proc actor_with_mailbox(id: int, name: string, mailbox: [string]) -> Actor {
  let a = spawn(id, name)
  let i: int = 0
  let msg_mailbox: [ActorMessage] = []
  loop {
    if i >= mailbox.len { break }
    msg_mailbox = msg_mailbox.push(make_message_with_id("bootstrap-" + i.to_string(), "text", mailbox[i], ""))
    i = i + 1
  }
  give Actor(
    a.id, a.name, ActorState.Busy,
    msg_mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc configure_mailbox(a: Actor, capacity: int, policy: MailboxPolicy) -> Actor {
  let cap = capacity
  if cap <= 0 { cap = 1 }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, cap, policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc configure_supervision(a: Actor, strategy: SupervisionStrategy, restart_limit: int) -> Actor {
  let limit = restart_limit
  if limit < 0 { limit = 0 }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    strategy, limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc configure_backoff(a: Actor, base: int, max: int, jitter: int) -> Actor {
  let b = base
  let m = max
  let j = jitter
  if b < 1 { b = 1 }
  if m < b { m = b }
  if j < 0 { j = 0 }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    b, m, j, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc configure_circuit_breaker(a: Actor, threshold: int, cooldown: int) -> Actor {
  let th = threshold
  let cd = cooldown
  if th < 1 { th = 1 }
  if cd < 1 { cd = 1 }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, th, cd, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc configure_idempotence(a: Actor, dedup_window: int) -> Actor {
  let dw = dedup_window
  if dw < 1 { dw = 1 }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    dw, trim_recent(a.recent_message_ids, dw),
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc register_hook(a: Actor, hook: LifecycleHook) -> Actor {
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks.push(hook), a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
}

proc mailbox_len(a: Actor) -> int {
  give a.mailbox.len
}

proc mailbox_is_empty(a: Actor) -> bool {
  give a.mailbox.len == 0
}

proc peek(a: Actor) -> string {
  if a.mailbox.len == 0 { give "" }
  give a.mailbox[0].payload
}

proc assign_message_identity(a: Actor, msg: ActorMessage) -> ActorMessage {
  let id = msg.message_id
  if id.len == 0 {
    id = "m-" + a.id.to_string() + "-" + a.next_message_seq.to_string()
  }
  let trace_id = msg.trace_id
  if trace_id.len == 0 {
    if a.last_trace_id.len > 0 {
      trace_id = a.last_trace_id
    } else {
      trace_id = "trace-" + a.id.to_string()
    }
  }
  let span_id = msg.span_id
  if span_id.len > 0 {
    span_id = span_id + "." + a.next_message_seq.to_string()
  } else {
    span_id = "span-" + a.id.to_string() + "-" + a.next_message_seq.to_string()
  }
  give ActorMessage(id, msg.kind, msg.payload, trace_id, span_id, a.tick, msg.priority)
}

proc mark_ask_completed(asks: [AskRecord], message_id: string) -> AskCompleteResult {
  let out: [AskRecord] = []
  let completed = 0
  let i: int = 0
  loop {
    if i >= asks.len { break }
    let rec = asks[i]
    if !rec.completed && !rec.canceled && !rec.timed_out && rec.message_id == message_id {
      out = out.push(AskRecord(rec.request_id, rec.message_id, rec.deadline_tick, rec.canceled, true, rec.timed_out))
      completed = completed + 1
    } else {
      out = out.push(rec)
    }
    i = i + 1
  }
  give AskCompleteResult(out, completed)
}

proc sweep_asks(asks: [AskRecord], tick: int) -> AskSweepResult {
  let out: [AskRecord] = []
  let timed_out: [string] = []
  let i: int = 0
  loop {
    if i >= asks.len { break }
    let rec = asks[i]
    if !rec.completed && !rec.canceled && !rec.timed_out && tick >= rec.deadline_tick {
      out = out.push(AskRecord(rec.request_id, rec.message_id, rec.deadline_tick, rec.canceled, rec.completed, true))
      timed_out = timed_out.push(rec.message_id)
    } else {
      out = out.push(rec)
    }
    i = i + 1
  }
  give AskSweepResult(out, timed_out)
}

proc ask(a: Actor, request_id: string, message: ActorMessage, timeout_ticks: int) -> Actor {
  let timeout = timeout_ticks
  if timeout < 1 { timeout = 1 }
  let msg = assign_message_identity(a, message)
  let rec = AskRecord(request_id, msg.message_id, a.tick + timeout, false, false, false)
  give Actor(
    a.id, a.name, ActorState.Busy,
    a.mailbox.push(msg), a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, trim_recent(a.recent_message_ids.push(msg.message_id), a.dedup_window),
    a.scheduler_lane, a.tick, a.next_message_seq + 1,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks.push(rec), a.events.push("ask_open:" + request_id), a.snapshots, a.snapshot_interval
  )
}

proc cancel_ask(a: Actor, request_id: string) -> Actor {
  let out: [AskRecord] = []
  let changed = false
  let i: int = 0
  loop {
    if i >= a.asks.len { break }
    let rec = a.asks[i]
    if rec.request_id == request_id && !rec.completed && !rec.timed_out && !rec.canceled {
      out = out.push(AskRecord(rec.request_id, rec.message_id, rec.deadline_tick, true, rec.completed, rec.timed_out))
      changed = true
    } else {
      out = out.push(rec)
    }
    i = i + 1
  }
  let events = a.events
  if changed {
    events = events.push("ask_cancel:" + request_id)
  }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    out, events, a.snapshots, a.snapshot_interval
  )
}

proc ask_state(a: Actor, request_id: string) -> string {
  let i: int = 0
  loop {
    if i >= a.asks.len { break }
    let rec = a.asks[i]
    if rec.request_id == request_id {
      if rec.completed { give "completed" }
      if rec.timed_out { give "timed_out" }
      if rec.canceled { give "canceled" }
      give "pending"
    }
    i = i + 1
  }
  give "unknown"
}

proc configure_snapshot(a: Actor, interval: int) -> Actor {
  let iv = interval
  if iv < 1 { iv = 1 }
  give Actor(
    a.id, a.name, a.state,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, iv
  )
}

proc starts_with(text: string, prefix: string) -> bool {
  if prefix.len > text.len { give false }
  let i: int = 0
  loop {
    if i >= prefix.len { break }
    if text[i] != prefix[i] { give false }
    i = i + 1
  }
  give true
}

proc hash_text(text: string) -> int {
  let h = 0
  let i: int = 0
  loop {
    if i >= text.len { break }
    h = h + text[i].to_int()
    i = i + 1
  }
  if h < 0 { h = -h }
  give h
}

proc replace_actor_at(workers: [Actor], idx: int, next: Actor) -> [Actor] {
  let out: [Actor] = []
  let i: int = 0
  loop {
    if i >= workers.len { break }
    if i == idx {
      out = out.push(next)
    } else {
      out = out.push(workers[i])
    }
    i = i + 1
  }
  give out
}

proc remove_last_actor(workers: [Actor]) -> [Actor] {
  if workers.len == 0 { give workers }
  let out: [Actor] = []
  let i: int = 0
  loop {
    if i >= workers.len - 1 { break }
    out = out.push(workers[i])
    i = i + 1
  }
  give out
}

proc sticky_find(sticky: [RouteBinding], key: string) -> int {
  let i: int = 0
  loop {
    if i >= sticky.len { break }
    if sticky[i].key == key { give sticky[i].shard_index }
    i = i + 1
  }
  give -1
}

proc sticky_set(sticky: [RouteBinding], key: string, shard_index: int) -> [RouteBinding] {
  let out: [RouteBinding] = []
  let found = false
  let i: int = 0
  loop {
    if i >= sticky.len { break }
    let b = sticky[i]
    if b.key == key {
      out = out.push(RouteBinding(key, shard_index))
      found = true
    } else {
      out = out.push(b)
    }
    i = i + 1
  }
  if !found {
    out = out.push(RouteBinding(key, shard_index))
  }
  give out
}

proc total_backlog(workers: [Actor]) -> int {
  let total = 0
  let i: int = 0
  loop {
    if i >= workers.len { break }
    total = total + workers[i].mailbox.len
    i = i + 1
  }
  give total
}

proc router_new(
  name: string,
  min_workers: int,
  max_workers: int,
  scale_up_backlog: int,
  scale_down_backlog: int,
  semantics: DeliverySemantics,
  retry_limit: int
) -> ActorRouter {
  let minw = min_workers
  let maxw = max_workers
  let up = scale_up_backlog
  let down = scale_down_backlog
  let retry = retry_limit
  if minw < 1 { minw = 1 }
  if maxw < minw { maxw = minw }
  if up < 1 { up = 1 }
  if down < 0 { down = 0 }
  if retry < 0 { retry = 0 }

  let workers: [Actor] = []
  let i: int = 0
  loop {
    if i >= minw { break }
    workers = workers.push(spawn(i + 1, name + "-w" + i.to_string()))
    i = i + 1
  }

  give ActorRouter(name, workers, [], minw, maxw, up, down, semantics, retry, minw + 1, [], [], [])
}

proc router_pick_index(r: ActorRouter, key: string) -> int {
  let existing = sticky_find(r.sticky, key)
  if existing >= 0 && existing < r.workers.len { give existing }
  if r.workers.len == 0 { give 0 }
  give hash_text(key) % r.workers.len
}

proc router_scale(r: ActorRouter) -> ActorRouter {
  let backlog = total_backlog(r.workers)
  let workers = r.workers
  let next_id = r.next_worker_id

  if backlog > r.scale_up_backlog && workers.len < r.max_workers {
    workers = workers.push(spawn(next_id, r.name + "-w" + next_id.to_string()))
    next_id = next_id + 1
  }
  if backlog <= r.scale_down_backlog && workers.len > r.min_workers {
    workers = remove_last_actor(workers)
  }

  give ActorRouter(
    r.name,
    workers,
    r.sticky,
    r.min_workers,
    r.max_workers,
    r.scale_up_backlog,
    r.scale_down_backlog,
    r.semantics,
    r.retry_limit,
    next_id,
    r.tenant_limits,
    r.tenant_counters,
    r.auth_rules
  )
}

proc router_route(r: ActorRouter, tenant_id: string, entity_id: string, message: ActorMessage) -> ActorRouter {
  let key = tenant_id + "|" + entity_id
  let idx = router_pick_index(r, key)
  if r.workers.len == 0 { give r }
  let workers = r.workers
  let sticky = sticky_set(r.sticky, key, idx)
  let staged = ActorRouter(
    r.name, workers, sticky,
    r.min_workers, r.max_workers,
    r.scale_up_backlog, r.scale_down_backlog,
    r.semantics, r.retry_limit, r.next_worker_id,
    r.tenant_limits, r.tenant_counters, r.auth_rules
  )
  give router_scale(staged)
}

proc router_shard_for(r: ActorRouter, tenant_id: string, entity_id: string) -> int {
  let key = tenant_id + "|" + entity_id
  give router_pick_index(r, key)
}

proc router_worker_count(r: ActorRouter) -> int {
  give r.workers.len
}

proc family_new(parent: Actor, children: [Actor]) -> ActorFamily {
  give ActorFamily(parent, children)
}

proc family_sibling_unchanged(before: ActorFamily, after: ActorFamily, child_index: int) -> bool {
  if before.children.len != after.children.len { give false }
  if before.parent.failures != after.parent.failures { give false }
  let i: int = 0
  loop {
    if i >= before.children.len { break }
    if i != child_index {
      if before.children[i].failures != after.children[i].failures { give false }
      if before.children[i].mailbox.len != after.children[i].mailbox.len { give false }
    }
    i = i + 1
  }
  give true
}

proc counters_non_negative(a: Actor) -> bool {
  if a.processed < 0 { give false }
  if a.failures < 0 { give false }
  if a.restarts < 0 { give false }
  if a.dropped < 0 { give false }
  if a.rejected < 0 { give false }
  if a.dead_letters.len < 0 { give false }
  if a.mailbox.len < 0 { give false }
  give true
}

proc no_loss_invariant(a: Actor, injected: int) -> bool {
  if injected < 0 { give false }
  let accounted = a.processed + a.mailbox.len + a.dropped + a.rejected + a.dead_letters.len
  give accounted >= injected
}

proc send(a: Actor, message: ActorMessage) -> Actor {
  let msg = assign_message_identity(a, message)

  if contains_text(a.recent_message_ids, msg.message_id) {
    give a
  }

  when a.state is ActorState.Stopped {
    let stopped = with_dead_letter(a, msg, "stopped")
    give run_hook(stopped, LifecycleHook.OnError)
  }

  if a.circuit_state == CircuitState.Open && a.tick < a.circuit_open_until {
    let blocked = with_dead_letter(a, msg, "circuit_open")
    give run_hook(blocked, LifecycleHook.OnError)
  }

  let recent = trim_recent(a.recent_message_ids.push(msg.message_id), a.dedup_window)
  let events = a.events.push("send:" + msg.message_id)

  if a.mailbox.len >= a.mailbox_capacity {

    when a.mailbox_policy is MailboxPolicy.DropNewest {
      let dropped_actor = Actor(
        a.id, a.name, a.state,
        a.mailbox, a.mailbox_capacity, a.mailbox_policy,
        a.processed, a.failures, a.restarts, a.dropped + 1, a.rejected, a.dead_letters,
        a.supervision, a.restart_limit,
        a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
        a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
        a.dedup_window, recent,
        a.scheduler_lane, a.tick, a.next_message_seq + 1,
        a.hooks, a.hook_runs,
        a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
        a.asks, events.push("drop_newest:" + msg.message_id), a.snapshots, a.snapshot_interval
      )
      let with_dl = with_dead_letter(dropped_actor, msg, "drop_newest")
      give run_hook(with_dl, LifecycleHook.OnError)
    }

    when a.mailbox_policy is MailboxPolicy.Reject {
      let rejected_actor = Actor(
        a.id, a.name, a.state,
        a.mailbox, a.mailbox_capacity, a.mailbox_policy,
        a.processed, a.failures, a.restarts, a.dropped, a.rejected + 1, a.dead_letters,
        a.supervision, a.restart_limit,
        a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
        a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
        a.dedup_window, recent,
        a.scheduler_lane, a.tick, a.next_message_seq + 1,
        a.hooks, a.hook_runs,
        a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
        a.asks, events.push("reject:" + msg.message_id), a.snapshots, a.snapshot_interval
      )
      let with_dl = with_dead_letter(rejected_actor, msg, "reject")
      give run_hook(with_dl, LifecycleHook.OnError)
    }

    let trimmed = drop_first(a.mailbox)
    give Actor(
      a.id, a.name, ActorState.Busy,
      trimmed.push(msg), a.mailbox_capacity, a.mailbox_policy,
      a.processed, a.failures, a.restarts, a.dropped + 1, a.rejected, a.dead_letters,
      a.supervision, a.restart_limit,
      a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
      a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
      a.dedup_window, recent,
      a.scheduler_lane, a.tick, a.next_message_seq + 1,
      a.hooks, a.hook_runs,
      a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
      a.asks, events.push("drop_oldest:" + msg.message_id), a.snapshots, a.snapshot_interval
    )
  }

  give Actor(
    a.id, a.name, ActorState.Busy,
    a.mailbox.push(msg), a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, recent,
    a.scheduler_lane, a.tick, a.next_message_seq + 1,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, events, a.snapshots, a.snapshot_interval
  )
}

proc step(a: Actor) -> Actor {
  let tick = a.tick + 1
  let sweep = sweep_asks(a.asks, tick)
  let dead = a.dead_letters
  let ei: int = 0
  loop {
    if ei >= sweep.timed_out_message_ids.len { break }
    let mid = sweep.timed_out_message_ids[ei]
    dead = dead.push(DeadLetter(ActorMessage(mid, "ask", "", a.last_trace_id, a.last_span_id, tick, MessagePriority.Normal), "ask_timeout"))
    ei = ei + 1
  }
  let base_events = a.events
  if sweep.timed_out_message_ids.len > 0 {
    base_events = base_events.push("ask_timeout")
  }

  if a.state == ActorState.Stopped && a.restart_ready_tick > 0 && tick >= a.restart_ready_tick {
    let resumed = Actor(
      a.id, a.name, ActorState.Idle,
      a.mailbox, a.mailbox_capacity, a.mailbox_policy,
      a.processed, a.failures, a.restarts, a.dropped, a.rejected, dead,
      a.supervision, a.restart_limit,
      a.backoff_base, a.backoff_max, a.backoff_jitter, 0,
      a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
      a.dedup_window, a.recent_message_ids,
      a.scheduler_lane, tick, a.next_message_seq,
      a.hooks, a.hook_runs,
      a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
      sweep.asks, base_events.push("restart_ready"), a.snapshots, a.snapshot_interval
    )
    give run_hook(resumed, LifecycleHook.OnRestart)
  }

  when a.state is ActorState.Stopped {
    give Actor(
      a.id, a.name, a.state,
      a.mailbox, a.mailbox_capacity, a.mailbox_policy,
      a.processed, a.failures, a.restarts, a.dropped, a.rejected, dead,
      a.supervision, a.restart_limit,
      a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
      a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
      a.dedup_window, a.recent_message_ids,
      a.scheduler_lane, tick, a.next_message_seq,
      a.hooks, a.hook_runs,
      a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
      sweep.asks, base_events.push("step_stopped"), a.snapshots, a.snapshot_interval
    )
  }

  let cstate = a.circuit_state
  let cfail = a.circuit_failures
  if cstate == CircuitState.Open && tick >= a.circuit_open_until {
    cstate = CircuitState.HalfOpen
    cfail = 0
  }

  if cstate == CircuitState.Open {
    give Actor(
      a.id, a.name, a.state,
      a.mailbox, a.mailbox_capacity, a.mailbox_policy,
      a.processed, a.failures, a.restarts, a.dropped, a.rejected, dead,
      a.supervision, a.restart_limit,
      a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
      cstate, cfail, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
      a.dedup_window, a.recent_message_ids,
      a.scheduler_lane, tick, a.next_message_seq,
      a.hooks, a.hook_runs,
      a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
      sweep.asks, base_events.push("step_circuit_open"), a.snapshots, a.snapshot_interval
    )
  }

  if a.mailbox.len == 0 {
    let idle = Actor(
      a.id, a.name, ActorState.Idle,
      a.mailbox, a.mailbox_capacity, a.mailbox_policy,
      a.processed, a.failures, a.restarts, a.dropped, a.rejected, dead,
      a.supervision, a.restart_limit,
      a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
      cstate, cfail, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
      a.dedup_window, a.recent_message_ids,
      a.scheduler_lane, tick, a.next_message_seq,
      a.hooks, a.hook_runs,
      a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
      sweep.asks, base_events.push("step_idle"), a.snapshots, a.snapshot_interval
    )
    if idle.processed == 0 {
      give run_hook(idle, LifecycleHook.OnStart)
    }
    give idle
  }

  let pop = pop_by_fair_lane(a.mailbox, a.scheduler_lane)
  let next_state = ActorState.Busy
  if pop.mailbox.len == 0 {
    next_state = ActorState.Idle
  }
  let next_circuit = cstate
  if cstate == CircuitState.HalfOpen {
    next_circuit = CircuitState.Closed
  }
  let latency = tick - pop.message.enqueued_tick
  if latency < 0 { latency = 0 }
  let latency_max = a.latency_max
  if latency > latency_max { latency_max = latency }
  let completed = mark_ask_completed(sweep.asks, pop.message.message_id)
  let snapshots = a.snapshots
  if a.snapshot_interval > 0 {
    if tick % a.snapshot_interval == 0 {
      snapshots = snapshots.push("tick=" + tick.to_string() + ";processed=" + (a.processed + 1).to_string() + ";mailbox=" + pop.mailbox.len.to_string())
    }
  }

  give Actor(
    a.id, a.name, next_state,
    pop.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed + 1, a.failures, a.restarts, a.dropped, a.rejected, dead,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    next_circuit, cfail,
    a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    pop.next_lane, tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total + latency, latency_max, latency, pop.message.trace_id, pop.message.span_id,
    completed.asks, base_events.push("step_process:" + pop.message.message_id), snapshots, a.snapshot_interval
  )
}

proc fail(a: Actor) -> Actor {
  let cfail = a.circuit_failures + 1
  let cstate = a.circuit_state
  let open_until = a.circuit_open_until

  if cfail >= a.circuit_threshold {
    cstate = CircuitState.Open
    open_until = a.tick + a.circuit_cooldown
  }

  let failed = Actor(
    a.id, a.name, ActorState.Busy,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures + 1, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    cstate, cfail, a.circuit_threshold, a.circuit_cooldown, open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
  give run_hook(failed, LifecycleHook.OnError)
}

proc stop(a: Actor) -> Actor {
  let stopped = Actor(
    a.id, a.name, ActorState.Stopped,
    a.mailbox, a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
    a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
  give run_hook(stopped, LifecycleHook.OnStop)
}

proc restart(a: Actor) -> Actor {
  let delay = restart_backoff_ticks(a)
  let restarting = Actor(
    a.id, a.name, ActorState.Stopped,
    [], a.mailbox_capacity, a.mailbox_policy,
    a.processed, a.failures, a.restarts + 1, a.dropped, a.rejected, a.dead_letters,
    a.supervision, a.restart_limit,
    a.backoff_base, a.backoff_max, a.backoff_jitter, a.tick + delay,
    CircuitState.HalfOpen, 0, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
    a.dedup_window, a.recent_message_ids,
    a.scheduler_lane, a.tick, a.next_message_seq,
    a.hooks, a.hook_runs,
    a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
    a.asks, a.events, a.snapshots, a.snapshot_interval
  )
  give run_hook(restarting, LifecycleHook.OnRestart)
}

proc supervision_decision(a: Actor, max_failures: int) -> string {
  if a.failures > max_failures {
    when a.supervision is SupervisionStrategy.Resume {
      give "resume"
    }
    when a.supervision is SupervisionStrategy.Restart {
      if a.restarts >= a.restart_limit {
        give "stop"
      }
      give "restart"
    }
    when a.supervision is SupervisionStrategy.Stop {
      give "stop"
    }
    give "escalate"
  }

  if a.failures > 0 {
    when a.supervision is SupervisionStrategy.Resume {
      give "resume"
    }
    when a.supervision is SupervisionStrategy.Restart {
      give "restart"
    }
    when a.supervision is SupervisionStrategy.Stop {
      give "stop"
    }
    give "escalate"
  }

  give "ok"
}

proc apply_supervision(a: Actor, max_failures: int) -> Actor {
  let decision = supervision_decision(a, max_failures)
  if decision == "resume" {
    give Actor(
      a.id, a.name, ActorState.Idle,
      a.mailbox, a.mailbox_capacity, a.mailbox_policy,
      a.processed, a.failures, a.restarts, a.dropped, a.rejected, a.dead_letters,
      a.supervision, a.restart_limit,
      a.backoff_base, a.backoff_max, a.backoff_jitter, a.restart_ready_tick,
      a.circuit_state, a.circuit_failures, a.circuit_threshold, a.circuit_cooldown, a.circuit_open_until,
      a.dedup_window, a.recent_message_ids,
      a.scheduler_lane, a.tick, a.next_message_seq,
      a.hooks, a.hook_runs,
      a.latency_total, a.latency_max, a.last_latency, a.last_trace_id, a.last_span_id,
      a.asks, a.events, a.snapshots, a.snapshot_interval
    )
  }
  if decision == "restart" {
    give restart(a)
  }
  if decision == "stop" {
    give stop(a)
  }
  give stop(a)
}

proc processed_count(a: Actor) -> int {
  give a.processed
}

proc failure_count(a: Actor) -> int {
  give a.failures
}

proc dropped_count(a: Actor) -> int {
  give a.dropped
}

proc rejected_count(a: Actor) -> int {
  give a.rejected
}

proc dead_letter_count(a: Actor) -> int {
  give a.dead_letters.len
}

proc dead_letter_reason(a: Actor, index: int) -> string {
  if index < 0 || index >= a.dead_letters.len { give "" }
  give a.dead_letters[index].reason
}

proc dead_letter_payload(a: Actor, index: int) -> string {
  if index < 0 || index >= a.dead_letters.len { give "" }
  give a.dead_letters[index].message.payload
}

proc circuit_is_open(a: Actor) -> bool {
  give a.circuit_state == CircuitState.Open && a.tick < a.circuit_open_until
}

proc restart_backoff(a: Actor) -> int {
  give restart_backoff_ticks(a)
}

proc scheduler_lane(a: Actor) -> int {
  give a.scheduler_lane
}

proc hook_run_count(a: Actor) -> int {
  give a.hook_runs
}

proc queue_depth(a: Actor) -> int {
  give a.mailbox.len
}

proc max_message_age(a: Actor) -> int {
  let max_age = 0
  let i: int = 0
  loop {
    if i >= a.mailbox.len { break }
    let age = a.tick - a.mailbox[i].enqueued_tick
    if age > max_age { max_age = age }
    i = i + 1
  }
  give max_age
}

proc throughput(a: Actor) -> int {
  if a.tick <= 0 { give 0 }
  give (a.processed * 1000) / a.tick
}

proc processing_latency_last(a: Actor) -> int {
  give a.last_latency
}

proc processing_latency_max(a: Actor) -> int {
  give a.latency_max
}

proc processing_latency_avg(a: Actor) -> int {
  if a.processed <= 0 { give 0 }
  give a.latency_total / a.processed
}

proc trace_state(a: Actor) -> string {
  give a.last_trace_id + ":" + a.last_span_id
}

proc event_count(a: Actor) -> int {
  give a.events.len
}

proc event_at(a: Actor, index: int) -> string {
  if index < 0 || index >= a.events.len { give "" }
  give a.events[index]
}

proc snapshot_count(a: Actor) -> int {
  give a.snapshots.len
}

proc snapshot_at(a: Actor, index: int) -> string {
  if index < 0 || index >= a.snapshots.len { give "" }
  give a.snapshots[index]
}

proc replay_events(a: Actor, events: [string]) -> Actor {
  let out = a
  let i: int = 0
  loop {
    if i >= events.len { break }
    let e = events[i]
    if e == "step" {
      out = step(out)
    }
    if e == "fail" {
      out = fail(out)
    }
    if e == "restart" {
      out = restart(out)
    }
    if e == "stop" {
      out = stop(out)
    }
    if starts_with(e, "send:") {
      out = send(out, make_message("replay", e, "trace-replay"))
    }
    i = i + 1
  }
  give out
}

proc send_with_delivery(a: Actor, message: ActorMessage, semantics: DeliverySemantics, retry_limit: int) -> Actor {
  when semantics is DeliverySemantics.AtMostOnce {
    give send(a, message)
  }

  let out = send(a, message)
  if !starts_with(message.kind, "nack") {
    give out
  }

  let retries = 0
  loop {
    if retries >= retry_limit { break }
    out = send(out, message)
    retries = retries + 1
  }

  if retries >= retry_limit {
    give with_dead_letter(out, message, "nack_retry_exhausted")
  }
  give out
}

proc router_dispatch(r: ActorRouter, tenant_id: string, entity_id: string, message: ActorMessage) -> ActorRouter {
  if r.workers.len == 0 { give r }
  let planned = router_route(r, tenant_id, entity_id, message)
  let idx = router_shard_for(planned, tenant_id, entity_id)
  let target = planned.workers[idx]
  let updated = send_with_delivery(target, message, planned.semantics, planned.retry_limit)
  let staged = ActorRouter(
    planned.name,
    replace_actor_at(planned.workers, idx, updated),
    planned.sticky,
    planned.min_workers,
    planned.max_workers,
    planned.scale_up_backlog,
    planned.scale_down_backlog,
    planned.semantics,
    planned.retry_limit,
    planned.next_worker_id,
    planned.tenant_limits,
    planned.tenant_counters,
    planned.auth_rules
  )
  give router_scale(staged)
}

proc delivery_attempt(a: Actor, message: ActorMessage, status: AckNack, retries: int, retry_limit: int) -> Actor {
  when status is AckNack.Ack {
    give send(a, message)
  }
  if retries < retry_limit {
    give send(a, message)
  }
  give with_dead_letter(a, message, "nack_retry_exhausted")
}

proc family_fail_child_isolated(f: ActorFamily, child_index: int) -> ActorFamily {
  if child_index < 0 || child_index >= f.children.len { give f }
  let failed_child = fail(f.children[child_index])
  let children = replace_actor_at(f.children, child_index, failed_child)
  give ActorFamily(f.parent, children)
}

proc property_invariants(seed: int, rounds: int) -> InvariantReport {
  let total_rounds = rounds
  if total_rounds < 1 { total_rounds = 1 }
  let a = configure_mailbox(spawn(seed + 100, "prop"), 6, MailboxPolicy.DropNewest)
  let injected = 0
  let checks = 0
  let i: int = 0
  loop {
    if i >= total_rounds { break }
    let kind = "ok"
    if (i % 5) == 0 {
      kind = "nack"
    }
    let msg = make_message_with_id(
      "p-" + i.to_string(),
      kind,
      "payload-" + i.to_string(),
      "trace-prop"
    )
    let semantics = DeliverySemantics.AtMostOnce
    if (i % 3) == 0 {
      semantics = DeliverySemantics.AtLeastOnce
    }
    a = send_with_delivery(a, msg, semantics, 2)
    injected = injected + 1
    if (i % 2) == 0 {
      a = step(a)
    }
    checks = checks + 1
    i = i + 1
  }

  let ok = counters_non_negative(a) && no_loss_invariant(a, injected)
  give InvariantReport(ok, checks, injected)
}

proc close(a: Actor) -> Actor {
  give stop(a)
}

proc find_tenant_limit(limits: [TenantLimit], tenant_id: string) -> TenantLimit {
  let i: int = 0
  loop {
    if i >= limits.len { break }
    if limits[i].tenant_id == tenant_id { give limits[i] }
    i = i + 1
  }
  give TenantLimit(tenant_id, 64, 10_000, "")
}

proc upsert_tenant_counter(counters: [TenantCounter], tenant_id: string, sent_delta: int, denied_delta: int) -> [TenantCounter] {
  let out: [TenantCounter] = []
  let found = false
  let i: int = 0
  loop {
    if i >= counters.len { break }
    let c = counters[i]
    if c.tenant_id == tenant_id {
      out = out.push(TenantCounter(tenant_id, c.sent + sent_delta, c.denied + denied_delta))
      found = true
    } else {
      out = out.push(c)
    }
    i = i + 1
  }
  if !found {
    out = out.push(TenantCounter(tenant_id, sent_delta, denied_delta))
  }
  give out
}

proc auth_allowed(rules: [AuthRule], from_ns: string, to_ns: string) -> bool {
  let i: int = 0
  let found = false
  let allowed = false
  loop {
    if i >= rules.len { break }
    let rule = rules[i]
    if rule.from_ns == from_ns && rule.to_ns == to_ns {
      found = true
      allowed = rule.allow
    }
    i = i + 1
  }
  if !found { give true }
  give allowed
}

proc router_with_tenant_limit(r: ActorRouter, tenant_id: string, mailbox_quota: int, send_quota: int, namespace_prefix: string) -> ActorRouter {
  let mq = mailbox_quota
  let sq = send_quota
  if mq < 1 { mq = 1 }
  if sq < 1 { sq = 1 }
  let out: [TenantLimit] = []
  let found = false
  let i: int = 0
  loop {
    if i >= r.tenant_limits.len { break }
    let lim = r.tenant_limits[i]
    if lim.tenant_id == tenant_id {
      out = out.push(TenantLimit(tenant_id, mq, sq, namespace_prefix))
      found = true
    } else {
      out = out.push(lim)
    }
    i = i + 1
  }
  if !found {
    out = out.push(TenantLimit(tenant_id, mq, sq, namespace_prefix))
  }
  give ActorRouter(
    r.name, r.workers, r.sticky, r.min_workers, r.max_workers,
    r.scale_up_backlog, r.scale_down_backlog, r.semantics, r.retry_limit, r.next_worker_id,
    out, r.tenant_counters, r.auth_rules
  )
}

proc router_with_auth_rule(r: ActorRouter, from_ns: string, to_ns: string, allow: bool) -> ActorRouter {
  let out = r.auth_rules.push(AuthRule(from_ns, to_ns, allow))
  give ActorRouter(
    r.name, r.workers, r.sticky, r.min_workers, r.max_workers,
    r.scale_up_backlog, r.scale_down_backlog, r.semantics, r.retry_limit, r.next_worker_id,
    r.tenant_limits, r.tenant_counters, out
  )
}

proc router_dispatch_secure(
  r: ActorRouter,
  tenant_id: string,
  entity_id: string,
  from_ns: string,
  to_ns: string,
  message: ActorMessage
) -> ActorRouter {
  if r.workers.len == 0 { give r }
  let lim = find_tenant_limit(r.tenant_limits, tenant_id)
  let planned = router_route(r, tenant_id, entity_id, message)
  let idx = router_shard_for(planned, tenant_id, entity_id)
  let target = planned.workers[idx]
  let allowed = auth_allowed(planned.auth_rules, from_ns, to_ns)
  let ns_ok = true
  if lim.namespace_prefix.len > 0 && !starts_with(to_ns, lim.namespace_prefix) {
    ns_ok = false
  }
  if !allowed || !ns_ok || target.mailbox.len >= lim.mailbox_quota {
    let counters = upsert_tenant_counter(planned.tenant_counters, tenant_id, 0, 1)
    give ActorRouter(
      planned.name, planned.workers, planned.sticky, planned.min_workers, planned.max_workers,
      planned.scale_up_backlog, planned.scale_down_backlog, planned.semantics, planned.retry_limit, planned.next_worker_id,
      planned.tenant_limits, counters, planned.auth_rules
    )
  }
  let updated = send_with_delivery(target, message, planned.semantics, planned.retry_limit)
  let counters = upsert_tenant_counter(planned.tenant_counters, tenant_id, 1, 0)
  let staged = ActorRouter(
    planned.name,
    replace_actor_at(planned.workers, idx, updated),
    planned.sticky,
    planned.min_workers,
    planned.max_workers,
    planned.scale_up_backlog,
    planned.scale_down_backlog,
    planned.semantics,
    planned.retry_limit,
    planned.next_worker_id,
    planned.tenant_limits,
    counters,
    planned.auth_rules
  )
  give router_scale(staged)
}

proc tenant_denied_count(r: ActorRouter, tenant_id: string) -> int {
  let i: int = 0
  loop {
    if i >= r.tenant_counters.len { break }
    if r.tenant_counters[i].tenant_id == tenant_id { give r.tenant_counters[i].denied }
    i = i + 1
  }
  give 0
}

proc tenant_sent_count(r: ActorRouter, tenant_id: string) -> int {
  let i: int = 0
  loop {
    if i >= r.tenant_counters.len { break }
    if r.tenant_counters[i].tenant_id == tenant_id { give r.tenant_counters[i].sent }
    i = i + 1
  }
  give 0
}

proc actor_last_error(a: Actor) -> string {
  if a.dead_letters.len == 0 { give "" }
  give a.dead_letters[a.dead_letters.len - 1].reason
}

proc admin_list_actors(r: ActorRouter) -> [AdminActorInfo] {
  let out: [AdminActorInfo] = []
  let i: int = 0
  loop {
    if i >= r.workers.len { break }
    let w = r.workers[i]
    out = out.push(AdminActorInfo(w.name, w.mailbox.len, actor_last_error(w)))
    i = i + 1
  }
  give out
}

proc admin_mailbox_depth(r: ActorRouter, actor_name: string) -> int {
  let i: int = 0
  loop {
    if i >= r.workers.len { break }
    if r.workers[i].name == actor_name { give r.workers[i].mailbox.len }
    i = i + 1
  }
  give -1
}

proc admin_last_error(r: ActorRouter, actor_name: string) -> string {
  let i: int = 0
  loop {
    if i >= r.workers.len { break }
    if r.workers[i].name == actor_name { give actor_last_error(r.workers[i]) }
    i = i + 1
  }
  give ""
}

proc remove_at_int(values: [int], idx: int) -> [int] {
  let out: [int] = []
  let i: int = 0
  loop {
    if i >= values.len { break }
    if i != idx {
      out = out.push(values[i])
    }
    i = i + 1
  }
  give out
}

proc min_index_int(values: [int]) -> int {
  if values.len == 0 { give -1 }
  let best = 0
  let i: int = 1
  loop {
    if i >= values.len { break }
    if values[i] < values[best] {
      best = i
    }
    i = i + 1
  }
  give best
}

proc percentile_linear(values: [int], p: int) -> int {
  if values.len == 0 { give 0 }
  let remaining = values
  let sorted: [int] = []
  loop {
    if remaining.len == 0 { break }
    let idx_min = min_index_int(remaining)
    sorted = sorted.push(remaining[idx_min])
    remaining = remove_at_int(remaining, idx_min)
  }
  let idx = (p * (sorted.len - 1)) / 100
  give sorted[idx]
}

proc benchmark_suite(seed: int, rounds: int) -> BenchReport {
  let n = rounds
  if n < 3 { n = 3 }
  let a = spawn(seed + 200, "bench")
  let latencies: [int] = []
  let restart_cost = 0
  let supervision_cost = 0
  let i: int = 0
  loop {
    if i >= n { break }
    let msg = make_message_with_id("b-" + i.to_string(), "job", "payload", "trace-bench")
    a = send(a, msg)
    a = step(a)
    latencies = latencies.push(a.last_latency)
    if (i % 8) == 0 {
      let before = a.tick
      a = restart(a)
      a = step(a)
      restart_cost = restart_cost + (a.tick - before)
    }
    if (i % 6) == 0 {
      let before2 = a.tick
      a = fail(a)
      a = apply_supervision(a, 0)
      supervision_cost = supervision_cost + (a.tick - before2 + 1)
    }
    i = i + 1
  }
  give BenchReport(
    percentile_linear(latencies, 50),
    percentile_linear(latencies, 95),
    percentile_linear(latencies, 99),
    throughput(a),
    restart_cost,
    supervision_cost
  )
}

proc fuzz_runtime(seed: int, steps: int) -> FuzzReport {
  let n = steps
  if n < 1 { n = 1 }
  let a = spawn(seed + 300, "fuzz")
  let rnd = seed + 1
  let sends = 0
  let fails = 0
  let restarts = 0
  let closes = 0
  let i: int = 0
  loop {
    if i >= n { break }
    rnd = (rnd * 1103515245 + 12345) % 2147483647
    let op = rnd % 5
    if op == 0 {
      let msg = make_message_with_id("fz-" + i.to_string(), "job", "p", "trace-fz")
      a = send(a, msg)
      sends = sends + 1
    } else if op == 1 {
      a = fail(a)
      fails = fails + 1
    } else if op == 2 {
      a = restart(a)
      restarts = restarts + 1
    } else if op == 3 {
      a = close(a)
      closes = closes + 1
    } else {
      a = step(a)
    }
    if !counters_non_negative(a) { give FuzzReport(false, i + 1, sends, fails, restarts, closes) }
    i = i + 1
  }
  give FuzzReport(true, n, sends, fails, restarts, closes)
}

proc is_running(a: Actor) -> bool {
  when a.state is ActorState.Stopped {
    give false
  }
  give true
}

proc stats(a: Actor) -> string {
  give "id=" + a.id.to_string() +
       ";state=" + a.state.to_string() +
       ";mailbox=" + queue_depth(a).to_string() +
       ";mailbox_age_max=" + max_message_age(a).to_string() +
       ";processed=" + a.processed.to_string() +
       ";failures=" + a.failures.to_string() +
       ";latency_last=" + a.last_latency.to_string() +
       ";latency_max=" + a.latency_max.to_string() +
       ";throughput_kppm=" + throughput(a).to_string() +
       ";restarts=" + a.restarts.to_string() +
       ";dropped=" + a.dropped.to_string() +
       ";rejected=" + a.rejected.to_string() +
       ";dead_letters=" + a.dead_letters.len.to_string() +
       ";circuit=" + a.circuit_state.to_string() +
       ";lane=" + a.scheduler_lane.to_string() +
       ";hooks=" + a.hook_runs.to_string() +
       ";trace=" + a.last_trace_id +
       ";span=" + a.last_span_id
}

proc ready() -> bool {
  give true
}

proc actor_snapshot(a: Actor) -> string {

  give "Actor(" +
       a.name +
       ", state=" +
       a.state.to_string() +
       ", mailbox=" +
       a.mailbox.len.to_string() +
       ", processed=" +
       a.processed.to_string() +
       ", failures=" +
       a.failures.to_string() +
       ")"
}

proc api_version() -> string {
  give "2.4.0"
}

proc package_meta() -> string {
  give "vitte/actor"
}

