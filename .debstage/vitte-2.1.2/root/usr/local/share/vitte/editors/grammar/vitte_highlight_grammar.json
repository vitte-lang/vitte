{
  "schema_version": "1.0",
  "keywords": [
    "space", "pull", "use", "share", "const", "let", "make", "type", "form", "trait", "pick", "case",
    "proc", "entry", "at", "macro", "give", "emit", "asm", "unsafe", "if", "else", "otherwise",
    "loop", "for", "in", "break", "continue", "select", "when", "match", "return", "not", "and", "or", "is", "as"
  ],
  "decl_keywords": ["proc", "form", "pick", "trait", "entry"],
  "types": [
    "bool", "string", "int", "char", "i8", "i16", "i32", "i64", "isize", "u8", "u16", "u32", "u64", "usize", "f32", "f64"
  ],
  "builtins": ["true", "false", "null"],
  "todos": ["TODO", "FIXME", "NOTE", "XXX"],
  "strict_patterns": {
    "diag_code": "VITTE-[A-Z]+[0-9]{4}",
    "alias_pkg": "[A-Za-z_][A-Za-z0-9_]*_pkg",
    "contract_block_start": "<<< ROLE-CONTRACT",
    "api_prefixes": ["diagnostics_", "quickfix_", "doctor_"]
  },
  "number_regex": "\\b(0x[0-9A-Fa-f]+|0b[01]+|[0-9]+)\\b",
  "use_path_regex": "\\<use\\>\\s+([A-Za-z0-9_./]+)",
  "comments": {
    "line": "//",
    "block_start": "/*",
    "block_end": "*/",
    "zone_start": "<<<",
    "zone_end": ">>>"
  }
}
