{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "<<<", "close": ">>>" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "<<<", "close": ">>>" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(?:(?:entry|proc|form|trait|pick|match|select|if|else|otherwise|loop|for|when|case)\\b.*\\{\\s*|.*<<<\\s*)$",
    "decreaseIndentPattern": "^\\s*(?:\\}|>>>|case\\b|otherwise\\b)\\b.*$"
  },
  "wordPattern": "(-?\\d*\\.?\\d+)|(\\w+)",
  "onEnterRules": [
    {
      "beforeText": "^\\s*.*\\{\\s*$",
      "afterText": "^\\s*\\}.*$",
      "action": { "indentAction": "IndentOutdent" }
    },
    {
      "beforeText": "^\\s*.*<<<\\s*$",
      "afterText": "^\\s*>>>.*$",
      "action": { "indentAction": "IndentOutdent" }
    },
    {
      "beforeText": "^\\s*(proc|entry|match|select|if|else|otherwise|loop|for|when|case|trait|form|pick)\\b.*\\{\\s*$",
      "action": { "indentAction": "Indent" }
    },
    {
      "beforeText": "^\\s*.*<<<\\s*$",
      "action": { "indentAction": "Indent" }
    }
  ]
}
