{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vitte",
  "scopeName": "source.ts.vitte",
  "fileTypes": [
    "vit",
    "vitte",
    "vitl"
  ],
  "patterns": [
    { "include": "#shebang" },
    { "include": "#comments" },
    { "include": "#block_comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#bool" },
    { "include": "#attributes" },
    { "include": "#declarations" },
    { "include": "#ts_like_symbols" },
    { "include": "#dense_identifiers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#builtins" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#fallback_everything" }
  ],
  "repository": {
    "shebang": {
      "name": "comment.line.shebang.vitte",
      "match": "^(#!).*$"
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.vitte",
          "begin": "#",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.vitte" }
          },
          "patterns": [
            { "include": "#todo" }
          ]
        },
        {
          "name": "comment.line.double-slash.vitte",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.vitte" }
          },
          "patterns": [
            { "include": "#todo" }
          ]
        }
      ]
    },
    "block_comments": {
      "patterns": [
        {
          "name": "comment.block.zone.vitte",
          "begin": "<<<",
          "end": ">>>",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.vitte" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.vitte" }
          },
          "patterns": [
            { "include": "#todo" }
          ]
        },
        {
          "name": "comment.block.vitte",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.begin.vitte" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.comment.end.vitte" }
          },
          "patterns": [
            { "include": "#todo" }
          ]
        }
      ]
    },
    "todo": {
      "name": "keyword.other.todo.vitte",
      "match": "\\b(TODO|FIXME|NOTE|XXX|BUG|HACK)\\b"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.vitte",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.vitte" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.vitte" }
          }
        },
        {
          "name": "string.quoted.double.vitte",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.vitte" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.vitte" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.vitte",
              "match": "\\\\(?:[\"\\\\]|n|r|t|0)"
            }
          ]
        },
        {
          "name": "string.quoted.single.vitte",
          "begin": "'",
          "end": "'",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.vitte" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.vitte" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.vitte",
              "match": "\\\\(?:['\\\\]|n|r|t|0)"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.vitte",
          "match": "\\b-?0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.vitte",
          "match": "\\b-?0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.vitte",
          "match": "\\b-?\\d[\\d_]*\\.\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.integer.vitte",
          "match": "\\b-?\\d[\\d_]*(?:[A-Za-z]+)?\\b"
        }
      ]
    },
    "bool": {
      "patterns": [
        {
          "name": "constant.language.boolean.vitte",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.vitte",
          "begin": "#\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.annotation.begin.vitte" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.annotation.end.vitte" }
          },
          "patterns": [
            { "include": "#keywords" },
            { "include": "#types" },
            { "include": "#builtins" }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.space.declaration.vitte",
          "match": "\\b(space|module|mod)\\s+([.]*[A-Za-z_][\\w]*(?:\\s*(?:/|\\.)\\s*[A-Za-z_][\\w]*)*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.namespace.vitte" }
          }
        },
        {
          "name": "meta.pull.declaration.vitte",
          "match": "\\b(pull|import)\\s+([.]*[A-Za-z_][\\w]*(?:\\s*(?:/|\\.)\\s*[A-Za-z_][\\w]*)*)(?:\\s+(as)\\s+([A-Za-z_][\\w]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.namespace.vitte" },
            "3": { "name": "keyword.operator.word.vitte" },
            "4": { "name": "entity.name.namespace.vitte" }
          }
        },
        {
          "name": "meta.use.declaration.vitte",
          "match": "\\b(use)\\s+([.]*[A-Za-z_][\\w]*(?:\\s*(?:/|\\.)\\s*[A-Za-z_][\\w]*)*)(?:\\s+(as)\\s+([A-Za-z_][\\w]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.namespace.vitte" },
            "3": { "name": "keyword.operator.word.vitte" },
            "4": { "name": "entity.name.namespace.vitte" }
          }
        },
        {
          "name": "meta.export.declaration.vitte",
          "match": "\\b(export)\\s+(all|[A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.namespace.vitte" }
          }
        },
        {
          "name": "meta.share.declaration.vitte",
          "match": "\\b(share)\\s+([A-Za-z_][\\w]*)(?:\\s*,\\s*([A-Za-z_][\\w]*))*",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" },
            "3": { "name": "variable.other.readwrite.vitte" }
          }
        },
        {
          "name": "meta.type.alias.vitte",
          "match": "\\b(type|typedef)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.type.vitte" }
          }
        },
        {
          "name": "meta.form.declaration.vitte",
          "match": "\\b(form|struct|class|trait)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.type.vitte" }
          }
        },
        {
          "name": "meta.pick.declaration.vitte",
          "match": "\\b(pick|enum|union)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.type.vitte" }
          }
        },
        {
          "name": "meta.proc.declaration.vitte",
          "match": "\\b(proc|fn|scenario|scn|program|prog)\\s+([A-Za-z_][\\w]*(?:/[A-Za-z_][\\w]*)?)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.function.vitte" }
          }
        },
        {
          "name": "meta.macro.declaration.vitte",
          "match": "\\b(macro)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.function.vitte" }
          }
        },
        {
          "name": "meta.entry.declaration.vitte",
          "match": "\\b(entry)\\s+([A-Za-z_][\\w]*)\\s+(at)\\s+([.]*[A-Za-z_][\\w]*(?:\\s*(?:/|\\.)\\s*[A-Za-z_][\\w]*)*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "entity.name.function.vitte" },
            "3": { "name": "keyword.operator.word.vitte" },
            "4": { "name": "entity.name.namespace.vitte" }
          }
        },
        {
          "name": "meta.declaration.const.vitte",
          "match": "\\b(const)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "variable.other.constant.vitte" }
          }
        },
        {
          "name": "meta.declaration.let.vitte",
          "match": "\\b(let|make)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" }
          }
        },
        {
          "name": "meta.field.declaration.vitte",
          "match": "\\b(field|case)\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" }
          }
        },
        {
          "name": "meta.variant.declaration.vitte",
          "match": "^\\s*([A-Z][A-Za-z0-9_]*)(?=\\s*(?:$|=|\\{|\\())",
          "captures": {
            "1": { "name": "constant.other.vitte" }
          }
        }
      ]
    },
    "ts_like_symbols": {
      "patterns": [
        {
          "name": "meta.function-call.vitte",
          "match": "\\b([A-Za-z_][\\w]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.vitte" }
          }
        },
        {
          "name": "meta.qualified-function-call.vitte",
          "match": "\\b([A-Za-z_][\\w]*(?:[./][A-Za-z_][\\w]*)*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.vitte" }
          }
        },
        {
          "name": "meta.type.identifier.vitte",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.type.vitte" }
          }
        }
      ]
    },
    "dense_identifiers": {
      "patterns": [
        {
          "name": "meta.namespace.path.vitte",
          "match": "\\b([A-Za-z_][\\w]*)(?=(?:/|\\.|::)[A-Za-z_])",
          "captures": {
            "1": { "name": "entity.name.namespace.vitte" }
          }
        },
        {
          "name": "meta.constant.identifier.vitte",
          "match": "\\b([A-Z][A-Z0-9_]{2,})\\b",
          "captures": {
            "1": { "name": "constant.other.vitte" }
          }
        },
        {
          "name": "meta.parameter.identifier.vitte",
          "match": "(\\(|,)\\s*([A-Za-z_][\\w]*)(?=\\s*[:,)])",
          "captures": {
            "2": { "name": "variable.parameter.vitte" }
          }
        },
        {
          "name": "meta.property.access.vitte",
          "match": "\\.\\s*([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "variable.other.property.vitte" }
          }
        },
        {
          "name": "meta.variable.binding.vitte",
          "match": "\\b(let|make|keep|const|global|static)\\b\\s+(?:mut\\s+|move\\s+|ref\\s+)?([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" }
          }
        },
        {
          "name": "meta.variable.assignment.vitte",
          "match": "\\b(set)\\b\\s+([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.control.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" }
          }
        },
        {
          "name": "meta.variable.loop.vitte",
          "match": "\\b(for|each)\\b\\s+([A-Za-z_][\\w]*)\\s+\\b(in|from)\\b",
          "captures": {
            "1": { "name": "keyword.control.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" },
            "3": { "name": "keyword.control.vitte" }
          }
        },
        {
          "name": "meta.match.binding.vitte",
          "match": "\\b(case|when)\\b\\s+([a-z_][\\w]*)\\s*(?==>|\\{)",
          "captures": {
            "1": { "name": "keyword.declaration.vitte" },
            "2": { "name": "variable.other.readwrite.vitte" }
          }
        },
        {
          "name": "meta.variant.access.vitte",
          "match": "::\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "constant.other.vitte" }
          }
        },
        {
          "name": "meta.identifier.vitte",
          "match": "\\b(?!space\\b|module\\b|mod\\b|pull\\b|import\\b|use\\b|export\\b|share\\b|const\\b|let\\b|make\\b|type\\b|typedef\\b|form\\b|struct\\b|class\\b|trait\\b|pick\\b|enum\\b|union\\b|case\\b|proc\\b|fn\\b|entry\\b|program\\b|prog\\b|scenario\\b|scn\\b|macro\\b|field\\b|if\\b|else\\b|otherwise\\b|when\\b|select\\b|match\\b|loop\\b|for\\b|in\\b|from\\b|step\\b|break\\b|continue\\b|return\\b|ret\\b|unsafe\\b|give\\b|emit\\b|asm\\b|set\\b|do\\b|say\\b|not\\b|and\\b|or\\b|is\\b|as\\b|at\\b|all\\b|true\\b|false\\b|null\\b|bool\\b|string\\b|int\\b|char\\b|i8\\b|i16\\b|i32\\b|i64\\b|i128\\b|isize\\b|u8\\b|u16\\b|u32\\b|u64\\b|u128\\b|usize\\b|f32\\b|f64\\b|Float\\b|Str\\b|print\\b|println\\b|len\\b|size\\b|assert\\b|panic\\b|range\\b|map\\b|filter\\b|reduce\\b|open\\b|read\\b|write\\b|close\\b|slice\\b|as_bytes\\b|push\\b|pop\\b|clear\\b|iter\\b|await\\b)([a-z_][\\w]*)\\b",
          "captures": {
            "1": { "name": "variable.other.readwrite.vitte" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.vitte",
          "match": "\\b(?:space|module|mod|pull|import|use|export|share|const|let|make|type|typedef|form|struct|class|trait|pick|enum|union|case|proc|fn|entry|program|prog|scenario|scn|macro|field)\\b"
        },
        {
          "name": "keyword.control.vitte",
          "match": "\\b(?:if|else|otherwise|loop|for|in|from|step|break|continue|select|when|match|return|ret|unsafe|do|say)\\b"
        },
        {
          "name": "keyword.operator.word.vitte",
          "match": "\\b(?:not|and|or|is|as|at|all)\\b"
        },
        {
          "name": "keyword.control.vitte",
          "match": "\\b(?:give|emit|asm|set|await)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.builtin.vitte",
          "match": "\\b(?:bool|string|int|char|i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|Float|Str)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.vitte",
          "match": "\\b(?:print|println|len|size|assert|panic|range|map|filter|reduce|open|read|write|close|slice|as_bytes|push|pop|clear|iter)\\b"
        },
        {
          "name": "constant.language.boolean.vitte",
          "match": "\\bnull\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.symbol.vitte",
          "match": "\\|>|\\.\\.|\\.\\.=|::|=>|\\|\\||&&|==|!=|<=|>=|<<=|>>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<|>>|->|=|\\+|-|\\*|/|%|<|>|!|\\.|&|\\||\\^|~"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "keyword.other.end.vitte", "match": "\\b\\.end\\b" },
        { "name": "punctuation.terminator.statement.vitte", "match": ";" },
        { "name": "punctuation.separator.comma.vitte", "match": "," },
        { "name": "punctuation.separator.colon.vitte", "match": ":" },
        { "name": "punctuation.section.group.begin.vitte", "match": "\\(" },
        { "name": "punctuation.section.group.end.vitte", "match": "\\)" },
        { "name": "punctuation.section.brackets.begin.vitte", "match": "\\[" },
        { "name": "punctuation.section.brackets.end.vitte", "match": "\\]" },
        { "name": "punctuation.section.block.begin.vitte", "match": "\\{" },
        { "name": "punctuation.section.block.end.vitte", "match": "\\}" },
        { "name": "punctuation.accessor.dot.vitte", "match": "\\." }
      ]
    },
    "fallback_everything": {
      "patterns": [
        {
          "name": "entity.name.type.vitte",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "variable.other.readwrite.vitte",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
        },
        {
          "name": "keyword.operator.symbol.vitte",
          "match": "[=+\\-*/%<>!&|^~]+"
        },
        {
          "name": "punctuation.vitte",
          "match": "\\S"
        }
      ]
    }
  }
}
