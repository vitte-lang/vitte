{
  "schema": "vitte.competitive_benchmarks.targeted_cases",
  "schema_version": "1.0.0",
  "baselines": ["c", "rust", "zig"],
  "cases": [
    {
      "id": "cli_startup",
      "description": "minimal command startup and argument parsing",
      "metric": "median_ms"
    },
    {
      "id": "json_parse",
      "description": "small and medium JSON parsing throughput",
      "metric": "mb_per_sec"
    },
    {
      "id": "utf8_validate",
      "description": "UTF-8 validation over mixed ASCII and Unicode input",
      "metric": "mb_per_sec"
    },
    {
      "id": "hashmap_insert_get",
      "description": "hash map insert and lookup workload",
      "metric": "ops_per_sec"
    }
  ],
  "policy": {
    "publish_requires_methodology": true,
    "publish_requires_reproducible_inputs": true,
    "publish_requires_all_baselines": true
  }
}
