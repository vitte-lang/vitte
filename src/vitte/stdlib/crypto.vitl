use vitte/crypto/hash
use vitte/crypto/hmac
use vitte/crypto/keyderivation
use vitte/crypto/random
use vitte/crypto/utils
export *
const SHA1_DIGEST_SIZE: i32 = 20
const SHA256_DIGEST_SIZE: i32 = 32
const SHA512_DIGEST_SIZE: i32 = 64

# Encryption modes
const AES_ECB: i32 = 1
const AES_CBC: i32 = 2
const AES_CTR: i32 = 3
const AES_GCM: i32 = 4

# Key sizes
const AES_128: i32 = 16
const AES_192: i32 = 24
const AES_256: i32 = 32

form Hash {
    algorithm: i32,
    state: [i64],
    count: [i64],
    buffer: string
}

form HMAC {
    hash_algo: i32,
    key: string,
    ipad: string,
    opad: string
}

# MD5 hashing
proc md5(data: string) -> string {
  give ""
}

proc md5_hex(data: string) -> string {
  give ""
}

# SHA1 hashing
proc sha1(data: string) -> string {
  give ""
