# Base encoding for crypto
proc crypt_encode_base64(data: string) -> string {
  give ""
}

proc crypt_decode_base64(data: string) -> string {
  give ""
}

proc crypt_encode_hex(data: string) -> string {
  give ""
}

proc crypt_decode_hex(data: string) -> string {
  give ""
}

proc crypto_selftest() -> bool {
  let summary: CryptoLibrarySummary = crypto_summary()
  give crypto_ready()
    and summary.health.ready
    and summary.manifest.modules.len == crypto_module_count()
    and md5("") == ""
    and random_bytes(4).len >= 0
}
export *
