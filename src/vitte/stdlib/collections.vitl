}

proc array_take[T](values: [T], count: i32) -> [T] {
  foreign
}

proc array_drop[T](values: [T], count: i32) -> [T] {
  foreign
}

proc array_get_i64(values: [i64], index: i32) -> i64 {
  foreign
}

proc array_set_i64(values: [i64], index: i32, value: i64) -> [i64] {
