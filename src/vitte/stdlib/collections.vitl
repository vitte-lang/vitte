test "collections vector push and sum" {
  let mut v: Vector[i64] = vector_new[i64]()
  v = vector_push(v, 10)
  v = vector_push(v, 20)
  v = vector_push(v, 30)

  assert vector_len(v) == 3
  assert vector_sum_i64(v) == 60
}

test "collections vector sort and search" {
  let v: Vector[i64] = vector_from_array([5, 1, 4, 2, 3])
  let sorted: Vector[i64] = vector_sort_i64(v)

  assert vector_binary_search_i64(sorted, 4) == 3
}

test "collections stack" {
  let mut s: Stack[i64] = stack_new[i64](8)
  s = stack_push(s, 1)
  s = stack_push(s, 2)

  let top: OptionI64 = stack_peek_i64(s)
  assert top.ok
  assert top.value == 2
}

test "collections hashmap" {
  let mut m: HashMap[i64] = hashmap_new[i64](8)
  m = hashmap_insert(m, "one", 1)
  m = hashmap_insert(m, "two", 2)

  assert hashmap_contains(m, "one")
  assert hashmap_size(m) == 2
}

test "collections hashset" {
  let mut s: HashSet = hashset_new()
  s = hashset_insert(s, "alpha")
  s = hashset_insert(s, "beta")

  assert hashset_contains(s, "alpha")
  assert hashset_size(s) == 2
}

test "collections range" {
  let values: [i32] = range3(0, 10, 2)
  assert array_len(values) == 5
}
