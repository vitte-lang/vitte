space vitte/stdlib/benchmarks/index

const STDLIB_BENCHMARKS_INDEX: string = "benchmarks"

use src/vitte/stdlib/benchmarks/modules/vec_bench as vec_bench
use src/vitte/stdlib/benchmarks/modules/string_bench as string_bench
use src/vitte/stdlib/benchmarks/modules/hashmap_bench as hashmap_bench
use src/vitte/stdlib/benchmarks/modules/utf8_bench as utf8_bench
use src/vitte/stdlib/benchmarks/modules/path_bench as path_bench
use src/vitte/stdlib/benchmarks/modules/format_bench as format_bench
use src/vitte/stdlib/benchmarks/modules/parse_bench as parse_bench

proc stdlib_benchmarks_smoke() -> bool {
    give vec_bench.bench_vec_push_pop(8) >= 8
        and string_bench.bench_string_push_concat(8) >= 8
        and hashmap_bench.bench_hashmap_insert_get(8) == 8
        and utf8_bench.bench_utf8_validate_decode(8) == 8
        and path_bench.bench_path_normalize_join(8) == 8
        and format_bench.bench_format_ints(8) > 0
        and parse_bench.bench_parse_numbers(8) == 8;
}
