use src/vitte/stdlib/core/string as core_string
use src/vitte/stdlib/std/parse as std_parse

proc bench_parse_numbers(iterations: usize) -> usize {
    let parsed: usize = 0;
    let index: usize = 0;
    while index < iterations {
        let value = std_parse.parse_i64(core_string.utf8_view("123456"), 10);
        if is_ok<i64, std_parse.ParseError>(value) {
            set parsed = parsed + 1;
        }
        set index = index + 1;
    }
    give parsed;
}
