use src/vitte/stdlib/alloc/string as alloc_string

proc bench_string_push_concat(iterations: usize) -> usize {
    let text: alloc_string.String = alloc_string.string_new();
    alloc_string.string_reserve(&mut text, iterations);

    let index: usize = 0;
    while index < iterations {
        alloc_string.string_push(&mut text, 65);
        set index = index + 1;
    }

    let joined: alloc_string.String = alloc_string.string_concat(text, "done");
    give alloc_string.string_len(joined);
}
