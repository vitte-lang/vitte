use src/vitte/stdlib/alloc/vec as alloc_vec

proc bench_vec_push_pop(iterations: usize) -> usize {
    let values: alloc_vec.Vec<int> = alloc_vec.vec_with_capacity<int>(iterations);
    let index: usize = 0;
    while index < iterations {
        alloc_vec.vec_push<int>(&mut values, index as int);
        set index = index + 1;
    }

    while alloc_vec.vec_len<int>(values) > 0 {
        let _ = alloc_vec.vec_pop<int>(&mut values);
    }

    give alloc_vec.vec_capacity<int>(values);
}
