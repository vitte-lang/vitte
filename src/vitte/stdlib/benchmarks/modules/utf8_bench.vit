use src/vitte/stdlib/core/string as core_string
use src/vitte/stdlib/encoding/utf8 as encoding_utf8

proc bench_utf8_validate_decode(iterations: usize) -> usize {
    let bytes: [int] = [86, 105, 116, 116, 101, 32, 195, 169];
    let valid: usize = 0;
    let index: usize = 0;
    while index < iterations {
        if encoding_utf8.is_valid_utf8(bytes) and core_string.validate_utf8([86, 105, 116, 116, 101]) {
            let _ = encoding_utf8.decode_utf8(bytes);
            set valid = valid + 1;
        }
        set index = index + 1;
    }
    give valid;
}
