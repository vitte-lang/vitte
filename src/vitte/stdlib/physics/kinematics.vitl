space vitte/stdlib/physics/kinematics

proc velocity(distance: f64, time: f64) -> f64 {
  if time == 0.0 { give 0.0 }
  give distance / time
}

proc acceleration(velocity_change: f64, time: f64) -> f64 {
  if time == 0.0 { give 0.0 }
  give velocity_change / time
}

proc position(start: f64, velocity: f64, time: f64) -> f64 {
  give start + velocity * time
}
