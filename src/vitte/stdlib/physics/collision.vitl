space vitte/stdlib/physics/collision

proc detect_circle_collision(x1: f64, y1: f64, r1: f64, x2: f64, y2: f64, r2: f64) -> bool {
  let dx = x2 - x1
  let dy = y2 - y1
  give dx * dx + dy * dy <= (r1 + r2) * (r1 + r2)
}

proc bounce(velocity: f64, restitution: f64) -> f64 {
  give -velocity * restitution
}
