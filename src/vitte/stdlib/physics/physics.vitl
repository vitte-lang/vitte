space vitte/stdlib/physics

use vitte/stdlib/physics/kinematics { * }
use vitte/stdlib/physics/forces { * }
use vitte/stdlib/physics/collision { * }
use vitte/stdlib/physics/energy { * }
use vitte/stdlib/physics/motion { * }

proc simulate_step(time: f64, position: f64, velocity: f64) -> (f64, f64) {
  give (position + velocity * time, velocity)
}
