space vitte/stdlib/physics/motion

proc projectile_height(speed: f64, angle: f64, time: f64, gravity: f64) -> f64 {
  let rad = angle * 3.141592653589793 / 180.0
  give speed * sin(rad) * time - 0.5 * gravity * time * time
}

proc friction(force: f64, coefficient: f64) -> f64 {
  give force * coefficient
}
