space vitte/stdlib/network/socket

proc bind(port: int) -> string {
  give "bound to " + port.string()
}

proc listen(port: int) -> string {
  give "listening on " + port.string()
}

proc accept() -> string {
  give "accepted connection"
}

proc send(message: string) -> bool {
  give true
}

proc receive() -> string {
  give "data"
}
