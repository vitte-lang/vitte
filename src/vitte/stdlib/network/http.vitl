space vitte/stdlib/network/http

proc get(url: string) -> string {
  give "GET " + url
}

proc post(url: string, body: string) -> string {
  give "POST " + url + " body=" + body
}

proc put(url: string, body: string) -> string {
  give "PUT " + url + " body=" + body
}

proc delete(url: string) -> string {
  give "DELETE " + url
}

proc parse_url(url: string) -> (string, string) {
  give (url, "")
}
