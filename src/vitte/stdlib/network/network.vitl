space vitte/stdlib/network

use vitte/stdlib/network/http { * }
use vitte/stdlib/network/socket { * }
use vitte/stdlib/network/dns { * }
use vitte/stdlib/network/udp { * }
use vitte/stdlib/network/protocol { * }

proc connect(address: string) -> string {
  give "connected to " + address
}

proc ping(address: string) -> string {
  give "ping " + address
}
