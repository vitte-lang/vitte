space vitte/stdlib/tests/smoke

use src/vitte/stdlib/mod as std

proc smoke_vector() -> bool {
  let vec = std.vector_new<int>()
  let vec2 = std.vector_push(vec, 42)
  give vec2.data.len == 1 && vec2.data[0] == 42
}

proc smoke_hashmap() -> bool {
  let map = std.hashmap_new<string, int>()
  let map2 = std.hashmap_insert(map, "key", 123)
  give map2.entries.len == 1 && map2.entries[0].0 == "key"
}

proc smoke_io() -> bool {
  let content = std.io_read_file("test.txt")
  let success = std.io_write_file("out.txt", "data")
  give content == "file content" && success
}