use src/vitte/stdlib/compression/stats as compression_stats

use src/vitte/stdlib/async as async_root
use src/vitte/stdlib/async/channel as async_channel
use src/vitte/stdlib/async/executor as async_executor
use src/vitte/stdlib/async/future as async_future

