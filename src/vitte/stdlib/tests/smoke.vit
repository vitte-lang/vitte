use src/vitte/stdlib/crypto/hash as crypto_hash
use src/vitte/stdlib/crypto/hmac as crypto_hmac
use src/vitte/stdlib/crypto/keyderivation as crypto_keyderivation
use src/vitte/stdlib/crypto/random as crypto_random
use src/vitte/stdlib/crypto/utils as crypto_utils

use src/vitte/stdlib/json as json
use src/vitte/stdlib/json/builder as json_builder
use src/vitte/stdlib/json/parse as json_parse
use src/vitte/stdlib/json/parser as json_parser
use src/vitte/stdlib/json/schema as json_schema
use src/vitte/stdlib/json/serialize as json_serialize
use src/vitte/stdlib/json/stringify as json_stringify
use src/vitte/stdlib/json/types as json_types

use src/vitte/stdlib/path as path
use src/vitte/stdlib/path/globbing as path_globbing
use src/vitte/stdlib/path/manipulation as path_manipulation
use src/vitte/stdlib/path/special as path_special
use src/vitte/stdlib/path/walker as path_walker

use src/vitte/stdlib/strings as strings
use src/vitte/stdlib/regex as regex
use src/vitte/stdlib/runtime as runtime
use src/vitte/stdlib/sysinfo as sysinfo
use src/vitte/stdlib/datetime as datetime
use src/vitte/stdlib/os as os
use src/vitte/stdlib/memory as memory
use src/vitte/stdlib/math as math
use src/vitte/stdlib/math/algebra as math_algebra
use src/vitte/stdlib/math/arithmetic as math_arithmetic
use src/vitte/stdlib/math/arrays as math_arrays
use src/vitte/stdlib/math/calculus as math_calculus
use src/vitte/stdlib/math/comparison as math_comparison
use src/vitte/stdlib/math/complex as math_complex
use src/vitte/stdlib/math/geometry as math_geometry
use src/vitte/stdlib/math/logic as math_logic
use src/vitte/stdlib/math/matrix as math_matrix
use src/vitte/stdlib/math/modular as math_modular
use src/vitte/stdlib/math/number_theory as math_number_theory
use src/vitte/stdlib/math/powers as math_powers
use src/vitte/stdlib/math/probability as math_probability
use src/vitte/stdlib/math/roots as math_roots
use src/vitte/stdlib/math/sequences as math_sequences
use src/vitte/stdlib/math/sort as math_sort
use src/vitte/stdlib/math/statistics as math_statistics
use src/vitte/stdlib/math/topology as math_topology
use src/vitte/stdlib/math/trigonometry as math_trigonometry
use src/vitte/stdlib/math/vector as math_vector

use src/vitte/stdlib/statistics/descriptive as statistics_descriptive
use src/vitte/stdlib/statistics/distributions as statistics_distributions
use src/vitte/stdlib/statistics/datasets as statistics_datasets
use src/vitte/stdlib/statistics/hypothesis as statistics_hypothesis
use src/vitte/stdlib/statistics/machine_learning as statistics_machine_learning
use src/vitte/stdlib/statistics/preprocessing as statistics_preprocessing
use src/vitte/stdlib/statistics/sampling as statistics_sampling
use src/vitte/stdlib/statistics/statistics as statistics_root
use src/vitte/stdlib/statistics/time_series as statistics_time_series
use src/vitte/stdlib/statistics/utils as statistics_utils
use src/vitte/stdlib/statistics/visualization as statistics_visualization

proc stdlib_smoke_core() -> bool {
  give core.core_selftest()
    and core_algorithms.algorithms_selftest()
    and core_concurrency.concurrency_selftest()
    and core_io_helpers.io_helpers_selftest()
    and core_memory.memory_selftest()
    and core_panic.panic_selftest()
    and core_types.types_selftest()
    and core_utils.utils_selftest()
}

proc stdlib_smoke_io() -> bool {
  give io.io_selftest()
    and io_buffer.buffer_selftest() == 0
    and io_file.file_selftest() == 0
    and io_fileops.fileops_selftest()
    and io_stdio.stdio_selftest() == 0
    and io_stream.stream_selftest() == 0
}

proc stdlib_smoke_compression() -> bool {
  give compression.compression_selftest()
    and compression_algorithms.compression_algorithms_selftest()
    and compression_brotli.brotli_selftest()
    and compression_deflate.deflate_selftest()
    and compression_huffman.huffman_selftest()
    and compression_interface.compression_interface_selftest()
    and compression_lz.lz_selftest()
    and compression_stats.compression_stats_selftest()
}

proc stdlib_smoke_async() -> bool {
  give async_root.async_selftest()
    and async_channel.channel_selftest()
    and async_executor.executor_selftest()
    and async_future.future_selftest()
}

proc stdlib_smoke_crypto() -> bool {
  give crypto.crypto_selftest()
    and crypto_hash.hash_selftest()
    and crypto_hmac.hmac_selftest() == 0
    and crypto_keyderivation.keyderivation_selftest()
    and crypto_random.random_selftest()
    and crypto_utils.crypto_utils_selftest()
}

proc stdlib_smoke_json() -> bool {
  give json.json_selftest()
    and json_builder.json_builder_selftest()
    and json_parse.json_parse_selftest()
    and json_parser.json_parser_selftest() == 0
    and json_schema.schema_selftest()
    and json_serialize.json_serialize_selftest() == 0
    and json_stringify.json_stringify_selftest()
    and json_types.json_types_selftest()
}

proc stdlib_smoke_path() -> bool {
  give path.path_selftest()
    and path_globbing.globbing_selftest()
    and path_manipulation.path_selftest()
    and path_special.special_selftest()
    and path_walker.walker_selftest()
}

proc stdlib_smoke_system() -> bool {
  give strings.strings_selftest()
    and regex.regex_selftest()
    and runtime.runtime_selftest()
    and sysinfo.sysinfo_selftest()
    and datetime.datetime_selftest() == 0
    and os.os_selftest() == 0
    and memory.memory_selftest() == 0
    and math_algebra.algebra_selftest()
    and math_arithmetic.arithmetic_selftest()
    and math_arrays.arrays_selftest()
    and math_calculus.calculus_selftest()
    and math_comparison.comparison_selftest()
    and math_complex.complex_selftest()
    and math_geometry.geometry_selftest()
    and math_logic.logic_selftest()
    and math_matrix.matrix_selftest()
    and math_modular.modular_selftest()
    and math_number_theory.number_theory_selftest()
    and math_powers.powers_selftest()
    and math_probability.probability_selftest()
    and math_roots.roots_selftest()
    and math_sequences.sequences_selftest()
    and math_sort.sort_selftest()
    and math_statistics.statistics_selftest()
    and math_topology.topology_selftest()
    and math_trigonometry.trigonometry_selftest()
    and math_vector.vector_selftest()
    and math.math_selftest() == 0
}

proc stdlib_smoke_statistics() -> bool {
  give statistics_descriptive.descriptive_selftest()
    and statistics_distributions.distributions_selftest()
    and statistics_datasets.datasets_selftest() == 0
    and statistics_hypothesis.hypothesis_selftest()
    and statistics_machine_learning.machine_learning_selftest() == 0
    and statistics_preprocessing.preprocessing_selftest()
    and statistics_sampling.sampling_selftest()
    and statistics_root.statistics_selftest() == 0
    and statistics_time_series.time_series_selftest()
    and statistics_utils.utils_selftest() == 0
    and statistics_visualization.visualization_selftest()
}
