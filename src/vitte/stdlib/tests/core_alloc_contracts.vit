use src/vitte/stdlib/core/iterator as core_iterator
use src/vitte/stdlib/core/slice as core_slice
use src/vitte/stdlib/alloc/vec as alloc_vec
use src/vitte/stdlib/alloc/string as alloc_string

proc stdlib_core_alloc_contracts_smoke() -> bool {
    let vec: alloc_vec.Vec<int> = alloc_vec.vec_new<int>();
    alloc_vec.vec_push<int>(&mut vec, 1);
    alloc_vec.vec_push<int>(&mut vec, 2);

    let owned: alloc_string.String = alloc_string.string_new();
    alloc_string.string_push(&mut owned, 65);

    give alloc_vec.vec_len<int>(vec) == 2
        and alloc_string.string_len(owned) > 0;
}
