use src/vitte/stdlib/std/time as std_time
use src/vitte/stdlib/platform/abi as platform_abi

proc stdlib_api_contracts_smoke() -> bool {
    let duration: std_time.Duration = std_time.duration_from_secs(1);
    give std_time.duration_as_nanos(duration) == 1000000000
        and platform_abi.supports_filesystem() == platform_abi.supports_filesystem();
}
