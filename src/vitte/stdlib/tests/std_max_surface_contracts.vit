space vitte/stdlib/tests/std_max_surface_contracts

const STD_MAX_SURFACE_MODULE_COUNT: usize = 12
const STD_MAX_SURFACE_SYMBOL_COUNT: usize = 123
const STD_MAX_MIN_SOURCE_LINES: usize = 30
const STD_MAX_MIN_PUBLIC_PROCS: usize = 10
const STD_MAX_MIN_NATIVE_PROCS: usize = 8

const STD_MAX_ALGORITHM: string = "src/vitte/stdlib/std/algorithm.vitl"
const STD_MAX_NUMERIC: string = "src/vitte/stdlib/std/numeric.vitl"
const STD_MAX_MEMORY: string = "src/vitte/stdlib/std/memory.vitl"
const STD_MAX_ITERATOR: string = "src/vitte/stdlib/std/iterator.vitl"
const STD_MAX_UTILITY: string = "src/vitte/stdlib/std/utility.vitl"
const STD_MAX_FUNCTIONAL: string = "src/vitte/stdlib/std/functional.vitl"
const STD_MAX_TUPLE: string = "src/vitte/stdlib/std/tuple.vitl"
const STD_MAX_OPTIONAL: string = "src/vitte/stdlib/std/optional.vitl"
const STD_MAX_VARIANT: string = "src/vitte/stdlib/std/variant.vitl"
const STD_MAX_EXPECTED: string = "src/vitte/stdlib/std/expected.vitl"
const STD_MAX_SPAN: string = "src/vitte/stdlib/std/span.vitl"
const STD_MAX_STRING_VIEW: string = "src/vitte/stdlib/std/string_view.vitl"

proc std_max_surface_modules_present() -> bool {
    give STD_MAX_SURFACE_MODULE_COUNT == 12;
}

proc std_max_surface_symbols_present() -> bool {
    give STD_MAX_SURFACE_SYMBOL_COUNT >= 120;
}

proc std_max_surface_is_not_empty() -> bool {
    give STD_MAX_MIN_SOURCE_LINES >= 30
        and STD_MAX_MIN_PUBLIC_PROCS >= 10
        and STD_MAX_MIN_NATIVE_PROCS >= 8;
}
