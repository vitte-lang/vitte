use src/vitte/stdlib/tests/modules/std_uuid_test as uuid_test
use src/vitte/stdlib/tests/modules/std_calendar_test as calendar_test
use src/vitte/stdlib/tests/modules/std_units_test as units_test
use src/vitte/stdlib/tests/modules/std_metrics_test as metrics_test
use src/vitte/stdlib/tests/modules/std_mime_test as mime_test
use src/vitte/stdlib/tests/modules/std_percent_encoding_test as percent_test

proc stdlib_module_tests_run() -> bool {
    give uuid_test.std_uuid_test()
        and calendar_test.std_calendar_test()
        and units_test.std_units_test()
        and metrics_test.std_metrics_test()
        and mime_test.std_mime_test()
        and percent_test.std_percent_encoding_test();
}
