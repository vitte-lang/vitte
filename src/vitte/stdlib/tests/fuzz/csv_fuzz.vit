use src/vitte/stdlib/core/string as core_string
use src/vitte/stdlib/std/csv as std_csv

proc fuzz_csv(seed: u64) -> bool {
    let bytes: [byte] = compiler_fuzz_bytes(seed);
    if not core_string.validate_utf8(bytes) {
        give true;
    }
    let parsed = std_csv.csv_parse(compiler_fuzz_utf8_view(bytes), std_csv.csv_default_options());
    give parsed.ok or parsed.ok == false;
}
