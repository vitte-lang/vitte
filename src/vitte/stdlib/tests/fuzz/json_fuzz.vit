use src/vitte/stdlib/core/string as core_string
use src/vitte/stdlib/std/serialization as std_serialization

proc fuzz_json(seed: u64) -> bool {
    let bytes: [byte] = compiler_fuzz_bytes(seed);
    if not core_string.validate_utf8(bytes) {
        give true;
    }
    let parsed = std_serialization.json_value(compiler_fuzz_utf8_view(bytes));
    give parsed.ok or parsed.ok == false;
}
