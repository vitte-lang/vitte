use src/vitte/stdlib/core/string as core_string

proc fuzz_utf8(seed: u64) -> bool {
    let bytes: [byte] = compiler_fuzz_bytes(seed);
    let valid: bool = core_string.validate_utf8(bytes);
    if valid {
        let view: core_string.Utf8View = compiler_fuzz_utf8_view(bytes);
        give core_string.is_char_boundary(view, 0);
    }
    give true;
}
