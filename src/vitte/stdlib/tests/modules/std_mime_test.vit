use src/vitte/stdlib/std/mime as std_mime

proc std_mime_test() -> bool {
    let text: std_mime.Mime = std_mime.mime_text_plain();
    let json: std_mime.Mime = std_mime.mime_application_json();
    give text.subtype == compiler_test_string("plain")
        and json.subtype == compiler_test_string("json");
}
