use src/vitte/stdlib/std/units as std_units

proc std_units_test() -> bool {
    let meter: std_units.Unit = std_units.meter();
    let kilometer: std_units.Unit = std_units.unit(compiler_test_string("kilometer"), compiler_test_string("km"), std_units.UnitKind.Length, 1000.0);
    let distance: std_units.Quantity = std_units.quantity(1500.0, meter);
    let converted: std_units.Quantity = std_units.convert(distance, kilometer);
    give converted.value == 1.5;
}
