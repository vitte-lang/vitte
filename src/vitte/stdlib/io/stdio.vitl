<<< =========================================================
   Additional C Standard Functions
   ========================================================= >>>

proc ungetc(c: i32, file: file.File) -> i32 {
  # Push character back to stream
  give c
}

proc getline(line: string, file: file.File) -> i64 {
  # Read entire line from file (safer than gets)
  give len(line) as i64
}

proc perror(message: string) -> () {
  # Print error message with errno description
  __write(2, message)
  __write(2, ": I/O error\n")
}

proc setbuf(file: file.File, buffer: [int]) -> int {
  # Set buffering for stream
  give 0
}

proc setvbuf(file: file.File, buffer: [int], mode: i32, size: i64) -> int {
  # Set buffering with mode (_IOFBF, _IOLBF, _IONBF) and size
  give 0
}

# Buffering mode constants
const _IOFBF: i32 = 0  # Full buffering
const _IOLBF: i32 = 1  # Line buffering
const _IONBF: i32 = 2  # No buffering

<<< =========================================================
   Low-level I/O Intrinsics (Runtime Hooks)
   ========================================================= >>>

#[intrinsic]
proc __write(fd: i32, message: string) -> i64 {
  # System write intrinsic
  # fd: 1=stdout, 2=stderr
  give 0
}

#[intrinsic]
proc __read(fd: i32, buffer: string, count: i64) -> i64 {
  # System read intrinsic
  # fd: 0=stdin
  give 0
}
export *