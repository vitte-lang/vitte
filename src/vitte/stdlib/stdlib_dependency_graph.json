{
  "schema": "vitte.stdlib.dependency-graph",
  "schema_version": "1.0.0",
  "levels": [
    "core",
    "alloc",
    "std",
    "platform",
    "experimental"
  ],
  "edges": [
    {
      "from": "alloc",
      "to": "core"
    },
    {
      "from": "std",
      "to": "core"
    },
    {
      "from": "std",
      "to": "alloc"
    },
    {
      "from": "platform",
      "to": "core"
    },
    {
      "from": "platform",
      "to": "alloc"
    },
    {
      "from": "platform",
      "to": "std"
    },
    {
      "from": "experimental",
      "to": "core"
    },
    {
      "from": "experimental",
      "to": "alloc"
    },
    {
      "from": "experimental",
      "to": "std"
    },
    {
      "from": "experimental",
      "to": "platform"
    }
  ],
  "rules": {
    "acyclic": true,
    "only_declared_edges": true,
    "same_level_imports_allowed": true
  }
}
