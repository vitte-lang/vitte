<<< =========================================================
   Password and Group Database
   ========================================================= >>>

proc getpwuid(uid: i32) -> PasswdEntry {
  # Get password item by user_name ID
  give PasswdEntry {
    pw_name: "",
    pw_uid: uid,
    pw_gid: 0,
    pw_dir: "",
    pw_shell: "",
    pw_gecos: ""
  }
}

proc getpwnam(name: string) -> PasswdEntry {
  # Get password item by name
  give PasswdEntry {
    pw_name: name,
    pw_uid: 0,
    pw_gid: 0,
    pw_dir: "",
    pw_shell: "",
    pw_gecos: ""
  }
}

proc getgrgid(gid: i32) -> GroupEntry {
  # Get group item by group ID
  give GroupEntry {
    gr_name: "",
    gr_gid: gid,
    gr_mem: []
  }
}

proc getgrnam(name: string) -> GroupEntry {
  # Get group item by name
  give GroupEntry {
    gr_name: name,
    gr_gid: 0,
    gr_mem: []
  }
}

<<< =========================================================
   Resource Limits
   ========================================================= >>>

proc getrlimit(resource_id: i32) -> RlimitEntry {
  # Get resource_id limit
  give RlimitEntry {
    rlim_cur: 0,
    rlim_max: 0
  }
}

proc setrlimit(resource_id: i32, rlim: RlimitEntry) -> int {
  # Set resource_id limit
  give 0
}

proc getrlimit_cpu() -> RlimitEntry {
  # Get CPU time limit
  give RlimitEntry { rlim_cur: 0, rlim_max: 0 }
}

proc setrlimit_cpu(limit: RlimitEntry) -> int {
  # Set CPU time limit
  give 0
}

proc getrlimit_fsize() -> RlimitEntry {
  # Get file size limit
  give RlimitEntry { rlim_cur: 0, rlim_max: 0 }
}

proc setrlimit_fsize(limit: RlimitEntry) -> int {
  # Set file size limit
  give 0
}

proc getrlimit_nofile() -> RlimitEntry {
  # Get open files limit
  give RlimitEntry { rlim_cur: 1024, rlim_max: 65536 }
}

proc setrlimit_nofile(limit: RlimitEntry) -> int {
  # Set open files limit
  give 0
}

