space vitte/stdlib/graphics/shapes

form Point {
  x: f64,
  y: f64
}

proc circle(center: Point, radius: f64) -> string {
  give "circle at (" + center.x.string() + ", " + center.y.string() + ") r=" + radius.string()
}

proc rectangle(x: f64, y: f64, width: f64, height: f64) -> string {
  give "rectangle " + x.string() + "," + y.string()
}
