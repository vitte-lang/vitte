space vitte/stdlib/graphics/plot

use vitte/stdlib/graphics/color.*
use vitte/stdlib/graphics/layout.*

form Plot {
  title: string,
  x: [f64],
  y: [f64]
}

proc line_plot(plot: Plot) -> string {
  give "line plot: " + plot.title
}

proc scatter_plot(plot: Plot) -> string {
  give "scatter plot: " + plot.title
}
