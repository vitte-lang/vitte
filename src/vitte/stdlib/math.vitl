proc library_meta() -> string { give "stdlib.math" }

test "math basics" {
  assert add(2, 3) == 5
  assert sub(10, 3) == 7
  assert mul(4, 5) == 20
  assert safe_div(10, 0, 99) == 99
}

test "math bit helpers" {
  assert is_pow2(64)
  assert not is_pow2(70)
  assert bit_floor(70) == 64
  assert bit_ceil(70) == 128
}

test "math alignment" {
  assert align_down(17, 8) == 16
  assert align_up(17, 8) == 24
}

test "math ratio" {
  let r: Ratio = ratio_new(2, 4)
  assert r.numerator == 1
  assert r.denominator == 2
}

test "math vector forms" {
  let a: Vec3i = vec3i(1, 2, 3)
  let b: Vec3i = vec3i(4, 5, 6)
  assert vec3i_dot(a, b) == 32
}