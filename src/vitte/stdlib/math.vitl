
space vitte/stdlib/math

<<< =========================================================
   Vitte Standard Library — Math Facade
   Maximal facade over arithmetic, comparison, number_theory,
   powers, roots, modular, geometry, arrays, vector, complex,
   matrix, probability, sequences, calculus and trigonometry.
   ========================================================= >>>

use stdlib/math/arithmetic as arithmetic
use stdlib/math/comparison as comparison
use stdlib/math/number_theory as number_theory
use stdlib/math/powers as powers
use stdlib/math/roots as roots
use stdlib/math/modular as modular
use stdlib/math/geometry as geometry
use stdlib/math/arrays as arrays
use stdlib/math/vector as vector
use stdlib/math/complex as complex
use stdlib/math/matrix as matrix
use stdlib/math/probability as probability
use stdlib/math/sequences as sequences
use stdlib/math/calculus as calculus
use stdlib/math/trigonometry as trigonometry

export *

const PI: f64 = arithmetic.PI
const E: f64 = arithmetic.E
const TAU: f64 = arithmetic.PI * 2.0
const HALF_PI: f64 = arithmetic.PI / 2.0
const QUARTER_PI: f64 = arithmetic.PI / 4.0
const DEG_TO_RAD: f64 = arithmetic.PI / 180.0
const RAD_TO_DEG: f64 = 180.0 / arithmetic.PI

const I32_MIN: int = -2147483648
const I32_MAX: int = 2147483647
const BYTE_BITS: int = 8
const WORD_BITS: int = 64
const DEFAULT_SCALE: int = 1000000
const PERCENT_SCALE: int = 100

form Ratio {
  numerator: int,
  denominator: int,
}

form IntRange {
  min: int,
  max: int,
}

form IntStats {
  count: int,
  sum: int,
  min: int,
  max: int,
  mean: int,
  range: int,
}

form Point2i {
  x: int,
  y: int,
}

form Size2i {
  width: int,
  height: int,
}

form Rect2i {
  x: int,
  y: int,
  width: int,
  height: int,
}

form Vec2i {
  x: int,
  y: int,
}

form Vec3i {
  x: int,
  y: int,
  z: int,
}

pick MathError {
  Ok,
  DivisionByZero,
  Overflow,
  InvalidInput,
  EmptyInput,
}

proc math_error_code(err: MathError) -> int {
  match err {
    case Ok => 0
    case DivisionByZero => -1
    case Overflow => -2
    case InvalidInput => -3
    case EmptyInput => -4
  }
}

proc add(a: int, b: int) -> int { give arithmetic.add(a, b) }
proc sub(a: int, b: int) -> int { give arithmetic.sub(a, b) }
proc mul(a: int, b: int) -> int { give arithmetic.mul(a, b) }
proc div_trunc(a: int, b: int) -> int { give arithmetic.div_trunc(a, b) }
proc rem(a: int, b: int) -> int { give arithmetic.rem(a, b) }
proc abs(value: int) -> int { give arithmetic.abs(value) }

proc min(a: int, b: int) -> int { give comparison.min(a, b) }
proc max(a: int, b: int) -> int { give comparison.max(a, b) }
proc clamp(value: int, low: int, high: int) -> int { give comparison.clamp(value, low, high) }
proc sign(value: int) -> int { give comparison.sign(value) }
proc between(value: int, low: int, high: int) -> bool { give comparison.between(value, low, high) }
proc compare(a: int, b: int) -> int { give comparison.compare(a, b) }

proc neg(value: int) -> int { give 0 - value }
proc inc(value: int) -> int { give value + 1 }
proc dec(value: int) -> int { give value - 1 }
proc square(value: int) -> int { give value * value }
proc cube(value: int) -> int { give value * value * value }
proc avg2(a: int, b: int) -> int { give a + (b - a) / 2 }
proc midpoint(a: int, b: int) -> int { give avg2(a, b) }

proc safe_div(a: int, b: int, fallback: int) -> int {
  if b == 0 {
    give fallback
  }

  give a / b
}

proc safe_rem(a: int, b: int, fallback: int) -> int {
  if b == 0 {
    give fallback
  }

  give a % b
}

proc saturating_add(a: int, b: int) -> int {
  if b > 0 and a > I32_MAX - b {
    give I32_MAX
  }

  if b < 0 and a < I32_MIN - b {
    give I32_MIN
  }

  give a + b
}

proc saturating_sub(a: int, b: int) -> int {
  if b < 0 and a > I32_MAX + b {
    give I32_MAX
  }

  if b > 0 and a < I32_MIN + b {
    give I32_MIN
  }

  give a - b
}

proc saturating_mul(a: int, b: int) -> int {
  if a == 0 or b == 0 {
    give 0
  }

  let result: int = a * b

  if result / b != a {
    if (a > 0 and b > 0) or (a < 0 and b < 0) {
      give I32_MAX
    }

    give I32_MIN
  }

  give result
}

proc checked_add_valid(a: int, b: int) -> bool {
  if b > 0 and a > I32_MAX - b {
    give false
  }

  if b < 0 and a < I32_MIN - b {
    give false
  }

  give true
}

proc checked_mul_valid(a: int, b: int) -> bool {
  if a == 0 or b == 0 {
    give true
  }

  let result: int = a * b
  give result / b == a
}

proc gcd(a: int, b: int) -> int { give number_theory.gcd(a, b) }
proc lcm(a: int, b: int) -> int { give number_theory.lcm(a, b) }
proc gcd_many(values: [int]) -> int { give number_theory.gcd_many(values) }
proc lcm_many(values: [int]) -> int { give number_theory.lcm_many(values) }
proc is_even(value: int) -> bool { give number_theory.is_even(value) }
proc is_odd(value: int) -> bool { give number_theory.is_odd(value) }
proc is_prime(value: int) -> bool { give number_theory.is_prime(value) }
proc is_composite(value: int) -> bool { give number_theory.is_composite(value) }
proc next_prime(value: int) -> int { give number_theory.next_prime(value) }
proc prev_prime(value: int) -> int { give number_theory.prev_prime(value) }
proc prime_factors(value: int) -> [int] { give number_theory.prime_factors(value) }
proc divisors(value: int) -> [int] { give number_theory.divisors(value) }
proc totient(value: int) -> int { give number_theory.totient(value) }
proc coprime(a: int, b: int) -> bool { give gcd(a, b) == 1 }

proc pow_int(base: int, exponent: int) -> int { give powers.pow_int(base, exponent) }
proc pow2(exponent: int) -> int { give powers.pow2(exponent) }
proc pow10(exponent: int) -> int { give powers.pow10(exponent) }
proc factorial(value: int) -> int { give powers.factorial(value) }
proc triangular(value: int) -> int { give powers.triangular(value) }
proc fibonacci(value: int) -> int { give powers.fibonacci(value) }
proc binomial(n: int, k: int) -> int { give powers.binomial(n, k) }
proc falling_factorial(value: int, count: int) -> int { give powers.falling_factorial(value, count) }
proc rising_factorial(value: int, count: int) -> int { give powers.rising_factorial(value, count) }
proc double_factorial(value: int) -> int { give powers.double_factorial(value) }

proc sqrt_floor(value: int) -> int { give roots.sqrt_floor(value) }
proc sqrt_ceil(value: int) -> int { give roots.sqrt_ceil(value) }
proc cube_root_floor(value: int) -> int { give roots.cube_root_floor(value) }
proc cube_root_ceil(value: int) -> int { give roots.cube_root_ceil(value) }
proc is_square(value: int) -> bool { give roots.is_square(value) }
proc is_cube(value: int) -> bool { give roots.is_cube(value) }
proc ilog2_floor(value: int) -> int { give roots.ilog2_floor(value) }
proc ilog10_floor(value: int) -> int { give roots.ilog10_floor(value) }

proc ceil_div(a: int, b: int) -> int {
  if b == 0 {
    give 0
  }

  let q: int = a / b
  let r: int = a % b

  if r == 0 {
    give q
  }

  if (a > 0 and b > 0) or (a < 0 and b < 0) {
    give q + 1
  }

  give q
}

proc floor_div(a: int, b: int) -> int {
  if b == 0 {
    give 0
  }

  let q: int = a / b
  let r: int = a % b

  if r == 0 {
    give q
  }

  if (a < 0 and b > 0) or (a > 0 and b < 0) {
    give q - 1
  }

  give q
}

proc floor_mod(a: int, b: int) -> int {
  if b == 0 {
    give 0
  }

  give a - floor_div(a, b) * b
}

proc div_round_nearest(a: int, b: int) -> int {
  if b == 0 {
    give 0
  }

  if a >= 0 {
    give (a + abs(b) / 2) / b
  }

  give (a - abs(b) / 2) / b
}

proc mod_normalize(value: int, modulus: int) -> int { give modular.mod_normalize(value, modulus) }
proc mod_add(a: int, b: int, modulus: int) -> int { give modular.mod_add(a, b, modulus) }
proc mod_sub(a: int, b: int, modulus: int) -> int { give modular.mod_sub(a, b, modulus) }
proc mod_mul(a: int, b: int, modulus: int) -> int { give modular.mod_mul(a, b, modulus) }
proc mod_pow(base: int, exponent: int, modulus: int) -> int { give modular.mod_pow(base, exponent, modulus) }
proc mod_neg(value: int, modulus: int) -> int { give modular.mod_neg(value, modulus) }
proc mod_inverse(value: int, modulus: int) -> int { give modular.mod_inverse(value, modulus) }
proc mod_div(a: int, b: int, modulus: int) -> int { give modular.mod_div(a, b, modulus) }

proc is_pow2(value: int) -> bool {
  if value <= 0 {
    give false
  }

  let mut current: int = value

  while current % 2 == 0 {
    current = current / 2
  }

  give current == 1
}

proc prev_pow2(value: int) -> int {
  if value <= 1 {
    give 1
  }

  let mut p: int = 1

  while (p * 2) <= value {
    p = p * 2
  }

  give p
}

proc next_pow2(value: int) -> int {
  if value <= 1 {
    give 1
  }

  let mut p: int = 1

  while p < value {
    p = p * 2
  }

  give p
}

proc has_single_bit(value: int) -> bool { give is_pow2(value) }
proc bit_floor(value: int) -> int { give prev_pow2(value) }
proc bit_ceil(value: int) -> int { give next_pow2(value) }

proc bit_width(value: int) -> int {
  if value <= 0 {
    give 0
  }

  give ilog2_floor(value) + 1
}

proc bit_count(value: int) -> int {
  let mut n: int = abs(value)
  let mut count: int = 0

  while n != 0 {
    if n % 2 != 0 {
      count = count + 1
    }

    n = n / 2
  }

  give count
}

proc lowbit(value: int) -> int {
  if value == 0 {
    give 0
  }

  let mut n: int = abs(value)
  let mut bit: int = 1

  while n % 2 == 0 {
    n = n / 2
    bit = bit * 2
  }

  give bit
}

proc lowbit_pow2(value: int) -> int { give lowbit(value) }
proc parity(value: int) -> int { give bit_count(value) % 2 }

proc is_bit_set(value: int, index: int) -> bool {
  if index < 0 {
    give false
  }

  give ((value / pow2(index)) % 2) != 0
}

proc set_bit(value: int, index: int) -> int {
  if index < 0 {
    give value
  }

  if is_bit_set(value, index) {
    give value
  }

  give value + pow2(index)
}

proc clear_bit(value: int, index: int) -> int {
  if index < 0 {
    give value
  }

  if not is_bit_set(value, index) {
    give value
  }

  give value - pow2(index)
}

proc toggle_bit(value: int, index: int) -> int {
  if is_bit_set(value, index) {
    give clear_bit(value, index)
  }

  give set_bit(value, index)
}

proc align_down(value: int, alignment: int) -> int {
  if alignment <= 0 {
    give value
  }

  give value - rem(value, alignment)
}

proc align_up(value: int, alignment: int) -> int {
  if alignment <= 0 {
    give value
  }

  let r: int = rem(value, alignment)

  if r == 0 {
    give value
  }

  give value + (alignment - r)
}

proc round_to(value: int, step: int) -> int {
  if step <= 0 {
    give value
  }

  give align_up(value, step)
}

proc floor_to(value: int, step: int) -> int {
  if step <= 0 {
    give value
  }

  give align_down(value, step)
}

proc round_down_pow2(value: int, alignment: int) -> int {
  if alignment <= 0 {
    give value
  }

  if not is_pow2(alignment) {
    give align_down(value, alignment)
  }

  give value - (value % alignment)
}

proc round_up_pow2(value: int, alignment: int) -> int {
  if alignment <= 0 {
    give value
  }

  if not is_pow2(alignment) {
    give align_up(value, alignment)
  }

  let r: int = value % alignment

  if r == 0 {
    give value
  }

  give value + (alignment - r)
}

proc clamp_zero(value: int) -> int {
  if value < 0 {
    give 0
  }

  give value
}

proc clamp_nonzero(value: int) -> int {
  if value == 0 {
    give 1
  }

  give value
}

proc clamp_percent(value: int) -> int { give clamp(value, 0, 100) }

proc lerp_int(a: int, b: int, t_scaled: int, scale: int) -> int {
  if scale == 0 {
    give a
  }

  give a + ((b - a) * t_scaled) / scale
}

proc inv_lerp_int(a: int, b: int, value: int, scale: int) -> int {
  if a == b {
    give 0
  }

  give ((value - a) * scale) / (b - a)
}

proc remap_int(value: int, in_min: int, in_max: int, out_min: int, out_max: int) -> int {
  let t: int = inv_lerp_int(in_min, in_max, value, DEFAULT_SCALE)
  give lerp_int(out_min, out_max, t, DEFAULT_SCALE)
}

proc smoothstep_scaled(edge0: int, edge1: int, value: int, scale: int) -> int {
  if edge0 == edge1 {
    give 0
  }

  let t0: int = inv_lerp_int(edge0, edge1, value, scale)
  let t: int = clamp(t0, 0, scale)
  give (t * t * (3 * scale - 2 * t)) / (scale * scale)
}

proc ratio_new(numerator: int, denominator: int) -> Ratio {
  if denominator == 0 {
    give Ratio { numerator: 0, denominator: 1 }
  }

  let g: int = gcd(abs(numerator), abs(denominator))
  let mut n: int = numerator / g
  let mut d: int = denominator / g

  if d < 0 {
    n = 0 - n
    d = 0 - d
  }

  give Ratio { numerator: n, denominator: d }
}

proc ratio_add(a: Ratio, b: Ratio) -> Ratio { give ratio_new(a.numerator * b.denominator + b.numerator * a.denominator, a.denominator * b.denominator) }
proc ratio_sub(a: Ratio, b: Ratio) -> Ratio { give ratio_new(a.numerator * b.denominator - b.numerator * a.denominator, a.denominator * b.denominator) }
proc ratio_mul(a: Ratio, b: Ratio) -> Ratio { give ratio_new(a.numerator * b.numerator, a.denominator * b.denominator) }
proc ratio_div(a: Ratio, b: Ratio) -> Ratio { give ratio_new(a.numerator * b.denominator, a.denominator * b.numerator) }

proc ratio_to_scaled(value: Ratio, scale: int) -> int {
  if value.denominator == 0 {
    give 0
  }

  give (value.numerator * scale) / value.denominator
}

proc ratio_percent(value: Ratio) -> int { give ratio_to_scaled(value, 100) }

proc rect_area(width: int, height: int) -> int { give geometry.rect_area(width, height) }
proc rect_perimeter(width: int, height: int) -> int { give geometry.rect_perimeter(width, height) }
proc triangle_area2(base: int, height: int) -> int { give geometry.triangle_area2(base, height) }
proc distance_sq(ax: int, ay: int, bx: int, by: int) -> int { give geometry.distance_sq(ax, ay, bx, by) }
proc manhattan_distance(ax: int, ay: int, bx: int, by: int) -> int { give geometry.manhattan_distance(ax, ay, bx, by) }

proc point(x: int, y: int) -> Point2i { give Point2i { x: x, y: y } }
proc size2(width: int, height: int) -> Size2i { give Size2i { width: width, height: height } }
proc rect(x: int, y: int, width: int, height: int) -> Rect2i { give Rect2i { x: x, y: y, width: width, height: height } }
proc vec2i(x: int, y: int) -> Vec2i { give Vec2i { x: x, y: y } }
proc vec3i(x: int, y: int, z: int) -> Vec3i { give Vec3i { x: x, y: y, z: z } }
proc point_distance_sq(a: Point2i, b: Point2i) -> int { give distance_sq(a.x, a.y, b.x, b.y) }
proc point_manhattan(a: Point2i, b: Point2i) -> int { give manhattan_distance(a.x, a.y, b.x, b.y) }
proc rect_right(r: Rect2i) -> int { give r.x + r.width }
proc rect_bottom(r: Rect2i) -> int { give r.y + r.height }
proc rect_contains_point(r: Rect2i, p: Point2i) -> bool { give p.x >= r.x and p.x < rect_right(r) and p.y >= r.y and p.y < rect_bottom(r) }
proc rect_intersects(a: Rect2i, b: Rect2i) -> bool { give a.x < rect_right(b) and rect_right(a) > b.x and a.y < rect_bottom(b) and rect_bottom(a) > b.y }

proc vec(x: int, y: int) -> [int] { give vector.vec2(x, y) }
proc vec_add(a: [int], b: [int]) -> [int] { give vector.vec2_add(a, b) }
proc vec_sub(a: [int], b: [int]) -> [int] { give vector.vec2_sub(a, b) }
proc vec_scale(a: [int], factor: int) -> [int] { give vector.vec2_scale(a, factor) }
proc vec_dot(a: [int], b: [int]) -> int { give vector.dot2(a, b) }
proc vec_norm_sq(a: [int]) -> int { give vector.norm2_sq(a) }

proc vec2i_add(a: Vec2i, b: Vec2i) -> Vec2i { give Vec2i { x: a.x + b.x, y: a.y + b.y } }
proc vec2i_sub(a: Vec2i, b: Vec2i) -> Vec2i { give Vec2i { x: a.x - b.x, y: a.y - b.y } }
proc vec2i_scale(a: Vec2i, factor: int) -> Vec2i { give Vec2i { x: a.x * factor, y: a.y * factor } }
proc vec2i_dot(a: Vec2i, b: Vec2i) -> int { give a.x * b.x + a.y * b.y }
proc vec2i_cross(a: Vec2i, b: Vec2i) -> int { give a.x * b.y - a.y * b.x }
proc vec2i_norm_sq(a: Vec2i) -> int { give vec2i_dot(a, a) }

proc vec3i_add(a: Vec3i, b: Vec3i) -> Vec3i { give Vec3i { x: a.x + b.x, y: a.y + b.y, z: a.z + b.z } }
proc vec3i_sub(a: Vec3i, b: Vec3i) -> Vec3i { give Vec3i { x: a.x - b.x, y: a.y - b.y, z: a.z - b.z } }
proc vec3i_scale(a: Vec3i, factor: int) -> Vec3i { give Vec3i { x: a.x * factor, y: a.y * factor, z: a.z * factor } }
proc vec3i_dot(a: Vec3i, b: Vec3i) -> int { give a.x * b.x + a.y * b.y + a.z * b.z }
proc vec3i_cross(a: Vec3i, b: Vec3i) -> Vec3i { give Vec3i { x: a.y * b.z - a.z * b.y, y: a.z * b.x - a.x * b.z, z: a.x * b.y - a.y * b.x } }
proc vec3i_norm_sq(a: Vec3i) -> int { give vec3i_dot(a, a) }

proc cx(real: int, imag: int) -> [int] { give complex.complex_pair(real, imag) }
proc cx_add(a: [int], b: [int]) -> [int] { give complex.complex_add(a, b) }
proc cx_sub(a: [int], b: [int]) -> [int] { give complex.complex_sub(a, b) }
proc cx_mul(a: [int], b: [int]) -> [int] { give complex.complex_mul(a, b) }
proc cx_conj(a: [int]) -> [int] { give complex.complex_conj(a) }
proc cx_abs_sq(a: [int]) -> int { give complex.complex_abs_sq(a) }

proc mat(a11: int, a12: int, a21: int, a22: int) -> [int] { give matrix.mat2(a11, a12, a21, a22) }
proc mat_id() -> [int] { give matrix.mat2_identity() }
proc mat_add(a: [int], b: [int]) -> [int] { give matrix.mat2_add(a, b) }
proc mat_sub(a: [int], b: [int]) -> [int] { give matrix.mat2_sub(a, b) }
proc mat_mul(a: [int], b: [int]) -> [int] { give matrix.mat2_mul(a, b) }
proc mat_trace(a: [int]) -> int { give matrix.mat2_trace(a) }
proc mat_det(a: [int]) -> int { give matrix.mat2_det(a) }

proc arr_len(values: [int]) -> int { give arrays.len(values) }
proc arr_is_empty(values: [int]) -> bool { give arrays.is_empty(values) }
proc arr_first(values: [int]) -> int { give arrays.first(values) }
proc arr_last(values: [int]) -> int { give arrays.last(values) }
proc arr_contains(values: [int], target: int) -> bool { give arrays.contains(values, target) }
proc arr_index_of(values: [int], target: int) -> int { give arrays.index_of(values, target) }
proc arr_count(values: [int], target: int) -> int { give arrays.count(values, target) }
proc arr_last_index_of(values: [int], target: int) -> int { give arrays.last_index_of(values, target) }
proc arr_copy(values: [int]) -> [int] { give arrays.copy(values) }
proc arr_append(values: [int], value: int) -> [int] { give arrays.append(values, value) }
proc arr_prepend(value: int, values: [int]) -> [int] { give arrays.prepend(value, values) }
proc arr_concat(left: [int], right: [int]) -> [int] { give arrays.concat(left, right) }
proc arr_push(values: [int], value: int) -> [int] { give arrays.push(values, value) }
proc arr_set(values: [int], index: int, value: int) -> [int] { give arrays.set_at(values, index, value) }
proc arr_swap(values: [int], left_index: int, right_index: int) -> [int] { give arrays.swap(values, left_index, right_index) }
proc arr_clear(values: [int]) -> [int] { give arrays.clear(values) }
proc arr_pop(values: [int]) -> [int] { give arrays.pop(values) }
proc arr_pop_at(values: [int], index: int) -> [int] { give arrays.pop_at(values, index) }
proc arr_insert(values: [int], index: int, value: int) -> [int] { give arrays.insert(values, index, value) }
proc arr_remove_at(values: [int], index: int) -> [int] { give arrays.remove_at(values, index) }
proc arr_repeat(value: int, count_items: int) -> [int] { give arrays.repeat(value, count_items) }
proc arr_fill(count_items: int, value: int) -> [int] { give arrays.fill(count_items, value) }
proc arr_reverse(values: [int]) -> [int] { give arrays.reverse(values) }
proc arr_sum(values: [int]) -> int { give arrays.sum(values) }
proc arr_min(values: [int]) -> int { give arrays.min(values) }
proc arr_max(values: [int]) -> int { give arrays.max(values) }
proc arr_mean(values: [int]) -> int { give arrays.mean_floor(values) }
proc arr_mean_scaled(values: [int], scale: int) -> int { give arrays.mean_scaled(values, scale) }
proc arr_range(values: [int]) -> int { give arrays.range(values) }
proc arr_sum_abs(values: [int]) -> int { give arrays.sum_abs(values) }
proc arr_product(values: [int]) -> int { give arrays.product(values) }
proc arr_any(values: [int]) -> bool { give arrays.any_nonzero(values) }
proc arr_all(values: [int]) -> bool { give arrays.all_nonzero(values) }
