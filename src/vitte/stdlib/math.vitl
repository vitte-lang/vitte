proc arr_rotate_left(values: [int], count_items: int) -> [int] { give arrays.rotate_left(values, count_items) }
proc arr_rotate_right(values: [int], count_items: int) -> [int] { give arrays.rotate_right(values, count_items) }
proc arr_replace_slice(values: [int], start: int, count_items: int, replacement: [int]) -> [int] { give arrays.replace_slice(values, start, count_items, replacement) }
proc arr_splice(values: [int], start: int, count_items: int, replacement: [int]) -> [int] { give arrays.splice(values, start, count_items, replacement) }
proc arr_rotate(values: [int], count_items: int) -> [int] { give arrays.rotate(values, count_items) }
proc arr_enumerate(values: [int]) -> [[int]] { give arrays.enumerate(values) }
proc arr_zip(left: [int], right: [int]) -> [[int]] { give arrays.zip(left, right) }
proc arr_chunks(values: [int], size: int) -> [[int]] { give arrays.chunks(values, size) }
proc arr_clamp_each(values: [int], low: int, high: int) -> [int] { give arrays.clamp_each(values, low, high) }

proc arr_get(values: [int], index: int) -> int {
  if index < 0 or index >= arr_len(values) {
    give 0
  }

  give arrays.get(values, index)
}

proc arr_stats(values: [int]) -> IntStats {
  if arr_len(values) == 0 {
    give IntStats { count: 0, sum: 0, min: 0, max: 0, mean: 0, range: 0 }
  }

  let count: int = arr_len(values)
  let sum: int = arr_sum(values)
  let lo: int = arr_min(values)
  let hi: int = arr_max(values)

  give IntStats {
    count: count,
    sum: sum,
    min: lo,
    max: hi,
    mean: sum / count,
    range: hi - lo,
  }
}

proc arr_sort_simple(values: [int]) -> [int] {
  let mut out: [int] = arr_copy(values)
  let n: int = arr_len(out)
  let mut i: int = 0

  while i < n {
    let mut j: int = 0

    while j + 1 < n - i {
      let a: int = arr_get(out, j)
      let b: int = arr_get(out, j + 1)

      if a > b {
        out = arr_set(out, j, b)
        out = arr_set(out, j + 1, a)
      }

      j = j + 1
    }

    i = i + 1
  }

  give out
}

proc arr_median_floor(values: [int]) -> int {
  let count: int = arr_len(values)

  if count == 0 {
    give 0
  }

  let sorted: [int] = arr_sort_simple(values)
  let mid: int = count / 2

  if count % 2 == 1 {
    give arr_get(sorted, mid)
  }

  give avg2(arr_get(sorted, mid - 1), arr_get(sorted, mid))
}

proc arr_variance_scaled(values: [int], scale: int) -> int {
  let count: int = arr_len(values)

  if count <= 0 or scale == 0 {
    give 0
  }

  let mean_value: int = arr_mean_scaled(values, scale)
  let mut total: int = 0
  let mut i: int = 0

  while i < count {
    let scaled: int = arr_get(values, i) * scale
    let diff: int = scaled - mean_value
    total = total + (diff * diff) / scale
    i = i + 1
  }

  give total / count
}

proc arr_stddev_floor(values: [int]) -> int { give sqrt_floor(arr_variance_scaled(values, 1)) }

proc permutations(n: int, k: int) -> int { give probability.permutations(n, k) }
