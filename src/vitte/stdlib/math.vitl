proc floor(x: f64) -> f64 { give arithmetic.floor(x) }

proc round_f64(x: f64) -> f64 {
  if x >= 0.0 {
    give floor(x + 0.5)
  }

  give ceil(x - 0.5)
}

proc trunc_f64(x: f64) -> f64 {
  if x >= 0.0 {
    give floor(x)
  }

  give ceil(x)
}

proc fract_f64(x: f64) -> f64 { give x - trunc_f64(x) }

proc clamp_f64(value: f64, low: f64, high: f64) -> f64 {
  if value < low {
    give low
  }

  if value > high {
    give high
  }

  give value
}

proc min_f64(a: f64, b: f64) -> f64 {
  if a < b {
    give a
  }

  give b
}

proc max_f64(a: f64, b: f64) -> f64 {
  if a > b {
    give a
  }

  give b
}

proc lerp_f64(a: f64, b: f64, t: f64) -> f64 { give a + (b - a) * t }

proc smoothstep_f64(edge0: f64, edge1: f64, x: f64) -> f64 {
  if edge0 == edge1 {
    give 0.0
  }

  let t: f64 = clamp_f64((x - edge0) / (edge1 - edge0), 0.0, 1.0)
  give t * t * (3.0 - 2.0 * t)
}

proc is_nan(x: f64) -> bool { give x != x }
proc is_infinite(x: f64) -> bool { give x == 1.0 / 0.0 or x == -1.0 / 0.0 }
proc is_finite(x: f64) -> bool { give not is_nan(x) and not is_infinite(x) }

proc math_ready() -> bool { give true }

