proc pairings(total: int) -> int { give probability.pairings(total) }

proc percent(part: int, total: int) -> int {
  if total == 0 {
    give 0
  }

  give (part * 100) / total
}

proc percent_scaled(part: int, total: int, scale: int) -> int {
  if total == 0 {
    give 0
  }

  give (part * scale) / total
}

