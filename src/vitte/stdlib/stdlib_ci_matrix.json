{
  "schema": "vitte.stdlib.ci-matrix",
  "schema_version": "1.0.0",
  "targets": [
    { "name": "posix-x86_64", "platform": "posix", "arch": "x86_64" },
    { "name": "posix-aarch64", "platform": "posix", "arch": "aarch64" },
    { "name": "windows-x86_64", "platform": "windows", "arch": "x86_64" },
    { "name": "wasm32", "platform": "wasm", "arch": "wasm32" },
    { "name": "embedded-armv7", "platform": "embedded", "arch": "armv7" }
  ],
  "commands": [
    "python3 tools/stdlib/run_checks.py",
    "make stdlib-gate"
  ],
  "rules": {
    "core_has_no_alloc_std_platform_imports": true,
    "std_uses_platform_for_os_access": true,
    "api_index_generated": true
  }
}
