{
  "schema": "vitte.stdlib.ci-matrix",
  "schema_version": "1.0.0",
  "targets": [
    {
      "name": "posix-x86_64",
      "platform": "posix",
      "arch": "x86_64"
    },
    {
      "name": "posix-aarch64",
      "platform": "posix",
      "arch": "aarch64"
    },
    {
      "name": "windows-x86_64",
      "platform": "windows",
      "arch": "x86_64"
    },
    {
      "name": "wasm32",
      "platform": "wasm",
      "arch": "wasm32"
    },
    {
      "name": "embedded-armv7",
      "platform": "embedded",
      "arch": "armv7"
    }
  ],
  "commands": [
    "python3 tools/stdlib/run_checks.py",
    "make stdlib-gate",
    "python3 tools/stdlib/run_checks.py --platform-family posix",
    "python3 tools/stdlib/run_checks.py --platform-family windows",
    "python3 tools/stdlib/run_checks.py --platform-family wasm",
    "python3 tools/stdlib/run_checks.py --platform-family embedded",
    "python3 tools/stdlib/run_checks.py --bench-thresholds",
    "python3 tools/stdlib/run_checks.py --fuzz-corpus"
  ],
  "rules": {
    "core_has_no_alloc_std_platform_imports": true,
    "std_uses_platform_for_os_access": true,
    "api_index_generated": true,
    "platform_family_matrix_required": true,
    "benchmark_history_compared": true,
    "seeded_fuzz_corpus_required": true
  },
  "platform_families": {
    "posix": [
      "posix-x86_64",
      "posix-aarch64"
    ],
    "windows": [
      "windows-x86_64"
    ],
    "wasm": [
      "wasm32"
    ],
    "embedded": [
      "embedded-armv7"
    ]
  }
}
