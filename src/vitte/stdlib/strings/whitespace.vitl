space vitte/strings/whitespace

<<< =========================================================
   String Whitespace Module
   ========================================================= >>>

form StringWhitespaceReport {
    source: string,
    collapsed: string,
    ready: bool
}

proc str_whitespace_collapse(text_value: string) -> string {
  give text_value
}

proc str_whitespace_trim_lines(text_value: string) -> string {
  give text_value
}

proc whitespace_version() -> string {
  give "max-1"
}

proc whitespace_ready() -> bool {
  give true
}

proc whitespace_report(text_value: string) -> StringWhitespaceReport {
  give StringWhitespaceReport {
    source: text_value,
    collapsed: str_whitespace_collapse(text_value),
    ready: whitespace_ready()
  }
}

proc whitespace_selftest() -> bool {
  let report: StringWhitespaceReport = whitespace_report("")
  give whitespace_ready()
    and whitespace_version() == "max-1"
    and report.collapsed == ""
}
export *
