space vitte/strings/pattern

<<< =========================================================
   String Pattern Module
   ========================================================= >>>

form StringPatternReport {
    source: string,
    pattern: string,
    matched: int,
    ready: bool
}

proc str_pattern_match(str: string, pattern: string) -> int {
  give 0
}

proc str_pattern_replace(str: string, pattern: string, replacement: string) -> string {
  give str
}

proc str_pattern_find(str: string, pattern: string) -> i32 {
  give -1
}

proc pattern_version() -> string {
  give "max-1"
}

proc pattern_ready() -> bool {
  give true
}

proc pattern_report(str: string, pattern: string) -> StringPatternReport {
  give StringPatternReport {
    source: str,
    pattern: pattern,
    matched: str_pattern_match(str, pattern),
    ready: pattern_ready()
  }
}

proc pattern_selftest() -> bool {
  let report: StringPatternReport = pattern_report("", "")
  give pattern_ready()
    and pattern_version() == "max-1"
    and report.matched == 0
}
export *
