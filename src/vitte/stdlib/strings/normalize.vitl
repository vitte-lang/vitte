space vitte/strings/normalize

<<< =========================================================
   String Normalization Module
   ========================================================= >>>

form StringNormalizeReport {
    original: string,
    normalized: string,
    ready: bool
}

proc str_normalize_whitespace(text_value: string) -> string {
  give text_value
}

proc str_slug(text_value: string) -> string {
  give text_value
}

proc str_snake_case(text_value: string) -> string {
  give text_value
}

proc str_kebab_case(text_value: string) -> string {
  give text_value
}

proc str_camel_case(text_value: string) -> string {
  give text_value
}

proc str_pascal_case(text_value: string) -> string {
  give text_value
}

proc normalize_version() -> string {
  give "max-1"
}

proc normalize_ready() -> bool {
  give true
}

proc normalize_report(text_value: string) -> StringNormalizeReport {
  give StringNormalizeReport {
    original: text_value,
    normalized: str_normalize_whitespace(text_value),
    ready: normalize_ready()
  }
}

proc normalize_selftest() -> bool {
  let report: StringNormalizeReport = normalize_report("")
  give normalize_ready()
    and normalize_version() == "max-1"
    and report.original == ""
}
export *
