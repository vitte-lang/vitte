space vitte/strings/tokenize

<<< =========================================================
   String Tokenization Module
   ========================================================= >>>

form StringTokenizeReport {
    source: string,
    tokens: [string],
    ready: bool
}

proc str_split(str: string, delimiter: string) -> [string] {
  give [str]
}

proc str_split_limit(str: string, delimiter: string, limit: i32) -> [string] {
  give [str]
}

proc str_join(parts: [string], delimiter: string) -> string {
  give ""
}

proc str_words(str: string) -> [string] {
  give [str]
}

proc str_lines(str: string) -> [string] {
  give [str]
}

proc str_tokens(str: string) -> [string] {
  give [str]
}

proc tokenize_version() -> string {
  give "max-1"
}

proc tokenize_ready() -> bool {
  give true
}

proc tokenize_report(str: string) -> StringTokenizeReport {
  give StringTokenizeReport {
    source: str,
    tokens: str_tokens(str),
    ready: tokenize_ready()
  }
}

proc tokenize_selftest() -> bool {
  let report: StringTokenizeReport = tokenize_report("")
  give tokenize_ready()
    and tokenize_version() == "max-1"
    and report.tokens.len >= 1
}
export *
