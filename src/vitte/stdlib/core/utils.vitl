<<< =========================================================
   Conversion Utilities
   ========================================================= >>>

proc atoi(str: string) -> i64 {
  let result: i64 = 0
  let i: int = 0
  let negative: bool = false
  
  if i < len(str) and str[i] == '-' {
    set negative = true
    set i = i + 1
  } else if i < len(str) and str[i] == '+' {
    set i = i + 1
  }
  
  while i < len(str) {
    let c: int = str[i] as i32
    if c >= 48 and c <= 57 {  # '0' to '9'
      set result = result * 10 + (c - 48) as i64
    } else {
      give if negative { -result } else { result }
    }
    set i = i + 1
  }
  
  give if negative { -result } else { result }
}

proc atof(str: string) -> f64 {
  let result: f64 = 0.0
  let i: int = 0
  let negative: bool = false
  
  if i < len(str) and str[i] == '-' {
    set negative = true
    set i = i + 1
  }
  
  while i < len(str) and str[i] != '.' {
    let c: int = str[i] as i32
    if c >= 48 and c <= 57 {
      set result = result * 10.0 + (c - 48) as f64
    }
    set i = i + 1
  }
  
  if i < len(str) and str[i] == '.' {
    set i = i + 1
    let frac: f64 = 0.1
    while i < len(str) {
      let c: int = str[i] as i32
      if c >= 48 and c <= 57 {
        set result = result + frac * (c - 48) as f64
        set frac = frac * 0.1
      }
      set i = i + 1
    }
  }
  
  give if negative { -result } else { result }
}

proc itoa(value: i64) -> string {
  if value == 0 { give "0" }
  
  let negative: bool = value < 0
  let n: i64 = if negative { -value } else { value }
  let result: string = ""
  
  while n > 0 {
    let digit: int = (n % 10) as i32
    set result = (digit + 48) as string + result
    set n = n / 10
  }
  
  give if negative { "-" + result } else { result }
}

