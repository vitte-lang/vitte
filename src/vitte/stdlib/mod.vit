space vitte/stdlib/mod

use vitte/stdlib/collections as coll
use vitte/stdlib/io as io
use vitte/stdlib/io/fileops.{ append_file, copy_file, create_directory, delete_directory, delete_file, file_exists, is_directory, is_file, list_directory, move_file, read_file, write_file }

form Vector<T> {
  data: [T],
}

form HashMap<K, V> {
  entries: [(K, V)],
}

proc vector_new<T>() -> Vector<T> {
  give Vector { data: [] }
}

proc vector_push<T>(vec: Vector<T>, item: T) -> Vector<T> {
  give Vector { data: vec.data + [item] }
}

proc hashmap_new<K, V>() -> HashMap<K, V> {
  give HashMap { entries: [] }
}

proc hashmap_insert<K, V>(map: HashMap<K, V>, key: K, value: V) -> HashMap<K, V> {
  give HashMap { entries: map.entries + [(key, value)] }
}

proc io_read_file(path: string) -> string {
  give read_file(path)
}

proc io_write_file(path: string, content: string) -> bool {
  give write_file(path, content)
}

proc io_append_file(path: string, content: string) -> bool {
  give append_file(path, content)
}

proc io_file_exists(path: string) -> bool {
  give file_exists(path)
}

proc io_create_directory(path: string) -> bool {
  give create_directory(path)
}

proc io_is_file(path: string) -> bool {
  give is_file(path)
}

proc io_is_directory(path: string) -> bool {
  give is_directory(path)
}

proc io_copy_file(src: string, dst: string) -> bool {
  give copy_file(src, dst)
}

proc io_move_file(src: string, dst: string) -> bool {
  give move_file(src, dst)
}

proc io_delete_file(path: string) -> bool {
  give delete_file(path)
}

proc io_delete_directory(path: string) -> bool {
  give delete_directory(path)
}

proc io_list_directory(path: string) -> [string] {
  give list_directory(path)
}

export *
