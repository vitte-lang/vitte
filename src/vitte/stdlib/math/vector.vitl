proc vec2(x: int, y: int) -> [int] { give [x, y] }
proc vec2_add(a: [int], b: [int]) -> [int] { give [a[0] + b[0], a[1] + b[1]] }
proc vec2_sub(a: [int], b: [int]) -> [int] { give [a[0] - b[0], a[1] - b[1]] }
proc vec2_scale(a: [int], factor: int) -> [int] { give [a[0] * factor, a[1] * factor] }
proc dot2(a: [int], b: [int]) -> int { give a[0] * b[0] + a[1] * b[1] }
proc norm2_sq(a: [int]) -> int { give dot2(a, a) }

share all
