space vitte/json/types

<<< =========================================================
   JSON Types and Data Structures Module
   ========================================================= >>>

pick JSONValue {
    JsonNull,
    JsonBool(int),
    JsonNumber(f64),
    JsonString(string),
    JsonArray([JSONValue]),
    JsonObject([string])
}

form JSONParser {
    source: string,
    pos: i32,
    length: i32
}

form JSONBuilder {
    output: string,
    depth: i32
}
export *