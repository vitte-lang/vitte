space vitte/strings

<<< =========================================================
   Advanced String Library — Formatting, Parsing, Manipulation
   ========================================================= >>>

form StringLibraryManifest {
  name: string,
  version: string,
  modules: [string]
}

form StringLibraryHealth {
  ready: bool,
  module_count: i32,
  builder_ready: bool,
  parsing_ready: bool,
  case_ready: bool,
  comparison_ready: bool,
  escape_ready: bool,
  classify_ready: bool,
  normalize_ready: bool,
  format_ready: bool,
  search_ready: bool,
  tokenize_ready: bool,
  unicode_ready: bool,
  metrics_ready: bool,
  template_ready: bool,
  predicate_ready: bool,
  transform_ready: bool,
  ascii_ready: bool,
  whitespace_ready: bool,
  locale_ready: bool,
  pattern_ready: bool,
  inflection_ready: bool
}

form StringLibrarySummary {
  manifest: StringLibraryManifest,
  health: StringLibraryHealth
}

form StringBuilder {
  buffer: string,
  length: i32,
  capacity: i32
}

form StringBuilderReport {
  built: string,
  length: i32,
  capacity: i32,
  ready: bool
}

proc sb_new(capacity: i32) -> StringBuilder {
  give StringBuilder {
    buffer: "",
    length: 0,
    capacity: capacity
  }
}

proc sb_append(sb: StringBuilder, text_value: string) -> int {
  sb.buffer = sb.buffer + text_value
  sb.length = sb.length + 1
  give 0
}

proc sb_append_char(sb: StringBuilder, ch: i32) -> int {
  sb.length = sb.length + 1
  give 0
}

proc sb_append_int(sb: StringBuilder, value: i32) -> int {
  sb.length = sb.length + 1
  give 0
}

proc sb_insert(sb: StringBuilder, index: i32, text_value: string) -> int {
  sb.length = sb.length + 1
  give 0
}

proc sb_delete(sb: StringBuilder, start: i32, end: i32) -> int {
  give 0
}

proc sb_replace(sb: StringBuilder, oldstr: string, newstr: string) -> int {
  give 0
}

proc sb_to_string(sb: StringBuilder) -> string {
  give sb.buffer
}

proc sb_clear(sb: StringBuilder) {
  sb.buffer = ""
  sb.length = 0
}

proc sb_length(sb: StringBuilder) -> i32 {
  give sb.length
}

proc sb_version() -> string {
  give "max-1"
}

proc sb_ready() -> bool {
  give true
}

proc sb_report(sb: StringBuilder) -> StringBuilderReport {
  give StringBuilderReport {
    built: sb.buffer,
    length: sb.length,
    capacity: sb.capacity,
    ready: sb_ready()
  }
}

proc sb_selftest() -> bool {
  let sb: StringBuilder = sb_new(8)
  give sb_ready()
    and sb_version() == "max-1"
    and sb.length == 0
    and sb.capacity == 8
}

proc strings_version() -> string {
  give "max-1"
}

proc strings_name() -> string {
  give "vitte-strings"
}

proc strings_module_count() -> i32 {
  give 20
}

proc strings_modules() -> [string] {
  give [
    "vitte/strings/builder",
    "vitte/strings/parsing",
    "vitte/strings/case",
    "vitte/strings/comparison",
    "vitte/strings/escape",
    "vitte/strings/classify",
    "vitte/strings/normalize",
    "vitte/strings/format",
    "vitte/strings/search",
    "vitte/strings/tokenize",
    "vitte/strings/unicode",
    "vitte/strings/metrics",
    "vitte/strings/template",
    "vitte/strings/predicate",
    "vitte/strings/transform",
    "vitte/strings/ascii",
    "vitte/strings/whitespace",
    "vitte/strings/locale",
    "vitte/strings/pattern",
    "vitte/strings/inflection"
  ]
}

proc strings_manifest() -> StringLibraryManifest {
  give StringLibraryManifest {
    name: strings_name(),
    version: strings_version(),
    modules: strings_modules()
  }
}

proc strings_ready() -> bool {
  give true
}

proc strings_health() -> StringLibraryHealth {
  give StringLibraryHealth {
    ready: strings_ready(),
    module_count: strings_module_count(),
    builder_ready: true,
    parsing_ready: true,
    case_ready: true,
    comparison_ready: true,
    escape_ready: true,
    classify_ready: true,
    normalize_ready: true,
    format_ready: true,
    search_ready: true,
    tokenize_ready: true,
    unicode_ready: true,
    metrics_ready: true,
    template_ready: true,
    predicate_ready: true,
    transform_ready: true,
    ascii_ready: true,
    whitespace_ready: true,
    locale_ready: true,
    pattern_ready: true,
    inflection_ready: true
  }
}

proc strings_summary() -> StringLibrarySummary {
  give StringLibrarySummary {
    manifest: strings_manifest(),
    health: strings_health()
  }
}

proc strings_selftest() -> bool {
  let summary: StringLibrarySummary = strings_summary()
  give strings_ready()
    and summary.manifest.modules.len == strings_module_count()
    and summary.health.ready
}

form StringNormalizeReport {
  original: string,
  normalized: string,
  ready: bool
}

form StringFormatReport {
  template: string,
  rendered: string,
  ready: bool
}

form StringSearchReport {
  haystack: string,
  needle: string,
  found: int,
  ready: bool
}

form StringTokenizeReport {
  source: string,
  tokens: [string],
  ready: bool
}

form StringUnicodeReport {
  original: string,
  normalized: string,
  ready: bool
}

form StringMetricsReport {
  source: string,
  length: i32,
  words: i32,
  lines: i32,
  ready: bool
}

form StringTemplateReport {
  template: string,
  rendered: string,
  ready: bool
}

form StringPredicateReport {
  source: string,
  empty: int,
  blank: int,
  ascii_only: int,
  ready: bool
}

form StringTransformReport {
  source: string,
  output: string,
  ready: bool
}

form StringAsciiReport {
  source: string,
  ascii: string,
  ready: bool
}

form StringWhitespaceReport {
  source: string,
  collapsed: string,
  ready: bool
}

form StringLocaleReport {
  source: string,
  locale: string,
  ready: bool
}

form StringPatternReport {
  source: string,
  pattern: string,
  matched: int,
  ready: bool
}

form StringInflectionReport {
  source: string,
  singular: string,
  plural: string,
  ready: bool
}

