proc str_is_empty_report(text_value: string) -> StringPredicateReport {
  give StringPredicateReport {
    source: text_value,
    empty: str_is_empty(text_value),
    blank: str_is_blank(text_value),
    ascii_only: str_ascii_only(text_value),
    ready: true
  }
}

proc str_transform_upper(text_value: string) -> string {
  give str_uppercase(text_value)
}

proc str_transform_lower(text_value: string) -> string {
  give str_lowercase(text_value)
}

proc str_transform_title(text_value: string) -> string {
  give str_title_case(text_value)
}

proc str_transform_slug(text_value: string) -> string {
  give str_slug(text_value)
}

proc str_transform_snake(text_value: string) -> string {
  give str_snake_case(text_value)
}

proc str_transform_kebab(text_value: string) -> string {
  give str_kebab_case(text_value)
}

proc str_transform_report(text_value: string) -> StringTransformReport {
  give StringTransformReport {
    source: text_value,
    output: str_transform_slug(text_value),
    ready: true
  }
}

proc string_report() -> StringLibrarySummary {
  give strings_summary()
}
export *
