proc str_ascii_report(text_value: string) -> StringAsciiReport {
  give StringAsciiReport {
    source: text_value,
    ascii: str_ascii_strip(text_value),
    ready: true
  }
}

proc str_whitespace_report(text_value: string) -> StringWhitespaceReport {
  give StringWhitespaceReport {
    source: text_value,
    collapsed: str_whitespace_collapse(text_value),
    ready: true
  }
}

proc str_locale_report(text_value: string) -> StringLocaleReport {
  give StringLocaleReport {
    source: text_value,
    locale: str_locale_normalize(text_value),
    ready: true
