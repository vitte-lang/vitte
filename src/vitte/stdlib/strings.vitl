proc str_normalize_report(text_value: string) -> StringNormalizeReport {
  give StringNormalizeReport {
    original: text_value,
    normalized: str_normalize_whitespace(text_value),
    ready: true
  }
}

proc str_format_report(template: string) -> StringFormatReport {
  give StringFormatReport {
    template: template,
    rendered: template,
    ready: true
  }
}

proc str_search_report(haystack: string, needle: string) -> StringSearchReport {
  give StringSearchReport {
    haystack: haystack,
    needle: needle,
    found: str_index_of(haystack, needle),
    ready: true
  }
}

proc str_tokenize_report(text_value: string) -> StringTokenizeReport {
  give StringTokenizeReport {
    source: text_value,
    tokens: str_words(text_value),
    ready: true
  }
}

