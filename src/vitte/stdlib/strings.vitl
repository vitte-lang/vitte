}

proc str_pattern_report(text_value: string, pattern: string) -> StringPatternReport {
  give StringPatternReport {
    source: text_value,
    pattern: pattern,
    matched: str_pattern_match(text_value, pattern),
    ready: true
  }
}

proc str_inflection_report(text_value: string) -> StringInflectionReport {
  give StringInflectionReport {
    source: text_value,
    singular: str_singularize(text_value),
    plural: str_pluralize(text_value),
    ready: true
  }
}

