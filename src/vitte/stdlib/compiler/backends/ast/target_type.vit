space vitte/compiler/backends/ast/target_type

<<< ROLE-CONTRACT
package: vitte.compiler.backends.ast.target_type
role: bootstrap-vitte-backend-ast
source_of_truth: src/vitte/compiler/backends/ast/target_type.vit
status: bootstrap-vitte
boundary: structural data model for the migrated backend surface
>>>

pick TargetQualifier {
  Const,
  Volatile
}

pick TargetTypeKind {
  Builtin,
  Pointer,
  Reference,
  Array,
  Function,
  Struct,
  Enum,
  Alias
}

form TargetType {
  kind: TargetTypeKind,
  name: string,
  qualifiers: [TargetQualifier],
  pointee: ?TargetType,
  array_size: ?int,
  param_types: [TargetType],
  return_type: ?TargetType
}

proc builtin(name: string) -> TargetType {
  give TargetType { kind: TargetTypeKind.Builtin, name: name, qualifiers: [], pointee: null, array_size: null, param_types: [], return_type: null }
}

proc pointer(base: TargetType) -> TargetType {
  give TargetType { kind: TargetTypeKind.Pointer, name: "", qualifiers: [], pointee: base, array_size: null, param_types: [], return_type: null }
}

proc reference(base: TargetType) -> TargetType {
  give TargetType { kind: TargetTypeKind.Reference, name: "", qualifiers: [], pointee: base, array_size: null, param_types: [], return_type: null }
}

proc array_type(base: TargetType, size: int) -> TargetType {
  give TargetType { kind: TargetTypeKind.Array, name: "", qualifiers: [], pointee: base, array_size: size, param_types: [], return_type: null }
}

proc function_type(return_type: TargetType, param_types: [TargetType]) -> TargetType {
  give TargetType { kind: TargetTypeKind.Function, name: "", qualifiers: [], pointee: null, array_size: null, param_types: param_types, return_type: return_type }
}

proc user_type(name: string, kind: TargetTypeKind) -> TargetType {
  give TargetType { kind: kind, name: name, qualifiers: [], pointee: null, array_size: null, param_types: [], return_type: null }
}

proc add_const(type_value: TargetType) -> TargetType {
  give TargetType {
    kind: type_value.kind,
    name: type_value.name,
    qualifiers: type_value.qualifiers + [TargetQualifier.Const],
    pointee: type_value.pointee,
    array_size: type_value.array_size,
    param_types: type_value.param_types,
    return_type: type_value.return_type
  }
}

proc add_volatile(type_value: TargetType) -> TargetType {
  give TargetType {
    kind: type_value.kind,
    name: type_value.name,
    qualifiers: type_value.qualifiers + [TargetQualifier.Volatile],
    pointee: type_value.pointee,
    array_size: type_value.array_size,
    param_types: type_value.param_types,
    return_type: type_value.return_type
  }
}

proc is_const(type_value: TargetType) -> bool {
  let i: int = 0
  while i < type_value.qualifiers.len {
    if type_value.qualifiers[i] == TargetQualifier.Const {
      give true
    }
    set i = i + 1
  }
  give false
}

export *
