space vitte/compiler/driver/options

form DriverOptions {
  target: string,
  output: string,
  emit_only: bool,
  optimize: bool,
  debug: bool,
  work_dir: string
}

proc default_options() -> DriverOptions {
  give DriverOptions {
    target: "",
    output: "a.out",
    emit_only: true,
    optimize: false,
    debug: false,
    work_dir: "."
  }
}

export *
