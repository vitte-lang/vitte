space vitte/core

use vitte/stdlib/core { * }

proc string_concat(a: string, b: string) -> string {
  give a + b
}

proc string_from_int(value: int) -> string {
  give to_string_int(value)
}

proc string_from_i64(value: i64) -> string {
  give to_string_i64(value)
}

proc string_from_bool(value: bool) -> string {
  give to_string_bool(value)
}

export *
