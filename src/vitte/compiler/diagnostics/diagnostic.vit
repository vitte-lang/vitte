    let found_text: string = found_position as string;
    let diag0: Diagnostic = diagnostic_error("TYPECK_E_ARGUMENT_ORDER", DiagnosticPhase.Typeck, "argument `" + argument_name + "` is in position " + found_text + " but proc `" + proc_name + "` expects it at position " + expected_text, span);
    let diag1: Diagnostic = diagnostic_with_rule(diag0, "proc argument order");
    give diagnostic_with_help(diag1, "move this argument to the expected position or use canonical named arguments when supported");
}

