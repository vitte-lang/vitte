}

proc typeck_proc_argument_arity(proc_name: string, expected_params: string, expected_arity: u64, found_arity: u64, span: SourceSpan) -> Diagnostic {
    let expected_text: string = expected_arity as string;
    let found_text: string = found_arity as string;
    let diag0: Diagnostic = diagnostic_error("TYPECK_E_CALL_ARITY", DiagnosticPhase.Typeck, "proc `" + proc_name + "` expects " + expected_text + " argument(s) but the call provides " + found_text, span);
    let diag1: Diagnostic = diagnostic_with_rule(diag0, "proc parameter arity");
    let diag2: Diagnostic = diagnostic_add_cause(diag1, "expected parameters: " + expected_params);
    give diagnostic_with_help(diag2, "rewrite the call so each provided argument maps to one expected parameter");
}

