    let diag0: Diagnostic = diagnostic_error("TYPECK_E_ARGUMENT_MISMATCH", DiagnosticPhase.Typeck, "argument for parameter `" + parameter_name + "` of proc `" + proc_name + "` expects `" + expected + "` but receives `" + found + "`", arg_span);
