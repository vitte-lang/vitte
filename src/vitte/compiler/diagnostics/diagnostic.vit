<<<
    Vitte compiler diagnostics core.

    Note:
      Canonical diagnostics path.
      Legacy typo path removed.
>>>

space vitte/compiler/diagnostics/diagnostic

use vitte/stdlib/io/fileops.{ is_file, read_file }
use vitte/compiler/infrastructure/diagnostics/fluent_catalog.{ fluent_catalog_lookup, fluent_catalog_normalize_locale }

const DIAGNOSTIC_SCHEMA_VERSION: string = "1.0.0"
const DIAGNOSTIC_USER_COLUMN_BASE: u64 = 1
const DIAGNOSTIC_USER_COLUMN_UNIT: string = "visual_unicode_column"
const DIAGNOSTIC_INTERNAL_OFFSET_UNIT: string = "utf8_byte_offset"
const DIAGNOSTIC_TAB_WIDTH: u64 = 4
const DIAGNOSTIC_CONFIDENCE_HIGH: string = "high"
const DIAGNOSTIC_CONFIDENCE_MEDIUM: string = "medium"
const DIAGNOSTIC_CONFIDENCE_LOW: string = "low"

pick DiagnosticSeverity {
    Help
    Note
    Warning
    Error
    Fatal
}

pick DiagnosticPhase {
    Lexer
    Parser
    Ast
    AstValidation
    ModuleResolution
    SymbolResolution
    Sema
    Hir
    Typeck
    Borrowck
    Lifetime
    Mir
    MirLowering
    MirVerification
    Ir
    Backend
    Linker
    RuntimeExecution
    Driver
    Internal
    Unknown
}

pick DiagnosticStyle {
    Plain
    Short
    Text
    Human
    Json
    Lsp
    Sarif
    Debug
}

pick DiagnosticLabelKind {
    Primary
    Secondary
    Context
    Previous
    Related
}

pick DiagnosticSuggestionKind {
    Insert
    Replace
    Remove
    Help
}

pick DiagnosticApplicability {
    Machine
    MaybeMachine
    Manual
}

pick DiagnosticFixKind {
    Insert
    Replace
    Remove
    Import
    Rename
    Convert
    Reorder
    ScopeSplit
    Help
}

pick DiagnosticKind {
    User
    Configuration
    Environment
    Linker
    InternalCompiler
}

form SourceSpan {
    file: string
    start_line: u64
    start_column: u64
    end_line: u64
    end_column: u64
    length: u64
    valid: bool
}

form PrimarySpan {
    span: SourceSpan
    message: string
    valid: bool
}

form SecondarySpan {
    span: SourceSpan
    message: string
    valid: bool
}

form DiagnosticLabel {
    kind: DiagnosticLabelKind
    message: string
    span: SourceSpan
    primary: bool
    valid: bool
}

form DiagnosticNote {
    message: string
    valid: bool
}

form DiagnosticHelp {
    message: string
    valid: bool
}

form DiagnosticSuggestion {
    kind: DiagnosticSuggestionKind
    message: string
    replacement: string
    span: SourceSpan
    secondary_spans: [SourceSpan]
    machine_applicable: bool
    applicability: DiagnosticApplicability
    confidence: string
    reason: string
    valid: bool
}

form DiagnosticFixPlan {
    id: string
    kind: DiagnosticFixKind
    message: string
    replacement: string
    span: SourceSpan
    secondary_spans: [SourceSpan]
    machine_applicable: bool
    confidence: string
    reason: string
    valid: bool
}

form DiagnosticCausalitySummary {
    root_count: u64
    cascade_count: u64
    suppressed_cascade_count: u64
    duplicate_count: u64
    summary: string
    valid: bool
}

form DiagnosticQuality {
    score: u64
    span_score: u64
    context_score: u64
    fix_score: u64
    stability_score: u64
    cascade_score: u64
    valid: bool
}

form Diagnostic {
    code: string
    kind: DiagnosticKind
    phase: DiagnosticPhase
    severity: DiagnosticSeverity
    title: string
    rule: string
    message: string
    explanation: string
    technical_note: string
    labels: [DiagnosticLabel]
    secondary_spans: [SourceSpan]
    notes: [DiagnosticNote]
    helps: [DiagnosticHelp]
    suggestions: [DiagnosticSuggestion]
    documentation_url: string
    root_cause: string
    cause_chain: [string]
    pipeline_context: [string]
    related_errors: [string]
    probable_fix: string
    subject_symbol: string
    subject_type: string
    subject_borrow: string
    external_command: string
    external_stderr: string
    internal_operation: string
    reproduction: string
    valid_example: string
    invalid_example: string
    primary_error_key: string
    cascade_of: string
    primary_span: SourceSpan
    span: SourceSpan
    file_id: u64
    internal_cause: string
    primary_error: bool
    cascade: bool
    suppressed: bool
    duplicate: bool
    recovery_possible: bool
    deprecated: bool
    unnecessary: bool
    fatal: bool
    valid: bool
}

form DiagnosticReport {
    diagnostics: [Diagnostic]
    valid: bool
    warning_count: u64
    error_count: u64
    fatal_count: u64
    root_count: u64
    cascade_count: u64
    suppressed_cascade_count: u64
    duplicate_count: u64
    recovery_possible: bool
    quality_score: u64
}

form DiagnosticEnvelope {
    schema: string
    schema_version: string
    producer: string
    command: string
    source: string
    report: DiagnosticReport
    valid: bool
}

form DiagnosticRenderConfig {
    style: DiagnosticStyle
    show_code: bool
    show_phase: bool
    show_notes: bool
    show_helps: bool
    show_suggestions: bool
    verbose: bool
    color: bool
}

proc span_empty() -> SourceSpan {
    give SourceSpan {
        file: "",
        start_line: 0,
        start_column: 0,
        end_line: 0,
        end_column: 0,
        length: 1,
        valid: false
    };
}

proc diagnostic_schema_version() -> string {
    give DIAGNOSTIC_SCHEMA_VERSION;
}

proc diagnostic_envelope(producer: string, command: string, source: string, report: DiagnosticReport) -> DiagnosticEnvelope {
    give DiagnosticEnvelope {
        schema: "vitte.diagnostics",
        schema_version: diagnostic_schema_version(),
        producer: producer,
        command: command,
        source: source,
        report: report,
        valid: report.valid
    };
}

proc span_create(file: string, line: u64, column: u64, length: u64) -> SourceSpan {
    let normalized_length: u64 = length;

    if normalized_length == 0 {
        set normalized_length = 1 as u64;
    }

    give SourceSpan {
        file: file,
        start_line: line,
        start_column: column,
        end_line: line,
        end_column: column + normalized_length,
        length: normalized_length,
        valid: file != "" and line > 0 and column > 0
    };
}

proc span_range(file: string, start_line: u64, start_column: u64, end_line: u64, end_column: u64) -> SourceSpan {
    let length: u64 = 1;

    if end_line == start_line and end_column > start_column {
        set length = end_column - start_column;
    }

    give SourceSpan {
        file: file,
        start_line: start_line,
        start_column: start_column,
        end_line: end_line,
        end_column: end_column,
        length: length,
        valid: file != "" and start_line > 0 and start_column > 0
    };
}

proc severity_name(severity: DiagnosticSeverity) -> string {
    if severity == DiagnosticSeverity.Help {
        give "help";
    }

    if severity == DiagnosticSeverity.Note {
        give "note";
    }

    if severity == DiagnosticSeverity.Warning {
        give "warning";
    }

    if severity == DiagnosticSeverity.Fatal {
        give "fatal";
    }

    give "error";
}

proc phase_name(phase: DiagnosticPhase) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "lexer";
    }

    if phase == DiagnosticPhase.Parser {
        give "parser";
    }

    if phase == DiagnosticPhase.Ast {
        give "ast";
    }

    if phase == DiagnosticPhase.AstValidation {
        give "ast_validation";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "module_resolution";
    }

    if phase == DiagnosticPhase.SymbolResolution {
        give "symbol_resolution";
    }

    if phase == DiagnosticPhase.Sema {
        give "sema";
    }

    if phase == DiagnosticPhase.Hir {
        give "hir";
    }

    if phase == DiagnosticPhase.Typeck {
        give "typeck";
    }

    if phase == DiagnosticPhase.Borrowck {
        give "borrowck";
    }

    if phase == DiagnosticPhase.Lifetime {
        give "lifetime";
    }

    if phase == DiagnosticPhase.Mir {
        give "mir";
    }

    if phase == DiagnosticPhase.MirLowering {
        give "mir_lowering";
    }

    if phase == DiagnosticPhase.MirVerification {
        give "mir_verification";
    }

    if phase == DiagnosticPhase.Ir {
        give "ir";
    }

    if phase == DiagnosticPhase.Backend {
        give "backend";
    }

    if phase == DiagnosticPhase.Linker {
        give "linker";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "runtime_execution";
    }

    if phase == DiagnosticPhase.Driver {
        give "driver";
    }

    if phase == DiagnosticPhase.Internal {
        give "internal";
    }

    give "unknown";
}

proc diagnostic_kind_name(kind: DiagnosticKind) -> string {
    if kind == DiagnosticKind.User {
        give "user";
    }

    if kind == DiagnosticKind.Configuration {
        give "configuration";
    }

    if kind == DiagnosticKind.Environment {
        give "environment";
    }

    if kind == DiagnosticKind.Linker {
        give "linker";
    }

    give "internal_compiler";
}

proc severity_is_error(severity: DiagnosticSeverity) -> bool {
    give severity == DiagnosticSeverity.Error
        or severity == DiagnosticSeverity.Fatal;
}

proc severity_is_fatal(severity: DiagnosticSeverity) -> bool {
    give severity == DiagnosticSeverity.Fatal;
}

proc label_kind_name(kind: DiagnosticLabelKind) -> string {
    if kind == DiagnosticLabelKind.Primary {
        give "primary";
    }

    if kind == DiagnosticLabelKind.Secondary {
        give "secondary";
    }

    if kind == DiagnosticLabelKind.Context {
        give "context";
    }

    if kind == DiagnosticLabelKind.Previous {
        give "previous";
    }

    give "related";
}

proc suggestion_kind_name(kind: DiagnosticSuggestionKind) -> string {
    if kind == DiagnosticSuggestionKind.Insert {
        give "insert";
    }

    if kind == DiagnosticSuggestionKind.Replace {
        give "replace";
    }

    if kind == DiagnosticSuggestionKind.Remove {
        give "remove";
    }

    give "help";
}

proc applicability_name(applicability: DiagnosticApplicability) -> string {
    if applicability == DiagnosticApplicability.Machine {
        give "machine";
    }

    if applicability == DiagnosticApplicability.MaybeMachine {
        give "maybe_machine";
    }

    give "manual";
}

proc fix_kind_name(kind: DiagnosticFixKind) -> string {
    if kind == DiagnosticFixKind.Insert {
        give "insert";
    }

    if kind == DiagnosticFixKind.Replace {
        give "replace";
    }

    if kind == DiagnosticFixKind.Remove {
        give "remove";
    }

    if kind == DiagnosticFixKind.Import {
        give "import";
    }

    if kind == DiagnosticFixKind.Rename {
        give "rename";
    }

    if kind == DiagnosticFixKind.Convert {
        give "convert";
    }

    if kind == DiagnosticFixKind.Reorder {
        give "reorder";
    }

    if kind == DiagnosticFixKind.ScopeSplit {
        give "scope-split";
    }

    give "help";
}

proc diagnostic_label(kind: DiagnosticLabelKind, message: string, span: SourceSpan) -> DiagnosticLabel {
    give DiagnosticLabel {
        kind: kind,
        message: message,
        span: span,
        primary: kind == DiagnosticLabelKind.Primary,
        valid: message != "" and span.valid
    };
}

proc primary_span(span: SourceSpan, message: string) -> PrimarySpan {
    give PrimarySpan {
        span: span,
        message: message,
        valid: span.valid and message != ""
    };
}

proc secondary_span(span: SourceSpan, message: string) -> SecondarySpan {
    give SecondarySpan {
        span: span,
        message: message,
        valid: span.valid and message != ""
    };
}

proc primary_span_label(value: PrimarySpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Primary, value.message, value.span);
}

proc secondary_span_label(value: SecondarySpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Secondary, value.message, value.span);
}

proc primary_label(message: string, span: SourceSpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Primary, message, span);
}

proc secondary_label(message: string, span: SourceSpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Secondary, message, span);
}

proc previous_label(message: string, span: SourceSpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Previous, message, span);
}

proc diagnostic_note(message: string) -> DiagnosticNote {
    give DiagnosticNote {
        message: message,
        valid: message != ""
    };
}

proc diagnostic_help(message: string) -> DiagnosticHelp {
    give DiagnosticHelp {
        message: message,
        valid: message != ""
    };
}

proc diagnostic_suggestion(kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, machine_applicable: bool) -> DiagnosticSuggestion {
    let confidence: string = if machine_applicable { DIAGNOSTIC_CONFIDENCE_HIGH } else { DIAGNOSTIC_CONFIDENCE_LOW };
    give DiagnosticSuggestion {
        kind: kind,
        message: message,
        replacement: replacement,
        span: span,
        secondary_spans: [],
        machine_applicable: machine_applicable and replacement != "",
        applicability: if machine_applicable { DiagnosticApplicability.Machine } else { DiagnosticApplicability.Manual },
        confidence: confidence,
        reason: message,
        valid: message != "" and span.valid
    };
}

proc diagnostic_suggestion_applicability(kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, applicability: DiagnosticApplicability, confidence: string, reason: string) -> DiagnosticSuggestion {
    let machine_applicable: bool = applicability == DiagnosticApplicability.Machine;
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(kind, message, replacement, span, machine_applicable);
    let normalized_confidence: string = diagnostic_normalize_confidence(confidence, applicability, replacement);
    set suggestion.applicability = applicability;
    set suggestion.confidence = normalized_confidence;
    set suggestion.machine_applicable = machine_applicable and normalized_confidence == DIAGNOSTIC_CONFIDENCE_HIGH and replacement != "";

    if reason != "" {
        set suggestion.reason = reason;
    }

    give suggestion;
}

proc diagnostic_suggestion_detail(kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, machine_applicable: bool, confidence: string, reason: string) -> DiagnosticSuggestion {
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(kind, message, replacement, span, machine_applicable);
    let normalized_confidence: string = diagnostic_normalize_confidence(confidence, suggestion.applicability, replacement);
    set suggestion.confidence = normalized_confidence;

    if reason != "" {
        set suggestion.reason = reason;
    }

    // Contract: machine_applicable and suggestion.confidence == "high" and replacement != ""
    if machine_applicable and suggestion.confidence == DIAGNOSTIC_CONFIDENCE_HIGH and replacement != "" {
        set suggestion.applicability = DiagnosticApplicability.Machine;
        set suggestion.machine_applicable = true;
    } elif suggestion.confidence == DIAGNOSTIC_CONFIDENCE_MEDIUM {
        set suggestion.applicability = DiagnosticApplicability.MaybeMachine;
        set suggestion.machine_applicable = false;
    } else {
        set suggestion.applicability = DiagnosticApplicability.Manual;
        set suggestion.machine_applicable = false;
    }

    give suggestion;
}

proc diagnostic_normalize_confidence(confidence: string, applicability: DiagnosticApplicability, replacement: string) -> string {
    if confidence == DIAGNOSTIC_CONFIDENCE_HIGH and applicability == DiagnosticApplicability.Machine and replacement != "" {
        give DIAGNOSTIC_CONFIDENCE_HIGH;
    }

    if confidence == DIAGNOSTIC_CONFIDENCE_HIGH {
        give DIAGNOSTIC_CONFIDENCE_MEDIUM;
    }

    if confidence == DIAGNOSTIC_CONFIDENCE_MEDIUM {
        give DIAGNOSTIC_CONFIDENCE_MEDIUM;
    }

    if confidence == DIAGNOSTIC_CONFIDENCE_LOW {
        give DIAGNOSTIC_CONFIDENCE_LOW;
    }

    if applicability == DiagnosticApplicability.MaybeMachine {
        give DIAGNOSTIC_CONFIDENCE_MEDIUM;
    }

    give DIAGNOSTIC_CONFIDENCE_LOW;
}

proc diagnostic_suggestion_with_secondary_span(suggestion: DiagnosticSuggestion, span: SourceSpan) -> DiagnosticSuggestion {
    if not span.valid {
        give suggestion;
    }

    set suggestion.secondary_spans = suggestion.secondary_spans + [span];
    give suggestion;
}

proc diagnostic_suggestion_with_secondary_spans(suggestion: DiagnosticSuggestion, spans: [SourceSpan]) -> DiagnosticSuggestion {
    let out: DiagnosticSuggestion = suggestion;
    let i: u64 = 0;

    while i < len(spans) {
        set out = diagnostic_suggestion_with_secondary_span(out, spans[i]);
        set i = i + 1;
    }

    give out;
}

proc diagnostic_fix_kind_from_suggestion(suggestion: DiagnosticSuggestion) -> DiagnosticFixKind {
    if suggestion.kind == DiagnosticSuggestionKind.Insert {
        if find(suggestion.message, "import") >= 0 {
            give DiagnosticFixKind.Import;
        }

        give DiagnosticFixKind.Insert;
    }

    if suggestion.kind == DiagnosticSuggestionKind.Replace {
        if find(suggestion.message, "convert") >= 0 or find(suggestion.message, "explicit") >= 0 {
            give DiagnosticFixKind.Convert;
        }

        if find(suggestion.message, "rename") >= 0 {
            give DiagnosticFixKind.Rename;
        }

        if find(suggestion.message, "ownership") >= 0 or find(suggestion.message, "borrow") >= 0 {
            give DiagnosticFixKind.Reorder;
        }

        give DiagnosticFixKind.Replace;
    }

    if suggestion.kind == DiagnosticSuggestionKind.Remove {
        give DiagnosticFixKind.Remove;
    }

    if find(suggestion.message, "scope") >= 0 {
        give DiagnosticFixKind.ScopeSplit;
    }

    give DiagnosticFixKind.Help;
}

proc diagnostic_fix_plan_id(code: string, index: u64) -> string {
    let index_text: string = index as string;
    give code + "-fix-" + index_text;
}

proc diagnostic_fix_plan_from_suggestion(code: string, index: u64, suggestion: DiagnosticSuggestion) -> DiagnosticFixPlan {
    give DiagnosticFixPlan {
        id: diagnostic_fix_plan_id(code, index),
        kind: diagnostic_fix_kind_from_suggestion(suggestion),
        message: suggestion.message,
        replacement: suggestion.replacement,
        span: suggestion.span,
        secondary_spans: suggestion.secondary_spans,
        machine_applicable: suggestion.machine_applicable,
        confidence: suggestion.confidence,
        reason: suggestion.reason,
        valid: suggestion.valid
    };
}

proc diagnostic_multispan_fix_plan(code: string, message: string, replacement: string, primary_span: SourceSpan, secondary_spans: [SourceSpan], confidence: string) -> DiagnosticFixPlan {
    let suggestion0: DiagnosticSuggestion = diagnostic_suggestion_detail(DiagnosticSuggestionKind.Replace, message, replacement, primary_span, confidence == "high", confidence, "multi-span correction updates every related location together");
    let suggestion1: DiagnosticSuggestion = diagnostic_suggestion_with_secondary_spans(suggestion0, secondary_spans);
    give diagnostic_fix_plan_from_suggestion(code, 0 as u64, suggestion1);
}

proc diagnostic_fix_plans(diagnostic: Diagnostic) -> [DiagnosticFixPlan] {
    let plans: [DiagnosticFixPlan] = [];
    let i: u64 = 0;

    while i < len(diagnostic.suggestions) {
        set plans = plans + [diagnostic_fix_plan_from_suggestion(diagnostic.code, i, diagnostic.suggestions[i])];
        set i = i + 1;
    }

    give plans;
}

proc diagnostic_default_rule(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "ICE") {
        give "internal compiler invariant";
    }

    if code == "PATTR003" {
        give "attribute placement";
    }

    if code == "P000_UNBALANCED" {
        give "delimiter balance";
    }

    if code == "E0001" {
        give "identifier grammar";
    }

    if code == "E0002" {
        give "expression grammar";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "assignment compatibility";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "proc argument compatibility";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "proc call arity";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "moved value access";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "exclusive access discipline";
    }

    if phase == DiagnosticPhase.Lexer {
        give "lexical token formation";
    }

    if phase == DiagnosticPhase.Parser {
        give "syntax tree construction";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "abstract syntax invariants";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "module graph resolution";
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give "semantic name and scope validation";
    }

    if phase == DiagnosticPhase.Hir {
        give "high-level intermediate representation validation";
    }

    if phase == DiagnosticPhase.Typeck {
        give "type compatibility";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership and lifetime safety";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give "middle IR correctness";
    }

    if phase == DiagnosticPhase.Ir {
        give "intermediate representation correctness";
    }

    if phase == DiagnosticPhase.Backend {
        give "backend emission contract";
    }

    if phase == DiagnosticPhase.Linker {
        give "link artifact contract";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "runtime execution contract";
    }

    if phase == DiagnosticPhase.Driver {
        give "compiler driver contract";
    }

    give "compiler diagnostic contract";
}

proc diagnostic_default_explanation(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "ICE") {
        give "The compiler violated one of its own internal invariants. This is not a user-program error.";
    }

    if code == "PATTR003" {
        give "An attribute block was parsed without a declaration following it, so the compiler cannot decide which item the attribute configures.";
    }

    if code == "P000_UNBALANCED" {
        give "A syntactic block was opened but not closed before the parser reached the recovery point.";
    }

    if code == "E0001" {
        give "The grammar requires an identifier at this position, but the current token cannot name a declaration, binding, field, or item.";
    }

    if code == "E0002" {
        give "The grammar requires an expression here, but the current token cannot start a literal, name, call, block, or grouped expression.";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "The assigned value does not satisfy the declared or inferred type of the assignment target.";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "A proc call argument does not satisfy the corresponding parameter type contract.";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "The proc call site provides a different number of arguments than the callee accepts.";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "A value is used after ownership has already been transferred away from this location.";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" {
        give "A mutable borrow was requested while another borrow still keeps the same value unavailable for exclusive access.";
    }

    if code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "A shared borrow was requested while mutable access is still active.";
    }

    if phase == DiagnosticPhase.Lexer {
        give "The lexer could not turn this source range into a stable token stream.";
    }

    if phase == DiagnosticPhase.Parser {
        give "The parser found a syntax problem while building the syntax tree, and the diagnostic includes context to guide the next correction.";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "The parsed syntax tree violates a structural invariant required before semantic analysis can continue.";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "The compiler could not resolve the module or import graph needed by this source.";
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give "Semantic analysis could not prove that this name, scope, or declaration is valid in the current context.";
    }

    if phase == DiagnosticPhase.Hir {
        give "The high-level IR contains a malformed node or unresolved semantic property.";
    }

    if phase == DiagnosticPhase.Typeck {
        give "Type checking found values, expressions, or declarations that do not satisfy the expected type contract.";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "Ownership analysis found an access pattern that cannot be proven safe with the current lifetimes.";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give "The middle IR could not be lowered or verified while preserving the required control-flow and data-flow invariants.";
    }

    if phase == DiagnosticPhase.Ir {
        give "The compiler IR is missing an invariant required by later optimization or code generation stages.";
    }

    if phase == DiagnosticPhase.Backend {
        give "The backend could not emit the requested target artifact from the verified compiler representation.";
    }

    if phase == DiagnosticPhase.Linker {
        give "The linker could not assemble the expected final artifact from backend outputs and external symbols.";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "The runtime execution step reported a failure after compilation reached executable form.";
    }

    if phase == DiagnosticPhase.Driver {
        give "The compiler driver rejected the request before or during pipeline orchestration.";
    }

    give "The compiler found an internal diagnostic condition that needs explicit handling.";
}

proc diagnostic_default_root_cause(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "ICE") {
        give "internal compiler defect";
    }

    if code == "PATTR003" {
        give "attribute prefix has no declaration target";
    }

    if code == "P000_UNBALANCED" {
        give "opening delimiter has no matching closing delimiter";
    }

    if code == "E0001" {
        give "expected identifier slot is occupied by a non-identifier token";
    }

    if code == "E0002" {
        give "expected expression slot is occupied by a token that cannot start an expression";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "assignment target imposes one type while the assigned expression produces another";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "proc call argument type does not match the parameter type";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "proc call argument count differs from the callee signature";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "ownership was moved before the later use";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "active borrow lifetime overlaps a later access requiring a different permission";
    }

    if phase == DiagnosticPhase.Lexer {
        give "source bytes do not match the lexical grammar";
    }

    if phase == DiagnosticPhase.Parser {
        give "token stream cannot form the expected syntax construct";
    }

    if phase == DiagnosticPhase.Typeck {
        give "actual type information does not match the required type contract";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership or lifetime constraints would be violated";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "artifact production failed after semantic analysis";
    }

    if phase == DiagnosticPhase.Driver {
        give "compiler invocation or pipeline configuration is invalid";
    }

    give phase_name(phase) + " phase rejected the current compiler state";
}

proc diagnostic_default_probable_fix(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "ICE") {
        give "rerun the same command with the same input and report the stable ICE identifier";
    }

    if code == "PATTR003" {
        give "attach the attribute to the next declaration or remove the standalone attribute block";
    }

    if code == "P000_UNBALANCED" {
        give "insert the missing closing delimiter at the end of the intended block";
    }

    if code == "E0001" {
        give "insert a valid identifier that names the declaration, binding, field, or item required here";
    }

    if code == "E0002" {
        give "insert an expression such as a literal, name, call, block, or grouped expression";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "change the assigned value, convert it explicitly, or change the target type";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "pass a value whose type matches the parameter or change the callee signature";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "add or remove call arguments until the call matches the callee signature";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "borrow before the move, clone intentionally, or reinitialize the value before this use";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "end the active borrow before this access or narrow the scope that keeps it alive";
    }

    if phase == DiagnosticPhase.Lexer {
        give "rewrite the highlighted source so it matches the lexical grammar";
    }

    if phase == DiagnosticPhase.Parser {
        give "repair the syntax near the primary span, then re-run the check to reveal later errors";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "reduce the malformed construct to valid syntax and rebuild the AST";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "fix the module path, import target, or package layout referenced by this source";
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give "declare, import, rename, or move the symbol so it is visible at this point";
    }

    if phase == DiagnosticPhase.Hir {
        give "fix the source construct that lowered into malformed HIR";
    }

    if phase == DiagnosticPhase.Typeck {
        give "align the expression type with the expected type, or change the declaration to match the value";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "shorten the borrow, move ownership earlier or later, clone explicitly, or keep the owner alive longer";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give "fix the source or lowering rule that produced invalid control-flow or data-flow";
    }

    if phase == DiagnosticPhase.Ir {
        give "repair the malformed IR input before backend selection";
    }

    if phase == DiagnosticPhase.Backend {
        give "select a supported target/backend pair or fix the codegen input that triggered emission failure";
    }

    if phase == DiagnosticPhase.Linker {
        give "ensure required object files, libraries, and external symbols are produced and visible to the linker";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "inspect the runtime failure and reproduce it with the same compiled artifact";
    }

    if phase == DiagnosticPhase.Driver {
        give "fix the command, input path, target, or compiler option reported by the driver";
    }

    give "preserve this diagnostic with a minimal reproduction and route it to the owning compiler phase";
}

proc diagnostic_default_documentation(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "ICE") {
        give "docs://compiler/internal-compiler-errors";
    }

    if phase == DiagnosticPhase.Lexer {
        give "docs://language/lexer";
    }

    if phase == DiagnosticPhase.Parser {
        give "docs://language/parser";
    }

    if phase == DiagnosticPhase.Typeck {
        give "docs://language/type-system";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "docs://language/ownership";
    }

    if phase == DiagnosticPhase.Backend {
        give "docs://compiler/backend";
    }

    if phase == DiagnosticPhase.Linker {
        give "docs://compiler/linking";
    }

    if phase == DiagnosticPhase.Driver {
        give "docs://compiler/driver";
    }

    give "docs://compiler/diagnostics";
}

proc diagnostic_default_kind(phase: DiagnosticPhase, code: string) -> DiagnosticKind {
    if starts_with(code, "ICE") or phase == DiagnosticPhase.Internal {
        give DiagnosticKind.InternalCompiler;
    }

    if phase == DiagnosticPhase.Linker or starts_with(code, "LINK_E_") or starts_with(code, "LINKER_") {
        give DiagnosticKind.Linker;
    }

    if phase == DiagnosticPhase.Driver or starts_with(code, "DRIVER_") {
        give DiagnosticKind.Configuration;
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.RuntimeExecution {
        give DiagnosticKind.Environment;
    }

    give DiagnosticKind.User;
}

proc diagnostic_default_step(phase: DiagnosticPhase) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "tokenization";
    }

    if phase == DiagnosticPhase.Parser {
        give "syntax parsing";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "ast validation";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "module resolution";
    }

    if phase == DiagnosticPhase.SymbolResolution {
        give "symbol resolution";
    }

    if phase == DiagnosticPhase.Sema {
        give "semantic analysis";
    }

    if phase == DiagnosticPhase.Hir {
        give "hir validation";
    }

    if phase == DiagnosticPhase.Typeck {
        give "type checking";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership checking";
    }

    if phase == DiagnosticPhase.MirLowering {
        give "mir lowering";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirVerification {
        give "mir verification";
    }

    if phase == DiagnosticPhase.Ir {
        give "ir validation";
    }

    if phase == DiagnosticPhase.Backend {
        give "backend code generation";
    }

    if phase == DiagnosticPhase.Linker {
        give "link";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "runtime execution";
    }

    if phase == DiagnosticPhase.Driver {
        give "driver";
    }

    give "internal diagnostics";
}

proc diagnostic_default_note(phase: DiagnosticPhase, code: string) -> string {
    give "clear, contextual, and correction-oriented diagnostics";
}

proc diagnostic_code_family(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "LEX_") or starts_with(code, "FLEX") {
        give "lexical-form";
    }

    if code == "PATTR003" {
        give "attribute-target";
    }

    if code == "P000_UNBALANCED" {
        give "delimiter-balance";
    }

    if starts_with(code, "P") or starts_with(code, "E00") {
        give "syntax-shape";
    }

    if starts_with(code, "TYPECK_") {
        give "type-contract";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "ownership-flow";
    }

    if starts_with(code, "BACKEND_") or starts_with(code, "LINKER_") {
        give "artifact-production";
    }

    give phase_name(phase);
}

proc diagnostic_correction_strategy(phase: DiagnosticPhase, code: string) -> string {
    if code == "LEX_E_UNTERMINATED_STRING" or code == "LEX_E_UNTERMINATED_CHAR" or code == "P000_UNBALANCED" {
        give "close-open-construct";
    }

    if code == "PATTR003" {
        give "attach-or-remove-prefix";
    }

    if code == "E0001" {
        give "insert-identifier";
    }

    if code == "E0002" {
        give "insert-expression";
    }

    if starts_with(code, "TYPECK_") {
        give "align-contract";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "shorten-or-reorder-access";
    }

    if starts_with(code, "BACKEND_") or starts_with(code, "LINKER_") {
        give "repair-toolchain-or-artifact";
    }

    if phase == DiagnosticPhase.Lexer {
        give "rewrite-token";
    }

    if phase == DiagnosticPhase.Parser {
        give "repair-local-syntax";
    }

    give "inspect-primary-span";
}

proc diagnostic_recovery_scope(phase: DiagnosticPhase, code: string) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "current-token";
    }

    if code == "P000_UNBALANCED" {
        give "enclosing-block";
    }

    if phase == DiagnosticPhase.Parser {
        give "current-declaration";
    }

    if phase == DiagnosticPhase.Typeck {
        give "current-expression";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership-path";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "build-artifact";
    }

    give "current-phase";
}

proc diagnostic_confidence(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" or code == "P000_UNBALANCED" or code == "E0001" or code == "E0002" {
        give "high";
    }

    if starts_with(code, "LEX_") {
        give "high";
    }

    if starts_with(code, "TYPECK_") or starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "medium";
    }

    if phase == DiagnosticPhase.Internal {
        give "low";
    }

    give "medium";
}

proc diagnostic_default_help(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "attributes must be immediately followed by the declaration they configure";
    }

    if code == "P000_UNBALANCED" {
        give "compare the opening delimiter label with the primary span and close the intended block";
    }

    give "";
}

proc diagnostic_default_suggestion_kind(phase: DiagnosticPhase, code: string) -> DiagnosticSuggestionKind {
    if code == "PATTR003" {
        give DiagnosticSuggestionKind.Remove;
    }

    if code == "P000_UNBALANCED" or code == "E0001" or code == "E0002" {
        give DiagnosticSuggestionKind.Insert;
    }

    if phase == DiagnosticPhase.Lexer {
        give DiagnosticSuggestionKind.Replace;
    }

    give DiagnosticSuggestionKind.Help;
}

proc diagnostic_default_suggestion_replacement(phase: DiagnosticPhase, code: string) -> string {
    if code == "P000_UNBALANCED" {
        give "}";
    }

    if code == "E0001" {
        give "name";
    }

    if code == "E0002" {
        give "0";
    }

    give "";
}

proc diagnostic_default_suggestion_message(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "remove this standalone attribute or move it directly before a declaration";
    }

    if code == "P000_UNBALANCED" {
        give "insert the missing closing delimiter for the block";
    }

    if code == "E0001" {
        give "insert a placeholder identifier, then rename it to the intended symbol";
    }

    if code == "E0002" {
        give "insert a placeholder expression, then replace it with the intended value";
    }

    if phase == DiagnosticPhase.Lexer {
        give "rewrite the invalid token at this span";
    }

    give "";
}

proc diagnostic_default_step1(phase: DiagnosticPhase, code: string) -> string {
    if code == "E0001" {
        give "Insert or rename the identifier at the highlighted token, then re-run the same command.";
    }

    if code == "E0002" {
        give "Complete the missing expression at the highlighted token before changing later lines.";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "Compare the expected and found types, then change the smaller side of the assignment.";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "Start with the argument position named by the diagnostic and match it to the callee parameter.";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "Count the callee parameters and rewrite the call argument list to match that count.";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "Find the earlier move, then borrow, clone, or reorder before this later use.";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "Find the active borrow and shorten its scope before this access.";
    }

    if phase == DiagnosticPhase.Lexer or phase == DiagnosticPhase.Parser {
        give "Fix the first highlighted token or delimiter before following later diagnostics.";
    }

    if phase == DiagnosticPhase.Typeck {
        give "Read the expected/found labels and repair the first type contract mismatch.";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "Trace the earliest move or borrow in the labels, then repair that access order.";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "Check the first backend or linker note, then verify the selected target and native tools.";
    }

    if phase == DiagnosticPhase.Driver {
        give "Re-run with --help and verify the command, input path, output path, target, and profile.";
    }

    give "Fix the first span reported for this diagnostic, then run the command again.";
}

proc diagnostic_default_example(phase: DiagnosticPhase, code: string) -> string {
    if code == "E0001" or code == "E0002" {
        give "proc main() -> int { give 0; }";
    }

    if starts_with(code, "TYPECK_") {
        give "let count: int = 1";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "let view = &value";
    }

    if phase == DiagnosticPhase.Driver {
        give "vitte check src/main.vit --lang en";
    }

    give "vitte check path/to/file.vit";
}

proc diagnostic_default_invalid_example(phase: DiagnosticPhase, code: string) -> string {
    if code == "E0001" {
        give "proc () -> int { give 0; }";
    }

    if code == "E0002" {
        give "proc main() -> int { give ; }";
    }

    if code == "P000_UNBALANCED" {
        give "proc main() -> int { give 0;";
    }

    if starts_with(code, "TYPECK_") {
        give "let count: int = \"one\"";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "move(value); use(value)";
    }

    if phase == DiagnosticPhase.Driver {
        give "vitte check";
    }

    if phase == DiagnosticPhase.Lexer {
        give "\"unterminated";
    }

    give "<invalid Vitte source>";
}

proc diagnostic_primary_key(code: string, span: SourceSpan) -> string {
    give code + "@" + span.file + ":" + span.start_line as string + ":" + span.start_column as string;
}

proc diagnostic_phase_can_recover(phase: DiagnosticPhase) -> bool {
    if phase == DiagnosticPhase.Lexer or phase == DiagnosticPhase.Parser {
        give true;
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give true;
    }

    if phase == DiagnosticPhase.ModuleResolution or phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give true;
    }

    if phase == DiagnosticPhase.Typeck or phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give true;
    }

    give false;
}

proc diagnostic_default_suggestion(phase: DiagnosticPhase, code: string, span: SourceSpan) -> DiagnosticSuggestion {
    let kind: DiagnosticSuggestionKind = diagnostic_default_suggestion_kind(phase, code);
    let message: string = diagnostic_default_suggestion_message(phase, code);
    let replacement: string = diagnostic_default_suggestion_replacement(phase, code);
    let confidence: string = diagnostic_confidence(phase, code);
    let reason: string = diagnostic_correction_strategy(phase, code);
    let machine_applicable: bool = replacement != "" and confidence == "high";
    give diagnostic_suggestion_detail(kind, message, replacement, span, machine_applicable, confidence, reason);
}

proc diagnostic_suggestion_limit() -> u64 {
    give 3 as u64;
}

proc diagnostic_suggestion_rank(suggestion: DiagnosticSuggestion) -> u64 {
    if suggestion.applicability == DiagnosticApplicability.Machine {
        give 0 as u64;
    }

    if suggestion.confidence == "high" {
        give 1 as u64;
    }

    if suggestion.applicability == DiagnosticApplicability.MaybeMachine or suggestion.confidence == "medium" {
        give 2 as u64;
    }

    give 3 as u64;
}

proc vitte_canonical_keywords() -> [string] {
    give ["space", "use", "form", "pick", "proc", "let", "set", "give"];
}

proc vitte_legacy_keyword_replacement(keyword: string) -> string {
    if keyword == "namespace" or keyword == "module" {
        give "space";
    }

    if keyword == "import" {
        give "use";
    }

    if keyword == "class" or keyword == "struct" or keyword == "record" {
        give "form";
    }

    if keyword == "enum" {
        give "pick";
    }

    if keyword == "fn" or keyword == "function" {
        give "proc";
    }

    if keyword == "var" {
        give "let";
    }

    if keyword == "return" {
        give "give";
    }

    give "";
}

proc vitte_suggestion_is_canonical(replacement: string) -> bool {
    if replacement == "" {
        give true;
    }

    if find(replacement, "return") >= 0 or find(replacement, "fn(") >= 0 or find(replacement, "function") >= 0 {
        give false;
    }

    if find(replacement, "struct") >= 0 or find(replacement, "class") >= 0 or find(replacement, "enum") >= 0 or find(replacement, "var ") >= 0 {
        give false;
    }

    if find(replacement, "use module {") >= 0 or find(replacement, "todo()") >= 0 or find(replacement, "...") >= 0 {
        give false;
    }

    if find(replacement, "<") >= 0 or find(replacement, ">") >= 0 {
        give false;
    }

    give true;
}

proc diagnostic_suggestion_list_add(suggestions: [DiagnosticSuggestion], suggestion: DiagnosticSuggestion) -> [DiagnosticSuggestion] {
    if not suggestion.valid {
        give suggestions;
    }

    if not vitte_suggestion_is_canonical(suggestion.replacement) {
        give suggestions;
    }

    let out: [DiagnosticSuggestion] = [];
    let inserted: bool = false;
    let i: u64 = 0;
    let rank: u64 = diagnostic_suggestion_rank(suggestion);

    while i < len(suggestions) {
        if not inserted and rank < diagnostic_suggestion_rank(suggestions[i]) {
            set out = out + [suggestion];
            set inserted = true;
        }

        if len(out) < diagnostic_suggestion_limit() {
            set out = out + [suggestions[i]];
        }

        set i = i + 1;
    }

    if not inserted and len(out) < diagnostic_suggestion_limit() {
        set out = out + [suggestion];
    }

    give out;
}

proc diagnostic_suggestion_list_extend(suggestions: [DiagnosticSuggestion], extra: [DiagnosticSuggestion]) -> [DiagnosticSuggestion] {
    let out: [DiagnosticSuggestion] = suggestions;
    let i: u64 = 0;

    while i < len(extra) {
        set out = diagnostic_suggestion_list_add(out, extra[i]);
        set i = i + 1;
    }

    give out;
}

proc diagnostic_catalog_suggestions(phase: DiagnosticPhase, code: string, span: SourceSpan) -> [DiagnosticSuggestion] {
    if code == "P000_UNBALANCED" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Insert, "insert the missing closing delimiter", "}", span, DiagnosticApplicability.Machine, "high", "parser reported an unbalanced block"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "check the nearest opened block before this span", "", span, DiagnosticApplicability.Manual, "medium", "a later parser error may be a recovery artifact")
        ];
    }

    if code == "E0001" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Insert, "insert a placeholder identifier", "name", span, DiagnosticApplicability.MaybeMachine, "medium", "the parser expected an identifier-like token"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "rename the placeholder to the intended symbol after parsing succeeds", "", span, DiagnosticApplicability.Manual, "medium", "the compiler cannot infer the real name")
        ];
    }

    if code == "E0002" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Insert, "insert a placeholder expression", "0", span, DiagnosticApplicability.MaybeMachine, "medium", "the parser expected an expression"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "replace the placeholder with the intended value before committing", "", span, DiagnosticApplicability.Manual, "medium", "placeholder expressions preserve parsing but not intent")
        ];
    }

    if code == "PATTR003" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Remove, "remove this standalone attribute", "", span, DiagnosticApplicability.Machine, "high", "standalone attributes are not attached to a declaration"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "move the attribute directly before the declaration it describes", "", span, DiagnosticApplicability.Manual, "medium", "attributes apply to the next declaration")
        ];
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" or code == "TYPECK_E_ARGUMENT_MISMATCH" or code == "TYPECK_E_BINARY_MISMATCH" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Replace, "replace the expression with a value of the expected type", "", span, DiagnosticApplicability.Manual, "medium", "the expected and found types disagree"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "change the annotation only if the broader API contract is wrong", "", span, DiagnosticApplicability.Manual, "medium", "type fixes should preserve the declared contract")
        ];
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Replace, "rewrite the call argument list to match the callee signature", "", span, DiagnosticApplicability.Manual, "medium", "the call arity does not match the signature"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "inspect the callee declaration before adding or removing arguments", "", span, DiagnosticApplicability.Manual, "medium", "the diagnostic cannot choose the semantic argument")
        ];
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "borrow the value before the move when ownership is not needed", "", span, DiagnosticApplicability.Manual, "medium", "a moved value is unavailable at this use"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "clone or copy only when the type and cost make that explicit", "", span, DiagnosticApplicability.Manual, "low", "ownership repairs can change performance or semantics"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "reorder this use before the move if the control flow allows it", "", span, DiagnosticApplicability.Manual, "medium", "the later use depends on the earlier move")
        ];
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "shorten the active borrow scope before this access", "", span, DiagnosticApplicability.Manual, "medium", "the borrow window overlaps this operation"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "split the block so the borrow ends before mutation", "", span, DiagnosticApplicability.Manual, "medium", "scope boundaries determine borrow lifetime")
        ];
    }

    if phase == DiagnosticPhase.Lexer {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Replace, "rewrite the invalid token at this span", "", span, DiagnosticApplicability.Manual, "medium", "tokenization must succeed before parsing can recover")
        ];
    }

    give [];
}

proc diagnostic_suggestion_list(phase: DiagnosticPhase, code: string, span: SourceSpan) -> [DiagnosticSuggestion] {
    let out: [DiagnosticSuggestion] = diagnostic_catalog_suggestions(phase, code, span);
    let fallback: DiagnosticSuggestion = diagnostic_default_suggestion(phase, code, span);
    give diagnostic_suggestion_list_add(out, fallback);
}

proc diagnostic_phase_requires_user_span(phase: DiagnosticPhase) -> bool {
    give phase == DiagnosticPhase.Lexer
        or phase == DiagnosticPhase.Parser
        or phase == DiagnosticPhase.Ast
        or phase == DiagnosticPhase.AstValidation
        or phase == DiagnosticPhase.ModuleResolution
        or phase == DiagnosticPhase.SymbolResolution
        or phase == DiagnosticPhase.Sema
        or phase == DiagnosticPhase.Hir
        or phase == DiagnosticPhase.Typeck
        or phase == DiagnosticPhase.Borrowck
        or phase == DiagnosticPhase.Lifetime
        or phase == DiagnosticPhase.Mir
        or phase == DiagnosticPhase.MirLowering
        or phase == DiagnosticPhase.MirVerification
        or phase == DiagnosticPhase.Ir
        or phase == DiagnosticPhase.Backend
        or phase == DiagnosticPhase.Linker;
}

proc diagnostic_missing_user_span_code(code: string, phase: DiagnosticPhase, span: SourceSpan) -> string {
    if code == "ICE0001" or phase == DiagnosticPhase.Internal or span.valid {
        give code;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give "ICE0001";
    }
    give code;
}

proc diagnostic_missing_user_span_phase(phase: DiagnosticPhase, span: SourceSpan) -> DiagnosticPhase {
    if phase == DiagnosticPhase.Internal or span.valid {
        give phase;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give DiagnosticPhase.Internal;
    }
    give phase;
}

proc diagnostic_missing_user_span_severity(severity: DiagnosticSeverity, phase: DiagnosticPhase, span: SourceSpan) -> DiagnosticSeverity {
    if phase == DiagnosticPhase.Internal or span.valid {
        give severity;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give DiagnosticSeverity.Fatal;
    }
    give severity;
}

proc diagnostic_missing_user_span_message(message: string, code: string, phase: DiagnosticPhase, span: SourceSpan) -> string {
    if phase == DiagnosticPhase.Internal or span.valid {
        give message;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give "internal compiler error: diagnostic " + code + " from " + phase_name(phase) + " requires an exact source span";
    }
    give message;
}

proc diagnostic_create(code: string, phase: DiagnosticPhase, severity: DiagnosticSeverity, message: string, span: SourceSpan) -> Diagnostic {
    let effective_code: string = diagnostic_missing_user_span_code(code, phase, span);
    let effective_phase: DiagnosticPhase = diagnostic_missing_user_span_phase(phase, span);
    let effective_severity: DiagnosticSeverity = diagnostic_missing_user_span_severity(severity, phase, span);
    let effective_message: string = diagnostic_missing_user_span_message(message, code, phase, span);
    let default_note_text: string = diagnostic_default_note(effective_phase, effective_code);
    let default_help_text: string = diagnostic_default_help(effective_phase, effective_code);
    let default_suggestions: [DiagnosticSuggestion] = diagnostic_suggestion_list(effective_phase, effective_code, span);
    let phase_context: string = diag_kv("phase", phase_name(effective_phase));
    let step_context: string = diag_kv("step", diagnostic_default_step(effective_phase));
    let family_context: string = diag_kv("family", diagnostic_code_family(effective_phase, effective_code));
    let strategy_context: string = diag_kv("correction_strategy", diagnostic_correction_strategy(effective_phase, effective_code));
    let recovery_context: string = diag_kv("recovery_scope", diagnostic_recovery_scope(effective_phase, effective_code));
    let confidence_context: string = diag_kv("confidence", diagnostic_confidence(effective_phase, effective_code));
    let cause: string = if effective_code == "ICE0001" and code != "ICE0001" { "diagnostic producer emitted user-facing diagnostic without an exact source span" } else { diagnostic_default_root_cause(effective_phase, effective_code) };
    give Diagnostic {
        code: effective_code,
        kind: diagnostic_default_kind(effective_phase, effective_code),
        phase: effective_phase,
        severity: effective_severity,
        title: effective_message,
        rule: diagnostic_default_rule(effective_phase, effective_code),
        message: effective_message,
        explanation: diagnostic_default_explanation(effective_phase, effective_code),
        technical_note: "",
        labels: [primary_label(effective_message, span)],
        secondary_spans: [],
        notes: if default_note_text == "" { [] } else { [diagnostic_note(default_note_text)] },
        helps: if default_help_text == "" { [] } else { [diagnostic_help(default_help_text)] },
        suggestions: default_suggestions,
        documentation_url: diagnostic_default_documentation(effective_phase, effective_code),
        root_cause: cause,
        cause_chain: [],
        pipeline_context: [phase_context, step_context, family_context, strategy_context, recovery_context, confidence_context],
        related_errors: [],
        probable_fix: diagnostic_default_probable_fix(effective_phase, effective_code),
        subject_symbol: "",
        subject_type: "",
        subject_borrow: "",
        external_command: "",
        external_stderr: "",
        internal_operation: "",
        reproduction: "",
        valid_example: diagnostic_default_example(effective_phase, effective_code),
        invalid_example: diagnostic_default_invalid_example(effective_phase, effective_code),
        primary_error_key: diagnostic_primary_key(effective_code, span),
        cascade_of: "",
        primary_span: span,
        span: span,
        file_id: 0,
        internal_cause: cause,
        primary_error: true,
        cascade: false,
        suppressed: false,
        duplicate: false,
        recovery_possible: diagnostic_phase_can_recover(effective_phase) and not severity_is_fatal(effective_severity),
        deprecated: false,
        unnecessary: false,
        fatal: severity_is_fatal(effective_severity),
        valid: effective_code != "" and effective_message != ""
    };
}

proc diagnostic_with_rule(diagnostic: Diagnostic, rule: string) -> Diagnostic {
    if rule == "" {
        give diagnostic;
    }

    set diagnostic.rule = rule;
    give diagnostic;
