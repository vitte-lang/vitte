<<<
    Vitte compiler diagnostics core.

    Note:
      Canonical diagnostics path.
      Legacy typo path removed.
>>>

space vitte/compiler/diagnostics/diagnostic

use vitte/stdlib/io/fileops.{ is_file, read_file }
use vitte/compiler/infrastructure/diagnostics/fluent_catalog.{ fluent_catalog_lookup, fluent_catalog_normalize_locale }

const DIAGNOSTIC_SCHEMA_VERSION: string = "1.0.0"

pick DiagnosticSeverity {
    Help
    Note
    Warning
    Error
    Fatal
}

pick DiagnosticPhase {
    Lexer
    Parser
    Ast
    AstValidation
    ModuleResolution
    SymbolResolution
    Sema
    Hir
    Typeck
    Borrowck
    Lifetime
    Mir
    MirLowering
    MirVerification
    Ir
    Backend
    Linker
    RuntimeExecution
    Driver
    Internal
    Unknown
}

pick DiagnosticStyle {
    Plain
    Text
    Human
    Json
    Debug
}

pick DiagnosticLabelKind {
    Primary
    Secondary
    Context
    Previous
    Related
}

pick DiagnosticSuggestionKind {
    Insert
    Replace
    Remove
    Help
}

pick DiagnosticApplicability {
    Machine
    MaybeMachine
    Manual
}

pick DiagnosticFixKind {
    Insert
    Replace
    Remove
    Import
    Rename
    Convert
    Reorder
    ScopeSplit
    Help
}

form SourceSpan {
    file: string
    start_line: u64
    start_column: u64
    end_line: u64
    end_column: u64
    length: u64
    valid: bool
}

form DiagnosticLabel {
    kind: DiagnosticLabelKind
    message: string
    span: SourceSpan
    primary: bool
    valid: bool
}

form DiagnosticNote {
    message: string
    valid: bool
}

form DiagnosticHelp {
    message: string
    valid: bool
}

form DiagnosticSuggestion {
    kind: DiagnosticSuggestionKind
    message: string
    replacement: string
    span: SourceSpan
    machine_applicable: bool
    applicability: DiagnosticApplicability
    confidence: string
    reason: string
    valid: bool
}

form DiagnosticFixPlan {
    id: string
    kind: DiagnosticFixKind
    message: string
    replacement: string
    span: SourceSpan
    machine_applicable: bool
    confidence: string
    reason: string
    valid: bool
}

form DiagnosticCausalitySummary {
    root_count: u64
    cascade_count: u64
    suppressed_cascade_count: u64
    duplicate_count: u64
    summary: string
    valid: bool
}

form DiagnosticQuality {
    score: u64
    span_score: u64
    context_score: u64
    fix_score: u64
    stability_score: u64
    cascade_score: u64
    valid: bool
}

form Diagnostic {
    code: string
    phase: DiagnosticPhase
    severity: DiagnosticSeverity
    title: string
    rule: string
    message: string
    explanation: string
    technical_note: string
    labels: [DiagnosticLabel]
    secondary_spans: [SourceSpan]
    notes: [DiagnosticNote]
    helps: [DiagnosticHelp]
    suggestions: [DiagnosticSuggestion]
    documentation_url: string
    root_cause: string
    cause_chain: [string]
    pipeline_context: [string]
    related_errors: [string]
    probable_fix: string
    subject_symbol: string
    subject_type: string
    subject_borrow: string
    valid_example: string
    invalid_example: string
    primary_error_key: string
    cascade_of: string
    primary_span: SourceSpan
    span: SourceSpan
    file_id: u64
    internal_cause: string
    primary_error: bool
    cascade: bool
    suppressed: bool
    duplicate: bool
    recovery_possible: bool
    deprecated: bool
    unnecessary: bool
    fatal: bool
    valid: bool
}

form DiagnosticReport {
    diagnostics: [Diagnostic]
    valid: bool
    warning_count: u64
    error_count: u64
    fatal_count: u64
    root_count: u64
    cascade_count: u64
    suppressed_cascade_count: u64
    duplicate_count: u64
    recovery_possible: bool
    quality_score: u64
}

form DiagnosticEnvelope {
    schema: string
    schema_version: string
    producer: string
    command: string
    source: string
    report: DiagnosticReport
    valid: bool
}

form DiagnosticRenderConfig {
    style: DiagnosticStyle
    show_code: bool
    show_phase: bool
    show_notes: bool
    show_helps: bool
    show_suggestions: bool
    color: bool
}

proc span_empty() -> SourceSpan {
    give SourceSpan {
        file: "",
        start_line: 0,
        start_column: 0,
        end_line: 0,
        end_column: 0,
        length: 1,
        valid: false
    };
}

proc diagnostic_schema_version() -> string {
    give DIAGNOSTIC_SCHEMA_VERSION;
}

proc diagnostic_envelope(producer: string, command: string, source: string, report: DiagnosticReport) -> DiagnosticEnvelope {
    give DiagnosticEnvelope {
        schema: "vitte.diagnostics",
        schema_version: diagnostic_schema_version(),
        producer: producer,
        command: command,
        source: source,
        report: report,
        valid: report.valid
    };
}

proc span_create(file: string, line: u64, column: u64, length: u64) -> SourceSpan {
    let normalized_length: u64 = length;

    if normalized_length == 0 {
        set normalized_length = 1 as u64;
    }

    give SourceSpan {
        file: file,
        start_line: line,
        start_column: column,
        end_line: line,
        end_column: column + normalized_length,
        length: normalized_length,
        valid: file != "" and line > 0 and column > 0
    };
}

proc span_range(file: string, start_line: u64, start_column: u64, end_line: u64, end_column: u64) -> SourceSpan {
    let length: u64 = 1;

    if end_line == start_line and end_column > start_column {
        set length = end_column - start_column;
    }

    give SourceSpan {
        file: file,
        start_line: start_line,
        start_column: start_column,
        end_line: end_line,
        end_column: end_column,
        length: length,
        valid: file != "" and start_line > 0 and start_column > 0
    };
}

proc severity_name(severity: DiagnosticSeverity) -> string {
    if severity == DiagnosticSeverity.Help {
        give "help";
    }

    if severity == DiagnosticSeverity.Note {
        give "note";
    }

    if severity == DiagnosticSeverity.Warning {
        give "warning";
    }

    if severity == DiagnosticSeverity.Fatal {
        give "fatal";
    }

    give "error";
}

proc phase_name(phase: DiagnosticPhase) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "lexer";
    }

    if phase == DiagnosticPhase.Parser {
        give "parser";
    }

    if phase == DiagnosticPhase.Ast {
        give "ast";
    }

    if phase == DiagnosticPhase.AstValidation {
        give "ast_validation";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "module_resolution";
    }

    if phase == DiagnosticPhase.SymbolResolution {
        give "symbol_resolution";
    }

    if phase == DiagnosticPhase.Sema {
        give "sema";
    }

    if phase == DiagnosticPhase.Hir {
        give "hir";
    }

    if phase == DiagnosticPhase.Typeck {
        give "typeck";
    }

    if phase == DiagnosticPhase.Borrowck {
        give "borrowck";
    }

    if phase == DiagnosticPhase.Lifetime {
        give "lifetime";
    }

    if phase == DiagnosticPhase.Mir {
        give "mir";
    }

    if phase == DiagnosticPhase.MirLowering {
        give "mir_lowering";
    }

    if phase == DiagnosticPhase.MirVerification {
        give "mir_verification";
    }

    if phase == DiagnosticPhase.Ir {
        give "ir";
    }

    if phase == DiagnosticPhase.Backend {
        give "backend";
    }

    if phase == DiagnosticPhase.Linker {
        give "linker";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "runtime_execution";
    }

    if phase == DiagnosticPhase.Driver {
        give "driver";
    }

    if phase == DiagnosticPhase.Internal {
        give "internal";
    }

    give "unknown";
}

proc severity_is_error(severity: DiagnosticSeverity) -> bool {
    give severity == DiagnosticSeverity.Error
        or severity == DiagnosticSeverity.Fatal;
}

proc severity_is_fatal(severity: DiagnosticSeverity) -> bool {
    give severity == DiagnosticSeverity.Fatal;
}

proc label_kind_name(kind: DiagnosticLabelKind) -> string {
    if kind == DiagnosticLabelKind.Primary {
        give "primary";
    }

    if kind == DiagnosticLabelKind.Secondary {
        give "secondary";
    }

    if kind == DiagnosticLabelKind.Context {
        give "context";
    }

    if kind == DiagnosticLabelKind.Previous {
        give "previous";
    }

    give "related";
}

proc suggestion_kind_name(kind: DiagnosticSuggestionKind) -> string {
    if kind == DiagnosticSuggestionKind.Insert {
        give "insert";
    }

    if kind == DiagnosticSuggestionKind.Replace {
        give "replace";
    }

    if kind == DiagnosticSuggestionKind.Remove {
        give "remove";
    }

    give "help";
}

proc applicability_name(applicability: DiagnosticApplicability) -> string {
    if applicability == DiagnosticApplicability.Machine {
        give "machine";
    }

    if applicability == DiagnosticApplicability.MaybeMachine {
        give "maybe_machine";
    }

    give "manual";
}

proc fix_kind_name(kind: DiagnosticFixKind) -> string {
    if kind == DiagnosticFixKind.Insert {
        give "insert";
    }

    if kind == DiagnosticFixKind.Replace {
        give "replace";
    }

    if kind == DiagnosticFixKind.Remove {
        give "remove";
    }

    if kind == DiagnosticFixKind.Import {
        give "import";
    }

    if kind == DiagnosticFixKind.Rename {
        give "rename";
    }

    if kind == DiagnosticFixKind.Convert {
        give "convert";
    }

    if kind == DiagnosticFixKind.Reorder {
        give "reorder";
    }

    if kind == DiagnosticFixKind.ScopeSplit {
        give "scope-split";
    }

    give "help";
}

proc diagnostic_label(kind: DiagnosticLabelKind, message: string, span: SourceSpan) -> DiagnosticLabel {
    give DiagnosticLabel {
        kind: kind,
        message: message,
        span: span,
        primary: kind == DiagnosticLabelKind.Primary,
        valid: message != "" and span.valid
    };
}

proc primary_label(message: string, span: SourceSpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Primary, message, span);
}

proc secondary_label(message: string, span: SourceSpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Secondary, message, span);
}

proc previous_label(message: string, span: SourceSpan) -> DiagnosticLabel {
    give diagnostic_label(DiagnosticLabelKind.Previous, message, span);
}

proc diagnostic_note(message: string) -> DiagnosticNote {
    give DiagnosticNote {
        message: message,
        valid: message != ""
    };
}

proc diagnostic_help(message: string) -> DiagnosticHelp {
    give DiagnosticHelp {
        message: message,
        valid: message != ""
    };
}

proc diagnostic_suggestion(kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, machine_applicable: bool) -> DiagnosticSuggestion {
    let confidence: string = if machine_applicable { "high" } else { "low" };
    give DiagnosticSuggestion {
        kind: kind,
        message: message,
        replacement: replacement,
        span: span,
        machine_applicable: machine_applicable,
        applicability: if machine_applicable { DiagnosticApplicability.Machine } else { DiagnosticApplicability.Manual },
        confidence: confidence,
        reason: message,
        valid: message != "" and span.valid
    };
}

proc diagnostic_suggestion_applicability(kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, applicability: DiagnosticApplicability, confidence: string, reason: string) -> DiagnosticSuggestion {
    let machine_applicable: bool = applicability == DiagnosticApplicability.Machine;
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(kind, message, replacement, span, machine_applicable);
    set suggestion.applicability = applicability;

    if confidence != "" {
        set suggestion.confidence = confidence;
    } elif applicability == DiagnosticApplicability.MaybeMachine {
        set suggestion.confidence = "medium";
    } elif applicability == DiagnosticApplicability.Manual {
        set suggestion.confidence = "low";
    }

    if reason != "" {
        set suggestion.reason = reason;
    }

    give suggestion;
}

proc diagnostic_suggestion_detail(kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, machine_applicable: bool, confidence: string, reason: string) -> DiagnosticSuggestion {
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(kind, message, replacement, span, machine_applicable);

    if confidence != "" {
        set suggestion.confidence = confidence;
    }

    if reason != "" {
        set suggestion.reason = reason;
    }

    if machine_applicable {
        set suggestion.applicability = DiagnosticApplicability.Machine;
    } elif confidence == "medium" {
        set suggestion.applicability = DiagnosticApplicability.MaybeMachine;
    } else {
        set suggestion.applicability = DiagnosticApplicability.Manual;
    }

    give suggestion;
}

proc diagnostic_fix_kind_from_suggestion(suggestion: DiagnosticSuggestion) -> DiagnosticFixKind {
    if suggestion.kind == DiagnosticSuggestionKind.Insert {
        if find(suggestion.message, "import") >= 0 {
            give DiagnosticFixKind.Import;
        }

        give DiagnosticFixKind.Insert;
    }

    if suggestion.kind == DiagnosticSuggestionKind.Replace {
        if find(suggestion.message, "convert") >= 0 or find(suggestion.message, "explicit") >= 0 {
            give DiagnosticFixKind.Convert;
        }

        if find(suggestion.message, "rename") >= 0 {
            give DiagnosticFixKind.Rename;
        }

        if find(suggestion.message, "ownership") >= 0 or find(suggestion.message, "borrow") >= 0 {
            give DiagnosticFixKind.Reorder;
        }

        give DiagnosticFixKind.Replace;
    }

    if suggestion.kind == DiagnosticSuggestionKind.Remove {
        give DiagnosticFixKind.Remove;
    }

    if find(suggestion.message, "scope") >= 0 {
        give DiagnosticFixKind.ScopeSplit;
    }

    give DiagnosticFixKind.Help;
}

proc diagnostic_fix_plan_id(code: string, index: u64) -> string {
    let index_text: string = index as string;
    give code + "-fix-" + index_text;
}

proc diagnostic_fix_plan_from_suggestion(code: string, index: u64, suggestion: DiagnosticSuggestion) -> DiagnosticFixPlan {
    give DiagnosticFixPlan {
        id: diagnostic_fix_plan_id(code, index),
        kind: diagnostic_fix_kind_from_suggestion(suggestion),
        message: suggestion.message,
        replacement: suggestion.replacement,
        span: suggestion.span,
        machine_applicable: suggestion.machine_applicable,
        confidence: suggestion.confidence,
        reason: suggestion.reason,
        valid: suggestion.valid
    };
}

proc diagnostic_fix_plans(diagnostic: Diagnostic) -> [DiagnosticFixPlan] {
    let plans: [DiagnosticFixPlan] = [];
    let i: u64 = 0;

    while i < len(diagnostic.suggestions) {
        set plans = plans + [diagnostic_fix_plan_from_suggestion(diagnostic.code, i, diagnostic.suggestions[i])];
        set i = i + 1;
    }

    give plans;
}

proc diagnostic_default_rule(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "attribute placement";
    }

    if code == "P000_UNBALANCED" {
        give "delimiter balance";
    }

    if code == "E0001" {
        give "identifier grammar";
    }

    if code == "E0002" {
        give "expression grammar";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "assignment compatibility";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "function argument compatibility";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "function call arity";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "moved value access";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "exclusive access discipline";
    }

    if phase == DiagnosticPhase.Lexer {
        give "lexical token formation";
    }

    if phase == DiagnosticPhase.Parser {
        give "syntax tree construction";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "abstract syntax invariants";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "module graph resolution";
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give "semantic name and scope validation";
    }

    if phase == DiagnosticPhase.Hir {
        give "high-level intermediate representation validation";
    }

    if phase == DiagnosticPhase.Typeck {
        give "type compatibility";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership and lifetime safety";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give "middle IR correctness";
    }

    if phase == DiagnosticPhase.Ir {
        give "intermediate representation correctness";
    }

    if phase == DiagnosticPhase.Backend {
        give "backend emission contract";
    }

    if phase == DiagnosticPhase.Linker {
        give "link artifact contract";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "runtime execution contract";
    }

    if phase == DiagnosticPhase.Driver {
        give "compiler driver contract";
    }

    give "compiler diagnostic contract";
}

proc diagnostic_default_explanation(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "An attribute block was parsed without a declaration following it, so the compiler cannot decide which item the attribute configures.";
    }

    if code == "P000_UNBALANCED" {
        give "A syntactic block was opened but not closed before the parser reached the recovery point.";
    }

    if code == "E0001" {
        give "The grammar requires an identifier at this position, but the current token cannot name a declaration, binding, field, or item.";
    }

    if code == "E0002" {
        give "The grammar requires an expression here, but the current token cannot start a literal, name, call, block, or grouped expression.";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "The assigned value does not satisfy the declared or inferred type of the assignment target.";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "A call argument does not satisfy the corresponding parameter type contract.";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "The call site provides a different number of arguments than the callee accepts.";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "A value is used after ownership has already been transferred away from this location.";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" {
        give "A mutable borrow was requested while another borrow still keeps the same value unavailable for exclusive access.";
    }

    if code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "A shared borrow was requested while mutable access is still active.";
    }

    if phase == DiagnosticPhase.Lexer {
        give "The lexer could not turn this source range into a stable token stream.";
    }

    if phase == DiagnosticPhase.Parser {
        give "The parser found a syntax problem while building the syntax tree, and the diagnostic includes context to guide the next correction.";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "The parsed syntax tree violates a structural invariant required before semantic analysis can continue.";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "The compiler could not resolve the module or import graph needed by this source.";
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give "Semantic analysis could not prove that this name, scope, or declaration is valid in the current context.";
    }

    if phase == DiagnosticPhase.Hir {
        give "The high-level IR contains a malformed node or unresolved semantic property.";
    }

    if phase == DiagnosticPhase.Typeck {
        give "Type checking found values, expressions, or declarations that do not satisfy the expected type contract.";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "Ownership analysis found an access pattern that cannot be proven safe with the current lifetimes.";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give "The middle IR could not be lowered or verified while preserving the required control-flow and data-flow invariants.";
    }

    if phase == DiagnosticPhase.Ir {
        give "The compiler IR is missing an invariant required by later optimization or code generation stages.";
    }

    if phase == DiagnosticPhase.Backend {
        give "The backend could not emit the requested target artifact from the verified compiler representation.";
    }

    if phase == DiagnosticPhase.Linker {
        give "The linker could not assemble the expected final artifact from backend outputs and external symbols.";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "The runtime execution step reported a failure after compilation reached executable form.";
    }

    if phase == DiagnosticPhase.Driver {
        give "The compiler driver rejected the request before or during pipeline orchestration.";
    }

    give "The compiler found an internal diagnostic condition that needs explicit handling.";
}

proc diagnostic_default_root_cause(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "attribute prefix has no declaration target";
    }

    if code == "P000_UNBALANCED" {
        give "opening delimiter has no matching closing delimiter";
    }

    if code == "E0001" {
        give "expected identifier slot is occupied by a non-identifier token";
    }

    if code == "E0002" {
        give "expected expression slot is occupied by a token that cannot start an expression";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "assignment target imposes one type while the assigned expression produces another";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "call argument type does not match the parameter type";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "call argument count differs from the callee signature";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "ownership was moved before the later use";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "active borrow lifetime overlaps a later access requiring a different permission";
    }

    if phase == DiagnosticPhase.Lexer {
        give "source bytes do not match the lexical grammar";
    }

    if phase == DiagnosticPhase.Parser {
        give "token stream cannot form the expected syntax construct";
    }

    if phase == DiagnosticPhase.Typeck {
        give "actual type information does not match the required type contract";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership or lifetime constraints would be violated";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "artifact production failed after semantic analysis";
    }

    if phase == DiagnosticPhase.Driver {
        give "compiler invocation or pipeline configuration is invalid";
    }

    give phase_name(phase) + " phase rejected the current compiler state";
}

proc diagnostic_default_probable_fix(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "attach the attribute to the next declaration or remove the standalone attribute block";
    }

    if code == "P000_UNBALANCED" {
        give "insert the missing closing delimiter at the end of the intended block";
    }

    if code == "E0001" {
        give "insert a valid identifier that names the declaration, binding, field, or item required here";
    }

    if code == "E0002" {
        give "insert an expression such as a literal, name, call, block, or grouped expression";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "change the assigned value, convert it explicitly, or change the target type";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "pass a value whose type matches the parameter or change the callee signature";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "add or remove call arguments until the call matches the callee signature";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "borrow before the move, clone intentionally, or reinitialize the value before this use";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "end the active borrow before this access or narrow the scope that keeps it alive";
    }

    if phase == DiagnosticPhase.Lexer {
        give "rewrite the highlighted source so it matches the lexical grammar";
    }

    if phase == DiagnosticPhase.Parser {
        give "repair the syntax near the primary span, then re-run the check to reveal later errors";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "reduce the malformed construct to valid syntax and rebuild the AST";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "fix the module path, import target, or package layout referenced by this source";
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give "declare, import, rename, or move the symbol so it is visible at this point";
    }

    if phase == DiagnosticPhase.Hir {
        give "fix the source construct that lowered into malformed HIR";
    }

    if phase == DiagnosticPhase.Typeck {
        give "align the expression type with the expected type, or change the declaration to match the value";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "shorten the borrow, move ownership earlier or later, clone explicitly, or keep the owner alive longer";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give "fix the source or lowering rule that produced invalid control-flow or data-flow";
    }

    if phase == DiagnosticPhase.Ir {
        give "repair the malformed IR input before backend selection";
    }

    if phase == DiagnosticPhase.Backend {
        give "select a supported target/backend pair or fix the codegen input that triggered emission failure";
    }

    if phase == DiagnosticPhase.Linker {
        give "ensure required object files, libraries, and external symbols are produced and visible to the linker";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "inspect the runtime failure and reproduce it with the same compiled artifact";
    }

    if phase == DiagnosticPhase.Driver {
        give "fix the command, input path, target, or compiler option reported by the driver";
    }

    give "preserve this diagnostic with a minimal reproduction and route it to the owning compiler phase";
}

proc diagnostic_default_documentation(phase: DiagnosticPhase, code: string) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "docs://language/lexer";
    }

    if phase == DiagnosticPhase.Parser {
        give "docs://language/parser";
    }

    if phase == DiagnosticPhase.Typeck {
        give "docs://language/type-system";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "docs://language/ownership";
    }

    if phase == DiagnosticPhase.Backend {
        give "docs://compiler/backend";
    }

    if phase == DiagnosticPhase.Linker {
        give "docs://compiler/linking";
    }

    if phase == DiagnosticPhase.Driver {
        give "docs://compiler/driver";
    }

    give "docs://compiler/diagnostics";
}

proc diagnostic_default_step(phase: DiagnosticPhase) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "tokenization";
    }

    if phase == DiagnosticPhase.Parser {
        give "syntax parsing";
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give "ast validation";
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give "module resolution";
    }

    if phase == DiagnosticPhase.SymbolResolution {
        give "symbol resolution";
    }

    if phase == DiagnosticPhase.Sema {
        give "semantic analysis";
    }

    if phase == DiagnosticPhase.Hir {
        give "hir validation";
    }

    if phase == DiagnosticPhase.Typeck {
        give "type checking";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership checking";
    }

    if phase == DiagnosticPhase.MirLowering {
        give "mir lowering";
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirVerification {
        give "mir verification";
    }

    if phase == DiagnosticPhase.Ir {
        give "ir validation";
    }

    if phase == DiagnosticPhase.Backend {
        give "backend code generation";
    }

    if phase == DiagnosticPhase.Linker {
        give "link";
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give "runtime execution";
    }

    if phase == DiagnosticPhase.Driver {
        give "driver";
    }

    give "internal diagnostics";
}

proc diagnostic_default_note(phase: DiagnosticPhase, code: string) -> string {
    give "clear, contextual, and correction-oriented diagnostics";
}

proc diagnostic_code_family(phase: DiagnosticPhase, code: string) -> string {
    if starts_with(code, "LEX_") or starts_with(code, "FLEX") {
        give "lexical-form";
    }

    if code == "PATTR003" {
        give "attribute-target";
    }

    if code == "P000_UNBALANCED" {
        give "delimiter-balance";
    }

    if starts_with(code, "P") or starts_with(code, "E00") {
        give "syntax-shape";
    }

    if starts_with(code, "TYPECK_") {
        give "type-contract";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "ownership-flow";
    }

    if starts_with(code, "BACKEND_") or starts_with(code, "LINKER_") {
        give "artifact-production";
    }

    give phase_name(phase);
}

proc diagnostic_correction_strategy(phase: DiagnosticPhase, code: string) -> string {
    if code == "LEX_E_UNTERMINATED_STRING" or code == "LEX_E_UNTERMINATED_CHAR" or code == "P000_UNBALANCED" {
        give "close-open-construct";
    }

    if code == "PATTR003" {
        give "attach-or-remove-prefix";
    }

    if code == "E0001" {
        give "insert-identifier";
    }

    if code == "E0002" {
        give "insert-expression";
    }

    if starts_with(code, "TYPECK_") {
        give "align-contract";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "shorten-or-reorder-access";
    }

    if starts_with(code, "BACKEND_") or starts_with(code, "LINKER_") {
        give "repair-toolchain-or-artifact";
    }

    if phase == DiagnosticPhase.Lexer {
        give "rewrite-token";
    }

    if phase == DiagnosticPhase.Parser {
        give "repair-local-syntax";
    }

    give "inspect-primary-span";
}

proc diagnostic_recovery_scope(phase: DiagnosticPhase, code: string) -> string {
    if phase == DiagnosticPhase.Lexer {
        give "current-token";
    }

    if code == "P000_UNBALANCED" {
        give "enclosing-block";
    }

    if phase == DiagnosticPhase.Parser {
        give "current-declaration";
    }

    if phase == DiagnosticPhase.Typeck {
        give "current-expression";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "ownership-path";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "build-artifact";
    }

    give "current-phase";
}

proc diagnostic_confidence(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" or code == "P000_UNBALANCED" or code == "E0001" or code == "E0002" {
        give "high";
    }

    if starts_with(code, "LEX_") {
        give "high";
    }

    if starts_with(code, "TYPECK_") or starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "medium";
    }

    if phase == DiagnosticPhase.Internal {
        give "low";
    }

    give "medium";
}

proc diagnostic_default_help(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "attributes must be immediately followed by the declaration they configure";
    }

    if code == "P000_UNBALANCED" {
        give "compare the opening delimiter label with the primary span and close the intended block";
    }

    if phase == DiagnosticPhase.Lexer {
        give "fix this token first; later parser errors may disappear after tokenization is stable";
    }

    if phase == DiagnosticPhase.Parser {
        give "fix the earliest syntax error first; later syntax errors may be recovery artifacts";
    }

    if phase == DiagnosticPhase.Typeck {
        give "trace the expected type origin and the found value origin before changing code";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "look for the first move or borrow that keeps the value unavailable at the primary span";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "verify the selected target, emitted artifact path, and external tool output together";
    }

    give "start at the primary span, then use labels and cause chain to avoid fixing symptoms";
}

proc diagnostic_default_suggestion_kind(phase: DiagnosticPhase, code: string) -> DiagnosticSuggestionKind {
    if code == "PATTR003" {
        give DiagnosticSuggestionKind.Remove;
    }

    if code == "P000_UNBALANCED" or code == "E0001" or code == "E0002" {
        give DiagnosticSuggestionKind.Insert;
    }

    if phase == DiagnosticPhase.Lexer or phase == DiagnosticPhase.Typeck {
        give DiagnosticSuggestionKind.Replace;
    }

    give DiagnosticSuggestionKind.Help;
}

proc diagnostic_default_suggestion_replacement(phase: DiagnosticPhase, code: string) -> string {
    if code == "P000_UNBALANCED" {
        give "}";
    }

    if code == "E0001" {
        give "name";
    }

    if code == "E0002" {
        give "todo()";
    }

    give "";
}

proc diagnostic_default_suggestion_message(phase: DiagnosticPhase, code: string) -> string {
    if code == "PATTR003" {
        give "remove this standalone attribute or move it directly before a declaration";
    }

    if code == "P000_UNBALANCED" {
        give "insert the missing closing delimiter for the block";
    }

    if code == "E0001" {
        give "insert a placeholder identifier, then rename it to the intended symbol";
    }

    if code == "E0002" {
        give "insert a placeholder expression, then replace it with the intended value";
    }

    if phase == DiagnosticPhase.Lexer {
        give "rewrite the invalid token at this span";
    }

    if phase == DiagnosticPhase.Typeck {
        give "replace the highlighted expression with one that satisfies the expected type";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "reorder, shorten, or clone around the highlighted access";
    }

    give "apply the probable fix described by this diagnostic";
}

proc diagnostic_default_step1(phase: DiagnosticPhase, code: string) -> string {
    if code == "E0001" {
        give "Insert or rename the identifier at the highlighted token, then re-run the same command.";
    }

    if code == "E0002" {
        give "Complete the missing expression at the highlighted token before changing later lines.";
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" {
        give "Compare the expected and found types, then change the smaller side of the assignment.";
    }

    if code == "TYPECK_E_ARGUMENT_MISMATCH" {
        give "Start with the argument position named by the diagnostic and match it to the callee parameter.";
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give "Count the callee parameters and rewrite the call argument list to match that count.";
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give "Find the earlier move, then borrow, clone, or reorder before this later use.";
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "Find the active borrow and shorten its scope before this access.";
    }

    if phase == DiagnosticPhase.Lexer or phase == DiagnosticPhase.Parser {
        give "Fix the first highlighted token or delimiter before following later diagnostics.";
    }

    if phase == DiagnosticPhase.Typeck {
        give "Read the expected/found labels and repair the first type contract mismatch.";
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give "Trace the earliest move or borrow in the labels, then repair that access order.";
    }

    if phase == DiagnosticPhase.Backend or phase == DiagnosticPhase.Linker {
        give "Check the first backend or linker note, then verify the selected target and native tools.";
    }

    if phase == DiagnosticPhase.Driver {
        give "Re-run with --help and verify the command, input path, output path, target, and profile.";
    }

    give "Fix the first span reported for this diagnostic, then run the command again.";
}

proc diagnostic_default_example(phase: DiagnosticPhase, code: string) -> string {
    if code == "E0001" or code == "E0002" {
        give "proc main() -> int { give 0; }";
    }

    if starts_with(code, "TYPECK_") {
        give "let count: int = 1";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "let view = &value";
    }

    if phase == DiagnosticPhase.Driver {
        give "vitte check src/main.vit --lang en";
    }

    give "vitte check path/to/file.vit";
}

proc diagnostic_default_invalid_example(phase: DiagnosticPhase, code: string) -> string {
    if code == "E0001" {
        give "proc () -> int { give 0; }";
    }

    if code == "E0002" {
        give "proc main() -> int { give ; }";
    }

    if code == "P000_UNBALANCED" {
        give "proc main() -> int { give 0;";
    }

    if starts_with(code, "TYPECK_") {
        give "let count: int = \"one\"";
    }

    if starts_with(code, "BORROWCK_") or starts_with(code, "BORROW_") {
        give "move(value); use(value)";
    }

    if phase == DiagnosticPhase.Driver {
        give "vitte check";
    }

    if phase == DiagnosticPhase.Lexer {
        give "\"unterminated";
    }

    give "<invalid Vitte source>";
}

proc diagnostic_primary_key(code: string, span: SourceSpan) -> string {
    give code + "@" + span.file + ":" + span.start_line as string + ":" + span.start_column as string;
}

proc diagnostic_phase_can_recover(phase: DiagnosticPhase) -> bool {
    if phase == DiagnosticPhase.Lexer or phase == DiagnosticPhase.Parser {
        give true;
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give true;
    }

    if phase == DiagnosticPhase.ModuleResolution or phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give true;
    }

    if phase == DiagnosticPhase.Typeck or phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give true;
    }

    give false;
}

proc diagnostic_default_suggestion(phase: DiagnosticPhase, code: string, span: SourceSpan) -> DiagnosticSuggestion {
    let kind: DiagnosticSuggestionKind = diagnostic_default_suggestion_kind(phase, code);
    let message: string = diagnostic_default_suggestion_message(phase, code);
    let replacement: string = diagnostic_default_suggestion_replacement(phase, code);
    let confidence: string = diagnostic_confidence(phase, code);
    let reason: string = diagnostic_correction_strategy(phase, code);
    let machine_applicable: bool = replacement != "" and confidence == "high";
    give diagnostic_suggestion_detail(kind, message, replacement, span, machine_applicable, confidence, reason);
}

proc diagnostic_suggestion_limit() -> u64 {
    give 5 as u64;
}

proc diagnostic_suggestion_rank(suggestion: DiagnosticSuggestion) -> u64 {
    if suggestion.applicability == DiagnosticApplicability.Machine {
        give 0 as u64;
    }

    if suggestion.confidence == "high" {
        give 1 as u64;
    }

    if suggestion.applicability == DiagnosticApplicability.MaybeMachine or suggestion.confidence == "medium" {
        give 2 as u64;
    }

    give 3 as u64;
}

proc diagnostic_suggestion_list_add(suggestions: [DiagnosticSuggestion], suggestion: DiagnosticSuggestion) -> [DiagnosticSuggestion] {
    if not suggestion.valid {
        give suggestions;
    }

    let out: [DiagnosticSuggestion] = [];
    let inserted: bool = false;
    let i: u64 = 0;
    let rank: u64 = diagnostic_suggestion_rank(suggestion);

    while i < len(suggestions) {
        if not inserted and rank < diagnostic_suggestion_rank(suggestions[i]) {
            set out = out + [suggestion];
            set inserted = true;
        }

        if len(out) < diagnostic_suggestion_limit() {
            set out = out + [suggestions[i]];
        }

        set i = i + 1;
    }

    if not inserted and len(out) < diagnostic_suggestion_limit() {
        set out = out + [suggestion];
    }

    give out;
}

proc diagnostic_suggestion_list_extend(suggestions: [DiagnosticSuggestion], extra: [DiagnosticSuggestion]) -> [DiagnosticSuggestion] {
    let out: [DiagnosticSuggestion] = suggestions;
    let i: u64 = 0;

    while i < len(extra) {
        set out = diagnostic_suggestion_list_add(out, extra[i]);
        set i = i + 1;
    }

    give out;
}

proc diagnostic_catalog_suggestions(phase: DiagnosticPhase, code: string, span: SourceSpan) -> [DiagnosticSuggestion] {
    if code == "P000_UNBALANCED" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Insert, "insert the missing closing delimiter", "}", span, DiagnosticApplicability.Machine, "high", "parser reported an unbalanced block"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "check the nearest opened block before this span", "", span, DiagnosticApplicability.Manual, "medium", "a later parser error may be a recovery artifact")
        ];
    }

    if code == "E0001" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Insert, "insert a placeholder identifier", "name", span, DiagnosticApplicability.MaybeMachine, "medium", "the parser expected an identifier-like token"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "rename the placeholder to the intended symbol after parsing succeeds", "", span, DiagnosticApplicability.Manual, "medium", "the compiler cannot infer the real name")
        ];
    }

    if code == "E0002" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Insert, "insert a placeholder expression", "todo()", span, DiagnosticApplicability.MaybeMachine, "medium", "the parser expected an expression"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "replace the placeholder with the intended value before committing", "", span, DiagnosticApplicability.Manual, "medium", "placeholder expressions preserve parsing but not intent")
        ];
    }

    if code == "PATTR003" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Remove, "remove this standalone attribute", "", span, DiagnosticApplicability.Machine, "high", "standalone attributes are not attached to a declaration"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "move the attribute directly before the declaration it describes", "", span, DiagnosticApplicability.Manual, "medium", "attributes apply to the next declaration")
        ];
    }

    if code == "TYPECK_E_ASSIGN_MISMATCH" or code == "TYPECK_E_ARGUMENT_MISMATCH" or code == "TYPECK_E_BINARY_MISMATCH" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Replace, "replace the expression with a value of the expected type", "", span, DiagnosticApplicability.Manual, "medium", "the expected and found types disagree"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "change the annotation only if the broader API contract is wrong", "", span, DiagnosticApplicability.Manual, "medium", "type fixes should preserve the declared contract")
        ];
    }

    if code == "TYPECK_E_CALL_ARITY" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Replace, "rewrite the call argument list to match the callee signature", "", span, DiagnosticApplicability.Manual, "medium", "the call arity does not match the signature"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "inspect the callee declaration before adding or removing arguments", "", span, DiagnosticApplicability.Manual, "medium", "the diagnostic cannot choose the semantic argument")
        ];
    }

    if code == "BORROWCK_E_USE_AFTER_MOVE" or code == "BORROW_E_USE_AFTER_MOVE" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "borrow the value before the move when ownership is not needed", "", span, DiagnosticApplicability.Manual, "medium", "a moved value is unavailable at this use"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "clone or copy only when the type and cost make that explicit", "", span, DiagnosticApplicability.Manual, "low", "ownership repairs can change performance or semantics"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "reorder this use before the move if the control flow allows it", "", span, DiagnosticApplicability.Manual, "medium", "the later use depends on the earlier move")
        ];
    }

    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" or code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "shorten the active borrow scope before this access", "", span, DiagnosticApplicability.Manual, "medium", "the borrow window overlaps this operation"),
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Help, "split the block so the borrow ends before mutation", "", span, DiagnosticApplicability.Manual, "medium", "scope boundaries determine borrow lifetime")
        ];
    }

    if phase == DiagnosticPhase.Lexer {
        give [
            diagnostic_suggestion_applicability(DiagnosticSuggestionKind.Replace, "rewrite the invalid token at this span", "", span, DiagnosticApplicability.Manual, "medium", "tokenization must succeed before parsing can recover")
        ];
    }

    give [];
}

proc diagnostic_suggestion_list(phase: DiagnosticPhase, code: string, span: SourceSpan) -> [DiagnosticSuggestion] {
    let out: [DiagnosticSuggestion] = diagnostic_catalog_suggestions(phase, code, span);
    let fallback: DiagnosticSuggestion = diagnostic_default_suggestion(phase, code, span);
    give diagnostic_suggestion_list_add(out, fallback);
}

proc diagnostic_phase_requires_user_span(phase: DiagnosticPhase) -> bool {
    give phase == DiagnosticPhase.Lexer
        or phase == DiagnosticPhase.Parser
        or phase == DiagnosticPhase.Ast
        or phase == DiagnosticPhase.AstValidation
        or phase == DiagnosticPhase.ModuleResolution
        or phase == DiagnosticPhase.SymbolResolution
        or phase == DiagnosticPhase.Sema
        or phase == DiagnosticPhase.Hir
        or phase == DiagnosticPhase.Typeck
        or phase == DiagnosticPhase.Borrowck
        or phase == DiagnosticPhase.Lifetime
        or phase == DiagnosticPhase.Mir
        or phase == DiagnosticPhase.MirLowering
        or phase == DiagnosticPhase.MirVerification
        or phase == DiagnosticPhase.Ir
        or phase == DiagnosticPhase.Backend
        or phase == DiagnosticPhase.Linker;
}

proc diagnostic_missing_user_span_code(code: string, phase: DiagnosticPhase, span: SourceSpan) -> string {
    if code == "ICE0001" or phase == DiagnosticPhase.Internal or span.valid {
        give code;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give "ICE0001";
    }
    give code;
}

proc diagnostic_missing_user_span_phase(phase: DiagnosticPhase, span: SourceSpan) -> DiagnosticPhase {
    if phase == DiagnosticPhase.Internal or span.valid {
        give phase;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give DiagnosticPhase.Internal;
    }
    give phase;
}

proc diagnostic_missing_user_span_severity(severity: DiagnosticSeverity, phase: DiagnosticPhase, span: SourceSpan) -> DiagnosticSeverity {
    if phase == DiagnosticPhase.Internal or span.valid {
        give severity;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give DiagnosticSeverity.Fatal;
    }
    give severity;
}

proc diagnostic_missing_user_span_message(message: string, code: string, phase: DiagnosticPhase, span: SourceSpan) -> string {
    if phase == DiagnosticPhase.Internal or span.valid {
        give message;
    }
    if diagnostic_phase_requires_user_span(phase) {
        give "internal compiler error: diagnostic " + code + " from " + phase_name(phase) + " requires an exact source span";
    }
    give message;
}

proc diagnostic_create(code: string, phase: DiagnosticPhase, severity: DiagnosticSeverity, message: string, span: SourceSpan) -> Diagnostic {
    let effective_code: string = diagnostic_missing_user_span_code(code, phase, span);
    let effective_phase: DiagnosticPhase = diagnostic_missing_user_span_phase(phase, span);
    let effective_severity: DiagnosticSeverity = diagnostic_missing_user_span_severity(severity, phase, span);
    let effective_message: string = diagnostic_missing_user_span_message(message, code, phase, span);
    let default_note_text: string = diagnostic_default_note(effective_phase, effective_code);
    let default_help_text: string = diagnostic_default_help(effective_phase, effective_code);
    let default_suggestions: [DiagnosticSuggestion] = diagnostic_suggestion_list(effective_phase, effective_code, span);
    let phase_context: string = diag_kv("phase", phase_name(effective_phase));
    let step_context: string = diag_kv("step", diagnostic_default_step(effective_phase));
    let family_context: string = diag_kv("family", diagnostic_code_family(effective_phase, effective_code));
    let strategy_context: string = diag_kv("correction_strategy", diagnostic_correction_strategy(effective_phase, effective_code));
    let recovery_context: string = diag_kv("recovery_scope", diagnostic_recovery_scope(effective_phase, effective_code));
    let confidence_context: string = diag_kv("confidence", diagnostic_confidence(effective_phase, effective_code));
    let cause: string = if effective_code == "ICE0001" and code != "ICE0001" { "diagnostic producer emitted user-facing diagnostic without an exact source span" } else { diagnostic_default_root_cause(effective_phase, effective_code) };
    give Diagnostic {
        code: effective_code,
        phase: effective_phase,
        severity: effective_severity,
        title: effective_message,
        rule: diagnostic_default_rule(effective_phase, effective_code),
        message: effective_message,
        explanation: diagnostic_default_explanation(effective_phase, effective_code),
        technical_note: "",
        labels: [primary_label(effective_message, span)],
        secondary_spans: [],
        notes: if default_note_text == "" { [] } else { [diagnostic_note(default_note_text)] },
        helps: if default_help_text == "" { [] } else { [diagnostic_help(default_help_text)] },
        suggestions: default_suggestions,
        documentation_url: diagnostic_default_documentation(effective_phase, effective_code),
        root_cause: cause,
        cause_chain: [],
        pipeline_context: [phase_context, step_context, family_context, strategy_context, recovery_context, confidence_context],
        related_errors: [],
        probable_fix: diagnostic_default_probable_fix(effective_phase, effective_code),
        subject_symbol: "",
        subject_type: "",
        subject_borrow: "",
        valid_example: diagnostic_default_example(effective_phase, effective_code),
        invalid_example: diagnostic_default_invalid_example(effective_phase, effective_code),
        primary_error_key: diagnostic_primary_key(effective_code, span),
        cascade_of: "",
        primary_span: span,
        span: span,
        file_id: 0,
        internal_cause: cause,
        primary_error: true,
        cascade: false,
        suppressed: false,
        duplicate: false,
        recovery_possible: diagnostic_phase_can_recover(effective_phase) and not severity_is_fatal(effective_severity),
        deprecated: false,
        unnecessary: false,
        fatal: severity_is_fatal(effective_severity),
        valid: effective_code != "" and effective_message != ""
    };
}

proc diagnostic_with_rule(diagnostic: Diagnostic, rule: string) -> Diagnostic {
    if rule == "" {
        give diagnostic;
    }

    set diagnostic.rule = rule;
    give diagnostic;
}

proc diagnostic_with_explanation(diagnostic: Diagnostic, explanation: string) -> Diagnostic {
    if explanation == "" {
        give diagnostic;
    }

    set diagnostic.explanation = explanation;
    give diagnostic;
}

proc diagnostic_with_technical_note(diagnostic: Diagnostic, technical_note: string) -> Diagnostic {
    if technical_note == "" {
        give diagnostic;
    }

    set diagnostic.technical_note = technical_note;
    give diagnostic;
}

proc diagnostic_with_documentation(diagnostic: Diagnostic, documentation_url: string) -> Diagnostic {
    if documentation_url == "" {
        give diagnostic;
    }

    set diagnostic.documentation_url = documentation_url;
    give diagnostic;
}

proc diagnostic_with_root_cause(diagnostic: Diagnostic, root_cause: string) -> Diagnostic {
    if root_cause == "" {
        give diagnostic;
    }

    set diagnostic.root_cause = root_cause;
    set diagnostic.internal_cause = root_cause;
    give diagnostic;
}

proc diagnostic_add_cause(diagnostic: Diagnostic, cause: string) -> Diagnostic {
    if cause == "" {
        give diagnostic;
    }

    set diagnostic.cause_chain = diagnostic.cause_chain + [cause];
    give diagnostic;
}

proc diagnostic_with_file_id(diagnostic: Diagnostic, file_id: u64) -> Diagnostic {
    set diagnostic.file_id = file_id;
    give diagnostic;
}

proc diagnostic_with_internal_cause(diagnostic: Diagnostic, internal_cause: string) -> Diagnostic {
    if internal_cause == "" {
        give diagnostic;
    }

    set diagnostic.internal_cause = internal_cause;
    give diagnostic;
}

proc diagnostic_add_pipeline_context(diagnostic: Diagnostic, context: string) -> Diagnostic {
    if context == "" {
        give diagnostic;
    }

    set diagnostic.pipeline_context = diagnostic.pipeline_context + [context];
    give diagnostic;
}

proc diagnostic_add_related_error(diagnostic: Diagnostic, related_error: string) -> Diagnostic {
    if related_error == "" {
        give diagnostic;
    }

    set diagnostic.related_errors = diagnostic.related_errors + [related_error];
    give diagnostic;
}

proc diagnostic_with_probable_fix(diagnostic: Diagnostic, probable_fix: string) -> Diagnostic {
    if probable_fix == "" {
        give diagnostic;
    }

    set diagnostic.probable_fix = probable_fix;
    give diagnostic;
}

proc diagnostic_with_subject_symbol(diagnostic: Diagnostic, subject_symbol: string) -> Diagnostic {
    if subject_symbol == "" {
        give diagnostic;
    }

    set diagnostic.subject_symbol = subject_symbol;
    give diagnostic;
}

proc diagnostic_with_subject_type(diagnostic: Diagnostic, subject_type: string) -> Diagnostic {
    if subject_type == "" {
        give diagnostic;
    }

    set diagnostic.subject_type = subject_type;
    give diagnostic;
}

proc diagnostic_with_subject_borrow(diagnostic: Diagnostic, subject_borrow: string) -> Diagnostic {
    if subject_borrow == "" {
        give diagnostic;
    }

    set diagnostic.subject_borrow = subject_borrow;
    give diagnostic;
}

proc diagnostic_with_examples(diagnostic: Diagnostic, valid_example: string, invalid_example: string) -> Diagnostic {
    if valid_example != "" {
        set diagnostic.valid_example = valid_example;
    }

    if invalid_example != "" {
        set diagnostic.invalid_example = invalid_example;
    }

    give diagnostic;
}

proc diagnostic_mark_cascade(diagnostic: Diagnostic, primary_error_key: string) -> Diagnostic {
    if primary_error_key == "" {
        give diagnostic;
    }

    set diagnostic.primary_error = false;
    set diagnostic.cascade = true;
    set diagnostic.cascade_of = primary_error_key;
    set diagnostic.pipeline_context = diagnostic.pipeline_context + [diag_kv("cascade_of", primary_error_key)];
    give diagnostic;
}

proc diagnostic_mark_suppressed(diagnostic: Diagnostic, primary_error_key: string) -> Diagnostic {
    set diagnostic = diagnostic_mark_cascade(diagnostic, primary_error_key);
    set diagnostic.suppressed = true;
    give diagnostic;
}

proc diagnostic_error(code: string, phase: DiagnosticPhase, message: string, span: SourceSpan) -> Diagnostic {
    give diagnostic_create(code, phase, DiagnosticSeverity.Error, message, span);
}

proc diagnostic_warning(code: string, phase: DiagnosticPhase, message: string, span: SourceSpan) -> Diagnostic {
    give diagnostic_create(code, phase, DiagnosticSeverity.Warning, message, span);
}

proc diagnostic_fatal(code: string, phase: DiagnosticPhase, message: string, span: SourceSpan) -> Diagnostic {
    give diagnostic_create(code, phase, DiagnosticSeverity.Fatal, message, span);
}

proc diagnostic_with_label(diagnostic: Diagnostic, label: DiagnosticLabel) -> Diagnostic {
    set diagnostic.labels = diagnostic.labels + [label];
    if label.primary {
        set diagnostic.span = label.span;
        set diagnostic.primary_span = label.span;
    } else {
        set diagnostic.secondary_spans = diagnostic.secondary_spans + [label.span];
    }

    give diagnostic;
}

proc diagnostic_with_note(diagnostic: Diagnostic, message: string) -> Diagnostic {
    if message == "" {
        give diagnostic;
    }

    set diagnostic.notes = diagnostic.notes + [diagnostic_note(message)];

    give diagnostic;
}

proc diagnostic_with_help(diagnostic: Diagnostic, message: string) -> Diagnostic {
    if message == "" {
        give diagnostic;
    }

    set diagnostic.helps = diagnostic.helps + [diagnostic_help(message)];

    give diagnostic;
}

proc diagnostic_with_suggestion(diagnostic: Diagnostic, suggestion: DiagnosticSuggestion) -> Diagnostic {
    set diagnostic.suggestions = diagnostic.suggestions + [suggestion];

    give diagnostic;
}

proc diagnostic_with_suggestion_detail(diagnostic: Diagnostic, kind: DiagnosticSuggestionKind, message: string, replacement: string, span: SourceSpan, machine_applicable: bool, confidence: string, reason: string) -> Diagnostic {
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion_detail(kind, message, replacement, span, machine_applicable, confidence, reason);
    give diagnostic_with_suggestion(diagnostic, suggestion);
}

proc diagnostic_with_replace(diagnostic: Diagnostic, message: string, replacement: string, span: SourceSpan) -> Diagnostic {
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(DiagnosticSuggestionKind.Replace, message, replacement, span, true);
    give diagnostic_with_suggestion(diagnostic, suggestion);
}

proc diagnostic_with_insert(diagnostic: Diagnostic, message: string, replacement: string, span: SourceSpan) -> Diagnostic {
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(DiagnosticSuggestionKind.Insert, message, replacement, span, true);
    give diagnostic_with_suggestion(diagnostic, suggestion);
}

proc diagnostic_with_remove(diagnostic: Diagnostic, message: string, span: SourceSpan) -> Diagnostic {
    let suggestion: DiagnosticSuggestion = diagnostic_suggestion(DiagnosticSuggestionKind.Remove, message, "", span, true);
    give diagnostic_with_suggestion(diagnostic, suggestion);
}

proc same_diagnostic(left: Diagnostic, right: Diagnostic) -> bool {
    if left.code != right.code {
        give false;
    }

    if left.message != right.message {
        give false;
    }

    if left.span.file != right.span.file {
        give false;
    }

    if left.span.start_line != right.span.start_line {
        give false;
    }

    if left.span.start_column != right.span.start_column {
        give false;
    }

    give true;
}

proc add_unique_diagnostic(diagnostics: [Diagnostic], diagnostic: Diagnostic) -> [Diagnostic] {
    let i: u64 = 0;

    while i < len(diagnostics) {
        if same_diagnostic(diagnostics[i], diagnostic) {
            give diagnostics;
        }

        set i = i + 1;
    }

    give diagnostics + [diagnostic];
}

proc merge_diagnostics(left: [Diagnostic], right: [Diagnostic]) -> [Diagnostic] {
    let out: [Diagnostic] = left;
    let i: u64 = 0;

    while i < len(right) {
        set out = add_unique_diagnostic(out, right[i]);
        set i = i + 1;
    }

    give out;
}

proc diagnostic_phase_priority(phase: DiagnosticPhase) -> u64 {
    if phase == DiagnosticPhase.Lexer {
        give 10 as u64;
    }

    if phase == DiagnosticPhase.Parser {
        give 20 as u64;
    }

    if phase == DiagnosticPhase.Ast or phase == DiagnosticPhase.AstValidation {
        give 30 as u64;
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give 40 as u64;
    }

    if phase == DiagnosticPhase.SymbolResolution or phase == DiagnosticPhase.Sema {
        give 50 as u64;
    }

    if phase == DiagnosticPhase.Hir {
        give 60 as u64;
    }

    if phase == DiagnosticPhase.Typeck {
        give 70 as u64;
    }

    if phase == DiagnosticPhase.Borrowck or phase == DiagnosticPhase.Lifetime {
        give 80 as u64;
    }

    if phase == DiagnosticPhase.Mir or phase == DiagnosticPhase.MirLowering or phase == DiagnosticPhase.MirVerification {
        give 90 as u64;
    }

    if phase == DiagnosticPhase.Ir {
        give 100 as u64;
    }

    if phase == DiagnosticPhase.Backend {
        give 110 as u64;
    }

    if phase == DiagnosticPhase.Linker {
        give 120 as u64;
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give 130 as u64;
    }

    if phase == DiagnosticPhase.Driver {
        give 5 as u64;
    }

    give 200 as u64;
}

proc diagnostic_severity_priority(severity: DiagnosticSeverity) -> u64 {
    if severity == DiagnosticSeverity.Fatal {
        give 0 as u64;
    }

    if severity == DiagnosticSeverity.Error {
        give 10 as u64;
    }

    if severity == DiagnosticSeverity.Warning {
        give 20 as u64;
    }

    if severity == DiagnosticSeverity.Note {
        give 30 as u64;
    }

    give 40 as u64;
}

proc diagnostic_cascade_penalty(diagnostic: Diagnostic) -> u64 {
    if diagnostic.phase == DiagnosticPhase.Lexer or diagnostic.phase == DiagnosticPhase.Parser {
        give 0 as u64;
    }

    if find(diagnostic.message, "unknown") >= 0 {
        give 1 as u64;
    }

    if find(diagnostic.message, "invalid") >= 0 {
        give 2 as u64;
    }

    if find(diagnostic.message, "mismatch") >= 0 {
        give 4 as u64;
    }

    give 3 as u64;
}

proc diagnostic_priority(diagnostic: Diagnostic) -> u64 {
    give diagnostic_severity_priority(diagnostic.severity)
        + diagnostic_phase_priority(diagnostic.phase)
        + diagnostic_cascade_penalty(diagnostic);
}

proc diagnostic_should_precede(left: Diagnostic, right: Diagnostic) -> bool {
    if left.span.file < right.span.file {
        give true;
    }

    if left.span.file > right.span.file {
        give false;
    }

    if left.span.start_line < right.span.start_line {
        give true;
    }

    if left.span.start_line > right.span.start_line {
        give false;
    }

    if left.span.start_column < right.span.start_column {
        give true;
    }

    if left.span.start_column > right.span.start_column {
        give false;
    }

    if left.code < right.code {
        give true;
    }

    if left.code > right.code {
        give false;
    }

    give left.message <= right.message;
}

proc prioritize_diagnostics(diagnostics: [Diagnostic]) -> [Diagnostic] {
    let out: [Diagnostic] = [];
    let i: u64 = 0;

    while i < len(diagnostics) {
        let candidate: Diagnostic = diagnostics[i];
        let inserted: bool = false;
        let next: [Diagnostic] = [];
        let j: u64 = 0;

        while j < len(out) {
            if not inserted and diagnostic_should_precede(candidate, out[j]) {
                set next = next + [candidate];
                set inserted = true;
            }

            set next = next + [out[j]];
            set j = j + 1;
        }

        if not inserted {
            set next = next + [candidate];
        }

        set out = next;
        set i = i + 1;
    }

    give out;
}

proc diagnostic_is_root(diagnostic: Diagnostic) -> bool {
    if diagnostic.cascade or diagnostic.cascade_of != "" or diagnostic.suppressed {
        give false;
    }

    if diagnostic.primary_error {
        give true;
    }

    if diagnostic.phase == DiagnosticPhase.Lexer or diagnostic.phase == DiagnosticPhase.Parser {
        give true;
    }

    if len(diagnostic.cause_chain) > 0 {
        give true;
    }

    if diagnostic.root_cause != "" and diagnostic.probable_fix != "" {
        give true;
    }

    give false;
}

proc diagnostic_cascade_limit() -> u64 {
    give 3 as u64;
}

proc diagnostic_same_primary_area(left: Diagnostic, right: Diagnostic) -> bool {
    if left.span.file == "" or right.span.file == "" {
        give false;
    }

    if left.span.file != right.span.file {
        give false;
    }

    if right.span.start_line < left.span.start_line {
        give false;
    }

    give right.span.start_line <= left.span.start_line + 8;
}

proc diagnostic_should_derive_from(primary: Diagnostic, candidate: Diagnostic) -> bool {
    if primary.primary_error_key == "" {
        give false;
    }

    if not severity_is_error(primary.severity) {
        give false;
    }

    if not severity_is_error(candidate.severity) {
        give false;
    }

    if primary.code == candidate.code and primary.message == candidate.message {
        give false;
    }

    if diagnostic_phase_priority(candidate.phase) <= diagnostic_phase_priority(primary.phase) {
        give false;
    }

    give diagnostic_same_primary_area(primary, candidate);
}

proc diagnostics_suppressed_cascade_count(diagnostics: [Diagnostic]) -> u64 {
    let count: u64 = 0;
    let i: u64 = 0;

    while i < len(diagnostics) {
        if diagnostics[i].suppressed {
            set count = count + 1;
        }

        set i = i + 1;
    }

    give count;
}

proc diagnostics_duplicate_count(original: [Diagnostic], normalized: [Diagnostic]) -> u64 {
    let unique: [Diagnostic] = [];
    let i: u64 = 0;

    while i < len(original) {
        set unique = add_unique_diagnostic(unique, original[i]);
        set i = i + 1;
    }

    if len(original) <= len(unique) {
        give 0 as u64;
    }

    give len(original) - len(unique);
}

proc diagnostics_suppressed_cascade_count_from_original(original: [Diagnostic], normalized: [Diagnostic]) -> u64 {
    let unique: [Diagnostic] = [];
    let i: u64 = 0;

    while i < len(original) {
        set unique = add_unique_diagnostic(unique, original[i]);
        set i = i + 1;
    }

    if len(unique) <= len(normalized) {
        give 0 as u64;
    }

    give len(unique) - len(normalized);
}

proc diagnostics_recovery_possible(diagnostics: [Diagnostic]) -> bool {
    let i: u64 = 0;

    while i < len(diagnostics) {
        if diagnostics[i].recovery_possible and not diagnostics[i].suppressed {
            give true;
        }

        set i = i + 1;
    }

    give false;
}

proc diagnostic_report_visible_diagnostics(diagnostics: [Diagnostic]) -> [Diagnostic] {
    let ordered: [Diagnostic] = prioritize_diagnostics(diagnostics);
    let out: [Diagnostic] = [];
    let primary: Diagnostic = diagnostic_create("DIAG_INTERNAL_PRIMARY", DiagnosticPhase.Internal, DiagnosticSeverity.Note, "internal primary placeholder", span_empty());
    let have_primary: bool = false;
    let cascade_count: u64 = 0;
    let i: u64 = 0;

    while i < len(ordered) {
        let candidate: Diagnostic = ordered[i];

        if len(add_unique_diagnostic(out, candidate)) == len(out) {
            set candidate.duplicate = true;
            set candidate.suppressed = true;
        } elif have_primary and diagnostic_should_derive_from(primary, candidate) {
            set candidate = diagnostic_mark_cascade(candidate, primary.primary_error_key);

            if cascade_count >= diagnostic_cascade_limit() {
                set candidate = diagnostic_mark_suppressed(candidate, primary.primary_error_key);
            } else {
                set out = out + [candidate];
                set cascade_count = cascade_count + 1;
            }
        } else {
            if not have_primary and severity_is_error(candidate.severity) {
                set candidate.primary_error = true;
                set candidate.cascade = false;
                set candidate.cascade_of = "";
                set primary = candidate;
                set have_primary = true;
            }

            set out = out + [candidate];
        }

        set i = i + 1;
    }

    give out;
}

proc diagnostic_root_count(diagnostics: [Diagnostic]) -> u64 {
    let count: u64 = 0;
    let i: u64 = 0;

    while i < len(diagnostics) {
        if diagnostic_is_root(diagnostics[i]) {
            set count = count + 1;
        }
        set i = i + 1;
    }

    give count;
}

proc diagnostic_cascade_count(diagnostics: [Diagnostic]) -> u64 {
    let roots: u64 = diagnostic_root_count(diagnostics);

    if len(diagnostics) <= roots {
        give 0 as u64;
    }

    give len(diagnostics) - roots;
}

proc diagnostic_causality_summary(diagnostics: [Diagnostic]) -> DiagnosticCausalitySummary {
    let roots: u64 = diagnostic_root_count(diagnostics);
    let cascades: u64 = diagnostic_cascade_count(diagnostics);
    let suppressed: u64 = diagnostics_suppressed_cascade_count(diagnostics);
    let duplicates: u64 = 0;
    let roots_text: string = roots as string;
    let cascades_text: string = cascades as string;
    let suppressed_text: string = suppressed as string;
    give DiagnosticCausalitySummary {
        root_count: roots,
        cascade_count: cascades,
        suppressed_cascade_count: suppressed,
        duplicate_count: duplicates,
        summary: roots_text + " root diagnostic(s), " + cascades_text + " probable cascade diagnostic(s), " + suppressed_text + " suppressed cascade diagnostic(s)",
        valid: true
    };
}

proc diagnostic_quality(diagnostic: Diagnostic) -> DiagnosticQuality {
    let span_score: u64 = if diagnostic.span.valid { 20 } else { 0 };
    let context_score: u64 = 0;
    let fix_score: u64 = 0;
    let stability_score: u64 = 0;
    let cascade_score: u64 = 0;

    if diagnostic.rule != "" {
        set context_score = context_score + 5;
    }
    if diagnostic.explanation != "" {
        set context_score = context_score + 5;
    }
    if diagnostic.root_cause != "" {
        set context_score = context_score + 5;
    }
    if len(diagnostic.pipeline_context) >= 4 {
        set context_score = context_score + 5;
    }

    if diagnostic.probable_fix != "" {
        set fix_score = fix_score + 10;
    }
    if len(diagnostic.suggestions) > 0 {
        set fix_score = fix_score + 10;
    }

    if diagnostic.code != "" {
        set stability_score = stability_score + 5;
    }
    if diagnostic.documentation_url != "" {
        set stability_score = stability_score + 5;
    }
    if diagnostic_code_family(diagnostic.phase, diagnostic.code) != "" {
        set stability_score = stability_score + 5;
    }
    if diagnostic_confidence(diagnostic.phase, diagnostic.code) != "" {
        set stability_score = stability_score + 5;
    }

    if diagnostic_is_root(diagnostic) {
        set cascade_score = 20 as u64;
    } else {
        set cascade_score = 10 as u64;
    }

    give DiagnosticQuality {
        score: span_score + context_score + fix_score + stability_score + cascade_score,
        span_score: span_score,
        context_score: context_score,
        fix_score: fix_score,
        stability_score: stability_score,
        cascade_score: cascade_score,
        valid: diagnostic.valid
    };
}

proc diagnostic_quality_score(diagnostic: Diagnostic) -> u64 {
    give diagnostic_quality(diagnostic).score;
}

proc diagnostic_report_quality_score(diagnostics: [Diagnostic]) -> u64 {
    if len(diagnostics) == 0 {
        give 100 as u64;
    }

    let total: u64 = 0;
    let i: u64 = 0;

    while i < len(diagnostics) {
        set total = total + diagnostic_quality_score(diagnostics[i]);
        set i = i + 1;
    }

    give total / len(diagnostics);
}

proc diagnostic_count_severity(diagnostics: [Diagnostic], severity: DiagnosticSeverity) -> u64 {
    let count: u64 = 0;
    let i: u64 = 0;

    while i < len(diagnostics) {
        if diagnostics[i].severity == severity {
            set count = count + 1;
        }

        set i = i + 1;
    }

    give count;
}

proc diagnostics_have_errors(diagnostics: [Diagnostic]) -> bool {
    let i: u64 = 0;

    while i < len(diagnostics) {
        if severity_is_error(diagnostics[i].severity) {
            give true;
        }

        if diagnostics[i].fatal {
            give true;
        }

        set i = i + 1;
    }

    give false;
}

proc diagnostics_have_fatal(diagnostics: [Diagnostic]) -> bool {
    let i: u64 = 0;

    while i < len(diagnostics) {
        if diagnostics[i].fatal {
            give true;
        }

        if diagnostics[i].severity == DiagnosticSeverity.Fatal {
            give true;
        }

        set i = i + 1;
    }

    give false;
}

proc diagnostic_report(diagnostics: [Diagnostic]) -> DiagnosticReport {
    let ordered: [Diagnostic] = diagnostic_report_visible_diagnostics(diagnostics);
    let causality: DiagnosticCausalitySummary = diagnostic_causality_summary(ordered);
    let suppressed_cascades: u64 = diagnostics_suppressed_cascade_count_from_original(diagnostics, ordered);
    let duplicates: u64 = diagnostics_duplicate_count(diagnostics, ordered);
    give DiagnosticReport {
        diagnostics: ordered,
        valid: !diagnostics_have_errors(ordered),
        warning_count: diagnostic_count_severity(
            ordered,
            DiagnosticSeverity.Warning
        ),
        error_count: diagnostic_count_severity(
            ordered,
            DiagnosticSeverity.Error
        ),
        fatal_count: diagnostic_count_severity(
            ordered,
            DiagnosticSeverity.Fatal
        ),
        root_count: causality.root_count,
        cascade_count: causality.cascade_count,
        suppressed_cascade_count: suppressed_cascades,
        duplicate_count: duplicates,
        recovery_possible: diagnostics_recovery_possible(ordered),
        quality_score: diagnostic_report_quality_score(ordered)
    };
}

proc diagnostic_report_empty() -> DiagnosticReport {
    give diagnostic_report([]);
}

proc diagnostic_report_add(report: DiagnosticReport, diagnostic: Diagnostic) -> DiagnosticReport {
    let diagnostics: [Diagnostic] = add_unique_diagnostic(report.diagnostics, diagnostic);
    give diagnostic_report(diagnostics);
}

proc diagnostic_report_merge(left: DiagnosticReport, right: DiagnosticReport) -> DiagnosticReport {
    let diagnostics: [Diagnostic] = merge_diagnostics(left.diagnostics, right.diagnostics);
    give diagnostic_report(diagnostics);
}

proc default_render_config() -> DiagnosticRenderConfig {
    give DiagnosticRenderConfig {
        style: DiagnosticStyle.Human,
        show_code: true,
        show_phase: true,
        show_notes: true,
        show_helps: true,
        show_suggestions: true,
        color: true
    };
}

proc ansi_reset() -> string {
    give "\u001b[0m";
}

proc ansi_bold() -> string {
    give "\u001b[1m";
}

proc ansi_red() -> string {
    give "\u001b[31m";
}

proc ansi_yellow() -> string {
    give "\u001b[33m";
}

proc ansi_blue() -> string {
    give "\u001b[34m";
}

proc ansi_cyan() -> string {
    give "\u001b[36m";
}

proc diag_lparen() -> string {
    give slice("()", 0, 1);
}

proc diag_rparen() -> string {
    give slice("()", 1, 2);
}

proc diag_eq() -> string {
    give slice("a=b", 1, 2);
}

proc diag_kv(key: string, value: string) -> string {
    give key + diag_eq() + value;
}

proc severity_color(severity: DiagnosticSeverity) -> string {
    if severity == DiagnosticSeverity.Error or severity == DiagnosticSeverity.Fatal {
        give ansi_bold() + ansi_red();
    }

    if severity == DiagnosticSeverity.Warning {
        give ansi_bold() + ansi_yellow();
    }

    if severity == DiagnosticSeverity.Note {
        give ansi_blue();
    }

    if severity == DiagnosticSeverity.Help {
        give ansi_cyan();
    }

    give "";
}

proc color_wrap(config: DiagnosticRenderConfig, color: string, text: string) -> string {
    if !config.color or color == "" {
        give text;
    }

    give color + text + ansi_reset();
}

proc span_location_text(span: SourceSpan) -> string {
    if !span.valid {
        give "<unknown>";
    }

    let start_line: string = span.start_line as string;
    let start_column: string = span.start_column as string;
    give span.file + ":" + start_line + ":" + start_column;
}

proc diagnostic_header_text(diagnostic: Diagnostic, config: DiagnosticRenderConfig) -> string {
    let text: string = severity_name(diagnostic.severity);

    if config.show_code and diagnostic.code != "" {
        set text = text + "[" + diagnostic.code + "]";
    }

    if config.show_phase {
        set text = text + " " + phase_name(diagnostic.phase);
    }

    set text = text + ": " + diagnostic.message;

    let color: string = severity_color(diagnostic.severity);
    give color_wrap(config, color, text);
}

proc diagnostic_text_line(diagnostic: Diagnostic) -> string {
    give "severity=" + severity_name(diagnostic.severity)
        + " code=" + diagnostic.code
        + " phase=" + phase_name(diagnostic.phase)
        + " span=" + span_location_text(diagnostic.span)
        + " message=" + diagnostic.message;
}

proc render_label(label: DiagnosticLabel, config: DiagnosticRenderConfig) -> string {
    let prefix: string = color_wrap(config, ansi_bold() + ansi_blue(), label_kind_name(label.kind));
    let location: string = span_location_text(label.span);
    give "  " + prefix + ": " + location + " " + label.message;
}

proc render_note(note: DiagnosticNote, config: DiagnosticRenderConfig) -> string {
    let prefix: string = color_wrap(config, ansi_bold() + ansi_blue(), "note");
    give "  " + prefix + ": " + note.message;
}

proc render_help(help: DiagnosticHelp, config: DiagnosticRenderConfig) -> string {
    let prefix: string = color_wrap(config, ansi_bold() + ansi_cyan(), "help");
    give "  " + prefix + ": " + help.message;
}

proc render_detail(prefix: string, value: string) -> string {
    give "  " + prefix + ": " + value;
}

proc repeat_text(text: string, count: u64) -> string {
    let out: string = "";
    let i: u64 = 0;

    while i < count {
        set out = out + text;
        set i = i + 1;
    }

    give out;
}

proc line_number_width(line: u64) -> u64 {
    let width: u64 = 1;
    let value: u64 = line;

    while value >= 10 {
        set width = width + 1;
        set value = value / 10;
    }

    give width;
}

proc padding(width: u64, text: string) -> string {
    if len(text) >= width {
        give text;
    }

    give repeat_text(" ", width - len(text)) + text;
}

proc read_source_line(file: string, line_number: u64) -> string {
    if file == "" or !is_file(file) {
        give "";
    }

    let source_text: string = read_file(file);

    if source_text == "" {
        give "";
    }

    let lines: [string] = split(source_text, "\n");

    if line_number == 0 or line_number > len(lines) {
        give "";
    }

    give lines[line_number - 1];
}

proc label_marker(label: DiagnosticLabel) -> string {
    if label.kind == DiagnosticLabelKind.Primary {
        give "^";
    }

    if label.kind == DiagnosticLabelKind.Previous {
        give "-";
    }

    give "~";
}

proc render_source_line_block(label: DiagnosticLabel, line_width: u64) -> [string] {
    let source_line: string = read_source_line(label.span.file, label.span.start_line);

    if source_line == "" {
        give [];
    }

    let line_number: string = label.span.start_line as string;
    let line_text: string = padding(line_width, line_number);
    let marker_width: u64 = label.span.length;

    if marker_width == 0 {
        set marker_width = 1 as u64;
    }

    let caret_offset: u64 = if label.span.start_column > 0 { label.span.start_column - 1 } else { 0 };
    let caret_padding: string = repeat_text(" ", caret_offset);
    let caret_marker: string = label_marker(label);
    let caret_text: string = repeat_text(caret_marker, marker_width);

    give [
        " " + line_text + " | " + source_line,
        " " + repeat_text(" ", line_width) + " | " + caret_padding + caret_text + " " + label.message
    ];
}

proc render_pipeline_block(values: [string]) -> [string] {
    let filtered: [string] = [];
    let pipeline_text: string = "";
    let i: u64 = 0;

    while i < len(values) {
        if values[i] != "" {
            set filtered = filtered + [values[i]];
        }
        set i = i + 1;
    }

    if len(filtered) == 0 {
        give [];
    }

    i = 0 as u64;
    while i < len(filtered) {
        if i > 0 {
            set pipeline_text = pipeline_text + " -> ";
        }
        set pipeline_text = pipeline_text + filtered[i];
        set i = i + 1;
    }

    give [
        "",
        "Pipeline:",
        "  " + pipeline_text
    ];
}

proc render_string_list(prefix: string, values: [string]) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;

    while i < len(values) {
        if values[i] != "" {
            set out = out + [render_detail(prefix, values[i])];
        }
        set i = i + 1;
    }

    give out;
}

proc render_suggestion(suggestion: DiagnosticSuggestion, config: DiagnosticRenderConfig) -> string {
    let prefix: string = color_wrap(config, ansi_bold() + ansi_cyan(), "suggestion");
    let kind_name: string = suggestion_kind_name(suggestion.kind);
    let location: string = span_location_text(suggestion.span);
    let applicability: string = applicability_name(suggestion.applicability);
    let text: string = "  " + prefix + ": " + kind_name + " " + location + " " + suggestion.message;

    if suggestion.replacement != "" {
        set text = text + " => `" + suggestion.replacement + "`";
    }

    if suggestion.confidence != "" {
        set text = text + " " + diag_lparen() + suggestion.confidence + " confidence" + diag_rparen();
    }

    if applicability != "" {
        set text = text + " [" + applicability + "]";
    }

    if suggestion.reason != "" and suggestion.reason != suggestion.message {
        set text = text + " because " + suggestion.reason;
    }

    give text;
}

proc append_line(text: string, line: string) -> string {
    if text == "" {
        give line;
    }

    give text + "\n" + line;
}

proc render_diagnostic(diagnostic: Diagnostic, config: DiagnosticRenderConfig) -> string {
    if config.style == DiagnosticStyle.Text {
        give diagnostic_text_line(diagnostic);
    }

    if config.style == DiagnosticStyle.Human {
        let out_human: string = diagnostic_header_text(diagnostic, config);
        let location_header: string = "  --> " + span_location_text(diagnostic.span);
        let human_out: string = append_line(out_human, location_header);
        let line_width: u64 = line_number_width(diagnostic.span.start_line);
        let i_human: u64 = 0;

        set human_out = append_line(human_out, " " + repeat_text(" ", line_width) + " |");

        while i_human < len(diagnostic.labels) {
            let label: DiagnosticLabel = diagnostic.labels[i_human];
            let blocks: [string] = render_source_line_block(label, line_width);

            if len(blocks) > 0 {
                let j_human: u64 = 0;
                while j_human < len(blocks) {
                    set human_out = append_line(human_out, blocks[j_human]);
                    set j_human = j_human + 1;
                }
            }

            set i_human = i_human + 1;
        }

        set human_out = append_line(human_out, " " + repeat_text(" ", line_width) + " |");

        if diagnostic.explanation != "" {
            set human_out = append_line(human_out, "note: " + diagnostic.explanation);
        }

        if diagnostic.root_cause != "" {
            set human_out = append_line(human_out, "cause: " + diagnostic.root_cause);
        }

        set human_out = append_line(human_out, "step 1: " + diagnostic_default_step1(diagnostic.phase, diagnostic.code));

        let cause_human: u64 = 0;
        while cause_human < len(diagnostic.cause_chain) {
                set human_out = append_line(human_out, "cause: " + diagnostic.cause_chain[cause_human]);
            set cause_human = cause_human + 1;
        }

        if diagnostic.probable_fix != "" {
            set human_out = append_line(human_out, "help: " + diagnostic.probable_fix);
        }

        let notes_human: u64 = 0;
        while notes_human < len(diagnostic.notes) {
            set human_out = append_line(human_out, "note: " + diagnostic.notes[notes_human].message);
            set notes_human = notes_human + 1;
        }

        let helps_human: u64 = 0;
        while helps_human < len(diagnostic.helps) {
            set human_out = append_line(human_out, "help: " + diagnostic.helps[helps_human].message);
            set helps_human = helps_human + 1;
        }

        if config.show_suggestions {
            let suggestion_human: u64 = 0;
            while suggestion_human < len(diagnostic.suggestions) {
                let suggestion_text: string = render_suggestion(diagnostic.suggestions[suggestion_human], config);
                set human_out = append_line(human_out, suggestion_text);
                set suggestion_human = suggestion_human + 1;
            }
        }

        let pipeline_blocks: [string] = render_pipeline_block(diagnostic.pipeline_context);
        let pipeline_human: u64 = 0;
        while pipeline_human < len(pipeline_blocks) {
            set human_out = append_line(human_out, pipeline_blocks[pipeline_human]);
            set pipeline_human = pipeline_human + 1;
        }

        if diagnostic.documentation_url != "" {
            set human_out = append_line(human_out, "docs: " + diagnostic.documentation_url);
        }

        give human_out;
    }

    let out: string = diagnostic_header_text(diagnostic, config);

    set out = append_line(out, " --> " + span_location_text(diagnostic.span));

    let i: u64 = 0;

    while i < len(diagnostic.labels) {
        set out = append_line(out, render_label(diagnostic.labels[i], config));
        set i = i + 1;
    }

    if diagnostic.rule != "" {
        set out = append_line(out, render_detail("rule", diagnostic.rule));
    }

    if diagnostic.subject_symbol != "" {
        set out = append_line(out, render_detail("symbol", diagnostic.subject_symbol));
    }

    if diagnostic.subject_type != "" {
        set out = append_line(out, render_detail("type", diagnostic.subject_type));
    }

    if diagnostic.subject_borrow != "" {
        set out = append_line(out, render_detail("borrow", diagnostic.subject_borrow));
    }

    if diagnostic.explanation != "" {
        set out = append_line(out, render_detail("explanation", diagnostic.explanation));
    }

    if diagnostic.technical_note != "" {
        set out = append_line(out, render_detail("technical_note", diagnostic.technical_note));
    }

    if diagnostic.root_cause != "" {
        set out = append_line(out, render_detail("root_cause", diagnostic.root_cause));
    }

    set out = append_line(out, render_detail("step_1", diagnostic_default_step1(diagnostic.phase, diagnostic.code)));

    if diagnostic.probable_fix != "" {
        set out = append_line(out, render_detail("probable_fix", diagnostic.probable_fix));
    }

    let extra_lines: [string] = render_string_list("cause", diagnostic.cause_chain);
    i = 0 as u64;
    while i < len(extra_lines) {
        set out = append_line(out, extra_lines[i]);
        set i = i + 1;
    }

    let pipeline_lines: [string] = render_string_list("pipeline", diagnostic.pipeline_context);
    i = 0 as u64;
    while i < len(pipeline_lines) {
        set out = append_line(out, pipeline_lines[i]);
        set i = i + 1;
    }

    let related_lines: [string] = render_string_list("related", diagnostic.related_errors);
    i = 0 as u64;
    while i < len(related_lines) {
        set out = append_line(out, related_lines[i]);
        set i = i + 1;
    }

    if config.show_notes {
        set i = 0 as u64;

        while i < len(diagnostic.notes) {
            set out = append_line(out, render_note(diagnostic.notes[i], config));
            set i = i + 1;
        }
    }

    if config.show_helps {
        set i = 0 as u64;

        while i < len(diagnostic.helps) {
            set out = append_line(out, render_help(diagnostic.helps[i], config));
            set i = i + 1;
        }
    }

    if config.show_suggestions {
        set i = 0 as u64;

        while i < len(diagnostic.suggestions) {
            set out = append_line(out, render_suggestion(diagnostic.suggestions[i], config));
            set i = i + 1;
        }
    }

    if diagnostic.documentation_url != "" {
        set out = append_line(out, render_detail("docs", diagnostic.documentation_url));
    }

    give out;
}

proc render_report(report: DiagnosticReport, config: DiagnosticRenderConfig) -> string {
    let out: string = "";
    let i: u64 = 0;

    while i < len(report.diagnostics) {
        if out != "" {
            set out = out + "\n\n";
        }

        set out = out + render_diagnostic(report.diagnostics[i], config);

        set i = i + 1;
    }

    if out == "" {
        give "diagnostics: ok";
    }

    give out;
}

proc report_summary(report: DiagnosticReport) -> string {
    if report.valid {
        give "diagnostics ok";
    }

    let error_count: string = report.error_count as string;
    let warning_count: string = report.warning_count as string;
    let fatal_count: string = report.fatal_count as string;
    give "diagnostics failed: " + error_count + " error" + diag_lparen() + "s" + diag_rparen() + ", " + warning_count + " warning" + diag_lparen() + "s" + diag_rparen() + ", " + fatal_count + " fatal" + diag_lparen() + "s" + diag_rparen();
}

proc first_backtick_fragment(text: string) -> string {
    let start: int = find(text, "`");

    if start < 0 {
        give "";
    }

    let rest_start_i: int = start + 1;
    let rest_start: u64 = rest_start_i as u64;
    let rest: string = slice(text, rest_start, len(text));
    let end0: int = find(rest, "`");

    if end0 < 0 {
        give "";
    }

    let fragment_end: u64 = end0 as u64;
    give slice(rest, 0, fragment_end);
}

proc lexer_rule_from_code(code: string) -> string {
    if code == "LEX_E_INVALID_CHAR" {
        give "source character set";
    }

    if code == "LEX_E_UNTERMINATED_STRING" {
        give "string literal termination";
    }

    if code == "LEX_E_UNTERMINATED_CHAR" or code == "LEX_E_INVALID_CHAR_LITERAL" {
        give "char literal shape";
    }

    if code == "LEX_E_INVALID_NUMBER" {
        give "numeric literal grammar";
    }

    if code == "LEX_E_UNTERMINATED_BLOCK_COMMENT" or code == "LEX_E_UNTERMINATED_REGION_COMMENT" {
        give "comment termination";
    }

    if code == "LEX_E_INVALID_UNICODE" or code == "LEX_E_INVALID_UNICODE_ESCAPE" {
        give "unicode escape syntax";
    }

    if code == "LEX_E_TOKEN_TOO_LARGE" {
        give "maximum token byte length";
    }

    if code == "LEX_E_INVALID_UTF8" {
        give "utf-8 source decoding";
    }

    if code == "LEX_E_INVALID_ESCAPE" {
        give "escape sequence grammar";
    }

    give "lexical token formation";
}

proc lexer_explanation_from_surface(code: string, message: string) -> string {
    let fragment: string = first_backtick_fragment(message);

    if code == "LEX_E_INVALID_CHAR" {
        if fragment != "" {
            give "The lexer encountered the unsupported character `" + fragment + "` and could not classify it as whitespace, punctuation, identifier, or literal content.";
        }

        give "The lexer encountered a source character that does not belong to the Vitte lexical grammar.";
    }

    if code == "LEX_E_UNTERMINATED_STRING" {
        give "The lexer reached the end of the current string token before finding the closing quote, so parsing cannot continue with a stable token stream.";
    }

    if code == "LEX_E_UNTERMINATED_CHAR" {
        give "The lexer reached the end of the char literal before finding the closing quote, so the token does not represent exactly one character.";
    }

    if code == "LEX_E_INVALID_CHAR_LITERAL" {
        give "A Vitte char literal must encode exactly one character after escape decoding, but this token does not satisfy that rule.";
    }

    if code == "LEX_E_INVALID_NUMBER" {
        give "The numeric token does not match the accepted integer or float grammar for its radix, separators, or suffix.";
    }

    if code == "LEX_E_UNTERMINATED_BLOCK_COMMENT" or code == "LEX_E_UNTERMINATED_REGION_COMMENT" {
        give "The lexer entered a comment construct and reached the end of the source before its terminating delimiter was found.";
    }

    if code == "LEX_E_INVALID_UNICODE" or code == "LEX_E_INVALID_UNICODE_ESCAPE" {
        give "The lexer found a unicode escape that does not encode a valid scalar value or does not follow the required escape syntax.";
    }

    if code == "LEX_E_INVALID_UTF8" {
        give "The source buffer contains bytes that are not valid UTF-8, so the lexer cannot interpret the next source character reliably.";
    }

    if code == "LEX_E_TOKEN_TOO_LARGE" {
        give "The lexer accepted the token shape, but its byte length exceeded the implementation limit for a single token.";
    }

    if code == "LEX_E_INVALID_ESCAPE" {
        give "The escape sequence inside the literal is not recognized by the Vitte lexer.";
    }

    give "The lexer could not form a valid token from this part of the source.";
}

proc lexer_probable_fix_from_surface(code: string, message: string) -> string {
    let fragment: string = first_backtick_fragment(message);

    if code == "LEX_E_INVALID_CHAR" {
        if fragment != "" {
            give "remove `" + fragment + "` or replace it with valid Vitte syntax";
        }

        give "remove or replace the unsupported source character";
    }

    if code == "LEX_E_UNTERMINATED_STRING" {
        give "insert the missing closing quote for the string literal";
    }

    if code == "LEX_E_UNTERMINATED_CHAR" or code == "LEX_E_INVALID_CHAR_LITERAL" {
        give "rewrite the char literal so it contains exactly one character and a closing quote";
    }

    if code == "LEX_E_INVALID_NUMBER" {
        give "rewrite the numeric literal using a valid radix, separator, and suffix combination";
    }

    if code == "LEX_E_UNTERMINATED_BLOCK_COMMENT" {
        give "close the block comment with `*/`";
    }

    if code == "LEX_E_UNTERMINATED_REGION_COMMENT" {
        give "close the region comment with `>>>`";
    }

    if code == "LEX_E_INVALID_UNICODE" or code == "LEX_E_INVALID_UNICODE_ESCAPE" {
        give "use a valid unicode scalar escape such as `u+0041`";
    }

    if code == "LEX_E_INVALID_UTF8" {
        give "save the source file as UTF-8 or remove the offending byte sequence";
    }

    if code == "LEX_E_TOKEN_TOO_LARGE" {
        give "split the token into smaller pieces or move the data into runtime input";
    }

    if code == "LEX_E_INVALID_ESCAPE" {
        give "replace the escape with a supported sequence such as `\\n`, `\\t`, `\\\\`, `\\\"`, or a valid unicode escape";
    }

    give "rewrite this token so it matches the Vitte lexical grammar";
}

proc lexer_documentation_from_code(code: string) -> string {
    if code == "LEX_E_INVALID_CHAR" {
        give "docs://language/lexer/source-characters";
    }

    if code == "LEX_E_UNTERMINATED_STRING" {
        give "docs://language/lexer/string-literals";
    }

    if code == "LEX_E_UNTERMINATED_CHAR" or code == "LEX_E_INVALID_CHAR_LITERAL" {
        give "docs://language/lexer/char-literals";
    }

    if code == "LEX_E_INVALID_NUMBER" {
        give "docs://language/lexer/numeric-literals";
    }

    if code == "LEX_E_UNTERMINATED_BLOCK_COMMENT" or code == "LEX_E_UNTERMINATED_REGION_COMMENT" {
        give "docs://language/lexer/comments";
    }

    if code == "LEX_E_INVALID_UNICODE" or code == "LEX_E_INVALID_UNICODE_ESCAPE" or code == "LEX_E_INVALID_UTF8" {
        give "docs://language/lexer/unicode";
    }

    if code == "LEX_E_TOKEN_TOO_LARGE" {
        give "docs://language/implementation/lexer-limits";
    }

    if code == "LEX_E_INVALID_ESCAPE" {
        give "docs://language/lexer/escape-sequences";
    }

    give "docs://language/lexer";
}

proc diagnostic_from_surface(code: string, message: string, span: SourceSpan, fatal: bool, byte_offset: u64) -> Diagnostic {
    let phase: DiagnosticPhase = phase_from_code(code);
    let severity: DiagnosticSeverity = if fatal {
        DiagnosticSeverity.Fatal
    } else {
        severity_from_code(code)
    };
    let diag0: Diagnostic = diagnostic_create(code, phase, severity, message, span);
    let diag1: Diagnostic = diag0;

    if phase == DiagnosticPhase.Lexer {
        let diag2: Diagnostic = diagnostic_with_rule(diag1, lexer_rule_from_code(code));
        let diag3: Diagnostic = diagnostic_with_explanation(diag2, lexer_explanation_from_surface(code, message));
        let diag4: Diagnostic = diagnostic_with_technical_note(diag3, "Detected during tokenization before parsing. Source offsets are tracked in bytes.");
        let diag5: Diagnostic = diagnostic_with_documentation(diag4, lexer_documentation_from_code(code));
        let diag6: Diagnostic = diagnostic_with_root_cause(diag5, "lexer could not form a valid token from the source bytes at this location");
        let diag7: Diagnostic = diagnostic_with_probable_fix(diag6, lexer_probable_fix_from_surface(code, message));
        let diag9: Diagnostic = diagnostic_with_note(diag7, "detected by the lexer before parser recovery");

        if byte_offset > 0 {
            let byte_offset_text: string = byte_offset as string;
            give diagnostic_with_note(diag9, "byte offset: " + byte_offset_text);
        }

        give diag9;
    }

    if phase == DiagnosticPhase.Parser {
        give diag1;
    }

    if phase == DiagnosticPhase.AstValidation {
        let diag2: Diagnostic = diagnostic_with_rule(diag1, "validated abstract syntax tree invariants");
        give diagnostic_with_note(diag2, "detected after parsing while validating AST structural invariants");
    }

    if phase == DiagnosticPhase.ModuleResolution {
        give diagnostic_with_note(diag1, "detected while resolving modules and imports");
    }

    if phase == DiagnosticPhase.SymbolResolution {
        give diagnostic_with_note(diag1, "detected while resolving names to visible symbols");
    }

    if phase == DiagnosticPhase.MirLowering {
        give diag1;
    }

    if phase == DiagnosticPhase.MirVerification {
        give diag1;
    }

    if phase == DiagnosticPhase.Backend {
        give diag1;
    }

    if phase == DiagnosticPhase.Linker {
        give diag1;
    }

    if phase == DiagnosticPhase.RuntimeExecution {
        give diag1;
    }

    give diag1;
}

proc phase_from_code(code: string) -> DiagnosticPhase {
    if starts_with(code, "LEX_") {
        give DiagnosticPhase.Lexer;
    }

    if starts_with(code, "FLEX") {
        give DiagnosticPhase.Lexer;
    }

    if starts_with(code, "P") or starts_with(code, "E00") {
        give DiagnosticPhase.Parser;
    }

    if starts_with(code, "FAST") {
        give DiagnosticPhase.AstValidation;
    }

    if code == "SEMA_E_INVALID_IMPORT" or code == "SEMA_E_INVALID_EXPORT" or code == "SEMA_E_INVALID_MODULE" or starts_with(code, "MODULE_") {
        give DiagnosticPhase.ModuleResolution;
    }

    if code == "SEMA_E_DUPLICATE_SYMBOL" or code == "SEMA_E_UNKNOWN_SYMBOL" or starts_with(code, "SYMBOL_") {
        give DiagnosticPhase.SymbolResolution;
    }

    if starts_with(code, "E10") or starts_with(code, "SEMA_") {
        give DiagnosticPhase.Sema;
    }

    if starts_with(code, "E20") {
        give DiagnosticPhase.Hir;
    }

    if starts_with(code, "TYPECK_") {
        give DiagnosticPhase.Typeck;
    }

    if starts_with(code, "BORROWCK_") {
        give DiagnosticPhase.Borrowck;
    }

    if starts_with(code, "MIR_") {
        give DiagnosticPhase.Mir;
    }

    if starts_with(code, "MIRLOWER_") {
        give DiagnosticPhase.MirLowering;
    }

    if starts_with(code, "MIRVERIFY_") {
        give DiagnosticPhase.MirVerification;
    }

    if starts_with(code, "IR_") {
        give DiagnosticPhase.Ir;
    }

    if starts_with(code, "BACKEND_") {
        give DiagnosticPhase.Backend;
    }

    if starts_with(code, "LINKER_") or starts_with(code, "LINK_E_") {
        give DiagnosticPhase.Linker;
    }

    if starts_with(code, "RUNTIME_") {
        give DiagnosticPhase.RuntimeExecution;
    }

    if starts_with(code, "DRIVER_") {
        give DiagnosticPhase.Driver;
    }

    give DiagnosticPhase.Internal;
}

proc severity_from_code(code: string) -> DiagnosticSeverity {
    if code == "PLOOP" or code == "P000_UNBALANCED" or ends_with(code, "_INTERNAL") {
        give DiagnosticSeverity.Fatal;
    }

    give DiagnosticSeverity.Error;
}

proc diagnostic_from_catalog(code: string, message: string, span: SourceSpan) -> Diagnostic {
    give diagnostic_create(code, phase_from_code(code), severity_from_code(code), message, span);
}

proc diagnostic_explain_text(code: string) -> string {
    give diagnostic_explain_text_lang(code, "en");
}

proc diagnostic_explain_text_lang(code: string, lang: string) -> string {
    let phase: DiagnosticPhase = phase_from_code(code);
    let span: SourceSpan = span_create("<explain>", 1, 1, 1);
    let locale: string = fluent_catalog_normalize_locale(lang);
    let localized_message: string = fluent_catalog_lookup(locale, code);
    let title: string = "diagnostic explanation for " + code;
    if localized_message != "" {
        set title = localized_message;
    }
    let diag: Diagnostic = diagnostic_create(code, phase, severity_from_code(code), title, span);
    let out: string = "error code: " + code;
    set out = out + "\nlang: " + locale;
    set out = out + "\nphase: " + phase_name(phase);
    set out = out + "\nfamily: " + diagnostic_code_family(phase, code);
    set out = out + "\nrule: " + diag.rule;
    set out = out + "\nmessage: " + title;
    set out = out + "\nsummary: " + diag.explanation;
    set out = out + "\ncause: " + diag.root_cause;
    set out = out + "\nstep 1: " + diagnostic_default_step1(phase, code);
    set out = out + "\ncorrection strategy: " + diagnostic_correction_strategy(phase, code);
    set out = out + "\nrecovery scope: " + diagnostic_recovery_scope(phase, code);
    set out = out + "\nconfidence: " + diagnostic_confidence(phase, code);
    set out = out + "\nfix: " + diag.probable_fix;
    set out = out + "\nexample: " + diagnostic_default_example(phase, code);
    set out = out + "\ndocs: " + diag.documentation_url;

    if len(diag.helps) > 0 {
        set out = out + "\nhelp: " + diag.helps[0].message;
    }

    if len(diag.suggestions) > 0 {
        set out = out + "\nquick fix: " + diag.suggestions[0].message;
    }

    give out;
}

proc parser_expected_identifier(span: SourceSpan) -> Diagnostic {
    give diagnostic_with_help(
        diagnostic_error(
            "E0001",
            DiagnosticPhase.Parser,
            "expected identifier",
            span
        ),
        "insert a valid identifier that matches the surrounding declaration or expression"
    );
}

proc parser_expected_expression(span: SourceSpan) -> Diagnostic {
    give diagnostic_with_help(
        diagnostic_error(
            "E0002",
            DiagnosticPhase.Parser,
            "expected expression",
            span
        ),
        "write a literal, name, call, or grouped expression that fits the grammar at this position"
    );
}

proc parser_unclosed_block(open_span: SourceSpan, eof_span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("P000_UNBALANCED", DiagnosticPhase.Parser, "unclosed block", eof_span);
    let open_label: DiagnosticLabel = previous_label("block starts here", open_span);
    set diag = diagnostic_with_label(diag, open_label);
    set diag = diagnostic_with_help(diag, "insert the missing closing delimiter and recheck the block structure above it");

    give diag;
}

proc lexer_unterminated_string(span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("LEX_E_UNTERMINATED_STRING", DiagnosticPhase.Lexer, "unterminated string literal", span);
    give diagnostic_with_help(diag, "terminate the string with a matching quote");
}

proc sema_unknown_identifier(name: string, span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("E1005", DiagnosticPhase.Sema, "unknown identifier `" + name + "`", span);
    set diag = diagnostic_with_note(diag, "no matching local, import, or item exists in this scope");
    set diag = diagnostic_with_help(diag, "declare the symbol before use or import it from a module");

    give diag;
}

proc typeck_assignment_mismatch(expected: string, found: string, span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("TYPECK_E_ASSIGN_MISMATCH", DiagnosticPhase.Typeck, "assignment expects `" + expected + "` but receives `" + found + "`", span);
    let expected_label: DiagnosticLabel = secondary_label("expected `" + expected + "` because the assignment target imposes it", span);
    let found_label: DiagnosticLabel = secondary_label("obtained `" + found + "` from the assigned expression", span);
    set diag = diagnostic_with_label(diag, expected_label);
    set diag = diagnostic_with_label(diag, found_label);
    set diag = diagnostic_add_cause(diag, "why expected type is imposed: assignment target type");
    set diag = diagnostic_add_cause(diag, "origin of obtained type: assigned expression");
    set diag = diagnostic_with_help(diag, "change the assigned value or add an explicit conversion");

    give diag;
}

proc borrowck_use_after_move(name: string, use_span: SourceSpan, move_span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("BORROWCK_E_USE_AFTER_MOVE", DiagnosticPhase.Borrowck, "value `" + name + "` used after move", use_span);
    let move_label: DiagnosticLabel = previous_label("value was moved here", move_span);
    set diag = diagnostic_with_label(diag, move_label);
    set diag = diagnostic_with_note(diag, "moved values cannot be accessed again until reinitialized");
    set diag = diagnostic_with_help(diag, "borrow the value instead of moving it, or clone it if duplication is intended");

    give diag;
}

proc borrowck_mutable_borrow_conflict(name: string, request_span: SourceSpan, active_span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("BORROWCK_E_MUTABLE_BORROW_CONFLICT", DiagnosticPhase.Borrowck, "cannot mutably borrow `" + name + "` while another borrow is active", request_span);
    let active_label: DiagnosticLabel = previous_label("active borrow starts here", active_span);
    set diag = diagnostic_with_label(diag, active_label);
    set diag = diagnostic_with_label(diag, secondary_label("conflict appears here: mutable borrow requires exclusive access", request_span));
    set diag = diagnostic_with_note(diag, "mutable access requires exclusive access");
    set diag = diagnostic_with_help(diag, "end the previous borrow before taking mutable access");

    give diag;
}

proc ir_invalid_terminator(span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic_error("IR_E_INVALID_TERMINATOR", DiagnosticPhase.Ir, "invalid block terminator", span);
    set diag = diagnostic_with_note(diag, "basic blocks must end with exactly one terminator");
    set diag = diagnostic_with_help(diag, "insert a return, jump, branch, or unreachable instruction");

    give diag;
}

proc attach_expected_found_details(diagnostic: Diagnostic, rule_name: string, expected: string, found: string, expected_origin: string, found_origin: string, probable_fix: string) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_with_rule(diagnostic, rule_name);
    let diag1: Diagnostic = diagnostic_with_explanation(diag0, "The expected type is `" + expected + "` because of " + expected_origin + "; the obtained type is `" + found + "` from " + found_origin + ".");
    let diag2: Diagnostic = diagnostic_with_root_cause(diag1, rule_name + " imposes `" + expected + "` here, but the checked value has type `" + found + "`");
    let diag3: Diagnostic = diagnostic_add_cause(diag2, "why expected type is imposed: " + expected_origin);
    let diag4: Diagnostic = diagnostic_add_cause(diag3, "origin of obtained type: " + found_origin);
    let diag5: Diagnostic = diagnostic_with_subject_type(diag4, expected);
    let diag6: Diagnostic = diagnostic_with_label(diag5, secondary_label("expected `" + expected + "` from " + expected_origin, diagnostic.span));
    let diag7: Diagnostic = diagnostic_with_label(diag6, secondary_label("obtained `" + found + "` from " + found_origin, diagnostic.span));

    if probable_fix != "" {
        give diagnostic_with_probable_fix(diag7, probable_fix);
    }

    give diag7;
}

proc typeck_argument_mismatch(expected: string, found: string, expected_origin: string, found_origin: string, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("TYPECK_E_ARGUMENT_MISMATCH", DiagnosticPhase.Typeck, "call argument expects `" + expected + "` but receives `" + found + "`", span);
    let diag1: Diagnostic = diagnostic_with_help(diag0, "pass a `" + expected + "` value or change the callee signature");
    give attach_expected_found_details(diag1, "function argument compatibility", expected, found, expected_origin, found_origin, "align the argument type with the parameter type");
}

proc typeck_invalid_call_arity(callee: string, expected_arity: u64, found_arity: u64, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("TYPECK_E_CALL_ARITY", DiagnosticPhase.Typeck, "wrong number of call arguments", span);
    let diag1: Diagnostic = diagnostic_with_rule(diag0, "function call arity");
    let diag2: Diagnostic = diagnostic_with_subject_symbol(diag1, callee);
    let expected_arity_text: string = expected_arity as string;
    let found_arity_text: string = found_arity as string;
    let diag3: Diagnostic = diagnostic_add_cause(diag2, "callee `" + callee + "` expects " + expected_arity_text + " argument" + diag_lparen() + "s" + diag_rparen());
    let diag4: Diagnostic = diagnostic_add_cause(diag3, "call site provided " + found_arity_text + " argument" + diag_lparen() + "s" + diag_rparen());
    give diagnostic_with_probable_fix(diag4, "add or remove arguments so the call matches the callee signature");
}

proc typeck_if_branch_mismatch(then_type: string, else_type: string, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("TYPECK_E_IF_BRANCH_MISMATCH", DiagnosticPhase.Typeck, "if branches produce different result types", span);
    let diag1: Diagnostic = diagnostic_with_help(diag0, "make both branches return the same type or insert an explicit conversion");
    give attach_expected_found_details(diag1, "if expression branch unification", then_type, else_type, "the then branch result", "the else branch result", "normalize both branches to one common result type");
}

proc typeck_non_exhaustive_match(missing_case: string, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("TYPECK_E_MATCH_NON_EXHAUSTIVE", DiagnosticPhase.Typeck, "match expression is not exhaustive", span);
    let diag1: Diagnostic = diagnostic_with_rule(diag0, "pattern coverage completeness");
    let diag2: Diagnostic = diagnostic_add_cause(diag1, "missing case: `" + missing_case + "`");
    give diagnostic_with_probable_fix(diag2, "add the missing arm or a catch-all pattern");
}

proc borrowck_move_while_borrowed(name: string, move_span: SourceSpan, borrow_span: SourceSpan, use_span: SourceSpan, lifetime_text: string) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("BORROWCK_E_MOVE_WHILE_BORROWED", DiagnosticPhase.Borrowck, "cannot move `" + name + "` while a borrow is still active", use_span);
    let diag1: Diagnostic = diagnostic_with_subject_symbol(diag0, name);
    let diag2: Diagnostic = diagnostic_with_subject_borrow(diag1, lifetime_text);
    let borrow_label: DiagnosticLabel = previous_label("borrow starts here", borrow_span);
    let move_label: DiagnosticLabel = secondary_label("move attempted here", move_span);
    let diag3: Diagnostic = diagnostic_with_label(diag2, borrow_label);
    let diag4: Diagnostic = diagnostic_with_label(diag3, move_label);
    let borrow_start_line: string = borrow_span.start_line as string;
    let diag5: Diagnostic = diagnostic_add_cause(diag4, "borrow is active from line " + borrow_start_line + " to about line " + lifetime_text);
    let diag6: Diagnostic = diagnostic_add_cause(diag5, "move would invalidate a reference that may still be used later");
    give diagnostic_with_probable_fix(diag6, "shorten the borrow scope, clone the value, or move after the borrow ends");
}

proc borrowck_shared_borrow_conflict(name: string, request_span: SourceSpan, active_span: SourceSpan, lifetime_text: string) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("BORROWCK_E_SHARED_BORROW_CONFLICT", DiagnosticPhase.Borrowck, "cannot shared-borrow `" + name + "` while a mutable borrow is active", request_span);
    let diag1: Diagnostic = diagnostic_with_subject_symbol(diag0, name);
    let diag2: Diagnostic = diagnostic_with_subject_borrow(diag1, lifetime_text);
    let active_label: DiagnosticLabel = previous_label("mutable borrow starts here", active_span);
    let diag3: Diagnostic = diagnostic_with_label(diag2, active_label);
    let diag4: Diagnostic = diagnostic_add_cause(diag3, "the mutable borrow remains active until about line " + lifetime_text);
    give diagnostic_with_probable_fix(diag4, "use a shorter mutable borrow scope or replace it with a shared reference");
}

proc borrowck_lifetime_too_short(name: string, borrow_span: SourceSpan, drop_span: SourceSpan, lifetime_text: string) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("BORROWCK_E_LIFETIME_TOO_SHORT", DiagnosticPhase.Borrowck, "borrowed value `" + name + "` does not live long enough", borrow_span);
    let diag1: Diagnostic = diagnostic_with_subject_symbol(diag0, name);
    let diag2: Diagnostic = diagnostic_with_subject_borrow(diag1, lifetime_text);
    let borrow_label: DiagnosticLabel = previous_label("borrow created here", borrow_span);
    let drop_label: DiagnosticLabel = secondary_label("owner stops being valid here", drop_span);
    let diag3: Diagnostic = diagnostic_with_label(diag2, borrow_label);
    let diag4: Diagnostic = diagnostic_with_label(diag3, drop_label);
    let diag5: Diagnostic = diagnostic_add_cause(diag4, "borrow needs to survive until about line " + lifetime_text);
    give diagnostic_with_probable_fix(diag5, "move the owner to a longer-lived scope or keep the reference inside a shorter scope");
}

proc mir_cfg_incoherent(span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_error("MIR_E_CFG_INCOHERENT", DiagnosticPhase.MirVerification, "MIR control-flow graph is incoherent", span);
    let diag1: Diagnostic = diagnostic_with_rule(diag0, "each MIR edge must point to a valid reachable basic block");
    give diagnostic_with_help(diag1, "repair the malformed control-flow edge or lower the source again");
}

proc backend_unsupported_target_detail(backend_name: string, target_name: string, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_fatal("BACKEND_E_UNSUPPORTED_TARGET", DiagnosticPhase.Backend, "backend target is not supported", span);
    let diag1: Diagnostic = diagnostic_add_pipeline_context(diag0, diag_kv("backend", backend_name));
    let diag2: Diagnostic = diagnostic_add_pipeline_context(diag1, diag_kv("target", target_name));
    give diagnostic_with_probable_fix(diag2, "switch target or select a backend that supports " + target_name);
}

proc backend_command_failed(phase: DiagnosticPhase, code: string, message: string, backend_name: string, target_name: string, command_text: string, stderr_text: string, expected_artifact: string, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = diagnostic_fatal(code, phase, message, span);
    let diag1: Diagnostic = diagnostic_add_pipeline_context(diag0, diag_kv("backend", backend_name));
    let diag2: Diagnostic = diagnostic_add_pipeline_context(diag1, diag_kv("target", target_name));
    let diag3: Diagnostic = diagnostic_add_cause(diag2, "external command: " + command_text);
    let diag4: Diagnostic = diagnostic_add_cause(diag3, "stderr: " + stderr_text);
    give diagnostic_with_probable_fix(diag4, "ensure the tool exists and produces `" + expected_artifact + "`");
}

proc linker_unresolved_symbol(symbol_name: string, backend_name: string, target_name: string, command_text: string, stderr_text: string, expected_artifact: string, span: SourceSpan) -> Diagnostic {
    let diag0: Diagnostic = backend_command_failed(DiagnosticPhase.Linker, "LINKER_E_UNRESOLVED_SYMBOL", "linker could not resolve external symbol `" + symbol_name + "`", backend_name, target_name, command_text, stderr_text, expected_artifact, span);
    give diagnostic_with_subject_symbol(diag0, symbol_name);
}

