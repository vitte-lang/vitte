space vitte/compiler/diagnostics/catalog

use vitte/compiler/frontend/ast/node.{
  AstSpan,
  ast_span_empty
}

pick DiagnosticSeverity {
  Info
  Warning
  Error
  Fatal
}

pick DiagnosticCategory {
  Lexer
  Parser
  Ast
  Hir
  Mir
  Borrowck
  Typeck
  Backend
  Linker
  Runtime
  Driver
  Bootstrap
  Internal
  Unknown
}

form DiagnosticLabel {
  message: string
  span: AstSpan
  primary: bool
  valid: bool
}

form DiagnosticNote {
  text: string
  valid: bool
}

form DiagnosticCode {
  code: string
  category: DiagnosticCategory
  severity: DiagnosticSeverity
  title: string
  explanation: string
  notes: [DiagnosticNote]
  labels: [DiagnosticLabel]
  valid: bool
}

form DiagnosticCatalog {
  diagnostics: [DiagnosticCode]
  version: string
  valid: bool
}

proc diagnostic_label(
  message: string,
  span: AstSpan,
  primary: bool
) -> DiagnosticLabel {

  give DiagnosticLabel {
    message: message,
    span: span,
    primary: primary,
    valid: message != ""
  }
}

proc diagnostic_note(
  text: string
) -> DiagnosticNote {

  give DiagnosticNote {
    text: text,
    valid: text != ""
  }
}

proc diagnostic_code(
  code: string,
  category: DiagnosticCategory,
  severity: DiagnosticSeverity,
  title: string,
  explanation: string
) -> DiagnosticCode {

  give DiagnosticCode {
    code: code,
    category: category,
    severity: severity,
    title: title,
    explanation: explanation,
    notes: [],
    labels: [],
    valid:
      code != ""
      and title != ""
      and explanation != ""
  }
}

proc add_note(
  diagnostic: DiagnosticCode,
  note: DiagnosticNote
) -> DiagnosticCode {

  make next = diagnostic

  set next.notes =
    next.notes + [note]

  give next
}

proc add_label(
  diagnostic: DiagnosticCode,
  label: DiagnosticLabel
) -> DiagnosticCode {

  make next = diagnostic

  set next.labels =
    next.labels + [label]

  give next
}

proc empty_catalog() -> DiagnosticCatalog {

  give DiagnosticCatalog {
    diagnostics: [],
    version: "catalog-v1",
    valid: true
  }
}

proc register(
  catalog: DiagnosticCatalog,
  diagnostic: DiagnosticCode
) -> DiagnosticCatalog {

  make next = catalog

  set next.diagnostics =
    next.diagnostics + [diagnostic]

  give next
}

proc find_by_code(
  catalog: DiagnosticCatalog,
  code: string
) -> DiagnosticCode {

  let i: i32 = 0

  while i < len(catalog.diagnostics) {

    if catalog.diagnostics[i].code == code {
      give catalog.diagnostics[i]
    }

    set i = i + 1
  }

  give diagnostic_code(
    "UNKNOWN",
    DiagnosticCategory.Unknown,
    DiagnosticSeverity.Error,
    "unknown diagnostic",
    "diagnostic code not found"
  )
}

proc bootstrap_catalog() -> DiagnosticCatalog {

  make catalog =
    empty_catalog()

  <<< ===================================================== >>>
  <<< Lexer diagnostics                                     >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      add_note(
        diagnostic_code(
          "LEX_E_UNTERMINATED_STRING",
          DiagnosticCategory.Lexer,
          DiagnosticSeverity.Error,
          "unterminated string literal",
          "lexer reached end of file before string termination"
        ),

        diagnostic_note(
          "expected closing quote"
        )
      )
    )

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "LEX_E_INVALID_CHAR",
        DiagnosticCategory.Lexer,
        DiagnosticSeverity.Error,
        "invalid character",
        "source contains unsupported character sequence"
      )
    )

  <<< ===================================================== >>>
  <<< Parser diagnostics                                    >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "PARSE_E_EXPECTED_TOKEN",
        DiagnosticCategory.Parser,
        DiagnosticSeverity.Error,
        "expected token",
        "parser expected another token kind"
      )
    )

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "PARSE_E_UNEXPECTED_TOKEN",
        DiagnosticCategory.Parser,
        DiagnosticSeverity.Error,
        "unexpected token",
        "unexpected token encountered during parsing"
      )
    )

  <<< ===================================================== >>>
  <<< AST diagnostics                                       >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "AST_E_INVALID_NODE",
        DiagnosticCategory.Ast,
        DiagnosticSeverity.Error,
        "invalid AST node",
        "AST node failed semantic invariants"
      )
    )

  <<< ===================================================== >>>
  <<< HIR diagnostics                                       >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "HIR_E_INVALID_EXPR",
        DiagnosticCategory.Hir,
        DiagnosticSeverity.Error,
        "invalid HIR expression",
        "HIR expression validation failed"
      )
    )

  <<< ===================================================== >>>
  <<< MIR diagnostics                                       >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "MIR_E_INVALID_BLOCK",
        DiagnosticCategory.Mir,
        DiagnosticSeverity.Error,
        "invalid MIR block",
        "MIR control flow graph is invalid"
      )
    )

  <<< ===================================================== >>>
  <<< Borrow checker diagnostics                            >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "BORROWCK_E_MOVE_AFTER_BORROW",
        DiagnosticCategory.Borrowck,
        DiagnosticSeverity.Error,
        "move after borrow",
        "value moved while active borrow exists"
      )
    )

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "BORROWCK_E_MUTABLE_ALIAS",
        DiagnosticCategory.Borrowck,
        DiagnosticSeverity.Error,
        "mutable alias violation",
        "multiple mutable references detected"
      )
    )

  <<< ===================================================== >>>
  <<< Type checker diagnostics                              >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "TYPECK_E_ASSIGN_MISMATCH",
        DiagnosticCategory.Typeck,
        DiagnosticSeverity.Error,
        "assignment type mismatch",
        "assigned expression type does not match target type"
      )
    )

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "TYPECK_E_UNKNOWN_TYPE",
        DiagnosticCategory.Typeck,
        DiagnosticSeverity.Error,
        "unknown type",
        "type resolution failed"
      )
    )

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "TYPECK_E_INVALID_CALL",
        DiagnosticCategory.Typeck,
        DiagnosticSeverity.Error,
        "invalid function call",
        "call arguments do not match function signature"
      )
    )

  <<< ===================================================== >>>
  <<< Backend diagnostics                                   >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "BACKEND_E_UNSUPPORTED_TARGET",
        DiagnosticCategory.Backend,
        DiagnosticSeverity.Fatal,
        "unsupported backend target",
        "backend does not support selected target"
      )
    )

  <<< ===================================================== >>>
  <<< Linker diagnostics                                    >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "LINK_E_UNDEFINED_SYMBOL",
        DiagnosticCategory.Linker,
        DiagnosticSeverity.Error,
        "undefined symbol",
        "linker failed to resolve symbol"
      )
    )

  <<< ===================================================== >>>
  <<< Runtime diagnostics                                   >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "RUNTIME_E_PANIC",
        DiagnosticCategory.Runtime,
        DiagnosticSeverity.Fatal,
        "runtime panic",
        "runtime entered unrecoverable state"
      )
    )

  <<< ===================================================== >>>
  <<< Driver diagnostics                                    >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "DRIVER_E_INVALID_ARGUMENT",
        DiagnosticCategory.Driver,
        DiagnosticSeverity.Error,
        "invalid command line argument",
        "driver received unsupported argument"
      )
    )

  <<< ===================================================== >>>
  <<< Bootstrap diagnostics                                 >>>
  <<< ===================================================== >>>

  set catalog =
    register(
      catalog,

      diagnostic_code(
        "BOOTSTRAP_E_STAGE_FAILURE",
        DiagnosticCategory.Bootstrap,
        DiagnosticSeverity.Fatal,
        "bootstrap stage failure",
        "compiler bootstrap stage failed"
      )
    )

  give catalog
}

proc catalog_size(
  catalog: DiagnosticCatalog
) -> i32 {

  give len(catalog.diagnostics)
}

proc catalog_valid(
  catalog: DiagnosticCatalog
) -> bool {

  if not catalog.valid {
    give false
  }

  let i: i32 = 0

  while i < len(catalog.diagnostics) {

    if not catalog.diagnostics[i].valid {
      give false
    }

    set i = i + 1
  }

  give true
}

proc default_catalog() -> DiagnosticCatalog {
  give bootstrap_catalog()
}

export *