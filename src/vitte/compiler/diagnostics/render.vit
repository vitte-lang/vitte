<<<
    Vitte compiler diagnostics renderer.

    Note:
      Canonical diagnostics path.
      Legacy typo path removed.
>>>

space vitte/compiler/diagnostics/render

use vitte/compiler/diagnostics/diagnostic.{
    Diagnostic,
    DiagnosticReport,
    DiagnosticRenderConfig,
    DiagnosticStyle,
    DiagnosticSeverity,
    DiagnosticLabel,
    DiagnosticLabelKind,
    DiagnosticNote,
    DiagnosticHelp,
    DiagnosticSuggestion,
    DiagnosticSuggestionKind,
    SourceSpan,
    severity_name,
    phase_name,
    label_kind_name,
    suggestion_kind_name,
    applicability_name,
    span_location_text,
    default_render_config
}

pick RenderColorMode {
    Never
    Auto
    Always
}

form SourceLine {
    number: u64
    text: string
    valid: bool
}

form SourceFile {
    path: string
    lines: [SourceLine]
    valid: bool
}

form RenderedDiagnostic {
    text: string
    line_count: u64
    valid: bool
}

form RenderContext {
    config: DiagnosticRenderConfig
    source: SourceFile
    color_mode: RenderColorMode
    unicode: bool
}

proc render_color_mode_name(mode: RenderColorMode) -> string {
    if mode == RenderColorMode.Never {
        give "never";
    }

    if mode == RenderColorMode.Auto {
        give "auto";
    }

    if mode == RenderColorMode.Always {
        give "always";
    }

    give "never";
}

proc source_line(number: u64, text: string) -> SourceLine {
    give SourceLine {
        number: number,
        text: text,
        valid: number > 0
    };
}

proc source_file_empty() -> SourceFile {
    give SourceFile {
        path: "",
        lines: [],
        valid: false
    };
}

proc source_file(path: string, lines: [string]) -> SourceFile {
    let built: [SourceLine] = [];
    let i: u64 = 0;

    while i < len(lines) {
        set built = built + [source_line(i + 1, lines[i])];

        set i = i + 1;
    }

    give SourceFile {
        path: path,
        lines: built,
        valid: path != ""
    };
}

proc render_context_default() -> RenderContext {
    give RenderContext {
        config: default_render_config(),
        source: source_file_empty(),
        color_mode: RenderColorMode.Never,
        unicode: true
    };
}

proc render_context(config: DiagnosticRenderConfig, source: SourceFile) -> RenderContext {
    give RenderContext {
        config: config,
        source: source,
        color_mode: RenderColorMode.Never,
        unicode: true
    };
}

proc should_color(ctx: RenderContext) -> bool {
    if ctx.color_mode == RenderColorMode.Always {
        give true;
    }

    if ctx.color_mode == RenderColorMode.Never {
        give false;
    }

    give ctx.config.color;
}

proc ansi_reset() -> string {
    give "\u001b[0m";
}

proc ansi_bold() -> string {
    give "\u001b[1m";
}

proc ansi_red() -> string {
    give "\u001b[31m";
}

proc ansi_yellow() -> string {
    give "\u001b[33m";
}

proc ansi_blue() -> string {
    give "\u001b[34m";
}

proc ansi_cyan() -> string {
    give "\u001b[36m";
}

proc ansi_dim() -> string {
    give "\u001b[2m";
}

proc color_wrap(ctx: RenderContext, color: string, text: string) -> string {
    if !should_color(ctx) {
        give text;
    }

    give color + text + ansi_reset();
}

proc severity_color(severity: DiagnosticSeverity) -> string {
    if severity == DiagnosticSeverity.Error {
        give ansi_red();
    }

    if severity == DiagnosticSeverity.Fatal {
        give ansi_red();
    }

    if severity == DiagnosticSeverity.Warning {
        give ansi_yellow();
    }

    if severity == DiagnosticSeverity.Help {
        give ansi_cyan();
    }

    if severity == DiagnosticSeverity.Note {
        give ansi_blue();
    }

    give "";
}

proc append_line(text: string, line: string) -> string {
    if text == "" {
        give line;
    }

    give text + "\n" + line;
}

proc count_lines(text: string) -> u64 {
    if text == "" {
        give 0 as u64;
    }

    let count: u64 = 1;
    let i: u64 = 0;

    while i < len(text) {
        if slice(text, i, i + 1) == "\n" {
            set count = count + 1;
        }

        set i = i + 1;
    }

    give count;
}

proc rendered_diagnostic(text: string) -> RenderedDiagnostic {
    give RenderedDiagnostic {
        text: text,
        line_count: count_lines(text),
        valid: text != ""
    };
}

proc render_separator(ctx: RenderContext) -> string {
    if ctx.unicode {
        give " │ ";
    }

    give " | ";
}

proc render_arrow(ctx: RenderContext) -> string {
    if ctx.unicode {
        give "──>";
    }

    give "-->";
}

proc render_caret(ctx: RenderContext) -> string {
    if ctx.unicode {
        give "^";
    }

    give "^";
}

proc render_empty_gutter(ctx: RenderContext) -> string {
    if ctx.unicode {
        give "  │ ";
    }

    give "  | ";
}

proc render_header(ctx: RenderContext, diagnostic: Diagnostic) -> string {
    let sev: string = severity_name(diagnostic.severity);
    let color: string = severity_color(diagnostic.severity);
    let head: string = color_wrap(ctx, color, sev);

    let text: string = head;

    if ctx.config.show_code and diagnostic.code != "" {
        set text = text + "[" + diagnostic.code + "]";
    }

    if ctx.config.show_phase {
        set text = text + " " + phase_name(diagnostic.phase);
    }

    set text = text + ": " + diagnostic.message;

    give text;
}

proc render_location(ctx: RenderContext, span: SourceSpan) -> string {
    let arrow: string = render_arrow(ctx);
    give " " + arrow + " " + span_location_text(span);
}

proc source_line_at(source: SourceFile, line: u64) -> SourceLine {
    if line == 0 {
        give source_line(0, "");
    }

    let index: u64 = line - 1;

    if index >= len(source.lines) {
        give source_line(line, "");
    }

    give source.lines[index];
}

proc repeat_text(text: string, count: u64) -> string {
    let out: string = "";
    let i: u64 = 0;

    while i < count {
        set out = out + text;
        set i = i + 1;
    }

    give out;
}

proc decimal_width(value: u64) -> u64 {
    if value >= 1000000000 {
        give 10 as u64;
    }

    if value >= 100000000 {
        give 9 as u64;
    }

    if value >= 10000000 {
        give 8 as u64;
    }

    if value >= 1000000 {
        give 7 as u64;
    }

    if value >= 100000 {
        give 6 as u64;
    }

    if value >= 10000 {
        give 5 as u64;
    }

    if value >= 1000 {
        give 4 as u64;
    }

    if value >= 100 {
        give 3 as u64;
    }

    if value >= 10 {
        give 2 as u64;
    }

    give 1 as u64;
}

proc pad_left(text: string, width: u64) -> string {
    let out: string = text;

    while len(out) < width {
        set out = " " + out;
    }

    give out;
}

proc source_gutter_width(diagnostic: Diagnostic) -> u64 {
    let max_line: u64 = diagnostic.span.end_line;

    if diagnostic.span.start_line > max_line {
        set max_line = diagnostic.span.start_line;
    }

    give decimal_width(max_line);
}

proc render_source_line(ctx: RenderContext, source: SourceFile, span: SourceSpan, width: u64) -> string {
    let line: SourceLine = source_line_at(source, span.start_line);
    let line_number: string = span.start_line as string;
    let number: string = pad_left(line_number, width);
    give number + render_separator(ctx) + line.text;
}

proc render_marker_line(ctx: RenderContext, span: SourceSpan, message: string, width: u64) -> string {
    let prefix: string = repeat_text(" ", width) + render_separator(ctx);
    let before: string = repeat_text(" ", span.start_column - 1);

    let mark_len: u64 = span.length;

    if mark_len == 0 {
        set mark_len = 1 as u64;
    }

    let caret: string = render_caret(ctx);
    let marker: string = repeat_text(caret, mark_len);
    let error_color: string = severity_color(DiagnosticSeverity.Error);
    let colored: string = color_wrap(ctx, error_color, marker);

    give prefix + before + colored + " " + message;
}

proc render_label_block(ctx: RenderContext, diagnostic: Diagnostic, label: DiagnosticLabel) -> string {
    let out: string = "";
    let width: u64 = source_gutter_width(diagnostic);

    if ctx.source.valid and label.span.valid and label.span.file == ctx.source.path {
        set out = append_line(out, render_source_line(ctx, ctx.source, label.span, width));
        set out = append_line(out, render_marker_line(ctx, label.span, label.message, width));

        give out;
    }

    give "  " + label_kind_name(label.kind) + ": " + span_location_text(label.span) + " " + label.message;
}

proc render_labels(ctx: RenderContext, diagnostic: Diagnostic) -> string {
    let out: string = "";
    let i: u64 = 0;

    while i < len(diagnostic.labels) {
        set out = append_line(out, render_label_block(ctx, diagnostic, diagnostic.labels[i]));

        set i = i + 1;
    }

    give out;
}

proc render_note_line(ctx: RenderContext, note: DiagnosticNote) -> string {
    let prefix: string = color_wrap(ctx, ansi_bold() + ansi_blue(), "  note");
    give prefix + ": " + note.message;
}

proc render_help_line(ctx: RenderContext, help: DiagnosticHelp) -> string {
    let prefix: string = color_wrap(ctx, ansi_bold() + ansi_cyan(), "  help");
    give prefix + ": " + help.message;
}

proc render_lparen() -> string {
    give slice("()", 0, 1);
}

proc render_rparen() -> string {
    give slice("()", 1, 2);
}

proc render_suggestion_line(ctx: RenderContext, suggestion: DiagnosticSuggestion) -> string {
    let kind_name: string = suggestion_kind_name(suggestion.kind);
    let location: string = span_location_text(suggestion.span);
    let text: string = "  suggestion: " + kind_name + " " + location + " " + suggestion.message;

    if suggestion.replacement != "" {
        set text = text + " => `" + suggestion.replacement + "`";
    }

    if suggestion.machine_applicable {
        set text = text + " [machine-applicable]";
    }

    set text = text + " [" + applicability_name(suggestion.applicability) + "]";

    if suggestion.confidence != "" {
        set text = text + " [" + suggestion.confidence + "]";
    }

    give color_wrap(ctx, ansi_cyan(), text);
}

proc render_notes(ctx: RenderContext, diagnostic: Diagnostic) -> string {
    let out: string = "";

    if !ctx.config.show_notes {
        give out;
    }

    let i: u64 = 0;

    while i < len(diagnostic.notes) {
        set out = append_line(out, render_note_line(ctx, diagnostic.notes[i]));

        set i = i + 1;
    }

    give out;
}

proc render_helps(ctx: RenderContext, diagnostic: Diagnostic) -> string {
    let out: string = "";

    if !ctx.config.show_helps {
        give out;
    }

    let i: u64 = 0;

    while i < len(diagnostic.helps) {
        set out = append_line(out, render_help_line(ctx, diagnostic.helps[i]));

        set i = i + 1;
    }

    give out;
}

proc render_suggestions(ctx: RenderContext, diagnostic: Diagnostic) -> string {
    let out: string = "";

    if !ctx.config.show_suggestions {
        give out;
    }

    let i: u64 = 0;

    while i < len(diagnostic.suggestions) {
        set out = append_line(out, render_suggestion_line(ctx, diagnostic.suggestions[i]));

        set i = i + 1;
    }

    give out;
}

proc render_diagnostic_text(ctx: RenderContext, diagnostic: Diagnostic) -> string {
    let out: string = render_header(ctx, diagnostic);
    set out = append_line(out, render_location(ctx, diagnostic.span));
    let labels: string = render_labels(ctx, diagnostic);

    if labels != "" {
        set out = append_line(out, labels);
    }

    let notes: string = render_notes(ctx, diagnostic);

    if notes != "" {
        set out = append_line(out, notes);
    }

    let helps: string = render_helps(ctx, diagnostic);

    if helps != "" {
        set out = append_line(out, helps);
    }

    let suggestions: string = render_suggestions(ctx, diagnostic);

    if suggestions != "" {
        set out = append_line(out, suggestions);
    }

    give out;
}

proc render_diagnostic(ctx: RenderContext, diagnostic: Diagnostic) -> RenderedDiagnostic {
    give rendered_diagnostic(render_diagnostic_text(ctx, diagnostic));
}

proc render_report_text(ctx: RenderContext, report: DiagnosticReport) -> string {
    let out: string = "";
    let i: u64 = 0;

    while i < len(report.diagnostics) {
        if out != "" {
            set out = out + "\n\n";
        }

        set out = out + render_diagnostic_text(ctx, report.diagnostics[i]);

        set i = i + 1;
    }

    if out == "" {
        give "diagnostics: ok";
    }

    give out;
}

proc render_report(ctx: RenderContext, report: DiagnosticReport) -> RenderedDiagnostic {
    give rendered_diagnostic(render_report_text(ctx, report));
}

proc render_report_summary(report: DiagnosticReport) -> string {
    if report.valid {
        give "diagnostics ok";
    }

    let error_count: string = report.error_count as string;
    let warning_count: string = report.warning_count as string;
    let fatal_count: string = report.fatal_count as string;
    give "diagnostics failed: " + error_count + " error" + render_lparen() + "s" + render_rparen() + ", " + warning_count + " warning" + render_lparen() + "s" + render_rparen() + ", " + fatal_count + " fatal" + render_lparen() + "s" + render_rparen();
}

proc render_plain_diagnostic(diagnostic: Diagnostic) -> string {
    give severity_name(diagnostic.severity) + "[" + diagnostic.code + "]: " + diagnostic.message + " at " + span_location_text(diagnostic.span);
}

proc render_plain_report(report: DiagnosticReport) -> string {
    let out: string = "";
    let i: u64 = 0;

    while i < len(report.diagnostics) {
        set out = append_line(out, render_plain_diagnostic(report.diagnostics[i]));

        set i = i + 1;
    }

    if out == "" {
        give "diagnostics: ok";
    }

    give out;
}

proc render_with_source_lines(diagnostic: Diagnostic, path: string, lines: [string]) -> string {
    let source: SourceFile = source_file(path, lines);
    let ctx: RenderContext = render_context(default_render_config(), source);
    give render_diagnostic_text(ctx, diagnostic);
}

proc render_report_with_source_lines(report: DiagnosticReport, path: string, lines: [string]) -> string {
    let source: SourceFile = source_file(path, lines);
    let ctx: RenderContext = render_context(default_render_config(), source);
    give render_report_text(ctx, report);
}

share RenderColorMode
share SourceLine
share SourceFile
share RenderedDiagnostic
share RenderContext

share render_color_mode_name
share source_line
share source_file_empty
share source_file
share render_context_default
share render_context

share should_color
share ansi_reset
share ansi_bold
share ansi_red
share ansi_yellow
share ansi_blue
share ansi_cyan
share ansi_dim
share color_wrap
share severity_color

share append_line
share count_lines
share rendered_diagnostic

share render_separator
share render_arrow
share render_caret
share render_empty_gutter

share render_header
share render_location

share source_line_at
share repeat_text
share decimal_width
share pad_left
share source_gutter_width
share render_source_line
share render_marker_line

share render_label_block
share render_labels
share render_note_line
share render_help_line
share render_suggestion_line
share render_notes
share render_helps
share render_suggestions

share render_diagnostic_text
share render_diagnostic
share render_report_text
share render_report
share render_report_summary

share render_plain_diagnostic
share render_plain_report
share render_with_source_lines
share render_report_with_source_lines
