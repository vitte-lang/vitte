<<<
    /home/vincentr/Documents/GitHub/vitte/src/vitte/compiler/diagnostics/lsp.vit

    Language Server Protocol diagnostics bridge for Vitte.
>>>

space vitte/compiler/diagnostics/lsp

use vitte/compiler/diagnostics/diagnostic.{
    Diagnostic,
    DiagnosticReport,
    DiagnosticSeverity,
    DiagnosticLabel,
    DiagnosticNote,
    DiagnosticHelp,
    DiagnosticSuggestion,
    SourceSpan,
    severity_name
}

pick LspDiagnosticSeverity {
    Error
    Warning
    Information
    Hint
}

pick LspMessageType {
    Error
    Warning
    Info
    Log
}

form LspPosition {
    line: u64
    character: u64
    valid: bool
}

form LspRange {
    start: LspPosition
    end: LspPosition
    valid: bool
}

form LspDiagnosticRelatedInformation {
    location_uri: string
    location_range: LspRange
    message: string
    valid: bool
}

form LspDiagnosticTag {
    value: u64
    valid: bool
}

form LspCodeDescription {
    href: string
    valid: bool
}

form LspDiagnostic {
    range: LspRange
    severity: LspDiagnosticSeverity
    code: string
    code_description: LspCodeDescription
    source: string
    message: string
    related_information: [LspDiagnosticRelatedInformation]
    tags: [LspDiagnosticTag]
    data: string
    valid: bool
}

form LspPublishDiagnosticsParams {
    uri: string
    diagnostics: [LspDiagnostic]
    version: u64
    valid: bool
}

proc lsp_position(
    line: u64,
    character: u64
) -> LspPosition {
    give LspPosition {
        line: line,
        character: character,
        valid: true
    };
}

proc lsp_range(
    start: LspPosition,
    end: LspPosition
) -> LspRange {
    give LspRange {
        start: start,
        end: end,
        valid: start.valid and end.valid
    };
}

proc lsp_related_information(
    uri: string,
    range: LspRange,
    message: string
) -> LspDiagnosticRelatedInformation {
    give LspDiagnosticRelatedInformation {
        location_uri: uri,
        location_range: range,
        message: message,
        valid: uri != "" and range.valid
    };
}

proc lsp_tag(value: u64) -> LspDiagnosticTag {
    give LspDiagnosticTag {
        value: value,
        valid: true
    };
}

proc lsp_code_description(
    href: string
) -> LspCodeDescription {
    give LspCodeDescription {
        href: href,
        valid: href != ""
    };
}

proc lsp_severity(
    severity: DiagnosticSeverity
) -> LspDiagnosticSeverity {
    if severity == DiagnosticSeverity.Fatal {
        give LspDiagnosticSeverity.Error;
    }

    if severity == DiagnosticSeverity.Error {
        give LspDiagnosticSeverity.Error;
    }

    if severity == DiagnosticSeverity.Warning {
        give LspDiagnosticSeverity.Warning;
    }

    if severity == DiagnosticSeverity.Note {
        give LspDiagnosticSeverity.Information;
    }

    give LspDiagnosticSeverity.Hint;
}

proc lsp_position_from_span_start(
    span: SourceSpan
) -> LspPosition {
    let line: u64 = 0;
    let column: u64 = 0;

    if span.start_line > 0 {
        set line = span.start_line - 1;
    }

    if span.start_column > 0 {
        set column = span.start_column - 1;
    }

    give lsp_position(line, column);
}

proc lsp_position_from_span_end(
    span: SourceSpan
) -> LspPosition {
    let line: u64 = 0;
    let column: u64 = 0;

    if span.end_line > 0 {
        set line = span.end_line - 1;
    }

    if span.end_column > 0 {
        set column = span.end_column - 1;
    }

    give lsp_position(line, column);
}

proc lsp_range_from_span(
    span: SourceSpan
) -> LspRange {
    give lsp_range(
        lsp_position_from_span_start(span),
        lsp_position_from_span_end(span)
    );
}

proc span_uri(
    span: SourceSpan
) -> string {
    if starts_with(span.file, "file://") {
        give span.file;
    }

    if starts_with(span.file, "/") {
        give "file://" + span.file;
    }

    give "file:///" + span.file;
}

proc diagnostic_related_information(
    label: DiagnosticLabel
) -> LspDiagnosticRelatedInformation {
    give lsp_related_information(
        span_uri(label.span),
        lsp_range_from_span(label.span),
        label.message
    );
}

proc diagnostic_tags(
    diagnostic: Diagnostic
) -> [LspDiagnosticTag] {
    let tags: [LspDiagnosticTag] = [];

    if diagnostic.deprecated {
        set tags = tags + [lsp_tag(2)];
    }

    if diagnostic.unnecessary {
        set tags = tags + [lsp_tag(1)];
    }

    give tags;
}

proc diagnostic_data(
    diagnostic: Diagnostic
) -> string {
    let data: string =
        "severity=" + severity_name(diagnostic.severity);

    give data +
        ";phase=" + diagnostic.phase_name +
        ";code=" + diagnostic.code;
}

proc diagnostic_related_information_list(
    diagnostic: Diagnostic
) -> [LspDiagnosticRelatedInformation] {
    let info: [LspDiagnosticRelatedInformation] = [];
    let i: u64 = 0;

    while i < len(diagnostic.labels) {
        set info =
            info + [
                diagnostic_related_information(
                    diagnostic.labels[i]
                )
            ];

        set i = i + 1;
    }

    i = 0;

    while i < len(diagnostic.notes) {
        let note: DiagnosticNote =
            diagnostic.notes[i];

        set info =
            info + [
                lsp_related_information(
                    span_uri(diagnostic.span),
                    lsp_range_from_span(diagnostic.span),
                    "note: " + note.message
                )
            ];

        set i = i + 1;
    }

    i = 0;

    while i < len(diagnostic.helps) {
        let help: DiagnosticHelp =
            diagnostic.helps[i];

        set info =
            info + [
                lsp_related_information(
                    span_uri(diagnostic.span),
                    lsp_range_from_span(diagnostic.span),
                    "help: " + help.message
                )
            ];

        set i = i + 1;
    }

    i = 0;

    while i < len(diagnostic.suggestions) {
        let suggestion: DiagnosticSuggestion =
            diagnostic.suggestions[i];

        let message: string =
            "suggestion: " + suggestion.message;

        if suggestion.replacement != "" {
            set message =
                message +
                " => `" +
                suggestion.replacement +
                "`";
        }

        set info =
            info + [
                lsp_related_information(
                    span_uri(suggestion.span),
                    lsp_range_from_span(suggestion.span),
                    message
                )
            ];

        set i = i + 1;
    }

    give info;
}

proc lsp_diagnostic(
    diagnostic: Diagnostic
) -> LspDiagnostic {
    give LspDiagnostic {
        range:
            lsp_range_from_span(diagnostic.span),

        severity:
            lsp_severity(diagnostic.severity),

        code:
            diagnostic.code,

        code_description:
            lsp_code_description(
                "https://vitte.dev/errors/" +
                diagnostic.code
            ),

        source:
            "vitte",

        message:
            diagnostic.message,

        related_information:
            diagnostic_related_information_list(
                diagnostic
            ),

        tags:
            diagnostic_tags(diagnostic),

        data:
            diagnostic_data(diagnostic),

        valid:
            diagnostic.valid
    };
}

proc lsp_diagnostics(
    diagnostics: [Diagnostic]
) -> [LspDiagnostic] {
    let out: [LspDiagnostic] = [];
    let i: u64 = 0;

    while i < len(diagnostics) {
        set out =
            out + [
                lsp_diagnostic(diagnostics[i])
            ];

        set i = i + 1;
    }

    give out;
}

proc lsp_publish_diagnostics(
    uri: string,
    diagnostics: [Diagnostic],
    version: u64
) -> LspPublishDiagnosticsParams {
    give LspPublishDiagnosticsParams {
        uri: uri,
        diagnostics:
            lsp_diagnostics(diagnostics),
        version: version,
        valid: uri != ""
    };
}

proc lsp_publish_report(
    uri: string,
    report: DiagnosticReport,
    version: u64
) -> LspPublishDiagnosticsParams {
    give lsp_publish_diagnostics(
        uri,
        report.diagnostics,
        version
    );
}

proc lsp_severity_name(
    severity: LspDiagnosticSeverity
) -> string {
    if severity == LspDiagnosticSeverity.Error {
        give "error";
    }

    if severity == LspDiagnosticSeverity.Warning {
        give "warning";
    }

    if severity == LspDiagnosticSeverity.Information {
        give "information";
    }

    give "hint";
}

proc lsp_message_type(
    severity: DiagnosticSeverity
) -> LspMessageType {
    if severity == DiagnosticSeverity.Fatal {
        give LspMessageType.Error;
    }

    if severity == DiagnosticSeverity.Error {
        give LspMessageType.Error;
    }

    if severity == DiagnosticSeverity.Warning {
        give LspMessageType.Warning;
    }

    if severity == DiagnosticSeverity.Note {
        give LspMessageType.Info;
    }

    give LspMessageType.Log;
}

proc lsp_message_type_name(
    kind: LspMessageType
) -> string {
    if kind == LspMessageType.Error {
        give "error";
    }

    if kind == LspMessageType.Warning {
        give "warning";
    }

    if kind == LspMessageType.Info {
        give "info";
    }

    give "log";
}

proc lsp_diagnostic_summary(
    diagnostic: LspDiagnostic
) -> string {
    give diagnostic.code +
        ": " +
        diagnostic.message;
}

proc lsp_publish_summary(
    params: LspPublishDiagnosticsParams
) -> string {
    give "published " +
        (len(params.diagnostics) as string) +
        " diagnostic(s) to " +
        params.uri;
}

share LspDiagnosticSeverity
share LspMessageType
share LspPosition
share LspRange
share LspDiagnosticRelatedInformation
share LspDiagnosticTag
share LspCodeDescription
share LspDiagnostic
share LspPublishDiagnosticsParams

share lsp_position
share lsp_range
share lsp_related_information
share lsp_tag
share lsp_code_description

share lsp_severity
share lsp_position_from_span_start
share lsp_position_from_span_end
share lsp_range_from_span

share span_uri
share diagnostic_related_information
share diagnostic_tags
share diagnostic_data
share diagnostic_related_information_list

share lsp_diagnostic
share lsp_diagnostics
share lsp_publish_diagnostics
share lsp_publish_report

share lsp_severity_name
share lsp_message_type
share lsp_message_type_name

share lsp_diagnostic_summary
share lsp_publish_summary