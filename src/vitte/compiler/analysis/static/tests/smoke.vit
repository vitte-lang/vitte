space vitte/compiler/analysis/static/tests/smoke

use src/vitte/compiler/analysis/static/mod as sa

proc smoke_static_analyses_count() -> bool {
  let results = sa.run_all_static_analyses()
  give results.len == 4
}

proc smoke_static_analyses_success() -> bool {
  let results = sa.run_all_static_analyses()
  let i: int = 0
  while i < results.len {
    if !results[i].success { give false }
    set i = i + 1
  }
  give true
}

proc smoke_static_analysis_metric_thresholds() -> bool {
  let m = sa.baseline_metrics()
  if m.fixture_count < 5 { give false }
  if m.cfg_blocks_total < 24 { give false }
  if m.alias_classes_total < 14 { give false }
  if m.points_to_sets_total < 19 { give false }
  give true
}
