space vitte/compiler/analysis/typeck/complete/procs

use vitte/compiler/analysis/typeck.traits.{ type_is_truthy }
use vitte/compiler/analysis/typeck.unify.{ unify_types }
use vitte/compiler/analysis/typeck/complete/context.{ CompleteContext, context_add_symbol, env_get, env_has, env_set, symbol_exists }
use vitte/compiler/analysis/typeck/complete/diagnostics.{ add_complete_diag, complete_diag, duplicate_symbol_diag, incompatible_type_diag, unknown_type_diag }
use vitte/compiler/analysis/typeck/complete/exprs.{ infer_expr_type }
use vitte/compiler/analysis/typeck/complete/normalize.{ base_type_name, generic_param_names, normalize_ast_signature, normalize_ast_type }
use vitte/compiler/analysis/typeck/complete/types.{
  CompleteBinding,
  CompleteBlockResult,
  CompleteProcSignature,
  CompleteSymbol,
  CompleteSymbolKind,
  complete_binding,
  complete_block_result,
  complete_impl_info_empty,
  complete_trait_info_empty
}
use vitte/compiler/diagnostics/diagnostic.{ Diagnostic }
use vitte/compiler/frontend/ast/item.{ AstItem, AstItemKind }
use vitte/compiler/frontend/ast/pattern.{ AstPattern, AstPatternKind }
use vitte/compiler/frontend/ast/stmt.{ AstStmt, AstStmtKind }

export *

proc bind_pattern(env: [CompleteBinding], pattern: AstPattern, type_name: string, mutable: bool) -> [CompleteBinding] {
  if pattern.kind == AstPatternKind.Name or pattern.kind == AstPatternKind.Binding {
    give env_set(env, complete_binding(pattern.binding_name, type_name, mutable, true));
  }
  let out: [CompleteBinding] = env;
  let i: u64 = 0;
  while i < len(pattern.children) {
    set out = bind_pattern(out, pattern.children[i], type_name, mutable);
    set i = i + 1;
  }
  give out;
}

proc signature_scope(signature: CompleteProcSignature) -> [CompleteBinding] {
  let env: [CompleteBinding] = [];
  let i: u64 = 0;
  while i < len(signature.generic_params) {
    set env = env_set(env, complete_binding(signature.generic_params[i], signature.generic_params[i], false, true));
    set i = i + 1;
  }
  set i = 0;
  while i < len(signature.params) {
    let param_name: string = signature.params[i].name;
    let param_type: string = if signature.params[i].type_name != "" { signature.params[i].type_name } else { "unknown" };
    if param_name != "" {
      set env = env_set(env, complete_binding(param_name, param_type, signature.params[i].mode == "mut", true));
    }
    set i = i + 1;
  }
  give env;
}

proc check_stmt_block(ctx: CompleteContext, env0: [CompleteBinding], stmts: [AstStmt], return_type: string) -> CompleteBlockResult {
  let env: [CompleteBinding] = env0;
  let diagnostics: [Diagnostic] = [];
  let i: u64 = 0;
  while i < len(stmts) {
    let stmt: AstStmt = stmts[i];
    if stmt.kind == AstStmtKind.Let or stmt.kind == AstStmtKind.Const {
      let expr_result = infer_expr_type(ctx, env, stmt.expr);
      let declared: string = normalize_ast_type(stmt.annotation);
      let actual: string = if declared != "" { declared } else { expr_result.ty };
      set diagnostics = diagnostics + expr_result.diagnostics;
      if declared != "" and expr_result.ty != "" and expr_result.ty != "unknown" and unify_types(declared, expr_result.ty) == "unknown" {
        set diagnostics = add_complete_diag(diagnostics, incompatible_type_diag(declared, expr_result.ty, stmt.span));
      }
      set env = bind_pattern(env, stmt.pattern, actual, stmt.mutable);
    } elif stmt.kind == AstStmtKind.Set {
      let expr_result = infer_expr_type(ctx, env, stmt.expr);
      set diagnostics = diagnostics + expr_result.diagnostics;
      let target_name: string = if stmt.target != "" { stmt.target } else { stmt.pattern.binding_name };
      if not env_has(env, target_name) {
        set diagnostics = add_complete_diag(diagnostics, complete_diag("TYPECK_E_UNKNOWN_NAME", "unknown assignment target `" + target_name + "`", stmt.span, "declare the binding before assignment"));
      } else {
        let binding: CompleteBinding = env_get(env, target_name);
        if binding.type_name != "" and expr_result.ty != "" and unify_types(binding.type_name, expr_result.ty) == "unknown" {
          set diagnostics = add_complete_diag(diagnostics, incompatible_type_diag(binding.type_name, expr_result.ty, stmt.span));
        }
      }
    } elif stmt.kind == AstStmtKind.Give {
      let expr_result = infer_expr_type(ctx, env, stmt.expr);
      set diagnostics = diagnostics + expr_result.diagnostics;
      let expected: string = if return_type != "" { return_type } else { "unit" };
      if expected != "unit" and unify_types(expected, expr_result.ty) == "unknown" {
        set diagnostics = add_complete_diag(diagnostics, incompatible_type_diag(expected, expr_result.ty, stmt.span));
      }
    } elif stmt.kind == AstStmtKind.If or stmt.kind == AstStmtKind.While or stmt.kind == AstStmtKind.StaticAssert or stmt.kind == AstStmtKind.Assert {
      let condition_result = infer_expr_type(ctx, env, if stmt.condition.valid { stmt.condition } else { stmt.expr });
      set diagnostics = diagnostics + condition_result.diagnostics;
      if not type_is_truthy(condition_result.ty) {
        set diagnostics = add_complete_diag(diagnostics, complete_diag("TYPECK_E_CONDITION_TYPE", "condition must be truthy", stmt.span, "use a bool or another truthy scalar value"));
      }
      let then_result: CompleteBlockResult = check_stmt_block(ctx, env, stmt.then_stmts, return_type);
      let else_result: CompleteBlockResult = check_stmt_block(ctx, env, stmt.else_stmts, return_type);
      set diagnostics = diagnostics + then_result.diagnostics + else_result.diagnostics;
    } elif stmt.kind == AstStmtKind.ExprStmt {
      let expr_result = infer_expr_type(ctx, env, stmt.expr);
      set diagnostics = diagnostics + expr_result.diagnostics;
    } elif len(stmt.then_stmts) > 0 or len(stmt.else_stmts) > 0 or len(stmt.catch_stmts) > 0 {
      let nested: CompleteBlockResult = check_stmt_block(ctx, env, stmt.then_stmts + stmt.else_stmts + stmt.catch_stmts, return_type);
      set diagnostics = diagnostics + nested.diagnostics;
    }
    set i = i + 1;
  }
  give complete_block_result(env, diagnostics);
}

proc register_proc_signatures(ctx: CompleteContext) -> CompleteContext {
  let out: CompleteContext = ctx;
  let i: u64 = 0;
  while i < len(out.module.items) {
    let item: AstItem = out.module.items[i];
    if item.kind == AstItemKind.Proc and item.name != "" {
      if symbol_exists(out.symbols, item.name) {
        set out.diagnostics = add_complete_diag(out.diagnostics, duplicate_symbol_diag(item.name, item.span));
      } else {
        let signature: CompleteProcSignature = normalize_ast_signature(item.signature);
        let symbol: CompleteSymbol = CompleteSymbol {
          kind: CompleteSymbolKind.Proc,
          name: item.name,
          qualified_name: item.name,
          type_name: item.name,
          span: item.span,
          generic_params: generic_param_names(item.generic_params),
          fields: [],
          variants: [],
          proc_signature: signature,
          trait_info: complete_trait_info_empty(),
          impl_info: complete_impl_info_empty(),
          valid: true
        };
        set out = context_add_symbol(out, symbol);
      }
    }
    set i = i + 1;
  }
  give out;
}

proc validate_proc_signature_types(ctx: CompleteContext, item: AstItem, signature: CompleteProcSignature) -> CompleteContext {
  let out: CompleteContext = ctx;
  let i: u64 = 0;
  while i < len(signature.params) {
    let param_ty: string = signature.params[i].type_name;
    let param_base: string = base_type_name(param_ty);
    if param_ty != "" and not symbol_exists(out.symbols, param_base) {
      let generic_ok: bool = env_has(signature_scope(signature), param_ty);
      if not generic_ok {
        set out.diagnostics = add_complete_diag(out.diagnostics, unknown_type_diag(param_ty, item.span));
      }
    }
    set i = i + 1;
  }
  let return_base: string = base_type_name(signature.return_type);
  if signature.return_type != "" and signature.return_type != "unit" and not symbol_exists(out.symbols, return_base) {
    let generic_ok: bool = env_has(signature_scope(signature), signature.return_type);
    if not generic_ok {
      set out.diagnostics = add_complete_diag(out.diagnostics, unknown_type_diag(signature.return_type, item.span));
    }
  }
  give out;
}

proc typecheck_procs(ctx: CompleteContext) -> CompleteContext {
  let out: CompleteContext = ctx;
  let i: u64 = 0;
  while i < len(out.module.items) {
    let item: AstItem = out.module.items[i];
    if item.kind == AstItemKind.Proc {
      let signature: CompleteProcSignature = normalize_ast_signature(item.signature);
      set out = validate_proc_signature_types(out, item, signature);
      let env: [CompleteBinding] = signature_scope(signature);
      let block_result: CompleteBlockResult = check_stmt_block(out, env, item.stmts, signature.return_type);
      set out.diagnostics = out.diagnostics + block_result.diagnostics;
    }
    set i = i + 1;
  }
  give out;
}
