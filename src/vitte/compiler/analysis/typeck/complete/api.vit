space vitte/compiler/analysis/typeck/complete/api

use vitte/compiler/analysis/typeck/complete/builtins.{ register_builtins }
use vitte/compiler/analysis/typeck/complete/context.{ CompleteContext, complete_context }
use vitte/compiler/analysis/typeck/complete/forms.{ register_forms_and_picks }
use vitte/compiler/analysis/typeck/complete/procs.{ register_proc_signatures, typecheck_procs }
use vitte/compiler/analysis/typeck/complete/surface.{ SurfaceItem, collect_surface_items }
use vitte/compiler/analysis/typeck/complete/traits_impls.{ register_impls, register_traits }
use vitte/compiler/analysis/typeck/complete/types.{ CompleteResult, complete_result }
use vitte/compiler/frontend/ast/item.{ AstModule }
use vitte/compiler/frontend/pipeline.{ FrontendOutput }

export *

proc run_complete_typeck_module(module: AstModule) -> CompleteResult {
  give run_complete_typeck_module_with_surfaces(module, []);
}

proc run_complete_typeck_module_with_surfaces(module: AstModule, surfaces: [SurfaceItem]) -> CompleteResult {
  let ctx0: CompleteContext = complete_context(module);
  let ctx1: CompleteContext = register_builtins(ctx0);
  let ctx2: CompleteContext = register_forms_and_picks(ctx1, surfaces);
  let ctx3: CompleteContext = register_traits(ctx2, surfaces);
  let ctx4: CompleteContext = register_proc_signatures(ctx3);
  let ctx5: CompleteContext = register_impls(ctx4, surfaces);
  let ctx6: CompleteContext = typecheck_procs(ctx5);
  give complete_result(ctx6.symbols, ctx6.diagnostics);
}

proc run_complete_typeck_frontend(output: FrontendOutput) -> CompleteResult {
  let surfaces: [SurfaceItem] = collect_surface_items(output.ast_root, output.source_text);
  give run_complete_typeck_module_with_surfaces(output.ast_root, surfaces);
}
