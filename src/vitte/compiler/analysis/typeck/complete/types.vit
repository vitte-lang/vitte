space vitte/compiler/analysis/typeck/complete/types

use vitte/compiler/frontend/ast/node.{ AstSpan, ast_span_empty }
use vitte/compiler/diagnostics/diagnostic.{ Diagnostic, DiagnosticReport, diagnostic_report }

export *

pick CompleteSymbolKind {
  Unknown,
  Primitive,
  Form,
  Pick,
  Variant,
  Proc,
  Trait,
  Impl,
  TypeParam,
}

form CompleteField {
  name: string
  type_name: string
  valid: bool
}

form CompleteVariant {
  name: string
  payload_types: [string]
  valid: bool
}

form CompleteProcParam {
  name: string
  type_name: string
  mode: string
  variadic: bool
  valid: bool
}

form CompleteProcSignature {
  name: string
  generic_params: [string]
  params: [CompleteProcParam]
  return_type: string
  where_clauses: [string]
  requires: [string]
  effects: [string]
  noexcept: bool
  valid: bool
}

form CompleteTraitRequirement {
  name: string
  signature: CompleteProcSignature
  valid: bool
}

form CompleteTraitInfo {
  name: string
  generic_params: [string]
  requirements: [CompleteTraitRequirement]
  valid: bool
}

form CompleteImplInfo {
  trait_name: string
  target_type: string
  generic_params: [string]
  methods: [CompleteProcSignature]
  valid: bool
}

form CompleteSymbol {
  kind: CompleteSymbolKind
  name: string
  qualified_name: string
  type_name: string
  span: AstSpan
  generic_params: [string]
  fields: [CompleteField]
  variants: [CompleteVariant]
  proc_signature: CompleteProcSignature
  trait_info: CompleteTraitInfo
  impl_info: CompleteImplInfo
  valid: bool
}

form CompleteBinding {
  name: string
  type_name: string
  mutable: bool
  initialized: bool
  moved: bool
  valid: bool
}

form CompleteExprResult {
  ty: string
  diagnostics: [Diagnostic]
  valid: bool
}

form CompleteBlockResult {
  env: [CompleteBinding]
  diagnostics: [Diagnostic]
  valid: bool
}

form CompleteResult {
  report: DiagnosticReport
  symbols: [CompleteSymbol]
  valid: bool
}

proc complete_field(name: string, type_name: string) -> CompleteField {
  give CompleteField {
    name: name,
    type_name: type_name,
    valid: name != "" and type_name != ""
  };
}

proc complete_variant(name: string, payload_types: [string]) -> CompleteVariant {
  give CompleteVariant {
    name: name,
    payload_types: payload_types,
    valid: name != ""
  };
}

proc complete_proc_param(name: string, type_name: string, mode: string, variadic: bool) -> CompleteProcParam {
  give CompleteProcParam {
    name: name,
    type_name: type_name,
    mode: mode,
    variadic: variadic,
    valid: name != "" or variadic
  };
}

proc complete_signature_empty() -> CompleteProcSignature {
  give CompleteProcSignature {
    name: "",
    generic_params: [],
    params: [],
    return_type: "unit",
    where_clauses: [],
    requires: [],
    effects: [],
    noexcept: false,
    valid: false
  };
}

proc complete_trait_info_empty() -> CompleteTraitInfo {
  give CompleteTraitInfo {
    name: "",
    generic_params: [],
    requirements: [],
    valid: false
  };
}

proc complete_impl_info_empty() -> CompleteImplInfo {
  give CompleteImplInfo {
    trait_name: "",
    target_type: "",
    generic_params: [],
    methods: [],
    valid: false
  };
}

proc complete_symbol(kind: CompleteSymbolKind, name: string, type_name: string) -> CompleteSymbol {
  give CompleteSymbol {
    kind: kind,
    name: name,
    qualified_name: name,
    type_name: type_name,
    span: ast_span_empty(),
    generic_params: [],
    fields: [],
    variants: [],
    proc_signature: complete_signature_empty(),
    trait_info: complete_trait_info_empty(),
    impl_info: complete_impl_info_empty(),
    valid: name != ""
  };
}

proc complete_binding(name: string, type_name: string, mutable: bool, initialized: bool) -> CompleteBinding {
  give CompleteBinding {
    name: name,
    type_name: type_name,
    mutable: mutable,
    initialized: initialized,
    moved: false,
    valid: name != ""
  };
}

proc complete_expr_result(ty: string, diagnostics: [Diagnostic]) -> CompleteExprResult {
  give CompleteExprResult {
    ty: ty,
    diagnostics: diagnostics,
    valid: len(diagnostics) == 0 and ty != ""
  };
}

proc complete_block_result(env: [CompleteBinding], diagnostics: [Diagnostic]) -> CompleteBlockResult {
  give CompleteBlockResult {
    env: env,
    diagnostics: diagnostics,
    valid: len(diagnostics) == 0
  };
}

proc complete_result(symbols: [CompleteSymbol], diagnostics: [Diagnostic]) -> CompleteResult {
  let report: DiagnosticReport = diagnostic_report(diagnostics);
  give CompleteResult {
    report: report,
    symbols: symbols,
    valid: report.valid
  };
}
