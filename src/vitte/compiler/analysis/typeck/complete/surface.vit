space vitte/compiler/analysis/typeck/complete/surface

use vitte/compiler/frontend/ast/item.{ AstItem, AstItemKind, AstModule }
use vitte/compiler/analysis/typeck/complete/types.{
  CompleteField,
  CompleteImplInfo,
  CompleteProcParam,
  CompleteProcSignature,
  CompleteTraitRequirement,
  CompleteVariant,
  complete_field,
  complete_impl_info_empty,
  complete_proc_param,
  complete_signature_empty,
  complete_variant
}

export *

proc token_lparen() -> string {
  give slice("a(b", 1, 2);
}

proc token_rparen() -> string {
  give slice("a)b", 1, 2);
}

proc token_lbracket() -> string {
  give slice("a[b", 1, 2);
}

proc token_rbracket() -> string {
  give slice("a]b", 1, 2);
}

proc token_lbrace() -> string {
  give slice("a{b", 1, 2);
}

proc token_rbrace() -> string {
  give slice("a}b", 1, 2);
}

proc token_comma() -> string {
  give slice("a,b", 1, 2);
}

proc token_semicolon() -> string {
  give slice("a;b", 1, 2);
}

proc token_colon() -> string {
  give slice("a:b", 1, 2);
}

proc last_index_of(text: string, needle: string) -> int {
  if text == "" or needle == "" or len(needle) > len(text) {
    give -1;
  }
  let i: u64 = len(text) - len(needle);
  loop {
    if slice(text, i, i + len(needle)) == needle {
      give i as int;
    }
    if i == 0 {
      break;
    }
    set i = i - 1;
  }
  give -1;
}

form SurfaceItem {
  kind: AstItemKind
  name: string
  fields: [CompleteField]
  variants: [CompleteVariant]
  trait_requirements: [CompleteTraitRequirement]
  impl_info: CompleteImplInfo
  valid: bool
}

proc source_lines_between(source_text: string, start_line: u64, end_line: u64) -> string {
  if source_text == "" or start_line == 0 or end_line == 0 or end_line < start_line {
    give "";
  }
  let lines: [string] = split(source_text, "\n");
  let out: string = "";
  let i: u64 = start_line - 1;
  while i < len(lines) and i <= end_line - 1 {
    if out != "" {
      set out = out + "\n";
    }
    set out = out + lines[i];
    set i = i + 1;
  }
  give out;
}

proc body_between_braces(text: string) -> string {
  let open: int = find(text, token_lbrace());
  let close: int = last_index_of(text, token_rbrace());
  if open < 0 or close < 0 or close <= open {
    give "";
  }
  give trim(slice(text, open + 1, close));
}

proc split_top_level_text(text: string, separator: string) -> [string] {
  if trim(text) == "" {
    give [];
  }
  let parts: [string] = [];
  let current: string = "";
  let i: u64 = 0;
  let round: u64 = 0;
  let square: u64 = 0;
  let curly: u64 = 0;
  while i < len(text) {
    let ch: string = slice(text, i, i + 1);
    if ch == token_lparen() {
      set round = round + 1;
    } elif ch == token_rparen() and round > 0 {
      set round = round - 1;
    } elif ch == token_lbracket() {
      set square = square + 1;
    } elif ch == token_rbracket() and square > 0 {
      set square = square - 1;
    } elif ch == token_lbrace() {
      set curly = curly + 1;
    } elif ch == token_rbrace() and curly > 0 {
      set curly = curly - 1;
    }

    let is_sep: bool = ch == separator and round == 0 and square == 0 and curly == 0;
    if is_sep {
      if trim(current) != "" {
        set parts = parts + [trim(current)];
      }
      set current = "";
    } else {
      set current = current + ch;
    }
    set i = i + 1;
  }
  if trim(current) != "" {
    set parts = parts + [trim(current)];
  }
  give parts;
}

proc parse_surface_proc_param(text: string) -> CompleteProcParam {
  let trimmed: string = trim(text);
  if trimmed == "..." {
    give complete_proc_param("", "", "", true);
  }
  let colon: int = find(trimmed, token_colon());
  if colon < 0 {
    give complete_proc_param(trimmed, "", "", false);
  }
  let left: string = trim(slice(trimmed, 0, colon));
  let right: string = trim(slice(trimmed, colon + 1, len(trimmed)));
  let parts: [string] = split(left, " ");
  let mode: string = "";
  let name: string = left;
  if len(parts) > 1 {
    set name = parts[len(parts) - 1];
    set mode = trim(slice(left, 0, find(left, name)));
  }
  give complete_proc_param(name, right, mode, false);
}

proc parse_surface_signature(header_text: string) -> CompleteProcSignature {
  let header: string = trim(header_text);
  if not starts_with(header, "proc ") {
    give complete_signature_empty();
  }
  let open: int = find(header, token_lparen());
  let close: int = last_index_of(header, token_rparen());
  if open < 0 or close < 0 or close <= open {
    give complete_signature_empty();
  }
  let name_text: string = trim(slice(header, 5, open));
  let generic_params: [string] = [];
  let open_generics: int = find(name_text, token_lbracket());
  let close_generics: int = last_index_of(name_text, token_rbracket());
  let name: string = name_text;
  if open_generics >= 0 and close_generics > open_generics {
    set name = trim(slice(name_text, 0, open_generics));
    let generic_text: string = trim(slice(name_text, open_generics + 1, close_generics));
    if generic_text != "" {
      set generic_params = split_top_level_text(generic_text, token_comma());
    }
  }
  let params_text: string = trim(slice(header, open + 1, close));
  let params: [CompleteProcParam] = [];
  let raw_params: [string] = split_top_level_text(params_text, token_comma());
  let i: u64 = 0;
  while i < len(raw_params) {
    set params = params + [parse_surface_proc_param(raw_params[i])];
    set i = i + 1;
  }
  let tail: string = trim(slice(header, close + 1, len(header)));
  let return_type: string = "unit";
  let where_clauses: [string] = [];
  let requires: [string] = [];
  let effects: [string] = [];
  let noexcept: bool = contains(tail, "noexcept");
  let arrow: int = find(tail, "->");
  if arrow >= 0 {
    let return_tail: string = trim(slice(tail, arrow + 2, len(tail)));
    let cut: u64 = len(return_tail);
    let where_index: int = find(return_tail, " where ");
    let requires_index: int = find(return_tail, " requires ");
    let effects_index: int = find(return_tail, " effects ");
    if where_index >= 0 and where_index as u64 < cut {
      set cut = where_index as u64;
    }
    if requires_index >= 0 and requires_index as u64 < cut {
      set cut = requires_index as u64;
    }
    if effects_index >= 0 and effects_index as u64 < cut {
      set cut = effects_index as u64;
    }
    set return_type = trim(slice(return_tail, 0, cut));
  }
  if contains(tail, " where ") {
    let start: int = find(tail, " where ");
    let segment: string = trim(slice(tail, start + 7, len(tail)));
    let stop: int = find(segment, " requires ");
    if stop < 0 {
      set stop = find(segment, " effects ");
    }
    if stop >= 0 {
      set segment = trim(slice(segment, 0, stop));
    }
    set where_clauses = split_top_level_text(segment, token_comma());
  }
  if contains(tail, " requires ") {
    let start: int = find(tail, " requires ");
    let segment: string = trim(slice(tail, start + 10, len(tail)));
    let stop: int = find(segment, " effects ");
    if stop >= 0 {
      set segment = trim(slice(segment, 0, stop));
    }
    set requires = split_top_level_text(segment, token_comma());
  }
  if contains(tail, " effects ") {
    let start: int = find(tail, " effects ");
    let segment: string = trim(slice(tail, start + 9, len(tail)));
    set effects = split_top_level_text(segment, token_comma());
  }
  give CompleteProcSignature {
    name: name,
    generic_params: generic_params,
    params: params,
    return_type: if return_type != "" { return_type } else { "unit" },
    where_clauses: where_clauses,
    requires: requires,
    effects: effects,
    noexcept: noexcept,
    valid: name != ""
  };
}

proc parse_form_fields(body_text: string) -> [CompleteField] {
  let lines: [string] = split(body_text, "\n");
  let fields: [CompleteField] = [];
  let i: u64 = 0;
  while i < len(lines) {
    let line: string = trim(lines[i]);
    let cleaned: string = trim(replace(replace(line, token_comma(), ""), token_semicolon(), ""));
    let colon: int = find(cleaned, token_colon());
    if cleaned != "" and colon > 0 and not starts_with(cleaned, "proc ") {
      let name: string = trim(slice(cleaned, 0, colon));
      let type_name: string = trim(slice(cleaned, colon + 1, len(cleaned)));
      if name != "" and type_name != "" {
        set fields = fields + [complete_field(name, type_name)];
      }
    }
    set i = i + 1;
  }
  give fields;
}

proc parse_pick_variants(body_text: string) -> [CompleteVariant] {
  let lines: [string] = split(body_text, "\n");
  let variants: [CompleteVariant] = [];
  let i: u64 = 0;
  while i < len(lines) {
    let line: string = trim(replace(replace(lines[i], token_comma(), ""), token_semicolon(), ""));
    if line != "" {
      let open: int = find(line, token_lparen());
      let close: int = last_index_of(line, token_rparen());
      if open >= 0 and close > open {
        let name: string = trim(slice(line, 0, open));
        let payload_text: string = trim(slice(line, open + 1, close));
        set variants = variants + [complete_variant(name, split_top_level_text(payload_text, token_comma()))];
      } else {
        set variants = variants + [complete_variant(line, [])];
      }
    }
    set i = i + 1;
  }
  give variants;
}

proc extract_proc_headers(body_text: string) -> [string] {
  let lines: [string] = split(body_text, "\n");
  let headers: [string] = [];
  let current: string = "";
  let collecting: bool = false;
  let i: u64 = 0;
  while i < len(lines) {
    let line: string = trim(lines[i]);
    if starts_with(line, "proc ") {
      set current = line;
      set collecting = true;
      if contains(line, "{") or ends_with(line, ";") {
        set headers = headers + [trim(replace(trim(slice(current, 0, if find(current, "{") >= 0 { find(current, "{") } else { len(current) })), ";", ""))];
        set current = "";
        set collecting = false;
      }
    } elif collecting {
      set current = current + " " + line;
      if contains(line, "{") or ends_with(line, ";") {
        set headers = headers + [trim(replace(trim(slice(current, 0, if find(current, "{") >= 0 { find(current, "{") } else { len(current) })), ";", ""))];
        set current = "";
        set collecting = false;
      }
    }
    set i = i + 1;
  }
  give headers;
}

proc parse_trait_requirements(body_text: string) -> [CompleteTraitRequirement] {
  let headers: [string] = extract_proc_headers(body_text);
  let requirements: [CompleteTraitRequirement] = [];
  let i: u64 = 0;
  while i < len(headers) {
    let signature: CompleteProcSignature = parse_surface_signature(headers[i]);
    if signature.valid {
      set requirements = requirements + [CompleteTraitRequirement {
        name: signature.name,
        signature: signature,
        valid: true
      }];
    }
    set i = i + 1;
  }
  give requirements;
}

proc parse_impl_info(item_name: string, item_text: string, body_text: string) -> CompleteImplInfo {
  let header_end: int = find(item_text, "{");
  let header: string = if header_end >= 0 { trim(slice(item_text, 0, header_end)) } else { trim(item_text) };
  let trait_name: string = "";
  let target_type: string = item_name;
  let header_rest: string = trim(replace(header, "impl", ""));
  let for_index: int = find(header_rest, " for ");
  if for_index >= 0 {
    set trait_name = trim(slice(header_rest, 0, for_index));
    set target_type = trim(slice(header_rest, for_index + 5, len(header_rest)));
  } else {
    set target_type = header_rest;
  }
  let headers: [string] = extract_proc_headers(body_text);
  let methods: [CompleteProcSignature] = [];
  let i: u64 = 0;
  while i < len(headers) {
    let signature: CompleteProcSignature = parse_surface_signature(headers[i]);
    if signature.valid {
      set methods = methods + [signature];
    }
    set i = i + 1;
  }
  give CompleteImplInfo {
    trait_name: trait_name,
    target_type: target_type,
    generic_params: [],
    methods: methods,
    valid: target_type != ""
  };
}

proc surface_for_item(item: AstItem, source_text: string) -> SurfaceItem {
  let text: string = source_lines_between(source_text, item.span.start_line, item.span.end_line);
  let body_text: string = body_between_braces(text);
  if item.kind == AstItemKind.Form or item.kind == AstItemKind.Class or item.kind == AstItemKind.Union or item.kind == AstItemKind.Bits {
    give SurfaceItem {
      kind: item.kind,
      name: item.name,
      fields: parse_form_fields(body_text),
      variants: [],
      trait_requirements: [],
      impl_info: complete_impl_info_empty(),
      valid: true
    };
  }
  if item.kind == AstItemKind.Pick or item.kind == AstItemKind.Flags {
    give SurfaceItem {
      kind: item.kind,
      name: item.name,
      fields: [],
      variants: parse_pick_variants(body_text),
      trait_requirements: [],
      impl_info: complete_impl_info_empty(),
      valid: true
    };
  }
  if item.kind == AstItemKind.Trait {
    give SurfaceItem {
      kind: item.kind,
      name: item.name,
      fields: [],
      variants: [],
      trait_requirements: parse_trait_requirements(body_text),
      impl_info: complete_impl_info_empty(),
      valid: true
    };
  }
  if item.kind == AstItemKind.Impl {
    give SurfaceItem {
      kind: item.kind,
      name: item.name,
      fields: [],
      variants: [],
      trait_requirements: [],
      impl_info: parse_impl_info(item.name, text, body_text),
      valid: true
    };
  }
  give SurfaceItem {
    kind: item.kind,
    name: item.name,
    fields: [],
    variants: [],
    trait_requirements: [],
    impl_info: complete_impl_info_empty(),
    valid: false
  };
}

proc collect_surface_items(module: AstModule, source_text: string) -> [SurfaceItem] {
  let out: [SurfaceItem] = [];
  let i: u64 = 0;
  while i < len(module.items) {
    set out = out + [surface_for_item(module.items[i], source_text)];
    set i = i + 1;
  }
  give out;
}

proc find_surface_item(surfaces: [SurfaceItem], kind: AstItemKind, name: string) -> SurfaceItem {
  let i: u64 = 0;
  while i < len(surfaces) {
    if surfaces[i].kind == kind and surfaces[i].name == name {
      give surfaces[i];
    }
    set i = i + 1;
  }
  give SurfaceItem {
    kind: AstItemKind.Unknown,
    name: "",
    fields: [],
    variants: [],
    trait_requirements: [],
    impl_info: complete_impl_info_empty(),
    valid: false
  };
}
