space vitte/compiler/analysis/typeck

use vitte/compiler/analysis/typeck/checker.{ run_typeck_hir }
use vitte/compiler/analysis/typeck/errors.{ TypeckResult }
use vitte/compiler/middle/hir.{ HirUnit }

export *

proc production_typeck_pipeline_name() -> string {
  give "hir";
}

proc production_typeck_pipeline_status() -> string {
  give "canonical";
}

proc run_production_typeck_hir(hir: HirUnit) -> TypeckResult {
  give run_typeck_hir(hir);
}
