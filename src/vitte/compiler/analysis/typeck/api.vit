space vitte/compiler/analysis/typeck

use vitte/compiler/analysis/typeck/checker.{ run_typeck_hir }
use vitte/compiler/analysis/typeck/complete.{ CompleteResult, CompleteSymbolKind, run_complete_typeck_frontend, run_complete_typeck_module }
use vitte/compiler/analysis/typeck/errors.{ TypeckResult }
use vitte/compiler/frontend/ast/item.{ AstModule }
use vitte/compiler/frontend/pipeline.{ FrontendOutput }
use vitte/compiler/middle/hir.{ HirUnit }

export *

proc production_typeck_pipeline_name() -> string {
  give "hir";
}

proc experimental_typeck_pipeline_name() -> string {
  give "complete";
}

proc production_typeck_pipeline_status() -> string {
  give "production";
}

proc experimental_typeck_pipeline_status() -> string {
  give "experimental";
}

proc run_production_typeck_hir(hir: HirUnit) -> TypeckResult {
  give run_typeck_hir(hir);
}

proc run_experimental_complete_typeck_frontend(output: FrontendOutput) -> CompleteResult {
  give run_complete_typeck_frontend(output);
}

proc run_experimental_complete_typeck_module(module: AstModule) -> CompleteResult {
  give run_complete_typeck_module(module);
}
