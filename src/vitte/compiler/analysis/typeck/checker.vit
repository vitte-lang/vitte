space vitte/compiler/analysis/typeck

use vitte/compiler/analysis/typeck/coercion.{ types_compatible }
use vitte/compiler/analysis/typeck/errors.{ TypeckResult, add_unique_diag, typeck_assignment_mismatch, typeck_condition_type, typeck_conflicting_impl, typeck_diag, typeck_invalid_hir_result, typeck_non_exhaustive_match, typeck_result, typeck_return_mismatch }
use vitte/compiler/analysis/typeck/infer.{ TypeBinding, constrained_generic_type_binding, env_get, env_has, env_index, env_set, infer_expr_type, param_type_binding, trait_impl_binding_name }
use vitte/compiler/analysis/typeck/traits.{ type_is_copy, type_is_known, type_is_truthy }
use vitte/compiler/diagnostics/diagnostic.{ Diagnostic }
use vitte/compiler/middle/hir.{ HirExpr, HirItem, HirItemKind, HirModule, HirNominalMember, HirNominalMemberKind, HirProcParam, HirStmt, HirStmtKind, HirUnit }

form TypeckStmtWalk {
  stmts: [HirStmt]
  env: [TypeBinding]
  diagnostics: [Diagnostic]
  valid: bool
}

form TypeckMemberWalk {
  members: [HirNominalMember]
  diagnostics: [Diagnostic]
  valid: bool
}

proc nominal_type_env_name(name: string) -> string {
  give "@type:" + name;
}

proc nominal_member_env_name(owner: string, member: string) -> string {
  give "@member:" + owner + "." + member;
}

proc proc_param_signature_text(param: HirProcParam, target_type_text: string) -> string {
  let ty: string = if param.annotation_text == "Self" and target_type_text != "" { target_type_text } else { if param.annotation_text != "" { param.annotation_text } else { "opaque" } };
  if param.variadic {
    give "...";
  }
  if param.borrowed and param.mutable {
    give "&mut " + ty;
  }
  if param.borrowed {
    give "borrow " + ty;
  }
  if param.mutable {
    give "mut " + ty;
  }
  if param.mode != "" {
    give param.mode + " " + ty;
  }
  give ty;
}

proc proc_signature_type(params: [HirProcParam], return_type: string, target_type_text: string) -> string {
  let out: [string] = [];
  let i: u64 = 0;
  while i < len(params) {
    set out = out + [proc_param_signature_text(params[i], target_type_text)];
    set i = i + 1;
  }
  let ret: string = if return_type != "" { return_type } else { "unit" };
  give "fn(" + join(out, ", ") + ") -> " + ret;
}

proc bind_member_signature(item: HirItem, member: HirNominalMember) -> string {
  let params: [string] = [];
  let start_index: u64 = 0;
  if len(member.params) > 0 and (member.kind == HirNominalMemberKind.TraitMethod or member.kind == HirNominalMemberKind.ImplMethod) {
    let first: string = member.params[0].annotation_text;
    if first == "Self" or (item.target_type_text != "" and first == item.target_type_text) {
      set start_index = 1;
    }
  }
  let i: u64 = start_index;
  while i < len(member.params) {
    let param_ty: string = proc_param_signature_text(member.params[i], item.target_type_text);
    set params = params + [param_ty];
    set i = i + 1;
  }
  let joined: string = join(params, ", ");
  let ret: string = if member.annotation_text != "" { member.annotation_text } else { "unit" };
  give "fn(" + joined + ") -> " + ret;
}

proc nominal_member_binding_type(item: HirItem, member: HirNominalMember) -> string {
  if member.kind == HirNominalMemberKind.Field {
    if member.annotation_text != "" {
      give member.annotation_text;
    }
    give "opaque";
  }
  if member.kind == HirNominalMemberKind.Variant {
    if item.kind == HirItemKind.Bits or item.kind == HirItemKind.Flags {
      if item.annotation_text != "" {
        give item.annotation_text;
      }
      give item.name;
    }
    if member.annotation_text != "" {
      give "fn(" + member.annotation_text + ") -> " + item.name;
    }
    give item.name;
  }
  give bind_member_signature(item, member);
}

proc generic_param_index(params: [string], name: string) -> int {
  let i: int = 0;
  while i < len(params) {
    if params[i] == name {
      give i;
    }
    set i = i + 1;
  }
  give -1;
}

proc replace_generic_bound(bounds: [string], index: u64, bound: string) -> [string] {
  let out: [string] = [];
  let i: u64 = 0;
  while i < len(bounds) {
    if i == index {
      let next_bound: string = if bounds[i] == "" { trim(bound) } else { bounds[i] + " + " + trim(bound) };
      set out = out + [next_bound];
    } else {
      set out = out + [bounds[i]];
    }
    set i = i + 1;
  }
  give out;
}

proc item_generic_bounds(item: HirItem) -> [string] {
  let bounds: [string] = [];
  let i: u64 = 0;
  while i < len(item.generic_params) {
    let inline_bound: string = if i < len(item.generic_param_info) { item.generic_param_info[i].bound_text } else { "" };
    set bounds = bounds + [inline_bound];
    set i = i + 1;
  }

  let clause_index: u64 = 0;
  while clause_index < len(item.where_clauses) {
    let clause: string = trim(item.where_clauses[clause_index]);
    let colon: int = find(clause, ":");
    if colon > 0 {
      let param_name: string = trim(slice(clause, 0, colon));
      let bound: string = trim(slice(clause, colon + 1, len(clause)));
      let index: int = generic_param_index(item.generic_params, param_name);
      if index >= 0 and bound != "" {
        set bounds = replace_generic_bound(bounds, index as u64, bound);
      }
    }
    set clause_index = clause_index + 1;
  }
  give bounds;
}

proc nominal_type_bindings(items: [HirItem]) -> [TypeBinding] {
  let out: [TypeBinding] = [];
  let i: u64 = 0;
  while i < len(items) {
    let item: HirItem = items[i];
    if item.name != "" and item.kind != HirItemKind.Space and item.kind != HirItemKind.Use and item.kind != HirItemKind.Export {
      if item.kind == HirItemKind.Proc {
        set out = out + [constrained_generic_type_binding(item.name, proc_signature_type(item.params, item.annotation_text, item.target_type_text), item.generic_params, item_generic_bounds(item))];
      }
      if item.kind == HirItemKind.Impl and item.name != "" and item.target_type_text != "" {
        set out = env_set(out, trait_impl_binding_name(item.name, item.target_type_text), "impl");
      }
      set out = env_set(out, nominal_type_env_name(item.name), item.name);
      let owner_name: string = if item.kind == HirItemKind.Impl and item.target_type_text != "" { item.target_type_text } else { item.name };
      let j: u64 = 0;
      while j < len(item.members) {
        if item.members[j].name != "" and owner_name != "" {
          set out = env_set(out, nominal_member_env_name(owner_name, item.members[j].name), nominal_member_binding_type(item, item.members[j]));
        }
        set j = j + 1;
      }
    }
    set i = i + 1;
  }
  give out;
}

proc match_stmt_has_fallback_arm(stmt: HirStmt) -> bool {
  let i: u64 = 0;
  while i < len(stmt.then_stmts) {
    let is_fallback_arm: bool = stmt.then_stmts[i].name == "_" or stmt.then_stmts[i].name == "else";
    if stmt.then_stmts[i].kind == HirStmtKind.When and is_fallback_arm {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc trait_item_by_name(items: [HirItem], name: string) -> HirItem {
  let i: u64 = 0;
  while i < len(items) {
    if items[i].kind == HirItemKind.Trait and items[i].name == name {
      give items[i];
    }
    set i = i + 1;
  }
  give HirItem {
    id: 0,
    span: items[0].span,
    kind: HirItemKind.Unknown,
    name: "",
    resolved_id: 0,
    namespace: "",
    visibility: "",
    exported: false,
    abi: "",
    generic_count: 0,
    generic_params: [],
    generic_param_info: [],
    where_clauses: [],
    requires: [],
    type_param_count: 0,
    attribute_count: 0,
    modifier_count: 0,
    member_count: 0,
    signature_param_count: 0,
    params: [],
    annotation_text: "",
    target_type_text: "",
    expr: HirExpr { id: 0, span: items[0].span, kind: 0, text: "", name: "", operator: "", binding: "", resolved_id: 0, resolved_kind: "", external: false, value_mode: 0, inferred_type: "unknown", place_category: 0, copyable: false, diagnostics: [], children: [], valid: false },
    stmts: [],
    members: [],
    message: "",
    scope_depth: 0,
    diagnostics: [],
    valid: false
  };
}

proc member_env(params: [HirProcParam], target_type_text: string) -> [TypeBinding] {
  let env: [TypeBinding] = [];
  let i: u64 = 0;
  while i < len(params) {
    let ty: string = if params[i].annotation_text == "Self" and target_type_text != "" { target_type_text } else { if params[i].annotation_text != "" { params[i].annotation_text } else { "opaque" } };
    if params[i].name != "" and not params[i].variadic {
      set env = env + [param_type_binding(params[i].name, ty, params[i].mutable, params[i].borrowed)];
    }
    set i = i + 1;
  }
  give env;
}

proc typeck_member(module_env: [TypeBinding], item: HirItem, member: HirNominalMember) -> TypeckMemberWalk {
  let local_env: [TypeBinding] = module_env + member_env(member.params, item.target_type_text);
  let typed_expr: HirExpr = annotate_expr(local_env, member.expr);
  let body_result: TypeckStmtWalk = check_stmt_tree([], local_env, member.body_stmts, member.annotation_text, member.name);
  let diagnostics: [Diagnostic] = body_result.diagnostics;
  give TypeckMemberWalk {
    members: [HirNominalMember {
      id: member.id,
      span: member.span,
      kind: member.kind,
      name: member.name,
      annotation_text: member.annotation_text,
      expr: typed_expr,
      params: member.params,
      body_stmts: body_result.stmts,
      message: member.message,
      valid: member.valid
    }],
    diagnostics: diagnostics,
    valid: len(diagnostics) == 0
  };
}

proc typeck_members(module_env: [TypeBinding], item: HirItem) -> TypeckMemberWalk {
  let out: [HirNominalMember] = [];
  let diagnostics: [Diagnostic] = [];
  let i: u64 = 0;
  while i < len(item.members) {
    let walk: TypeckMemberWalk = typeck_member(module_env, item, item.members[i]);
    set out = out + walk.members;
    set diagnostics = diagnostics + walk.diagnostics;
    set i = i + 1;
  }
  give TypeckMemberWalk { members: out, diagnostics: diagnostics, valid: len(diagnostics) == 0 };
}

proc find_member(members: [HirNominalMember], name: string) -> HirNominalMember {
  let i: u64 = 0;
  while i < len(members) {
    if members[i].name == name {
      give members[i];
    }
    set i = i + 1;
  }
  give HirNominalMember { id: 0, span: members[0].span, kind: 0, name: "", annotation_text: "", expr: HirExpr { id: 0, span: members[0].span, kind: 0, text: "", name: "", operator: "", binding: "", resolved_id: 0, resolved_kind: "", external: false, value_mode: 0, inferred_type: "unknown", place_category: 0, copyable: false, diagnostics: [], children: [], valid: false }, params: [], body_stmts: [], message: "", valid: false };
}

proc check_impl_against_trait(items: [HirItem], item: HirItem) -> [Diagnostic] {
  let out: [Diagnostic] = [];
  if item.kind != HirItemKind.Impl or len(item.members) == 0 {
    give out;
  }
  let trait_item: HirItem = trait_item_by_name(items, item.name);
  if not trait_item.valid {
    give out + [typeck_diag("TYPECK_E_IMPL_UNKNOWN_TRAIT", "impl target trait is not declared", [item.name], "declare the trait before implementing it", item.span, true)];
  }
  let i: u64 = 0;
  while i < len(trait_item.members) {
    let trait_member: HirNominalMember = trait_item.members[i];
    let impl_member: HirNominalMember = find_member(item.members, trait_member.name);
    if not impl_member.valid {
      set out = out + [typeck_diag("TYPECK_E_IMPL_MISSING_MEMBER", "impl is missing a required trait method", [item.name, trait_member.name], "define the missing method on the impl", item.span, true)];
    } else {
      if len(impl_member.params) != len(trait_member.params) {
        set out = out + [typeck_diag("TYPECK_E_IMPL_SIGNATURE_MISMATCH", "impl method parameter count does not match trait method", [trait_member.name], "align impl method arity with the trait declaration", impl_member.span, true)];
      } elif impl_member.annotation_text != trait_member.annotation_text {
        set out = out + [typeck_diag("TYPECK_E_IMPL_SIGNATURE_MISMATCH", "impl method return type does not match trait method", [trait_member.name, trait_member.annotation_text, impl_member.annotation_text], "align impl method return type with the trait declaration", impl_member.span, true)];
      } else {
        let j: u64 = 0;
        while j < len(trait_member.params) and j < len(impl_member.params) {
          if trait_member.params[j].annotation_text != impl_member.params[j].annotation_text {
            set out = out + [typeck_diag("TYPECK_E_IMPL_SIGNATURE_MISMATCH", "impl method parameter type does not match trait method", [trait_member.name, trait_member.params[j].annotation_text, impl_member.params[j].annotation_text], "align impl method parameter types with the trait declaration", impl_member.span, true)];
          }
          set j = j + 1;
        }
      }
    }
    set i = i + 1;
  }
  give out;
}

proc check_impl_coherence(items: [HirItem], item_index: u64) -> [Diagnostic] {
  let out: [Diagnostic] = [];
  if item_index >= len(items) {
    give out;
  }

  let item: HirItem = items[item_index];
  let trait_name: string = trim(item.name);
  let target_type: string = trim(item.target_type_text);
  if item.kind != HirItemKind.Impl or trait_name == "" or target_type == "" {
    give out;
  }

  let i: u64 = 0;
  while i < item_index {
    let previous: HirItem = items[i];
    if previous.kind == HirItemKind.Impl
      and trim(previous.name) == trait_name
      and trim(previous.target_type_text) == target_type {
      give [typeck_conflicting_impl(trait_name, target_type, previous.span, item.span)];
    }
    set i = i + 1;
  }

  give out;
}

proc run_typeck_hir(hir: HirUnit) -> TypeckResult {
  if not hir.valid {
    give typeck_invalid_hir_result(hir);
  }

  let checked: TypeckResult = check_module([], [], hir);
  give checked;
}

proc annotate_expr(env: [TypeBinding], expr: HirExpr) -> HirExpr {
  let children: [HirExpr] = [];
  let i: u64 = 0;
  while i < len(expr.children) {
    set children = children + [annotate_expr(env, expr.children[i])];
    set i = i + 1;
  }

  let base: HirExpr = HirExpr {
    id: expr.id,
    span: expr.span,
    kind: expr.kind,
    text: expr.text,
    name: expr.name,
    operator: expr.operator,
    binding: expr.binding,
    resolved_id: expr.resolved_id,
    resolved_kind: expr.resolved_kind,
    external: expr.external,
    value_mode: expr.value_mode,
    inferred_type: expr.inferred_type,
    place_category: expr.place_category,
    copyable: expr.copyable,
    generic_arguments: expr.generic_arguments,
    diagnostics: expr.diagnostics,
    children: children,
    valid: expr.valid
  };
  let inferred = infer_expr_type(env, base);
  give HirExpr {
    id: base.id,
    span: base.span,
    kind: base.kind,
    text: base.text,
    name: base.name,
    operator: base.operator,
    binding: base.binding,
    resolved_id: base.resolved_id,
    resolved_kind: base.resolved_kind,
    external: base.external,
    value_mode: base.value_mode,
    inferred_type: inferred.ty,
    place_category: base.place_category,
    copyable: type_is_copy(inferred.ty),
    generic_arguments: base.generic_arguments,
    diagnostics: base.diagnostics,
    children: children,
    valid: base.valid
  };
}

proc check_stmt_tree(diagnostics: [Diagnostic], env: [TypeBinding], stmts: [HirStmt], return_type: string, owner_name: string) -> TypeckStmtWalk {
  let out: [Diagnostic] = diagnostics;
  let current_env: [TypeBinding] = env;
  let typed: [HirStmt] = [];
  let j: u64 = 0;
  while j < len(stmts) {
    let stmt: HirStmt = stmts[j];
    let result = infer_expr_type(current_env, stmt.expr);
    let typed_expr: HirExpr = annotate_expr(current_env, stmt.expr);
    set out = out + result.diagnostics;

    let then_checked: TypeckStmtWalk = check_stmt_tree([], current_env, stmt.then_stmts, return_type, owner_name);
    let else_checked: TypeckStmtWalk = check_stmt_tree([], current_env, stmt.else_stmts, return_type, owner_name);
    set out = out + then_checked.diagnostics + else_checked.diagnostics;

    if stmt.kind == HirStmtKind.Let {
      if not type_is_known(result.ty) {
        set out = add_unique_diag(out, typeck_diag(
          "TYPECK_E_UNKNOWN_TYPE",
          "unable to infer type of declaration `" + stmt.name + "`",
          [stmt.name],
          "add a more explicit initializer or type annotation",
          stmt.span,
          true
        ));
      }
      if stmt.name != "" {
        set current_env = env_set(current_env, stmt.name, result.ty);
      }
    } elif stmt.kind == HirStmtKind.Set {
      let target_name: string = stmt.target_binding;
      if target_name == "" {
        set target_name = stmt.target;
      }
      if target_name != "" and env_has(current_env, target_name) {
        let binding: TypeBinding = current_env[env_index(current_env, target_name)];
        if not binding.mutable {
          set out = add_unique_diag(out, typeck_diag(
            "TYPECK_E_IMMUTABLE_ASSIGN",
            "cannot assign to immutable binding `" + target_name + "`",
            [target_name],
            "declare the binding as `mut` before assigning to it",
            stmt.span,
            true
          ));
        } elif type_is_known(result.ty) and not types_compatible(binding.ty, result.ty) {
          set out = add_unique_diag(out, typeck_assignment_mismatch(
            target_name,
            binding.ty,
            result.ty,
            stmt.span
          ));
        }
      } elif target_name != "" and not env_has(current_env, target_name) {
        set current_env = env_set(current_env, target_name, result.ty);
      }
    } elif stmt.kind == HirStmtKind.StaticAssert or stmt.kind == HirStmtKind.If or stmt.kind == HirStmtKind.While {
      if not type_is_truthy(result.ty) {
        set out = add_unique_diag(out, typeck_condition_type(
          result.ty,
          stmt.span
        ));
      }
    } elif stmt.kind == HirStmtKind.Match {
      if !match_stmt_has_fallback_arm(stmt) {
        set out = add_unique_diag(out, typeck_non_exhaustive_match(
          "_",
          stmt.span
        ));
      }
    } elif stmt.kind == HirStmtKind.Give {
      if return_type != "" and type_is_known(result.ty) and not types_compatible(return_type, result.ty) {
        set out = add_unique_diag(out, typeck_return_mismatch(
          owner_name,
          return_type,
          result.ty,
          stmt.span
        ));
      }
    }

    set typed = typed + [HirStmt {
      id: stmt.id,
      span: stmt.span,
      kind: stmt.kind,
      name: stmt.name,
      target: stmt.target,
      target_binding: stmt.target_binding,
      target_resolved_id: stmt.target_resolved_id,
      target_resolved_kind: stmt.target_resolved_kind,
      annotation_text: stmt.annotation_text,
      expr: typed_expr,
      message: stmt.message,
      mutable: stmt.mutable,
      scope_depth: stmt.scope_depth,
      then_stmts: then_checked.stmts,
      else_stmts: else_checked.stmts,
      catch_stmts: stmt.catch_stmts,
      diagnostics: stmt.diagnostics,
      valid: stmt.valid
    }];
    set j = j + 1;
  }

  give TypeckStmtWalk {
    stmts: typed,
    env: current_env,
    diagnostics: out,
    valid: len(out) == 0
  };
}

proc check_module(diagnostics: [Diagnostic], env: [TypeBinding], hir: HirUnit) -> TypeckResult {
  let out: [Diagnostic] = diagnostics;
  let items: [HirItem] = [];
  let module_env: [TypeBinding] = env + nominal_type_bindings(hir.module.items);
  let i: u64 = 0;
  while i < len(hir.module.items) {
    let item: HirItem = hir.module.items[i];
    if item.kind == HirItemKind.Unknown {
      set out = add_unique_diag(out, typeck_diag(
        "TYPECK_E_UNKNOWN_ITEM",
        "unknown HIR item kind",
        [item.name],
        "lower the item into a supported HIR kind",
        item.span,
        true
      ));
    }

    let item_result = infer_expr_type(module_env, item.expr);
    let typed_item_expr: HirExpr = annotate_expr(module_env, item.expr);
    set out = out + item_result.diagnostics;
    if item.kind == HirItemKind.Const and item.name != "" {
      set module_env = env_set(module_env, item.name, item_result.ty);
    }

    let item_env: [TypeBinding] = module_env + member_env(item.params, "");
    let stmt_result: TypeckStmtWalk = check_stmt_tree([], item_env, item.stmts, item.annotation_text, item.name);
    let member_result: TypeckMemberWalk = typeck_members(module_env, item);
    set out = out + stmt_result.diagnostics;
    set out = out + member_result.diagnostics;
    set out = out + check_impl_against_trait(hir.module.items, item);
    set out = out + check_impl_coherence(hir.module.items, i);
    set module_env = stmt_result.env;

    set items = items + [HirItem {
      id: item.id,
      span: item.span,
      kind: item.kind,
      name: item.name,
      resolved_id: item.resolved_id,
      namespace: item.namespace,
      visibility: item.visibility,
      exported: item.exported,
      abi: item.abi,
      generic_count: item.generic_count,
      generic_params: item.generic_params,
      generic_param_info: item.generic_param_info,
      where_clauses: item.where_clauses,
      requires: item.requires,
      type_param_count: item.type_param_count,
      attribute_count: item.attribute_count,
      modifier_count: item.modifier_count,
      member_count: item.member_count,
      signature_param_count: item.signature_param_count,
      params: item.params,
      annotation_text: item.annotation_text,
      target_type_text: item.target_type_text,
      expr: typed_item_expr,
      stmts: stmt_result.stmts,
      members: member_result.members,
      message: item.message,
      scope_depth: item.scope_depth,
      diagnostics: item.diagnostics,
      valid: item.valid
    }];
    set i = i + 1;
  }

  let typed_hir: HirUnit = HirUnit {
      source_path: hir.source_path,
      module: HirModule {
        items: items,
        valid: hir.module.valid
      },
      node_count: hir.node_count,
      symbol_count: hir.symbol_count,
      scope_count: hir.scope_count,
      valid: hir.valid
  };
  give typeck_result(typed_hir, out);
}
