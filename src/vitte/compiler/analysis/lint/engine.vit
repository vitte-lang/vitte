space vitte/compiler/analysis/lint

use vitte/compiler/analysis/lint/levels.{ LintSeverity }
use vitte/compiler/analysis/lint/report.{ LintDiagnostic, LintResult, lint_diagnostic }
use vitte/compiler/analysis/lint/rules.{
  LintBindingStat,
  expr_is_constant_bool,
  stats_add,
  stats_index,
  stats_mark_set,
  stats_mark_use
}
use vitte/compiler/frontend/ast/node.{ AstSpan }
use vitte/compiler/middle/hir.{ HirExpr, HirExprKind, HirItemKind, HirStmt, HirStmtKind, HirUnit }

form LintWalk {
  diagnostics: [LintDiagnostic]
  stats: [LintBindingStat]
  valid: bool
}

proc lint_add_diag(diagnostics: [LintDiagnostic], diagnostic: LintDiagnostic) -> [LintDiagnostic] {
  let i: u64 = 0;
  while i < len(diagnostics) {
    if diagnostics[i].code == diagnostic.code and diagnostics[i].span.start_line == diagnostic.span.start_line and diagnostics[i].message == diagnostic.message {
      give diagnostics;
    }
    set i = i + 1;
  }
  give diagnostics + [diagnostic];
}

proc record_expr_uses(stats: [LintBindingStat], expr: HirExpr) -> [LintBindingStat] {
  let current: [LintBindingStat] = stats;
  let binding_name: string = expr.binding;
  if binding_name == "" and expr.kind == HirExprKind.Name {
    set binding_name = expr.name;
  }
  if binding_name != "" and expr.resolved_kind == "local" and stats_index(current, binding_name) >= 0 {
    set current = stats_mark_use(current, binding_name);
  }

  let i: u64 = 0;
  while i < len(expr.children) {
    set current = record_expr_uses(current, expr.children[i]);
    set i = i + 1;
  }
  give current;
}

proc root_binding_name(name: string) -> string {
  let trimmed: string = trim(name);
  if trimmed == "" {
    give "";
  }

  let i: u64 = 0;
  while i < len(trimmed) {
    let ch: string = slice(trimmed, i, i + 1);
    let is_lower_alpha: bool = ch >= "a" and ch <= "z";
    let is_upper_alpha: bool = ch >= "A" and ch <= "Z";
    let is_digit: bool = ch >= "0" and ch <= "9";
    let valid_ident: bool = is_lower_alpha or is_upper_alpha or ch == "_" or is_digit;
    if not valid_ident {
      break;
    }
    set i = i + 1;
  }
  give slice(trimmed, 0, i);
}

proc span_for_name(source_path: string, line: u64, name: string) -> AstSpan {
  give AstSpan {
    file: source_path,
    start_line: line,
    start_column: 1,
    end_line: line,
    end_column: len(name) as u64 + 1
  };
}

proc collect_stmt_data(source_path: string, diagnostics: [LintDiagnostic], stats: [LintBindingStat], stmt: HirStmt) -> LintWalk {
  let current_diagnostics: [LintDiagnostic] = diagnostics;
  let current_stats: [LintBindingStat] = record_expr_uses(stats, stmt.expr);

  if stmt.kind == HirStmtKind.Let and stmt.name != "" {
    set current_stats = stats_add(current_stats, stmt.name, stmt.mutable, stmt.span.start_line);
  } elif stmt.kind == HirStmtKind.Set {
    let target_name: string = stmt.target_binding;
    if target_name == "" {
      set target_name = stmt.target;
    }
    set target_name = root_binding_name(target_name);
    if target_name != "" and stats_index(current_stats, target_name) >= 0 {
      set current_stats = stats_mark_set(current_stats, target_name);
    }
  }

  let is_branch_stmt: bool = stmt.kind == HirStmtKind.If or stmt.kind == HirStmtKind.While;
  let has_constant_condition: bool = expr_is_constant_bool(stmt.expr);
  if is_branch_stmt and has_constant_condition {
    set current_diagnostics = lint_add_diag(current_diagnostics, lint_diagnostic(
      "LINT_W_CONSTANT_CONDITION",
      LintSeverity.Warning,
      "constant condition in control flow",
      [stmt.expr.text],
      "remove the branch or replace the constant with a computed condition",
      stmt.span,
      false
    ));
  }

  let i: u64 = 0;
  while i < len(stmt.then_stmts) {
    let nested: LintWalk = collect_stmt_data(source_path, current_diagnostics, current_stats, stmt.then_stmts[i]);
    set current_diagnostics = nested.diagnostics;
    set current_stats = nested.stats;
    set i = i + 1;
  }

  i = 0;
  while i < len(stmt.else_stmts) {
    let nested: LintWalk = collect_stmt_data(source_path, current_diagnostics, current_stats, stmt.else_stmts[i]);
    set current_diagnostics = nested.diagnostics;
    set current_stats = nested.stats;
    set i = i + 1;
  }

  give LintWalk {
    diagnostics: current_diagnostics,
    stats: current_stats,
    valid: true
  };
}

proc finalize_stats_diagnostics(source_path: string, diagnostics: [LintDiagnostic], stats: [LintBindingStat]) -> [LintDiagnostic] {
  let out: [LintDiagnostic] = diagnostics;
  let i: u64 = 0;
  while i < len(stats) {
    let stat: LintBindingStat = stats[i];
    if stat.use_count == 0 and not starts_with(stat.name, "_") {
      set out = lint_add_diag(out, lint_diagnostic(
        "LINT_W_UNUSED_LOCAL",
        LintSeverity.Warning,
        "local `" + stat.name + "` is never used",
        [stat.name],
        "remove the binding or prefix it with `_` if it is intentionally unused",
        span_for_name(source_path, stat.declared_line, stat.name),
        false
      ));
    }
    if stat.mutable and stat.set_count == 0 {
      set out = lint_add_diag(out, lint_diagnostic(
        "LINT_W_UNUSED_MUT",
        LintSeverity.Warning,
        "binding `" + stat.name + "` is mutable but never reassigned",
        [stat.name],
        "remove `mut` from the binding if mutation is not required",
        span_for_name(source_path, stat.declared_line, stat.name),
        false
      ));
    }
    set i = i + 1;
  }
  give out;
}

proc run_lint_hir(source_path: string, hir: HirUnit) -> LintResult {
  if not hir.valid or not hir.module.valid {
    give LintResult {
      diagnostics: [],
      valid: true
    };
  }

  let diagnostics: [LintDiagnostic] = [];
  let stats: [LintBindingStat] = [];
  let i: u64 = 0;
  while i < len(hir.module.items) {
    if hir.module.items[i].kind == HirItemKind.Proc {
      let j: u64 = 0;
      while j < len(hir.module.items[i].stmts) {
        let stmt: HirStmt = hir.module.items[i].stmts[j];
        let nested: LintWalk = collect_stmt_data(source_path, diagnostics, stats, stmt);
        set diagnostics = nested.diagnostics;
        set stats = nested.stats;
        set j = j + 1;
      }
    }
    set i = i + 1;
  }

  give LintResult {
    diagnostics: finalize_stats_diagnostics(source_path, diagnostics, stats),
    valid: true
  };
}
