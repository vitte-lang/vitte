space vitte/compiler/analysis/lint

use vitte/compiler/analysis/lint/levels.{ LintSeverity }
use vitte/compiler/analysis/lint/report.{ LintDiagnostic, LintResult, lint_diagnostic }
use vitte/compiler/analysis/lint/rules.{
  LintBindingStat,
  expr_is_constant_bool,
  stats_add,
  stats_add_binding,
  stats_index,
  stats_mark_set,
  stats_mark_use
}
use vitte/compiler/frontend/ast/node.{ Span }
use vitte/compiler/source/span.{ span }
use vitte/compiler/middle/hir.{ HirExpr, HirExprKind, HirItemKind, HirProcParam, HirStmt, HirStmtKind, HirUnit, hir_stmt_terminated }

form LintWalk {
  diagnostics: [LintDiagnostic]
  stats: [LintBindingStat]
  valid: bool
}

proc lint_add_diag(diagnostics: [LintDiagnostic], diagnostic: LintDiagnostic) -> [LintDiagnostic] {
  let i: u64 = 0;
  while i < len(diagnostics) {
    if diagnostics[i].code == diagnostic.code and diagnostics[i].span.start_line == diagnostic.span.start_line and diagnostics[i].message == diagnostic.message {
      give diagnostics;
    }
    set i = i + 1;
  }
  give diagnostics + [diagnostic];
}

proc record_expr_uses(stats: [LintBindingStat], expr: HirExpr) -> [LintBindingStat] {
  let current: [LintBindingStat] = stats;
  let binding_name: string = expr.binding;
  if binding_name == "" and expr.kind == HirExprKind.Name {
    set binding_name = expr.name;
  }
  if binding_name != "" and expr.resolved_kind == "local" and stats_index(current, binding_name) >= 0 {
    set current = stats_mark_use(current, binding_name);
  }

  let i: u64 = 0;
  while i < len(expr.children) {
    set current = record_expr_uses(current, expr.children[i]);
    set i = i + 1;
  }
  give current;
}

proc root_binding_name(name: string) -> string {
  let trimmed: string = trim(name);
  if trimmed == "" {
    give "";
  }

  let i: u64 = 0;
  while i < len(trimmed) {
    let ch: string = slice(trimmed, i, i + 1);
    let is_lower_alpha: bool = ch >= "a" and ch <= "z";
    let is_upper_alpha: bool = ch >= "A" and ch <= "Z";
    let is_digit: bool = ch >= "0" and ch <= "9";
    let valid_ident: bool = is_lower_alpha or is_upper_alpha or ch == "_" or is_digit;
    if not valid_ident {
      break;
    }
    set i = i + 1;
  }
  give slice(trimmed, 0, i);
}

proc span_for_name(source_path: string, line: u64, name: string) -> Span {
  give span(source_path, line, 1, line, len(name) as u64 + 1);
}

proc bool_literal_text(expr: HirExpr) -> string {
  if expr.valid and expr.kind == HirExprKind.Bool {
    give trim(expr.text);
  }
  give "";
}

proc stmt_list_terminates(stmts: [HirStmt]) -> bool {
  let i: u64 = 0;
  while i < len(stmts) {
    if stmt_terminates(stmts[i]) {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc stmt_terminates(stmt: HirStmt) -> bool {
  if hir_stmt_terminated(stmt) or stmt.kind == HirStmtKind.Break or stmt.kind == HirStmtKind.Continue {
    give true;
  }
  if stmt.kind == HirStmtKind.If and len(stmt.then_stmts) > 0 and len(stmt.else_stmts) > 0 {
    give stmt_list_terminates(stmt.then_stmts) and stmt_list_terminates(stmt.else_stmts);
  }
  give false;
}

proc item_requires_return(annotation_text: string) -> bool {
  let text: string = trim(annotation_text);
  give text != "" and text != "void" and text != "unit" and text != "()";
}

proc add_unreachable_branch_diag(diagnostics: [LintDiagnostic], stmt: HirStmt, condition_text: string) -> [LintDiagnostic] {
  if stmt.kind == HirStmtKind.If and condition_text == "false" and len(stmt.then_stmts) > 0 {
    give lint_add_diag(diagnostics, lint_diagnostic(
      "LINT_W_UNREACHABLE_BRANCH",
      LintSeverity.Warning,
      "branch is unreachable because the condition is always false",
      [stmt.expr.text],
      "remove the unreachable branch or replace the constant condition",
      stmt.then_stmts[0].span,
      false
    ));
  }
  if stmt.kind == HirStmtKind.If and condition_text == "true" and len(stmt.else_stmts) > 0 {
    give lint_add_diag(diagnostics, lint_diagnostic(
      "LINT_W_UNREACHABLE_BRANCH",
      LintSeverity.Warning,
      "else branch is unreachable because the condition is always true",
      [stmt.expr.text],
      "remove the unreachable branch or replace the constant condition",
      stmt.else_stmts[0].span,
      false
    ));
  }
  if stmt.kind == HirStmtKind.While and condition_text == "false" {
    give lint_add_diag(diagnostics, lint_diagnostic(
      "LINT_W_UNREACHABLE_BRANCH",
      LintSeverity.Warning,
      "loop body is unreachable because the condition is always false",
      [stmt.expr.text],
      "remove the loop or replace the constant condition",
      stmt.span,
      false
    ));
  }
  give diagnostics;
}

proc collect_stmt_data(source_path: string, diagnostics: [LintDiagnostic], stats: [LintBindingStat], stmt: HirStmt) -> LintWalk {
  let current_diagnostics: [LintDiagnostic] = diagnostics;
  let current_stats: [LintBindingStat] = record_expr_uses(stats, stmt.expr);

  if stmt.kind == HirStmtKind.Let and stmt.name != "" {
    set current_stats = stats_add(current_stats, stmt.name, stmt.mutable, stmt.span.start_line);
  } elif stmt.kind == HirStmtKind.Set {
    let target_name: string = stmt.target_binding;
    if target_name == "" {
      set target_name = stmt.target;
    }
    set target_name = root_binding_name(target_name);
    if target_name != "" and stats_index(current_stats, target_name) >= 0 {
      set current_stats = stats_mark_set(current_stats, target_name);
    }
  }

  let is_branch_stmt: bool = stmt.kind == HirStmtKind.If or stmt.kind == HirStmtKind.While;
  let has_constant_condition: bool = expr_is_constant_bool(stmt.expr);
  if is_branch_stmt and has_constant_condition {
    let condition_text: string = bool_literal_text(stmt.expr);
    set current_diagnostics = lint_add_diag(current_diagnostics, lint_diagnostic(
      "LINT_W_CONSTANT_CONDITION",
      LintSeverity.Warning,
      "constant condition in control flow",
      [stmt.expr.text],
      "remove the branch or replace the constant with a computed condition",
      stmt.span,
      false
    ));
    set current_diagnostics = add_unreachable_branch_diag(current_diagnostics, stmt, condition_text);
  }

  if stmt.kind == HirStmtKind.ExprStmt and stmt.expr.valid {
    set current_diagnostics = lint_add_diag(current_diagnostics, lint_diagnostic(
      "LINT_W_UNUSED_VALUE",
      LintSeverity.Warning,
      "value produced by expression is never used",
      [stmt.expr.text],
      "assign the value, pass it to another expression, or remove the expression",
      stmt.expr.span,
      false
    ));
  }

  let then_walk: LintWalk = collect_stmt_list_data(source_path, current_diagnostics, current_stats, stmt.then_stmts);
  set current_diagnostics = then_walk.diagnostics;
  set current_stats = then_walk.stats;

  let else_walk: LintWalk = collect_stmt_list_data(source_path, current_diagnostics, current_stats, stmt.else_stmts);
  set current_diagnostics = else_walk.diagnostics;
  set current_stats = else_walk.stats;

  give LintWalk {
    diagnostics: current_diagnostics,
    stats: current_stats,
    valid: true
  };
}

proc collect_stmt_list_data(source_path: string, diagnostics: [LintDiagnostic], stats: [LintBindingStat], stmts: [HirStmt]) -> LintWalk {
  let current_diagnostics: [LintDiagnostic] = diagnostics;
  let current_stats: [LintBindingStat] = stats;
  let terminated: bool = false;
  let i: u64 = 0;
  while i < len(stmts) {
    let stmt: HirStmt = stmts[i];
    if terminated or stmt.unreachable {
      set current_diagnostics = lint_add_diag(current_diagnostics, lint_diagnostic(
        "LINT_W_DEAD_CODE",
        LintSeverity.Warning,
        "statement is unreachable",
        [stmt.message],
        "remove the statement or move it before the terminating control flow",
        stmt.span,
        false
      ));
    }
    let nested: LintWalk = collect_stmt_data(source_path, current_diagnostics, current_stats, stmt);
    set current_diagnostics = nested.diagnostics;
    set current_stats = nested.stats;
    if stmt_terminates(stmt) {
      set terminated = true;
    }
    set i = i + 1;
  }
  give LintWalk {
    diagnostics: current_diagnostics,
    stats: current_stats,
    valid: true
  };
}

proc finalize_stats_diagnostics(source_path: string, diagnostics: [LintDiagnostic], stats: [LintBindingStat]) -> [LintDiagnostic] {
  let out: [LintDiagnostic] = diagnostics;
  let i: u64 = 0;
  while i < len(stats) {
    let stat: LintBindingStat = stats[i];
    if stat.use_count == 0 and not starts_with(stat.name, "_") {
      if stat.parameter {
        set out = lint_add_diag(out, lint_diagnostic(
          "LINT_W_UNUSED_PARAMETER",
          LintSeverity.Warning,
          "parameter `" + stat.name + "` is never used",
          [stat.name],
          "remove the parameter or prefix it with `_` if it is intentionally unused",
          span_for_name(source_path, stat.declared_line, stat.name),
          false
        ));
      } else {
      set out = lint_add_diag(out, lint_diagnostic(
        "LINT_W_UNUSED_LOCAL",
        LintSeverity.Warning,
        "local `" + stat.name + "` is never used",
        [stat.name],
        "remove the binding or prefix it with `_` if it is intentionally unused",
        span_for_name(source_path, stat.declared_line, stat.name),
        false
      ));
      }
    }
    if stat.mutable and not stat.parameter and stat.set_count == 0 {
      set out = lint_add_diag(out, lint_diagnostic(
        "LINT_W_UNUSED_MUT",
        LintSeverity.Warning,
        "binding `" + stat.name + "` is mutable but never reassigned",
        [stat.name],
        "remove `mut` from the binding if mutation is not required",
        span_for_name(source_path, stat.declared_line, stat.name),
        false
      ));
    }
    set i = i + 1;
  }
  give out;
}

proc collect_item_params(stats: [LintBindingStat], item_line: u64, params: [HirProcParam]) -> [LintBindingStat] {
  let out: [LintBindingStat] = stats;
  let i: u64 = 0;
  while i < len(params) {
    let param: HirProcParam = params[i];
    if param.valid and param.name != "" {
      set out = stats_add_binding(out, param.name, param.mutable, true, item_line);
    }
    set i = i + 1;
  }
  give out;
}

proc add_missing_return_diag(diagnostics: [LintDiagnostic], item_name: string, annotation_text: string, item_span: Span, stmts: [HirStmt]) -> [LintDiagnostic] {
  if item_requires_return(annotation_text) and not stmt_list_terminates(stmts) {
    give lint_add_diag(diagnostics, lint_diagnostic(
      "LINT_W_MISSING_RETURN",
      LintSeverity.Warning,
      "proc `" + item_name + "` may exit without returning `" + trim(annotation_text) + "`",
      [item_name, trim(annotation_text)],
      "add a `give` on every control-flow path",
      item_span,
      false
    ));
  }
  give diagnostics;
}

proc run_lint_hir(source_path: string, hir: HirUnit) -> LintResult {
  if not hir.valid or not hir.module.valid {
    give LintResult {
      diagnostics: [],
      valid: true
    };
  }

  let diagnostics: [LintDiagnostic] = [];
  let i: u64 = 0;
  while i < len(hir.module.items) {
    if hir.module.items[i].kind == HirItemKind.Proc {
      let item_stats: [LintBindingStat] = collect_item_params([], hir.module.items[i].span.start_line, hir.module.items[i].params);
      let nested: LintWalk = collect_stmt_list_data(source_path, diagnostics, item_stats, hir.module.items[i].stmts);
      set diagnostics = nested.diagnostics;
      set diagnostics = finalize_stats_diagnostics(source_path, diagnostics, nested.stats);
      set diagnostics = add_missing_return_diag(diagnostics, hir.module.items[i].name, hir.module.items[i].annotation_text, hir.module.items[i].span, hir.module.items[i].stmts);
    }
    set i = i + 1;
  }

  give LintResult {
    diagnostics: diagnostics,
    valid: true
  };
}
