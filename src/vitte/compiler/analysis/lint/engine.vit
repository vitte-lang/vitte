<<< ========================================================= >>>
<<< Vitte 2026 — Official Compiler Source                    >>>
<<< Component: Compiler / Analysis / Lint                    >>>
<<< File: compiler/analysis/lint/engine.vit                  >>>
<<< Module: vitte/compiler/analysis/lint/engine              >>>
<<< Purpose: lint rule execution engine and diagnostic flow   >>>
<<< ========================================================= >>>

space vitte/compiler/analysis/lint/engine

const LINT_ENGINE_INVALID_ID: u64 = 18446744073709551615
const LINT_ENGINE_VERSION: u32 = 2026
const LINT_ENGINE_MAX_RULES: u64 = 65536
const LINT_ENGINE_MAX_DIAGNOSTICS: u64 = 1048576
const LINT_ENGINE_MAX_FILES: u64 = 262144

pick LintLevel {
    Allow
    Info
    Warn
    Deny
    Forbid
}

pick LintRuleKind {
    Style
    Correctness
    Safety
    Performance
    Complexity
    Portability
    Security
    Deprecated
    Experimental
    Internal
}

pick LintTargetKind {
    Module
    Item
    Function
    Type
    Statement
    Expression
    Pattern
    Attribute
    Import
    File
}

pick LintErrorKind {
    None
    UnknownRule
    DisabledRule
    RuleLimitExceeded
    DiagnosticLimitExceeded
    FileLimitExceeded
    InvalidTarget
    InvalidConfiguration
    InternalFailure
}

form LintSpan {
    file: string
    line: u64
    column: u64
    length: u64
}

form LintRule {
    id: u64
    name: string
    kind: LintRuleKind
    level: LintLevel
    enabled: bool
    description: string
}

form LintTarget {
    id: u64
    kind: LintTargetKind
    name: string
    span: LintSpan
    valid: bool
}

form LintDiagnostic {
    id: u64
    rule: u64
    level: LintLevel
    message: string
    target: LintTarget
    span: LintSpan
}

form LintError {
    kind: LintErrorKind
    message: string
    span: LintSpan
}

form LintEngine {
    rules: [LintRule]
    targets: [LintTarget]
    diagnostics: [LintDiagnostic]
    errors: [LintError]
    valid: bool
}

proc span_empty() -> LintSpan {
    give LintSpan {
        file: "compiler/analysis/lint/engine.vit",
        line: 0,
        column: 0,
        length: 0
    }
}

proc rule_create(
    id: u64,
    name: string,
    kind: LintRuleKind,
    level: LintLevel,
    description: string
) -> LintRule {
    give LintRule {
        id: id,
        name: name,
        kind: kind,
        level: level,
        enabled: true,
        description: description
    }
}

proc target_invalid() -> LintTarget {
    give LintTarget {
        id: LINT_ENGINE_INVALID_ID,
        kind: LintTargetKind.File,
        name: "invalid",
        span: span_empty(),
        valid: false
    }
}

proc target_create(
    id: u64,
    kind: LintTargetKind,
    name: string,
    span: LintSpan
) -> LintTarget {
    give LintTarget {
        id: id,
        kind: kind,
        name: name,
        span: span,
        valid: true
    }
}

proc diagnostic_create(
    id: u64,
    rule: u64,
    level: LintLevel,
    message: string,
    target: LintTarget,
    span: LintSpan
) -> LintDiagnostic {
    give LintDiagnostic {
        id: id,
        rule: rule,
        level: level,
        message: message,
        target: target,
        span: span
    }
}

proc error_create(
    kind: LintErrorKind,
    message: string,
    span: LintSpan
) -> LintError {
    give LintError {
        kind: kind,
        message: message,
        span: span
    }
}

proc engine_empty() -> LintEngine {
    give LintEngine {
        rules: [],
        targets: [],
        diagnostics: [],
        errors: [],
        valid: true
    }
}

proc engine_default() -> LintEngine {
    let engine = engine_empty()

    let e1 = engine_add_rule(
        engine,
        rule_create(
            1,
            "unused_import",
            LintRuleKind.Correctness,
            LintLevel.Warn,
            "detect unused imports"
        )
    )

    let e2 = engine_add_rule(
        e1,
        rule_create(
            2,
            "unused_variable",
            LintRuleKind.Correctness,
            LintLevel.Warn,
            "detect unused local variables"
        )
    )

    let e3 = engine_add_rule(
        e2,
        rule_create(
            3,
            "dead_code",
            LintRuleKind.Correctness,
            LintLevel.Warn,
            "detect unreachable or unused code"
        )
    )

    let e4 = engine_add_rule(
        e3,
        rule_create(
            4,
            "unsafe_without_reason",
            LintRuleKind.Safety,
            LintLevel.Deny,
            "detect unsafe blocks without explanation"
        )
    )

    let e5 = engine_add_rule(
        e4,
        rule_create(
            5,
            "large_stack_allocation",
            LintRuleKind.Performance,
            LintLevel.Warn,
            "detect large stack allocations"
        )
    )

    give e5
}

proc engine_add_error(
    engine: LintEngine,
    error: LintError
) -> LintEngine {
    give LintEngine {
        rules: engine.rules,
        targets: engine.targets,
        diagnostics: engine.diagnostics,
        errors: engine.errors + [error],
        valid: false
    }
}

proc engine_add_rule(
    engine: LintEngine,
    rule: LintRule
) -> LintEngine {
    if vector_len(engine.rules) >= LINT_ENGINE_MAX_RULES {
        give engine_add_error(
            engine,
            error_create(
                LintErrorKind.RuleLimitExceeded,
                "too many lint rules",
                span_empty()
            )
        )
    }

    give LintEngine {
        rules: engine.rules + [rule],
        targets: engine.targets,
        diagnostics: engine.diagnostics,
        errors: engine.errors,
        valid: engine.valid
    }
}

proc engine_add_target(
    engine: LintEngine,
    target: LintTarget
) -> LintEngine {
    if vector_len(engine.targets) >= LINT_ENGINE_MAX_FILES {
        give engine_add_error(
            engine,
            error_create(
                LintErrorKind.FileLimitExceeded,
                "too many lint targets",
                target.span
            )
        )
    }

    give LintEngine {
        rules: engine.rules,
        targets: engine.targets + [target],
        diagnostics: engine.diagnostics,
        errors: engine.errors,
        valid: engine.valid
    }
}

proc engine_add_diagnostic(
    engine: LintEngine,
    diagnostic: LintDiagnostic
) -> LintEngine {
    if vector_len(engine.diagnostics) >= LINT_ENGINE_MAX_DIAGNOSTICS {
        give engine_add_error(
            engine,
            error_create(
                LintErrorKind.DiagnosticLimitExceeded,
                "too many lint diagnostics",
                diagnostic.span
            )
        )
    }

    give LintEngine {
        rules: engine.rules,
        targets: engine.targets,
        diagnostics: engine.diagnostics + [diagnostic],
        errors: engine.errors,
        valid: engine.valid
    }
}

proc find_rule(engine: LintEngine, id: u64) -> LintRule {
    let i: u64 = 0

    loop i < vector_len(engine.rules) {
        if engine.rules[i].id == id {
            give engine.rules[i]
        }

        set i = i + 1
    }

    give rule_create(
        LINT_ENGINE_INVALID_ID,
        "unknown",
        LintRuleKind.Internal,
        LintLevel.Allow,
        ""
    )
}

proc rule_enabled(engine: LintEngine, id: u64) -> bool {
    let rule = find_rule(engine, id)

    if rule.id == LINT_ENGINE_INVALID_ID {
        give false
    }

    if rule.enabled == false {
        give false
    }

    if rule.level == LintLevel.Allow {
        give false
    }

    give true
}

proc rule_with_level(rule: LintRule, level: LintLevel) -> LintRule {
    give LintRule {
        id: rule.id,
        name: rule.name,
        kind: rule.kind,
        level: level,
        enabled: rule.enabled,
        description: rule.description
    }
}

proc engine_set_rule_level(
    engine: LintEngine,
    rule_id: u64,
    level: LintLevel
) -> LintEngine {
    let next: [LintRule] = []
    let found = false

    let i: u64 = 0

    loop i < vector_len(engine.rules) {
        if engine.rules[i].id == rule_id {
            set next = next + [rule_with_level(engine.rules[i], level)]
            set found = true
        } else {
            set next = next + [engine.rules[i]]
        }

        set i = i + 1
    }

    if found == false {
        give engine_add_error(
            engine,
            error_create(
                LintErrorKind.UnknownRule,
                "unknown lint rule",
                span_empty()
            )
        )
    }

    give LintEngine {
        rules: next,
        targets: engine.targets,
        diagnostics: engine.diagnostics,
        errors: engine.errors,
        valid: engine.valid
    }
}

proc emit_lint(
    engine: LintEngine,
    diagnostic_id: u64,
    rule_id: u64,
    message: string,
    target: LintTarget
) -> LintEngine {
    let rule = find_rule(engine, rule_id)

    if rule.id == LINT_ENGINE_INVALID_ID {
        give engine_add_error(
            engine,
            error_create(
                LintErrorKind.UnknownRule,
                "unknown lint rule",
                target.span
            )
        )
    }

    if rule.enabled == false or rule.level == LintLevel.Allow {
        give engine
    }

    let diagnostic = diagnostic_create(
        diagnostic_id,
        rule.id,
        rule.level,
        message,
        target,
        target.span
    )

    give engine_add_diagnostic(engine, diagnostic)
}

proc lint_unused_import(
    engine: LintEngine,
    target: LintTarget,
    used: bool
) -> LintEngine {
    if used {
        give engine
    }

    give emit_lint(
        engine,
        vector_len(engine.diagnostics),
        1,
        "unused import",
        target
    )
}

proc lint_unused_variable(
    engine: LintEngine,
    target: LintTarget,
    used: bool
) -> LintEngine {
    if used {
        give engine
    }

    give emit_lint(
        engine,
        vector_len(engine.diagnostics),
        2,
        "unused variable",
        target
    )
}

proc lint_dead_code(
    engine: LintEngine,
    target: LintTarget,
    reachable: bool
) -> LintEngine {
    if reachable {
        give engine
    }

    give emit_lint(
        engine,
        vector_len(engine.diagnostics),
        3,
        "dead code",
        target
    )
}

proc lint_unsafe_reason(
    engine: LintEngine,
    target: LintTarget,
    has_reason: bool
) -> LintEngine {
    if has_reason {
        give engine
    }

    give emit_lint(
        engine,
        vector_len(engine.diagnostics),
        4,
        "unsafe block requires explicit reason",
        target
    )
}

proc lint_large_stack_allocation(
    engine: LintEngine,
    target: LintTarget,
    size_bytes: u64
) -> LintEngine {
    if size_bytes <= 4096 {
        give engine
    }

    give emit_lint(
        engine,
        vector_len(engine.diagnostics),
        5,
        "large stack allocation",
        target
    )
}

proc run_target_lints(
    engine: LintEngine,
    target: LintTarget
) -> LintEngine {
    if target.valid == false {
        give engine_add_error(
            engine,
            error_create(
                LintErrorKind.InvalidTarget,
                "invalid lint target",
                target.span
            )
        )
    }

    give engine
}

proc run_all_lints(engine: LintEngine) -> LintEngine {
    let current = engine
    let i: u64 = 0

    loop i < vector_len(current.targets) {
        set current = run_target_lints(current, current.targets[i])
        set i = i + 1
    }

    give current
}

proc lint_has_errors(engine: LintEngine) -> bool {
    let i: u64 = 0

    loop i < vector_len(engine.diagnostics) {
        let diagnostic = engine.diagnostics[i]

        if diagnostic.level == LintLevel.Deny {
            give true
        }

        if diagnostic.level == LintLevel.Forbid {
            give true
        }

        set i = i + 1
    }

    give false
}

proc lint_warning_count(engine: LintEngine) -> u64 {
    let count: u64 = 0
    let i: u64 = 0

    loop i < vector_len(engine.diagnostics) {
        if engine.diagnostics[i].level == LintLevel.Warn {
            set count = count + 1
        }

        set i = i + 1
    }

    give count
}

proc lint_error_count(engine: LintEngine) -> u64 {
    let count: u64 = 0
    let i: u64 = 0

    loop i < vector_len(engine.diagnostics) {
        if engine.diagnostics[i].level == LintLevel.Deny or engine.diagnostics[i].level == LintLevel.Forbid {
            set count = count + 1
        }

        set i = i + 1
    }

    give count
}

proc level_name(level: LintLevel) -> string {
    if level == LintLevel.Allow {
        give "allow"
    }

    if level == LintLevel.Info {
        give "info"
    }

    if level == LintLevel.Warn {
        give "warn"
    }

    if level == LintLevel.Deny {
        give "deny"
    }

    if level == LintLevel.Forbid {
        give "forbid"
    }

    give "unknown"
}

proc print_diagnostic(diagnostic: LintDiagnostic) {
    emit "lint"
    emit level_name(diagnostic.level)
    emit diagnostic.message
    emit diagnostic.span.file
    emit diagnostic.span.line
    emit diagnostic.span.column
}

proc print_report(engine: LintEngine) {
    emit "lint report"
    emit vector_len(engine.rules)
    emit vector_len(engine.targets)
    emit vector_len(engine.diagnostics)
    emit vector_len(engine.errors)

    let i: u64 = 0

    loop i < vector_len(engine.diagnostics) {
        print_diagnostic(engine.diagnostics[i])
        set i = i + 1
    }
}

proc vector_len[T](items: [T]) -> u64 {
    give 0
}