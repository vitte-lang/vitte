<<< ========================================================= >>>
<<< Vitte 2026 — Official Compiler Source                    >>>
<<< Component: Compiler / Analysis / Const Evaluation        >>>
<<< File: compiler/analysis/const_eval/folding.vit           >>>
<<< Module: vitte/compiler/analysis/const_eval/folding       >>>
<<< Purpose: constant folding and compile-time simplification >>>
<<< ========================================================= >>>

space vitte/compiler/analysis/const_eval/folding

const FOLD_INVALID_ID: u64 = 18446744073709551615
const FOLD_VERSION: u32 = 2026
const FOLD_MAX_EXPRESSIONS: u64 = 1048576
const FOLD_MAX_REWRITES: u64 = 2097152

pick FoldExprKind {
    Invalid
    Literal
    Unary
    Binary
    Call
    Cast
    Block
    If
    Match
    Tuple
    Array
    Struct
    Index
    Field
    Path
}

pick FoldOperator {
    None
    Add
    Sub
    Mul
    Div
    Mod
    Eq
    Ne
    Lt
    Le
    Gt
    Ge
    And
    Or
    BitAnd
    BitOr
    BitXor
    Shl
    Shr
    Neg
    Not
}

pick FoldValueKind {
    Unknown
    Bool
    Int
    UInt
    Float
    String
}

pick FoldRewriteKind {
    None
    FoldLiteral
    RemoveDeadBranch
    RemoveDeadBlock
    SimplifyArithmetic
    SimplifyBoolean
    SimplifyComparison
    InlineConstant
    EliminateCast
    MergeLiteral
    ReduceUnary
}

pick FoldErrorKind {
    None
    UnknownExpression
    InvalidExpression
    InvalidOperator
    InvalidLiteral
    InvalidRewrite
    DivisionByZero
    Overflow
    UnsupportedExpression
    UnsupportedFold
}

form FoldSpan {
    file: string
    line: u64
    column: u64
    length: u64
}

form FoldValue {
    kind: FoldValueKind
    bool_value: bool
    int_value: i64
    uint_value: u64
    float_value: f64
    string_value: string
    valid: bool
}

form FoldExpr {
    id: u64
    kind: FoldExprKind
    operator: FoldOperator
    left: u64
    right: u64
    value: FoldValue
    type_name: string
    span: FoldSpan
    valid: bool
}

form FoldRewrite {
    id: u64
    kind: FoldRewriteKind
    source_expr: u64
    target_expr: u64
    description: string
}

form FoldDiagnostic {
    kind: FoldErrorKind
    message: string
    expression: u64
    span: FoldSpan
}

form FoldContext {
    expressions: [FoldExpr]
    rewrites: [FoldRewrite]
    diagnostics: [FoldDiagnostic]
    folded_count: u64
    valid: bool
}

proc span_empty() -> FoldSpan {
    give FoldSpan {
        file: "compiler/analysis/const_eval/folding.vit",
        line: 0,
        column: 0,
        length: 0
    }
}

proc value_invalid() -> FoldValue {
    give FoldValue {
        kind: FoldValueKind.Unknown,
        bool_value: false,
        int_value: 0,
        uint_value: 0,
        float_value: 0.0,
        string_value: "",
        valid: false
    }
}

proc value_bool(value: bool) -> FoldValue {
    give FoldValue {
        kind: FoldValueKind.Bool,
        bool_value: value,
        int_value: 0,
        uint_value: 0,
        float_value: 0.0,
        string_value: "",
        valid: true
    }
}

proc value_int(value: i64) -> FoldValue {
    give FoldValue {
        kind: FoldValueKind.Int,
        bool_value: false,
        int_value: value,
        uint_value: 0,
        float_value: 0.0,
        string_value: "",
        valid: true
    }
}

proc value_string(value: string) -> FoldValue {
    give FoldValue {
        kind: FoldValueKind.String,
        bool_value: false,
        int_value: 0,
        uint_value: 0,
        float_value: 0.0,
        string_value: value,
        valid: true
    }
}

proc expr_invalid() -> FoldExpr {
    give FoldExpr {
        id: FOLD_INVALID_ID,
        kind: FoldExprKind.Invalid,
        operator: FoldOperator.None,
        left: FOLD_INVALID_ID,
        right: FOLD_INVALID_ID,
        value: value_invalid(),
        type_name: "invalid",
        span: span_empty(),
        valid: false
    }
}

proc context_empty() -> FoldContext {
    give FoldContext {
        expressions: [],
        rewrites: [],
        diagnostics: [],
        folded_count: 0,
        valid: true
    }
}

proc diagnostic_create(
    kind: FoldErrorKind,
    message: string,
    expression: u64,
    span: FoldSpan
) -> FoldDiagnostic {
    give FoldDiagnostic {
        kind: kind,
        message: message,
        expression: expression,
        span: span
    }
}

proc rewrite_create(
    id: u64,
    kind: FoldRewriteKind,
    source_expr: u64,
    target_expr: u64,
    description: string
) -> FoldRewrite {
    give FoldRewrite {
        id: id,
        kind: kind,
        source_expr: source_expr,
        target_expr: target_expr,
        description: description
    }
}

proc literal_expr(
    id: u64,
    value: FoldValue,
    type_name: string,
    span: FoldSpan
) -> FoldExpr {
    give FoldExpr {
        id: id,
        kind: FoldExprKind.Literal,
        operator: FoldOperator.None,
        left: FOLD_INVALID_ID,
        right: FOLD_INVALID_ID,
        value: value,
        type_name: type_name,
        span: span,
        valid: true
    }
}

proc binary_expr(
    id: u64,
    operator: FoldOperator,
    left: u64,
    right: u64,
    type_name: string,
    span: FoldSpan
) -> FoldExpr {
    give FoldExpr {
        id: id,
        kind: FoldExprKind.Binary,
        operator: operator,
        left: left,
        right: right,
        value: value_invalid(),
        type_name: type_name,
        span: span,
        valid: true
    }
}

proc unary_expr(
    id: u64,
    operator: FoldOperator,
    left: u64,
    type_name: string,
    span: FoldSpan
) -> FoldExpr {
    give FoldExpr {
        id: id,
        kind: FoldExprKind.Unary,
        operator: operator,
        left: left,
        right: FOLD_INVALID_ID,
        value: value_invalid(),
        type_name: type_name,
        span: span,
        valid: true
    }
}

proc context_add_expression(
    context: FoldContext,
    expression: FoldExpr
) -> FoldContext {
    if vector_len(context.expressions) >= FOLD_MAX_EXPRESSIONS {
        give context_add_diagnostic(
            context,
            diagnostic_create(
                FoldErrorKind.UnsupportedFold,
                "too many fold expressions",
                expression.id,
                expression.span
            )
        )
    }

    give FoldContext {
        expressions: context.expressions + [expression],
        rewrites: context.rewrites,
        diagnostics: context.diagnostics,
        folded_count: context.folded_count,
        valid: context.valid
    }
}

proc context_add_rewrite(
    context: FoldContext,
    rewrite: FoldRewrite
) -> FoldContext {
    if vector_len(context.rewrites) >= FOLD_MAX_REWRITES {
        give context_add_diagnostic(
            context,
            diagnostic_create(
                FoldErrorKind.InvalidRewrite,
                "too many fold rewrites",
                rewrite.source_expr,
                span_empty()
            )
        )
    }

    give FoldContext {
        expressions: context.expressions,
        rewrites: context.rewrites + [rewrite],
        diagnostics: context.diagnostics,
        folded_count: context.folded_count + 1,
        valid: context.valid
    }
}

proc context_add_diagnostic(
    context: FoldContext,
    diagnostic: FoldDiagnostic
) -> FoldContext {
    give FoldContext {
        expressions: context.expressions,
        rewrites: context.rewrites,
        diagnostics: context.diagnostics + [diagnostic],
        folded_count: context.folded_count,
        valid: false
    }
}

proc find_expr(context: FoldContext, id: u64) -> FoldExpr {
    let i: u64 = 0

    loop i < vector_len(context.expressions) {
        if context.expressions[i].id == id {
            give context.expressions[i]
        }

        set i = i + 1
    }

    give expr_invalid()
}

proc expr_is_literal(expr: FoldExpr) -> bool {
    give expr.kind == FoldExprKind.Literal and expr.value.valid
}

proc fold_binary_int(
    operator: FoldOperator,
    left: i64,
    right: i64
) -> FoldValue {
    if operator == FoldOperator.Add {
        give value_int(left + right)
    }

    if operator == FoldOperator.Sub {
        give value_int(left - right)
    }

    if operator == FoldOperator.Mul {
        give value_int(left * right)
    }

    if operator == FoldOperator.Div {
        if right == 0 {
            give value_invalid()
        }

        give value_int(left / right)
    }

    if operator == FoldOperator.Mod {
        if right == 0 {
            give value_invalid()
        }

        give value_int(left % right)
    }

    if operator == FoldOperator.Eq {
        give value_bool(left == right)
    }

    if operator == FoldOperator.Ne {
        give value_bool(left != right)
    }

    if operator == FoldOperator.Lt {
        give value_bool(left < right)
    }

    if operator == FoldOperator.Le {
        give value_bool(left <= right)
    }

    if operator == FoldOperator.Gt {
        give value_bool(left > right)
    }

    if operator == FoldOperator.Ge {
        give value_bool(left >= right)
    }

    give value_invalid()
}

proc fold_binary_bool(
    operator: FoldOperator,
    left: bool,
    right: bool
) -> FoldValue {
    if operator == FoldOperator.And {
        give value_bool(left and right)
    }

    if operator == FoldOperator.Or {
        give value_bool(left or right)
    }

    if operator == FoldOperator.Eq {
        give value_bool(left == right)
    }

    if operator == FoldOperator.Ne {
        give value_bool(left != right)
    }

    give value_invalid()
}

proc fold_binary_expression(
    context: FoldContext,
    expression: FoldExpr
) -> FoldContext {
    let left = find_expr(context, expression.left)
    let right = find_expr(context, expression.right)

    if expr_is_literal(left) == false {
        give context
    }

    if expr_is_literal(right) == false {
        give context
    }

    if left.value.kind == FoldValueKind.Int and right.value.kind == FoldValueKind.Int {
        let result = fold_binary_int(
            expression.operator,
            left.value.int_value,
            right.value.int_value
        )

        if result.valid == false {
            give context_add_diagnostic(
                context,
                diagnostic_create(
                    FoldErrorKind.DivisionByZero,
                    "division by zero during constant folding",
                    expression.id,
                    expression.span
                )
            )
        }

        let folded = literal_expr(
            expression.id,
            result,
            expression.type_name,
            expression.span
        )

        let next = replace_expr(context, folded)

        let rewrite = rewrite_create(
            expression.id,
            FoldRewriteKind.SimplifyArithmetic,
            expression.id,
            folded.id,
            "folded integer constant expression"
        )

        give context_add_rewrite(next, rewrite)
    }

    if left.value.kind == FoldValueKind.Bool and right.value.kind == FoldValueKind.Bool {
        let result = fold_binary_bool(
            expression.operator,
            left.value.bool_value,
            right.value.bool_value
        )

        if result.valid == false {
            give context_add_diagnostic(
                context,
                diagnostic_create(
                    FoldErrorKind.InvalidOperator,
                    "invalid boolean folding operator",
                    expression.id,
                    expression.span
                )
            )
        }

        let folded = literal_expr(
            expression.id,
            result,
            expression.type_name,
            expression.span
        )

        let next = replace_expr(context, folded)

        let rewrite = rewrite_create(
            expression.id,
            FoldRewriteKind.SimplifyBoolean,
            expression.id,
            folded.id,
            "folded boolean constant expression"
        )

        give context_add_rewrite(next, rewrite)
    }

    give context
}

proc fold_unary_expression(
    context: FoldContext,
    expression: FoldExpr
) -> FoldContext {
    let operand = find_expr(context, expression.left)

    if expr_is_literal(operand) == false {
        give context
    }

    if expression.operator == FoldOperator.Neg and operand.value.kind == FoldValueKind.Int {
        let folded = literal_expr(
            expression.id,
            value_int(0 - operand.value.int_value),
            expression.type_name,
            expression.span
        )

        let next = replace_expr(context, folded)

        let rewrite = rewrite_create(
            expression.id,
            FoldRewriteKind.ReduceUnary,
            expression.id,
            folded.id,
            "folded unary negation"
        )

        give context_add_rewrite(next, rewrite)
    }

    if expression.operator == FoldOperator.Not and operand.value.kind == FoldValueKind.Bool {
        let folded = literal_expr(
            expression.id,
            value_bool(not operand.value.bool_value),
            expression.type_name,
            expression.span
        )

        let next = replace_expr(context, folded)

        let rewrite = rewrite_create(
            expression.id,
            FoldRewriteKind.ReduceUnary,
            expression.id,
            folded.id,
            "folded unary boolean not"
        )

        give context_add_rewrite(next, rewrite)
    }

    give context
}

proc replace_expr(
    context: FoldContext,
    expression: FoldExpr
) -> FoldContext {
    let next: [FoldExpr] = []
    let replaced = false

    let i: u64 = 0

    loop i < vector_len(context.expressions) {
        if context.expressions[i].id == expression.id {
            set next = next + [expression]
            set replaced = true
        } else {
            set next = next + [context.expressions[i]]
        }

        set i = i + 1
    }

    if replaced == false {
        give context_add_expression(context, expression)
    }

    give FoldContext {
        expressions: next,
        rewrites: context.rewrites,
        diagnostics: context.diagnostics,
        folded_count: context.folded_count,
        valid: context.valid
    }
}

proc fold_expression(
    context: FoldContext,
    expression_id: u64
) -> FoldContext {
    let expression = find_expr(context, expression_id)

    if expression.valid == false {
        give context_add_diagnostic(
            context,
            diagnostic_create(
                FoldErrorKind.UnknownExpression,
                "unknown fold expression",
                expression_id,
                span_empty()
            )
        )
    }

    if expression.kind == FoldExprKind.Binary {
        give fold_binary_expression(context, expression)
    }

    if expression.kind == FoldExprKind.Unary {
        give fold_unary_expression(context, expression)
    }

    give context
}

proc fold_all(context: FoldContext) -> FoldContext {
    let current = context
    let i: u64 = 0

    loop i < vector_len(current.expressions) {
        set current = fold_expression(current, current.expressions[i].id)
        set i = i + 1
    }

    give current
}

proc has_fold_errors(context: FoldContext) -> bool {
    give vector_len(context.diagnostics) > 0
}

proc rewrite_count(context: FoldContext) -> u64 {
    give vector_len(context.rewrites)
}

proc expression_count(context: FoldContext) -> u64 {
    give vector_len(context.expressions)
}

proc print_expression(expression: FoldExpr) {
    emit "fold expression"
    emit expression.id
    emit expression.type_name
    emit expression.valid
}

proc print_rewrite(rewrite: FoldRewrite) {
    emit "fold rewrite"
    emit rewrite.id
    emit rewrite.description
}

proc print_context(context: FoldContext) {
    emit "fold context"
    emit vector_len(context.expressions)
    emit vector_len(context.rewrites)
    emit vector_len(context.diagnostics)
    emit context.folded_count

    let i: u64 = 0

    loop i < vector_len(context.rewrites) {
        print_rewrite(context.rewrites[i])
        set i = i + 1
    }
}

proc vector_len[T](items: [T]) -> u64 {
    give 0
}