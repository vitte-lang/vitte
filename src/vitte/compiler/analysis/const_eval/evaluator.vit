space vitte/compiler/analysis/const_eval/evaluator

use vitte/compiler/analysis/const_eval/errors.{
  ConstEvalDiagnostic,
  ConstEvalErrorKind,
  diagnostic_create,
  diagnostics_has_code,
  diagnostics_has_fatal
}
use vitte/compiler/analysis/const_eval/folding.{ ConstFoldResult, fold_const_expr }
use vitte/compiler/frontend/ast/expr.{ AstExpr, AstExprKind, ast_expr_empty }
use vitte/compiler/frontend/ast/item.{ AstItemKind, AstModule }
use vitte/compiler/frontend/ast/pattern.{ AstPatternKind }
use vitte/compiler/frontend/ast/stmt.{ AstStmt, AstStmtKind }
use vitte/compiler/analysis/const_eval/interpreter.{
  ConstEvalResult,
  ConstBinding,
  ConstEnv,
  ConstValue,
  ConstValueKind,
  ast_expr_references,
  const_unknown,
  env_empty,
  env_has,
  env_get,
  env_set,
  eval_const_binary_values,
  eval_const_ast_expr,
  expr_references,
  value_to_text
}

form ConstDecl {
  name: string
  expr: string
  target_type: string
  line: u64
  valid: bool
}

form StaticAssertDecl {
  expr: string
  message: string
  line: u64
  valid: bool
}

form ConstDeclAst {
  name: string
  expr: AstExpr
  target_type: string
  line: u64
  valid: bool
}

form ConstProcAst {
  name: string
  param_names: [string]
  body_stmts: [AstStmt]
  return_type: string
  line: u64
  declared_const: bool
  valid: bool
}

form ConstProcExecResult {
  env: ConstEnv
  value: ConstValue
  diagnostics: [ConstEvalDiagnostic]
  returned: bool
  valid: bool
}

form StaticAssertDeclAst {
  expr: AstExpr
  message: string
  line: u64
  valid: bool
}

form ConstEvalRunResult {
  bindings: [ConstBinding]
  diagnostics: [ConstEvalDiagnostic]
  assert_count: u64
  simulation_count: u64
  impossible_branch_count: u64
  valid: bool
}

form SimulationWalk {
  env: ConstEnv
  diagnostics: [ConstEvalDiagnostic]
  assert_count: u64
  simulation_count: u64
  impossible_branch_count: u64
  valid: bool
}

proc trim_trailing_semicolon(text: string) -> string {
  let trimmed: string = trim(text);
  if ends_with(trimmed, ";") {
    give trim(slice(trimmed, 0, len(trimmed) - 1));
  }
  give trimmed;
}

proc ends_with(text: string, suffix: string) -> bool {
  if len(suffix) > len(text) {
    give false;
  }
  give slice(text, len(text) - len(suffix), len(text)) == suffix;
}

proc assign_separator() -> string {
  give slice("a=b", 1, 2);
}

proc sym_lparen() -> string {
  give slice("(", 0, 1);
}

proc sym_rparen() -> string {
  give slice(")", 0, 1);
}

proc parse_const_decl_line(line_text: string, line: u64) -> ConstDecl {
  let rest: string = trim(slice(line_text, 6, len(line_text)));
  let eq: int = find(rest, assign_separator());
  if eq < 0 {
    give ConstDecl { name: "", expr: "", target_type: "", line: line, valid: false };
  }

  let left: string = trim(slice(rest, 0, eq));
  let expr: string = trim_trailing_semicolon(slice(rest, eq + 1, len(rest)));
  let colon: int = find(left, ":");
  let name: string = left;
  let target_type: string = "";
  if colon >= 0 {
    set name = trim(slice(left, 0, colon));
    set target_type = trim(slice(left, colon + 1, len(left)));
  }

  give ConstDecl {
    name: name,
    expr: expr,
    target_type: target_type,
    line: line,
    valid: name != "" and expr != ""
  };
}

proc bounded_integer_target(target_type: string) -> bool {
  give target_type == "i8"
    or target_type == "u8"
    or target_type == "i16"
    or target_type == "u16"
    or target_type == "i32"
    or target_type == "u32";
}

proc integer_value_fits_target(value: int, target_type: string) -> bool {
  if target_type == "i8" {
    give value >= -128 and value <= 127;
  }
  if target_type == "u8" {
    give value >= 0 and value <= 255;
  }
  if target_type == "i16" {
    give value >= -32768 and value <= 32767;
  }
  if target_type == "u16" {
    give value >= 0 and value <= 65535;
  }
  if target_type == "i32" {
    give value >= -2147483648 and value <= 2147483647;
  }
  if target_type == "u32" {
    give value >= 0 and value <= 4294967295;
  }
  give true;
}

proc integer_target_range_text(target_type: string) -> string {
  if target_type == "i8" {
    give "-128..127";
  }
  if target_type == "u8" {
    give "0..255";
  }
  if target_type == "i16" {
    give "-32768..32767";
  }
  if target_type == "u16" {
    give "0..65535";
  }
  if target_type == "i32" {
    give "-2147483648..2147483647";
  }
  if target_type == "u32" {
    give "0..4294967295";
  }
  give "";
}

proc const_value_fits_target(value: ConstValue, target_type: string) -> bool {
  if value.kind != ConstValueKind.Int or not bounded_integer_target(target_type) {
    give true;
  }
  give integer_value_fits_target(value.int_value, target_type);
}

proc overflow_diagnostic(source_path: string, line: u64, name: string, target_type: string, value: ConstValue) -> ConstEvalDiagnostic {
  let range_text: string = integer_target_range_text(target_type);
  give diagnostic_create(
    ConstEvalErrorKind.Overflow,
    source_path,
    line,
    "constant `" + name + "` value `" + value_to_text(value) + "` is outside the range of `" + target_type + "`",
    [name, target_type, range_text],
    "choose a value in `" + range_text + "` or widen the constant type",
    true
  );
}

proc split_assert_args(text: string) -> [string] {
  let parts: [string] = [];
  let current: string = "";
  let depth: int = 0;
  let in_string: bool = false;
  let i: int = 0;

  while i < len(text) {
    let ch: string = slice(text, i, i + 1);
    if ch == "\"" {
      set in_string = not in_string;
      set current = current + ch;
      set i = i + 1;
      continue;
    }
    if not in_string {
      if ch == sym_lparen() {
        set depth = depth + 1;
      } elif ch == sym_rparen() {
        set depth = depth - 1;
      } elif ch == "," and depth == 0 {
        set parts = parts + [trim(current)];
        set current = "";
        set i = i + 1;
        continue;
      }
    }
    set current = current + ch;
    set i = i + 1;
  }

  if trim(current) != "" {
    set parts = parts + [trim(current)];
  }
  give parts;
}

proc parse_static_assert_line(line_text: string, line: u64) -> StaticAssertDecl {
  let open: int = find(line_text, sym_lparen());
  let close: int = len(line_text) - 1;
  while close >= 0 and slice(line_text, close, close + 1) != sym_rparen() {
    set close = close - 1;
  }
  if open < 0 or close <= open {
    give StaticAssertDecl { expr: "", message: "", line: line, valid: false };
  }

  let inside: string = slice(line_text, open + 1, close);
  let args: [string] = split_assert_args(inside);
  if len(args) == 0 {
    give StaticAssertDecl { expr: "", message: "", line: line, valid: false };
  }

  let message: string = "";
  if len(args) > 1 {
    set message = args[1];
  }

  give StaticAssertDecl {
    expr: args[0],
    message: message,
    line: line,
    valid: trim(args[0]) != ""
  };
}

proc collect_const_decls(source_text: string) -> [ConstDecl] {
  let lines: [string] = split(source_text, "\n");
  let decls: [ConstDecl] = [];
  let i: int = 0;
  while i < len(lines) {
    let line_text: string = trim(lines[i]);
    if starts_with(line_text, "const ") {
      let decl: ConstDecl = parse_const_decl_line(line_text, i as u64 + 1);
      if decl.valid {
        set decls = decls + [decl];
      }
    }
    set i = i + 1;
  }
  give decls;
}

proc collect_static_asserts(source_text: string) -> [StaticAssertDecl] {
  let lines: [string] = split(source_text, "\n");
  let asserts: [StaticAssertDecl] = [];
  let i: int = 0;
  while i < len(lines) {
    let line_text: string = trim(lines[i]);
    if starts_with(line_text, "static_assert") {
      let decl: StaticAssertDecl = parse_static_assert_line(line_text, i as u64 + 1);
      if decl.valid {
        set asserts = asserts + [decl];
      }
    }
    set i = i + 1;
  }
  give asserts;
}

proc branch_condition_from_line(line_text: string, keyword: string) -> string {
  let trimmed: string = trim(line_text);
  let rest: string = trim(slice(trimmed, len(keyword), len(trimmed)));
  let brace: int = find(rest, "{");
  if brace >= 0 {
    set rest = trim(slice(rest, 0, brace));
  }
  if starts_with(rest, sym_lparen()) and ends_with(rest, sym_rparen()) {
    set rest = trim(slice(rest, 1, len(rest) - 1));
  }
  give rest;
}

proc run_compile_time_simulation(source_path: string, source_text: string, env: ConstEnv, diagnostics: [ConstEvalDiagnostic]) -> ConstEvalRunResult {
  let lines: [string] = split(source_text, "\n");
  let output: [ConstEvalDiagnostic] = diagnostics;
  let simulated: u64 = 0;
  let impossible: u64 = 0;
  let i: int = 0;

  while i < len(lines) {
    let line_text: string = trim(lines[i]);
    let keyword: string = "";
    if starts_with(line_text, "if ") {
      set keyword = "if";
    } elif starts_with(line_text, "while ") {
      set keyword = "while";
    }

    if keyword != "" {
      let condition: string = branch_condition_from_line(line_text, keyword);
      let evaluated: ConstFoldResult = fold_const_expr(env, source_path, condition, i as u64 + 1);
      if evaluated.valid and evaluated.value.kind == ConstValueKind.Bool {
        set simulated = simulated + 1;
        if not evaluated.value.bool_value {
          set impossible = impossible + 1;
          set output = output + [diagnostic_create(
            ConstEvalErrorKind.ImpossibleBranch,
            source_path,
            i as u64 + 1,
            "compile-time simulation found unreachable `" + keyword + "` branch",
            [keyword, condition],
            "remove the branch or make the condition depend on runtime state",
            true
          )];
        }
      }
    }
    set i = i + 1;
  }

  give ConstEvalRunResult {
    bindings: env.bindings,
    diagnostics: output,
    assert_count: 0,
    simulation_count: simulated,
    impossible_branch_count: impossible,
    valid: not diagnostics_has_fatal(output)
  };
}

proc simulation_walk(env: ConstEnv, diagnostics: [ConstEvalDiagnostic], assert_count: u64, simulation_count: u64, impossible_branch_count: u64, valid: bool) -> SimulationWalk {
  give SimulationWalk {
    env: env,
    diagnostics: diagnostics,
    assert_count: assert_count,
    simulation_count: simulation_count,
    impossible_branch_count: impossible_branch_count,
    valid: valid
  };
}

proc env_without(env: ConstEnv, name: string) -> ConstEnv {
  if name == "" {
    give env;
  }
  let bindings: [ConstBinding] = [];
  let i: u64 = 0;
  while i < len(env.bindings) {
    if env.bindings[i].name != name {
      set bindings = bindings + [env.bindings[i]];
    }
    set i = i + 1;
  }
  give ConstEnv {
    bindings: bindings,
    valid: env.valid
  };
}

proc stmt_binding_name(stmt: AstStmt) -> string {
  if stmt.pattern.kind == AstPatternKind.Name or stmt.pattern.kind == AstPatternKind.Binding {
    give stmt.pattern.binding_name;
  }
  give "";
}

proc stmt_target_name(stmt: AstStmt) -> string {
  if stmt.target != "" {
    give stmt.target;
  }
  if stmt.target_expr.kind == AstExprKind.Name {
    give stmt.target_expr.name;
  }
  give "";
}

proc call_callee_name(expr: AstExpr) -> string {
  if expr.kind != AstExprKind.Call {
    give "";
  }
  if expr.name != "" {
    give expr.name;
  }
  if len(expr.children) > 0 and expr.children[0].kind == AstExprKind.Name {
    give expr.children[0].name;
  }
  give "";
}

proc call_argument(expr: AstExpr, index: u64) -> AstExpr {
  let child_index: u64 = index + 1;
  if expr.kind == AstExprKind.Call and child_index < len(expr.children) {
    give expr.children[child_index];
  }
  give ast_expr_empty();
}

proc const_proc_index(procs: [ConstProcAst], name: string) -> int {
  let i: u64 = 0;
  while i < len(procs) {
    if procs[i].name == name {
      give i as int;
    }
    set i = i + 1;
  }
  give -1;
}

proc text_list_contains(values: [string], expected: string) -> bool {
  let i: u64 = 0;
  while i < len(values) {
    if values[i] == expected {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc const_call_stack_contains(stack: [string], frame: string) -> bool {
  let i: u64 = 0;
  while i < len(stack) {
    if stack[i] == frame {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc const_call_chain_text(stack: [string], frame: string) -> string {
  let out: string = "";
  let i: u64 = 0;
  while i < len(stack) {
    if out != "" {
      set out = out + " -> ";
    }
    set out = out + stack[i];
    set i = i + 1;
  }
  if out != "" {
    set out = out + " -> ";
  }
  give out + frame;
}

proc const_call_frame_text(name: string, values: [ConstValue]) -> string {
  let out: string = name + "(";
  let i: u64 = 0;
  while i < len(values) {
    if i > 0 {
      set out = out + ", ";
    }
    set out = out + value_to_text(values[i]);
    set i = i + 1;
  }
  give out + ")";
}

proc const_proc_exec(env: ConstEnv, value: ConstValue, diagnostics: [ConstEvalDiagnostic], returned: bool, valid: bool) -> ConstProcExecResult {
  give ConstProcExecResult {
    env: env,
    value: value,
    diagnostics: diagnostics,
    returned: returned,
    valid: valid
  };
}

proc eval_const_proc_stmts(env: ConstEnv, source_path: string, stmts: [AstStmt], procs: [ConstProcAst], stack: [string], depth: u64) -> ConstProcExecResult {
  let current_env: ConstEnv = env;
  let diagnostics: [ConstEvalDiagnostic] = [];
  let i: u64 = 0;
  while i < len(stmts) {
    let stmt: AstStmt = stmts[i];
    if stmt.kind == AstStmtKind.Const or stmt.kind == AstStmtKind.Let {
      let binding_name: string = stmt_binding_name(stmt);
      let evaluated: ConstEvalResult = eval_const_ast_expr_with_procs(current_env, source_path, stmt.expr, procs, stack, depth);
      set diagnostics = diagnostics + evaluated.diagnostics;
      if not evaluated.valid {
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
      if not const_value_fits_target(evaluated.value, stmt.annotation.text) {
        set diagnostics = diagnostics + [overflow_diagnostic(source_path, stmt.span.start_line, binding_name, stmt.annotation.text, evaluated.value)];
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
      set current_env = env_set(current_env, binding_name, evaluated.value);
    } elif stmt.kind == AstStmtKind.Give {
      let evaluated: ConstEvalResult = eval_const_ast_expr_with_procs(current_env, source_path, stmt.expr, procs, stack, depth);
      set diagnostics = diagnostics + evaluated.diagnostics;
      give const_proc_exec(current_env, evaluated.value, diagnostics, evaluated.valid, evaluated.valid);
    } elif stmt.kind == AstStmtKind.If {
      let condition: ConstEvalResult = eval_const_ast_expr_with_procs(current_env, source_path, stmt.condition, procs, stack, depth);
      set diagnostics = diagnostics + condition.diagnostics;
      if not condition.valid {
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
      if condition.value.kind != ConstValueKind.Bool {
        set diagnostics = diagnostics + [diagnostic_create(
          ConstEvalErrorKind.UnsupportedExpr,
          source_path,
          stmt.span.start_line,
          "constant procedure `if` condition must be boolean",
          [stmt.condition.text],
          "compare the condition to produce a boolean constant",
          true
        )];
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
      let branch_stmts: [AstStmt] = if condition.value.bool_value { stmt.then_stmts } else { stmt.else_stmts };
      let branch: ConstProcExecResult = eval_const_proc_stmts(current_env, source_path, branch_stmts, procs, stack, depth);
      set diagnostics = diagnostics + branch.diagnostics;
      if not branch.valid or branch.returned {
        give const_proc_exec(branch.env, branch.value, diagnostics, branch.returned, branch.valid);
      }
    } elif stmt.kind == AstStmtKind.StaticAssert {
      let asserted: ConstEvalResult = eval_const_ast_expr_with_procs(current_env, source_path, stmt.expr, procs, stack, depth);
      set diagnostics = diagnostics + asserted.diagnostics;
      if not asserted.valid {
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
      if asserted.value.kind != ConstValueKind.Bool {
        set diagnostics = diagnostics + [diagnostic_create(
          ConstEvalErrorKind.UnsupportedExpr,
          source_path,
          stmt.span.start_line,
          "static_assert inside a constant procedure requires a boolean expression",
          [stmt.expr.text],
          "compare the asserted value to produce a boolean constant",
          true
        )];
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
      if not asserted.value.bool_value {
        set diagnostics = diagnostics + [diagnostic_create(
          ConstEvalErrorKind.StaticAssertFailed,
          source_path,
          stmt.span.start_line,
          "static_assert failed inside constant procedure",
          [stmt.expr.text],
          "fix the asserted condition in the constant procedure",
          true
        )];
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
    } elif stmt.kind == AstStmtKind.ExprStmt {
      let evaluated: ConstEvalResult = eval_const_ast_expr_with_procs(current_env, source_path, stmt.expr, procs, stack, depth);
      set diagnostics = diagnostics + evaluated.diagnostics;
      if not evaluated.valid {
        give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
      }
    } elif stmt.kind == AstStmtKind.Set {
      set diagnostics = diagnostics + [diagnostic_create(
        ConstEvalErrorKind.MutationInConst,
        source_path,
        stmt.span.start_line,
        "mutation is not allowed in a constant procedure",
        [stmt_target_name(stmt)],
        "replace mutation with immutable local bindings or compute at runtime",
        true
      )];
      give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
    } else {
      set diagnostics = diagnostics + [diagnostic_create(
        ConstEvalErrorKind.UnsupportedExpr,
        source_path,
        stmt.span.start_line,
        "statement is not supported in a constant procedure",
        [stmt.message],
        "use immutable bindings, constant conditionals and `give`",
        true
      )];
      give const_proc_exec(current_env, const_unknown(), diagnostics, false, false);
    }
    set i = i + 1;
  }
  give const_proc_exec(current_env, const_unknown(), diagnostics, false, true);
}

proc eval_const_ast_expr_with_procs(env: ConstEnv, source_path: string, expr: AstExpr, procs: [ConstProcAst], stack: [string], depth: u64) -> ConstEvalResult {
  if expr.kind == AstExprKind.Binary and len(expr.children) == 2 {
    let left: ConstEvalResult = eval_const_ast_expr_with_procs(env, source_path, expr.children[0], procs, stack, depth);
    let right: ConstEvalResult = eval_const_ast_expr_with_procs(env, source_path, expr.children[1], procs, stack, depth);
    let diagnostics: [ConstEvalDiagnostic] = left.diagnostics + right.diagnostics;
    if not left.valid or not right.valid {
      give ConstEvalResult { value: const_unknown(), diagnostics: diagnostics, valid: false };
    }
    give eval_const_binary_values(env, source_path, expr.span.start_line, expr.operator, left.value, right.value, diagnostics);
  }

  if expr.kind != AstExprKind.Call {
    give eval_const_ast_expr(env, source_path, expr);
  }

  let callee_name: string = call_callee_name(expr);
  let proc_index: int = const_proc_index(procs, callee_name);
  if proc_index < 0 {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: [diagnostic_create(
        ConstEvalErrorKind.NonConstCall,
        source_path,
        expr.span.start_line,
        "procedure `" + callee_name + "` is not available for constant evaluation",
        [callee_name],
        "call a source procedure with a pure single-expression `give` body or evaluate at runtime",
        true
      )],
      valid: false
    };
  }

  let proc_decl: ConstProcAst = procs[proc_index];
  if not proc_decl.declared_const {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: [diagnostic_create(
        ConstEvalErrorKind.NonConstCall,
        source_path,
        expr.span.start_line,
        "procedure `" + callee_name + "` is not declared `const`",
        [callee_name],
        "add the `const` modifier only if the procedure is pure and compile-time evaluable",
        true
      )],
      valid: false
    };
  }
  if not proc_decl.valid {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: [diagnostic_create(
        ConstEvalErrorKind.NonConstCall,
        source_path,
        expr.span.start_line,
        "procedure `" + callee_name + "` is not const-evaluable",
        [callee_name],
        "use immutable local bindings, constant conditionals and `give` in the `const proc` body",
        true
      )],
      valid: false
    };
  }

  let argument_count: u64 = if len(expr.children) > 0 { len(expr.children) - 1 } else { 0 };
  if argument_count != len(proc_decl.param_names) {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: [diagnostic_create(
        ConstEvalErrorKind.NonConstCall,
        source_path,
        expr.span.start_line,
        "constant call to `" + callee_name + "` has the wrong number of arguments",
        [callee_name, to_string(len(proc_decl.param_names)), to_string(argument_count)],
        "pass exactly " + to_string(len(proc_decl.param_names)) + " constant arguments",
        true
      )],
      valid: false
    };
  }

  if depth >= 64 {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: [diagnostic_create(
        ConstEvalErrorKind.Cycle,
        source_path,
        expr.span.start_line,
        "constant call recursion limit exceeded",
        [const_call_chain_text(stack, callee_name + "(...)")],
        "reduce the constant call depth below 64",
        true
      )],
      valid: false
    };
  }

  let local_env: ConstEnv = env;
  let diagnostics: [ConstEvalDiagnostic] = [];
  let argument_values: [ConstValue] = [];
  let i: u64 = 0;
  while i < argument_count {
    let argument_expr: AstExpr = call_argument(expr, i);
    let argument: ConstEvalResult = eval_const_ast_expr_with_procs(env, source_path, argument_expr, procs, stack, depth);
    set diagnostics = diagnostics + argument.diagnostics;
    if argument.valid {
      set argument_values = argument_values + [argument.value];
    }
    set i = i + 1;
  }
  if diagnostics_has_fatal(diagnostics) or len(argument_values) != argument_count {
    give ConstEvalResult { value: const_unknown(), diagnostics: diagnostics, valid: false };
  }

  let call_frame: string = const_call_frame_text(callee_name, argument_values);
  if const_call_stack_contains(stack, call_frame) {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: [diagnostic_create(
        ConstEvalErrorKind.Cycle,
        source_path,
        expr.span.start_line,
        "recursive constant call cycle detected",
        [const_call_chain_text(stack, call_frame)],
        "change the recursive arguments so the call reaches a base case",
        true
      )],
      valid: false
    };
  }

  let binding_index: u64 = 0;
  while binding_index < len(proc_decl.param_names) {
    set local_env = env_set(local_env, proc_decl.param_names[binding_index], argument_values[binding_index]);
    set binding_index = binding_index + 1;
  }

  let executed: ConstProcExecResult = eval_const_proc_stmts(local_env, source_path, proc_decl.body_stmts, procs, stack + [call_frame], depth + 1);
  if not executed.valid {
    give ConstEvalResult { value: const_unknown(), diagnostics: diagnostics + executed.diagnostics, valid: false };
  }
  if not executed.returned {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: diagnostics + executed.diagnostics + [diagnostic_create(
        ConstEvalErrorKind.UnsupportedExpr,
        source_path,
        proc_decl.line,
        "constant procedure `" + callee_name + "` did not return a value",
        [callee_name],
        "ensure every constant control-flow path reaches `give`",
        true
      )],
      valid: false
    };
  }
  if not const_value_fits_target(executed.value, proc_decl.return_type) {
    give ConstEvalResult {
      value: const_unknown(),
      diagnostics: diagnostics + executed.diagnostics + [overflow_diagnostic(source_path, proc_decl.line, callee_name, proc_decl.return_type, executed.value)],
      valid: false
    };
  }
  give ConstEvalResult { value: executed.value, diagnostics: diagnostics + executed.diagnostics, valid: true };
}

proc add_impossible_branch_diag(diagnostics: [ConstEvalDiagnostic], source_path: string, line: u64, condition_text: string, message: string) -> [ConstEvalDiagnostic] {
  give diagnostics + [diagnostic_create(
    ConstEvalErrorKind.ImpossibleBranch,
    source_path,
    line,
    message,
    [condition_text],
    "remove the dead control-flow path or make the condition depend on runtime state",
    true
  )];
}

proc simulate_static_assert_stmt(source_path: string, stmt: AstStmt, env: ConstEnv, current: SimulationWalk) -> SimulationWalk {
  let evaluated: ConstEvalResult = eval_const_ast_expr(env, source_path, stmt.expr);
  let diagnostics: [ConstEvalDiagnostic] = current.diagnostics + evaluated.diagnostics;
  if not evaluated.valid {
    give simulation_walk(env, diagnostics, current.assert_count + 1, current.simulation_count, current.impossible_branch_count, false);
  }
  if evaluated.value.kind != ConstValueKind.Bool {
    give simulation_walk(
      env,
      diagnostics + [diagnostic_create(
        ConstEvalErrorKind.UnsupportedExpr,
        source_path,
        stmt.span.start_line,
        "static_assert requires a boolean constant expression",
        ["static_assert"],
        "compare the expression to produce a boolean result",
        true
      )],
      current.assert_count + 1,
      current.simulation_count,
      current.impossible_branch_count,
      false
    );
  }
  if evaluated.value.bool_value {
    give simulation_walk(env, diagnostics, current.assert_count + 1, current.simulation_count, current.impossible_branch_count, current.valid);
  }
  let message: string = if stmt.message != "" { "static_assert failed: " + stmt.message } else { "static_assert failed" };
  give simulation_walk(
    env,
    diagnostics + [diagnostic_create(
      ConstEvalErrorKind.StaticAssertFailed,
      source_path,
      stmt.span.start_line,
      message,
      ["static_assert", stmt.expr.text],
      "fix the asserted condition or move it to runtime if it is not constant",
      true
    )],
    current.assert_count + 1,
    current.simulation_count,
    current.impossible_branch_count,
    false
  );
}

proc simulate_assert_call_stmt(source_path: string, stmt: AstStmt, env: ConstEnv, current: SimulationWalk) -> SimulationWalk {
  let callee_name: string = call_callee_name(stmt.expr);
  if callee_name != "assert" {
    give current;
  }
  let condition: AstExpr = call_argument(stmt.expr, 0);
  if not condition.valid {
    give current;
  }
  let evaluated: ConstEvalResult = eval_const_ast_expr(env, source_path, condition);
  let diagnostics: [ConstEvalDiagnostic] = current.diagnostics + evaluated.diagnostics;
  if not evaluated.valid {
    give simulation_walk(env, diagnostics, current.assert_count, current.simulation_count + 1, current.impossible_branch_count, false);
  }
  if evaluated.value.kind != ConstValueKind.Bool or evaluated.value.bool_value {
    give simulation_walk(env, diagnostics, current.assert_count, current.simulation_count + 1, current.impossible_branch_count, not diagnostics_has_fatal(diagnostics));
  }
  give simulation_walk(
    env,
    diagnostics + [diagnostic_create(
      ConstEvalErrorKind.StaticAssertFailed,
      source_path,
      stmt.span.start_line,
      "compile-time simulation reached an `assert` that always fails",
      ["assert", condition.text],
      "fix the assertion condition or make it depend on runtime state",
      true
    )],
    current.assert_count,
    current.simulation_count + 1,
    current.impossible_branch_count,
    false
  );
}

proc simulate_stmt_list(source_path: string, stmts: [AstStmt], env: ConstEnv, diagnostics: [ConstEvalDiagnostic], assert_count: u64, simulation_count: u64, impossible_branch_count: u64) -> SimulationWalk {
  let current0: SimulationWalk = simulation_walk(env, diagnostics, assert_count, simulation_count, impossible_branch_count, not diagnostics_has_fatal(diagnostics));
  let current: SimulationWalk = current0;
  let i: u64 = 0;
  while i < len(stmts) {
    let stmt: AstStmt = stmts[i];
    let next_env: ConstEnv = current.env;
    let next_diags: [ConstEvalDiagnostic] = current.diagnostics;
    let next_asserts: u64 = current.assert_count;
    let next_simulated: u64 = current.simulation_count;
    let next_impossible: u64 = current.impossible_branch_count;

    if stmt.kind == AstStmtKind.Const or stmt.kind == AstStmtKind.Let {
      let binding_name: string = stmt_binding_name(stmt);
      if binding_name != "" and stmt.expr.valid {
        let evaluated: ConstEvalResult = eval_const_ast_expr(current.env, source_path, stmt.expr);
        set next_diags = next_diags + evaluated.diagnostics;
        if evaluated.valid {
          set next_env = env_set(next_env, binding_name, evaluated.value);
        } else {
          set next_env = env_without(next_env, binding_name);
        }
      }
    } elif stmt.kind == AstStmtKind.Set {
      let target_name: string = stmt_target_name(stmt);
      if target_name != "" {
        let evaluated: ConstEvalResult = eval_const_ast_expr(current.env, source_path, stmt.expr);
        set next_diags = next_diags + evaluated.diagnostics;
        if evaluated.valid {
          set next_env = env_set(next_env, target_name, evaluated.value);
        } else {
          set next_env = env_without(next_env, target_name);
        }
      }
    } elif stmt.kind == AstStmtKind.StaticAssert {
      let walked: SimulationWalk = simulate_static_assert_stmt(source_path, stmt, current.env, current);
      set next_env = walked.env;
      set next_diags = walked.diagnostics;
      set next_asserts = walked.assert_count;
      set next_simulated = walked.simulation_count;
      set next_impossible = walked.impossible_branch_count;
    } elif stmt.kind == AstStmtKind.ExprStmt {
      let walked: SimulationWalk = simulate_assert_call_stmt(source_path, stmt, current.env, current);
      set next_env = walked.env;
      set next_diags = walked.diagnostics;
      set next_asserts = walked.assert_count;
      set next_simulated = walked.simulation_count;
      set next_impossible = walked.impossible_branch_count;
    } elif stmt.kind == AstStmtKind.If or stmt.kind == AstStmtKind.While {
      let evaluated: ConstEvalResult = eval_const_ast_expr(current.env, source_path, stmt.condition);
      if evaluated.valid and evaluated.value.kind == ConstValueKind.Bool {
        set next_simulated = next_simulated + 1;
        if stmt.kind == AstStmtKind.If {
          if evaluated.value.bool_value {
            let then_walk: SimulationWalk = simulate_stmt_list(source_path, stmt.then_stmts, current.env, next_diags, next_asserts, next_simulated, next_impossible);
            set next_env = then_walk.env;
            set next_diags = then_walk.diagnostics;
            set next_asserts = then_walk.assert_count;
            set next_simulated = then_walk.simulation_count;
            set next_impossible = then_walk.impossible_branch_count;
          } else {
            set next_impossible = next_impossible + 1;
            set next_diags = add_impossible_branch_diag(next_diags, source_path, stmt.span.start_line, stmt.condition.text, "compile-time simulation found an `if` branch that can never execute");
            if len(stmt.else_stmts) > 0 {
              let else_walk: SimulationWalk = simulate_stmt_list(source_path, stmt.else_stmts, current.env, next_diags, next_asserts, next_simulated, next_impossible);
              set next_env = else_walk.env;
              set next_diags = else_walk.diagnostics;
              set next_asserts = else_walk.assert_count;
              set next_simulated = else_walk.simulation_count;
              set next_impossible = else_walk.impossible_branch_count;
            }
          }
        } elif evaluated.value.bool_value {
          let body_walk: SimulationWalk = simulate_stmt_list(source_path, stmt.then_stmts, current.env, next_diags, next_asserts, next_simulated, next_impossible);
          set next_env = body_walk.env;
          set next_diags = body_walk.diagnostics;
          set next_asserts = body_walk.assert_count;
          set next_simulated = body_walk.simulation_count;
          set next_impossible = body_walk.impossible_branch_count;
        } else {
          set next_impossible = next_impossible + 1;
          set next_diags = add_impossible_branch_diag(next_diags, source_path, stmt.span.start_line, stmt.condition.text, "compile-time simulation found a `while` loop that can never execute");
        }
      }
    }

    set current = simulation_walk(next_env, next_diags, next_asserts, next_simulated, next_impossible, not diagnostics_has_fatal(next_diags));
    set i = i + 1;
  }
  give current;
}

proc run_compile_time_simulation_ast(source_path: string, module: AstModule, env: ConstEnv, diagnostics: [ConstEvalDiagnostic], assert_count: u64) -> ConstEvalRunResult {
  let current0: SimulationWalk = simulation_walk(env, diagnostics, assert_count, 0, 0, not diagnostics_has_fatal(diagnostics));
  let current: SimulationWalk = current0;
  let i: u64 = 0;
  while i < len(module.items) {
    if len(module.items[i].stmts) > 0 {
      set current = simulate_stmt_list(
        source_path,
        module.items[i].stmts,
        current.env,
        current.diagnostics,
        current.assert_count,
        current.simulation_count,
        current.impossible_branch_count
      );
    }
    set i = i + 1;
  }
  give ConstEvalRunResult {
    bindings: current.env.bindings,
    diagnostics: current.diagnostics,
    assert_count: current.assert_count,
    simulation_count: current.simulation_count,
    impossible_branch_count: current.impossible_branch_count,
    valid: current.valid
  };
}

proc decl_name_exists(decls: [ConstDecl], name: string) -> bool {
  let i: int = 0;
  while i < len(decls) {
    if decls[i].name == name {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc unresolved_dep_names(decls: [ConstDecl], env: ConstEnv, expr: string) -> [string] {
  let refs: [string] = expr_references(expr);
  let missing: [string] = [];
  let i: int = 0;
  while i < len(refs) {
    if decl_name_exists(decls, refs[i]) and not env_has(env, refs[i]) {
      set missing = missing + [refs[i]];
    }
    set i = i + 1;
  }
  give missing;
}

proc already_emitted(diags: [ConstEvalDiagnostic], code: string, line: u64) -> bool {
  let i: int = 0;
  while i < len(diags) {
    if diags[i].code == code and diags[i].span.line == line {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc run_const_decls(source_path: string, decls: [ConstDecl]) -> ConstEvalRunResult {
  let env: ConstEnv = env_empty();
  let resolved: [ConstBinding] = [];
  let diagnostics: [ConstEvalDiagnostic] = [];
  let pending: [ConstDecl] = decls;
  let progress: bool = true;

  while progress and len(pending) > 0 {
    set progress = false;
    let next_pending: [ConstDecl] = [];
    let i: int = 0;

    while i < len(pending) {
      let decl: ConstDecl = pending[i];
      let unresolved: [string] = unresolved_dep_names(decls, env, decl.expr);
      if len(unresolved) > 0 {
        set next_pending = next_pending + [decl];
        set i = i + 1;
        continue;
      }

      let folded: ConstFoldResult = fold_const_expr(env, source_path, decl.expr, decl.line);
      if folded.valid and const_value_fits_target(folded.value, decl.target_type) {
        set env = env_set(env, decl.name, folded.value);
        set resolved = resolved + [ConstBinding { name: decl.name, value: folded.value, valid: true }];
        set progress = true;
      } elif folded.valid {
        set diagnostics = diagnostics + [overflow_diagnostic(source_path, decl.line, decl.name, decl.target_type, folded.value)];
      } else {
        let j: int = 0;
        while j < len(folded.diagnostics) {
          if not already_emitted(diagnostics, folded.diagnostics[j].code, folded.diagnostics[j].span.line) {
            set diagnostics = diagnostics + [folded.diagnostics[j]];
          }
          set j = j + 1;
        }
      }
      set i = i + 1;
    }

    set pending = next_pending;
  }

  let k: int = 0;
  while k < len(pending) {
    let refs: [string] = expr_references(pending[k].expr);
    let cycle_like: bool = false;
    let r: int = 0;
    while r < len(refs) {
      if refs[r] == pending[k].name or decl_name_exists(pending, refs[r]) {
        set cycle_like = true;
      }
      set r = r + 1;
    }
    if cycle_like {
      set diagnostics = diagnostics + [diagnostic_create(
        ConstEvalErrorKind.Cycle,
        source_path,
        pending[k].line,
        "cyclic constant dependency around `" + pending[k].name + "`",
        [pending[k].name],
        "break the cycle by introducing a base constant or runtime initialization",
        true
      )];
    } else {
      set diagnostics = diagnostics + [diagnostic_create(
        ConstEvalErrorKind.UnknownName,
        source_path,
        pending[k].line,
        "constant `" + pending[k].name + "` depends on unknown names",
        [pending[k].name],
        "declare dependent constants before use",
        true
      )];
    }
    set k = k + 1;
  }

  give ConstEvalRunResult {
    bindings: resolved,
    diagnostics: diagnostics,
    assert_count: 0,
    simulation_count: 0,
    impossible_branch_count: 0,
    valid: not diagnostics_has_fatal(diagnostics)
  };
}

proc decl_name_exists_ast(decls: [ConstDeclAst], name: string) -> bool {
  let i: u64 = 0;
  while i < len(decls) {
    if decls[i].name == name {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc unresolved_dep_names_ast(decls: [ConstDeclAst], env: ConstEnv, expr: AstExpr) -> [string] {
  let refs: [string] = ast_expr_references(expr);
  let missing: [string] = [];
  let i: u64 = 0;
  while i < len(refs) {
    if decl_name_exists_ast(decls, refs[i]) and not env_has(env, refs[i]) {
      set missing = missing + [refs[i]];
    }
    set i = i + 1;
  }
  give missing;
}

proc run_const_decls_ast(source_path: string, decls: [ConstDeclAst], procs: [ConstProcAst]) -> ConstEvalRunResult {
  let env: ConstEnv = env_empty();
  let resolved: [ConstBinding] = [];
  let diagnostics: [ConstEvalDiagnostic] = [];
  let pending: [ConstDeclAst] = decls;
  let progress: bool = true;

  while progress and len(pending) > 0 {
    set progress = false;
    let next_pending: [ConstDeclAst] = [];
    let i: u64 = 0;
    while i < len(pending) {
      let decl: ConstDeclAst = pending[i];
      let unresolved: [string] = unresolved_dep_names_ast(decls, env, decl.expr);
      if len(unresolved) > 0 {
        set next_pending = next_pending + [decl];
        set i = i + 1;
        continue;
      }
      let evaluated: ConstEvalResult = eval_const_ast_expr_with_procs(env, source_path, decl.expr, procs, [], 0);
      if evaluated.valid and const_value_fits_target(evaluated.value, decl.target_type) {
        set env = env_set(env, decl.name, evaluated.value);
        set resolved = resolved + [ConstBinding { name: decl.name, value: evaluated.value, valid: true }];
        set progress = true;
      } elif evaluated.valid {
        set diagnostics = diagnostics + [overflow_diagnostic(source_path, decl.line, decl.name, decl.target_type, evaluated.value)];
      } else {
        set diagnostics = diagnostics + evaluated.diagnostics;
      }
      set i = i + 1;
    }
    set pending = next_pending;
  }

  let k: u64 = 0;
  while k < len(pending) {
    set diagnostics = diagnostics + [diagnostic_create(
      ConstEvalErrorKind.Cycle,
      source_path,
      pending[k].line,
      "cyclic constant dependency involving `" + pending[k].name + "`",
      [pending[k].name],
      "break the dependency cycle between constants",
      true
    )];
    set k = k + 1;
  }

  give ConstEvalRunResult {
    bindings: resolved,
    diagnostics: diagnostics,
    assert_count: 0,
    simulation_count: 0,
    impossible_branch_count: 0,
    valid: not diagnostics_has_fatal(diagnostics)
  };
}

proc run_static_asserts_ast(source_path: string, asserts: [StaticAssertDeclAst], procs: [ConstProcAst], env: ConstEnv, diagnostics: [ConstEvalDiagnostic]) -> ConstEvalRunResult {
  let output: [ConstEvalDiagnostic] = diagnostics;
  let i: u64 = 0;
  while i < len(asserts) {
    let evaluated: ConstEvalResult = eval_const_ast_expr_with_procs(env, source_path, asserts[i].expr, procs, [], 0);
    if not evaluated.valid {
      set output = output + evaluated.diagnostics;
    } elif evaluated.value.kind != ConstValueKind.Bool {
      set output = output + [diagnostic_create(
        ConstEvalErrorKind.UnsupportedExpr,
        source_path,
        asserts[i].line,
        "static_assert requires a boolean constant expression",
        ["static_assert"],
        "compare the expression to produce a boolean result",
        true
      )];
    } elif not evaluated.value.bool_value {
      let message: string = "static_assert failed";
      if asserts[i].message != "" {
        set message = "static_assert failed: " + asserts[i].message;
      }
      set output = output + [diagnostic_create(
        ConstEvalErrorKind.StaticAssertFailed,
        source_path,
        asserts[i].line,
        message,
        ["static_assert", asserts[i].expr.text],
        "fix the asserted condition or move it to runtime if it is not constant",
        true
      )];
    }
    set i = i + 1;
  }

  give ConstEvalRunResult {
    bindings: env.bindings,
    diagnostics: output,
    assert_count: len(asserts) as u64,
    simulation_count: 0,
    impossible_branch_count: 0,
    valid: not diagnostics_has_fatal(output)
  };
}

proc run_static_asserts(source_path: string, asserts: [StaticAssertDecl], env: ConstEnv, diagnostics: [ConstEvalDiagnostic]) -> ConstEvalRunResult {
  let output: [ConstEvalDiagnostic] = diagnostics;
  let i: int = 0;

  while i < len(asserts) {
    let evaluated = fold_const_expr(env, source_path, asserts[i].expr, asserts[i].line);
    if not evaluated.valid {
      set output = output + evaluated.diagnostics;
    } elif evaluated.value.kind != ConstValueKind.Bool {
      set output = output + [diagnostic_create(
        ConstEvalErrorKind.StaticAssertFailed,
        source_path,
        asserts[i].line,
        "static_assert requires a boolean constant expression",
        ["static_assert"],
        "compare the expression to produce a boolean result",
        true
      )];
    } elif not evaluated.value.bool_value {
      let message: string = "static_assert failed";
      if asserts[i].message != "" {
        set message = "static_assert failed: " + asserts[i].message;
      }
      set output = output + [diagnostic_create(
        ConstEvalErrorKind.StaticAssertFailed,
        source_path,
        asserts[i].line,
        message,
        ["static_assert", asserts[i].expr],
        "fix the asserted condition or move it to runtime if it is not constant",
        true
      )];
    }
    set i = i + 1;
  }

  give ConstEvalRunResult {
    bindings: env.bindings,
    diagnostics: output,
    assert_count: len(asserts) as u64,
    simulation_count: 0,
    impossible_branch_count: 0,
    valid: not diagnostics_has_fatal(output)
  };
}

proc run_const_eval(source_path: string, source_text: string) -> ConstEvalRunResult {
  let decls: [ConstDecl] = collect_const_decls(source_text);
  let asserts: [StaticAssertDecl] = collect_static_asserts(source_text);
  let decl_result: ConstEvalRunResult = run_const_decls(source_path, decls);

  let env: ConstEnv = ConstEnv {
    bindings: decl_result.bindings,
    valid: decl_result.valid
  };

  let asserted: ConstEvalRunResult = run_static_asserts(source_path, asserts, env, decl_result.diagnostics);
  let simulated: ConstEvalRunResult = run_compile_time_simulation(source_path, source_text, env, asserted.diagnostics);

  give ConstEvalRunResult {
    bindings: asserted.bindings,
    diagnostics: simulated.diagnostics,
    assert_count: asserted.assert_count,
    simulation_count: simulated.simulation_count,
    impossible_branch_count: simulated.impossible_branch_count,
    valid: asserted.valid and simulated.valid
  };
}

proc run_const_eval_ast(source_path: string, module: AstModule) -> ConstEvalRunResult {
  let decls: [ConstDeclAst] = [];
  let asserts: [StaticAssertDeclAst] = [];
  let procs: [ConstProcAst] = [];
  let i: u64 = 0;
  while i < len(module.items) {
    let item = module.items[i];
    if item.kind == AstItemKind.Const {
      set decls = decls + [ConstDeclAst { name: item.name, expr: item.expr, target_type: item.annotation.text, line: item.span.start_line, valid: item.valid }];
    } elif item.kind == AstItemKind.StaticAssert {
      set asserts = asserts + [StaticAssertDeclAst { expr: item.expr, message: item.message, line: item.span.start_line, valid: item.valid }];
    } elif item.kind == AstItemKind.Proc {
      let param_names: [string] = [];
      let params_valid: bool = true;
      let j: u64 = 0;
      while j < len(item.signature.params) {
        let param_name: string = item.signature.params[j].pattern.binding_name;
        if param_name == "" {
          set param_name = item.signature.params[j].pattern.name;
        }
        if param_name == "" {
          set params_valid = false;
        }
        set param_names = param_names + [param_name];
        set j = j + 1;
      }
      let declared_const: bool = text_list_contains(item.modifiers, "const");
      set procs = procs + [ConstProcAst {
        name: item.name,
        param_names: param_names,
        body_stmts: item.stmts,
        return_type: item.signature.return_type.text,
        line: item.span.start_line,
        declared_const: declared_const,
        valid: item.valid and declared_const and params_valid and len(item.stmts) > 0
      }];
    }
    set i = i + 1;
  }

  let decl_result: ConstEvalRunResult = run_const_decls_ast(source_path, decls, procs);
  let env: ConstEnv = ConstEnv {
    bindings: decl_result.bindings,
    valid: decl_result.valid
  };
  let asserted: ConstEvalRunResult = run_static_asserts_ast(source_path, asserts, procs, env, decl_result.diagnostics);
  let asserted_env: ConstEnv = ConstEnv {
    bindings: asserted.bindings,
    valid: asserted.valid
  };
  give run_compile_time_simulation_ast(source_path, module, asserted_env, asserted.diagnostics, asserted.assert_count);
}
