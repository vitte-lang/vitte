space vitte/compiler/analysis/const_eval/errors

pick ConstEvalErrorKind {
  None,
  DivisionByZero,
  UnknownName,
  NonConstCall,
  MutationInConst,
  UnsupportedExpr,
  Overflow,
  StaticAssertFailed,
  ImpossibleBranch,
  Cycle,
  ParseError,
}

pick ConstEvalSeverity {
  Warning,
  Error,
}

form ConstEvalSpan {
  file: string
  line: u64
  column: u64
  length: u64
}

form ConstEvalDiagnostic {
  kind: ConstEvalErrorKind
  code: string
  severity: ConstEvalSeverity
  message: string
  labels: [string]
  suggestion: string
  span: ConstEvalSpan
  fatal: bool
}

proc span_create(file: string, line: u64, column: u64, length: u64) -> ConstEvalSpan {
  give ConstEvalSpan {
    file: file,
    line: line,
    column: column,
    length: length
  };
}

proc span_empty() -> ConstEvalSpan {
  give span_create("compiler/analysis/const_eval", 0, 0, 0);
}

proc error_code(kind: ConstEvalErrorKind) -> string {
  if kind == ConstEvalErrorKind.DivisionByZero {
    give "CONST_EVAL_E_DIVISION_BY_ZERO";
  }
  if kind == ConstEvalErrorKind.UnknownName {
    give "CONST_EVAL_E_UNKNOWN_NAME";
  }
  if kind == ConstEvalErrorKind.NonConstCall {
    give "CONST_EVAL_E_NON_CONST_CALL";
  }
  if kind == ConstEvalErrorKind.MutationInConst {
    give "CONST_EVAL_E_MUTATION_IN_CONST";
  }
  if kind == ConstEvalErrorKind.UnsupportedExpr {
    give "CONST_EVAL_E_UNSUPPORTED_EXPR";
  }
  if kind == ConstEvalErrorKind.Overflow {
    give "CONST_EVAL_E_OVERFLOW";
  }
  if kind == ConstEvalErrorKind.StaticAssertFailed {
    give "CONST_EVAL_E_STATIC_ASSERT_FAILED";
  }
  if kind == ConstEvalErrorKind.ImpossibleBranch {
    give "CONST_EVAL_E_IMPOSSIBLE_BRANCH";
  }
  if kind == ConstEvalErrorKind.Cycle {
    give "CONST_EVAL_E_CYCLE";
  }
  if kind == ConstEvalErrorKind.ParseError {
    give "CONST_EVAL_E_PARSE";
  }
  give "CONST_EVAL_E_UNKNOWN";
}

proc severity_name(severity: ConstEvalSeverity) -> string {
  if severity == ConstEvalSeverity.Warning {
    give "warning";
  }
  give "error";
}

proc diagnostic_create(kind: ConstEvalErrorKind, file: string, line: u64, message: string, labels: [string], suggestion: string, fatal: bool) -> ConstEvalDiagnostic {
  give ConstEvalDiagnostic {
    kind: kind,
    code: error_code(kind),
    severity: ConstEvalSeverity.Error,
    message: message,
    labels: labels,
    suggestion: suggestion,
    span: span_create(file, line, 1, 1),
    fatal: fatal
  };
}

proc diagnostics_has_fatal(diagnostics: [ConstEvalDiagnostic]) -> bool {
  let i: u64 = 0;
  while i < len(diagnostics) {
    if diagnostics[i].fatal {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc diagnostics_has_code(diagnostics: [ConstEvalDiagnostic], code: string) -> bool {
  let i: u64 = 0;
  while i < len(diagnostics) {
    if diagnostics[i].code == code {
      give true;
    }
    set i = i + 1;
  }
  give false;
}
