space vitte/compiler/analysis/borrowck/loans

pick LoanKind {
  Shared,
  Mutable,
}

form Loan {
  id: u64
  alias: string
  owner: string
  kind: LoanKind
  start_line: u64
  end_line: u64
  scope_end_line: u64
  active: bool
  valid: bool
}

form LoanTable {
  loans: [Loan]
  valid: bool
}

proc loan_create(id: u64, alias: string, owner: string, kind: LoanKind, line: u64) -> Loan {
  give loan_create_scoped(id, alias, owner, kind, line, line);
}

proc loan_create_scoped(id: u64, alias: string, owner: string, kind: LoanKind, line: u64, scope_end_line: u64) -> Loan {
  give Loan {
    id: id,
    alias: alias,
    owner: owner,
    kind: kind,
    start_line: line,
    end_line: line,
    scope_end_line: scope_end_line,
    active: true,
    valid: alias != "" and owner != ""
  };
}

proc loan_table_empty() -> LoanTable {
  give LoanTable {
    loans: [],
    valid: true
  };
}

proc loan_conflicts(active_kind: LoanKind, requested_kind: LoanKind) -> bool {
  if active_kind == LoanKind.Mutable {
    give true;
  }
  give requested_kind == LoanKind.Mutable;
}

proc add_loan(table: LoanTable, loan: Loan) -> LoanTable {
  give LoanTable {
    loans: table.loans + [loan],
    valid: table.valid and loan.valid
  };
}

proc owner_has_active_shared(table: LoanTable, owner: string) -> u64 {
  let count: u64 = 0;
  let i: u64 = 0;
  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and loan.owner == owner and loan.kind == LoanKind.Shared {
      set count = count + 1;
    }
    set i = i + 1;
  }
  give count;
}

proc owner_has_active_mutable(table: LoanTable, owner: string) -> bool {
  let i: u64 = 0;
  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and loan.owner == owner and loan.kind == LoanKind.Mutable {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc owner_has_conflict(table: LoanTable, owner: string, requested_kind: LoanKind) -> bool {
  let i: u64 = 0;
  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and loan.owner == owner and loan_conflicts(loan.kind, requested_kind) {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc alias_is_active(table: LoanTable, alias: string) -> bool {
  let i: u64 = 0;
  while i < len(table.loans) {
    if table.loans[i].active and table.loans[i].alias == alias {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc owner_for_alias(table: LoanTable, alias: string) -> string {
  let i: u64 = 0;
  while i < len(table.loans) {
    if table.loans[i].active and table.loans[i].alias == alias {
      give table.loans[i].owner;
    }
    set i = i + 1;
  }
  give "";
}

proc kind_for_alias(table: LoanTable, alias: string) -> LoanKind {
  let i: u64 = 0;
  while i < len(table.loans) {
    if table.loans[i].active and table.loans[i].alias == alias {
      give table.loans[i].kind;
    }
    set i = i + 1;
  }
  give LoanKind.Shared;
}

proc deactivate_alias(table: LoanTable, alias: string, line: u64) -> LoanTable {
  let loans: [Loan] = [];
  let i: u64 = 0;

  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and loan.alias == alias {
      set loans = loans + [Loan {
        id: loan.id,
        alias: loan.alias,
        owner: loan.owner,
        kind: loan.kind,
        start_line: loan.start_line,
        end_line: line,
        scope_end_line: loan.scope_end_line,
        active: false,
        valid: loan.valid
      }];
    } else {
      set loans = loans + [loan];
    }
    set i = i + 1;
  }

  give LoanTable {
    loans: loans,
    valid: table.valid
  };
}

proc deactivate_expired_loans(table: LoanTable, line: u64) -> LoanTable {
  let loans: [Loan] = [];
  let i: u64 = 0;
  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and loan.scope_end_line < line {
      set loans = loans + [Loan {
        id: loan.id,
        alias: loan.alias,
        owner: loan.owner,
        kind: loan.kind,
        start_line: loan.start_line,
        end_line: line,
        scope_end_line: loan.scope_end_line,
        active: false,
        valid: loan.valid
      }];
    } else {
      set loans = loans + [loan];
    }
    set i = i + 1;
  }

  give LoanTable {
    loans: loans,
    valid: table.valid
  };
}
