form BorrowCheckResult {
  diagnostics: [BorrowDiagnostic]
  ownership: OwnershipTable
  moves: MoveTracker
  loans: LoanTable
  lifetimes: LifetimeResult
  valid: bool
}

form BorrowBlockState {
  block_id: u64
  result: BorrowCheckResult
  valid: bool
}

form BorrowScopeInfo {
  name: string
  scope_end_line: u64
  ty: string
  copyable: bool
  mutable: bool
  borrowed: bool
  valid: bool
}

form BorrowFunctionParam {
  name: string
  type_name: string
  mutable: bool
  borrowed: bool
  variadic: bool
  valid: bool
}

form BorrowFunctionInfo {
  name: string
  params: [BorrowFunctionParam]
  valid: bool
}

form BorrowMetadata {
  scopes: [BorrowScopeInfo]
  functions: [BorrowFunctionInfo]
  valid: bool
}

proc split_lines(text: string) -> [string] {
  give split(text, "\n");
}

proc binding_name(binding_text: string) -> string {
  let binding: string = trim(binding_text);
  if binding == "" {
    give "";
  }

  let without_mut: string = binding;
  if starts_with(without_mut, "mut ") {
    set without_mut = trim(slice(without_mut, 4, len(without_mut)));
  }

  let colon: int = find(without_mut, ":");
  if colon >= 0 {
    set without_mut = trim(slice(without_mut, 0, colon));
  }

  give move_source_from_expr(without_mut);
}

proc assign_separator() -> string {
  give slice("a=b", 1, 2);
}

proc stmt_lhs(line: string, prefix: string) -> string {
  let rest: string = trim(slice(line, len(prefix), len(line)));
  let eq: int = find(rest, assign_separator());
  if eq < 0 {
    give binding_name(rest);
  }
  give binding_name(slice(rest, 0, eq));
}

proc stmt_rhs(line: string, prefix: string) -> string {
  let rest: string = trim(slice(line, len(prefix), len(line)));
  let eq: int = find(rest, assign_separator());
  if eq < 0 {
    give "";
  }
  give trim(slice(rest, eq + 1, len(rest)));
}

proc parse_borrow_owner(expr: string) -> string {
  let trimmed: string = trim(expr);
  if starts_with(trimmed, "&mut ") {
    give place_name(place_from_text(slice(trimmed, 5, len(trimmed))));
  }
  if starts_with(trimmed, "&") {
    give place_name(place_from_text(slice(trimmed, 1, len(trimmed))));
  }
  give "";
}

proc take_place_prefix(text: string) -> string {
  let trimmed: string = trim(text);
  if trimmed == "" {
    give "";
  }

  let i: int = 0;
  while i < len(trimmed) {
    let ch: string = slice(trimmed, i, i + 1);
    let is_lower_alpha: bool = ch >= "a" and ch <= "z";
    let is_upper_alpha: bool = ch >= "A" and ch <= "Z";
    let is_alpha: bool = is_lower_alpha or is_upper_alpha or ch == "_";
    let is_digit: bool = ch >= "0" and ch <= "9";
    let is_dot: bool = ch == ".";
    let is_star: bool = ch == "*";
    let is_index: bool = ch == "[" or ch == "]";
    if i == 0 {
      if not is_alpha and not is_star {
        give "";
      }
    } elif not is_alpha and not is_digit and not is_dot and not is_star and not is_index {
      give slice(trimmed, 0, i);
    }
    set i = i + 1;
  }
  give trimmed;
}

proc place_from_text(text: string) -> Place {
  let trimmed: string = trim(text);
  if starts_with(trimmed, "&mut ") {
    give place_named(trim(slice(trimmed, 5, len(trimmed))));
  } elif starts_with(trimmed, "&") {
    give place_named(trim(slice(trimmed, 1, len(trimmed))));
  } elif starts_with(trimmed, "move ") {
    give place_named(trim(slice(trimmed, 5, len(trimmed))));
  }
  give place_named(take_place_prefix(trimmed));
}

proc place_name(place: Place) -> string {
  give place_key(place);
}

proc root_of_place_name(name: string) -> string {
  let place: Place = place_named(name);
  give place.root;
}

proc place_name_contains(text: string, prefix: string) -> bool {
  give place_prefix(place_named(prefix), place_named(text));
}

proc place_names_overlap(left: string, right: string) -> bool {
  give place_overlap(place_named(left), place_named(right));
}

proc ensure_place_declared(table: OwnershipTable, name: string, line: u64) -> OwnershipTable {
  if name == "" or has_local(table, name) {
    give table;
  }
  let root: string = root_of_place_name(name);
  if root != "" and has_local(table, root) {
    give declare_local(table, name, line, true);
  }
  give table;
}

proc is_moved_place(table: OwnershipTable, name: string) -> bool {
  let i: u64 = 0;
  while i < len(table.locals) {
    if place_names_overlap(table.locals[i].name, name) and table.locals[i].state == LocalStateKind.Moved {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc shared_borrow_count_place(table: OwnershipTable, name: string) -> u64 {
  let count: u64 = 0;
  let i: u64 = 0;
  while i < len(table.locals) {
    if place_names_overlap(table.locals[i].name, name) {
      set count = count + table.locals[i].shared_borrows;
    }
    set i = i + 1;
  }
  give count;
}

proc is_mutably_borrowed_place(table: OwnershipTable, name: string) -> bool {
  let i: u64 = 0;
  while i < len(table.locals) {
    if place_names_overlap(table.locals[i].name, name) and table.locals[i].mutable_borrowed {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc owner_has_conflict_place(table: LoanTable, owner: string, requested_kind: LoanKind) -> bool {
  let i: u64 = 0;
  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and place_names_overlap(loan.owner, owner) and loan_conflicts(loan.kind, requested_kind) {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc first_conflicting_loan(table: LoanTable, owner: string, requested_kind: LoanKind) -> Loan {
  let i: u64 = 0;
  while i < len(table.loans) {
    let loan: Loan = table.loans[i];
    if loan.active and place_names_overlap(loan.owner, owner) and loan_conflicts(loan.kind, requested_kind) {
      give loan;
    }
    set i = i + 1;
  }
  give loan_invalid();
}

proc estimated_scope_text(line: u64) -> string {
  if line == 18446744073709551615 or line == 0 {
    give "unknown scope end";
  }
  give line as string;
}

proc borrow_scope_info(name: string, scope_end_line: u64, ty: string, copyable: bool, mutable: bool, borrowed: bool) -> BorrowScopeInfo {
  give BorrowScopeInfo {
    name: name,
    scope_end_line: scope_end_line,
    ty: ty,
    copyable: copyable,
    mutable: mutable,
    borrowed: borrowed,
    valid: name != ""
  };
}

proc borrow_metadata_empty() -> BorrowMetadata {
  give BorrowMetadata {
    scopes: [],
    functions: [],
    valid: true
  };
}

proc metadata_index(metadata: BorrowMetadata, name: string) -> int {
  let i: int = 0;
  while i < len(metadata.scopes) {
    if metadata.scopes[i].name == name {
      give i;
    }
    set i = i + 1;
  }
  give -1;
}

proc metadata_scope_end(metadata: BorrowMetadata, name: string) -> u64 {
  let index: int = metadata_index(metadata, name);
  if index < 0 {
    give 18446744073709551615 as u64;
  }
  give metadata.scopes[index].scope_end_line;
}

proc metadata_type(metadata: BorrowMetadata, name: string) -> string {
  let index: int = metadata_index(metadata, name);
  if index >= 0 {
    give metadata.scopes[index].ty;
  }
  let root: string = root_of_place_name(name);
  if root != "" and root != name {
    let root_index: int = metadata_index(metadata, root);
    if root_index >= 0 {
      let projected: string = trim(slice(name, len(root), len(name)));
      give project_place_type(metadata.scopes[root_index].ty, projected);
    }
  }
  give "opaque";
}

proc metadata_is_copy(metadata: BorrowMetadata, name: string) -> bool {
  let index: int = metadata_index(metadata, name);
  if index >= 0 {
    give metadata.scopes[index].copyable;
  }
  give type_is_copy(metadata_type(metadata, name));
}

proc borrow_function_param(name: string, type_name: string, mutable: bool, borrowed: bool, variadic: bool) -> BorrowFunctionParam {
  give BorrowFunctionParam {
    name: name,
    type_name: type_name,
    mutable: mutable,
    borrowed: borrowed,
    variadic: variadic,
    valid: name != "" or variadic
  };
}

proc borrow_function_info(name: string, params: [BorrowFunctionParam]) -> BorrowFunctionInfo {
  give BorrowFunctionInfo {
    name: name,
    params: params,
    valid: name != ""
  };
}

proc metadata_function_index(metadata: BorrowMetadata, name: string) -> int {
  let i: int = 0;
  while i < len(metadata.functions) {
    if metadata.functions[i].name == name {
      give i;
    }
    set i = i + 1;
  }
  give -1;
}

proc metadata_set_function(metadata: BorrowMetadata, function0: BorrowFunctionInfo) -> BorrowMetadata {
  let out: [BorrowFunctionInfo] = [];
  let found: bool = false;
  let i: u64 = 0;
  while i < len(metadata.functions) {
    if metadata.functions[i].name == function0.name {
      set out = out + [function0];
      set found = true;
    } else {
      set out = out + [metadata.functions[i]];
    }
    set i = i + 1;
  }
  if not found {
    set out = out + [function0];
  }
  give BorrowMetadata {
    scopes: metadata.scopes,
    functions: out,
    valid: metadata.valid and function0.valid
  };
}

proc metadata_find_function(metadata: BorrowMetadata, name: string) -> BorrowFunctionInfo {
  let index: int = metadata_function_index(metadata, name);
  if index < 0 {
    give BorrowFunctionInfo { name: "", params: [], valid: false };
  }
  give metadata.functions[index];
}

proc borrow_function_params_from_hir(params0: [HirProcParam], target_type_text: string) -> [BorrowFunctionParam] {
  let out: [BorrowFunctionParam] = [];
  let i: u64 = 0;
  while i < len(params0) {
    let ty: string = if params0[i].annotation_text == "Self" and target_type_text != "" { target_type_text } else { if params0[i].annotation_text != "" { params0[i].annotation_text } else { "opaque" } };
    set out = out + [borrow_function_param(params0[i].name, ty, params0[i].mutable, params0[i].borrowed, params0[i].variadic)];
    set i = i + 1;
  }
  give out;
}

proc borrow_function_params_from_mir(params0: [MirFunctionParam]) -> [BorrowFunctionParam] {
  let out: [BorrowFunctionParam] = [];
  let i: u64 = 0;
  while i < len(params0) {
    set out = out + [borrow_function_param(
      params0[i].name,
      params0[i].type_name,
      params0[i].mutable,
      params0[i].borrowed,
      params0[i].variadic
    )];
    set i = i + 1;
  }
  give out;
}

proc function_params_from_mir(functions: [MirFunction], name: string) -> [BorrowFunctionParam] {
  let i: u64 = 0;
  while i < len(functions) {
    if functions[i].name == name {
      give borrow_function_params_from_mir(functions[i].params);
    }
    set i = i + 1;
  }
  give [];
}

proc metadata_set_scope(metadata: BorrowMetadata, scope: BorrowScopeInfo) -> BorrowMetadata {
  let scopes: [BorrowScopeInfo] = [];
  let found: bool = false;
  let i: u64 = 0;
  while i < len(metadata.scopes) {
    let current: BorrowScopeInfo = metadata.scopes[i];
    if current.name == scope.name {
      let end_line: u64 = current.scope_end_line;
      if scope.scope_end_line > end_line {
        set end_line = scope.scope_end_line;
      }
      set scopes = scopes + [BorrowScopeInfo {
        name: scope.name,
        scope_end_line: end_line,
        ty: scope.ty,
        copyable: scope.copyable,
        mutable: scope.mutable,
        borrowed: scope.borrowed,
        valid: scope.valid
      }];
      set found = true;
    } else {
      set scopes = scopes + [current];
    }
    set i = i + 1;
  }
  if not found {
    set scopes = scopes + [scope];
  }
  give BorrowMetadata {
    scopes: scopes,
    functions: metadata.functions,
    valid: metadata.valid and scope.valid
  };
}

proc max_stmt_line(stmt: HirStmt) -> u64 {
  let line_no: u64 = stmt.span.start_line;
  let i: u64 = 0;
  let max_line: u64 = line_no;
  while i < len(stmt.then_stmts) {
    let nested: u64 = max_stmt_line(stmt.then_stmts[i]);
    if nested > max_line {
      set max_line = nested;
    }
    set i = i + 1;
  }
  i = 0;
  while i < len(stmt.else_stmts) {
    let nested: u64 = max_stmt_line(stmt.else_stmts[i]);
    if nested > max_line {
      set max_line = nested;
    }
    set i = i + 1;
  }
  give max_line;
}

proc max_stmt_list_line(stmts: [HirStmt]) -> u64 {
  let max_line: u64 = 0;
  let i: u64 = 0;
  while i < len(stmts) {
    let line_no: u64 = max_stmt_line(stmts[i]);
    if line_no > max_line {
      set max_line = line_no;
    }
    set i = i + 1;
  }
  give max_line;
}

proc expr_static_type(expr: HirExpr) -> string {
  if expr.inferred_type != "" and expr.inferred_type != "unknown" {
    give expr.inferred_type;
  }
  give "opaque";
}

proc expr_copyable(expr: HirExpr) -> bool {
  if expr.copyable {
    give true;
  }
  give type_is_copy(expr_static_type(expr));
}

proc collect_stmt_metadata(metadata: BorrowMetadata, scope_end_line: u64, stmt: HirStmt) -> BorrowMetadata {
  let current: BorrowMetadata = metadata;
  let expr_ty: string = expr_static_type(stmt.expr);
  if stmt.kind == HirStmtKind.Let and stmt.name != "" {
    set current = metadata_set_scope(current, borrow_scope_info(stmt.name, scope_end_line, expr_ty, expr_copyable(stmt.expr), stmt.mutable, false));
  } elif stmt.kind == HirStmtKind.Const and stmt.name != "" {
    set current = metadata_set_scope(current, borrow_scope_info(stmt.name, scope_end_line, expr_ty, expr_copyable(stmt.expr), false, false));
  }

  if len(stmt.then_stmts) > 0 {
    let then_end: u64 = max_stmt_list_line(stmt.then_stmts) + 1;
    let i: u64 = 0;
    while i < len(stmt.then_stmts) {
      set current = collect_stmt_metadata(current, then_end, stmt.then_stmts[i]);
      set i = i + 1;
    }
  }
  if len(stmt.else_stmts) > 0 {
    let else_end: u64 = max_stmt_list_line(stmt.else_stmts) + 1;
    let i: u64 = 0;
    while i < len(stmt.else_stmts) {
      set current = collect_stmt_metadata(current, else_end, stmt.else_stmts[i]);
      set i = i + 1;
    }
  }

  give current;
}

proc collect_hir_metadata(hir: HirUnit) -> BorrowMetadata {
  let metadata: BorrowMetadata = borrow_metadata_empty();
  let current: BorrowMetadata = metadata;
  let i: u64 = 0;
  while i < len(hir.module.items) {
    let item = hir.module.items[i];
    if item.kind == HirItemKind.Const and item.name != "" {
      let item_ty: string = expr_static_type(item.expr);
      set current = metadata_set_scope(current, borrow_scope_info(item.name, item.span.end_line + 1, item_ty, expr_copyable(item.expr), false, false));
    }
    if item.kind == HirItemKind.Proc {
      let body_end: u64 = max_stmt_list_line(item.stmts) + 1;
      let params0: [BorrowFunctionParam] = borrow_function_params_from_hir(item.params, item.target_type_text);
      set current = metadata_set_function(current, borrow_function_info(item.name, params0));
      let p: u64 = 0;
      while p < len(params0) {
        if not params0[p].variadic and params0[p].name != "" {
          set current = metadata_set_scope(current, borrow_scope_info(
            params0[p].name,
            body_end,
            params0[p].type_name,
            params0[p].borrowed or type_is_copy(params0[p].type_name),
            params0[p].mutable,
            params0[p].borrowed
          ));
        }
        set p = p + 1;
      }
      let j: u64 = 0;
      while j < len(item.stmts) {
        set current = collect_stmt_metadata(current, body_end, item.stmts[j]);
        set j = j + 1;
      }
    }
    if item.kind == HirItemKind.Impl {
      let j: u64 = 0;
      while j < len(item.members) {
        let member = item.members[j];
        if member.kind == HirNominalMemberKind.ImplMethod and member.name != "" {
          let symbol_name: string = "vitte_impl_" + item.name + "_for_" + item.target_type_text + "_" + member.name;
          let body_end: u64 = max_stmt_list_line(member.body_stmts) + 1;
          let params0: [BorrowFunctionParam] = borrow_function_params_from_hir(member.params, item.target_type_text);
          set current = metadata_set_function(current, borrow_function_info(symbol_name, params0));
          let p: u64 = 0;
          while p < len(params0) {
            if not params0[p].variadic and params0[p].name != "" {
              set current = metadata_set_scope(current, borrow_scope_info(
                params0[p].name,
                body_end,
                params0[p].type_name,
                params0[p].borrowed or type_is_copy(params0[p].type_name),
                params0[p].mutable,
                params0[p].borrowed
              ));
            }
            set p = p + 1;
          }
          let k: u64 = 0;
          while k < len(member.body_stmts) {
            set current = collect_stmt_metadata(current, body_end, member.body_stmts[k]);
            set k = k + 1;
          }
        }
        set j = j + 1;
      }
    }
    set i = i + 1;
  }
  give current;
}

proc is_mutable_borrow_expr(expr: string) -> bool {
  give starts_with(trim(expr), "&mut ");
}

proc is_shared_borrow_expr(expr: string) -> bool {
  let trimmed: string = trim(expr);
  give starts_with(trimmed, "&") and not starts_with(trimmed, "&mut ");
}

proc add_diag(result: BorrowCheckResult, diagnostic: BorrowDiagnostic) -> BorrowCheckResult {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    let existing: BorrowDiagnostic = result.diagnostics[i];
    if existing.code == diagnostic.code and existing.span.line == diagnostic.span.line and existing.message == diagnostic.message {
      give result;
    }
    set i = i + 1;
  }
  give BorrowCheckResult {
    diagnostics: result.diagnostics + [diagnostic],
    ownership: result.ownership,
    moves: result.moves,
    loans: result.loans,
    lifetimes: result.lifetimes,
    valid: false
  };
}

proc replace_ownership(result: BorrowCheckResult, ownership: OwnershipTable) -> BorrowCheckResult {
  give BorrowCheckResult {
    diagnostics: result.diagnostics,
    ownership: ownership,
    moves: result.moves,
    loans: result.loans,
    lifetimes: result.lifetimes,
    valid: result.valid and ownership.valid
  };
}

proc replace_moves(result: BorrowCheckResult, moves: MoveTracker) -> BorrowCheckResult {
  give BorrowCheckResult {
    diagnostics: result.diagnostics,
    ownership: result.ownership,
    moves: moves,
    loans: result.loans,
    lifetimes: result.lifetimes,
    valid: result.valid and moves.valid
  };
}

proc replace_loans(result: BorrowCheckResult, loans: LoanTable) -> BorrowCheckResult {
  give BorrowCheckResult {
    diagnostics: result.diagnostics,
    ownership: result.ownership,
    moves: result.moves,
    loans: loans,
    lifetimes: result.lifetimes,
    valid: result.valid and loans.valid
  };
}

proc replace_lifetimes(result: BorrowCheckResult, lifetimes: LifetimeResult) -> BorrowCheckResult {
  give BorrowCheckResult {
    diagnostics: result.diagnostics + lifetimes.diagnostics,
    ownership: result.ownership,
    moves: result.moves,
    loans: result.loans,
    lifetimes: lifetimes,
    valid: result.valid and lifetimes.valid and not diagnostics_has_fatal(lifetimes.diagnostics)
  };
}

proc expire_loans(result: BorrowCheckResult, metadata: BorrowMetadata, line: u64) -> BorrowCheckResult {
  let expired: LoanTable = deactivate_expired_loans(result.loans, line);
  let current: BorrowCheckResult = replace_loans(result, expired);
  let ownership0: OwnershipTable = current.ownership;
  let i: u64 = 0;
  while i < len(expired.loans) {
    let loan: Loan = expired.loans[i];
    if not loan.active and loan.end_line == line {
      if loan.kind == LoanKind.Mutable {
        set ownership0 = set_mutable_borrow(ownership0, loan.owner, false, line);
      } else {
        set ownership0 = release_shared_borrow(ownership0, loan.owner, line);
      }
    }
    set i = i + 1;
  }
  give replace_ownership(current, ownership0);
}

proc release_alias(result: BorrowCheckResult, alias: string, line: u64) -> BorrowCheckResult {
  if not alias_is_active(result.loans, alias) {
    give result;
  }

  let owner: string = owner_for_alias(result.loans, alias);
  let kind: LoanKind = kind_for_alias(result.loans, alias);
  let loans0: LoanTable = deactivate_alias(result.loans, alias, line);
  let result0: BorrowCheckResult = replace_loans(result, loans0);

  if kind == LoanKind.Mutable {
    give replace_ownership(result0, set_mutable_borrow(result0.ownership, owner, false, line));
  }
  give replace_ownership(result0, release_shared_borrow(result0.ownership, owner, line));
}

proc bind_plain_value(result: BorrowCheckResult, binding: string, line: u64) -> BorrowCheckResult {
  let ownership0: OwnershipTable = declare_local(result.ownership, binding, line, true);
  give replace_ownership(result, ownership0);
}

proc record_direct_return_ref(result: BorrowCheckResult, source_path: string, owner: string, line: u64) -> BorrowCheckResult {
  let lifetimes0: LifetimeResult = add_return_constraint(result.lifetimes, owner, "return", line);
  let lifetimes1: LifetimeResult = add_returned_local_diagnostic(lifetimes0, source_path, line, owner, "", true);
  let lifetimes2: LifetimeResult = add_fact(lifetimes1, lifetime_fact("", owner, "return", line, LifetimeFactKind.Return));
  let result0: BorrowCheckResult = replace_lifetimes(result, lifetimes2);
  give replace_moves(result0, tracker_record_return(result0.moves, owner, line));
}

proc record_alias_return(result: BorrowCheckResult, source_path: string, alias: string, owner: string, line: u64) -> BorrowCheckResult {
  let lifetimes0: LifetimeResult = add_return_constraint(result.lifetimes, owner, "return", line);
  let lifetimes1: LifetimeResult = add_returned_local_diagnostic(lifetimes0, source_path, line, owner, alias, false);
  let lifetimes2: LifetimeResult = add_fact(lifetimes1, lifetime_fact(alias, owner, "return", line, LifetimeFactKind.Return));
  let result0: BorrowCheckResult = replace_lifetimes(result, lifetimes2);
  give replace_moves(result0, tracker_record_return(result0.moves, alias, line));
}

proc handle_borrow_binding(result: BorrowCheckResult, metadata: BorrowMetadata, source_path: string, binding: string, owner: string, mutable: bool, line: u64) -> BorrowCheckResult {
  let current: BorrowCheckResult = release_alias(result, binding, line);
  let ownership0: OwnershipTable = ensure_place_declared(current.ownership, owner, line);
  let current0: BorrowCheckResult = replace_ownership(current, ownership0);

  if owner == "" {
    give bind_plain_value(current0, binding, line);
  }
  if is_moved_place(current0.ownership, owner) {
    give add_diag(current0, diagnostic_create(
      BorrowErrorKind.BorrowOfMovedValue,
      source_path,
      line,
      "cannot borrow moved local `" + owner + "`",
      [owner, binding],
      "reinitialize the value before borrowing it",
      true
    ));
  }

  let requested: LoanKind = LoanKind.Shared;
  if mutable {
    set requested = LoanKind.Mutable;
  }

  if owner_has_conflict_place(current0.loans, owner, requested) {
    let conflict_loan: Loan = first_conflicting_loan(current0.loans, owner, requested);
    if requested == LoanKind.Mutable {
      give add_diag(current0, borrow_error_mutable_borrow_conflict_story(
        source_path,
        owner,
        line,
        conflict_loan.start_line,
        estimated_scope_text(conflict_loan.scope_end_line),
        conflict_loan.id
      ));
    }
    give add_diag(current0, borrow_error_shared_borrow_conflict_story(
      source_path,
      owner,
      line,
      conflict_loan.start_line,
      estimated_scope_text(conflict_loan.scope_end_line),
      conflict_loan.id
    ));
  }

  let alias_scope_end: u64 = metadata_scope_end(metadata, binding);
  let owner_scope_end: u64 = metadata_scope_end(metadata, owner);
  let loans0: LoanTable = add_loan(current0.loans, loan_create_scoped(
    len(current0.loans.loans) as u64 + 1,
    binding,
    owner,
    requested,
    line,
    alias_scope_end
  ));
  let current1: BorrowCheckResult = replace_loans(current0, loans0);
  let ownership1: OwnershipTable = declare_local(current1.ownership, binding, line, true);
  let current2: BorrowCheckResult = replace_ownership(current1, ownership1);

  let ownership2: OwnershipTable = current2.ownership;
  if mutable {
    set ownership2 = set_mutable_borrow(ownership2, owner, true, line);
  } else {
    set ownership2 = add_shared_borrow(ownership2, owner, line);
  }

  let lifetimes1: LifetimeResult = add_temporal_ownership_fact(
    current2.lifetimes,
    temporal_ownership_window(owner, binding, line, owner_scope_end, line, alias_scope_end, mutable)
  );
  let current3: BorrowCheckResult = replace_ownership(current2, ownership2);
  give replace_lifetimes(current3, lifetimes1);
}

proc handle_move_binding(result: BorrowCheckResult, metadata: BorrowMetadata, source_path: string, binding: string, source: string, line: u64) -> BorrowCheckResult {
  let current: BorrowCheckResult = release_alias(result, binding, line);
  let ownership0: OwnershipTable = ensure_place_declared(current.ownership, source, line);
  let current0: BorrowCheckResult = replace_ownership(current, ownership0);

  if metadata_is_copy(metadata, source) {
    let ownership_copy: OwnershipTable = declare_local(current0.ownership, binding, line, true);
    give replace_ownership(current0, ownership_copy);
  }

  if source == "" or not has_local(current0.ownership, source) {
    give bind_plain_value(current0, binding, line);
  }
  if is_moved_place(current0.ownership, source) {
    let previous_move: MoveEvent = last_event_for(current0.moves, source);
    let previous_line: u64 = if previous_move.valid { previous_move.line } else { line };
    give add_diag(current0, borrow_error_move_after_move_story(
      source_path,
      source,
      line,
      previous_line,
      "until `" + source + "` is reinitialized",
      previous_line
    ));
  }
  if shared_borrow_count_place(current0.ownership, source) > 0 or is_mutably_borrowed_place(current0.ownership, source) {
    let conflict_loan: Loan = first_conflicting_loan(current0.loans, source, LoanKind.Mutable);
    let borrow_line: u64 = if conflict_loan.valid { conflict_loan.start_line } else { line };
    let lifetime_text: string = if conflict_loan.valid { estimated_scope_text(conflict_loan.scope_end_line) } else { "unknown scope end" };
    let conflict_id: u64 = if conflict_loan.valid { conflict_loan.id } else { line };
    give add_diag(current0, borrow_error_move_while_borrowed_story(
      source_path,
      source,
      line,
      borrow_line,
      lifetime_text,
      conflict_id
    ));
  }

  let ownership1: OwnershipTable = mark_moved(current0.ownership, source, line);
  let current1: BorrowCheckResult = replace_ownership(current0, ownership1);
  let moves0: MoveTracker = tracker_record_move(current1.moves, source, line);
  let current2: BorrowCheckResult = replace_moves(current1, moves0);
  let ownership2: OwnershipTable = declare_local(current2.ownership, binding, line, true);
  give replace_ownership(current2, ownership2);
}

proc handle_set(result: BorrowCheckResult, metadata: BorrowMetadata, source_path: string, target: string, rhs: string, line: u64) -> BorrowCheckResult {
  let current: BorrowCheckResult = release_alias(result, target, line);
  let ownership0: OwnershipTable = ensure_place_declared(current.ownership, target, line);
  let current0: BorrowCheckResult = replace_ownership(current, ownership0);
  if target == "" {
    give current0;
  }
  if shared_borrow_count_place(current0.ownership, target) > 0 or is_mutably_borrowed_place(current0.ownership, target) {
    give add_diag(current0, diagnostic_create(
      BorrowErrorKind.WriteWhileBorrowed,
      source_path,
      line,
      "cannot write `" + target + "` while it is borrowed",
      [target],
      "end the active borrow before assigning to the local",
      true
    ));
  }

  let owner: string = parse_borrow_owner(rhs);
  if owner != "" {
    give handle_borrow_binding(current0, metadata, source_path, target, owner, is_mutable_borrow_expr(rhs), line);
  }

  let source: string = move_source_from_expr(rhs);
  if source != "" and source != target {
    let current1: BorrowCheckResult = handle_move_binding(current0, metadata, source_path, target, source, line);
    if current1.valid {
      let ownership1: OwnershipTable = mark_reinitialized(current1.ownership, target, line);
      let moves0: MoveTracker = tracker_record_reinit(current1.moves, target, line);
      let current2: BorrowCheckResult = replace_ownership(current1, ownership1);
      give replace_moves(current2, moves0);
    }
    give current1;
  }

  let ownership1: OwnershipTable = mark_reinitialized(current0.ownership, target, line);
  let moves0: MoveTracker = tracker_record_reinit(current0.moves, target, line);
  let current1: BorrowCheckResult = replace_ownership(current0, ownership1);
  give replace_moves(current1, moves0);
}

proc handle_give(result: BorrowCheckResult, source_path: string, expr: string, line: u64) -> BorrowCheckResult {
  let owner: string = parse_borrow_owner(expr);
  if owner != "" and (has_local(result.ownership, owner) or has_local(result.ownership, root_of_place_name(owner))) {
    give record_direct_return_ref(result, source_path, owner, line);
  }

  let value: string = move_source_from_expr(expr);
  let place_value: string = place_name(place_from_text(expr));
  let actual_value: string = value;
  if place_value != "" {
    set actual_value = place_value;
  }
  if actual_value == "" {
    give result;
  }

  if alias_is_active(result.loans, actual_value) {
    let owner0: string = owner_for_alias(result.loans, actual_value);
    give record_alias_return(result, source_path, actual_value, owner0, line);
  }

  if is_moved_place(result.ownership, actual_value) {
    let previous_move: MoveEvent = last_event_for(result.moves, actual_value);
    let previous_line: u64 = if previous_move.valid { previous_move.line } else { line };
    give add_diag(result, borrow_error_use_after_move_story(
      source_path,
      actual_value,
      line,
      previous_line,
      "until `" + actual_value + "` is reinitialized",
      previous_line
    ));
  }

  give replace_moves(result, tracker_record_return(result.moves, actual_value, line));
}

proc borrow_result_empty() -> BorrowCheckResult {
  give BorrowCheckResult {
    diagnostics: [],
    ownership: ownership_table_empty(),
    moves: move_tracker_empty(),
    loans: loan_table_empty(),
    lifetimes: lifetime_result_empty(region_solution_empty()),
    valid: true
  };
}

proc borrow_result_with_params(params0: [BorrowFunctionParam]) -> BorrowCheckResult {
  let current: BorrowCheckResult = borrow_result_empty();
  let ownership0: OwnershipTable = current.ownership;
  let i: u64 = 0;
  while i < len(params0) {
    if not params0[i].variadic and params0[i].name != "" {
      set ownership0 = declare_local(ownership0, params0[i].name, 0, true);
    }
    set i = i + 1;
  }
  give replace_ownership(current, ownership0);
}

proc move_event_same(a: MoveEvent, b: MoveEvent) -> bool {
  give a.local == b.local and a.kind == b.kind and a.line == b.line and a.detail == b.detail;
}

proc append_unique_move_events(base: MoveTracker, extra: MoveTracker) -> MoveTracker {
  let events: [MoveEvent] = base.events;
  let i: u64 = 0;
  while i < len(extra.events) {
    let found: bool = false;
    let j: u64 = 0;
    while j < len(events) {
      if move_event_same(events[j], extra.events[i]) {
        set found = true;
      }
      set j = j + 1;
    }
    if not found {
      set events = events + [extra.events[i]];
    }
    set i = i + 1;
  }
  give MoveTracker { events: events, valid: base.valid and extra.valid };
}

proc loan_same(a: Loan, b: Loan) -> bool {
  give a.alias == b.alias and a.owner == b.owner and a.kind == b.kind and a.active == b.active and a.start_line == b.start_line;
}

proc append_unique_loans(base: LoanTable, extra: LoanTable) -> LoanTable {
  let loans = base.loans;
  let i: u64 = 0;
  while i < len(extra.loans) {
    let found: bool = false;
    let j: u64 = 0;
    while j < len(loans) {
      if loan_same(loans[j], extra.loans[i]) {
        set found = true;
      }
      set j = j + 1;
    }
    if not found {
      set loans = loans + [extra.loans[i]];
    }
    set i = i + 1;
  }
  give LoanTable { loans: loans, valid: base.valid and extra.valid };
}

proc ownership_local_fingerprint(local: LocalState) -> string {
  let state_text: string = local.state as string;
  let shared_text: string = local.shared_borrows as string;
  let mutable_text: string = local.mutable_borrowed as string;
  let fingerprint: string = local.name + "|" + place_name(local.place);
  set fingerprint = fingerprint + "|" + state_text;
  set fingerprint = fingerprint + "|" + shared_text;
  set fingerprint = fingerprint + "|" + mutable_text;
  give fingerprint;
}

proc merge_local_state(left: LocalState, right: LocalState) -> LocalState {
  let state: LocalStateKind = left.state;
  let shared_borrows: u64 = left.shared_borrows;
  if right.shared_borrows > shared_borrows {
    set shared_borrows = right.shared_borrows;
  }
  let last_line: u64 = left.last_line;
  if right.last_line > last_line {
    set last_line = right.last_line;
  }
  if left.state == LocalStateKind.Moved or right.state == LocalStateKind.Moved {
    set state = LocalStateKind.Moved;
  } elif left.state == LocalStateKind.Uninitialized or right.state == LocalStateKind.Uninitialized {
    set state = LocalStateKind.Uninitialized;
  } else {
    set state = LocalStateKind.Available;
  }
  give LocalState {
    name: left.name,
    place: left.place,
    state: state,
    shared_borrows: shared_borrows,
    mutable_borrowed: left.mutable_borrowed or right.mutable_borrowed,
    last_line: last_line,
    valid: left.valid and right.valid
  };
}

proc merge_ownership(left: OwnershipTable, right: OwnershipTable) -> OwnershipTable {
  let locals: [LocalState] = left.locals;
  let i: u64 = 0;
  while i < len(right.locals) {
    let candidate = right.locals[i];
    if has_local(OwnershipTable { locals: locals, facts: left.facts, valid: left.valid }, candidate.name) {
      let current: LocalState = find_local(OwnershipTable { locals: locals, facts: left.facts, valid: left.valid }, candidate.name);
      let merged: LocalState = merge_local_state(current, candidate);
      let table0: OwnershipTable = replace_local(OwnershipTable { locals: locals, facts: left.facts, valid: left.valid }, merged);
      set locals = table0.locals;
    } else {
      set locals = locals + [candidate];
    }
    set i = i + 1;
  }
  give OwnershipTable { locals: locals, facts: left.facts + right.facts, valid: left.valid and right.valid };
}

proc merge_lifetimes(left: LifetimeResult, right: LifetimeResult) -> LifetimeResult {
  give LifetimeResult {
    facts: left.facts + right.facts,
    diagnostics: left.diagnostics + right.diagnostics,
    regions: merge_region_solutions(left.regions, right.regions),
    valid: left.valid and right.valid
  };
}

proc append_unique_diagnostics(left: [BorrowDiagnostic], right: [BorrowDiagnostic]) -> [BorrowDiagnostic] {
  let out: [BorrowDiagnostic] = left;
  let i: u64 = 0;
  while i < len(right) {
    let found: bool = false;
    let j: u64 = 0;
    while j < len(out) {
      if out[j].code == right[i].code and out[j].span.line == right[i].span.line and out[j].message == right[i].message {
        set found = true;
      }
      set j = j + 1;
    }
    if not found {
      set out = out + [right[i]];
    }
    set i = i + 1;
  }
  give out;
}

proc merge_results(left: BorrowCheckResult, right: BorrowCheckResult) -> BorrowCheckResult {
  if len(left.ownership.locals) == 0 and len(left.loans.loans) == 0 and len(left.moves.events) == 0 and len(left.diagnostics) == 0 {
    give right;
  }
  if len(right.ownership.locals) == 0 and len(right.loans.loans) == 0 and len(right.moves.events) == 0 and len(right.diagnostics) == 0 {
    give left;
  }
  give BorrowCheckResult {
    diagnostics: append_unique_diagnostics(left.diagnostics, right.diagnostics),
    ownership: merge_ownership(left.ownership, right.ownership),
    moves: append_unique_move_events(left.moves, right.moves),
    loans: append_unique_loans(left.loans, right.loans),
    lifetimes: merge_lifetimes(left.lifetimes, right.lifetimes),
    valid: left.valid and right.valid
  };
}

proc result_fingerprint(result: BorrowCheckResult) -> string {
  let text: string = result.valid as string;
  let i: u64 = 0;
  while i < len(result.ownership.locals) {
    set text = text + "|" + ownership_local_fingerprint(result.ownership.locals[i]);
    set i = i + 1;
  }
  i = 0;
  while i < len(result.loans.loans) {
    let loan = result.loans.loans[i];
    let loan_kind_text: string = loan.kind as string;
    let loan_active_text: string = loan.active as string;
    let loan_text: string = "|loan:" + loan.alias + ":" + loan.owner;
    set loan_text = loan_text + ":" + loan_kind_text;
    set loan_text = loan_text + ":" + loan_active_text;
    set text = text + loan_text;
    set i = i + 1;
  }
  give text;
}

proc block_state_invalid(block_id: u64) -> BorrowBlockState {
  give BorrowBlockState { block_id: block_id, result: borrow_result_empty(), valid: false };
}

proc block_state_get(states: [BorrowBlockState], block_id: u64) -> BorrowBlockState {
  let i: u64 = 0;
  while i < len(states) {
    if states[i].block_id == block_id {
      give states[i];
    }
    set i = i + 1;
  }
  give block_state_invalid(block_id);
}

proc block_state_set(states: [BorrowBlockState], updated: BorrowBlockState) -> [BorrowBlockState] {
  let out: [BorrowBlockState] = [];
  let found: bool = false;
  let i: u64 = 0;
  while i < len(states) {
    if states[i].block_id == updated.block_id {
      set out = out + [updated];
      set found = true;
    } else {
      set out = out + [states[i]];
    }
    set i = i + 1;
  }
  if not found {
    set out = out + [updated];
  }
  give out;
}

proc terminator_targets(term: MirTerminator) -> [u64] {
  if term.kind == MirTerminatorKind.Goto {
    give [term.target_block];
  }
  if term.kind == MirTerminatorKind.Branch {
    give [term.target_block, term.else_block];
  }
  if term.kind == MirTerminatorKind.Switch {
    give term.switch_targets + [term.else_block];
  }
  give [];
}

proc block_has_target(block: MirBlock, target: u64) -> bool {
  let targets: [u64] = terminator_targets(block.terminator);
  let i: u64 = 0;
  while i < len(targets) {
    if targets[i] == target {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc merge_predecessors(initial: BorrowCheckResult, entry_block: u64, blocks: [MirBlock], states: [BorrowBlockState], block_id: u64) -> BorrowCheckResult {
  if block_id == entry_block {
    give initial;
  }
  let merged: BorrowCheckResult = borrow_result_empty();
  let found_predecessor: bool = false;
  let i: u64 = 0;
  while i < len(blocks) {
    if block_has_target(blocks[i], block_id) {
      set found_predecessor = true;
      let pred = block_state_get(states, blocks[i].id);
      if pred.valid {
        set merged = merge_results(merged, pred.result);
      }
    }
    set i = i + 1;
  }
  if not found_predecessor {
    give borrow_result_empty();
  }
  give merged;
}

proc queue_contains(queue: [u64], value: u64) -> bool {
  let i: u64 = 0;
  while i < len(queue) {
    if queue[i] == value {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc append_successors(queue: [u64], block: MirBlock) -> [u64] {
  let out: [u64] = queue;
  let targets: [u64] = terminator_targets(block.terminator);
  let i: u64 = 0;
  while i < len(targets) {
    if not queue_contains(out, targets[i]) {
      set out = out + [targets[i]];
    }
    set i = i + 1;
  }
  give out;
}

proc pop_queue(queue: [u64]) -> [u64] {
  let out: [u64] = [];
  let i: u64 = 1;
  while i < len(queue) {
    set out = out + [queue[i]];
    set i = i + 1;
  }
  give out;
}

proc find_block(blocks: [MirBlock], block_id: u64) -> MirBlock {
  let i: u64 = 0;
  while i < len(blocks) {
    if blocks[i].id == block_id {
      give blocks[i];
    }
    set i = i + 1;
  }
  give MirBlock { id: 0, statements: [], terminator: MirTerminator { kind: MirTerminatorKind.Unreachable, target_block: 0, else_block: 0, condition: MirOperand { text: "", place: MirPlace { local: "", projection: "", valid: false }, valid: false }, switch_values: [], switch_targets: [], valid: false }, valid: false };
}

proc operand_place_name(operand: MirOperand) -> string {
  if operand.place.valid {
    give mir_place_name(operand.place);
  }
  let place: Place = place_from_text(operand.text);
  give place_name(place);
}

proc mir_place_name(place: MirPlace) -> string {
  if not place.valid {
    give "";
  }
  if place.projection != "" {
    if starts_with(place.projection, "*") {
      give place.projection + place.local;
    }
    if starts_with(place.projection, "[") {
      give place.local + place.projection;
    }
    give place.local + "." + place.projection;
  }
  give place.local;
}

proc operand_local(operand: MirOperand) -> string {
  if operand.place.valid {
    give operand.place.local;
  }
  give "";
}

proc handle_use_local(result: BorrowCheckResult, source_path: string, local: string, line: u64) -> BorrowCheckResult {
  if local == "" {
    give result;
  }
  let ownership0: OwnershipTable = ensure_place_declared(result.ownership, local, line);
  let current: BorrowCheckResult = replace_ownership(result, ownership0);
  if not has_local(current.ownership, local) {
    give current;
  }
  if is_moved_place(current.ownership, local) {
    let previous_move: MoveEvent = last_event_for(current.moves, local);
    let previous_line: u64 = if previous_move.valid { previous_move.line } else { line };
    give add_diag(current, borrow_error_use_after_move_story(
      source_path,
      local,
      line,
      previous_line,
      "until `" + local + "` is reinitialized",
      previous_line
    ));
  }
  give replace_moves(current, tracker_record_use(current.moves, local, line));
}

proc call_target_name(stmt: MirStatement) -> string {
  if stmt.rvalue.kind != MirRvalueKind.Call {
    give "";
  }
  if len(stmt.rvalue.operands) > 0 and stmt.rvalue.operator != "variant-ctor" and stmt.rvalue.operator != "method-dispatch" {
    if stmt.rvalue.operands[0].place.valid and stmt.rvalue.operands[0].place.local != "" {
      give stmt.rvalue.operands[0].place.local;
    }
  }
  let open0: int = find(stmt.rvalue.text, "(");
  if open0 > 0 {
    give trim(slice(stmt.rvalue.text, 0, open0));
  }
  give "";
}

proc call_argument_start_index(stmt: MirStatement) -> u64 {
  if stmt.rvalue.operator == "variant-ctor" or stmt.rvalue.operator == "method-dispatch" {
    give 0 as u64;
  }
  if stmt.rvalue.kind == MirRvalueKind.Call and len(stmt.rvalue.operands) > 0 {
    give 1 as u64;
  }
  give 0 as u64;
}

proc apply_call_signature(result: BorrowCheckResult, metadata: BorrowMetadata, source_path: string, functions: [MirFunction], stmt: MirStatement) -> BorrowCheckResult {
  let target_name: string = call_target_name(stmt);
  if target_name == "" {
    give result;
  }
  let fn_params: [BorrowFunctionParam] = function_params_from_mir(functions, target_name);
  let fallback_info: BorrowFunctionInfo = if len(fn_params) == 0 { metadata_find_function(metadata, target_name) } else { BorrowFunctionInfo { name: "", params: [], valid: false } };
  let params_for_call: [BorrowFunctionParam] = if len(fn_params) > 0 { fn_params } else { fallback_info.params };
  if len(params_for_call) == 0 {
    let current0: BorrowCheckResult = result;
    let i0: u64 = call_argument_start_index(stmt);
    while i0 < len(stmt.rvalue.operands) {
      set current0 = handle_use_local(current0, source_path, operand_place_name(stmt.rvalue.operands[i0]), stmt.span.start_line);
      set i0 = i0 + 1;
    }
    let target0: string = mir_place_name(stmt.place);
    if target0 != "" {
      let ownership0: OwnershipTable = mark_reinitialized(current0.ownership, target0, stmt.span.start_line);
      let moves0: MoveTracker = tracker_record_reinit(current0.moves, target0, stmt.span.start_line);
      let current1: BorrowCheckResult = replace_ownership(current0, ownership0);
      give replace_moves(current1, moves0);
    }
    give current0;
  }

  let current: BorrowCheckResult = result;
  let arg_start: u64 = call_argument_start_index(stmt);
  let arg_index: u64 = arg_start;
  let param_index: u64 = 0;
  while arg_index < len(stmt.rvalue.operands) {
    let local: string = operand_place_name(stmt.rvalue.operands[arg_index]);
    if local == "" {
      set arg_index = arg_index + 1;
      set param_index = param_index + 1;
      continue;
    }
    let effective_param_index: u64 = if param_index < len(params_for_call) { param_index } else { len(params_for_call) - 1 };
    let param0: BorrowFunctionParam = params_for_call[effective_param_index];
    if param0.variadic {
      set current = handle_use_local(current, source_path, local, stmt.span.start_line);
    } elif param0.borrowed {
      let alias: string = "__call_borrow_" + string(stmt.id) + "_" + string(param_index);
      set current = handle_borrow_binding(current, metadata, source_path, alias, local, param0.mutable, stmt.span.start_line);
    } elif type_is_copy(param0.type_name) {
      set current = handle_use_local(current, source_path, local, stmt.span.start_line);
    } else {
      let alias: string = "__call_move_" + string(stmt.id) + "_" + string(param_index);
      set current = handle_move_binding(current, metadata, source_path, alias, local, stmt.span.start_line);
    }
    set arg_index = arg_index + 1;
    set param_index = param_index + 1;
  }
  let target: string = mir_place_name(stmt.place);
  if target != "" {
    let ownership0: OwnershipTable = mark_reinitialized(current.ownership, target, stmt.span.start_line);
    let moves0: MoveTracker = tracker_record_reinit(current.moves, target, stmt.span.start_line);
    let current0: BorrowCheckResult = replace_ownership(current, ownership0);
    give replace_moves(current0, moves0);
  }
  give current;
}

proc execute_mir_statement(result: BorrowCheckResult, metadata: BorrowMetadata, source_path: string, functions: [MirFunction], stmt: MirStatement) -> BorrowCheckResult {
  let line_no: u64 = stmt.span.start_line;
  let current: BorrowCheckResult = expire_loans(result, metadata, line_no);
  if stmt.kind == MirStatementKind.Assign {
    if stmt.rvalue.kind == MirRvalueKind.Call {
      give apply_call_signature(current, metadata, source_path, functions, stmt);
    }
    let target: string = mir_place_name(stmt.place);
    if stmt.rvalue.kind == MirRvalueKind.BorrowShared or stmt.rvalue.kind == MirRvalueKind.BorrowMut {
      let owner: string = "";
      if len(stmt.rvalue.operands) > 0 {
        set owner = operand_place_name(stmt.rvalue.operands[0]);
      } else {
        set owner = parse_borrow_owner(stmt.rvalue.text);
      }
      give handle_borrow_binding(current, metadata, source_path, target, owner, stmt.rvalue.kind == MirRvalueKind.BorrowMut, line_no);
    }

    if stmt.rvalue.kind == MirRvalueKind.Use {
      let source: string = "";
      if len(stmt.rvalue.operands) > 0 {
        set source = operand_place_name(stmt.rvalue.operands[0]);
      } else {
        set source = place_name(place_from_text(stmt.rvalue.text));
      }
      if source != "" and source != target {
        let current0: BorrowCheckResult = handle_move_binding(current, metadata, source_path, target, source, line_no);
        if current0.valid {
          let ownership0: OwnershipTable = mark_reinitialized(current0.ownership, target, line_no);
          let moves0: MoveTracker = tracker_record_reinit(current0.moves, target, line_no);
          let current1: BorrowCheckResult = replace_ownership(current0, ownership0);
          give replace_moves(current1, moves0);
        }
        give current0;
      }
    }

    let current0: BorrowCheckResult = current;
    let i: u64 = 0;
    while i < len(stmt.rvalue.operands) {
      set current0 = handle_use_local(current0, source_path, operand_place_name(stmt.rvalue.operands[i]), line_no);
      set i = i + 1;
    }
    let ownership0: OwnershipTable = mark_reinitialized(current0.ownership, target, line_no);
    let moves0: MoveTracker = tracker_record_reinit(current0.moves, target, line_no);
    let current1: BorrowCheckResult = replace_ownership(current0, ownership0);
    give replace_moves(current1, moves0);
  }

  if stmt.kind == MirStatementKind.Return {
    let expr: string = stmt.rvalue.text;
    give handle_give(current, source_path, expr, line_no);
  }

  if stmt.kind == MirStatementKind.Assert {
    let current0: BorrowCheckResult = current;
    let i: u64 = 0;
    while i < len(stmt.rvalue.operands) {
      set current0 = handle_use_local(current0, source_path, operand_place_name(stmt.rvalue.operands[i]), line_no);
      set i = i + 1;
    }
    give current0;
  }

  give current;
}

proc execute_mir_block(result: BorrowCheckResult, metadata: BorrowMetadata, source_path: string, functions: [MirFunction], block: MirBlock) -> BorrowCheckResult {
  let current: BorrowCheckResult = result;
  let line_no: u64 = 0;
  let i: u64 = 0;
  while i < len(block.statements) {
    set line_no = block.statements[i].span.start_line;
    set current = execute_mir_statement(current, metadata, source_path, functions, block.statements[i]);
    set i = i + 1;
  }

  if block.terminator.kind == MirTerminatorKind.Branch or block.terminator.kind == MirTerminatorKind.Switch {
    let current0: BorrowCheckResult = expire_loans(current, metadata, line_no + 1);
    give handle_use_local(current0, source_path, operand_place_name(block.terminator.condition), line_no);
  }
  give expire_loans(current, metadata, line_no + 1);
}

proc block_max_line(block: MirBlock) -> u64 {
  let line_no: u64 = 0;
  let i: u64 = 0;
  while i < len(block.statements) {
    if block.statements[i].span.start_line > line_no {
      set line_no = block.statements[i].span.start_line;
    }
    set i = i + 1;
  }
  give line_no;
}

proc max_line_for_function(fn0: MirFunction) -> u64 {
  let max_line: u64 = 0;
  let i: u64 = 0;
  while i < len(fn0.blocks) {
    let line_no: u64 = block_max_line(fn0.blocks[i]);
    if line_no > max_line {
      set max_line = line_no;
    }
    set i = i + 1;
  }
  give max_line;
}

proc close_known_regions(result: BorrowCheckResult, metadata: BorrowMetadata, fn0: MirFunction) -> LifetimeResult {
  let final_line: u64 = 1;
  let bi: u64 = 0;
  let max_line: u64 = 0;
  while bi < len(fn0.blocks) {
    let block_line: u64 = block_max_line(fn0.blocks[bi]);
    if block_line > max_line {
      set max_line = block_line;
    }
    set bi = bi + 1;
  }
  let current: LifetimeResult = result.lifetimes;
  let regions0: RegionSolution = close_region(current.regions, "return", max_line + 1);
  let closed0: LifetimeResult = LifetimeResult {
    facts: current.facts,
    diagnostics: current.diagnostics,
    regions: regions0,
    valid: current.valid and regions0.valid
  };

  let i: u64 = 0;
  let closed: LifetimeResult = closed0;
  while i < len(metadata.scopes) {
    let scope = metadata.scopes[i];
    let next_regions: RegionSolution = close_region(closed.regions, scope.name, scope.scope_end_line);
    set closed = LifetimeResult {
      facts: closed.facts,
      diagnostics: closed.diagnostics,
      regions: next_regions,
      valid: closed.valid and next_regions.valid
    };
    set i = i + 1;
  }

  i = 0;
  while i < len(result.ownership.locals) {
    let local: LocalState = result.ownership.locals[i];
    let region_end: u64 = local.last_line + 1;
    let scope_end: u64 = metadata_scope_end(metadata, local.name);
    if scope_end != 18446744073709551615 and scope_end > region_end {
      set region_end = scope_end;
    }
    let next_regions: RegionSolution = close_region(closed.regions, local.name, region_end);
    set closed = LifetimeResult {
      facts: closed.facts,
      diagnostics: closed.diagnostics,
      regions: next_regions,
      valid: closed.valid and next_regions.valid
    };
    set i = i + 1;
  }
  give closed;
}

proc borrow_check_mir_function(source_path: string, metadata: BorrowMetadata, functions: [MirFunction], fn0: MirFunction) -> BorrowCheckResult {
  let body_end: u64 = max_line_for_function(fn0) + 1;
  let metadata0: BorrowMetadata = metadata;
  let p: u64 = 0;
  while p < len(fn0.params) {
    if not fn0.params[p].variadic and fn0.params[p].name != "" {
      set metadata0 = metadata_set_scope(metadata0, borrow_scope_info(
        fn0.params[p].name,
        body_end,
        fn0.params[p].type_name,
        fn0.params[p].borrowed or type_is_copy(fn0.params[p].type_name),
        fn0.params[p].mutable,
        fn0.params[p].borrowed
      ));
    }
    set p = p + 1;
  }
  let initial0: BorrowCheckResult = borrow_result_with_params(function_params_from_mir(functions, fn0.name));
  let states: [BorrowBlockState] = [];
  let worklist: [u64] = [];
  let i: u64 = 0;
  while i < len(fn0.blocks) {
    set worklist = worklist + [fn0.blocks[i].id];
    set i = i + 1;
  }

  while len(worklist) > 0 {
    let block_id: u64 = worklist[0];
    set worklist = pop_queue(worklist);
    let block: MirBlock = find_block(fn0.blocks, block_id);
    if not block.valid {
      continue;
    }

    let in_state: BorrowCheckResult = merge_predecessors(initial0, fn0.entry_block, fn0.blocks, states, block.id);
    let out_state: BorrowCheckResult = execute_mir_block(in_state, metadata0, source_path, functions, block);
    let previous: BorrowBlockState = block_state_get(states, block.id);
    if not previous.valid or result_fingerprint(previous.result) != result_fingerprint(out_state) {
      set states = block_state_set(states, BorrowBlockState { block_id: block.id, result: out_state, valid: true });
      set worklist = append_successors(worklist, block);
    }
  }

  let merged: BorrowCheckResult = borrow_result_empty();
  let i: u64 = 0;
  while i < len(fn0.blocks) {
    let state: BorrowBlockState = block_state_get(states, fn0.blocks[i].id);
    if state.valid {
      set merged = merge_results(merged, state.result);
    }
    set i = i + 1;
  }

  let lifetimes0: LifetimeResult = close_known_regions(merged, metadata0, fn0);
  let current0: BorrowCheckResult = replace_lifetimes(merged, finalize_lifetimes(lifetimes0));
  give BorrowCheckResult {
    diagnostics: current0.diagnostics,
    ownership: current0.ownership,
    moves: current0.moves,
    loans: current0.loans,
    lifetimes: current0.lifetimes,
    valid: current0.valid and not diagnostics_has_fatal(current0.diagnostics)
  };
}

proc borrow_check_mir_with_metadata(source_path: string, mir: MirUnit, metadata: BorrowMetadata) -> BorrowCheckResult {
  if not mir.valid or not mir.module.valid {
    give add_diag(borrow_result_empty(), diagnostic_create(
      BorrowErrorKind.UseAfterMove,
      source_path,
      0,
      "borrow checking requires valid MIR",
      ["mir"],
      "fix HIR/MIR validation errors before borrow checking",
      true
    ));
  }
  let current: BorrowCheckResult = borrow_result_empty();
  let i: u64 = 0;
  while i < len(mir.module.functions) {
    let fn_result: BorrowCheckResult = borrow_check_mir_function(source_path, metadata, mir.module.functions, mir.module.functions[i]);
    set current = merge_results(current, fn_result);
    set i = i + 1;
  }
  give BorrowCheckResult {
    diagnostics: current.diagnostics,
    ownership: current.ownership,
    moves: current.moves,
    loans: current.loans,
    lifetimes: current.lifetimes,
    valid: current.valid and not diagnostics_has_fatal(current.diagnostics)
  };
}

proc borrow_check_mir(source_path: string, mir: MirUnit) -> BorrowCheckResult {
  give borrow_check_mir_with_metadata(source_path, mir, borrow_metadata_empty());
}

proc borrow_check_hir_mir(source_path: string, hir: HirUnit, mir: MirUnit) -> BorrowCheckResult {
  let metadata: BorrowMetadata = collect_hir_metadata(hir);
  give borrow_check_mir_with_metadata(source_path, mir, metadata);
}

proc borrow_check_source(source_path: string, source_text: string) -> BorrowCheckResult {
  let frontend: FrontendOutput = frontend_run(source_path, source_text);
  if not frontend.valid {
    give add_diag(borrow_result_empty(), diagnostic_create(
      BorrowErrorKind.UseAfterMove,
      source_path,
      0,
      "borrow checking requires valid frontend output",
      ["frontend"],
      "fix parsing or AST validation errors before borrow checking",
      true
    ));
  }
  let hir: HirUnit = lower_ast_to_hir(frontend);
  let mir: MirUnit = lower_hir_to_mir(hir);
  give borrow_check_hir_mir(source_path, hir, mir);
}

proc hir_expr_owner(expr: HirExpr) -> string {
  let is_borrow_expr: bool = expr.kind == HirExprKind.BorrowShared or expr.kind == HirExprKind.BorrowMut;
  if is_borrow_expr and len(expr.children) > 0 {
    if expr.children[0].binding != "" {
      give place_name(place_from_text(expr.children[0].binding));
    }
    give place_name(place_from_text(expr.children[0].text));
  }
  give "";
}

proc hir_expr_is_mutable_borrow(expr: HirExpr) -> bool {
  give expr.kind == HirExprKind.BorrowMut;
}

proc hir_expr_move_source(expr: HirExpr) -> string {
  if expr.binding != "" {
    give place_name(place_from_text(expr.binding));
  }
  if expr.kind == HirExprKind.Name {
    give place_name(place_from_text(expr.name));
  }
  give place_name(place_from_text(expr.text));
}

proc hir_expr_place(expr: HirExpr) -> Place {
  let is_borrow_expr: bool = expr.kind == HirExprKind.BorrowShared or expr.kind == HirExprKind.BorrowMut;
  if is_borrow_expr and len(expr.children) > 0 {
    if expr.children[0].binding != "" {
      give place_from_text(expr.children[0].binding);
    }
    give place_from_text(expr.children[0].text);
  }
  if expr.binding != "" {
    give place_from_text(expr.binding);
  }
  if expr.kind == HirExprKind.Name {
    give place_from_text(expr.name);
  }
  give place_from_text(expr.text);
}

proc hir_stmt_binding_place(stmt: HirStmt) -> Place {
  give place_from_text(stmt.name);
}

proc hir_stmt_target_place(stmt: HirStmt) -> Place {
  if stmt.target_binding != "" {
    give place_from_text(stmt.target_binding);
  }
  if stmt.target != "" {
    give place_from_text(stmt.target);
  }
  give hir_stmt_binding_place(stmt);
}

proc check_hir_stmt(result: BorrowCheckResult, source_path: string, stmt: HirStmt) -> BorrowCheckResult {
  let line_no: u64 = stmt.span.start_line;
  let current: BorrowCheckResult = result;
  let metadata: BorrowMetadata = borrow_metadata_empty();

  if stmt.kind == HirStmtKind.Let or stmt.kind == HirStmtKind.Const {
    let binding_place: Place = hir_stmt_binding_place(stmt);
    let binding: string = place_name(binding_place);
    let rhs_place: Place = hir_expr_place(stmt.expr);
    let rhs: string = place_name(rhs_place);
    let current0: BorrowCheckResult = current;
    if binding != "" and not has_local(current0.ownership, binding) {
      let ownership0: OwnershipTable = declare_local(current0.ownership, binding, line_no, rhs != "");
      let current1: BorrowCheckResult = replace_ownership(current0, ownership0);
      let lifetimes0: LifetimeResult = current1.lifetimes;
      let ensured: RegionSolution = ensure_region(lifetimes0.regions, binding, line_no);
      let lifetimes1: LifetimeResult = LifetimeResult {
        facts: lifetimes0.facts,
        diagnostics: lifetimes0.diagnostics,
        regions: ensured,
        valid: lifetimes0.valid and ensured.valid
      };
      let current2: BorrowCheckResult = replace_lifetimes(current1, lifetimes1);
      if rhs == "" {
        give current2;
      }
      let owner: string = hir_expr_owner(stmt.expr);
      if owner != "" {
        give handle_borrow_binding(current2, metadata, source_path, binding, owner, hir_expr_is_mutable_borrow(stmt.expr), line_no);
      }
      give handle_move_binding(current2, metadata, source_path, binding, rhs, line_no);
    }
    give current;
  }

  if stmt.kind == HirStmtKind.Set {
    let target_place: Place = hir_stmt_target_place(stmt);
    let rhs_place: Place = hir_expr_place(stmt.expr);
    let rhs_text: string = stmt.expr.text;
    if rhs_place.valid and rhs_text == "" {
      set rhs_text = place_name(rhs_place);
    }
    give handle_set(current, metadata, source_path, place_name(target_place), rhs_text, line_no);
  }
  if stmt.kind == HirStmtKind.Give {
    let value_place: Place = hir_expr_place(stmt.expr);
    let expr_text: string = stmt.expr.text;
    if value_place.valid and expr_text == "" {
      set expr_text = place_name(value_place);
    }
    give handle_give(current, source_path, expr_text, line_no);
  }

  let nested0: BorrowCheckResult = current;
  let i: u64 = 0;
  while i < len(stmt.then_stmts) {
    set nested0 = check_hir_stmt(nested0, source_path, stmt.then_stmts[i]);
    set i = i + 1;
  }
  i = 0;
  while i < len(stmt.else_stmts) {
    set nested0 = check_hir_stmt(nested0, source_path, stmt.else_stmts[i]);
    set i = i + 1;
  }
  give nested0;
}

proc borrow_check_hir(source_path: string, hir: HirUnit) -> BorrowCheckResult {
  let mir: MirUnit = lower_hir_to_mir(hir);
  give borrow_check_hir_mir(source_path, hir, mir);
}
