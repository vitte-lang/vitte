space vitte/compiler/analysis/borrowck/errors

<<< ========================================================= >>>
<<< GENERATED FILE — Borrow Checker Diagnostics             >>>
<<< ========================================================= >>>

const BORROWCK_ERROR_VERSION: u32 = 1
const BORROWCK_INVALID_ID: u64 = 18446744073709551615

pick BorrowErrorKind {
    None
    MoveAfterMove
    MoveOutOfBorrow
    UseAfterMove
    UseAfterFree
    MutableBorrowConflict
    ImmutableBorrowConflict
    MutableAndImmutableConflict
    DanglingReference
    InvalidLifetime
    EscapingReference
    DoubleMutableBorrow
    PartialMove
    InvalidReborrow
    BorrowOutlivesOwner
    InvalidDropOrder
    InvalidCapture
    GeneratorBorrowViolation
    AsyncBorrowViolation
    InteriorMutabilityViolation
    UnsafeAlias
    InvalidRegionFlow
    InvalidLoopBorrow
    InvalidMatchBorrow
    InvalidClosureBorrow
    InvalidPointerEscape
    InvalidTemporaryLifetime
    InvalidGlobalBorrow
    InvalidThreadShare
    InvalidAtomicAccess
    InvalidOwnershipTransfer
    InvalidSelfBorrow
    InvalidTraitBorrow
    InvalidIndexBorrow
    InvalidSliceBorrow
    InvalidFieldBorrow
    InvalidPatternBorrow
    InvalidDestructureBorrow
    InvalidPhiBorrow
    InvalidReturnBorrow
    InvalidYieldBorrow
    Unknown
}

pick BorrowSeverity {
    Info
    Warning
    Error
    Fatal
}

pick BorrowSuggestionKind {
    None
    CloneValue
    AddReference
    AddMutableReference
    IntroduceLifetime
    SplitBorrow
    RestrictScope
    ReorderStatements
    InsertMove
    InsertCopy
    UseArc
    UseRc
    UseCell
    UseRefCell
    UseMutex
    UseRwLock
}

form BorrowSpan {
    file: string
    line: u64
    column: u64
    length: u64
}

form BorrowRegion {
    id: u64
    name: string
    depth: u64
    temporary: bool
}

form BorrowValue {
    id: u64
    name: string
    moved: bool
    borrowed: bool
    mutable: bool
    region: BorrowRegion
}

form BorrowSuggestion {
    kind: BorrowSuggestionKind
    message: string
    replacement: string
}

form BorrowDiagnostic {
    id: u64
    kind: BorrowErrorKind
    severity: BorrowSeverity
    message: string
    span: BorrowSpan
    value: BorrowValue
    suggestions: [BorrowSuggestion]
}

form BorrowErrorReport {
    diagnostics: [BorrowDiagnostic]
    error_count: u64
    warning_count: u64
    fatal_count: u64
    valid: bool
}

proc span_empty() -> BorrowSpan {
    give BorrowSpan {
        file: "",
        line: 0,
        column: 0,
        length: 0
    }
}

proc region_empty() -> BorrowRegion {
    give BorrowRegion {
        id: BORROWCK_INVALID_ID,
        name: "invalid",
        depth: 0,
        temporary: false
    }
}

proc value_empty() -> BorrowValue {
    give BorrowValue {
        id: BORROWCK_INVALID_ID,
        name: "invalid",
        moved: false,
        borrowed: false,
        mutable: false,
        region: region_empty()
    }
}

proc suggestion_none() -> BorrowSuggestion {
    give BorrowSuggestion {
        kind: BorrowSuggestionKind.None,
        message: "",
        replacement: ""
    }
}

proc diagnostic_empty() -> BorrowDiagnostic {
    give BorrowDiagnostic {
        id: BORROWCK_INVALID_ID,
        kind: BorrowErrorKind.None,
        severity: BorrowSeverity.Info,
        message: "",
        span: span_empty(),
        value: value_empty(),
        suggestions: []
    }
}

proc report_empty() -> BorrowErrorReport {
    give BorrowErrorReport {
        diagnostics: [],
        error_count: 0,
        warning_count: 0,
        fatal_count: 0,
        valid: true
    }
}

proc suggestion_create(
    kind: BorrowSuggestionKind,
    message: string,
    replacement: string
) -> BorrowSuggestion {

    give BorrowSuggestion {
        kind: kind,
        message: message,
        replacement: replacement
    }
}

proc diagnostic_create(
    id: u64,
    kind: BorrowErrorKind,
    severity: BorrowSeverity,
    message: string,
    span: BorrowSpan,
    value: BorrowValue
) -> BorrowDiagnostic {

    give BorrowDiagnostic {
        id: id,
        kind: kind,
        severity: severity,
        message: message,
        span: span,
        value: value,
        suggestions: []
    }
}

proc diagnostic_add_suggestion(
    diagnostic: BorrowDiagnostic,
    suggestion: BorrowSuggestion
) -> BorrowDiagnostic {

    give BorrowDiagnostic {
        id: diagnostic.id,
        kind: diagnostic.kind,
        severity: diagnostic.severity,
        message: diagnostic.message,
        span: diagnostic.span,
        value: diagnostic.value,
        suggestions: diagnostic.suggestions + [suggestion]
    }
}

proc report_add(
    report: BorrowErrorReport,
    diagnostic: BorrowDiagnostic
) -> BorrowErrorReport {

    let errors = report.error_count
    let warnings = report.warning_count
    let fatals = report.fatal_count

    if diagnostic.severity == BorrowSeverity.Error {
        set errors = errors + 1
    }

    if diagnostic.severity == BorrowSeverity.Warning {
        set warnings = warnings + 1
    }

    if diagnostic.severity == BorrowSeverity.Fatal {
        set fatals = fatals + 1
    }

    give BorrowErrorReport {
        diagnostics: report.diagnostics + [diagnostic],
        error_count: errors,
        warning_count: warnings,
        fatal_count: fatals,
        valid: fatals == 0
    }
}

proc error_move_after_move(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.MoveAfterMove,
        BorrowSeverity.Error,
        "value moved more than once",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.CloneValue,
        "clone the value before moving",
        ".clone()"
    )

    give diagnostic_add_suggestion(base, suggestion)
}

proc error_use_after_move(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.UseAfterMove,
        BorrowSeverity.Error,
        "use after move detected",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.CloneValue,
        "clone the value before move",
        ".clone()"
    )

    give diagnostic_add_suggestion(base, suggestion)
}

proc error_mutable_conflict(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.MutableBorrowConflict,
        BorrowSeverity.Error,
        "mutable borrow conflicts with existing borrow",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.RestrictScope,
        "reduce mutable borrow scope",
        ""
    )

    give diagnostic_add_suggestion(base, suggestion)
}

proc error_immutable_conflict(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.ImmutableBorrowConflict,
        BorrowSeverity.Error,
        "immutable borrow conflicts with mutable borrow",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.SplitBorrow,
        "split borrows into separate scopes",
        ""
    )

    give diagnostic_add_suggestion(base, suggestion)
}

proc error_dangling_reference(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.DanglingReference,
        BorrowSeverity.Fatal,
        "dangling reference detected",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.IntroduceLifetime,
        "introduce explicit lifetime",
        "'a"
    )

    give diagnostic_add_suggestion(base, suggestion)
}

proc error_invalid_lifetime(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.InvalidLifetime,
        BorrowSeverity.Error,
        "invalid lifetime relation",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.IntroduceLifetime,
        "define explicit lifetime constraints",
        "'a: 'b"
    )

    give diagnostic_add_suggestion(base, suggestion)
}

