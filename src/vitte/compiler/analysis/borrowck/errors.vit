proc report_has_errors(report: BorrowErrorReport) -> bool {
    give report.error_count > 0
}

proc report_has_fatals(report: BorrowErrorReport) -> bool {
    give report.fatal_count > 0
}

proc report_total(report: BorrowErrorReport) -> u64 {
    give vector_len(report.diagnostics)
}

proc severity_name(severity: BorrowSeverity) -> string {
    if severity == BorrowSeverity.Info {
        give "info"
    }

    if severity == BorrowSeverity.Warning {
        give "warning"
    }

    if severity == BorrowSeverity.Error {
        give "error"
    }

    if severity == BorrowSeverity.Fatal {
        give "fatal"
    }

    give "unknown"
}

proc error_name(kind: BorrowErrorKind) -> string {
    if kind == BorrowErrorKind.MoveAfterMove {
        give "move_after_move"
    }

    if kind == BorrowErrorKind.UseAfterMove {
        give "use_after_move"
    }

    if kind == BorrowErrorKind.MutableBorrowConflict {
        give "mutable_borrow_conflict"
    }

    if kind == BorrowErrorKind.ImmutableBorrowConflict {
        give "immutable_borrow_conflict"
    }

    if kind == BorrowErrorKind.DanglingReference {
        give "dangling_reference"
    }

    if kind == BorrowErrorKind.InvalidLifetime {
        give "invalid_lifetime"
    }

    give "borrow_error"
}

proc print_diagnostic(diagnostic: BorrowDiagnostic) {
    emit severity_name(diagnostic.severity)
    emit error_name(diagnostic.kind)
    emit diagnostic.message
    emit diagnostic.span.file
    emit diagnostic.span.line
    emit diagnostic.span.column
}

proc print_report(report: BorrowErrorReport) {
    emit "borrowck report"
    emit report.error_count
    emit report.warning_count
    emit report.fatal_count

    let i: u64 = 0

    loop i < vector_len(report.diagnostics) {
        print_diagnostic(report.diagnostics[i])
        set i = i + 1
    }
}

proc vector_len[T](items: [T]) -> u64 {
    give 0
}