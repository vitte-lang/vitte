    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.PartialMove,
        BorrowSeverity.Error,
        "partial move prevents later access",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.InsertCopy,
        "copy field before partial move",
        ""
    )

    give diagnostic_add_suggestion(base, suggestion)
}

proc error_invalid_drop_order(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.InvalidDropOrder,
        BorrowSeverity.Fatal,
        "drop order invalidates active borrow",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.ReorderStatements,
        "reorder destruction sequence",
        ""
    )

