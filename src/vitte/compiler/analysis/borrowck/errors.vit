space vitte/compiler/analysis/borrowck/errors

use vitte/compiler/diagnostics/diagnostic.{
    Diagnostic,
    DiagnosticReport,
    DiagnosticSeverity,
    DiagnosticPhase,
    SourceSpan,
    diagnostic_error,
    diagnostic_warning,
    diagnostic_fatal,
    diagnostic_with_note,
    diagnostic_with_help,
    diagnostic_with_label,
    diagnostic_with_rule,
    diagnostic_with_explanation,
    diagnostic_with_root_cause,
    diagnostic_add_cause,
    diagnostic_with_probable_fix,
    diagnostic_with_subject_symbol,
    diagnostic_with_subject_borrow,
    secondary_label,
    previous_label,
    add_unique_diagnostic,
    merge_diagnostics,
    diagnostic_report
}

use vitte/compiler/diagnostics/catalog.{
    diagnostic_message,
    diagnostic_default_help,
    diagnostic_default_note
}

const BORROWCK_INVALID_ID: u64 = 18446744073709551615

pick BorrowErrorKind {
    None
    MoveAfterMove
    PartialMove
    UseAfterMove
    BorrowOfMovedValue
    MutableBorrowConflict
    SharedBorrowConflict
    WriteWhileBorrowed
    MoveWhileBorrowed
    DropWhileBorrowed
    AssignWhileBorrowed
    ReturnRefToLocal
    ReturnBorrowOfLocal
    DanglingReference
    LifetimeTooShort
    ImmutableAssign
    UseAfterDrop
    DoubleDrop
    UninitializedUse
    Internal
}

pick BorrowPhase {
    CollectMoves
    CollectLoans
    AliasAnalysis
    CaptureAnalysis
    DropAnalysis
    Dataflow
    RegionCheck
    Validate
    Report
    Unknown
}

form BorrowDiagnosticResult {
    diagnostic: Diagnostic
    kind: BorrowErrorKind
    phase: BorrowPhase
    entity: u64
    valid: bool
}

proc span_create(file: string, line: u64, column: u64, length: u64) -> SourceSpan {
    let normalized_length: u64 = length;

    if normalized_length == 0 {
        set normalized_length = 1 as u64;
    }

    give SourceSpan {
        file: file,
        start_line: line,
        start_column: column,
        end_line: line,
        end_column: column + normalized_length,
        length: normalized_length,
        valid: file != "" and line > 0 and column > 0
    };
}

proc span_empty() -> SourceSpan {
    give span_create("compiler/analysis/borrowck", 0, 0, 1);
}

proc span_with_length(span: SourceSpan, length: u64) -> SourceSpan {
    give span_create(span.file, span.start_line, span.start_column, length);
}

proc error_code(kind: BorrowErrorKind) -> string {
    if kind == BorrowErrorKind.MoveAfterMove {
        give "BORROWCK_E_MOVE_AFTER_MOVE";
    }
    if kind == BorrowErrorKind.PartialMove {
        give "BORROWCK_E_PARTIAL_MOVE";
    }
    if kind == BorrowErrorKind.UseAfterMove {
        give "BORROWCK_E_USE_AFTER_MOVE";
    }
    if kind == BorrowErrorKind.BorrowOfMovedValue {
        give "BORROWCK_E_BORROW_OF_MOVED_VALUE";
    }
    if kind == BorrowErrorKind.MutableBorrowConflict {
        give "BORROWCK_E_MUTABLE_BORROW_CONFLICT";
    }
    if kind == BorrowErrorKind.SharedBorrowConflict {
        give "BORROWCK_E_SHARED_BORROW_CONFLICT";
    }
    if kind == BorrowErrorKind.WriteWhileBorrowed {
        give "BORROWCK_E_WRITE_WHILE_BORROWED";
    }
    if kind == BorrowErrorKind.MoveWhileBorrowed {
        give "BORROWCK_E_MOVE_WHILE_BORROWED";
    }
    if kind == BorrowErrorKind.DropWhileBorrowed {
        give "BORROWCK_E_DROP_WHILE_BORROWED";
    }
    if kind == BorrowErrorKind.AssignWhileBorrowed {
        give "BORROWCK_E_ASSIGN_WHILE_BORROWED";
    }
    if kind == BorrowErrorKind.ReturnRefToLocal {
        give "BORROWCK_E_RETURN_REF_TO_LOCAL";
    }
    if kind == BorrowErrorKind.ReturnBorrowOfLocal {
        give "BORROWCK_E_RETURN_BORROW_OF_LOCAL";
    }
    if kind == BorrowErrorKind.DanglingReference {
        give "BORROWCK_E_DANGLING_REFERENCE";
    }
    if kind == BorrowErrorKind.LifetimeTooShort {
        give "BORROWCK_E_LIFETIME_TOO_SHORT";
    }
    if kind == BorrowErrorKind.ImmutableAssign {
        give "BORROWCK_E_IMMUTABLE_ASSIGN";
    }
    if kind == BorrowErrorKind.UseAfterDrop {
        give "BORROWCK_E_USE_AFTER_DROP";
    }
    if kind == BorrowErrorKind.DoubleDrop {
        give "BORROWCK_E_DOUBLE_DROP";
    }
    if kind == BorrowErrorKind.UninitializedUse {
        give "BORROWCK_E_UNINITIALIZED_USE";
    }
    if kind == BorrowErrorKind.Internal {
        give "BORROWCK_E_INTERNAL";
    }
    give "BORROWCK_E_UNKNOWN";
}

proc borrowck_public_code(code: string) -> string {
    if code == "BORROWCK_E_ASSIGN_WHILE_BORROWED" {
        give "BOR0001";
    }
    if code == "BORROWCK_E_BORROW_OF_MOVED_VALUE" {
        give "BOR0002";
    }
    if code == "BORROWCK_E_DANGLING_REFERENCE" {
        give "BOR0003";
    }
    if code == "BORROWCK_E_DOUBLE_DROP" {
        give "BOR0004";
    }
    if code == "BORROWCK_E_DROP_WHILE_BORROWED" {
        give "BOR0005";
    }
    if code == "BORROWCK_E_IMMUTABLE_ASSIGN" {
        give "BOR0006";
    }
    if code == "BORROWCK_E_INTERNAL" {
        give "BOR0007";
    }
    if code == "BORROWCK_E_LIFETIME_TOO_SHORT" {
        give "BOR0008";
    }
    if code == "BORROWCK_E_MOVE_AFTER_MOVE" {
        give "BOR0010";
    }
    if code == "BORROWCK_E_MOVE_WHILE_BORROWED" {
        give "BOR0011";
    }
    if code == "BORROWCK_E_MUTABLE_BORROW_CONFLICT" {
        give "BOR0013";
    }
    if code == "BORROWCK_E_RETURN_BORROW_OF_LOCAL" {
        give "BOR0014";
    }
    if code == "BORROWCK_E_RETURN_REF_TO_LOCAL" {
        give "BOR0015";
    }
    if code == "BORROWCK_E_SHARED_BORROW_CONFLICT" {
        give "BOR0016";
    }
    if code == "BORROWCK_E_UNINITIALIZED_USE" {
        give "BOR0017";
    }
    if code == "BORROWCK_E_USE_AFTER_DROP" {
        give "BOR0019";
    }
    if code == "BORROWCK_E_USE_AFTER_MOVE" {
        give "BOR0020";
    }
    if code == "BORROWCK_E_WRITE_WHILE_BORROWED" {
        give "BOR0021";
    }
    give code;
}

proc borrow_phase_name(phase: BorrowPhase) -> string {
    if phase == BorrowPhase.CollectMoves {
        give "collect_moves";
    }
    if phase == BorrowPhase.CollectLoans {
        give "collect_loans";
    }
    if phase == BorrowPhase.AliasAnalysis {
        give "alias_analysis";
    }
    if phase == BorrowPhase.CaptureAnalysis {
        give "capture_analysis";
    }
    if phase == BorrowPhase.DropAnalysis {
        give "drop_analysis";
    }
    if phase == BorrowPhase.Dataflow {
        give "dataflow";
    }
    if phase == BorrowPhase.RegionCheck {
        give "region_check";
    }
    if phase == BorrowPhase.Validate {
        give "validate";
    }
    if phase == BorrowPhase.Report {
        give "report";
    }
    give "unknown";
}

proc borrow_phase_user_text(phase: BorrowPhase) -> string {
    if phase == BorrowPhase.CollectMoves {
        give "the compiler is reading where values are moved";
    }
    if phase == BorrowPhase.CollectLoans {
        give "the compiler is reading where values are borrowed";
    }
    if phase == BorrowPhase.AliasAnalysis {
        give "the compiler is checking whether two names can refer to the same value";
    }
    if phase == BorrowPhase.CaptureAnalysis {
        give "the compiler is checking values captured by nested code";
    }
    if phase == BorrowPhase.DropAnalysis {
        give "the compiler is checking where values are destroyed";
    }
    if phase == BorrowPhase.Dataflow {
        give "the compiler is following ownership through the control flow";
    }
    if phase == BorrowPhase.RegionCheck {
        give "the compiler is checking that every borrow ends before its owner is destroyed";
    }
    if phase == BorrowPhase.Validate {
        give "the compiler is validating the ownership facts before reporting";
    }
    if phase == BorrowPhase.Report {
        give "the compiler is preparing the user-facing borrow diagnostic";
    }
    give "the compiler is checking Vitte ownership rules";
}

proc borrow_message(code: string, fallback: string) -> string {
    let msg: string = diagnostic_message(code);

    if msg != "" {
        give msg;
    }

    give fallback;
}

proc borrow_help(code: string, fallback: string) -> string {
    let help: string = diagnostic_default_help(code);

    if help != "" {
        give help;
    }

    give fallback;
}

proc borrow_note(code: string, fallback: string) -> string {
    let note: string = diagnostic_default_note(code);

    if note != "" {
        give note;
    }

    give fallback;
}

proc severity_for_fatal(fatal: bool) -> DiagnosticSeverity {
    if fatal {
        give DiagnosticSeverity.Fatal;
    }

    give DiagnosticSeverity.Error;
}

proc diagnostic_from_severity(code: string, severity: DiagnosticSeverity, message: string, span: SourceSpan) -> Diagnostic {
    if severity == DiagnosticSeverity.Fatal {
        give diagnostic_fatal(code, DiagnosticPhase.Borrowck, message, span);
    }

    if severity == DiagnosticSeverity.Warning {
        give diagnostic_warning(code, DiagnosticPhase.Borrowck, message, span);
    }

    give diagnostic_error(code, DiagnosticPhase.Borrowck, message, span);
}

proc attach_labels_and_help(diagnostic: Diagnostic, labels: [string], suggestion: string, span: SourceSpan) -> Diagnostic {
    let diag: Diagnostic = diagnostic;
    let i: u64 = 0;

    while i < len(labels) {
        if labels[i] != "" {
            set diag = diagnostic_with_label(diag, secondary_label(labels[i], span));
        }

        set i = i + 1;
    }

    if suggestion != "" {
        set diag = diagnostic_with_help(diag, suggestion);
    }

    give diag;
}

proc attach_borrow_context(diagnostic: Diagnostic, code: string, phase: BorrowPhase, entity: u64) -> Diagnostic {
    let diag: Diagnostic = diagnostic;

    set diag = diagnostic_with_note(diag, borrow_phase_user_text(phase));

    let note: string = diagnostic_default_note(code);

    if note != "" {
        set diag = diagnostic_with_note(diag, note);
    }

    give diag;
}

proc diagnostic_create(kind: BorrowErrorKind, file: string, line: u64, message: string, labels: [string], suggestion: string, fatal: bool) -> Diagnostic {
    let code: string = borrowck_public_code(error_code(kind));
    let resolved_message: string = borrow_message(code, message);
    let resolved_help: string = borrow_help(code, suggestion);
    let length: u64 = 1;

    if len(labels) > 0 and labels[0] != "" {
        set length = len(labels[0]) as u64;
    }

    let span: SourceSpan = span_create(file, line, 1, length);

    let diag: Diagnostic = diagnostic_from_severity(
        code,
        severity_for_fatal(fatal),
        resolved_message,
        span
    );

    give attach_labels_and_help(diag, labels, resolved_help, span);
}

proc diagnostic_full(kind: BorrowErrorKind, severity: DiagnosticSeverity, phase: BorrowPhase, message: string, labels: [string], suggestion: string, span: SourceSpan, entity: u64) -> Diagnostic {
    let code: string = borrowck_public_code(error_code(kind));
    let resolved_message: string = borrow_message(code, message);
    let resolved_help: string = borrow_help(code, suggestion);

    let diag: Diagnostic = diagnostic_from_severity(
        code,
        severity,
        resolved_message,
        span
    );

    set diag = attach_borrow_context(diag, code, phase, entity);

    give attach_labels_and_help(diag, labels, resolved_help, span);
}

proc borrow_diagnostic_result(diagnostic: Diagnostic, kind: BorrowErrorKind, phase: BorrowPhase, entity: u64) -> BorrowDiagnosticResult {
    give BorrowDiagnosticResult {
        diagnostic: diagnostic,
        kind: kind,
        phase: phase,
        entity: entity,
        valid: diagnostic.valid
    };
}

proc add_unique_borrow_diagnostic(diagnostics: [Diagnostic], diagnostic: Diagnostic) -> [Diagnostic] {
    give add_unique_diagnostic(diagnostics, diagnostic);
}

proc merge_borrow_diagnostics(left: [Diagnostic], right: [Diagnostic]) -> [Diagnostic] {
    give merge_diagnostics(left, right);
}

proc diagnostics_has_fatal(diagnostics: [Diagnostic]) -> bool {
    give diagnostic_report(diagnostics).fatal_count > 0;
}

proc diagnostics_have_errors(diagnostics: [Diagnostic]) -> bool {
    let report: DiagnosticReport = diagnostic_report(diagnostics);

    give report.error_count > 0 or report.fatal_count > 0;
}

proc diagnostics_valid(diagnostics: [Diagnostic]) -> bool {
    give diagnostic_report(diagnostics).valid;
}

proc borrow_report(diagnostics: [Diagnostic]) -> DiagnosticReport {
    give diagnostic_report(diagnostics);
}

proc borrow_report_empty() -> DiagnosticReport {
    give diagnostic_report([]);
}

proc borrow_report_add(report: DiagnosticReport, diagnostic: Diagnostic) -> DiagnosticReport {
    give diagnostic_report(add_unique_diagnostic(report.diagnostics, diagnostic));
}

proc borrow_error_generic(kind: BorrowErrorKind, file: string, line: u64, entity: u64, fallback_message: string, fallback_note: string, fallback_help: string) -> Diagnostic {
    let code: string = borrowck_public_code(error_code(kind));
    let span: SourceSpan = span_create(file, line, 1, 1);
    let message: string = borrow_message(code, fallback_message);

    let diag: Diagnostic = diagnostic_error(
        code,
        DiagnosticPhase.Borrowck,
        message,
        span
    );

    set diag = attach_borrow_context(diag, code, BorrowPhase.Dataflow, entity);
    set diag = diagnostic_with_note(diag, borrow_note(code, fallback_note));
    set diag = diagnostic_with_help(diag, borrow_help(code, fallback_help));

    give diag;
}

proc borrow_error_temporal_story(kind: BorrowErrorKind, name: string, primary_message: string, use_span: SourceSpan, previous_span: SourceSpan, previous_message: string, lifetime_text: string, probable_fix: string, entity: u64) -> Diagnostic {
    let code: string = borrowck_public_code(error_code(kind));
    let conflict_text: string = if kind == BorrowErrorKind.UseAfterMove {
        "conflict appears here: `" + name + "` is used after ownership moved"
    } elif kind == BorrowErrorKind.MoveAfterMove {
        "conflict appears here: `" + name + "` is moved again"
    } elif kind == BorrowErrorKind.PartialMove {
        "conflict appears here: `" + name + "` is used after one of its fields was moved"
    } elif kind == BorrowErrorKind.MoveWhileBorrowed {
        "conflict appears here: `" + name + "` is moved while a borrow is still active"
    } elif kind == BorrowErrorKind.MutableBorrowConflict {
        "conflict appears here: a second mutable borrow of `" + name + "` requires exclusive access"
    } elif kind == BorrowErrorKind.SharedBorrowConflict {
        "conflict appears here: immutable borrow of `" + name + "` overlaps an active mutable borrow"
    } elif kind == BorrowErrorKind.WriteWhileBorrowed or kind == BorrowErrorKind.AssignWhileBorrowed {
        "conflict appears here: `set` mutates `" + name + "` while a borrow is active"
    } elif kind == BorrowErrorKind.DropWhileBorrowed {
        "conflict appears here: `" + name + "` is destroyed while a borrow is active"
    } elif kind == BorrowErrorKind.LifetimeTooShort or kind == BorrowErrorKind.DanglingReference or kind == BorrowErrorKind.ReturnRefToLocal or kind == BorrowErrorKind.ReturnBorrowOfLocal {
        "conflict appears here: reference to `" + name + "` would outlive its owner"
    } else {
        "conflict appears here for `" + name + "`"
    };
    let previous_text: string = if kind == BorrowErrorKind.UseAfterMove or kind == BorrowErrorKind.MoveAfterMove {
        "value was moved here"
    } elif kind == BorrowErrorKind.PartialMove {
        previous_message
    } elif kind == BorrowErrorKind.MoveWhileBorrowed or kind == BorrowErrorKind.MutableBorrowConflict or kind == BorrowErrorKind.SharedBorrowConflict or kind == BorrowErrorKind.WriteWhileBorrowed or kind == BorrowErrorKind.AssignWhileBorrowed or kind == BorrowErrorKind.DropWhileBorrowed or kind == BorrowErrorKind.LifetimeTooShort or kind == BorrowErrorKind.DanglingReference or kind == BorrowErrorKind.ReturnRefToLocal or kind == BorrowErrorKind.ReturnBorrowOfLocal {
        previous_message + "; borrow is still active at the conflict"
    } else {
        previous_message
    };
    let diag0: Diagnostic = diagnostic_error(
        code,
        DiagnosticPhase.Borrowck,
        borrow_message(code, primary_message),
        use_span
    );
    let diag1: Diagnostic = attach_borrow_context(
        diag0,
        code,
        BorrowPhase.Dataflow,
        entity
    );
    let diag2: Diagnostic = diagnostic_with_rule(
        diag1,
        "borrowed values must remain valid and non-conflicting for the whole borrow duration"
    );
    let diag3: Diagnostic = diagnostic_with_subject_symbol(
        diag2,
        name
    );
    let diag4: Diagnostic = diagnostic_with_subject_borrow(
        diag3,
        lifetime_text
    );
    let diag5: Diagnostic = diagnostic_with_label(
        diag4,
        previous_label(
            previous_text,
            previous_span
        )
    );
    let diag6: Diagnostic = diagnostic_with_label(
        diag5,
        secondary_label(
            conflict_text,
            use_span
        )
    );
    let diag7: Diagnostic = diagnostic_with_explanation(
        diag6,
        "Vitte rejected this ownership step because `" + name + "` was already committed to an earlier move or borrow that still matters here"
    );
    let diag8: Diagnostic = diagnostic_with_root_cause(
        diag7,
        "the earlier code event overlaps this later operation on `" + name + "`"
    );
    let previous_line_text: string = previous_span.start_line as string;
    let use_line_text: string = use_span.start_line as string;
    let diag9: Diagnostic = diagnostic_add_cause(
        diag8,
        "chronology step 1: `" + name + "` is created before the first highlighted ownership event"
    );
    let diag10: Diagnostic = diagnostic_add_cause(
        diag9,
        "chronology step 2: " + previous_text + " at line " + previous_line_text
    );
    let diag11: Diagnostic = diagnostic_add_cause(
        diag10,
        "chronology step 3: " + conflict_text + " at line " + use_line_text
    );
    let has_borrow_lifetime: bool = kind == BorrowErrorKind.MoveWhileBorrowed or kind == BorrowErrorKind.MutableBorrowConflict or kind == BorrowErrorKind.SharedBorrowConflict or kind == BorrowErrorKind.WriteWhileBorrowed or kind == BorrowErrorKind.AssignWhileBorrowed or kind == BorrowErrorKind.DropWhileBorrowed or kind == BorrowErrorKind.LifetimeTooShort or kind == BorrowErrorKind.DanglingReference or kind == BorrowErrorKind.ReturnRefToLocal or kind == BorrowErrorKind.ReturnBorrowOfLocal;
    let diag12: Diagnostic = if has_borrow_lifetime and lifetime_text != "" {
        diagnostic_add_cause(diag11, "chronology step 4: borrow ends " + lifetime_text)
    } else {
        diagnostic_add_cause(diag11, "chronology step 4: the value can be reused only after a new `let` initialization or a valid `set`")
    };
    let diag13: Diagnostic = diagnostic_add_cause(
        diag12,
        "where the value is reused: line " + use_line_text
    );

    let diag14: Diagnostic = diagnostic_with_probable_fix(
        diag13,
        probable_fix
    );
    give diagnostic_with_help(
        diag14,
        "rewrite the ownership path so the earlier event no longer conflicts with this use; shorten the borrow, clone explicitly, or move the later access"
    );
}

proc borrow_error_move_after_move(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.MoveAfterMove,
        file,
        line,
        entity,
        "value was moved more than once",
        "ownership was already transferred by a previous move",
        "borrow the value or clone it before moving again"
    );
}

proc borrow_error_use_after_move(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.UseAfterMove,
        file,
        line,
        entity,
        "value used after move",
        "moved values cannot be used again until reinitialized",
        "borrow the value or clone it before the move"
    );
}

proc borrow_error_use_after_move_story(file: string, name: string, use_line: u64, move_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.UseAfterMove,
        name,
        "value `" + name + "` used after move",
        span_create(file, use_line, 1, 1),
        span_create(file, move_line, 1, 1),
        "move happened here",
        lifetime_text,
        "clone `" + name + "`, borrow it instead, or reinitialize it before the later use",
        entity
    );
}

proc borrow_error_move_after_move_story(file: string, name: string, current_line: u64, previous_move_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.MoveAfterMove,
        name,
        "value `" + name + "` was moved more than once",
        span_create(file, current_line, 1, 1),
        span_create(file, previous_move_line, 1, 1),
        "first move happened here",
        lifetime_text,
        "clone `" + name + "`, borrow it, or reinitialize it before moving again",
        entity
    );
}

proc borrow_error_partial_move(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.PartialMove,
        file,
        line,
        entity,
        "value used after one of its fields was moved",
        "moving a field can leave the rest of the form only partly available",
        "move the whole value, clone the field, or rebuild the form before using it again"
    );
}

proc borrow_error_partial_move_story(file: string, name: string, use_line: u64, field_move_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.PartialMove,
        name,
        "value `" + name + "` is used after a partial move",
        span_create(file, use_line, 1, 1),
        span_create(file, field_move_line, 1, 1),
        "one field was moved here",
        lifetime_text,
        "rebuild `" + name + "`, avoid moving the field, or move the whole value once",
        entity
    );
}

proc borrow_error_borrow_of_moved_value(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.BorrowOfMovedValue,
        file,
        line,
        entity,
        "cannot borrow moved value",
        "the value no longer has an owner at this program point",
        "borrow before moving, or reinitialize the value before borrowing"
    );
}

proc borrow_error_mutable_borrow_conflict(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.MutableBorrowConflict,
        file,
        line,
        entity,
        "mutable borrow conflicts with another active borrow",
        "a mutable borrow requires exclusive access, so it cannot overlap another mutable or immutable borrow",
        "end the previous borrow before taking this mutable borrow"
    );
}

proc borrow_error_mutable_borrow_conflict_story(file: string, name: string, request_line: u64, active_borrow_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.MutableBorrowConflict,
        name,
        "mutable borrow of `" + name + "` conflicts with another active borrow",
        span_create(file, request_line, 1, 1),
        span_create(file, active_borrow_line, 1, 1),
        "active borrow starts here",
        lifetime_text,
        "shorten the earlier borrow, create a nested scope, or switch to a shared reference",
        entity
    );
}

proc borrow_error_shared_borrow_conflict(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.SharedBorrowConflict,
        file,
        line,
        entity,
        "immutable borrow conflicts with an active mutable borrow",
        "immutable access cannot overlap exclusive mutable access",
        "end the mutable borrow before taking the immutable borrow"
    );
}

proc borrow_error_shared_borrow_conflict_story(file: string, name: string, request_line: u64, active_borrow_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.SharedBorrowConflict,
        name,
        "immutable borrow of `" + name + "` conflicts with an active mutable borrow",
        span_create(file, request_line, 1, 1),
        span_create(file, active_borrow_line, 1, 1),
        "mutable borrow starts here",
        lifetime_text,
        "end the mutable borrow sooner or keep every later use behind the same mutable reference",
        entity
    );
}

proc borrow_error_write_while_borrowed(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.WriteWhileBorrowed,
        file,
        line,
        entity,
        "cannot write while value is borrowed",
        "an active borrow prevents mutation of this value",
        "end the borrow before writing or use a separate value"
    );
}

proc borrow_error_move_while_borrowed(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.MoveWhileBorrowed,
        file,
        line,
        entity,
        "cannot move while value is borrowed",
        "active borrows keep the value available for their lifetime",
        "end the borrow before moving the value"
    );
}

proc borrow_error_move_while_borrowed_story(file: string, name: string, move_line: u64, borrow_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.MoveWhileBorrowed,
        name,
        "cannot move `" + name + "` while it is still borrowed",
        span_create(file, move_line, 1, 1),
        span_create(file, borrow_line, 1, 1),
        "borrow starts here",
        lifetime_text,
        "clone the value, move it after the borrow ends, or shorten the borrow scope",
        entity
    );
}

proc borrow_error_drop_while_borrowed(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.DropWhileBorrowed,
        file,
        line,
        entity,
        "cannot destroy value while it is borrowed",
        "destroying the owner would invalidate active borrows",
        "let all borrows end before the value is destroyed"
    );
}

proc borrow_error_drop_while_borrowed_story(file: string, name: string, drop_line: u64, borrow_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.DropWhileBorrowed,
        name,
        "cannot destroy `" + name + "` while it is still borrowed",
        span_create(file, drop_line, 1, 1),
        span_create(file, borrow_line, 1, 1),
        "borrow starts here",
        lifetime_text,
        "destroy `" + name + "` only after the borrow ends, or shorten the borrow scope",
        entity
    );
}

proc borrow_error_assign_while_borrowed(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.AssignWhileBorrowed,
        file,
        line,
        entity,
        "cannot `set` value while it is borrowed",
        "`set` would overwrite storage referenced by an active borrow",
        "end the borrow before assigning a new value with `set`"
    );
}

proc borrow_error_assign_while_borrowed_story(file: string, name: string, assign_line: u64, borrow_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.AssignWhileBorrowed,
        name,
        "cannot `set` `" + name + "` while it is still borrowed",
        span_create(file, assign_line, 1, 1),
        span_create(file, borrow_line, 1, 1),
        "borrow starts here",
        lifetime_text,
        "move the `set` after the borrow ends or shorten the borrow scope",
        entity
    );
}

proc borrow_error_return_ref_to_local(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.ReturnRefToLocal,
        file,
        line,
        entity,
        "cannot return reference to local value",
        "local storage is destroyed when the current scope ends",
        "return an owned value or store the value in longer-lived storage"
    );
}

proc borrow_error_return_ref_to_local_story(file: string, name: string, give_line: u64, local_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.ReturnRefToLocal,
        name,
        "cannot `give` a reference to local `" + name + "`",
        span_create(file, give_line, 1, 1),
        span_create(file, local_line, 1, 1),
        "local value is created here",
        lifetime_text,
        "return an owned value or move the owner to a longer-lived scope",
        entity
    );
}

proc borrow_error_return_borrow_of_local(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.ReturnBorrowOfLocal,
        file,
        line,
        entity,
        "cannot return borrow of local value",
        "the borrow cannot outlive the local owner",
        "return an owned value instead of a borrow"
    );
}

proc borrow_error_dangling_reference(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.DanglingReference,
        file,
        line,
        entity,
        "reference may outlive the value it points to",
        "the owner can be destroyed before the reference is used",
        "extend the owner lifetime or return an owned value instead"
    );
}

proc borrow_error_lifetime_too_short(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.LifetimeTooShort,
        file,
        line,
        entity,
        "lifetime does not live long enough",
        "the reference needs the owner to remain valid longer",
        "extend the owner lifetime or avoid storing the borrow beyond the owner"
    );
}

proc borrow_error_lifetime_too_short_story(file: string, name: string, borrow_line: u64, owner_end_line: u64, lifetime_text: string, entity: u64) -> Diagnostic {
    give borrow_error_temporal_story(
        BorrowErrorKind.LifetimeTooShort,
        name,
        "borrow of `" + name + "` outlives its owner",
        span_create(file, owner_end_line, 1, 1),
        span_create(file, borrow_line, 1, 1),
        "borrow starts here",
        lifetime_text,
        "move the owner to a longer-lived scope or keep the reference in a shorter scope",
        entity
    );
}

proc borrow_error_use_after_drop(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.UseAfterDrop,
        file,
        line,
        entity,
        "value used after drop",
        "the value has already been destroyed",
        "avoid using the value after drop or reinitialize it first"
    );
}

proc borrow_error_double_drop(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.DoubleDrop,
        file,
        line,
        entity,
        "value dropped more than once",
        "dropping an already destroyed value is invalid",
        "ensure each owned value is dropped exactly once"
    );
}

proc borrow_error_uninitialized_use(file: string, line: u64, entity: u64) -> Diagnostic {
    give borrow_error_generic(
        BorrowErrorKind.UninitializedUse,
        file,
        line,
        entity,
        "use of uninitialized value",
        "the value has not been initialized on every control-flow path",
        "initialize the value before reading it"
    );
}

proc borrow_error_internal(file: string, line: u64, message: string) -> Diagnostic {
    let code: string = error_code(BorrowErrorKind.Internal);
    let span: SourceSpan = span_create(file, line, 1, 1);
    let resolved_message: string = borrow_message(code, message);

    let diag: Diagnostic = diagnostic_fatal(
        code,
        DiagnosticPhase.Borrowck,
        resolved_message,
        span
    );

    set diag = diagnostic_with_note(diag, borrow_note(code, "internal compiler error in borrow checking"));
    set diag = diagnostic_with_help(diag, borrow_help(code, "report this compiler error with a minimal reproduction"));

    give diag;
}

proc diagnostic_summary(diagnostic: Diagnostic) -> string {
    give diagnostic.code + ": " + diagnostic.message;
}

proc report_summary(report: DiagnosticReport) -> string {
    if report.valid {
        give "borrowck ok";
    }

    let text: string = "borrowck failed: ";
    let error_text: string = report.error_count as string;
    let fatal_text: string = report.fatal_count as string;
    set text = text + error_text;
    set text = text + " error(s), ";
    set text = text + fatal_text;
    set text = text + " fatal(s)";
    give text;
}

