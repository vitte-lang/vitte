    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.InvalidThreadShare,
        BorrowSeverity.Fatal,
        "non thread-safe value shared across threads",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.UseMutex,
        "protect shared state with mutex",
        "Mutex<T>"
    )

