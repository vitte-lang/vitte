    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.EscapingReference,
        BorrowSeverity.Fatal,
        "reference escapes valid region",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.RestrictScope,
        "reduce reference lifetime",
        ""
    )

