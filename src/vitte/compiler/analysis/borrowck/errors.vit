proc error_async_borrow(
    id: u64,
    value: BorrowValue,
    span: BorrowSpan
) -> BorrowDiagnostic {

    let base = diagnostic_create(
        id,
        BorrowErrorKind.AsyncBorrowViolation,
        BorrowSeverity.Error,
        "borrow crosses async suspension point",
        span,
        value
    )

    let suggestion = suggestion_create(
        BorrowSuggestionKind.UseArc,
        "wrap shared state in Arc",
        "Arc<T>"
    )

    give diagnostic_add_suggestion(base, suggestion)
}

