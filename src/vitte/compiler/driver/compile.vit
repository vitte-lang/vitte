use vitte/compiler/driver/exit_status.{ DriverExitStatus }

pick DriverDiagnosticLevel {
    Note,
    Warning,
    Error,
}

form DriverDiagnostic {
    level: DriverDiagnosticLevel
    stage: string
    code: string
    message: string
    valid: bool
}

form DriverCompileResult {
    status: DriverExitStatus
    message: string
    ir_valid: bool
    backend_name: string
    target_name: string
    profile_name: string
    opt_level: string
    packaging: string
    deterministic: bool
    debug_enabled: bool
    emit_debug_sections: bool
    lto_enabled: bool
    pgo_mode: string
    prefer_native_toolchain: bool
    llvm_toolchain_summary: string
    codegen_object_format: string
    codegen_section_count: u64
    diagnostics: [DriverDiagnostic]
    grammar_version: string
    token_count: u64
    toplevel_count: u64
    stmt_count: u64
    expr_count: u64
    type_count: u64
    pattern_count: u64
}

form DriverCompileConfig {
    backend_name: string
    target_name: string
    profile_name: string
    opt_level: string
    packaging: string
    deterministic: bool
    debug_enabled: bool
    emit_debug_sections: bool
    lto_enabled: bool
    pgo_mode: string
    prefer_native_toolchain: bool
    llvm_toolchain: LlvmToolchainPaths
    valid: bool
}

proc json_escape(text: string) -> string {
    let escaped: string = "";
    let i: u64 = 0;
    while i < len(text) {
        let ch: string = slice(text, i, i + 1);
        if ch == "\\" {
            set escaped = escaped + "\\\\";
        } elif ch == "\"" {
            set escaped = escaped + "\\\"";
        } elif ch == "\n" {
            set escaped = escaped + "\\n";
        } elif ch == "\r" {
            set escaped = escaped + "\\r";
        } elif ch == "\t" {
            set escaped = escaped + "\\t";
        } else {
            set escaped = escaped + ch;
        }
        set i = i + 1;
    }
    give escaped;
}

proc profile_opt_level(profile_name: string) -> string {
    if profile_name == "enterprise-debug" {
        give "O0";
    }
    if profile_name == "enterprise-size" {
        give "Oz";
    }
    if profile_name == "enterprise-release" or profile_name == "enterprise-lto" or profile_name == "enterprise-pgo" {
        give "O3";
    }
    give "O2";
}

proc profile_packaging(profile_name: string) -> string {
    if profile_name == "enterprise-static" {
        give "static-library";
    }
    if profile_name == "enterprise-shared" {
        give "shared-library";
    }
    give "executable";
}

proc profile_lto_enabled(profile_name: string) -> bool {
    give profile_name == "enterprise-lto" or profile_name == "enterprise-release";
}

proc profile_pgo_mode(profile_name: string) -> string {
    if profile_name == "enterprise-pgo" {
        give "instrument";
    }
    give "off";
}

proc profile_emit_debug_sections(profile_name: string, debug_enabled: bool) -> bool {
    if profile_name == "enterprise-debug" {
        give true;
    }
    give debug_enabled;
}

proc driver_compile_config_full(backend_name: string, target_name: string, profile_name: string, opt_level: string, packaging: string, deterministic: bool, debug_enabled: bool, emit_debug_sections: bool, lto_enabled: bool, pgo_mode: string, prefer_native_toolchain: bool, llvm_toolchain: LlvmToolchainPaths) -> DriverCompileConfig {
    give DriverCompileConfig {
        backend_name: backend_name,
        target_name: target_name,
        profile_name: profile_name,
        opt_level: opt_level,
        packaging: packaging,
        deterministic: deterministic,
        debug_enabled: debug_enabled,
        emit_debug_sections: emit_debug_sections,
        lto_enabled: lto_enabled,
        pgo_mode: pgo_mode,
        prefer_native_toolchain: prefer_native_toolchain,
        llvm_toolchain: llvm_toolchain,
        valid: backend_name != "" and target_name != "" and profile_name != "" and opt_level != "" and packaging != ""
    };
}

proc driver_compile_config(backend_name: string, target_name: string, profile_name: string, deterministic: bool, debug_enabled: bool) -> DriverCompileConfig {
    give driver_compile_config_full(
        backend_name,
        target_name,
        profile_name,
        profile_opt_level(profile_name),
        profile_packaging(profile_name),
        deterministic,
        debug_enabled,
        profile_emit_debug_sections(profile_name, debug_enabled),
        profile_lto_enabled(profile_name),
        profile_pgo_mode(profile_name),
        false,
        default_llvm_toolchain_paths()
    );
}

proc default_compile_config() -> DriverCompileConfig {
    give driver_compile_config("x86_64", "x86_64-linux", "enterprise-default", true, true);
}

proc driver_diagnostic(level: DriverDiagnosticLevel, stage: string, code: string, message: string) -> DriverDiagnostic {
    give DriverDiagnostic {
        level: level,
        stage: stage,
        code: code,
        message: message,
        valid: stage != "" and code != "" and message != ""
    };
}

proc config_diagnostics(config: DriverCompileConfig) -> [DriverDiagnostic] {
    let diagnostics: [DriverDiagnostic] = [];
    if config.emit_debug_sections and not config.debug_enabled {
        set diagnostics = diagnostics + [driver_diagnostic(DriverDiagnosticLevel.Warning, "driver", "config.debug.mismatch", "debug sections requested while debug is disabled")];
    }
    if config.prefer_native_toolchain and config.backend_name != "llvm" and config.backend_name != "llvm-ir" {
        set diagnostics = diagnostics + [driver_diagnostic(DriverDiagnosticLevel.Note, "driver", "config.native.inert", "native LLVM toolchain request is ignored for the current backend")];
    }
    if config.lto_enabled and config.backend_name != "llvm" and config.backend_name != "llvm-ir" {
        set diagnostics = diagnostics + [driver_diagnostic(DriverDiagnosticLevel.Note, "driver", "config.lto.inert", "LTO is recorded but inactive for the current backend")];
    }
    if config.pgo_mode != "off" and config.backend_name != "llvm" and config.backend_name != "llvm-ir" {
        set diagnostics = diagnostics + [driver_diagnostic(DriverDiagnosticLevel.Note, "driver", "config.pgo.inert", "PGO is recorded but inactive for the current backend")];
    }
    give diagnostics;
}

proc codegen_diagnostics(codegen: CodegenResult) -> [DriverDiagnostic] {
    let diagnostics: [DriverDiagnostic] = [];
    let built: [DriverDiagnostic] = diagnostics;
    let i: u64 = 0;
    while i < len(codegen.diagnostics) {
        let diag0 = codegen.diagnostics[i];
        let level = if diag0.level == LlvmDiagnosticLevel.Error {
            DriverDiagnosticLevel.Error
        } elif diag0.level == LlvmDiagnosticLevel.Warning {
            DriverDiagnosticLevel.Warning
        } else {
            DriverDiagnosticLevel.Note
        };
        set built = built + [driver_diagnostic(level, diag0.stage, diag0.code, diag0.message)];
        set i = i + 1;
    }
    i = 0;
    while i < len(codegen.errors) {
        set built = built + [driver_diagnostic(DriverDiagnosticLevel.Error, "codegen", "codegen.error", codegen.errors[i])];
        set i = i + 1;
    }
    give built;
}

proc backend_supports_target(backend_name: string, target_name0: string) -> bool {
    if backend_name == "x86_64" {
        give target_name0 == "x86_64-linux";
    }
    if backend_name == "llvm" or backend_name == "llvm-ir" {
        give target_name0 == "x86_64-linux" or target_name0 == "aarch64-linux" or target_name0 == "riscv64-linux" or target_name0 == "i386-linux";
    }
    give false;
}

proc config_support_message(config: DriverCompileConfig) -> string {
    if not config.valid {
        give "invalid compile configuration";
    }
    if config.opt_level != "O0" and config.opt_level != "O1" and config.opt_level != "O2" and config.opt_level != "O3" and config.opt_level != "Os" and config.opt_level != "Oz" {
        give "unsupported optimization level: " + config.opt_level;
    }
    if config.packaging != "executable" and config.packaging != "static-library" and config.packaging != "shared-library" and config.packaging != "object" {
        give "unsupported packaging mode: " + config.packaging;
    }
    if config.pgo_mode != "off" and config.pgo_mode != "instrument" and config.pgo_mode != "use" {
        give "unsupported pgo mode: " + config.pgo_mode;
    }
    if not backend_supports_target(config.backend_name, config.target_name) {
        give "unsupported backend/target combination: " + config.backend_name + " -> " + config.target_name;
    }
    give "";
}

proc artifact_kind_from_packaging(packaging: string) -> LinkArtifactKind {
    if packaging == "static-library" {
        give LinkArtifactKind.StaticLibrary;
    }
    if packaging == "shared-library" {
        give LinkArtifactKind.SharedLibrary;
    }
    if packaging == "object" {
        give LinkArtifactKind.ObjectFile;
    }
    give LinkArtifactKind.Executable;
}

proc empty_compile_result(status: DriverExitStatus, message: string, ir_valid: bool, config: DriverCompileConfig) -> DriverCompileResult {
    let diagnostics: [DriverDiagnostic] = config_diagnostics(config);
    give DriverCompileResult {
        status: status,
        message: message,
        ir_valid: ir_valid,
        backend_name: config.backend_name,
        target_name: config.target_name,
        profile_name: config.profile_name,
        opt_level: config.opt_level,
        packaging: config.packaging,
        deterministic: config.deterministic,
        debug_enabled: config.debug_enabled,
        emit_debug_sections: config.emit_debug_sections,
        lto_enabled: config.lto_enabled,
        pgo_mode: config.pgo_mode,
        prefer_native_toolchain: config.prefer_native_toolchain,
        llvm_toolchain_summary: "",
        codegen_object_format: "",
        codegen_section_count: 0,
        diagnostics: diagnostics,
        grammar_version: "",
        token_count: 0,
        toplevel_count: 0,
        stmt_count: 0,
        expr_count: 0,
        type_count: 0,
        pattern_count: 0
    };
}

proc frontend_compile_result(status: DriverExitStatus, message: string, ir_valid: bool, fe: FrontendOutput, config: DriverCompileConfig) -> DriverCompileResult {
    let diagnostics: [DriverDiagnostic] = config_diagnostics(config);
    give DriverCompileResult {
        status: status,
        message: message,
        ir_valid: ir_valid,
        backend_name: config.backend_name,
        target_name: config.target_name,
        profile_name: config.profile_name,
        opt_level: config.opt_level,
        packaging: config.packaging,
        deterministic: config.deterministic,
        debug_enabled: config.debug_enabled,
        emit_debug_sections: config.emit_debug_sections,
        lto_enabled: config.lto_enabled,
        pgo_mode: config.pgo_mode,
        prefer_native_toolchain: config.prefer_native_toolchain,
        llvm_toolchain_summary: "",
        codegen_object_format: "",
        codegen_section_count: 0,
        diagnostics: diagnostics,
        grammar_version: fe.grammar_version,
        token_count: fe.token_count,
        toplevel_count: fe.toplevel_count,
        stmt_count: fe.stmt_count,
        expr_count: fe.expr_count,
        type_count: fe.type_count,
        pattern_count: fe.pattern_count
    };
}

