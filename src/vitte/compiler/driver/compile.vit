space vitte/compiler/driver

use vitte/compiler/infrastructure/session/options { SessionOptions, default_options }
use vitte/compiler/driver/pipeline { localized_status }

proc compile_once() -> [string] {
  let options: SessionOptions = default_options()
  let start: string = localized_status(options, "driver-start")
  let done: string = localized_status(options, "driver-done")
  give [start, done]
}
