pick CompilerMode {
    Check,
    Build,
    Run,
    Test,
    EmitAst,
    EmitHir,
    EmitMir,
    EmitIr,
    EmitObject,
    EmitAssembly,
}

pick CompilerStage {
    Init,
    Configure,
    LoadInput,
    Lex,
    Parse,
    Ast,
    Hir,
    Resolve,
    Typeck,
    Borrowck,
    Mir,
    MirValidate,
    MirOptimize,
    Ir,
    IrValidate,
    Codegen,
    Object,
    Link,
    Run,
    Done,
}

pick PhaseResult {
    Success,
    Warning,
    FatalError,
    Skipped,
    Unimplemented,
}

form CompilerInput {
    path: string
    source: string
    virtual: bool
}

form CompilerOutput {
    executable_path: string
    object_path: string
    assembly_path: string
    ir_path: string
    report_path: string
}

form CompilerOptions {
    mode: CompilerMode
    target: string
    profile: string
    output_dir: string
    emit_report: bool
    emit_json: bool
    verbose: bool
    trace_pipeline: bool
    validate_links: bool
    stop_after: CompilerStage
}

form CompilerState {
    stage: CompilerStage
    ok: bool
    input_loaded: bool
    frontend_ok: bool
    analysis_ok: bool
    mir_ok: bool
    ir_ok: bool
    codegen_ok: bool
    link_ok: bool
    stage_logs: [string]
    phase_results: [string]
}

form CompilerResult {
    status: driver.DriverExitStatus
    code: u64
    message: string
    stage: CompilerStage
    output: CompilerOutput
    diagnostics: List<report.Diagnostic>
    stage_logs: [string]
    phase_results: [string]
}

form Compiler {
    options: CompilerOptions
    state: CompilerState
    input: CompilerInput
    output: CompilerOutput
    diagnostics: List<report.Diagnostic>
    session: context.CompilationSession
    diagnostic_session: diagnostics.DiagnosticSession
    logger: logger.CompilerLogger
}

form CompilerCliRequest {
    command: string
    input_path: string
    output_path: string
    source_text: string
    verbose: bool
    trace_pipeline: bool
    valid: bool
    status: driver.DriverExitStatus
    message: string
}

proc default_options() -> CompilerOptions {
    give CompilerOptions {
        mode: CompilerMode::Build,
        target: "native",
        profile: "debug",
        output_dir: "build",
        emit_report: true,
        emit_json: false,
        verbose: false,
        trace_pipeline: false,
        validate_links: true,
        stop_after: CompilerStage::Done
    };
}

proc empty_input() -> CompilerInput {
    give CompilerInput {
        path: "",
        source: "",
        virtual: false
    };
}

proc empty_output() -> CompilerOutput {
    give CompilerOutput {
        executable_path: "",
        object_path: "",
        assembly_path: "",
        ir_path: "",
        report_path: ""
    };
}

proc initial_state() -> CompilerState {
    give CompilerState {
        stage: CompilerStage::Init,
        ok: true,
        input_loaded: false,
        frontend_ok: false,
        analysis_ok: false,
        mir_ok: false,
        ir_ok: false,
        codegen_ok: false,
        link_ok: false,
        stage_logs: [],
        phase_results: []
    };
}

proc cli_exit_code(status: driver.DriverExitStatus) -> int {
    give (driver.exit_code(status) as int);
}

proc empty_cli_request() -> CompilerCliRequest {
    give CompilerCliRequest {
        command: "",
        input_path: "",
        output_path: "a.out",
        source_text: "",
        verbose: false,
        trace_pipeline: false,
        valid: false,
        status: driver.DriverExitStatus::InvalidArguments,
        message: "missing compiler command"
    };
}

proc cli_command_from_text(text: string) -> string {
    if text == "check" {
        give "check";
    }
    if text == "build" {
        give "build";
    }
    if text == "compile" {
        give "build";
    }
    if text == "run" {
        give "run";
    }
    if text == "dump-tokens" {
        give "dump-tokens";
    }
    if text == "dump-ast" {
        give "dump-ast";
    }
    if text == "dump-hir" {
        give "dump-hir";
    }
    if text == "dump-mir" {
        give "dump-mir";
    }
    if text == "test" {
        give "test";
    }
    if text == "help" or text == "--help" or text == "-h" {
        give "help";
    }
    give "";
}

proc cli_is_output_flag(text: string) -> bool {
    give text == "-o" or text == "--out" or text == "--output";
}

proc cli_is_source_flag(text: string) -> bool {
    give text == "--source" or text == "--source-text";
}

proc cli_is_input_flag(text: string) -> bool {
    give text == "--src" or text == "--input";
}

proc cli_is_known_flag(text: string) -> bool {
    give cli_is_output_flag(text)
        or cli_is_source_flag(text)
        or cli_is_input_flag(text)
        or text == "--verbose"
        or text == "--trace-pipeline"
        or text == "--native"
        or text == "--no-native"
        or text == "--json";
}

proc parse_cli_request(args: list[string]) -> CompilerCliRequest {
    let request: CompilerCliRequest = empty_cli_request();

    if len(args) == 0 {
        set request.command = "help";
        set request.valid = true;
        set request.status = driver.DriverExitStatus::Ok;
        set request.message = "usage: vittec check|build|run|dump-tokens|dump-ast|dump-hir|dump-mir <file.vit> [-o out]";
        give request;
    }

    set request.command = cli_command_from_text(args[0]);

    if request.command == "" {
        set request.status = driver.DriverExitStatus::InvalidArguments;
        set request.message = "unknown compiler command: " + args[0];
        give request;
    }

    if request.command == "help" {
        set request.valid = true;
        set request.status = driver.DriverExitStatus::Ok;
        set request.message = "usage: vittec check|build|run|dump-tokens|dump-ast|dump-hir|dump-mir <file.vit> [-o out]";
        give request;
    }

    let i: u64 = 1;
    while i < len(args) {
        let arg: string = args[i];

        if cli_is_output_flag(arg) {
            if i + 1 >= len(args) {
                set request.status = driver.DriverExitStatus::InvalidArguments;
                set request.message = "missing value after " + arg;
                give request;
            }
            set request.output_path = args[i + 1];
            set i = i + 2;
        } elif cli_is_source_flag(arg) {
            if i + 1 >= len(args) {
                set request.status = driver.DriverExitStatus::InvalidArguments;
                set request.message = "missing value after " + arg;
                give request;
            }
            set request.source_text = args[i + 1];
            set i = i + 2;
        } elif cli_is_input_flag(arg) {
            if i + 1 >= len(args) {
                set request.status = driver.DriverExitStatus::InvalidArguments;
                set request.message = "missing value after " + arg;
                give request;
            }
            set request.input_path = args[i + 1];
            set i = i + 2;
        } elif cli_is_known_flag(arg) {
            if arg == "--verbose" {
                set request.verbose = true;
            }
            if arg == "--trace-pipeline" {
                set request.trace_pipeline = true;
            }
            set i = i + 1;
        } else {
            if request.input_path == "" {
                set request.input_path = arg;
            }
            set i = i + 1;
        }
    }

    if request.input_path == "" and request.source_text != "" {
        set request.input_path = "inline.vit";
    }

    if request.input_path == "" and request.source_text == "" {
        set request.status = driver.DriverExitStatus::MissingInput;
        set request.message = "missing input file or --source text";
        give request;
    }

    set request.valid = true;
    set request.status = driver.DriverExitStatus::Ok;
    set request.message = "compiler request parsed";

    give request;
}

proc cli_compile_config(request: CompilerCliRequest) -> DriverCompileConfig {
    let config: DriverCompileConfig = default_compile_config();
    give config;
}

proc is_internal_status(status: driver.DriverExitStatus) -> bool {
    give status == driver.DriverExitStatus::InternalError
        or status == driver.DriverExitStatus::BootstrapFailure
        or status == driver.DriverExitStatus::PipelineFailure;
}

proc print_internal_compiler_error(
    phase: string,
    source_location: string,
    stack_trace: string
) {
    let ice0: ice.InternalCompilerError =
        ice.internal_compiler_error(
            phase,
            stack_trace,
            source_location,
            version_text()
        );
    print(ice.render_internal_compiler_error_text(ice0));
}

proc cli_request_source_location(request: CompilerCliRequest) -> string {
    if request.input_path != "" {
        give request.input_path;
    }
    if request.source_text != "" {
        give "inline.vit";
    }
    give "<unknown>";
}

proc run_cli_request(request: CompilerCliRequest) -> int {
    if !request.valid {
        give cli_exit_code(request.status);
    }

    if request.command == "help" {
        give cli_exit_code(driver.DriverExitStatus::Ok);
    }

    if request.source_text == "" {
        give cli_exit_code(driver.DriverExitStatus::IoFailure);
    }

    let config: DriverCompileConfig = cli_compile_config(request);
    let result: DriverCompileResult;

    if request.trace_pipeline {
        let opts: CompilerOptions = default_options();
        if request.command == "check" {
            set opts.mode = CompilerMode::Check;
        } elif request.command == "run" {
            set opts.mode = CompilerMode::Run;
        } else {
            set opts.mode = CompilerMode::Build;
        }
        set opts.verbose = request.verbose;
        set opts.trace_pipeline = true;
        let c0 = compiler_from_source(request.input_path, request.source_text, opts);
        let r0: CompilerResult = run_compiler(c0);
        let expected: [string] = [
            "source manager",
            "lexer",
            "parser",
            "AST validation",
            "module resolver",
            "HIR lowering",
            "sema",
            "typeck",
            "borrowck",
            "MIR lowering",
            "MIR verify",
            "backend",
            "linker"
        ];
        let i: u64 = 0;
        while i < len(expected) {
            let key: string = expected[i] + "=Success";
            let hit: bool = false;
            let j: u64 = 0;
            while j < len(r0.phase_results) {
                if r0.phase_results[j] == key {
                    set hit = true;
                }
                set j = j + 1;
            }
            if hit {
                print("[OK] " + expected[i] + "\n");
            } else {
                print("[FAIL] " + expected[i] + " not executed\n");
            }
            set i = i + 1;
        }
        if r0.status == driver.DriverExitStatus::Ok {
            print("Build OK.\n");
        } else {
            print("Build FAILED.\n");
        }
        give r0.code as int;
    }

    if request.command == "check" {
        set result = check_source_with_config(request.input_path, request.source_text, config);
        give cli_exit_code(result.status);
    }

    if request.command == "build" {
        set result = compile_source_with_config(request.input_path, request.source_text, config);
        give cli_exit_code(result.status);
    }

    if request.command == "run" {
        set result = compile_source_with_config(request.input_path, request.source_text, config);
        if result.status != driver.DriverExitStatus::Ok {
            give cli_exit_code(result.status);
        }
        give cli_exit_code(driver.DriverExitStatus::RuntimeFailure);
    }

    if request.command == "dump-tokens"
        or request.command == "dump-ast"
        or request.command == "dump-hir"
        or request.command == "dump-mir" {
        set result = check_source_with_config(request.input_path, request.source_text, config);
        give cli_exit_code(result.status);
    }

    if request.command == "test" {
        give cli_exit_code(driver.DriverExitStatus::UnsupportedFeature);
    }

    give cli_exit_code(driver.DriverExitStatus::InvalidArguments);
}

proc run_cli_main(args: list[string]) -> int {
    give run_cli_main_with_ice_boundary(args);
}

proc run_cli_main_with_ice_boundary(args: list[string]) -> int {
    let request: CompilerCliRequest = parse_cli_request(args);
    let code: int = run_cli_request(request);
    if code == 2 {
        let phase: string = if request.command != "" { request.command } else { "cli" };
        let source_loc: string = cli_request_source_location(request);
        print_internal_compiler_error(
            phase,
            source_loc,
            "panic boundary: run_cli_main_with_ice_boundary > run_cli_request"
        );
    }
    give code;
}

proc new_compiler(options: CompilerOptions) -> Compiler {
    let session0: context.CompilationSession =
        context.default_compilation_session();
    give Compiler {
        options: options,
        state: initial_state(),
        input: empty_input(),
        output: empty_output(),
        diagnostics: [],
        session: session0,
        diagnostic_session: diagnostics.diagnostic_session(),
        logger: logger.compiler_logger(options.verbose, options.trace_pipeline)
    };
}

proc compiler_from_source(
    path: string,
    source: string,
    options: CompilerOptions
) -> Compiler {
    let compiler = new_compiler(options);

    set compiler.input = CompilerInput {
        path: path,
        source: source,
        virtual: true
    };

    set compiler.state.input_loaded = true;
    set compiler = sync_session_from_options(compiler);
    set compiler = sync_session_with_input(compiler);

    give compiler;
}

proc backend_options_from_compiler_options(options0: CompilerOptions) -> options.BackendOptions {
    give options.BackendOptions {
        backend_name: "x86_64",
        emit_debug_sections: options0.emit_report,
        lto_enabled: false,
        pgo_mode: "off",
        prefer_native_toolchain: false
    };
}

proc optimization_level_from_profile(profile_name: string) -> options.OptimizationLevel {
    if profile_name == "debug" {
        give options.OptimizationLevel.O0;
    }
    if profile_name == "size" {
        give options.OptimizationLevel.Os;
    }
    if profile_name == "release" {
        give options.OptimizationLevel.O3;
    }
    give options.OptimizationLevel.O2;
}

proc sync_session_from_options(compiler: Compiler) -> Compiler {
    let target0: TargetConfig = target_config_from_name(compiler.options.target);
    let triple0: string = if target0.valid { target0.target_triple } else { "x86_64-linux" };
    let backend0: options.BackendOptions = options.BackendOptions {
        backend_name: if target0.valid { target0.backend_name } else { "x86_64" },
        emit_debug_sections: compiler.options.emit_report,
        lto_enabled: false,
        pgo_mode: "off",
        prefer_native_toolchain: false
    };
    let cfg0: config.CompilationConfig = config.compilation_config(
        triple0,
        optimization_level_from_profile(compiler.options.profile),
        backend0
    );
    let opts0: options.SessionOptions = options.SessionOptions {
        locale: "en-US",
        optimization_level: cfg0.optimization_level,
        backend: cfg0.backend_options
    };
    set compiler.session = context.compilation_session_with_config(cfg0, opts0);
    give compiler;
}

proc sync_session_with_input(compiler: Compiler) -> Compiler {
    let path0: string = if compiler.input.path != "" { compiler.input.path } else { "inline.vit" };
    let text0: string = compiler_source_text(compiler);
    let manager0: files.SourceManager = files.source_manager_empty();
    let manager1: files.SourceManager = if compiler.input.virtual {
        files.source_manager_with_virtual_file(manager0, path0, text0)
    } else {
        files.source_manager_with_file(manager0, path0, text0)
    };
    set compiler.session.source_manager = files.include_stdlib(manager1);
    give compiler;
}

proc set_stage(
    compiler: Compiler,
    stage: CompilerStage
) -> Compiler {
    set compiler.state.stage = stage;
    give compiler;
}

proc should_stop(
    compiler: Compiler,
    stage: CompilerStage
) -> bool {
    give compiler.options.stop_after == stage;
}

proc log_stage(compiler: Compiler, event: string) -> Compiler {
    set compiler.state.stage_logs = compiler.state.stage_logs + [event];
    set compiler.logger = logger.trace(compiler.logger, event);
    give compiler;
}

proc phase_result_text(result: PhaseResult) -> string {
    if result == PhaseResult::Success { give "Success"; }
    if result == PhaseResult::Warning { give "Warning"; }
    if result == PhaseResult::FatalError { give "FatalError"; }
    if result == PhaseResult::Skipped { give "Skipped"; }
    give "Unimplemented";
}

proc record_phase_result(compiler: Compiler, phase: string, result: PhaseResult, critical: bool) -> Compiler {
    let text: string = phase + "=" + phase_result_text(result);
    set compiler.state.phase_results = compiler.state.phase_results + [text];
    if critical and (result == PhaseResult::FatalError or result == PhaseResult::Skipped or result == PhaseResult::Unimplemented) {
        set compiler.state.ok = false;
    }
    give compiler;
}

proc stop_after_stage_from_cli(name: string) -> CompilerStage {
    if name == "lex" { give CompilerStage::Lex; }
    if name == "parse" { give CompilerStage::Parse; }
    if name == "ast" { give CompilerStage::Ast; }
    if name == "hir" { give CompilerStage::Hir; }
    if name == "resolve" { give CompilerStage::Resolve; }
    if name == "typeck" { give CompilerStage::Typeck; }
    if name == "borrowck" { give CompilerStage::Borrowck; }
    if name == "mir" { give CompilerStage::Mir; }
    if name == "mir_validate" { give CompilerStage::MirValidate; }
    if name == "mir_optimize" { give CompilerStage::MirOptimize; }
    if name == "ir" { give CompilerStage::Ir; }
    if name == "ir_validate" { give CompilerStage::IrValidate; }
    if name == "codegen" { give CompilerStage::Codegen; }
    if name == "object" { give CompilerStage::Object; }
    if name == "link" { give CompilerStage::Link; }
    if name == "run" { give CompilerStage::Run; }
    give CompilerStage::Done;
}

proc stop_stage_in_frontend(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Lex
        or stage == CompilerStage::Parse
        or stage == CompilerStage::Ast
        or stage == CompilerStage::Hir;
}

proc stop_stage_in_analysis(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Resolve
        or stage == CompilerStage::Typeck
        or stage == CompilerStage::Borrowck;
}

proc stop_stage_in_mir(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Mir
        or stage == CompilerStage::MirValidate
        or stage == CompilerStage::MirOptimize;
}

proc stop_stage_in_ir(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Ir
        or stage == CompilerStage::IrValidate;
}

proc stop_stage_in_codegen(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Codegen
        or stage == CompilerStage::Object;
}

proc stop_stage_in_link(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Link;
}

proc stop_stage_in_run(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Run;
}

proc stop_reached_in_frontend(compiler: Compiler) -> bool {
    give stop_stage_in_frontend(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_analysis(compiler: Compiler) -> bool {
    give stop_stage_in_analysis(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_mir(compiler: Compiler) -> bool {
    give stop_stage_in_mir(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_ir(compiler: Compiler) -> bool {
    give stop_stage_in_ir(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_codegen(compiler: Compiler) -> bool {
    give stop_stage_in_codegen(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_link(compiler: Compiler) -> bool {
    give stop_stage_in_link(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_run(compiler: Compiler) -> bool {
    give stop_stage_in_run(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc fail(
    compiler: Compiler,
    status: driver.DriverExitStatus,
    message: string
) -> CompilerResult {
    set compiler.state.ok = false;
    set compiler.logger = logger.error(compiler.logger, message);

    give CompilerResult {
        status: status,
        code: driver.exit_code(status),
        message: message,
        stage: compiler.state.stage,
        output: compiler.output,
        diagnostics: compiler.diagnostics,
        stage_logs: compiler.state.stage_logs,
        phase_results: compiler.state.phase_results
    };
}

proc success(
    compiler: Compiler,
    message: string
) -> CompilerResult {
    set compiler.logger = logger.info(compiler.logger, message);
    give CompilerResult {
        status: driver.DriverExitStatus::Ok,
        code: 0,
        message: message,
        stage: compiler.state.stage,
        output: compiler.output,
        diagnostics: compiler.diagnostics,
        stage_logs: compiler.state.stage_logs,
        phase_results: compiler.state.phase_results
    };
}

proc add_diagnostic(
    compiler: Compiler,
    diagnostic: report.Diagnostic
) -> Compiler {
    set compiler.diagnostics =
        list.push(compiler.diagnostics, diagnostic);

    give compiler;
}

proc emit_session_diagnostic(
    compiler: Compiler,
    severity: string,
    code: string,
    file: string,
    line: u64,
    column: u64,
    message: string
) -> Compiler {
    let path0: string = if file != "" { file } else { compiler.input.path };
    let manager0: files.SourceManager =
        files.cache_source(
            compiler.session.source_manager,
            path0,
            compiler_source_text(compiler),
            compiler.input.virtual
        );
    let span0: files.SourceSpan =
        diagnostics.manager_span_from_location(manager0, path0, line, column);
    if severity == "fatal" {
        set compiler.diagnostic_session =
            diagnostics.emit_fatal(compiler.diagnostic_session, code, message, span0);
    } elif severity == "warning" {
        set compiler.diagnostic_session =
            diagnostics.emit_warning(compiler.diagnostic_session, code, message, span0);
    } elif severity == "note" {
        set compiler.diagnostic_session =
            diagnostics.emit_note(compiler.diagnostic_session, code, message, span0);
    } else {
        set compiler.diagnostic_session =
            diagnostics.emit_error(compiler.diagnostic_session, code, message, span0);
    }
    set compiler.session.source_manager = manager0;
    give compiler;
}

proc emit_session_diagnostic_with_span(
    compiler: Compiler,
    severity: string,
    code: string,
    message: string,
    span0: files.SourceSpan
) -> Compiler {
    if !span0.valid {
        give compiler;
    }
    if severity == "fatal" {
        set compiler.diagnostic_session =
            diagnostics.emit_fatal(compiler.diagnostic_session, code, message, span0);
    } elif severity == "warning" {
        set compiler.diagnostic_session =
            diagnostics.emit_warning(compiler.diagnostic_session, code, message, span0);
    } elif severity == "note" {
        set compiler.diagnostic_session =
            diagnostics.emit_note(compiler.diagnostic_session, code, message, span0);
    } else {
        set compiler.diagnostic_session =
            diagnostics.emit_error(compiler.diagnostic_session, code, message, span0);
    }
    give compiler;
}

proc has_diagnostics(compiler: Compiler) -> bool {
    give list.len(compiler.diagnostics) > 0;
}

proc configure_compiler(compiler: Compiler) -> Compiler {
    set compiler = set_stage(compiler, CompilerStage::Configure);
    set compiler = sync_session_from_options(compiler);

    if compiler.options.target == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_MISSING_TARGET",
            "missing compiler target"
        );
        set compiler.state.ok = false;
    }

    if compiler.options.output_dir == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_MISSING_OUTPUT_DIR",
            "missing compiler output directory"
        );
        set compiler.state.ok = false;
    }

    give compiler;
}

proc validate_input(compiler: Compiler) -> Compiler {
    set compiler = set_stage(compiler, CompilerStage::LoadInput);

    if compiler.input.path == "" && compiler.input.source == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_NO_INPUT",
            "no input file or source provided"
        );
        set compiler.state.ok = false;
    }

    if compiler.input.path != "" {
        set compiler.state.input_loaded = true;
    }
    set compiler = sync_session_with_input(compiler);

    give compiler;
}

proc validate_compiler_links(compiler: Compiler) -> Compiler {
    if !compiler.options.validate_links {
        give compiler;
    }

    if compiler.options.target == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_INVALID_LINK_TARGET",
            "invalid compiler link: target is empty"
        );
        set compiler.state.ok = false;
    }
    let target0: TargetConfig = target_config_from_name(compiler.options.target);
    if !target0.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_INVALID_TARGET_CONFIG",
            "unsupported target config: " + compiler.options.target
        );
        set compiler.state.ok = false;
    } else {
        set compiler.options.target = target0.target_triple;
        set compiler.logger = logger.debug(
            compiler.logger,
            "target_config name=" + target0.name
                + " ptr=" + (target0.pointer_size as string)
                + " endian=" + target0.endianness
                + " abi=" + target0.abi
                + " linker=" + target0.linker_path
                + " format=" + target0.object_format
        );
    }

    if compiler.options.profile == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_INVALID_LINK_PROFILE",
            "invalid compiler link: profile is empty"
        );
        set compiler.state.ok = false;
    }

    give compiler;
}

proc compiler_source_text(compiler: Compiler) -> string {
    if compiler.input.source != "" {
        give compiler.input.source;
    }
    give "";
}

proc typed_diag_text(
    severity: string,
    code: string,
    file: string,
    line: u64,
    column: u64,
    message: string
) -> string {
    give "severity="
        + severity
        + " code="
        + code
        + " span="
        + file
        + ":"
        + (line as string)
        + ":"
        + (column as string)
        + " message="
        + message;
}

proc frontend_diag_message(diag: FrontendDiagnostic) -> string {
    let sev: string = if diag.fatal { "fatal" } else { "error" };
    give typed_diag_text(
        sev,
        "DRIVER_E_FRONTEND_DIAG_" + diag.code,
        diag.file,
        diag.line,
        diag.column,
        diag.message
    );
}

proc analysis_diag_message(diag: AnalysisDiagnostic) -> string {
    give typed_diag_text(
        diag.severity,
        "DRIVER_E_ANALYSIS_DIAG_" + diag.code,
        diag.file,
        diag.line,
        diag.column,
        diag.phase + ": " + diag.message
    );
}

proc add_typed_diagnostic(
    compiler: Compiler,
    severity: string,
    code: string,
    message: string
) -> Compiler {
    set compiler = emit_session_diagnostic(
        compiler,
        severity,
        code,
        compiler.input.path,
        1,
        1,
        message
    );
    let d =
        report.diagnostic(
            severity,
            code,
            compiler.input.path,
            1,
            1,
            message
        );
    give add_diagnostic(compiler, d);
}

proc append_frontend_diagnostics(
    compiler: Compiler,
    diagnostics: [FrontendDiagnostic]
) -> Compiler {
    let out: Compiler = compiler;
    let i: u64 = 0;
    while i < len(diagnostics) {
        let severity: string = if diagnostics[i].fatal { "fatal" } else { "error" };
        let d = report.diagnostic(
            severity,
            "DRIVER_E_FRONTEND_DIAG_" + diagnostics[i].code,
            diagnostics[i].file,
            diagnostics[i].line,
            diagnostics[i].column,
            diagnostics[i].message
        );
        set out = emit_session_diagnostic_with_span(
            out,
            severity,
            "DRIVER_E_FRONTEND_DIAG_" + diagnostics[i].code,
            diagnostics[i].message,
            files.source_span(diagnostics[i].file_id, diagnostics[i].span_start, diagnostics[i].span_end)
        );
        set out = add_diagnostic(out, d);
        set i = i + 1;
    }
    set out.session.module_graph.modules = out.session.module_graph.modules + ["frontend/ast"];
    give out;
}

proc append_analysis_diagnostics(
    compiler: Compiler,
    diagnostics: [AnalysisDiagnostic]
) -> Compiler {
    let out: Compiler = compiler;
    let i: u64 = 0;
    while i < len(diagnostics) {
        let d = report.diagnostic(
            diagnostics[i].severity,
            "DRIVER_E_ANALYSIS_DIAG_" + diagnostics[i].code,
            diagnostics[i].file,
            diagnostics[i].line,
            diagnostics[i].column,
            diagnostics[i].phase + ": " + diagnostics[i].message
        );
        set out = emit_session_diagnostic_with_span(
            out,
            diagnostics[i].severity,
            "DRIVER_E_ANALYSIS_DIAG_" + diagnostics[i].code,
            diagnostics[i].phase + ": " + diagnostics[i].message,
            files.source_span(diagnostics[i].file_id, diagnostics[i].span_start, diagnostics[i].span_end)
        );
        set out = add_diagnostic(out, d);
        set i = i + 1;
    }
    set out.session.symbol_tables.scopes = out.session.symbol_tables.scopes + ["analysis/global"];
    give out;
}

proc run_frontend(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Lex);
    if should_stop(compiler, CompilerStage::Lex) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }

    if !compiler.state.input_loaded {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_FRONTEND_INPUT_NOT_LOADED",
            "frontend failed: input was not loaded"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Parse);
    if should_stop(compiler, CompilerStage::Parse) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }

    if compiler.input.source == "" && compiler.input.path == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_PARSE_EMPTY_SOURCE",
            "parse failed: empty source input"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput =
        frontend_run(
            compiler.input.path,
            compiler_source_text(compiler)
        );
    set compiler =
        append_frontend_diagnostics(
            compiler,
            frontend_out.diagnostics
        );
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !frontend_out.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_FRONTEND_INVALID",
            "frontend pipeline returned invalid output"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if frontend_out.toplevel_count == 0 or !frontend_out.ast_root.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_PARSE_EMPTY_AST",
            "parser returned empty or invalid AST"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Ast);
    if should_stop(compiler, CompilerStage::Ast) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }
    set compiler = set_stage(compiler, CompilerStage::Hir);
    if should_stop(compiler, CompilerStage::Hir) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }

    set compiler.state.frontend_ok = true;
    set compiler.session.module_graph.valid = true;

    give compiler;
}

proc run_analysis(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Resolve);
    if should_stop(compiler, CompilerStage::Resolve) {
        set compiler.state.analysis_ok = true;
        give compiler;
    }

    if !compiler.state.frontend_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_ANALYSIS_FRONTEND_INCOMPLETE",
            "analysis failed: frontend did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput =
        frontend_run(
            compiler.input.path,
            compiler_source_text(compiler)
        );
    let analysis_out: AnalysisOutput =
        analysis_run(frontend_out);
    set compiler =
        append_frontend_diagnostics(
            compiler,
            frontend_out.diagnostics
        );
    set compiler =
        append_analysis_diagnostics(
            compiler,
            analysis_out.diagnostics
        );
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !analysis_out.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_ANALYSIS_INVALID",
            "analysis pipeline returned invalid output"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if !analysis_out.sema_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_SEMA_NOT_EXECUTED",
            "semantic analysis was not executed successfully"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if !analysis_out.typeck_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_TYPECK_NOT_EXECUTED",
            "type checking was not executed successfully"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if !analysis_out.borrowck_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_BORROWCK_NOT_EXECUTED",
            "borrow checker was not executed successfully"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Typeck);
    if should_stop(compiler, CompilerStage::Typeck) {
        set compiler.state.analysis_ok = true;
        give compiler;
    }
    set compiler = set_stage(compiler, CompilerStage::Borrowck);
    if should_stop(compiler, CompilerStage::Borrowck) {
        set compiler.state.analysis_ok = true;
        give compiler;
    }

    set compiler.state.analysis_ok = true;
    set compiler.session.symbol_tables.valid = true;

    give compiler;
}

proc run_mir_pipeline(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Mir);
    if should_stop(compiler, CompilerStage::Mir) {
        set compiler.state.mir_ok = true;
        give compiler;
    }

    if !compiler.state.analysis_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_MIR_ANALYSIS_INCOMPLETE",
            "MIR build failed: analysis did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput =
        frontend_run(
            compiler.input.path,
            compiler_source_text(compiler)
        );
    let middle_out: MiddleOutput =
        middle_run(frontend_out);
    set compiler =
        append_frontend_diagnostics(
            compiler,
            frontend_out.diagnostics
        );
    set compiler =
        append_analysis_diagnostics(
            compiler,
            middle_out.analysis.diagnostics
        );
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !middle_out.analysis.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_MIR_ANALYSIS_INVALID",
            "middle pipeline analysis invalid"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    if !middle_out.mir.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_MIR_INVALID",
            "MIR validation failed in middle pipeline"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::MirValidate);
    if should_stop(compiler, CompilerStage::MirValidate) {
        set compiler.state.mir_ok = true;
        give compiler;
    }
    set compiler = set_stage(compiler, CompilerStage::MirOptimize);
    if should_stop(compiler, CompilerStage::MirOptimize) {
        set compiler.state.mir_ok = true;
        give compiler;
    }

    set compiler.state.mir_ok = true;
    set compiler.session.interners.valid = true;

    give compiler;
}

proc run_ir_pipeline(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Ir);
    if should_stop(compiler, CompilerStage::Ir) {
        set compiler.state.ir_ok = true;
        give compiler;
    }

    if !compiler.state.mir_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_IR_MIR_INCOMPLETE",
            "mir_to_ir failed: MIR pipeline did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput =
        frontend_run(
            compiler.input.path,
            compiler_source_text(compiler)
        );
    let middle_out: MiddleOutput =
        middle_run(frontend_out);
    set compiler =
        append_frontend_diagnostics(
            compiler,
            frontend_out.diagnostics
        );
    set compiler =
        append_analysis_diagnostics(
            compiler,
            middle_out.analysis.diagnostics
        );
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !middle_out.ir.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_IR_INVALID",
            "IR lowering/verification failed in middle pipeline"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::IrValidate);
    if should_stop(compiler, CompilerStage::IrValidate) {
        set compiler.state.ir_ok = true;
        give compiler;
    }

    set compiler.state.ir_ok = true;
    set compiler.session.package_registry.valid = true;

    give compiler;
}

proc run_codegen(compiler: Compiler) -> Compiler {
    set compiler = sync_session_from_options(compiler);
    set compiler = set_stage(compiler, CompilerStage::Codegen);
    if should_stop(compiler, CompilerStage::Codegen) {
        set compiler.state.codegen_ok = true;
        give compiler;
    }

    if !compiler.state.ir_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_CODEGEN_IR_INCOMPLETE",
            "codegen failed: IR pipeline did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let backend_out: BackendPipelineResult =
        compile_to_valid_ir_with_profile_and_packaging(
            compiler.input.path,
            compiler_source_text(compiler),
            "x86_64",
            "x86_64-linux",
            "enterprise-default",
            true,
            true,
            "executable",
            false,
            default_llvm_toolchain_paths()
        );
    set compiler =
        append_frontend_diagnostics(
            compiler,
            backend_out.frontend.diagnostics
        );
    set compiler =
        append_analysis_diagnostics(
            compiler,
            backend_out.analysis.diagnostics
        );
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !backend_out.codegen.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_CODEGEN_INVALID",
            "backend codegen failed"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if !backend_out.codegen.object_ready or backend_out.codegen.section_count == 0 or backend_out.codegen.object_text == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_BACKEND_EMPTY_OUTPUT",
            "backend generated an empty object output"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Object);
    if should_stop(compiler, CompilerStage::Object) {
        set compiler.state.codegen_ok = true;
        give compiler;
    }

    set compiler.output.object_path =
        compiler.options.output_dir + "/main.o";

    set compiler.state.codegen_ok = true;

    give compiler;
}

proc run_linker(compiler: Compiler) -> Compiler {
    set compiler = sync_session_from_options(compiler);
    set compiler = set_stage(compiler, CompilerStage::Link);
    if should_stop(compiler, CompilerStage::Link) {
        set compiler.state.link_ok = true;
        give compiler;
    }

    if !compiler.state.codegen_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_LINK_CODEGEN_INCOMPLETE",
            "link failed: object emission did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let backend_out: BackendPipelineResult =
        compile_to_valid_ir_with_profile_and_packaging(
            compiler.input.path,
            compiler_source_text(compiler),
            "x86_64",
            "x86_64-linux",
            "enterprise-default",
            true,
            true,
            "executable",
            false,
            default_llvm_toolchain_paths()
        );
    set compiler =
        append_frontend_diagnostics(
            compiler,
            backend_out.frontend.diagnostics
        );
    set compiler =
        append_analysis_diagnostics(
            compiler,
            backend_out.analysis.diagnostics
        );
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !backend_out.artifact.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_LINK_INVALID",
            "backend linker artifact invalid"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if len(backend_out.artifact.outputs) == 0 {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_LINK_NO_OUTPUT",
            "linker did not produce any output artifact"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler.output.executable_path =
        compiler.options.output_dir + "/main";

    set compiler.state.link_ok = true;

    give compiler;
}

proc run_executable(compiler: Compiler) -> Compiler {
    set compiler = set_stage(compiler, CompilerStage::Run);
    if should_stop(compiler, CompilerStage::Run) {
        give compiler;
    }

    if !compiler.state.link_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_RUN_LINK_INCOMPLETE",
            "run failed: executable was not linked"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    give compiler;
}

proc status_for_stage(stage: CompilerStage) -> driver.DriverExitStatus {
    if stage == CompilerStage::LoadInput {
        give driver.DriverExitStatus::InvalidInput;
    }

    if stage == CompilerStage::Lex {
        give driver.DriverExitStatus::LexFailure;
    }

    if stage == CompilerStage::Parse {
        give driver.DriverExitStatus::ParseFailure;
    }

    if stage == CompilerStage::Ast {
        give driver.DriverExitStatus::AstFailure;
    }

    if stage == CompilerStage::Hir {
        give driver.DriverExitStatus::HirFailure;
    }

    if stage == CompilerStage::Resolve {
        give driver.DriverExitStatus::ResolveFailure;
    }

    if stage == CompilerStage::Typeck {
        give driver.DriverExitStatus::TypeFailure;
    }

    if stage == CompilerStage::Borrowck {
        give driver.DriverExitStatus::BorrowckFailure;
    }

    if stage == CompilerStage::Mir {
        give driver.DriverExitStatus::MirBuildFailure;
    }

    if stage == CompilerStage::MirValidate {
        give driver.DriverExitStatus::MirValidationFailure;
    }

    if stage == CompilerStage::Ir {
        give driver.DriverExitStatus::IrLoweringFailure;
    }

    if stage == CompilerStage::IrValidate {
        give driver.DriverExitStatus::IrValidationFailure;
    }

    if stage == CompilerStage::Codegen {
        give driver.DriverExitStatus::CodegenFailure;
    }

    if stage == CompilerStage::Object {
        give driver.DriverExitStatus::ObjectEmissionFailure;
    }

    if stage == CompilerStage::Link {
        give driver.DriverExitStatus::LinkFailure;
    }

    give driver.DriverExitStatus::InternalError;
}

proc finalize_compiler(compiler: Compiler) -> CompilerResult {
    if diagnostics.has_errors(compiler.diagnostic_session) {
        give fail(
            compiler,
            status_for_stage(compiler.state.stage),
            "compiler failed: diagnostics session contains errors"
        );
    }

    if !compiler.state.ok {
        give fail(
            compiler,
            status_for_stage(compiler.state.stage),
            "compiler failed at stage: " + stage_name(compiler.state.stage)
        );
    }

    if compiler.state.stage == compiler.options.stop_after {
        give success(
            compiler,
            "compiler stopped after stage: " + stage_name(compiler.state.stage)
        );
    }

    set compiler = set_stage(compiler, CompilerStage::Done);

    give success(compiler, "compiler pipeline completed successfully");
}

proc run_compiler(compiler: Compiler) -> CompilerResult {
    set compiler = log_stage(compiler, "enter:1.load_source");
    set compiler.diagnostic_session = diagnostics.diagnostic_session();
    set compiler = record_phase_result(compiler, "source manager", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:1.load_source:ok");

    set compiler = log_stage(compiler, "enter:2.lex+3.parse+4.validate_ast");
    set compiler = configure_compiler(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "lexer", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "parser", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "AST validation", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:2.lex+3.parse+4.validate_ast:failed");
        give finalize_compiler(compiler);
    }

    set compiler = validate_input(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "lexer", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "parser", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "AST validation", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:2.lex+3.parse+4.validate_ast:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "lexer", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "parser", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "AST validation", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:2.lex+3.parse+4.validate_ast:ok");

    set compiler = log_stage(compiler, "enter:5.resolve_modules");
    set compiler = validate_compiler_links(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "module resolver", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:5.resolve_modules:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "module resolver", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:5.resolve_modules:ok");

    set compiler = log_stage(compiler, "enter:6.lower_hir+7.sema+8.typeck+9.borrowck");
    set compiler = run_frontend(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_frontend(compiler) {
        set compiler = record_phase_result(compiler, "HIR lowering", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:failed");
        give finalize_compiler(compiler);
    }

    set compiler = run_analysis(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_analysis(compiler) {
        set compiler = record_phase_result(compiler, "sema", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "typeck", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "borrowck", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "HIR lowering", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "sema", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "typeck", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "borrowck", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:ok");

    set compiler = log_stage(compiler, "enter:10.lower_mir+11.verify_mir+12.optimize");
    set compiler = run_mir_pipeline(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_mir(compiler) {
        set compiler = record_phase_result(compiler, "MIR lowering", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "MIR verify", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:10.lower_mir+11.verify_mir+12.optimize:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "MIR lowering", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "MIR verify", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:10.lower_mir+11.verify_mir+12.optimize:ok");

    set compiler = log_stage(compiler, "enter:13.backend_emit+14.object_file");
    set compiler = run_ir_pipeline(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_ir(compiler) {
        set compiler = record_phase_result(compiler, "backend", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:failed");
        give finalize_compiler(compiler);
    }

    if compiler.options.mode == CompilerMode::Check {
        set compiler = record_phase_result(compiler, "backend", PhaseResult::Skipped, true);
        set compiler = record_phase_result(compiler, "linker", PhaseResult::Skipped, true);
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:ok(check-mode)");
        give finalize_compiler(compiler);
    }

    set compiler = run_codegen(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_codegen(compiler) {
        set compiler = record_phase_result(compiler, "backend", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "backend", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:ok");

    set compiler = log_stage(compiler, "enter:15.link_executable");
    set compiler = run_linker(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_link(compiler) {
        set compiler = record_phase_result(compiler, "linker", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:15.link_executable:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "linker", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:15.link_executable:ok");

    if compiler.options.mode == CompilerMode::Run {
        set compiler = log_stage(compiler, "enter:run_executable");
        set compiler = run_executable(compiler);
        if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 or stop_reached_in_run(compiler) {
            set compiler = log_stage(compiler, "exit:run_executable:failed");
            give finalize_compiler(compiler);
        }
        set compiler = log_stage(compiler, "exit:run_executable:ok");
    }

    give finalize_compiler(compiler);
}

proc compile_source(
    path: string,
    source: string,
    options: CompilerOptions
) -> CompilerResult {
    let compiler = compiler_from_source(path, source, options);
    give run_compiler(compiler);
}

proc compile_file(
    path: string,
    options: CompilerOptions
) -> CompilerResult {
    let compiler = new_compiler(options);

    set compiler.input = CompilerInput {
        path: path,
        source: "",
        virtual: false
    };

    give run_compiler(compiler);
}

proc stage_name(stage: CompilerStage) -> string {
    if stage == CompilerStage::Init {
        give "init";
    }

    if stage == CompilerStage::Configure {
        give "configure";
    }

    if stage == CompilerStage::LoadInput {
        give "load_input";
    }

    if stage == CompilerStage::Lex {
        give "lex";
    }

    if stage == CompilerStage::Parse {
        give "parse";
    }

    if stage == CompilerStage::Ast {
        give "ast";
    }

    if stage == CompilerStage::Hir {
        give "hir";
    }

    if stage == CompilerStage::Resolve {
        give "resolve";
    }

    if stage == CompilerStage::Typeck {
        give "typeck";
    }

    if stage == CompilerStage::Borrowck {
        give "borrowck";
    }

    if stage == CompilerStage::Mir {
        give "mir";
    }

    if stage == CompilerStage::MirValidate {
        give "mir_validate";
    }

    if stage == CompilerStage::MirOptimize {
        give "mir_optimize";
    }

    if stage == CompilerStage::Ir {
        give "ir";
    }

    if stage == CompilerStage::IrValidate {
        give "ir_validate";
    }

    if stage == CompilerStage::Codegen {
        give "codegen";
    }

    if stage == CompilerStage::Object {
        give "object";
    }

    if stage == CompilerStage::Link {
        give "link";
    }

    if stage == CompilerStage::Run {
        give "run";
    }

    if stage == CompilerStage::Done {
        give "done";
    }

    give "unknown";
}

