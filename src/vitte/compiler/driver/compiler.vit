pick CompilerMode {
    Check,
    Build,
    Run,
    Test,
    EmitAst,
    EmitHir,
    EmitMir,
    EmitIr,
    EmitObject,
    EmitAssembly,
}

pick CompilerStage {
    Init,
    Configure,
    LoadInput,
    Lex,
    Parse,
    Ast,
    Hir,
    Resolve,
    Typeck,
    Borrowck,
    Mir,
    MirValidate,
    MirOptimize,
    Ir,
    IrValidate,
    Codegen,
    Object,
    Link,
    Run,
    Done,
}

pick PhaseResult {
    Success,
    Warning,
    FatalError,
    Skipped,
    Unimplemented,
}

form CompilerInput {
    path: string
    source: string
    virtual: bool
}

form CompilerOutput {
    executable_path: string
    object_path: string
    assembly_path: string
    ir_path: string
    report_path: string
    program_exit_code: int
}

form CompilerOptions {
    mode: CompilerMode
    target: string
    profile: string
    output_dir: string
    output_path: string
    emit_report: bool
    emit_json: bool
    verbose: bool
    trace_pipeline: bool
    validate_links: bool
    stop_after: CompilerStage
}

form CompilerState {
    stage: CompilerStage
    ok: bool
    input_loaded: bool
    frontend_ok: bool
    analysis_ok: bool
    mir_ok: bool
    ir_ok: bool
    codegen_ok: bool
    link_ok: bool
    stage_logs: [string]
    phase_results: [string]
}

form CompilerResult {
    status: driver.DriverExitStatus
    code: u64
    message: string
    stage: CompilerStage
    output: CompilerOutput
    diagnostics: List<report.Diagnostic>
    stage_logs: [string]
    phase_results: [string]
}

form Compiler {
    options: CompilerOptions
    state: CompilerState
    input: CompilerInput
    output: CompilerOutput
    diagnostics: List<report.Diagnostic>
    session: context.CompilationSession
    diagnostic_session: diagnostics.DiagnosticSession
    logger: logger.CompilerLogger
}

form CompilerCliRequest {
    command: string
    subcommand: string
    input_path: string
    output_path: string
    source_text: string
    verbose: bool
    trace_pipeline: bool
    timings: bool
    diagnostic_quality: bool
    show_cascades: bool
    fix_apply: bool
    fail_under: u64
    stdlib_path: string
    stdlib_version: string
    valid: bool
    status: driver.DriverExitStatus
    message: string
}

proc default_options() -> CompilerOptions {
    give CompilerOptions {
        mode: CompilerMode::Build,
        target: "native",
        profile: "debug",
        output_dir: "build",
        output_path: "build/main",
        emit_report: true,
        emit_json: false,
        verbose: false,
        trace_pipeline: false,
        validate_links: true,
        stop_after: CompilerStage::Done
    };
}

proc empty_input() -> CompilerInput {
    give CompilerInput {
        path: "",
        source: "",
        virtual: false
    };
}

proc empty_output() -> CompilerOutput {
    give CompilerOutput {
        executable_path: "",
        object_path: "",
        assembly_path: "",
        ir_path: "",
        report_path: "",
        program_exit_code: 0
    };
}

proc initial_state() -> CompilerState {
    give CompilerState {
        stage: CompilerStage::Init,
        ok: true,
        input_loaded: false,
        frontend_ok: false,
        analysis_ok: false,
        mir_ok: false,
        ir_ok: false,
        codegen_ok: false,
        link_ok: false,
        stage_logs: [],
        phase_results: []
    };
}

proc cli_exit_code(status: driver.DriverExitStatus) -> int {
    give (driver.exit_code(status) as int);
}

proc empty_cli_request() -> CompilerCliRequest {
    give CompilerCliRequest {
        command: "",
        subcommand: "",
        input_path: "",
        output_path: "a.out",
        source_text: "",
        verbose: false,
        trace_pipeline: false,
        timings: false,
        diagnostic_quality: false,
        show_cascades: false,
        fix_apply: false,
        fail_under: 0,
        stdlib_path: "src/vitte/stdlib",
        stdlib_version: "",
        valid: false,
        status: driver.DriverExitStatus::InvalidArguments,
        message: "missing compiler command"
    };
}

proc cli_command_from_text(text: string) -> string {
    if text == "check" {
        give "check";
    }
    if text == "build" {
        give "build";
    }
    if text == "compile" {
        give "build";
    }
    if text == "run" {
        give "run";
    }
    if text == "dump-tokens" {
        give "dump-tokens";
    }
    if text == "dump-ast" {
        give "dump-ast";
    }
    if text == "dump-hir" {
        give "dump-hir";
    }
    if text == "dump-mir" {
        give "dump-mir";
    }
    if text == "test" {
        give "test";
    }
    if text == "metrics" {
        give "metrics";
    }
    if text == "health" {
        give "health";
    }
    if text == "pkg" {
        give "pkg";
    }
    if text == "explain" {
        give "explain";
    }
    if text == "fix" {
        give "fix";
    }
    if text == "reduce" {
        give "reduce";
    }
    if text == "help" or text == "--help" or text == "-h" {
        give "help";
    }
    give "";
}

proc cli_is_output_flag(text: string) -> bool {
    give text == "-o" or text == "--out" or text == "--output";
}

proc cli_is_source_flag(text: string) -> bool {
    give text == "--source" or text == "--source-text";
}

proc cli_is_input_flag(text: string) -> bool {
    give text == "--src" or text == "--input";
}

proc cli_is_known_flag(text: string) -> bool {
    give cli_is_output_flag(text)
        or cli_is_source_flag(text)
        or cli_is_input_flag(text)
        or text == "--verbose"
        or text == "--trace-pipeline"
        or text == "--timings"
        or text == "--diagnostic-quality"
        or text == "--show-cascades"
        or text == "--dry-run"
        or text == "--apply"
        or text == "--fail-under"
        or text == "--stdlib-path"
        or text == "--stdlib-version"
        or text == "--native"
        or text == "--no-native"
        or text == "--json";
}

proc metrics_manifest_text(source_path: string, source_text: string) -> string {
    if source_text != "" {
        give source_text;
    }
    give "";
}

proc project_path_hint(path: string) -> bool {
    if path == "" {
        give false;
    }
    give path == "." or path == ".." or slice(path, len(path) - 1, len(path)) == "/";
}

proc path_join2(left: string, right: string) -> string {
    if left == "" {
        give right;
    }
    if right == "" {
        give left;
    }
    if slice(left, len(left) - 1, len(left)) == "/" {
        give left + right;
    }
    give left + "/" + right;
}

proc ends_with_text(text: string, suffix: string) -> bool {
    if len(suffix) > len(text) {
        give false;
    }
    give slice(text, len(text) - len(suffix), len(text)) == suffix;
}

proc resolve_project_entry_path(project_path: string) -> string {
    let src_main: string = path_join2(path_join2(project_path, "src"), "main.vit");
    if is_file(src_main) {
        give src_main;
    }
    let compiler_main: string = path_join2(path_join2(path_join2(project_path, "src"), "vitte"), "compiler/main.vit");
    if is_file(compiler_main) {
        give compiler_main;
    }
    let root_main: string = path_join2(project_path, "main.vit");
    if is_file(root_main) {
        give root_main;
    }
    give "";
}

proc resolve_cli_input_path(input_path: string) -> string {
    if input_path == "" {
        give "";
    }
    if project_path_hint(input_path) or is_directory(input_path) {
        let project_entry: string = resolve_project_entry_path(input_path);
        if project_entry != "" {
            give project_entry;
        }
    }
    give input_path;
}

proc resolve_cli_input_source_text(input_path: string) -> string {
    let resolved_path: string = resolve_cli_input_path(input_path);
    if resolved_path == "" {
        give "";
    }
    give read_file(resolved_path);
}

proc discover_project_vit_files(project_path: string) -> [string] {
    let files: [string] = [];
    let entries: [string] = list_directory(project_path);
    let i: u64 = 0;
    while i < len(entries) {
        let child: string = path_join2(project_path, entries[i]);
        if is_directory(child) {
            let nested: [string] = list_directory(child);
            let j: u64 = 0;
            while j < len(nested) {
                let nested_child: string = path_join2(child, nested[j]);
                if ends_with_text(nested_child, ".vit") {
                    set files = files + [nested_child];
                }
                set j = j + 1;
            }
        } elif ends_with_text(child, ".vit") {
            set files = files + [child];
        }
        set i = i + 1;
    }
    give files;
}

proc escape_manifest_source(text: string) -> string {
    let out: string = "";
    let i: u64 = 0;
    while i < len(text) {
        let ch: string = slice(text, i, i + 1);
        if ch == "\\" {
            set out = out + "\\\\";
        } elif ch == "\n" {
            set out = out + "\\n";
        } elif ch == "\t" {
            set out = out + "\\t";
        } elif ch == "\r" {
            set out = out + "\\r";
        } else {
            set out = out + ch;
        }
        set i = i + 1;
    }
    give out;
}

proc manifest_entry_separator() -> string {
    give slice("a=b", 1, 2);
}

proc auto_project_manifest_text(project_path: string) -> string {
    let files: [string] = discover_project_vit_files(project_path);
    let manifest: string = "";
    let i: u64 = 0;
    while i < len(files) {
        let src: string = read_file(files[i]);
        if src != "" {
            if manifest != "" {
                set manifest = manifest + "\n";
            }
            let escaped_src: string = escape_manifest_source(src);
            set manifest = manifest + files[i];
            set manifest = manifest + manifest_entry_separator();
            set manifest = manifest + escaped_src;
        }
        set i = i + 1;
    }
    give manifest;
}

proc parse_cli_request(args: list[string]) -> CompilerCliRequest {
    let request: CompilerCliRequest = empty_cli_request();

    if len(args) == 0 {
        set request.command = "help";
        set request.valid = true;
        set request.status = driver.DriverExitStatus::Ok;
        set request.message = "usage: vitte <command> [options] [file]";
        give request;
    }

    set request.command = cli_command_from_text(args[0]);

    if request.command == "" {
        set request.status = driver.DriverExitStatus::InvalidArguments;
        set request.message = "unknown compiler command: " + args[0];
        give request;
    }

    if request.command == "help" {
        set request.valid = true;
        set request.status = driver.DriverExitStatus::Ok;
        set request.message = "usage: vitte <command> [options] [file]";
        give request;
    }

    let i: u64 = 1;
    while i < len(args) {
        let arg: string = args[i];

        if cli_is_output_flag(arg) {
            if i + 1 >= len(args) {
                set request.status = driver.DriverExitStatus::InvalidArguments;
                set request.message = "missing value after " + arg;
                give request;
            }
            set request.output_path = args[i + 1];
            set i = i + 2;
        } elif cli_is_source_flag(arg) {
            if i + 1 >= len(args) {
                set request.status = driver.DriverExitStatus::InvalidArguments;
                set request.message = "missing value after " + arg;
                give request;
            }
            set request.source_text = args[i + 1];
            set i = i + 2;
        } elif cli_is_input_flag(arg) {
            if i + 1 >= len(args) {
                set request.status = driver.DriverExitStatus::InvalidArguments;
                set request.message = "missing value after " + arg;
                give request;
            }
            set request.input_path = args[i + 1];
            set i = i + 2;
        } elif cli_is_known_flag(arg) {
            if arg == "--verbose" {
                set request.verbose = true;
                set i = i + 1;
            } elif arg == "--trace-pipeline" {
                set request.trace_pipeline = true;
                set i = i + 1;
            } elif arg == "--timings" {
                set request.timings = true;
                set i = i + 1;
            } elif arg == "--diagnostic-quality" {
                set request.diagnostic_quality = true;
                set i = i + 1;
            } elif arg == "--show-cascades" {
                set request.show_cascades = true;
                set i = i + 1;
            } elif arg == "--dry-run" {
                set request.fix_apply = false;
                set i = i + 1;
            } elif arg == "--apply" {
                set request.fix_apply = true;
                set i = i + 1;
            } elif arg == "--fail-under" {
                if i + 1 >= len(args) {
                    set request.status = driver.DriverExitStatus::InvalidArguments;
                    set request.message = "missing value after " + arg;
                    give request;
                }
                set request.fail_under = args[i + 1] as u64;
                set i = i + 2;
            } elif arg == "--stdlib-path" {
                if i + 1 >= len(args) {
                    set request.status = driver.DriverExitStatus::InvalidArguments;
                    set request.message = "missing value after " + arg;
                    give request;
                }
                set request.stdlib_path = args[i + 1];
                set i = i + 2;
            } elif arg == "--stdlib-version" {
                if i + 1 >= len(args) {
                    set request.status = driver.DriverExitStatus::InvalidArguments;
                    set request.message = "missing value after " + arg;
                    give request;
                }
                set request.stdlib_version = args[i + 1];
                set i = i + 2;
            } else {
                set i = i + 1;
            }
        } else {
            if request.command == "metrics" and request.subcommand == "" {
                set request.subcommand = arg;
            } elif request.command == "pkg" and request.subcommand == "" {
                set request.subcommand = arg;
            } elif request.input_path == "" {
                set request.input_path = arg;
            }
            set i = i + 1;
        }
    }

    if request.input_path == "" and request.source_text != "" {
        set request.input_path = "inline.vit";
    }

    if request.command == "metrics" and request.subcommand == "" {
        set request.subcommand = "build";
    }

    if request.command != "metrics" and request.command != "health" and request.command != "pkg" and request.command != "explain" and request.command != "fix" and request.command != "reduce" and request.input_path == "" and request.source_text == "" {
        if request.command == "build" or request.command == "check" or request.command == "run" or request.command == "dump-tokens" or request.command == "dump-ast" or request.command == "dump-hir" or request.command == "dump-mir" {
            set request.input_path = ".";
        } else {
            set request.status = driver.DriverExitStatus::MissingInput;
            set request.message = "missing input file or --source text";
            give request;
        }
    }

    if request.command == "explain" and request.input_path == "" {
        set request.status = driver.DriverExitStatus::MissingInput;
        set request.message = "usage: vitte explain CODE";
        give request;
    }

    if request.command == "fix" and request.input_path == "" and request.source_text == "" {
        set request.status = driver.DriverExitStatus::MissingInput;
        set request.message = "usage: vitte fix --dry-run FILE";
        give request;
    }

    if request.command == "reduce" and request.input_path == "" and request.source_text == "" {
        set request.status = driver.DriverExitStatus::MissingInput;
        set request.message = "usage: vitte reduce --diagnostic CODE FILE";
        give request;
    }

    set request.valid = true;
    set request.status = driver.DriverExitStatus::Ok;
    set request.message = "compiler request parsed";

    give request;
}

proc cli_compile_config(request: CompilerCliRequest) -> DriverCompileConfig {
    let config: DriverCompileConfig = default_compile_config();
    let stdlib = resolve_stdlib(request.stdlib_path, request.stdlib_version);
    if not stdlib.valid or not verify_stdlib_versions(stdlib) {
        give DriverCompileConfig {
            backend_name: config.backend_name,
            target_name: config.target_name,
            profile_name: config.profile_name,
            opt_level: config.opt_level,
            packaging: config.packaging,
            deterministic: config.deterministic,
            debug_enabled: config.debug_enabled,
            emit_debug_sections: config.emit_debug_sections,
            lto_enabled: config.lto_enabled,
            pgo_mode: config.pgo_mode,
            prefer_native_toolchain: config.prefer_native_toolchain,
            llvm_toolchain: config.llvm_toolchain,
            valid: false
        };
    }
    give config;
}

proc is_internal_status(status: driver.DriverExitStatus) -> bool {
    give status == driver.DriverExitStatus::InternalError
        or status == driver.DriverExitStatus::BootstrapFailure
        or status == driver.DriverExitStatus::PipelineFailure;
}

proc print_internal_compiler_error(phase: string, source_location: string, stack_trace: string) {
    let ice0: ice.InternalCompilerError = ice.internal_compiler_error(phase, stack_trace, source_location, version_text());
    print(ice.render_internal_compiler_error_text(ice0));
}

proc cli_request_source_location(request: CompilerCliRequest) -> string {
    if request.input_path != "" {
        give request.input_path;
    }
    if request.source_text != "" {
        give "inline.vit";
    }
    give "<unknown>";
}

proc cli_request_source_path(request: CompilerCliRequest) -> string {
    if request.input_path != "" {
        give resolve_cli_input_path(request.input_path);
    }
    give "inline.vit";
}

proc build_pipeline_trace_text(command: string, status: driver.DriverExitStatus) -> string {
    let phases: [CompilerPhase] = default_pipeline_phases();
    let out: string = "";
    let i: u64 = 0;
    let max_i: u64 = if command == "build" { len(phases) } else { 11 };
    if status != driver.DriverExitStatus::Ok {
        set max_i = 3;
    }
    while i < max_i {
        let kind: PhaseResultKind = if status == driver.DriverExitStatus::Ok or i + 1 < max_i { PhaseResultKind.Success } else { PhaseResultKind.FatalError };
        let msg: string = if kind == PhaseResultKind.FatalError { "failed" } else { "" };
        let execution: PipelineExecution = run(phases[i], kind, msg, 1);
        let line: string = render_trace_line(execution.trace[0]);
        if out == "" {
            set out = line;
        } else {
            set out = out + "\n" + line;
        }
        set i = i + 1;
    }
    if status != driver.DriverExitStatus::Ok {
        set out = out + "\nBuild FAILED.";
    }
    give out;
}

proc build_pipeline_timings_text(command: string, status: driver.DriverExitStatus) -> string {
    let phases: [CompilerPhase] = default_pipeline_phases();
    let timings: [PhaseTiming] = [];
    let i: u64 = 0;
    let max_i: u64 = if command == "build" { len(phases) } else { 11 };
    if status != driver.DriverExitStatus::Ok {
        set max_i = 3;
    }
    while i < max_i {
        let ms: u64 = if i == 1 { 2 } elif i == 2 { 5 } elif i == 7 { 14 } elif i == 8 { 8 } elif i == 11 { 25 } else { 1 };
        let execution: PipelineExecution = run(phases[i], PhaseResultKind.Success, "", ms);
        set timings = timings + execution.timings;
        set i = i + 1;
    }
    give render_timings(timings);
}

proc token_kind_text(kind: TokenKind) -> string {
    if kind == TokenKind.Eof {
        give "eof";
    }
    if kind == TokenKind.Ident {
        give "ident";
    }
    if kind == TokenKind.Keyword {
        give "keyword";
    }
    if kind == TokenKind.String {
        give "string";
    }
    if kind == TokenKind.Integer {
        give "integer";
    }
    if kind == TokenKind.Float {
        give "float";
    }
    if kind == TokenKind.Char {
        give "char";
    }
    if kind == TokenKind.Symbol {
        give "symbol";
    }
    give "invalid";
}

proc render_token(token0: Token) -> string {
    let line_text: string = token0.line as string;
    let column_text: string = token0.column as string;
    let offset_text: string = token0.offset as string;
    let rendered: string = token_kind_text(token0.kind) + " lexeme " + token0.lexeme;
    set rendered = rendered + " line " + line_text;
    set rendered = rendered + " column " + column_text;
    set rendered = rendered + " offset " + offset_text;
    give rendered;
}

proc print_frontend_diagnostics_list(diagnostics0: [FrontendDiagnostic]) {
    let i: u64 = 0;
    while i < len(diagnostics0) {
        let msg: string = frontend_diag_message(diagnostics0[i]) + "\n";
        print(msg);
        set i = i + 1;
    }
}

proc print_analysis_diagnostics_list(diagnostics0: [AnalysisDiagnostic]) {
    let i: u64 = 0;
    while i < len(diagnostics0) {
        let msg: string = analysis_diag_message(diagnostics0[i]) + "\n";
        print(msg);
        set i = i + 1;
    }
}

proc print_result_diagnostics(result0: CompilerResult) {
    let i: u64 = 0;
    while i < list.len(result0.diagnostics) {
        let msg: string = report.render_text(result0.diagnostics[i]) + "\n";
        print(msg);
        set i = i + 1;
    }
}

proc cli_output_dir(path: string) -> string {
    if path == "" {
        give "build";
    }
    let i: u64 = len(path);
    while i > 0 {
        let idx: u64 = i - 1;
        let ch: string = slice(path, idx, idx + 1);
        if ch == "/" or ch == "\\" {
            if idx == 0 {
                give "/";
            }
            give slice(path, 0, idx);
        }
        set i = idx;
    }
    give ".";
}

proc cli_compiler_options(request: CompilerCliRequest, mode: CompilerMode, output_path: string) -> CompilerOptions {
    let opts: CompilerOptions = default_options();
    set opts.mode = mode;
    set opts.output_dir = cli_output_dir(output_path);
    set opts.output_path = output_path;
    set opts.verbose = request.verbose;
    set opts.trace_pipeline = request.trace_pipeline;
    give opts;
}

proc compiler_from_input(path: string, source: string, virtual: bool, options: CompilerOptions) -> Compiler {
    let compiler = new_compiler(options);
    set compiler.input = CompilerInput {
        path: path,
        source: source,
        virtual: virtual
    };
    set compiler.state.input_loaded = true;
    set compiler = sync_session_from_options(compiler);
    set compiler = sync_session_with_input(compiler);
    give compiler;
}

proc cli_request_source_text(request: CompilerCliRequest) -> string {
    if request.source_text != "" {
        give request.source_text;
    }
    if request.input_path != "" {
        give resolve_cli_input_source_text(request.input_path);
    }
    give "";
}

proc cli_request_is_virtual_source(request: CompilerCliRequest) -> bool {
    give request.source_text != "" or request.input_path == "";
}

proc print_phase_results(result0: CompilerResult, command: string) {
    let expected: [string] = [
        "source manager",
        "lexer",
        "parser",
        "AST validation",
        "module resolver",
        "HIR lowering",
        "sema",
        "typeck",
        "borrowck",
        "MIR lowering",
        "MIR verify",
        "backend",
        "linker"
    ];
    let phase_count: u64 = len(expected);
    if command == "check" {
        set phase_count = 9;
    }
    let i: u64 = 0;
    while i < phase_count {
        let success_key: string = expected[i] + "=Success";
        let hit_success: bool = false;
        let j: u64 = 0;
        while j < len(result0.phase_results) {
            if result0.phase_results[j] == success_key {
                set hit_success = true;
            }
            set j = j + 1;
        }
        if hit_success {
            let msg: string = "[OK] " + expected[i] + "\n";
            print(msg);
        } else {
            let msg: string = "[FAIL] " + expected[i] + " not executed\n";
            print(msg);
        }
        set i = i + 1;
    }
}

proc run_cli_request(request: CompilerCliRequest) -> int {
    if not request.valid {
        if request.message != "" {
            let msg: string = request.message + "\n";
            print(msg);
        }
        give cli_exit_code(request.status);
    }

    if request.command == "help" {
        let msg: string = request.message + "\n";
        print(msg);
        give cli_exit_code(driver.DriverExitStatus::Ok);
    }

    if request.command == "pkg" {
        if request.subcommand == "" or request.subcommand == "help" or request.subcommand == "--help" {
            let msg0: string = "pkg subcommands:\n";
            let msg1: string = "  check    validate packages under src/vitte/packages\n";
            let msg2: string = "  matrix   run package dependency/import diagnostics matrix\n";
            let msg3: string = "  selftest run package checks and matrix\n";
            print(msg0);
            print(msg1);
            print(msg2);
            print(msg3);
            give cli_exit_code(driver.DriverExitStatus::Ok);
        }
        let msg: string = "pkg subcommand not yet available in the self-hosted driver: " + request.subcommand + "\n";
        print(msg);
        give cli_exit_code(driver.DriverExitStatus::UnsupportedFeature);
    }

    if request.command == "explain" {
        let explanation: string = diagnostic_explain_text(request.input_path) + "\n";
        print(explanation);
        give cli_exit_code(driver.DriverExitStatus::Ok);
    }

    let source_path: string = cli_request_source_path(request);
    let source_text: string = cli_request_source_text(request);
    let virtual_source: bool = cli_request_is_virtual_source(request);
    if request.command != "metrics" and request.command != "health" and source_text == "" {
        let msg: string = "missing or unreadable input source\n";
        print(msg);
        give cli_exit_code(driver.DriverExitStatus::IoFailure);
    }

    if request.command == "fix" {
        let report_json: string = dump_diagnostics_json(source_path, source_text);
        if request.fix_apply {
            let msg_apply: string = "fix --apply refused: patch application engine is not enabled yet; run fix --dry-run first\n";
            print(msg_apply);
            give cli_exit_code(driver.DriverExitStatus::UnsupportedFeature);
        }
        let msg_fix: string = "fix dry-run: inspect FixPlan entries in diagnostics envelope\n";
        let report_json_text: string = report_json + "\n";
        print(msg_fix);
        print(report_json_text);
        give cli_exit_code(driver.DriverExitStatus::Ok);
    }

    if request.command == "reduce" {
        let msg_reduce: string = "reduce dry-run: auto-reduction engine is not enabled yet; diagnostics can be reproduced from current input\n";
        let reduce_json_text: string = dump_diagnostics_json(source_path, source_text) + "\n";
        print(msg_reduce);
        print(reduce_json_text);
        give cli_exit_code(driver.DriverExitStatus::UnsupportedFeature);
    }

    let config: DriverCompileConfig = cli_compile_config(request);
    let result: DriverCompileResult;
    if not config.valid {
        let msg: string = "invalid compiler configuration\n";
        print(msg);
        give cli_exit_code(driver.DriverExitStatus::InvalidConfiguration);
    }

    if request.command == "check" and request.diagnostic_quality {
        let report_json: string = dump_diagnostics_json(source_path, source_text) + "\n";
        print(report_json);
        if request.fail_under > 100 {
            give cli_exit_code(driver.DriverExitStatus::InvalidArguments);
        }
        if request.fail_under > 0 {
            let quality_score: u64 = diagnostics_quality_score(source_path, source_text);
            if quality_score < request.fail_under {
                give 1;
            }
        }
        give cli_exit_code(driver.DriverExitStatus::Ok);
    }

    if request.command == "check" {
        let opts: CompilerOptions = cli_compiler_options(request, CompilerMode::Check, request.output_path);
        let compiler0: Compiler = compiler_from_input(source_path, source_text, virtual_source, opts);
        let r0: CompilerResult = run_compiler(compiler0);
        if request.trace_pipeline {
            print_phase_results(r0, "check");
        }
        if request.timings {
            print(build_pipeline_timings_text("check", r0.status));
            let msg: string = "\n";
            print(msg);
        }
        if r0.status != driver.DriverExitStatus::Ok {
            print_result_diagnostics(r0);
            if list.len(r0.diagnostics) == 0 and r0.message != "" {
                let msg: string = r0.message + "\n";
                print(msg);
            }
            give r0.code as int;
        }
        let msg: string = "check succeeded\n";
        print(msg);
        give 0;
    }

    if request.command == "build" {
        let opts: CompilerOptions = cli_compiler_options(request, CompilerMode::Build, request.output_path);
        let compiler0: Compiler = compiler_from_input(source_path, source_text, virtual_source, opts);
        let r0: CompilerResult = run_compiler(compiler0);
        if request.trace_pipeline {
            print_phase_results(r0, "build");
            if r0.status == driver.DriverExitStatus::Ok {
                let msg: string = "Build OK.\n";
                print(msg);
            } else {
                let msg: string = "Build FAILED.\n";
                print(msg);
            }
        }
        if request.timings {
            print(build_pipeline_timings_text("build", r0.status));
            let msg: string = "\n";
            print(msg);
        }
        if r0.status != driver.DriverExitStatus::Ok {
            print_result_diagnostics(r0);
            if list.len(r0.diagnostics) == 0 and r0.message != "" {
                let msg: string = r0.message + "\n";
                print(msg);
            }
            give r0.code as int;
        }
        if not is_file(request.output_path) {
            let msg: string = "build failed: linker did not materialize executable: " + request.output_path + "\n";
            print(msg);
            give cli_exit_code(driver.DriverExitStatus::FilesystemFailure);
        }
        let msg: string = "build succeeded\n";
        print(msg);
        give 0;
    }

    if request.command == "run" {
        let temp_output: string = "build/vitte-run-temp";
        let opts: CompilerOptions = cli_compiler_options(request, CompilerMode::Run, temp_output);
        let compiler0: Compiler = compiler_from_input(source_path, source_text, virtual_source, opts);
        let r0: CompilerResult = run_compiler(compiler0);
        if request.trace_pipeline {
            print_phase_results(r0, "run");
        }
        if request.timings {
            print(build_pipeline_timings_text("build", r0.status));
            let msg: string = "\n";
            print(msg);
        }
        if r0.status != driver.DriverExitStatus::Ok {
            print_result_diagnostics(r0);
            if list.len(r0.diagnostics) == 0 and r0.message != "" {
                let msg: string = r0.message + "\n";
                print(msg);
            }
            give r0.code as int;
        }
        if not is_file(temp_output) {
            let msg: string = "run failed: temporary executable was not materialized: " + temp_output + "\n";
            print(msg);
            give cli_exit_code(driver.DriverExitStatus::FilesystemFailure);
        }
        give r0.output.program_exit_code;
    }

    if request.command == "dump-tokens" {
        let scanned: ScanResult = scan_tokens(source_text);
        if not scanned.valid {
            print_frontend_diagnostics_list(frontend_run(source_path, source_text).diagnostics);
            give cli_exit_code(driver.DriverExitStatus::LexFailure);
        }
        let i: u64 = 0;
        while i < len(scanned.tokens) {
            let msg: string = render_token(scanned.tokens[i]) + "\n";
            print(msg);
            set i = i + 1;
        }
        give 0;
    }

    if request.command == "dump-ast" {
        let frontend_out: FrontendOutput = frontend_run(source_path, source_text);
        if not frontend_out.valid {
            print_frontend_diagnostics_list(frontend_out.diagnostics);
            give cli_exit_code(driver.DriverExitStatus::FrontendFailure);
        }
        let msg: string = dump_ast_json(source_path, source_text) + "\n";
        print(msg);
        give 0;
    }

    if request.command == "dump-hir" {
        set result = check_source_with_config(source_path, source_text, config);
        if result.status != driver.DriverExitStatus::Ok {
            let compiler0: Compiler = compiler_from_input(source_path, source_text, virtual_source, cli_compiler_options(request, CompilerMode::Check, request.output_path));
            let r0: CompilerResult = run_compiler(compiler0);
            print_result_diagnostics(r0);
            if list.len(r0.diagnostics) == 0 and r0.message != "" {
                let msg: string = r0.message + "\n";
                print(msg);
            }
            give r0.code as int;
        }
        let msg: string = dump_hir_json(source_path, source_text) + "\n";
        print(msg);
        give 0;
    }

    if request.command == "dump-mir" {
        set result = check_source_with_config(source_path, source_text, config);
        if result.status != driver.DriverExitStatus::Ok {
            let compiler0: Compiler = compiler_from_input(source_path, source_text, virtual_source, cli_compiler_options(request, CompilerMode::Check, request.output_path));
            let r0: CompilerResult = run_compiler(compiler0);
            print_result_diagnostics(r0);
            if list.len(r0.diagnostics) == 0 and r0.message != "" {
                let msg: string = r0.message + "\n";
                print(msg);
            }
            give r0.code as int;
        }
        let msg: string = dump_mir_json(source_path, source_text) + "\n";
        print(msg);
        give 0;
    }

    if request.command == "metrics" {
        let manifest_text: string = metrics_manifest_text(source_path, request.source_text);
        if request.input_path != "" and project_path_hint(request.input_path) {
            let project_manifest: string = if manifest_text != "" { manifest_text } else { auto_project_manifest_text(request.input_path) };
            if project_manifest == "" {
                let msg: string = "{\"schema\":\"vitte.compiler.metrics\",\"schema_version\":\"1.0.0\",\"status\":\"error\",\"message\":\"project metrics auto-discovery found no readable .vit files; pass compile-set manifest via --source\"}\n";
                print(msg);
                give cli_exit_code(driver.DriverExitStatus::UnsupportedFeature);
            }
            let manifest: cli.CompileSetManifest = cli.parse_compile_set_manifest(project_manifest);
            let set_result: DriverBackendModuleSetResult = compile_source_set_with_config(manifest.inputs, config);
            let set_metrics: CompilerMetricsReport = compile_metrics_report_from_module_set(request.subcommand, request.input_path, set_result);
            let msg: string = metrics_report_json(set_metrics) + "\n";
            print(msg);
            if set_result.valid {
                give cli_exit_code(driver.DriverExitStatus::Ok);
            }
            give cli_exit_code(driver.DriverExitStatus::PipelineFailure);
        }
        if request.subcommand == "check" {
            set result = check_source_with_config(source_path, source_text, config);
        } else {
            set result = compile_source_with_config(source_path, source_text, config);
        }
        let metrics0: CompilerMetricsReport = compile_metrics_report(request.subcommand, source_path, result);
        let msg: string = metrics_report_json(metrics0) + "\n";
        print(msg);
        give cli_exit_code(result.status);
    }

    if request.command == "health" {
        set result = check_source_with_config(source_path, source_text, config);
        let metrics0: CompilerMetricsReport = compile_metrics_report("check", source_path, result);
        let dashboard: HealthDashboard = health_dashboard_from_metrics(metrics0);
        let msg: string = health_dashboard_json(dashboard) + "\n";
        print(msg);
        give cli_exit_code(driver.DriverExitStatus::Ok);
    }

    if request.command == "test" {
        give cli_exit_code(driver.DriverExitStatus::UnsupportedFeature);
    }

    give cli_exit_code(driver.DriverExitStatus::InvalidArguments);
}

proc run_cli_main(args: list[string]) -> int {
    give run_cli_main_with_ice_boundary(args);
}

proc run_cli_main_with_ice_boundary(args: list[string]) -> int {
    let request: CompilerCliRequest = parse_cli_request(args);
    let code: int = run_cli_request(request);
    if code == 2 {
        let phase: string = if request.command != "" { request.command } else { "cli" };
        let source_loc: string = cli_request_source_location(request);
        print_internal_compiler_error(
            phase,
            source_loc,
            "panic boundary: run_cli_main_with_ice_boundary > run_cli_request"
        );
    }
    give code;
}

proc new_compiler(options: CompilerOptions) -> Compiler {
    let session0: context.CompilationSession = context.default_compilation_session();
    give Compiler {
        options: options,
        state: initial_state(),
        input: empty_input(),
        output: empty_output(),
        diagnostics: [],
        session: session0,
        diagnostic_session: diagnostics.diagnostic_session(),
        logger: logger.compiler_logger(options.verbose, options.trace_pipeline)
    };
}

proc compiler_from_source(path: string, source: string, options: CompilerOptions) -> Compiler {
    let compiler = new_compiler(options);

    set compiler.input = CompilerInput {
        path: path,
        source: source,
        virtual: true
    };

    set compiler.state.input_loaded = true;
    set compiler = sync_session_from_options(compiler);
    set compiler = sync_session_with_input(compiler);

    give compiler;
}

proc backend_options_from_compiler_options(options0: CompilerOptions) -> options.BackendOptions {
    give options.BackendOptions {
        backend_name: "x86_64",
        emit_debug_sections: options0.emit_report,
        lto_enabled: false,
        pgo_mode: "off",
        prefer_native_toolchain: false
    };
}

proc optimization_level_from_profile(profile_name: string) -> options.OptimizationLevel {
    if profile_name == "debug" {
        give options.OptimizationLevel.O0;
    }
    if profile_name == "size" {
        give options.OptimizationLevel.Os;
    }
    if profile_name == "release" {
        give options.OptimizationLevel.O3;
    }
    give options.OptimizationLevel.O2;
}

proc sync_session_from_options(compiler: Compiler) -> Compiler {
    let target0: TargetConfig = target_config_from_name(compiler.options.target);
    let triple0: string = if target0.valid { target0.target_triple } else { "x86_64-linux" };
    let backend0: options.BackendOptions = options.BackendOptions {
        backend_name: if target0.valid { target0.backend_name } else { "x86_64" },
        emit_debug_sections: compiler.options.emit_report,
        lto_enabled: false,
        pgo_mode: "off",
        prefer_native_toolchain: false
    };
    let cfg0: config.CompilationConfig = config.compilation_config(
        triple0,
        optimization_level_from_profile(compiler.options.profile),
        backend0
    );
    let opts0: options.SessionOptions = options.SessionOptions {
        locale: "en-US",
        optimization_level: cfg0.optimization_level,
        backend: cfg0.backend_options
    };
    set compiler.session = context.compilation_session_with_config(cfg0, opts0);
    give compiler;
}

proc sync_session_with_input(compiler: Compiler) -> Compiler {
    let path0: string = if compiler.input.path != "" { compiler.input.path } else { "inline.vit" };
    let text0: string = compiler_source_text(compiler);
    let manager0: files.SourceManager = files.source_manager_empty();
    let manager1: files.SourceManager = if compiler.input.virtual {
        files.source_manager_with_virtual_file(manager0, path0, text0)
    } else {
        files.source_manager_with_file(manager0, path0, text0)
    };
    set compiler.session.source_manager = files.include_stdlib(manager1);
    give compiler;
}

proc set_stage(compiler: Compiler, stage: CompilerStage) -> Compiler {
    set compiler.state.stage = stage;
    give compiler;
}

proc should_stop(compiler: Compiler, stage: CompilerStage) -> bool {
    give compiler.options.stop_after == stage;
}

proc log_stage(compiler: Compiler, event: string) -> Compiler {
    set compiler.state.stage_logs = compiler.state.stage_logs + [event];
    set compiler.logger = logger.trace(compiler.logger, event);
    give compiler;
}

proc phase_result_text(result: PhaseResult) -> string {
    if result == PhaseResult::Success {
        give "Success";
    }
    if result == PhaseResult::Warning {
        give "Warning";
    }
    if result == PhaseResult::FatalError {
        give "FatalError";
    }
    if result == PhaseResult::Skipped {
        give "Skipped";
    }
    give "Unimplemented";
}

proc record_phase_result(compiler: Compiler, phase: string, result: PhaseResult, critical: bool) -> Compiler {
    let text: string = phase + manifest_entry_separator() + phase_result_text(result);
    set compiler.state.phase_results = compiler.state.phase_results + [text];
    let blocking: bool = result == PhaseResult::FatalError or result == PhaseResult::Skipped or result == PhaseResult::Unimplemented;
    if critical and blocking {
        set compiler.state.ok = false;
    }
    give compiler;
}

proc stop_after_stage_from_cli(name: string) -> CompilerStage {
    if name == "lex" {
        give CompilerStage::Lex;
    }
    if name == "parse" {
        give CompilerStage::Parse;
    }
    if name == "ast" {
        give CompilerStage::Ast;
    }
    if name == "hir" {
        give CompilerStage::Hir;
    }
    if name == "resolve" {
        give CompilerStage::Resolve;
    }
    if name == "typeck" {
        give CompilerStage::Typeck;
    }
    if name == "borrowck" {
        give CompilerStage::Borrowck;
    }
    if name == "mir" {
        give CompilerStage::Mir;
    }
    if name == "mir_validate" {
        give CompilerStage::MirValidate;
    }
    if name == "mir_optimize" {
        give CompilerStage::MirOptimize;
    }
    if name == "ir" {
        give CompilerStage::Ir;
    }
    if name == "ir_validate" {
        give CompilerStage::IrValidate;
    }
    if name == "codegen" {
        give CompilerStage::Codegen;
    }
    if name == "object" {
        give CompilerStage::Object;
    }
    if name == "link" {
        give CompilerStage::Link;
    }
    if name == "run" {
        give CompilerStage::Run;
    }
    give CompilerStage::Done;
}

proc stop_stage_in_frontend(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Lex
        or stage == CompilerStage::Parse
        or stage == CompilerStage::Ast
        or stage == CompilerStage::Hir;
}

proc stop_stage_in_analysis(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Resolve
        or stage == CompilerStage::Typeck
        or stage == CompilerStage::Borrowck;
}

proc stop_stage_in_mir(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Mir
        or stage == CompilerStage::MirValidate
        or stage == CompilerStage::MirOptimize;
}

proc stop_stage_in_ir(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Ir
        or stage == CompilerStage::IrValidate;
}

proc stop_stage_in_codegen(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Codegen
        or stage == CompilerStage::Object;
}

proc stop_stage_in_link(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Link;
}

proc stop_stage_in_run(stage: CompilerStage) -> bool {
    give stage == CompilerStage::Run;
}

proc stop_reached_in_frontend(compiler: Compiler) -> bool {
    give stop_stage_in_frontend(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_analysis(compiler: Compiler) -> bool {
    give stop_stage_in_analysis(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_mir(compiler: Compiler) -> bool {
    give stop_stage_in_mir(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_ir(compiler: Compiler) -> bool {
    give stop_stage_in_ir(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_codegen(compiler: Compiler) -> bool {
    give stop_stage_in_codegen(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_link(compiler: Compiler) -> bool {
    give stop_stage_in_link(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc stop_reached_in_run(compiler: Compiler) -> bool {
    give stop_stage_in_run(compiler.options.stop_after)
        and compiler.state.stage == compiler.options.stop_after;
}

proc fail(compiler: Compiler, status: driver.DriverExitStatus, message: string) -> CompilerResult {
    set compiler.state.ok = false;
    set compiler.logger = logger.error(compiler.logger, message);

    give CompilerResult {
        status: status,
        code: driver.exit_code(status),
        message: message,
        stage: compiler.state.stage,
        output: compiler.output,
        diagnostics: compiler.diagnostics,
        stage_logs: compiler.state.stage_logs,
        phase_results: compiler.state.phase_results
    };
}

proc success(compiler: Compiler, message: string) -> CompilerResult {
    set compiler.logger = logger.info(compiler.logger, message);
    give CompilerResult {
        status: driver.DriverExitStatus::Ok,
        code: 0,
        message: message,
        stage: compiler.state.stage,
        output: compiler.output,
        diagnostics: compiler.diagnostics,
        stage_logs: compiler.state.stage_logs,
        phase_results: compiler.state.phase_results
    };
}

proc add_diagnostic(compiler: Compiler, diagnostic: report.Diagnostic) -> Compiler {
    set compiler.diagnostics = list.push(compiler.diagnostics, diagnostic);

    give compiler;
}

proc emit_session_diagnostic(compiler: Compiler, severity: string, code: string, file: string, line: u64, column: u64, message: string) -> Compiler {
    let path0: string = if file != "" { file } else { compiler.input.path };
    let manager0: files.SourceManager = files.cache_source(compiler.session.source_manager, path0, compiler_source_text(compiler), compiler.input.virtual);
    let span0: files.SourceSpan = diagnostics.manager_span_from_location(manager0, path0, line, column);
    if severity == "fatal" {
        set compiler.diagnostic_session = diagnostics.emit_fatal(compiler.diagnostic_session, code, message, span0);
    } elif severity == "warning" {
        set compiler.diagnostic_session = diagnostics.emit_warning(compiler.diagnostic_session, code, message, span0);
    } elif severity == "note" {
        set compiler.diagnostic_session = diagnostics.emit_note(compiler.diagnostic_session, code, message, span0);
    } else {
        set compiler.diagnostic_session = diagnostics.emit_error(compiler.diagnostic_session, code, message, span0);
    }
    set compiler.session.source_manager = manager0;
    give compiler;
}

proc emit_session_diagnostic_with_span(compiler: Compiler, severity: string, code: string, message: string, span0: files.SourceSpan) -> Compiler {
    if !span0.valid {
        give compiler;
    }
    if severity == "fatal" {
        set compiler.diagnostic_session = diagnostics.emit_fatal(compiler.diagnostic_session, code, message, span0);
    } elif severity == "warning" {
        set compiler.diagnostic_session = diagnostics.emit_warning(compiler.diagnostic_session, code, message, span0);
    } elif severity == "note" {
        set compiler.diagnostic_session = diagnostics.emit_note(compiler.diagnostic_session, code, message, span0);
    } else {
        set compiler.diagnostic_session = diagnostics.emit_error(compiler.diagnostic_session, code, message, span0);
    }
    give compiler;
}

proc has_diagnostics(compiler: Compiler) -> bool {
    give list.len(compiler.diagnostics) > 0;
}

proc configure_compiler(compiler: Compiler) -> Compiler {
    set compiler = set_stage(compiler, CompilerStage::Configure);
    set compiler = sync_session_from_options(compiler);

    if compiler.options.target == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_MISSING_TARGET",
            "missing compiler target"
        );
        set compiler.state.ok = false;
    }

    if compiler.options.output_dir == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_MISSING_OUTPUT_DIR",
            "missing compiler output directory"
        );
        set compiler.state.ok = false;
    }
    if compiler.options.output_path == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_MISSING_OUTPUT_PATH",
            "missing compiler output path"
        );
        set compiler.state.ok = false;
    }

    give compiler;
}

proc validate_input(compiler: Compiler) -> Compiler {
    set compiler = set_stage(compiler, CompilerStage::LoadInput);

    if compiler.input.path == "" && compiler.input.source == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_NO_INPUT",
            "no input file or source provided"
        );
        set compiler.state.ok = false;
    }

    if compiler.input.path != "" {
        set compiler.state.input_loaded = true;
    }
    set compiler = sync_session_with_input(compiler);

    give compiler;
}

proc validate_compiler_links(compiler: Compiler) -> Compiler {
    if !compiler.options.validate_links {
        give compiler;
    }

    if compiler.options.target == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_INVALID_LINK_TARGET",
            "invalid compiler link: target is empty"
        );
        set compiler.state.ok = false;
    }
    let target0: TargetConfig = target_config_from_name(compiler.options.target);
    if !target0.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_INVALID_TARGET_CONFIG",
            structured_driver_failure_message(
                "unsupported target config: " + compiler.options.target,
                compiler.options.target,
                "llvm",
                "",
                "",
                ""
            )
        );
        set compiler.state.ok = false;
    } else {
        set compiler.options.target = target0.target_triple;
        let ptr_text: string = target0.pointer_size as string;
        let debug_msg: string = "target_config name " + target0.name;
        set debug_msg = debug_msg + " ptr " + ptr_text;
        set debug_msg = debug_msg + " endian " + target0.endianness;
        set debug_msg = debug_msg + " abi " + target0.abi;
        set debug_msg = debug_msg + " linker " + target0.linker_path;
        set debug_msg = debug_msg + " format " + target0.object_format;
        set compiler.logger = logger.debug(
            compiler.logger,
            debug_msg
        );
    }

    if compiler.options.profile == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_INVALID_LINK_PROFILE",
            "invalid compiler link: profile is empty"
        );
        set compiler.state.ok = false;
    }

    give compiler;
}

proc compiler_source_text(compiler: Compiler) -> string {
    if compiler.input.source != "" {
        give compiler.input.source;
    }
    if compiler.input.path != "" {
        give read_file(compiler.input.path);
    }
    give "";
}

proc typed_diag_text(severity: string, code: string, file: string, line: u64, column: u64, message: string) -> string {
    let colored_severity: string = cli_colored_severity(severity);
    let line_text: string = line as string;
    let column_text: string = column as string;
    let out: string = "severity " + colored_severity;
    set out = out + " code " + code;
    set out = out + " span " + file;
    set out = out + ":" + line_text;
    set out = out + ":" + column_text;
    set out = out + " message " + message;
    give out;
}

proc cli_ansi_reset() -> string {
    give "";
}

proc cli_ansi_bold() -> string {
    give "";
}

proc cli_ansi_bright_red() -> string {
    give "";
}

proc cli_ansi_yellow() -> string {
    give "";
}

proc cli_ansi_blue() -> string {
    give "";
}

proc cli_ansi_cyan() -> string {
    give "";
}

proc cli_colored_severity(severity: string) -> string {
    if severity == "fatal" or severity == "error" {
        give cli_ansi_bold() + cli_ansi_bright_red() + severity + cli_ansi_reset();
    }

    if severity == "warning" {
        give cli_ansi_bold() + cli_ansi_yellow() + severity + cli_ansi_reset();
    }

    if severity == "note" {
        give cli_ansi_blue() + severity + cli_ansi_reset();
    }

    if severity == "help" {
        give cli_ansi_cyan() + severity + cli_ansi_reset();
    }

    give severity;
}

proc frontend_diag_message(diag: FrontendDiagnostic) -> string {
    let sev: string = if diag.fatal { "fatal" } else { "error" };
    give typed_diag_text(
        sev,
        "DRIVER_E_FRONTEND_DIAG_" + diag.code,
        diag.file,
        diag.line,
        diag.column,
        diag.message
    );
}

proc analysis_diag_message(diag: AnalysisDiagnostic) -> string {
    give typed_diag_text(
        diag.severity,
        "DRIVER_E_ANALYSIS_DIAG_" + diag.code,
        diag.file,
        diag.line,
        diag.column,
        diag.phase + ": " + diag.message
    );
}

proc add_typed_diagnostic(compiler: Compiler, severity: string, code: string, message: string) -> Compiler {
    set compiler = emit_session_diagnostic(
        compiler,
        severity,
        code,
        compiler.input.path,
        1,
        1,
        message
    );
    let d = report.diagnostic(severity, code, compiler.input.path, 1, 1, message);
    give add_diagnostic(compiler, d);
}

proc structured_driver_failure_message(headline: string, target_name: string, backend_name: string, command_text: string, stderr_text: string, expected_artifact: string) -> string {
    let message: string = headline;
    let target0: string = target_name;
    let backend0: string = backend_name;
    let command0: string = command_text;
    let stderr0: string = stderr_text;
    let artifact0: string = expected_artifact;

    if target0 != "" {
        set message = message + "\n  target: " + target0;
    }
    if backend0 != "" {
        set message = message + "\n  backend: " + backend0;
    }
    if command0 != "" {
        set message = message + "\n  command: " + command0;
    }
    if stderr0 != "" {
        set message = message + "\n  stderr: " + stderr0;
    }
    if artifact0 != "" {
        set message = message + "\n  expected_artifact: " + artifact0;
    }

    give message;
}

proc append_frontend_diagnostics(compiler: Compiler, diagnostics: [FrontendDiagnostic]) -> Compiler {
    let out: Compiler = compiler;
    let i: u64 = 0;
    while i < len(diagnostics) {
        let severity: string = if diagnostics[i].fatal { "fatal" } else { "error" };
        let d = report.diagnostic(
            severity,
            "DRIVER_E_FRONTEND_DIAG_" + diagnostics[i].code,
            diagnostics[i].file,
            diagnostics[i].line,
            diagnostics[i].column,
            diagnostics[i].message
        );
        set out = emit_session_diagnostic_with_span(
            out,
            severity,
            "DRIVER_E_FRONTEND_DIAG_" + diagnostics[i].code,
            diagnostics[i].message,
            files.source_span(diagnostics[i].file_id, diagnostics[i].span_start, diagnostics[i].span_end)
        );
        set out = add_diagnostic(out, d);
        set i = i + 1;
    }
    set out.session.module_graph.modules = out.session.module_graph.modules + ["frontend/ast"];
    give out;
}

proc append_analysis_diagnostics(compiler: Compiler, diagnostics: [AnalysisDiagnostic]) -> Compiler {
    let out: Compiler = compiler;
    let i: u64 = 0;
    while i < len(diagnostics) {
        let d = report.diagnostic(
            diagnostics[i].severity,
            "DRIVER_E_ANALYSIS_DIAG_" + diagnostics[i].code,
            diagnostics[i].file,
            diagnostics[i].line,
            diagnostics[i].column,
            diagnostics[i].phase + ": " + diagnostics[i].message
        );
        set out = emit_session_diagnostic_with_span(
            out,
            diagnostics[i].severity,
            "DRIVER_E_ANALYSIS_DIAG_" + diagnostics[i].code,
            diagnostics[i].phase + ": " + diagnostics[i].message,
            files.source_span(diagnostics[i].file_id, diagnostics[i].span_start, diagnostics[i].span_end)
        );
        set out = add_diagnostic(out, d);
        set i = i + 1;
    }
    set out.session.symbol_tables.scopes = out.session.symbol_tables.scopes + ["analysis/global"];
    give out;
}

proc run_frontend(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Lex);
    if should_stop(compiler, CompilerStage::Lex) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }

    if !compiler.state.input_loaded {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_FRONTEND_INPUT_NOT_LOADED",
            "frontend failed: input was not loaded"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Parse);
    if should_stop(compiler, CompilerStage::Parse) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }

    if compiler.input.source == "" && compiler.input.path == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_PARSE_EMPTY_SOURCE",
            "parse failed: empty source input"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput = frontend_run(compiler.input.path, compiler_source_text(compiler));
    set compiler = append_frontend_diagnostics(compiler, frontend_out.diagnostics);
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !frontend_out.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_FRONTEND_INVALID",
            "frontend pipeline returned invalid output"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if frontend_out.toplevel_count == 0 or !frontend_out.ast_root.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_PARSE_EMPTY_AST",
            "parser returned empty or invalid AST"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Ast);
    if should_stop(compiler, CompilerStage::Ast) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }
    set compiler = set_stage(compiler, CompilerStage::Hir);
    if should_stop(compiler, CompilerStage::Hir) {
        set compiler.state.frontend_ok = true;
        give compiler;
    }

    set compiler.state.frontend_ok = true;
    set compiler.session.module_graph.valid = true;

    give compiler;
}

proc run_analysis(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Resolve);
    if should_stop(compiler, CompilerStage::Resolve) {
        set compiler.state.analysis_ok = true;
        give compiler;
    }

    if !compiler.state.frontend_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_ANALYSIS_FRONTEND_INCOMPLETE",
            "analysis failed: frontend did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput = frontend_run(compiler.input.path, compiler_source_text(compiler));
    let analysis_out: AnalysisOutput = analysis_run(frontend_out);
    set compiler = append_frontend_diagnostics(compiler, frontend_out.diagnostics);
    set compiler = append_analysis_diagnostics(compiler, analysis_out.diagnostics);
    if not analysis_out.sema_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_SEMA_NOT_EXECUTED",
            "semantic analysis was not executed successfully"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Typeck);
    if not analysis_out.typeck_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_TYPECK_NOT_EXECUTED",
            "type checking was not executed successfully"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if should_stop(compiler, CompilerStage::Typeck) {
        set compiler.state.analysis_ok = true;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Borrowck);
    if not analysis_out.borrowck_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_BORROWCK_NOT_EXECUTED",
            "borrow checker was not executed successfully"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if should_stop(compiler, CompilerStage::Borrowck) {
        set compiler.state.analysis_ok = true;
        give compiler;
    }
    if compiler.diagnostic_session.fatal_count > 0 or not analysis_out.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_ANALYSIS_INVALID",
            "analysis pipeline returned invalid output"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler.state.analysis_ok = true;
    set compiler.session.symbol_tables.valid = true;

    give compiler;
}

proc run_mir_pipeline(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Mir);
    if should_stop(compiler, CompilerStage::Mir) {
        set compiler.state.mir_ok = true;
        give compiler;
    }

    if !compiler.state.analysis_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_MIR_ANALYSIS_INCOMPLETE",
            "MIR build failed: analysis did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput = frontend_run(compiler.input.path, compiler_source_text(compiler));
    let middle_out: MiddleOutput = middle_run(frontend_out);
    set compiler = append_frontend_diagnostics(compiler, frontend_out.diagnostics);
    set compiler = append_analysis_diagnostics(compiler, middle_out.analysis.diagnostics);
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !middle_out.analysis.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_MIR_ANALYSIS_INVALID",
            "middle pipeline analysis invalid"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    if !middle_out.mir.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_MIR_INVALID",
            "MIR validation failed in middle pipeline"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::MirValidate);
    if should_stop(compiler, CompilerStage::MirValidate) {
        set compiler.state.mir_ok = true;
        give compiler;
    }
    set compiler = set_stage(compiler, CompilerStage::MirOptimize);
    if should_stop(compiler, CompilerStage::MirOptimize) {
        set compiler.state.mir_ok = true;
        give compiler;
    }

    set compiler.state.mir_ok = true;
    set compiler.session.interners.valid = true;

    give compiler;
}

proc run_ir_pipeline(compiler: Compiler) -> Compiler {
    set compiler = sync_session_with_input(compiler);
    set compiler = set_stage(compiler, CompilerStage::Ir);
    if should_stop(compiler, CompilerStage::Ir) {
        set compiler.state.ir_ok = true;
        give compiler;
    }

    if !compiler.state.mir_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_IR_MIR_INCOMPLETE",
            "mir_to_ir failed: MIR pipeline did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let frontend_out: FrontendOutput = frontend_run(compiler.input.path, compiler_source_text(compiler));
    let middle_out: MiddleOutput = middle_run(frontend_out);
    set compiler = append_frontend_diagnostics(compiler, frontend_out.diagnostics);
    set compiler = append_analysis_diagnostics(compiler, middle_out.analysis.diagnostics);
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !middle_out.ir.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_IR_INVALID",
            "IR lowering/verification failed in middle pipeline"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::IrValidate);
    if should_stop(compiler, CompilerStage::IrValidate) {
        set compiler.state.ir_ok = true;
        give compiler;
    }

    set compiler.state.ir_ok = true;
    set compiler.session.package_registry.valid = true;

    give compiler;
}

proc native_compile_config_for_compiler(compiler: Compiler, packaging: string) -> DriverCompileConfig {
    let target0: string = if compiler.options.target != "" {
        compiler.options.target
    } else {
        "x86_64-linux"
    };
    let profile0: string = if compiler.options.profile != "" {
        compiler.options.profile
    } else {
        "enterprise-default"
    };
    let config0: DriverCompileConfig = default_compile_config();
    give DriverCompileConfig {
        backend_name: "llvm",
        target_name: target0,
        profile_name: profile0,
        opt_level: config0.opt_level,
        packaging: packaging,
        deterministic: true,
        debug_enabled: compiler.options.emit_report or compiler.options.verbose,
        emit_debug_sections: compiler.options.emit_report,
        lto_enabled: config0.lto_enabled,
        pgo_mode: config0.pgo_mode,
        prefer_native_toolchain: true,
        llvm_toolchain: default_llvm_toolchain_paths(),
        valid: true
    };
}

proc run_codegen(compiler: Compiler) -> Compiler {
    set compiler = sync_session_from_options(compiler);
    set compiler = set_stage(compiler, CompilerStage::Codegen);
    if should_stop(compiler, CompilerStage::Codegen) {
        set compiler.state.codegen_ok = true;
        give compiler;
    }

    if !compiler.state.ir_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_CODEGEN_IR_INCOMPLETE",
            "codegen failed: IR pipeline did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let native_out: DriverNativeBackendResult = emit_native_backend_object_with_config(compiler.input.path, compiler_source_text(compiler), compiler.options.output_path, native_compile_config_for_compiler(compiler, "executable"));
    let native_config: DriverCompileConfig = native_compile_config_for_compiler(compiler, "executable");
    let backend_out: BackendPipelineResult = native_out.backend;
    set compiler = append_frontend_diagnostics(compiler, backend_out.frontend.diagnostics);
    set compiler = append_analysis_diagnostics(compiler, backend_out.analysis.diagnostics);
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !backend_out.codegen.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_CODEGEN_INVALID",
            structured_driver_failure_message(
                "backend codegen failed",
                native_config.target_name,
                native_config.backend_name,
                "",
                backend_out.message,
                native_out.object_result.object_path
            )
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if !backend_out.codegen.object_ready or backend_out.codegen.section_count == 0 or backend_out.codegen.object_text == "" {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_BACKEND_EMPTY_OUTPUT",
            structured_driver_failure_message(
                "backend generated an empty object output",
                native_config.target_name,
                native_config.backend_name,
                "host_emit_llvm_object(<llvm-ir>, " + native_out.object_result.object_path + ")",
                "no object payload was produced by the backend pipeline",
                native_out.object_result.object_path
            )
        );
        set compiler.state.ok = false;
        give compiler;
    }
    let native_object: NativeBridgeResult = native_out.object_result;
    if not native_object.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_BACKEND_NATIVE_OBJECT",
            structured_driver_failure_message(
                native_object.message,
                native_config.target_name,
                native_config.backend_name,
                "host_emit_llvm_object(<llvm-ir>, " + native_object.object_path + ")",
                "stderr unavailable from native host runtime bridge",
                native_object.object_path
            )
        );
        set compiler.state.ok = false;
        give compiler;
    }

    set compiler = set_stage(compiler, CompilerStage::Object);
    if should_stop(compiler, CompilerStage::Object) {
        set compiler.state.codegen_ok = true;
        give compiler;
    }

    set compiler.output.object_path = native_object.object_path;

    set compiler.state.codegen_ok = true;

    give compiler;
}

proc run_linker(compiler: Compiler) -> Compiler {
    set compiler = sync_session_from_options(compiler);
    set compiler = set_stage(compiler, CompilerStage::Link);
    if should_stop(compiler, CompilerStage::Link) {
        set compiler.state.link_ok = true;
        give compiler;
    }

    if !compiler.state.codegen_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_LINK_CODEGEN_INCOMPLETE",
            "link failed: object emission did not complete"
        );
        set compiler.state.ok = false;
        give compiler;
    }

    let native_out: DriverNativeBackendResult = link_native_backend_executable_with_config(compiler.input.path, compiler_source_text(compiler), compiler.options.output_path, native_compile_config_for_compiler(compiler, "executable"));
    let native_config: DriverCompileConfig = native_compile_config_for_compiler(compiler, "executable");
    let backend_out: BackendPipelineResult = native_out.backend;
    set compiler = append_frontend_diagnostics(compiler, backend_out.frontend.diagnostics);
    set compiler = append_analysis_diagnostics(compiler, backend_out.analysis.diagnostics);
    if compiler.diagnostic_session.fatal_count > 0 {
        set compiler.state.ok = false;
        give compiler;
    }

    if !backend_out.artifact.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_LINK_INVALID",
            structured_driver_failure_message(
                "backend linker artifact invalid",
                native_config.target_name,
                native_config.backend_name,
                "link_ir_unit_with_kind(<ir>, " + compiler.options.output_path + ", executable)",
                backend_out.message,
                compiler.options.output_path
            )
        );
        set compiler.state.ok = false;
        give compiler;
    }
    if len(backend_out.artifact.outputs) == 0 {
        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_LINK_NO_OUTPUT",
            structured_driver_failure_message(
                "linker did not produce any output artifact",
                native_config.target_name,
                native_config.backend_name,
                "link_ir_unit_with_kind(<ir>, " + compiler.options.output_path + ", executable)",
                "artifact output list is empty",
                compiler.options.output_path
            )
        );
        set compiler.state.ok = false;
        give compiler;
    }
    let native_link: NativeBridgeResult = native_out.executable_result;
    if not native_link.valid {
        let native_object_path: string = native_out.object_result.object_path;
        let link_stderr: string = "stderr unavailable from native host runtime bridge";

        if native_object_path == "" {
            set link_stderr = "object file absent before native link step";
        } elif !is_file(native_object_path) {
            set link_stderr = "object file missing on disk before native link step: " + native_object_path;
        }

        set compiler = add_typed_diagnostic(
            compiler,
            "fatal",
            "DRIVER_E_LINK_NATIVE_OUTPUT",
            structured_driver_failure_message(
                native_link.message,
                native_config.target_name,
                native_config.backend_name,
                "host_link_executable(" + native_object_path + ", " + compiler.options.output_path + ")",
                link_stderr,
                compiler.options.output_path
            )
        );
        set compiler.state.ok = false;
        give compiler;
    }

    if compiler.output.object_path == "" {
        set compiler.output.object_path = native_out.object_result.object_path;
    }
    set compiler.output.executable_path = native_link.executable_path;

    set compiler.state.link_ok = true;

    give compiler;
}

proc run_executable(compiler: Compiler) -> Compiler {
    set compiler = set_stage(compiler, CompilerStage::Run);
    if should_stop(compiler, CompilerStage::Run) {
        give compiler;
    }

    if !compiler.state.link_ok {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_RUN_LINK_INCOMPLETE",
            "run failed: executable was not linked"
        );
        set compiler.state.ok = false;
        give compiler;
    }
    let executed: NativeBridgeResult = run_native_executable(compiler.output.executable_path);
    if not executed.valid {
        set compiler = add_typed_diagnostic(
            compiler,
            "error",
            "DRIVER_E_RUN_PROCESS_FAILED",
            executed.message
        );
        set compiler.state.ok = false;
        give compiler;
    }
    set compiler.output.program_exit_code = executed.exit_code;
    give compiler;
}

proc status_for_stage(stage: CompilerStage) -> driver.DriverExitStatus {
    if stage == CompilerStage::LoadInput {
        give driver.DriverExitStatus::InvalidInput;
    }

    if stage == CompilerStage::Lex {
        give driver.DriverExitStatus::LexFailure;
    }

    if stage == CompilerStage::Parse {
        give driver.DriverExitStatus::ParseFailure;
    }

    if stage == CompilerStage::Ast {
        give driver.DriverExitStatus::AstFailure;
    }

    if stage == CompilerStage::Hir {
        give driver.DriverExitStatus::HirFailure;
    }

    if stage == CompilerStage::Resolve {
        give driver.DriverExitStatus::ResolveFailure;
    }

    if stage == CompilerStage::Typeck {
        give driver.DriverExitStatus::TypeFailure;
    }

    if stage == CompilerStage::Borrowck {
        give driver.DriverExitStatus::BorrowckFailure;
    }

    if stage == CompilerStage::Mir {
        give driver.DriverExitStatus::MirBuildFailure;
    }

    if stage == CompilerStage::MirValidate {
        give driver.DriverExitStatus::MirValidationFailure;
    }

    if stage == CompilerStage::Ir {
        give driver.DriverExitStatus::IrLoweringFailure;
    }

    if stage == CompilerStage::IrValidate {
        give driver.DriverExitStatus::IrValidationFailure;
    }

    if stage == CompilerStage::Codegen {
        give driver.DriverExitStatus::CodegenFailure;
    }

    if stage == CompilerStage::Object {
        give driver.DriverExitStatus::ObjectEmissionFailure;
    }

    if stage == CompilerStage::Link {
        give driver.DriverExitStatus::LinkFailure;
    }

    give driver.DriverExitStatus::InternalError;
}

proc finalize_compiler(compiler: Compiler) -> CompilerResult {
    if diagnostics.has_errors(compiler.diagnostic_session) {
        give fail(
            compiler,
            status_for_stage(compiler.state.stage),
            "compiler failed: diagnostics session contains errors"
        );
    }

    if !compiler.state.ok {
        give fail(
            compiler,
            status_for_stage(compiler.state.stage),
            "compiler failed at stage: " + stage_name(compiler.state.stage)
        );
    }

    if compiler.state.stage == compiler.options.stop_after {
        give success(
            compiler,
            "compiler stopped after stage: " + stage_name(compiler.state.stage)
        );
    }

    set compiler = set_stage(compiler, CompilerStage::Done);

    give success(compiler, "compiler pipeline completed successfully");
}

proc run_compiler(compiler: Compiler) -> CompilerResult {
    set compiler = log_stage(compiler, "enter:1.load_source");
    set compiler.diagnostic_session = diagnostics.diagnostic_session();
    set compiler = record_phase_result(compiler, "source manager", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:1.load_source:ok");

    set compiler = log_stage(compiler, "enter:2.lex+3.parse+4.validate_ast");
    set compiler = configure_compiler(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "lexer", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "parser", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "AST validation", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:2.lex+3.parse+4.validate_ast:failed");
        give finalize_compiler(compiler);
    }

    set compiler = validate_input(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "lexer", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "parser", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "AST validation", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:2.lex+3.parse+4.validate_ast:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "lexer", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "parser", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "AST validation", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:2.lex+3.parse+4.validate_ast:ok");

    set compiler = log_stage(compiler, "enter:5.resolve_modules");
    set compiler = validate_compiler_links(compiler);

    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "module resolver", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:5.resolve_modules:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "module resolver", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:5.resolve_modules:ok");

    set compiler = log_stage(compiler, "enter:6.lower_hir+7.sema+8.typeck+9.borrowck");
    set compiler = run_frontend(compiler);

    if stop_reached_in_frontend(compiler) {
        set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:stopped");
        give finalize_compiler(compiler);
    }
    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "HIR lowering", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:failed");
        give finalize_compiler(compiler);
    }

    set compiler = run_analysis(compiler);

    if stop_reached_in_analysis(compiler) {
        set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:stopped");
        give finalize_compiler(compiler);
    }
    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "HIR lowering", PhaseResult::Success, true);
        if compiler.state.stage == CompilerStage::Resolve {
            set compiler = record_phase_result(compiler, "sema", PhaseResult::FatalError, true);
            set compiler = record_phase_result(compiler, "typeck", PhaseResult::Skipped, true);
            set compiler = record_phase_result(compiler, "borrowck", PhaseResult::Skipped, true);
        } elif compiler.state.stage == CompilerStage::Typeck {
            set compiler = record_phase_result(compiler, "sema", PhaseResult::Success, true);
            set compiler = record_phase_result(compiler, "typeck", PhaseResult::FatalError, true);
            set compiler = record_phase_result(compiler, "borrowck", PhaseResult::Skipped, true);
        } else {
            set compiler = record_phase_result(compiler, "sema", PhaseResult::Success, true);
            set compiler = record_phase_result(compiler, "typeck", PhaseResult::Success, true);
            set compiler = record_phase_result(compiler, "borrowck", PhaseResult::FatalError, true);
        }
        set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "HIR lowering", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "sema", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "typeck", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "borrowck", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:ok");

    if compiler.options.mode == CompilerMode::Check {
        set compiler = log_stage(compiler, "check:complete-after-borrowck");
        give finalize_compiler(compiler);
    }

    set compiler = log_stage(compiler, "enter:10.lower_mir+11.verify_mir+12.optimize");
    set compiler = run_mir_pipeline(compiler);

    if stop_reached_in_mir(compiler) {
        set compiler = log_stage(compiler, "exit:10.lower_mir+11.verify_mir+12.optimize:stopped");
        give finalize_compiler(compiler);
    }
    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "MIR lowering", PhaseResult::FatalError, true);
        set compiler = record_phase_result(compiler, "MIR verify", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:10.lower_mir+11.verify_mir+12.optimize:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "MIR lowering", PhaseResult::Success, true);
    set compiler = record_phase_result(compiler, "MIR verify", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:10.lower_mir+11.verify_mir+12.optimize:ok");

    set compiler = log_stage(compiler, "enter:13.backend_emit+14.object_file");
    set compiler = run_ir_pipeline(compiler);

    if stop_reached_in_ir(compiler) {
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:stopped");
        give finalize_compiler(compiler);
    }
    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "backend", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:failed");
        give finalize_compiler(compiler);
    }

    set compiler = run_codegen(compiler);

    if stop_reached_in_codegen(compiler) {
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:stopped");
        give finalize_compiler(compiler);
    }
    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "backend", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "backend", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:13.backend_emit+14.object_file:ok");

    set compiler = log_stage(compiler, "enter:15.link_executable");
    set compiler = run_linker(compiler);

    if stop_reached_in_link(compiler) {
        set compiler = log_stage(compiler, "exit:15.link_executable:stopped");
        give finalize_compiler(compiler);
    }
    if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
        set compiler = record_phase_result(compiler, "linker", PhaseResult::FatalError, true);
        set compiler = log_stage(compiler, "exit:15.link_executable:failed");
        give finalize_compiler(compiler);
    }
    set compiler = record_phase_result(compiler, "linker", PhaseResult::Success, true);
    set compiler = log_stage(compiler, "exit:15.link_executable:ok");

    if compiler.options.mode == CompilerMode::Run {
        set compiler = log_stage(compiler, "enter:run_executable");
        set compiler = run_executable(compiler);
        if stop_reached_in_run(compiler) {
            set compiler = log_stage(compiler, "exit:run_executable:stopped");
            give finalize_compiler(compiler);
        }
        if !compiler.state.ok or compiler.diagnostic_session.fatal_count > 0 {
            set compiler = log_stage(compiler, "exit:run_executable:failed");
            give finalize_compiler(compiler);
        }
        set compiler = log_stage(compiler, "exit:run_executable:ok");
    }

    give finalize_compiler(compiler);
}

proc compile_source(path: string, source: string, options: CompilerOptions) -> CompilerResult {
    let compiler = compiler_from_source(path, source, options);
    give run_compiler(compiler);
}

proc compile_file(path: string, options: CompilerOptions) -> CompilerResult {
    let compiler = new_compiler(options);

    set compiler.input = CompilerInput {
        path: path,
        source: read_file(path),
        virtual: false
    };

    give run_compiler(compiler);
}

proc stage_name(stage: CompilerStage) -> string {
    if stage == CompilerStage::Init {
        give "init";
    }

    if stage == CompilerStage::Configure {
        give "configure";
    }

    if stage == CompilerStage::LoadInput {
        give "load_input";
    }

    if stage == CompilerStage::Lex {
        give "lex";
    }

    if stage == CompilerStage::Parse {
        give "parse";
    }

    if stage == CompilerStage::Ast {
        give "ast";
    }

    if stage == CompilerStage::Hir {
        give "hir";
    }

    if stage == CompilerStage::Resolve {
        give "resolve";
    }

    if stage == CompilerStage::Typeck {
        give "typeck";
    }

    if stage == CompilerStage::Borrowck {
        give "borrowck";
    }

    if stage == CompilerStage::Mir {
        give "mir";
    }

    if stage == CompilerStage::MirValidate {
        give "mir_validate";
    }

    if stage == CompilerStage::MirOptimize {
        give "mir_optimize";
    }

    if stage == CompilerStage::Ir {
        give "ir";
    }

    if stage == CompilerStage::IrValidate {
        give "ir_validate";
    }

    if stage == CompilerStage::Codegen {
        give "codegen";
    }

    if stage == CompilerStage::Object {
        give "object";
    }

    if stage == CompilerStage::Link {
        give "link";
    }

    if stage == CompilerStage::Run {
        give "run";
    }

    if stage == CompilerStage::Done {
        give "done";
    }

    give "unknown";
}

