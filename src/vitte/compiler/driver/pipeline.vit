space vitte/compiler/driver

use vitte/compiler/driver/commands.{ DriverCommand, command_from_text }
use vitte/compiler/driver/compile.{ DriverAnalysisArtifacts, DriverBackendModuleSetResult, DriverCompileConfig, DriverCompileResult, DriverDiagnostic, DriverDiagnosticLevel, DriverModuleInput, DriverModuleSetArtifacts, analyze_source, check_source_with_config, compile_source_set_with_config, compile_source_with_config, default_compile_config, dump_ast_json, dump_diagnostics_json, dump_hir_json, dump_mir_json }
use vitte/compiler/backend/ir.{ ir_validation_reason, unit_is_valid }
use vitte/compiler/middle/mir/validate.{ mir_validation_reason }
use vitte/compiler/driver/exit_status.{ exit_code }
use vitte/compiler/driver/result.{ CliReportResult, CliRunResult }
use vitte/compiler/driver/integration_registry.{ compiler_critical_modules, driver_integration_stamp }

form PipelineFailureSummary {
    pipeline_failed_at: string
    pipeline_failure_reason: string
    validation_reason: string
}

form CompileReport {
    command: string
    source_path: string
    exit_code: u64
    backend_name: string
    target_name: string
    profile_name: string
    opt_level: string
    packaging: string
    deterministic: bool
    debug_enabled: bool
    emit_debug_sections: bool
    lto_enabled: bool
    pgo_mode: string
    prefer_native_toolchain: bool
    llvm_toolchain_summary: string
    codegen_object_format: string
    codegen_section_count: u64
    diagnostic_count: u64
    diagnostics: [DriverDiagnostic]
    active_modules: [string]
    inactive_modules: [string]
    status: string
    message: string
    pipeline_failed_at: string
    pipeline_failure_reason: string
    validation_reason: string
    grammar_version: string
    token_count: u64
    toplevel_count: u64
    stmt_count: u64
    expr_count: u64
    type_count: u64
    pattern_count: u64
    stage_logs: [string]
}

form ModuleSetCompileReport {
    command: string
    module_count: u64
    exit_code: u64
    backend_name: string
    target_name: string
    profile_name: string
    opt_level: string
    packaging: string
    deterministic: bool
    debug_enabled: bool
    emit_debug_sections: bool
    lto_enabled: bool
    pgo_mode: string
    prefer_native_toolchain: bool
    llvm_toolchain_summary: string
    codegen_object_format: string
    codegen_section_count: u64
    diagnostic_count: u64
    diagnostics: [DriverDiagnostic]
    status: string
    message: string
    pipeline_failed_at: string
    pipeline_failure_reason: string
    validation_reason: string
    entry_symbol: string
    section_count: u64
    import_count: u64
    relocation_count: u64
    resolution_count: u64
    resolved_import_count: u64
    unresolved_import_count: u64
    resolved_symbol_count: u64
    unresolved_symbol_count: u64
    debug_section_count: u64
    text_section_size: u64
}

proc active_modules_table() -> [string] {
    give [driver_integration_stamp()] + compiler_critical_modules();
}

proc inactive_modules_table() -> [string] {
    give [
        "frontend:lexer=inactive",
        "frontend:parse=inactive",
        "middle:passes=inactive",
        "backend:codegen=inactive",
        "backend:target=inactive"
    ];
}

proc report_status(code: u64) -> string {
    if code == 0 {
        give "ok";
    }
    give "error";
}

proc json_escape(text: string) -> string {
    let escaped: string = "";
    for ch in text {
        let ch_text: string = to_string(ch);
        if ch_text == "\\" {
            set escaped = escaped + "\\\\";
        } else if ch_text == "\"" {
            set escaped = escaped + "\\\"";
        } else if ch_text == "\n" {
            set escaped = escaped + "\\n";
        } else if ch_text == "\r" {
            set escaped = escaped + "\\r";
        } else if ch_text == "\t" {
            set escaped = escaped + "\\t";
        } else {
            set escaped = escaped + ch_text;
        }
    }
    give escaped;
}

proc json_array(strings: [string]) -> string {
    let entries: string = "";
    let first: bool = true;
    for item in strings {
        if not first {
            set entries = entries + ",";
        }
        set entries = entries + "\"" + json_escape(item) + "\"";
        set first = false;
    }
    give "[" + entries + "]";
}

proc json_bool(value: bool) -> string {
    if value {
        give "true";
    }
    give "false";
}

proc stage_logs_for_command(command: DriverCommand, ok: bool) -> [string] {
    let logs: [string] = [
        "enter:1.load_source",
        "exit:1.load_source:ok",
        "enter:2.lex+3.parse+4.validate_ast",
        "exit:2.lex+3.parse+4.validate_ast:ok",
        "enter:5.resolve_modules",
        "exit:5.resolve_modules:ok",
        "enter:6.lower_hir+7.sema+8.typeck+9.borrowck",
        "exit:6.lower_hir+7.sema+8.typeck+9.borrowck:ok",
        "enter:10.lower_mir+11.verify_mir+12.optimize",
        "exit:10.lower_mir+11.verify_mir+12.optimize:ok",
        "enter:13.backend_emit+14.object_file",
        "exit:13.backend_emit+14.object_file:ok"
    ];
    if command != DriverCommand.Check {
        set logs = logs + [
            "enter:15.link_executable",
            "exit:15.link_executable:ok"
        ];
    }
    if !ok {
        set logs = logs + ["status:failed"];
    } else {
        set logs = logs + ["status:ok"];
    }
    give logs;
}

proc is_native_surface_payload(report_json: string, expected_surface: string) -> bool {
    give find(report_json, "\"schema\":\"vitte.compiler.surface\"") >= 0
        and find(report_json, "\"schema_version\":\"1.0.0\"") >= 0
        and find(report_json, "\"surface\":\"" + expected_surface + "\"") >= 0
        and find(report_json, "\"format\":\"bootstrap-json-v1\"") < 0;
}

proc unsupported_surface_result(command_name: string, dump_flag: string, message: string) -> CliReportResult {
    let report_json: string = "{\"status\":\"error\",\"code\":\"E_DRIVER_SURFACE_UNAVAILABLE\",\"command\":\"" + json_escape(command_name) + "\",\"flag\":\"" + json_escape(dump_flag) + "\",\"message\":\"" + json_escape(message) + "\"}";
    give CliReportResult {
        code: 2,
        message: "E_DRIVER_SURFACE_UNAVAILABLE: " + message,
        report_json: report_json
    };
}

proc diagnostic_level_text(level: DriverDiagnosticLevel) -> string {
    if level == DriverDiagnosticLevel.Note {
        give "note";
    }
    if level == DriverDiagnosticLevel.Warning {
        give "warning";
    }
    give "error";
}

proc diagnostic_json(diag0: DriverDiagnostic) -> string {
    give "{\"level\":\"" + diagnostic_level_text(diag0.level) + "\",\"stage\":\"" + json_escape(diag0.stage) + "\",\"code\":\"" + json_escape(diag0.code) + "\",\"message\":\"" + json_escape(diag0.message) + "\"}";
}

proc diagnostics_json(diagnostics: [DriverDiagnostic]) -> string {
    let entries: string = "";
    let first: bool = true;
    let i: u64 = 0;
    while i < len(diagnostics) {
        if not first {
            set entries = entries + ",";
        }
        set entries = entries + diagnostic_json(diagnostics[i]);
        set first = false;
        set i = i + 1;
    }
    give "[" + entries + "]";
}

proc pipeline_failure_summary_none() -> PipelineFailureSummary {
    give PipelineFailureSummary {
        pipeline_failed_at: "none",
        pipeline_failure_reason: "none",
        validation_reason: "none"
    };
}

proc pipeline_failure_summary(stage_name: string, reason: string) -> PipelineFailureSummary {
    give PipelineFailureSummary {
        pipeline_failed_at: stage_name,
        pipeline_failure_reason: reason,
        validation_reason: reason
    };
}

proc compile_report_failure_summary(command: DriverCommand, source_path: string, source_text: string, driver_result: DriverCompileResult, config: DriverCompileConfig) -> PipelineFailureSummary {
    if exit_code(driver_result.status) == 0 {
        give pipeline_failure_summary_none();
    }

    let artifacts: DriverAnalysisArtifacts = analyze_source(source_path, source_text);
    if not artifacts.mir.valid {
        let reason: string = mir_validation_reason(artifacts.mir);
        if reason != "none" {
            give pipeline_failure_summary("mir_validate", reason);
        }
    }

    if command != DriverCommand.Check {
        let backend = compile_source_set_with_config([DriverModuleInput { source_path: source_path, source_text: source_text, valid: source_path != "" }], config);
        if unit_is_valid(backend.ir_unit) {
            give pipeline_failure_summary_none();
        }
        let ir_reason0: string = ir_validation_reason(backend.ir_unit);
        if ir_reason0 != "none" {
            give pipeline_failure_summary("ir_validate", ir_reason0);
        }
    }

    give pipeline_failure_summary_none();
}

proc module_set_mir_validation_reason(artifacts: DriverModuleSetArtifacts) -> string {
    let i: u64 = 0;
    while i < len(artifacts.modules) {
        let reason: string = mir_validation_reason(artifacts.modules[i].mir);
        if reason != "none" {
            give reason;
        }
        set i = i + 1;
    }
    give "none";
}

proc module_set_failure_summary(result: DriverBackendModuleSetResult) -> PipelineFailureSummary {
    let mir_reason: string = module_set_mir_validation_reason(result.analysis);
    if mir_reason != "none" {
        give pipeline_failure_summary("mir_validate", mir_reason);
    }
    if not unit_is_valid(result.ir_unit) {
        let ir_reason0: string = ir_validation_reason(result.ir_unit);
        if ir_reason0 != "none" {
            give pipeline_failure_summary("ir_validate", ir_reason0);
        }
    }
    give pipeline_failure_summary_none();
}

proc compile_report_json(report: CompileReport) -> string {
    let active_count: string = "\"active_count\":" + to_string(len(report.active_modules));
    let inactive_count: string = "\"inactive_count\":" + to_string(len(report.inactive_modules));
    let json: string = "{\"command\":\"" + json_escape(report.command) + "\",\"source_path\":\"" + json_escape(report.source_path) + "\",\"exit_code\":" + to_string(report.exit_code) + ",\"backend_name\":\"" + json_escape(report.backend_name) + "\",\"target_name\":\"" + json_escape(report.target_name) + "\",\"profile_name\":\"" + json_escape(report.profile_name) + "\",\"opt_level\":\"" + json_escape(report.opt_level) + "\",\"packaging\":\"" + json_escape(report.packaging) + "\",\"deterministic\":" + json_bool(report.deterministic) + ",\"debug_enabled\":" + json_bool(report.debug_enabled) + ",\"emit_debug_sections\":" + json_bool(report.emit_debug_sections) + ",\"lto_enabled\":" + json_bool(report.lto_enabled) + ",\"pgo_mode\":\"" + json_escape(report.pgo_mode) + "\",\"prefer_native_toolchain\":" + json_bool(report.prefer_native_toolchain) + ",\"llvm_toolchain_summary\":\"" + json_escape(report.llvm_toolchain_summary) + "\",\"codegen_object_format\":\"" + json_escape(report.codegen_object_format) + "\",\"codegen_section_count\":" + to_string(report.codegen_section_count) + ",\"diagnostic_count\":" + to_string(report.diagnostic_count) + ",\"status\":\"" + json_escape(report.status) + "\",\"message\":\"" + json_escape(report.message) + "\",\"pipeline_failed_at\":\"" + json_escape(report.pipeline_failed_at) + "\",\"pipeline_failure_reason\":\"" + json_escape(report.pipeline_failure_reason) + "\",\"validation_reason\":\"" + json_escape(report.validation_reason) + "\",\"grammar_version\":\"" + json_escape(report.grammar_version) + "\",\"token_count\":" + to_string(report.token_count) + ",\"toplevel_count\":" + to_string(report.toplevel_count) + ",\"stmt_count\":" + to_string(report.stmt_count) + ",\"expr_count\":" + to_string(report.expr_count) + ",\"type_count\":" + to_string(report.type_count) + ",\"pattern_count\":" + to_string(report.pattern_count) + ",\"stage_logs\":" + json_array(report.stage_logs) + ",\"diagnostics\":" + diagnostics_json(report.diagnostics) + ",\"active_modules\":" + json_array(report.active_modules) + ",\"inactive_modules\":" + json_array(report.inactive_modules) + "," + active_count + "," + inactive_count + "}";
    give json;
}

proc module_set_compile_report_json(report: ModuleSetCompileReport) -> string {
    let json: string = "{\"command\":\"" + json_escape(report.command) + "\",\"module_count\":" + to_string(report.module_count) + ",\"exit_code\":" + to_string(report.exit_code) + ",\"backend_name\":\"" + json_escape(report.backend_name) + "\",\"target_name\":\"" + json_escape(report.target_name) + "\",\"profile_name\":\"" + json_escape(report.profile_name) + "\",\"opt_level\":\"" + json_escape(report.opt_level) + "\",\"packaging\":\"" + json_escape(report.packaging) + "\",\"deterministic\":" + json_bool(report.deterministic) + ",\"debug_enabled\":" + json_bool(report.debug_enabled) + ",\"emit_debug_sections\":" + json_bool(report.emit_debug_sections) + ",\"lto_enabled\":" + json_bool(report.lto_enabled) + ",\"pgo_mode\":\"" + json_escape(report.pgo_mode) + "\",\"prefer_native_toolchain\":" + json_bool(report.prefer_native_toolchain) + ",\"llvm_toolchain_summary\":\"" + json_escape(report.llvm_toolchain_summary) + "\",\"codegen_object_format\":\"" + json_escape(report.codegen_object_format) + "\",\"codegen_section_count\":" + to_string(report.codegen_section_count) + ",\"diagnostic_count\":" + to_string(report.diagnostic_count) + ",\"status\":\"" + json_escape(report.status) + "\",\"message\":\"" + json_escape(report.message) + "\",\"pipeline_failed_at\":\"" + json_escape(report.pipeline_failed_at) + "\",\"pipeline_failure_reason\":\"" + json_escape(report.pipeline_failure_reason) + "\",\"validation_reason\":\"" + json_escape(report.validation_reason) + "\",\"entry_symbol\":\"" + json_escape(report.entry_symbol) + "\",\"section_count\":" + to_string(report.section_count) + ",\"import_count\":" + to_string(report.import_count) + ",\"relocation_count\":" + to_string(report.relocation_count) + ",\"resolution_count\":" + to_string(report.resolution_count) + ",\"resolved_import_count\":" + to_string(report.resolved_import_count) + ",\"unresolved_import_count\":" + to_string(report.unresolved_import_count) + ",\"resolved_symbol_count\":" + to_string(report.resolved_symbol_count) + ",\"unresolved_symbol_count\":" + to_string(report.unresolved_symbol_count) + ",\"debug_section_count\":" + to_string(report.debug_section_count) + ",\"text_section_size\":" + to_string(report.text_section_size) + ",\"diagnostics\":" + diagnostics_json(report.diagnostics) + "}";
    give json;
}

proc module_set_import_count(result: DriverBackendModuleSetResult) -> u64 {
    let count: u64 = 0;
    let i: u64 = 0;
    while i < len(result.analysis.modules) {
        set count = count + len(result.analysis.modules[i].imports);
        set i = i + 1;
    }
    give count;
}

proc run_and_report(command_name: string, source_path: string, source_text: string) -> CompileReport {
    give run_and_report_with_config(command_name, source_path, source_text, default_compile_config());
}

proc run_and_report_with_config(command_name: string, source_path: string, source_text: string, config: DriverCompileConfig) -> CompileReport {
    let command: DriverCommand = command_from_text(command_name);
    let driver_result: DriverCompileResult;
    let exit: u64;

    if command == DriverCommand.Check {
        set driver_result = check_source_with_config(source_path, source_text, config);
    } else {
        set driver_result = compile_source_with_config(source_path, source_text, config);
    }
    set exit = exit_code(driver_result.status);
    let ok: bool = exit == 0;
    let failure_summary: PipelineFailureSummary = compile_report_failure_summary(command, source_path, source_text, driver_result, config);

    give CompileReport {
        command: command_name,
        source_path: source_path,
        exit_code: exit,
        backend_name: driver_result.backend_name,
        target_name: driver_result.target_name,
        profile_name: driver_result.profile_name,
        opt_level: driver_result.opt_level,
        packaging: driver_result.packaging,
        deterministic: driver_result.deterministic,
        debug_enabled: driver_result.debug_enabled,
        emit_debug_sections: driver_result.emit_debug_sections,
        lto_enabled: driver_result.lto_enabled,
        pgo_mode: driver_result.pgo_mode,
        prefer_native_toolchain: driver_result.prefer_native_toolchain,
        llvm_toolchain_summary: driver_result.llvm_toolchain_summary,
        codegen_object_format: driver_result.codegen_object_format,
        codegen_section_count: driver_result.codegen_section_count,
        diagnostic_count: len(driver_result.diagnostics),
        diagnostics: driver_result.diagnostics,
        active_modules: active_modules_table(),
        inactive_modules: inactive_modules_table(),
        status: report_status(exit),
        message: driver_result.message,
        pipeline_failed_at: failure_summary.pipeline_failed_at,
        pipeline_failure_reason: failure_summary.pipeline_failure_reason,
        validation_reason: failure_summary.validation_reason,
        grammar_version: driver_result.grammar_version,
        token_count: driver_result.token_count,
        toplevel_count: driver_result.toplevel_count,
        stmt_count: driver_result.stmt_count,
        expr_count: driver_result.expr_count,
        type_count: driver_result.type_count,
        pattern_count: driver_result.pattern_count,
        stage_logs: stage_logs_for_command(command, ok)
    };
}

proc run_set_and_report(command_name: string, inputs: [DriverModuleInput]) -> ModuleSetCompileReport {
    give run_set_and_report_with_config(command_name, inputs, default_compile_config());
}

proc run_set_and_report_with_config(command_name: string, inputs: [DriverModuleInput], config: DriverCompileConfig) -> ModuleSetCompileReport {
    let result: DriverBackendModuleSetResult = compile_source_set_with_config(inputs, config);
    let exit: u64 = 1;
    let message: string = result.message;
    if result.valid {
        set exit = 0 as u64;
    }
    let failure_summary: PipelineFailureSummary = module_set_failure_summary(result);
    give ModuleSetCompileReport {
        command: command_name,
        module_count: len(inputs),
        exit_code: exit,
        backend_name: result.config.backend_name,
        target_name: result.config.target_name,
        profile_name: result.config.profile_name,
        opt_level: result.config.opt_level,
        packaging: result.config.packaging,
        deterministic: result.config.deterministic,
        debug_enabled: result.config.debug_enabled,
        emit_debug_sections: result.config.emit_debug_sections,
        lto_enabled: result.config.lto_enabled,
        pgo_mode: result.config.pgo_mode,
        prefer_native_toolchain: result.config.prefer_native_toolchain,
        llvm_toolchain_summary: result.codegen.native_toolchain_summary,
        codegen_object_format: result.codegen.object_format,
        codegen_section_count: result.codegen.section_count,
        diagnostic_count: len(result.diagnostics),
        diagnostics: result.diagnostics,
        status: report_status(exit),
        message: message,
        pipeline_failed_at: failure_summary.pipeline_failed_at,
        pipeline_failure_reason: failure_summary.pipeline_failure_reason,
        validation_reason: failure_summary.validation_reason,
        entry_symbol: result.entry_symbol,
        section_count: result.artifact.metadata.section_count,
        import_count: module_set_import_count(result),
        relocation_count: result.artifact.metadata.relocation_count,
        resolution_count: result.artifact.metadata.resolution_count,
        resolved_import_count: result.artifact.metadata.resolved_import_count,
        unresolved_import_count: result.artifact.metadata.unresolved_import_count,
        resolved_symbol_count: result.artifact.metadata.resolved_symbol_count,
        unresolved_symbol_count: result.artifact.metadata.unresolved_symbol_count,
        debug_section_count: result.artifact.metadata.debug_section_count,
        text_section_size: result.artifact.metadata.text_section_size
    };
}

proc main_driver(command_name: string, source_path: string, source_text: string) -> CliRunResult {
    give main_driver_with_config(command_name, source_path, source_text, default_compile_config());
}

proc main_driver_with_config(command_name: string, source_path: string, source_text: string, config: DriverCompileConfig) -> CliRunResult {
    let command: DriverCommand = command_from_text(command_name);
    let result: DriverCompileResult;

    if command == DriverCommand.Check {
        set result = check_source_with_config(source_path, source_text, config);
    } else {
        set result = compile_source_with_config(source_path, source_text, config);
    }

    give CliRunResult {
        code: exit_code(result.status),
        message: result.message
    };
}

proc main_driver_report_json(command_name: string, source_path: string, source_text: string) -> string {
    give main_driver_report_json_with_config(command_name, source_path, source_text, default_compile_config());
}

proc main_driver_report_json_with_config(command_name: string, source_path: string, source_text: string, config: DriverCompileConfig) -> string {
    let report: CompileReport = run_and_report_with_config(command_name, source_path, source_text, config);
    give compile_report_json(report);
}

proc main_driver_surface_report_json(command_name: string, dump_flag: string, source_path: string, source_text: string) -> CliReportResult {
    give main_driver_surface_report_json_with_config(command_name, dump_flag, source_path, source_text, default_compile_config());
}

proc main_driver_surface_report_json_with_config(command_name: string, dump_flag: string, source_path: string, source_text: string, config: DriverCompileConfig) -> CliReportResult {
    let status: DriverCompileResult = check_source_with_config(source_path, source_text, config);
    if command_name == "parse" and dump_flag == "--dump-ast-json" {
        let report_json: string = dump_ast_json(source_path, source_text);
        if not is_native_surface_payload(report_json, "ast") {
            give unsupported_surface_result(command_name, dump_flag, "native ast payload is unavailable or invalid");
        }
        give CliReportResult {
            code: exit_code(status.status),
            message: status.message,
            report_json: report_json
        };
    }
    if command_name == "check" and dump_flag == "--dump-hir-json" {
        let report_json: string = dump_hir_json(source_path, source_text);
        if not is_native_surface_payload(report_json, "hir") {
            give unsupported_surface_result(command_name, dump_flag, "native hir payload is unavailable or invalid");
        }
        give CliReportResult {
            code: exit_code(status.status),
            message: status.message,
            report_json: report_json
        };
    }
    if command_name == "check" and dump_flag == "--dump-mir-json" {
        let report_json: string = dump_mir_json(source_path, source_text);
        if not is_native_surface_payload(report_json, "mir") {
            give unsupported_surface_result(command_name, dump_flag, "native mir payload is unavailable or invalid");
        }
        give CliReportResult {
            code: exit_code(status.status),
            message: status.message,
            report_json: report_json
        };
    }
    let diagnostics_json_dump: bool = dump_flag == "--diagnostics-json" or dump_flag == "--diag-json";
    if command_name == "check" and diagnostics_json_dump {
        let report_json: string = dump_diagnostics_json(source_path, source_text);
        if not is_native_surface_payload(report_json, "diagnostics") {
            give unsupported_surface_result(command_name, dump_flag, "native diagnostics payload is unavailable or invalid");
        }
        give CliReportResult {
            code: exit_code(status.status),
            message: status.message,
            report_json: report_json
        };
    }
    give unsupported_surface_result(command_name, dump_flag, "unsupported command/flag combination");
}

proc detect_dump_surface_flag(args: [string]) -> string {
    let i: u64 = 0;
    while i < len(args) {
        let arg0: string = args[i];
        if arg0 == "--dump-ast-json" {
            give "--dump-ast-json";
        }
        if arg0 == "--dump-ast-json-pretty" {
            give "--dump-ast-json";
        }
        if arg0 == "--dump-hir-json" {
            give "--dump-hir-json";
        }
        if arg0 == "--dump-mir-json" {
            give "--dump-mir-json";
        }
        if arg0 == "--diagnostics-json" or arg0 == "--diag-json" or arg0 == "--diag-json-pretty" {
            give "--diagnostics-json";
        }
        if arg0 == "--fix-preview" or arg0 == "--fix-why" {
            give "--diagnostics-json";
        }
        set i = i + 1;
    }
    give "";
}

proc detect_fix_flag(args: [string]) -> string {
    let i: u64 = 0;
    while i < len(args) {
        let arg0: string = args[i];
        if arg0 == "--fix" or arg0 == "--fix-safe" or arg0 == "--fix-preview" or arg0 == "--fix-why" {
            give arg0;
        }
        set i = i + 1;
    }
    give "";
}

proc detect_counterfactual_level(args: [string]) -> string {
    let i: u64 = 0;
    while i < len(args) {
        let arg0: string = args[i];
        if starts_with(arg0, "--counterfactual-level=") {
            give slice(arg0, len("--counterfactual-level="), len(arg0));
        }
        set i = i + 1;
    }
    give "basic";
}

proc has_surface_json_intent(args: [string]) -> bool {
    let i: u64 = 0;
    while i < len(args) {
        let arg0: string = args[i];
        if starts_with(arg0, "--dump-") or starts_with(arg0, "--diag") or starts_with(arg0, "--fix") or starts_with(arg0, "--counterfactual-level=") {
            give true;
        }
        set i = i + 1;
    }
    give false;
}

proc main_driver_surface_report_json_from_args(command_name: string, args: [string], source_path: string, source_text: string) -> CliReportResult {
    give main_driver_surface_report_json_from_args_with_config(command_name, args, source_path, source_text, default_compile_config());
}

proc main_driver_surface_report_json_from_args_with_config(command_name: string, args: [string], source_path: string, source_text: string, config: DriverCompileConfig) -> CliReportResult {
    let dump_flag: string = detect_dump_surface_flag(args);
    if dump_flag != "" {
        give main_driver_surface_report_json_with_config(command_name, dump_flag, source_path, source_text, config);
    }
    if command_name == "parse" or command_name == "check" or has_surface_json_intent(args) {
        give unsupported_surface_result(command_name, "", "missing or unsupported JSON surface flag");
    }
    let report: CompileReport = run_and_report_with_config(command_name, source_path, source_text, config);
    give CliReportResult {
        code: report.exit_code,
        message: report.message,
        report_json: compile_report_json(report)
    };
}

proc main_driver_set(command_name: string, inputs: [DriverModuleInput]) -> CliRunResult {
    give main_driver_set_with_config(command_name, inputs, default_compile_config());
}

proc main_driver_set_with_config(command_name: string, inputs: [DriverModuleInput], config: DriverCompileConfig) -> CliRunResult {
    let command: DriverCommand = command_from_text(command_name);
    if command == DriverCommand.CompileSet {
        let result: DriverBackendModuleSetResult = compile_source_set_with_config(inputs, config);
        let code: u64 = 1;
        let message: string = result.message;
        if result.valid {
            set code = 0 as u64;
        }
        give CliRunResult {
            code: code,
            message: message
        };
    }
    give CliRunResult {
        code: 1,
        message: "unsupported module-set command"
    };
}

proc main_driver_set_report_json(command_name: string, inputs: [DriverModuleInput]) -> string {
    give main_driver_set_report_json_with_config(command_name, inputs, default_compile_config());
}

proc main_driver_set_report_json_with_config(command_name: string, inputs: [DriverModuleInput], config: DriverCompileConfig) -> string {
    let command: DriverCommand = command_from_text(command_name);
    if command == DriverCommand.CompileSet {
        let report: ModuleSetCompileReport = run_set_and_report_with_config(command_name, inputs, config);
        give module_set_compile_report_json(report);
    }
    give "{\"command\":\"" + json_escape(command_name) + "\",\"status\":\"error\",\"message\":\"unsupported module-set command\"}";
}
