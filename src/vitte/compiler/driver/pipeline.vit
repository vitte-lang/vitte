space vitte/compiler/driver

use vitte/compiler/infrastructure/session/options { SessionOptions }
use vitte/compiler/infrastructure/diagnostics/fluent/bundle { new_bundle }
use vitte/compiler/infrastructure/diagnostics/fluent/format { format_message }

proc localized_status(options: SessionOptions, key: string) -> string {
  let bundle = new_bundle(options.locale, "en-US")
  give format_message(bundle, key, [])
}
