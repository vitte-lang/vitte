space vitte/compiler/driver

pick DriverCommand {
    Compile,
    Build,
    Check,
    Run,
    Test,
    CompileSet,
}

proc command_from_text(name: string) -> DriverCommand {
    if name == "check" {
        give DriverCommand.Check;
    }
    if name == "build" {
        give DriverCommand.Build;
    }
    if name == "compile" {
        give DriverCommand.Compile;
    }
    if name == "run" {
        give DriverCommand.Run;
    }
    if name == "test" {
        give DriverCommand.Test;
    }
    if name == "compile-set" {
        give DriverCommand.CompileSet;
    }
    give DriverCommand.Compile;
}
