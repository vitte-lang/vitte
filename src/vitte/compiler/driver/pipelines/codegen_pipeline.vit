space vitte/compiler/driver/pipelines

use vitte/compiler/codegen

form CodegenResult {
  artifact: GeneratedArtifact,
  diagnostics: [string],
}

proc run_codegen_pipeline(hir: string, backend: string) -> CodegenResult {
  let ir: string = lower_to_multi_ir(hir)
  let artifact: GeneratedArtifact = emit_multi_ir(ir, backend)

  give CodegenResult {
    artifact: artifact,
    diagnostics: [],
  }
}

