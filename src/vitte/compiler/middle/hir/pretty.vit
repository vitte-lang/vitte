  } elif kind == HirItemKind.Opaque {
    give "opaque"
  } elif kind == HirItemKind.Extern {
    give "extern"
  } elif kind == HirItemKind.Form {
    give "form"
  } elif kind == HirItemKind.Class {
    give "class"
  } elif kind == HirItemKind.Union {
    give "union"
  } elif kind == HirItemKind.Bits {
    give "bits"
  } elif kind == HirItemKind.Pick {
    give "pick"
  } elif kind == HirItemKind.Flags {
    give "flags"
  } elif kind == HirItemKind.Trait {
    give "trait"
  } elif kind == HirItemKind.Impl {
    give "impl"
  } elif kind == HirItemKind.Proc {
    give "proc"
  } elif kind == HirItemKind.Intrinsic {
    give "intrinsic"
  } elif kind == HirItemKind.Query {
    give "query"
  } elif kind == HirItemKind.Compiler {
    give "compiler"
  } elif kind == HirItemKind.Pass {
    give "pass"
  } elif kind == HirItemKind.Backend {
    give "backend"
  } elif kind == HirItemKind.Diagnostic {
