space vitte/compiler/middle/hir/pretty

use vitte/compiler/middle/hir.{
  HirExpr,
  HirExprKind,
  HirItem,
  HirItemKind,
  HirModule,
  HirStmt,
  HirStmtKind,
  HirUnit,
  HirValueMode,
  HirPlaceCategory,
  SemanticDiagnostic,
  SemanticSeverity,
  hir_value_mode_name,
  hir_place_category_name
}

export *

const PRETTY_INDENT: string = "  "

proc pretty_eq() -> string {
  give slice("a=b", 1, 2)
}

proc indent(depth: u64) -> string {
  let out: string = ""

  let i: u64 = 0

  while i < depth {
    set out = out + PRETTY_INDENT
    set i = i + 1
  }

  give out
}

proc severity_name(severity: SemanticSeverity) -> string {
  if severity == SemanticSeverity.Info {
    give "info"
  } elif severity == SemanticSeverity.Warning {
    give "warning"
  } elif severity == SemanticSeverity.Error {
    give "error"
  } elif severity == SemanticSeverity.Fatal {
    give "fatal"
  }

  give "unknown"
}

proc expr_kind_name(kind: HirExprKind) -> string {
  if kind == HirExprKind.Name {
    give "name"
  } elif kind == HirExprKind.Int {
    give "int"
  } elif kind == HirExprKind.Float {
    give "float"
  } elif kind == HirExprKind.Bool {
    give "bool"
  } elif kind == HirExprKind.String {
    give "string"
  } elif kind == HirExprKind.Char {
    give "char"
  } elif kind == HirExprKind.Binary {
    give "binary"
  } elif kind == HirExprKind.Unary {
    give "unary"
  } elif kind == HirExprKind.Call {
    give "call"
  } elif kind == HirExprKind.Index {
    give "index"
  } elif kind == HirExprKind.Member {
    give "member"
  } elif kind == HirExprKind.BorrowShared {
    give "borrow-shared"
  } elif kind == HirExprKind.BorrowMut {
    give "borrow-mut"
  } elif kind == HirExprKind.Deref {
    give "deref"
  } elif kind == HirExprKind.If {
    give "if"
  } elif kind == HirExprKind.Match {
    give "match"
  } elif kind == HirExprKind.Block {
    give "block"
  } elif kind == HirExprKind.Lambda {
    give "lambda"
  } elif kind == HirExprKind.Struct {
    give "struct"
  } elif kind == HirExprKind.Array {
    give "array"
  } elif kind == HirExprKind.Tuple {
    give "tuple"
  } elif kind == HirExprKind.Range {
    give "range"
  } elif kind == HirExprKind.Cast {
    give "cast"
  } elif kind == HirExprKind.Is {
    give "is"
  } elif kind == HirExprKind.Try {
    give "try"
  } elif kind == HirExprKind.Sizeof {
    give "sizeof"
  } elif kind == HirExprKind.Alignof {
    give "alignof"
  } elif kind == HirExprKind.Offsetof {
    give "offsetof"
  } elif kind == HirExprKind.Typeof {
    give "typeof"
  } elif kind == HirExprKind.Nameof {
    give "nameof"
  }

  give "unknown"
}

proc stmt_kind_name(kind: HirStmtKind) -> string {
