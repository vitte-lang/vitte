  } elif kind == HirItemKind.Macro {
    give "macro"
  } elif kind == HirItemKind.Entry {
    give "entry"
  } elif kind == HirItemKind.Test {
    give "test"
  } elif kind == HirItemKind.Bench {
    give "bench"
  } elif kind == HirItemKind.Comptime {
    give "comptime"
  } elif kind == HirItemKind.StaticAssert {
