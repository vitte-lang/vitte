proc item_kind_name(kind: HirItemKind) -> string {
  if kind == HirItemKind.Space {
    give "space"
  } elif kind == HirItemKind.Use {
    give "use"
  } elif kind == HirItemKind.Export {
    give "export"
  } elif kind == HirItemKind.Const {
