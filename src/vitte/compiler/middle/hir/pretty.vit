proc pretty_diagnostic(diag: SemanticDiagnostic, depth: u64) -> string {
  give indent(depth)
    + "["
    + severity_name(diag.severity)
    + "] "
    + diag.code
    + ": "
    + diag.message
}

proc pretty_expr(expr: HirExpr, depth: u64) -> string {
  let next_depth: u64 = depth + 1
  let expr_id_text: string = expr.id as string
  let copyable_text: string = expr.copyable as string
  let child_count_text: string = len(expr.children) as string
  let out: string = indent(depth) + "expr " + expr_kind_name(expr.kind) + " {"
  let out1: string = out + "\n" + indent(next_depth) + "id: " + expr_id_text
  let out2: string = out1 + "\n" + indent(next_depth) + "text: \"" + expr.text + "\""
  let out3: string = out2 + "\n" + indent(next_depth) + "type: " + expr.inferred_type
  let out4: string = out3 + "\n" + indent(next_depth) + "value_mode: " + hir_value_mode_name(expr.value_mode)
  let out5: string = out4 + "\n" + indent(next_depth) + "place_category: " + hir_place_category_name(expr.place_category)
  let out6: string = out5 + "\n" + indent(next_depth) + "copyable: " + copyable_text
  let out7: string = out6 + "\n" + indent(next_depth) + "children: " + child_count_text
  let rendered: string = out7

  let i: u64 = 0

  while i < len(expr.children) {
    set rendered = rendered + "\n" + pretty_expr(expr.children[i], next_depth)

    set i = i + 1
  }

  let d: u64 = 0

  while d < len(expr.diagnostics) {
    set rendered = rendered + "\n" + pretty_diagnostic(expr.diagnostics[d], next_depth)

    set d = d + 1
  }

  give rendered + "\n" + indent(depth) + "}"
}

proc pretty_stmt(stmt: HirStmt, depth: u64) -> string {
  let next_depth: u64 = depth + 1
  let stmt_id_text: string = stmt.id as string
  let scope_depth_text: string = stmt.scope_depth as string
  let mutable_text: string = stmt.mutable as string
  let out: string = indent(depth) + "stmt " + stmt_kind_name(stmt.kind) + " {"
  let out1: string = out + "\n" + indent(next_depth) + "id: " + stmt_id_text
  let out2: string = out1 + "\n" + indent(next_depth) + "name: \"" + stmt.name + "\""
  let out3: string = out2 + "\n" + indent(next_depth) + "scope_depth: " + scope_depth_text
  let out4: string = out3 + "\n" + indent(next_depth) + "mutable: " + mutable_text
  let rendered: string = out4 + "\n" + pretty_expr(stmt.expr, next_depth)

  let i: u64 = 0

  while i < len(stmt.then_stmts) {
    set rendered = rendered + "\n" + pretty_stmt(stmt.then_stmts[i], next_depth)

    set i = i + 1
  }

  let j: u64 = 0

  while j < len(stmt.else_stmts) {
    set rendered = rendered + "\n" + pretty_stmt(stmt.else_stmts[j], next_depth)

    set j = j + 1
  }

  let d: u64 = 0

  while d < len(stmt.diagnostics) {
    set rendered = rendered + "\n" + pretty_diagnostic(stmt.diagnostics[d], next_depth)

    set d = d + 1
  }

  give rendered + "\n" + indent(depth) + "}"
}

proc pretty_item(item: HirItem, depth: u64) -> string {
  let next_depth: u64 = depth + 1
  let out: string = indent(depth) + "item " + item_kind_name(item.kind) + " {"
  let out1: string = out + "\n" + indent(next_depth) + "name: \"" + item.name + "\""
  let out2: string = out1 + "\n" + indent(next_depth) + "visibility: " + item.visibility
  let out3: string = out2 + "\n" + indent(next_depth) + "namespace: " + item.namespace
  let rendered: string = out3

  if item.expr.valid {
    set rendered = rendered + "\n" + pretty_expr(item.expr, next_depth)
  }

  let i: u64 = 0

  while i < len(item.stmts) {
    set rendered = rendered + "\n" + pretty_stmt(item.stmts[i], next_depth)

    set i = i + 1
  }

  let d: u64 = 0

  while d < len(item.diagnostics) {
    set rendered = rendered + "\n" + pretty_diagnostic(item.diagnostics[d], next_depth)

    set d = d + 1
  }

  give rendered + "\n" + indent(depth) + "}"
}

proc pretty_module(module: HirModule) -> string {
  let item_count_text: string = len(module.items) as string
  let out: string = "module {\n" + indent(1) + "name: \"" + module.name + "\"\n" + indent(1) + "items: " + item_count_text
  let rendered: string = out

  let i: u64 = 0

  while i < len(module.items) {
    set rendered = rendered + "\n" + pretty_item(module.items[i], 1)

    set i = i + 1
  }

  give rendered + "\n}"
}

proc pretty_unit(unit: HirUnit) -> string {
  let node_count_text: string = unit.node_count as string
  let symbol_count_text: string = unit.symbol_count as string
  let scope_count_text: string = unit.scope_count as string
  let expr_count_text: string = unit.expr_count as string
  let stmt_count_text: string = unit.stmt_count as string
  let item_count_text: string = unit.item_count as string
  let valid_text: string = unit.valid as string
  let out: string = "hir-unit {\n" + indent(1) + "source_path: \"" + unit.source_path + "\"\n" + indent(1) + "nodes: " + node_count_text + "\n" + indent(1) + "symbols: " + symbol_count_text + "\n" + indent(1) + "scopes: " + scope_count_text + "\n" + indent(1) + "exprs: " + expr_count_text + "\n" + indent(1) + "stmts: " + stmt_count_text + "\n" + indent(1) + "items: " + item_count_text + "\n" + indent(1) + "valid: " + valid_text
  give out + "\n" + pretty_module(unit.module) + "\n}"
}

proc pretty_expr_inline(expr: HirExpr) -> string {
  give expr_kind_name(expr.kind)
    + "("
    + expr.text
    + ": "
    + expr.inferred_type
    + ")"
}

proc pretty_stmt_inline(stmt: HirStmt) -> string {
  give stmt_kind_name(stmt.kind)
    + "("
    + stmt.name
    + ")"
}

proc pretty_item_inline(item: HirItem) -> string {
  give item_kind_name(item.kind)
    + "("
    + item.name
    + ")"
}

proc pretty_summary(unit: HirUnit) -> string {
  let item_count: string = unit.item_count as string
  let expr_count: string = unit.expr_count as string
  let stmt_count: string = unit.stmt_count as string
  let symbol_count: string = unit.symbol_count as string
  let valid_text: string = unit.valid as string
  let eq: string = pretty_eq()
  give "items" + eq + item_count + " exprs" + eq + expr_count + " stmts" + eq + stmt_count + " symbols" + eq + symbol_count + " valid" + eq + valid_text
}

proc pretty_selftest() -> bool {
  let rendered: string = pretty_summary(HirUnit { source_path: "demo.vit", module: HirModule { name: "demo", items: [], diagnostics: [], dependency_count: 0, symbol_count: 0, valid: true }, node_count: 0, symbol_count: 0, scope_count: 0, expr_count: 0, stmt_count: 0, item_count: 0, lowered: true, analyzed: true, valid: true })

  give rendered != ""
    and expr_kind_name(HirExprKind.Int) == "int"
    and stmt_kind_name(HirStmtKind.Let) == "let"
    and item_kind_name(HirItemKind.Proc) == "proc"
}
