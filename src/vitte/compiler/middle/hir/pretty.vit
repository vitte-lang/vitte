  } elif kind == HirStmtKind.Set {
    give "set"
  } elif kind == HirStmtKind.Give {
    give "give"
  } elif kind == HirStmtKind.If {
    give "if"
  } elif kind == HirStmtKind.While {
    give "while"
  } elif kind == HirStmtKind.For {
    give "for"
  } elif kind == HirStmtKind.Loop {
    give "loop"
  } elif kind == HirStmtKind.Match {
    give "match"
  } elif kind == HirStmtKind.When {
    give "when"
  } elif kind == HirStmtKind.With {
    give "with"
  } elif kind == HirStmtKind.Try {
    give "try"
  } elif kind == HirStmtKind.Defer {
    give "defer"
  } elif kind == HirStmtKind.Unsafe {
    give "unsafe"
  } elif kind == HirStmtKind.Asm {
    give "asm"
  } elif kind == HirStmtKind.Emit {
    give "emit"
  } elif kind == HirStmtKind.Panic {
    give "panic"
  } elif kind == HirStmtKind.Assert {
    give "assert"
  } elif kind == HirStmtKind.Break {
    give "break"
  } elif kind == HirStmtKind.Continue {
    give "continue"
  } elif kind == HirStmtKind.Unreachable {
    give "unreachable"
  } elif kind == HirStmtKind.Select {
    give "select"
  } elif kind == HirStmtKind.Critical {
    give "critical"
  } elif kind == HirStmtKind.StaticAssert {
