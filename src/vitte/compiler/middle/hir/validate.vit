space vitte/compiler/middle/hir/validate

use vitte/compiler/middle/hir/hir.{ HirUnit, hir_module_empty }

proc validate_hir(hir: HirUnit) -> HirUnit {
  if not hir.module.valid or hir.node_count == 0 {
    give HirUnit {
      source_path: hir.source_path,
      module: hir_module_empty(),
      node_count: hir.node_count,
      valid: false
    };
  }
  give hir;
}
