space vitte/compiler/middle/hir/validate

use vitte/compiler/middle/hir.{
  HirExpr,
  HirExprKind,
  HirItem,
  HirItemKind,
  HirModule,
  HirNominalMember,
  HirNominalMemberKind,
  HirProcParam,
  HirStmt,
  HirStmtKind,
  HirUnit,
  HirValueMode,
  HirPlaceCategory,
  SemanticDiagnostic,
  SemanticSeverity,
  hir_module_empty,
  semantic_diagnostic
}

use vitte/compiler/frontend/ast.node.{ ast_span_empty }

export *

form HirValidationResult {
  diagnostics: [SemanticDiagnostic]
  checked_items: u64
  checked_stmts: u64
  checked_exprs: u64
  valid: bool
}

proc validation_result(diagnostics: [SemanticDiagnostic], checked_items: u64, checked_stmts: u64, checked_exprs: u64, valid: bool) -> HirValidationResult {
  give HirValidationResult {
    diagnostics: diagnostics,
    checked_items: checked_items,
    checked_stmts: checked_stmts,
    checked_exprs: checked_exprs,
    valid: valid
  };
}

proc validation_error(code: string, message: string) -> SemanticDiagnostic {
  give semantic_diagnostic(
    code,
    SemanticSeverity.Error,
    message,
    ast_span_empty(),
    "",
    ""
  );
}

proc hir_validate_eq() -> string {
  give slice("a=b", 1, 2);
}

proc expr_requires_place(expr: HirExpr) -> bool {
  give expr.kind == HirExprKind.BorrowShared or expr.kind == HirExprKind.BorrowMut or expr.kind == HirExprKind.Deref;
}

proc expr_is_place(expr: HirExpr) -> bool {
  give expr.place_category != HirPlaceCategory.Value and expr.place_category != HirPlaceCategory.Invalid;
}

proc expr_is_constant(expr: HirExpr) -> bool {
  give expr.constant;
}

proc expr_has_struct_shape(expr: HirExpr) -> bool {
  if expr.kind != HirExprKind.Struct {
    give true;
  }
  if expr.name == "" {
    give false;
  }
  if len(expr.children) == 0 {
    give false;
  }
  give expr.children[0].kind == HirExprKind.Name and expr.children[0].name == expr.name;
}

proc validate_expr(expr: HirExpr) -> [SemanticDiagnostic] {
  let diagnostics: [SemanticDiagnostic] = []

  if not expr.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0001", "invalid hir expression")]
  }

  if expr.kind == HirExprKind.Unknown {
    set diagnostics = diagnostics + [validation_error("HIRV0002", "unknown hir expression kind")]
  }

  if expr_requires_place(expr) and not expr_is_place(expr) {
    set diagnostics = diagnostics + [validation_error("HIRV0003", "borrow expression requires place expression")]
  }

  if expr.kind == HirExprKind.Int and expr.inferred_type == "unknown" {
    set diagnostics = diagnostics + [validation_error("HIRV0004", "integer expression missing inferred type")]
  }

  if expr.kind == HirExprKind.Set and not expr.assignable {
    set diagnostics = diagnostics + [validation_error("HIRV0005", "assignment target is not assignable")]
  }

  if expr.kind == HirExprKind.Name and expr.binding == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0006", "name expression missing binding")]
  }

  if not expr_has_struct_shape(expr) {
    set diagnostics = diagnostics + [validation_error("HIRV0007", "struct expression missing constructor shape")]
  }

  let i: u64 = 0

  while i < len(expr.children) {
    set diagnostics = diagnostics + validate_expr(expr.children[i])

    set i = i + 1
  }

  give diagnostics
}

proc validate_stmt(stmt: HirStmt) -> [SemanticDiagnostic] {
  let diagnostics: [SemanticDiagnostic] = []

  if not stmt.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0100", "invalid hir statement")]
  }

  if stmt.kind == HirStmtKind.Unknown {
    set diagnostics = diagnostics + [validation_error("HIRV0101", "unknown hir statement kind")]
  }

  if stmt.kind == HirStmtKind.Let and stmt.name == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0102", "let statement missing binding name")]
  }

  if stmt.kind == HirStmtKind.Set and stmt.target == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0103", "set statement missing target")]
  }

  if stmt.kind == HirStmtKind.Assert and stmt.expr.inferred_type != "bool" {
    set diagnostics = diagnostics + [validation_error("HIRV0104", "assert expression must be bool")]
  }

  if stmt.kind == HirStmtKind.StaticAssert and not expr_is_constant(stmt.expr) {
    set diagnostics = diagnostics + [validation_error("HIRV0105", "static assert requires constant expression")]
  }

  set diagnostics = diagnostics + validate_expr(stmt.expr)

  let i: u64 = 0

  while i < len(stmt.then_stmts) {
    set diagnostics = diagnostics + validate_stmt(stmt.then_stmts[i])

    set i = i + 1
  }

  let j: u64 = 0

  while j < len(stmt.else_stmts) {
    set diagnostics = diagnostics + validate_stmt(stmt.else_stmts[j])

    set j = j + 1
  }

  let k: u64 = 0

  while k < len(stmt.catch_stmts) {
    set diagnostics = diagnostics + validate_stmt(stmt.catch_stmts[k])

    set k = k + 1
  }

  give diagnostics
}

proc validate_param(param: HirProcParam) -> [SemanticDiagnostic] {
  let diagnostics: [SemanticDiagnostic] = []

  if not param.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0150", "invalid hir proc parameter")]
  }

  if not param.variadic and param.name == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0151", "hir proc parameter missing name")]
  }

  if not param.variadic and param.annotation_text == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0152", "hir proc parameter missing type annotation")]
  }

  if param.variadic and param.name == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0153", "variadic hir parameter missing marker")]
  }

  give diagnostics
}

proc validate_member(member: HirNominalMember) -> [SemanticDiagnostic] {
  let diagnostics: [SemanticDiagnostic] = []

  if not member.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0170", "invalid hir nominal member")]
  }

  if member.kind == HirNominalMemberKind.Unknown {
    set diagnostics = diagnostics + [validation_error("HIRV0171", "unknown hir nominal member kind")]
  }

  if member.name == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0172", "hir nominal member missing name")]
  }

  if (member.kind == HirNominalMemberKind.Field or member.kind == HirNominalMemberKind.Variant) and member.annotation_text == "" and not member.expr.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0173", "hir nominal member missing payload or annotation")]
  }

  if (member.kind == HirNominalMemberKind.TraitMethod or member.kind == HirNominalMemberKind.ImplMethod) and len(member.params) == 0 {
    set diagnostics = diagnostics + [validation_error("HIRV0174", "hir method member missing parameter surface")]
  }

  if member.kind == HirNominalMemberKind.ImplMethod and len(member.body_stmts) == 0 {
    set diagnostics = diagnostics + [validation_error("HIRV0175", "hir impl method missing body")]
  }

  if member.kind == HirNominalMemberKind.TraitMethod and member.annotation_text == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0176", "hir trait method missing return annotation")]
  }

  let i: u64 = 0
  while i < len(member.params) {
    set diagnostics = diagnostics + validate_param(member.params[i])
    set i = i + 1
  }

  let j: u64 = 0
  while j < len(member.body_stmts) {
    set diagnostics = diagnostics + validate_stmt(member.body_stmts[j])
    set j = j + 1
  }

  if member.expr.valid {
    set diagnostics = diagnostics + validate_expr(member.expr)
  }

  give diagnostics
}

proc validate_item(item: HirItem) -> [SemanticDiagnostic] {
  let diagnostics: [SemanticDiagnostic] = []
  let effective_member_count: u64 = if len(item.members) > 0 { len(item.members) } else { len(item.stmts) }

  if not item.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0200", "invalid hir item")]
  }

  if item.kind == HirItemKind.Unknown {
    set diagnostics = diagnostics + [validation_error("HIRV0201", "unknown hir item kind")]
  }

  if item.name == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0202", "hir item missing name")]
  }

  if item.kind == HirItemKind.Proc and len(item.stmts) == 0 {
    set diagnostics = diagnostics + [validation_error("HIRV0203", "procedure item missing body")]
  }

  if item.kind == HirItemKind.Trait and effective_member_count == 0 {
    set diagnostics = diagnostics + [validation_error("HIRV0204", "trait item missing member surface")]
  }

  if item.kind == HirItemKind.Impl and effective_member_count == 0 {
    set diagnostics = diagnostics + [validation_error("HIRV0205", "impl item missing member surface")]
  }

  if item.member_count != effective_member_count {
    set diagnostics = diagnostics + [validation_error("HIRV0206", "hir item member count does not match lowered statements")]
  }

  if (item.kind == HirItemKind.Bits or item.kind == HirItemKind.Flags) and item.annotation_text == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0207", "bits/flags item missing underlying type text")]
  }

  if item.kind == HirItemKind.Impl and item.target_type_text == "" {
    set diagnostics = diagnostics + [validation_error("HIRV0208", "impl item missing target type text")]
  }

  if item.signature_param_count != len(item.params) {
    set diagnostics = diagnostics + [validation_error("HIRV0209", "hir item signature parameter count does not match lowered params")]
  }

  if item.generic_count != len(item.generic_params) {
    set diagnostics = diagnostics + [validation_error("HIRV0210", "hir item generic parameter count does not match lowered names")]
  }

  if item.expr.valid {
    set diagnostics = diagnostics + validate_expr(item.expr)
  }

  let p: u64 = 0
  while p < len(item.params) {
    set diagnostics = diagnostics + validate_param(item.params[p])
    set p = p + 1
  }

  let i: u64 = 0

  while i < len(item.stmts) {
    set diagnostics = diagnostics + validate_stmt(item.stmts[i])

    set i = i + 1
  }

  let j: u64 = 0
  while j < len(item.members) {
    set diagnostics = diagnostics + validate_member(item.members[j])
    set j = j + 1
  }

  give diagnostics
}

proc validate_module(module: HirModule) -> [SemanticDiagnostic] {
  let diagnostics: [SemanticDiagnostic] = []

  if not module.valid {
    set diagnostics = diagnostics + [validation_error("HIRV0300", "invalid hir module")]
  }

  if len(module.items) == 0 {
    set diagnostics = diagnostics + [validation_error("HIRV0301", "hir module contains no items")]
  }

  let i: u64 = 0

  while i < len(module.items) {
    set diagnostics = diagnostics + validate_item(module.items[i])

    set i = i + 1
  }

  give diagnostics
}

proc build_validation_result(hir: HirUnit, diagnostics: [SemanticDiagnostic]) -> HirValidationResult {
  give validation_result(
    diagnostics,
    hir.item_count,
    hir.stmt_count,
    hir.expr_count,
    len(diagnostics) == 0
  )
}

proc validate_hir(hir: HirUnit) -> HirUnit {
  if not hir.module.valid or hir.node_count == 0 {
    give HirUnit {
      source_path: hir.source_path,
      module: hir_module_empty(),
      node_count: hir.node_count,
      symbol_count: hir.symbol_count,
      scope_count: hir.scope_count,
      expr_count: hir.expr_count,
      stmt_count: hir.stmt_count,
      item_count: hir.item_count,
      lowered: hir.lowered,
      analyzed: hir.analyzed,
      valid: false
    }
  }

  let diagnostics: [SemanticDiagnostic] = validate_module(hir.module)
  let result: HirValidationResult = build_validation_result(hir, diagnostics)
  let module: HirModule = HirModule {
    name: hir.module.name,
    items: hir.module.items,
    diagnostics: hir.module.diagnostics + diagnostics,
    dependency_count: hir.module.dependency_count,
    symbol_count: hir.module.symbol_count,
    valid: result.valid
  }

  give HirUnit {
    source_path: hir.source_path,
    module: module,
    node_count: hir.node_count,
    symbol_count: hir.symbol_count,
    scope_count: hir.scope_count,
    expr_count: hir.expr_count,
    stmt_count: hir.stmt_count,
    item_count: hir.item_count,
    lowered: hir.lowered,
    analyzed: true,
    valid: result.valid
  }
}

proc hir_validation_summary(result: HirValidationResult) -> string {
  let checked_items: string = result.checked_items as string
  let checked_stmts: string = result.checked_stmts as string
  let checked_exprs: string = result.checked_exprs as string
  let diagnostic_count: string = len(result.diagnostics) as string
  let valid_text: string = result.valid as string
  let eq: string = hir_validate_eq()
  give "items" + eq + checked_items + " stmts" + eq + checked_stmts + " exprs" + eq + checked_exprs + " diagnostics" + eq + diagnostic_count + " valid" + eq + valid_text
}

proc hir_validate_selftest() -> bool {
  let result: HirValidationResult = validation_result([], 1, 2, 3, true)

  give result.valid
    and result.checked_items == 1
    and result.checked_stmts == 2
    and result.checked_exprs == 3
    and hir_validation_summary(result) != ""
}
