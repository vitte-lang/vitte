space vitte/compiler/middle/hir/validate

use vitte/compiler/middle/hir/lower_ast.{ HirUnit }

proc validate_hir(hir: HirUnit) -> HirUnit {
  if hir.ast_root == "invalid" or hir.node_count == 0 {
    give HirUnit {
      source_path: hir.source_path,
      ast_root: hir.ast_root,
      node_count: hir.node_count,
      valid: false
    };
  }
  give hir;
}
