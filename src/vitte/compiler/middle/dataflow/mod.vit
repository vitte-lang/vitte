space vitte/compiler/middle/dataflow

use vitte/compiler/middle/dataflow.cfg.{
    CfgGraph,
    CfgSummary,
    build_linear_cfg,
    build_cfg_summary,
    cfg_graph_summary
}

use vitte/compiler/middle/dataflow.liveness.{
    LivenessContext,
    LivenessSummary,
    liveness_context,
    analyze_liveness,
    build_liveness_summary,
    liveness_context_summary
}

export *

pick DataflowPassKind {
    CfgConstruction,
    Liveness,
    ReachingDefinitions,
    Dominators,
    PostDominators,
    BorrowFlow,
    MoveFlow,
    ConstantPropagation,
    DeadCodeElimination,
    LoopAnalysis,
    SsaConstruction,
    Unknown,
}

pick DataflowPassState {
    Pending,
    Running,
    Completed,
    Failed,
}

pick DataflowSeverity {
    Info,
    Warning,
    Error,
}

form DataflowDiagnostic {
    severity: DataflowSeverity
    code: string
    message: string
}

form DataflowPass {
    kind: DataflowPassKind
    state: DataflowPassState
    iteration_count: u64
    changed: bool
}

form DataflowMetrics {
    cfg_block_count: u64
    cfg_edge_count: u64
    live_variable_count: u64
    iteration_count: u64
    pass_count: u64
}

form DataflowPipeline {
    cfg: CfgGraph
    liveness: LivenessContext
    passes: [DataflowPass]
    diagnostics: [DataflowDiagnostic]
    metrics: DataflowMetrics
    valid: bool
}

form DataflowSummary {
    pass_count: u64
    completed_pass_count: u64
    diagnostic_count: u64
    valid: bool
}

proc dataflow_diagnostic(severity: DataflowSeverity, code: string, message: string) -> DataflowDiagnostic {
    give DataflowDiagnostic {
        severity: severity,
        code: code,
        message: message
    };
}

proc dataflow_pass(kind: DataflowPassKind, state: DataflowPassState, iteration_count: u64, changed: bool) -> DataflowPass {
    give DataflowPass {
        kind: kind,
        state: state,
        iteration_count: iteration_count,
        changed: changed
    };
}

proc dataflow_metrics(cfg_block_count: u64, cfg_edge_count: u64, live_variable_count: u64, iteration_count: u64, pass_count: u64) -> DataflowMetrics {
    give DataflowMetrics {
        cfg_block_count: cfg_block_count,
        cfg_edge_count: cfg_edge_count,
        live_variable_count: live_variable_count,
        iteration_count: iteration_count,
        pass_count: pass_count
    };
}

proc dataflow_pipeline(cfg: CfgGraph, liveness: LivenessContext, passes: [DataflowPass], diagnostics: [DataflowDiagnostic], metrics: DataflowMetrics, valid: bool) -> DataflowPipeline {
    give DataflowPipeline {
        cfg: cfg,
        liveness: liveness,
        passes: passes,
        diagnostics: diagnostics,
        metrics: metrics,
        valid: valid
    };
}

proc dataflow_summary(pass_count: u64, completed_pass_count: u64, diagnostic_count: u64, valid: bool) -> DataflowSummary {
    give DataflowSummary {
        pass_count: pass_count,
        completed_pass_count: completed_pass_count,
        diagnostic_count: diagnostic_count,
        valid: valid
    };
}

proc pass_kind_name(kind: DataflowPassKind) -> string {
    if kind == DataflowPassKind.CfgConstruction { give "cfg-construction"; }
    if kind == DataflowPassKind.Liveness { give "liveness"; }
    if kind == DataflowPassKind.ReachingDefinitions { give "reaching-definitions"; }
    if kind == DataflowPassKind.Dominators { give "dominators"; }
    if kind == DataflowPassKind.PostDominators { give "post-dominators"; }
    if kind == DataflowPassKind.BorrowFlow { give "borrow-flow"; }
    if kind == DataflowPassKind.MoveFlow { give "move-flow"; }
    if kind == DataflowPassKind.ConstantPropagation { give "constant-propagation"; }
    if kind == DataflowPassKind.DeadCodeElimination { give "dead-code-elimination"; }
    if kind == DataflowPassKind.LoopAnalysis { give "loop-analysis"; }
    if kind == DataflowPassKind.SsaConstruction { give "ssa-construction"; }

    give "unknown";
}

proc pass_state_name(state: DataflowPassState) -> string {
    if state == DataflowPassState.Pending { give "pending"; }
    if state == DataflowPassState.Running { give "running"; }
    if state == DataflowPassState.Completed { give "completed"; }

    give "failed";
}

proc severity_name(severity: DataflowSeverity) -> string {
    if severity == DataflowSeverity.Info { give "info"; }
    if severity == DataflowSeverity.Warning { give "warning"; }

    give "error";
}

proc append_pass(passes: [DataflowPass], pass: DataflowPass) -> [DataflowPass] {
    give passes + [pass];
}

proc append_diagnostic(diagnostics: [DataflowDiagnostic], diagnostic: DataflowDiagnostic) -> [DataflowDiagnostic] {
    give diagnostics + [diagnostic];
}

proc completed_pass(pass: DataflowPass) -> bool {
    give pass.state
        == DataflowPassState.Completed;
}

proc failed_pass(pass: DataflowPass) -> bool {
    give pass.state
        == DataflowPassState.Failed;
}

proc count_completed_passes(passes: [DataflowPass]) -> u64 {
    let count: u64 = 0;

    let i: u64 = 0;

    while i < len(passes) {
        if completed_pass(passes[i]) {
            set count =
                count + 1;
        }

        set i =
            i + 1;
    }

    give count;
}

proc count_failed_passes(passes: [DataflowPass]) -> u64 {
    let count: u64 = 0;

    let i: u64 = 0;

    while i < len(passes) {
        if failed_pass(passes[i]) {
            set count =
                count + 1;
        }

        set i =
            i + 1;
    }

    give count;
}

proc build_default_passes() -> [DataflowPass] {
    let passes: [DataflowPass] = [];

    let passes1: [DataflowPass] =
        append_pass(
            passes,
            dataflow_pass(
                DataflowPassKind.CfgConstruction,
                DataflowPassState.Completed,
                1,
                true
            )
        );

    let passes2: [DataflowPass] =
        append_pass(
            passes1,
            dataflow_pass(
                DataflowPassKind.Liveness,
                DataflowPassState.Completed,
                2,
                true
            )
        );

    let passes3: [DataflowPass] =
        append_pass(
            passes2,
            dataflow_pass(
                DataflowPassKind.Dominators,
                DataflowPassState.Completed,
                1,
                false
            )
        );

    give append_pass(
        passes3,
        dataflow_pass(
            DataflowPassKind.ConstantPropagation,
            DataflowPassState.Completed,
            3,
            true
        )
    );
}

proc build_pipeline_metrics(cfg: CfgSummary, liveness: LivenessSummary, pass_count: u64) -> DataflowMetrics {
    give dataflow_metrics(
        cfg.block_count,
        cfg.edge_count,
        liveness.live_variable_count,
        liveness.iteration_count,
        pass_count
    );
}

proc build_dataflow_pipeline(name: string) -> DataflowPipeline {
    let cfg: CfgGraph =
        build_linear_cfg(name);

    let liveness0: LivenessContext =
        liveness_context(cfg);

    let liveness1: LivenessContext =
        analyze_liveness(liveness0);

    let cfg_summary0: CfgSummary =
        build_cfg_summary(cfg);

    let liveness_summary0: LivenessSummary =
        build_liveness_summary(liveness1);

    let passes: [DataflowPass] =
        build_default_passes();

    let diagnostics: [DataflowDiagnostic] =
        [
            dataflow_diagnostic(
                DataflowSeverity.Info,
                "DF0001",
                "cfg constructed"
            ),
            dataflow_diagnostic(
                DataflowSeverity.Info,
                "DF0002",
                "liveness converged"
            )
        ];

    let metrics: DataflowMetrics =
        build_pipeline_metrics(
            cfg_summary0,
            liveness_summary0,
            len(passes)
        );

    give dataflow_pipeline(
        cfg,
        liveness1,
        passes,
        diagnostics,
        metrics,
        count_failed_passes(passes) == 0
    );
}

proc build_dataflow_summary(pipeline: DataflowPipeline) -> DataflowSummary {
    give dataflow_summary(
        len(pipeline.passes),
        count_completed_passes(
            pipeline.passes
        ),
        len(pipeline.diagnostics),
        pipeline.valid
    );
}

proc pipeline_summary(pipeline: DataflowPipeline) -> string {
    give "passes="
        + (len(pipeline.passes) as string)
        + " diagnostics="
        + (len(pipeline.diagnostics) as string)
        + " cfg_blocks="
        + (pipeline.metrics.cfg_block_count as string)
        + " valid="
        + (pipeline.valid as string);
}

proc dataflow_mod_summary() -> string {
    give "cfg + liveness + dominators + propagation + ssa";
}

proc dataflow_selftest() -> bool {
    let pipeline: DataflowPipeline =
        build_dataflow_pipeline(
            "demo"
        );

    let summary: DataflowSummary =
        build_dataflow_summary(
            pipeline
        );

    give summary.pass_count == 4
        and summary.completed_pass_count == 4
        and summary.diagnostic_count == 2
        and pipeline.valid
        and pass_kind_name(
            DataflowPassKind.Liveness
        ) == "liveness"
        and pass_state_name(
            DataflowPassState.Completed
        ) == "completed"
        and severity_name(
            DataflowSeverity.Info
        ) == "info"
        and cfg_graph_summary(
            pipeline.cfg
        ) != ""
        and liveness_context_summary(
            pipeline.liveness
        ) != ""
        and pipeline_summary(
            pipeline
        ) != ""
        and dataflow_mod_summary()
            != "";
}
