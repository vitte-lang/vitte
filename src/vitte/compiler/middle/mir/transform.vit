space vitte/compiler/middle/mir/transform

use vitte/compiler/middle/mir.{
  MirBlock,
  MirBinaryOperator,
  MirFunction,
  MirModule,
  MirOperand,
  MirPlace,
  MirRvalue,
  MirRvalueKind,
  MirStatement,
  MirStatementKind,
  MirTerminator,
  MirTerminatorKind,
  MirUnit,
  mir_statement_kind_name,
  mir_terminator_kind_name
}

export *

pick MirTransformKind {
  SimplifyCfg,
  RemoveUnreachable,
  FoldConstants,
  EliminateCopies,
  EliminateNop,
  MergeBlocks,
  NormalizeBranches,
  Validate,
}

pick MirTransformResultKind {
  Unchanged,
  Changed,
  Invalid,
}

form MirTransformStep {
  kind: MirTransformKind
  result: MirTransformResultKind
  changed_blocks: u64
  changed_statements: u64
  valid: bool
}

form MirTransformStats {
  removed_blocks: u64
  removed_statements: u64
  folded_constants: u64
  merged_blocks: u64
  simplified_branches: u64
  valid: bool
}

form MirTransformReport {
  function_name: string
  steps: [MirTransformStep]
  stats: MirTransformStats
  changed: bool
  valid: bool
}

form MirIntegerRange {
  minimum: int
  maximum: int
  signed: bool
  supported: bool
}

form MirConstantFoldResult {
  rvalue: MirRvalue
  folded: bool
}

proc transform_step(kind: MirTransformKind, result: MirTransformResultKind, changed_blocks: u64, changed_statements: u64, valid: bool) -> MirTransformStep {
  give MirTransformStep {
    kind: kind,
    result: result,
    changed_blocks: changed_blocks,
    changed_statements: changed_statements,
    valid: valid
  }
}

proc transform_stats() -> MirTransformStats {
  give MirTransformStats {
    removed_blocks: 0,
    removed_statements: 0,
    folded_constants: 0,
    merged_blocks: 0,
    simplified_branches: 0,
    valid: true
  }
}

proc transform_report(function_name: string) -> MirTransformReport {
  give MirTransformReport {
    function_name: function_name,
    steps: [],
    stats: transform_stats(),
    changed: false,
    valid: true
  }
}

proc transform_kind_name(kind: MirTransformKind) -> string {
  if kind == MirTransformKind.SimplifyCfg {
    give "simplify-cfg"
  } elif kind == MirTransformKind.RemoveUnreachable {
    give "remove-unreachable"
  } elif kind == MirTransformKind.FoldConstants {
    give "fold-constants"
  } elif kind == MirTransformKind.EliminateCopies {
    give "eliminate-copies"
  } elif kind == MirTransformKind.EliminateNop {
    give "eliminate-nop"
  } elif kind == MirTransformKind.MergeBlocks {
    give "merge-blocks"
  } elif kind == MirTransformKind.NormalizeBranches {
    give "normalize-branches"
  } elif kind == MirTransformKind.Validate {
    give "validate"
  }

  give "unknown"
}

proc transform_result_name(kind: MirTransformResultKind) -> string {
  if kind == MirTransformResultKind.Unchanged {
    give "unchanged"
  } elif kind == MirTransformResultKind.Changed {
    give "changed"
  } elif kind == MirTransformResultKind.Invalid {
    give "invalid"
  }

  give "unknown"
}

proc append_step(report: MirTransformReport, step: MirTransformStep) -> MirTransformReport {
  give MirTransformReport {
    function_name: report.function_name,
    steps: report.steps + [step],
    stats: report.stats,
    changed: report.changed or step.result == MirTransformResultKind.Changed,
    valid: report.valid and step.valid
  }
}

proc constant_operand(operand: MirOperand) -> bool {
  give operand.constant
}

proc constant_rvalue(rvalue: MirRvalue) -> bool {
  if rvalue.kind != MirRvalueKind.Binary {
    give false
  }

  if len(rvalue.operands) != 2 {
    give false
  }

  give constant_operand(rvalue.operands[0])
    and constant_operand(rvalue.operands[1])
}

proc mir_integer_range(ty: string) -> MirIntegerRange {
  if ty == "i8" {
    give MirIntegerRange { minimum: -128, maximum: 127, signed: true, supported: true }
  } elif ty == "u8" {
    give MirIntegerRange { minimum: 0, maximum: 255, signed: false, supported: true }
  } elif ty == "i16" {
    give MirIntegerRange { minimum: -32768, maximum: 32767, signed: true, supported: true }
  } elif ty == "u16" {
    give MirIntegerRange { minimum: 0, maximum: 65535, signed: false, supported: true }
  } elif ty == "i32" {
    give MirIntegerRange { minimum: -2147483648, maximum: 2147483647, signed: true, supported: true }
  } elif ty == "u32" {
    give MirIntegerRange { minimum: 0, maximum: 4294967295, signed: false, supported: true }
  }
  give MirIntegerRange { minimum: 0, maximum: 0, signed: false, supported: false }
}

proc decimal_integer_text(text: string) -> bool {
  let value: string = trim(text)
  if value == "" {
    give false
  }
  let i: u64 = if slice(value, 0, 1) == "-" { 1 } else { 0 }
  if i == len(value) {
    give false
  }
  while i < len(value) {
    let ch: string = slice(value, i, i + 1)
    if ch < "0" or ch > "9" {
      give false
    }
    set i = i + 1
  }
  give true
}

proc integer_in_range(value: int, range0: MirIntegerRange) -> bool {
  give range0.supported and value >= range0.minimum and value <= range0.maximum
}

proc foldable_integer_operands(rvalue: MirRvalue) -> bool {
  if not constant_rvalue(rvalue) or rvalue.operands[0].ty != rvalue.operands[1].ty {
    give false
  }
  let range0: MirIntegerRange = mir_integer_range(rvalue.operands[0].ty)
  if not range0.supported or not decimal_integer_text(rvalue.operands[0].text) or not decimal_integer_text(rvalue.operands[1].text) {
    give false
  }
  give integer_in_range(parse_int(rvalue.operands[0].text), range0)
    and integer_in_range(parse_int(rvalue.operands[1].text), range0)
}

proc folded_constant_rvalue(original: MirRvalue, value: string, ty: string) -> MirRvalue {
  let operand: MirOperand = MirOperand {
    text: value,
    place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false },
    ty: ty,
    constant: true,
    move: false,
    valid: true
  }
  give MirRvalue {
    kind: MirRvalueKind.Use,
    text: value,
    operator: "folded-constant",
    generic_arguments: [],
    binary_operator: original.binary_operator,
    unary_operator: original.unary_operator,
    borrow_kind: original.borrow_kind,
    operands: [operand],
    ty: ty,
    temporary: original.temporary,
    valid: original.valid
  }
}

proc constant_fold_unchanged(rvalue: MirRvalue) -> MirConstantFoldResult {
  give MirConstantFoldResult { rvalue: rvalue, folded: false }
}

proc fold_integer_arithmetic(rvalue: MirRvalue) -> MirConstantFoldResult {
  let range0: MirIntegerRange = mir_integer_range(rvalue.ty)
  if not range0.supported or not foldable_integer_operands(rvalue) {
    give constant_fold_unchanged(rvalue)
  }
  let left: int = parse_int(rvalue.operands[0].text)
  let right: int = parse_int(rvalue.operands[1].text)
  let value: int = 0
  if rvalue.binary_operator == MirBinaryOperator.Add {
    if (right > 0 and left > range0.maximum - right) or (right < 0 and left < range0.minimum - right) {
      give constant_fold_unchanged(rvalue)
    }
    set value = left + right
  } elif rvalue.binary_operator == MirBinaryOperator.Sub {
    if (right > 0 and left < range0.minimum + right) or (right < 0 and left > range0.maximum + right) {
      give constant_fold_unchanged(rvalue)
    }
    set value = left - right
  } elif rvalue.binary_operator == MirBinaryOperator.Mul {
    if range0.signed {
      if (left > 0 and right > 0 and left > range0.maximum / right)
        or (left > 0 and right < 0 and right < range0.minimum / left)
        or (left < 0 and right > 0 and left < range0.minimum / right)
        or (left < 0 and right < 0 and right < range0.maximum / left) {
        give constant_fold_unchanged(rvalue)
      }
    } elif right != 0 and left > range0.maximum / right {
        give constant_fold_unchanged(rvalue)
    }
    set value = left * right
  } elif rvalue.binary_operator == MirBinaryOperator.Div {
    if right == 0 or (range0.signed and left == range0.minimum and right == -1) {
      give constant_fold_unchanged(rvalue)
    }
    set value = left / right
  } elif rvalue.binary_operator == MirBinaryOperator.Rem {
    if right == 0 or (range0.signed and left == range0.minimum and right == -1) {
      give constant_fold_unchanged(rvalue)
    }
    set value = left % right
  } else {
    give constant_fold_unchanged(rvalue)
  }
  if not integer_in_range(value, range0) {
    give constant_fold_unchanged(rvalue)
  }
  give MirConstantFoldResult { rvalue: folded_constant_rvalue(rvalue, value as string, rvalue.ty), folded: true }
}

proc fold_integer_comparison(rvalue: MirRvalue) -> MirConstantFoldResult {
  if not foldable_integer_operands(rvalue) {
    give constant_fold_unchanged(rvalue)
  }
  let left: int = parse_int(rvalue.operands[0].text)
  let right: int = parse_int(rvalue.operands[1].text)
  let value: bool = false
  if rvalue.binary_operator == MirBinaryOperator.Eq {
    set value = left == right
  } elif rvalue.binary_operator == MirBinaryOperator.Ne {
    set value = left != right
  } elif rvalue.binary_operator == MirBinaryOperator.Lt {
    set value = left < right
  } elif rvalue.binary_operator == MirBinaryOperator.Le {
    set value = left <= right
  } elif rvalue.binary_operator == MirBinaryOperator.Gt {
    set value = left > right
  } elif rvalue.binary_operator == MirBinaryOperator.Ge {
    set value = left >= right
  } else {
    give constant_fold_unchanged(rvalue)
  }
  give MirConstantFoldResult { rvalue: folded_constant_rvalue(rvalue, value as string, "bool"), folded: true }
}

proc fold_bool_binary(rvalue: MirRvalue) -> MirConstantFoldResult {
  if not constant_rvalue(rvalue) or rvalue.operands[0].ty != "bool" or rvalue.operands[1].ty != "bool" {
    give constant_fold_unchanged(rvalue)
  }
  let left_text: string = rvalue.operands[0].text
  let right_text: string = rvalue.operands[1].text
  if (left_text != "true" and left_text != "false") or (right_text != "true" and right_text != "false") {
    give constant_fold_unchanged(rvalue)
  }
  let left: bool = left_text == "true"
  let right: bool = right_text == "true"
  let value: bool = false
  if rvalue.binary_operator == MirBinaryOperator.And {
    set value = left and right
  } elif rvalue.binary_operator == MirBinaryOperator.Or {
    set value = left or right
  } elif rvalue.binary_operator == MirBinaryOperator.Eq {
    set value = left == right
  } elif rvalue.binary_operator == MirBinaryOperator.Ne {
    set value = left != right
  } else {
    give constant_fold_unchanged(rvalue)
  }
  give MirConstantFoldResult { rvalue: folded_constant_rvalue(rvalue, value as string, "bool"), folded: true }
}

proc fold_binary_constants(rvalue: MirRvalue) -> MirConstantFoldResult {
  if not constant_rvalue(rvalue) {
    give constant_fold_unchanged(rvalue)
  }
  if rvalue.operands[0].ty == "bool" and rvalue.operands[1].ty == "bool" {
    give fold_bool_binary(rvalue)
  }
  let arithmetic: MirConstantFoldResult = fold_integer_arithmetic(rvalue)
  if arithmetic.folded {
    give arithmetic
  }
  give fold_integer_comparison(rvalue)
}

proc fold_constants_statement(stmt: MirStatement) -> MirStatement {
  let folded: MirConstantFoldResult = fold_binary_constants(stmt.rvalue)
  give MirStatement {
    id: stmt.id,
    span: stmt.span,
    kind: stmt.kind,
    place: stmt.place,
    rvalue: folded.rvalue,
    reachable: stmt.reachable,
    valid: stmt.valid and folded.rvalue.valid
  }
}

proc fold_constants_block(block: MirBlock) -> MirBlock {
  let statements: [MirStatement] = []
  let i: u64 = 0
  while i < len(block.statements) {
    set statements = statements + [fold_constants_statement(block.statements[i])]
    set i = i + 1
  }
  give MirBlock {
    id: block.id,
    label: block.label,
    predecessors: block.predecessors,
    statements: statements,
    terminator: block.terminator,
    sealed: block.sealed,
    reachable: block.reachable,
    valid: block.valid
  }
}

proc fold_constants_function(function0: MirFunction) -> MirFunction {
  let blocks: [MirBlock] = []
  let i: u64 = 0
  while i < len(function0.blocks) {
    set blocks = blocks + [fold_constants_block(function0.blocks[i])]
    set i = i + 1
  }
  give MirFunction {
    id: function0.id,
    name: function0.name,
    generic_params: function0.generic_params,
    entry_block: function0.entry_block,
    params: function0.params,
    return_type: function0.return_type,
    local_count: function0.local_count,
    temporary_count: function0.temporary_count,
    blocks: blocks,
    valid: function0.valid
  }
}

proc count_folded_constants(before: MirFunction, after: MirFunction) -> u64 {
  let count: u64 = 0
  let i: u64 = 0
  while i < len(before.blocks) and i < len(after.blocks) {
    let j: u64 = 0
    while j < len(before.blocks[i].statements) and j < len(after.blocks[i].statements) {
      if before.blocks[i].statements[j].rvalue.kind == MirRvalueKind.Binary
        and after.blocks[i].statements[j].rvalue.kind == MirRvalueKind.Use
        and after.blocks[i].statements[j].rvalue.operator == "folded-constant" {
        set count = count + 1
      }
      set j = j + 1
    }
    set i = i + 1
  }
  give count
}

proc constant_fold_report_for(before: MirFunction, after: MirFunction) -> MirTransformReport {
  let folded: u64 = count_folded_constants(before, after)
  let result_kind: MirTransformResultKind = if folded > 0 { MirTransformResultKind.Changed } else { MirTransformResultKind.Unchanged }
  let valid: bool = validate_function(after)
  give MirTransformReport {
    function_name: after.name,
    steps: [transform_step(MirTransformKind.FoldConstants, result_kind, 0, folded, valid)],
    stats: MirTransformStats {
      removed_blocks: 0,
      removed_statements: 0,
      folded_constants: folded,
      merged_blocks: 0,
      simplified_branches: 0,
      valid: valid
    },
    changed: folded > 0,
    valid: valid
  }
}

proc nop_statement(stmt: MirStatement) -> bool {
  give stmt.kind == MirStatementKind.Nop
}

proc unreachable_block(block: MirBlock) -> bool {
  give not block.reachable
}

proc block_id_in(ids: [u64], id: u64) -> bool {
  let i: u64 = 0
  while i < len(ids) {
    if ids[i] == id {
      give true
    }
    set i = i + 1
  }
  give false
}

proc function_has_block(function0: MirFunction, id: u64) -> bool {
  let i: u64 = 0
  while i < len(function0.blocks) {
    if function0.blocks[i].id == id {
      give true
    }
    set i = i + 1
  }
  give false
}

proc append_successor(ids: [u64], function0: MirFunction, id: u64) -> [u64] {
  if id == 0 or block_id_in(ids, id) or not function_has_block(function0, id) {
    give ids
  }
  give ids + [id]
}

proc terminator_successors(function0: MirFunction, terminator: MirTerminator) -> [u64] {
  let out: [u64] = []
  if terminator.kind == MirTerminatorKind.Goto {
    set out = append_successor(out, function0, terminator.target_block)
  } elif terminator.kind == MirTerminatorKind.Branch {
    set out = append_successor(out, function0, terminator.target_block)
    set out = append_successor(out, function0, terminator.else_block)
  } elif terminator.kind == MirTerminatorKind.Switch {
    let i: u64 = 0
    while i < len(terminator.switch_targets) {
      set out = append_successor(out, function0, terminator.switch_targets[i])
      set i = i + 1
    }
    set out = append_successor(out, function0, terminator.else_block)
  } elif terminator.kind == MirTerminatorKind.Call {
    set out = append_successor(out, function0, terminator.target_block)
    set out = append_successor(out, function0, terminator.else_block)
    set out = append_successor(out, function0, terminator.unwind_block)
  }
  give out
}

proc block_by_id(function0: MirFunction, id: u64) -> MirBlock {
  let i: u64 = 0
  while i < len(function0.blocks) {
    if function0.blocks[i].id == id {
      give function0.blocks[i]
    }
    set i = i + 1
  }
  give MirBlock { id: 0, valid: false }
}

proc reachable_block_ids(function0: MirFunction) -> [u64] {
  let reachable: [u64] = []
  if not function_has_block(function0, function0.entry_block) {
    give reachable
  }
  set reachable = [function0.entry_block]
  let cursor: u64 = 0
  while cursor < len(reachable) {
    let block: MirBlock = block_by_id(function0, reachable[cursor])
    let successors: [u64] = terminator_successors(function0, block.terminator)
    let i: u64 = 0
    while i < len(successors) {
      if not block_id_in(reachable, successors[i]) {
        set reachable = reachable + [successors[i]]
      }
      set i = i + 1
    }
    set cursor = cursor + 1
  }
  give reachable
}

proc predecessors_for(block_id: u64, blocks: [MirBlock]) -> [u64] {
  let function0: MirFunction = MirFunction { entry_block: blocks[0].id, blocks: blocks, valid: true }
  let out: [u64] = []
  let i: u64 = 0
  while i < len(blocks) {
    let successors: [u64] = terminator_successors(function0, blocks[i].terminator)
    if block_id_in(successors, block_id) and not block_id_in(out, blocks[i].id) {
      set out = out + [blocks[i].id]
    }
    set i = i + 1
  }
  give out
}

proc eliminate_unreachable_function(function0: MirFunction) -> MirFunction {
  let reachable: [u64] = reachable_block_ids(function0)
  let retained: [MirBlock] = []
  let i: u64 = 0
  while i < len(function0.blocks) {
    if block_id_in(reachable, function0.blocks[i].id) {
      set retained = retained + [function0.blocks[i]]
    }
    set i = i + 1
  }

  let blocks: [MirBlock] = []
  let j: u64 = 0
  while j < len(retained) {
    set blocks = blocks + [MirBlock {
      id: retained[j].id,
      label: retained[j].label,
      predecessors: predecessors_for(retained[j].id, retained),
      statements: retained[j].statements,
      terminator: retained[j].terminator,
      sealed: retained[j].sealed,
      reachable: true,
      valid: retained[j].valid
    }]
    set j = j + 1
  }

  give MirFunction {
    id: function0.id,
    name: function0.name,
    generic_params: function0.generic_params,
    entry_block: function0.entry_block,
    params: function0.params,
    return_type: function0.return_type,
    local_count: function0.local_count,
    temporary_count: function0.temporary_count,
    blocks: blocks,
    valid: function0.valid and len(blocks) > 0
  }
}

proc dead_code_report_for(before: MirFunction, after: MirFunction) -> MirTransformReport {
  let removed_blocks: u64 = count_removed_blocks(before.blocks, after.blocks)
  let removed_statements: u64 = count_removed_statements(before.blocks, after.blocks)
  let changed: bool = removed_blocks > 0 or removed_statements > 0
  let valid: bool = validate_function(after)
  give MirTransformReport {
    function_name: after.name,
    steps: [transform_step(MirTransformKind.RemoveUnreachable, if changed { MirTransformResultKind.Changed } else { MirTransformResultKind.Unchanged }, removed_blocks, removed_statements, valid)],
    stats: MirTransformStats {
      removed_blocks: removed_blocks,
      removed_statements: removed_statements,
      folded_constants: 0,
      merged_blocks: 0,
      simplified_branches: 0,
      valid: valid
    },
    changed: changed,
    valid: valid
  }
}

proc trivial_goto(block: MirBlock) -> bool {
  give len(block.statements) == 0
    and block.terminator.kind == MirTerminatorKind.Goto
}

proc filter_nop_statements(statements: [MirStatement]) -> [MirStatement] {
  let out: [MirStatement] = []

  let i: u64 = 0

  while i < len(statements) {
    if not nop_statement(statements[i]) {
      set out = out + [statements[i]]
    }

    set i = i + 1
  }

  give out
}

proc remove_unreachable_blocks(blocks: [MirBlock]) -> [MirBlock] {
  let out: [MirBlock] = []

  let i: u64 = 0

  while i < len(blocks) {
    if not unreachable_block(blocks[i]) {
      set out = out + [blocks[i]]
    }

    set i = i + 1
  }

  give out
}

proc normalize_block(block: MirBlock) -> MirBlock {
  give MirBlock {
    id: block.id,
    label: block.label,
    predecessors: block.predecessors,
    statements: filter_nop_statements(
      block.statements
    ),
    terminator: block.terminator,
    sealed: block.sealed,
    reachable: block.reachable,
    valid: block.valid
  }
}

proc normalize_blocks(blocks: [MirBlock]) -> [MirBlock] {
  let out: [MirBlock] = []

  let i: u64 = 0

  while i < len(blocks) {
    set out = out + [normalize_block(blocks[i])]

    set i = i + 1
  }

  give out
}

proc validate_block(block: MirBlock) -> bool {
  if not block.valid {
    give false
  }

  if block.id == 0 {
    give false
  }

  if not block.terminator.valid {
    give false
  }

  give true
}

proc validate_function(function0: MirFunction) -> bool {
  if not function0.valid {
    give false
  }

  if function0.entry_block == 0 {
    give false
  }

  if len(function0.blocks) == 0 {
    give false
  }

  let i: u64 = 0

  while i < len(function0.blocks) {
    if not validate_block(function0.blocks[i]) {
      give false
    }

    set i = i + 1
  }

  give true
}

proc count_removed_blocks(before: [MirBlock], after: [MirBlock]) -> u64 {
  if len(before) < len(after) {
    give 0
  }

  give len(before) - len(after)
}

proc count_removed_statements(before: [MirBlock], after: [MirBlock]) -> u64 {
  let before_count: u64 = 0
  let after_count: u64 = 0

  let i: u64 = 0

  while i < len(before) {
    set before_count = before_count + len(before[i].statements)

    set i = i + 1
  }

  set i = 0

  while i < len(after) {
    set after_count = after_count + len(after[i].statements)

    set i = i + 1
  }

  if before_count < after_count {
    give 0
  }

  give before_count - after_count
}

proc simplify_cfg(function0: MirFunction) -> MirFunction {
  give MirFunction {
    id: function0.id,
    name: function0.name,
    generic_params: function0.generic_params,
    entry_block: function0.entry_block,
    params: function0.params,
    return_type: function0.return_type,
    local_count: function0.local_count,
    temporary_count: function0.temporary_count,
    blocks: normalize_blocks(
      remove_unreachable_blocks(
        function0.blocks
      )
    ),
    valid: function0.valid
  }
}

proc build_cfg_step(before: MirFunction, after: MirFunction) -> MirTransformStep {
  let removed_blocks: u64 = count_removed_blocks(before.blocks, after.blocks)
  let removed_statements: u64 = count_removed_statements(before.blocks, after.blocks)
  let result_kind: MirTransformResultKind = if removed_blocks > 0 or removed_statements > 0 {
    MirTransformResultKind.Changed
  } else {
    MirTransformResultKind.Unchanged
  }

  give transform_step(
    MirTransformKind.SimplifyCfg,
    result_kind,
    removed_blocks,
    removed_statements,
    after.valid
  )
}

proc build_validate_step(function0: MirFunction) -> MirTransformStep {
  let validated: bool = validate_function(function0)
  let result_kind: MirTransformResultKind = if validated {
    MirTransformResultKind.Unchanged
  } else {
    MirTransformResultKind.Invalid
  }
  give transform_step(
    MirTransformKind.Validate,
    result_kind,
    0,
    0,
    validated
  )
}

proc transform_function(function0: MirFunction) -> MirFunction {
  give simplify_cfg(function0)
}

proc optimize_function(function0: MirFunction) -> MirFunction {
  let simplified: MirFunction = simplify_cfg(function0)

  give MirFunction {
    id: simplified.id,
    name: simplified.name,
    generic_params: simplified.generic_params,
    entry_block: simplified.entry_block,
    params: simplified.params,
    return_type: simplified.return_type,
    local_count: simplified.local_count,
    temporary_count: simplified.temporary_count,
    blocks: simplified.blocks,
    valid: validate_function(simplified)
  }
}

proc transform_report_for(before: MirFunction, after: MirFunction) -> MirTransformReport {
  let report0: MirTransformReport = transform_report(after.name)
  let report1: MirTransformReport = append_step(report0, build_cfg_step(before, after))
  let report2: MirTransformReport = append_step(report1, build_validate_step(after))
  let cfg_step: MirTransformStep = report2.steps[0]

  give MirTransformReport {
    function_name: report2.function_name,
    steps: report2.steps,
    stats: MirTransformStats {
      removed_blocks: cfg_step.changed_blocks,
      removed_statements: cfg_step.changed_statements,
      folded_constants: 0,
      merged_blocks: 0,
      simplified_branches: 0,
      valid: report2.valid
    },
    changed: report2.changed,
    valid: report2.valid
  }
}

proc optimize_module(module0: MirModule) -> MirModule {
  let functions: [MirFunction] = []

  let i: u64 = 0

  while i < len(module0.functions) {
    set functions = functions + [optimize_function(module0.functions[i])]

    set i = i + 1
  }

  give MirModule {
    name: module0.name,
    functions: functions,
    valid: module0.valid
  }
}

proc optimize_unit(unit: MirUnit) -> MirUnit {
  let optimized: MirModule = optimize_module(unit.module)

  give MirUnit {
    source_path: unit.source_path,
    module: optimized,
    function_count: unit.function_count,
    block_count: unit.block_count,
    instruction_count: unit.instruction_count,
    lowered: unit.lowered,
    valid: optimized.valid and unit.valid
  }
}

proc report_summary(report: MirTransformReport) -> string {
  let step_count_text: string = len(report.steps) as string
  let removed_blocks_text: string = report.stats.removed_blocks as string
  let removed_statements_text: string = report.stats.removed_statements as string
  let changed_text: string = report.changed as string
  let valid_text: string = report.valid as string
  let out: string = "function " + report.function_name
  let with_steps: string = out + " steps " + step_count_text
  let with_blocks: string = with_steps + " removed-blocks " + removed_blocks_text
  let with_statements: string = with_blocks + " removed-statements " + removed_statements_text
  let with_changed: string = with_statements + " changed " + changed_text
  give with_changed + " valid " + valid_text
}

proc mir_transform_selftest() -> bool {
  let nop_stmt: MirStatement = MirStatement {
    id: 1,
    span: ast_span_empty(),
    kind: MirStatementKind.Nop,
    place: MirPlace {
      local: "",
      projection: "",
      deref_depth: 0,
      mutable: false,
      moved: false,
      valid: false
    },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Use,
      text: "",
      operator: "",
      binary_operator: MirBinaryOperator.Add,
      unary_operator: MirUnaryOperator.Not,
      borrow_kind: MirBorrowKind.Shared,
      operands: [],
      ty: "void",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  }

  let block0: MirBlock = MirBlock {
    id: 1,
    label: "entry",
    predecessors: [],
    statements: [nop_stmt],
    terminator: mir_terminator_return(),
    sealed: true,
    reachable: true,
    valid: true
  }

  let block1: MirBlock = MirBlock {
    id: 2,
    label: "dead",
    predecessors: [],
    statements: [],
    terminator: mir_terminator_return(),
    sealed: true,
    reachable: false,
    valid: true
  }

  let function0: MirFunction = MirFunction {
    id: 1,
    name: "main",
    entry_block: 1,
    params: [],
    return_type: "void",
    local_count: 0,
    temporary_count: 0,
    blocks: [block0, block1],
    valid: true
  }

  let optimized: MirFunction = optimize_function(function0)
  let report: MirTransformReport = transform_report_for(function0, optimized)

  give optimized.valid
    and len(optimized.blocks) == 1
    and len(optimized.blocks[0].statements) == 0
    and report.changed
    and report.stats.removed_blocks == 1
    and report.stats.removed_statements == 1
    and transform_kind_name(MirTransformKind.SimplifyCfg) == "simplify-cfg"
    and transform_result_name(MirTransformResultKind.Changed) == "changed"
    and report_summary(report) != ""
}
