space vitte/compiler/middle/lower/hir_to_mir

use vitte/compiler/middle/hir/lower_ast.{ HirUnit }

form MirUnit {
  source_path: string
  block_count: u64
  instruction_count: u64
  valid: bool
}

proc lower_hir_to_mir(hir: HirUnit) -> MirUnit {
  if not hir.valid {
    give MirUnit {
      source_path: hir.source_path,
      block_count: 0,
      instruction_count: 0,
      valid: false
    };
  }

  give MirUnit {
    source_path: hir.source_path,
    block_count: 1,
    instruction_count: 1,
    valid: true
  };
}
