space vitte/compiler/middle/lower/hir_to_mir

use vitte/compiler/middle/hir.{ HirExpr, HirExprKind, HirItemKind, HirStmt, HirStmtKind, HirUnit }
use vitte/compiler/middle/mir.{
  MirBlock,
  MirFunction,
  MirModule,
  MirOperand,
  MirPlace,
  MirRvalue,
  MirRvalueKind,
  MirStatement,
  MirStatementKind,
  MirTerminator,
  MirUnit,
  mir_module_empty,
  mir_place_empty,
  mir_terminator_branch,
  mir_terminator_goto,
  mir_terminator_return
}

form MirSequence {
  blocks: [MirBlock]
  entry_block: u64
  next_block_id: u64
  instruction_count: u64
  valid: bool
}

proc mir_place_from_name(name: string) -> MirPlace {
  let trimmed: string = trim(name);
  if trimmed == "" {
    give mir_place_empty();
  }

  let prefix: string = "";
  let i: u64 = 0;
  while i < len(trimmed) and slice(trimmed, i, i + 1) == "*" {
    set prefix = prefix + "*";
    set i = i + 1;
  }

  let start: u64 = i;
  while i < len(trimmed) {
    let ch: string = slice(trimmed, i, i + 1);
    let lower_alpha: bool = ch >= "a" and ch <= "z";
    let upper_alpha: bool = ch >= "A" and ch <= "Z";
    let digit: bool = ch >= "0" and ch <= "9";
    let valid_ident: bool = lower_alpha or upper_alpha or ch == "_" or digit;
    if not valid_ident {
      break;
    }
    set i = i + 1;
  }

  if i == start {
    give MirPlace { local: trimmed, projection: "", valid: true };
  }

  let local: string = slice(trimmed, start, i);
  let projection: string = prefix + slice(trimmed, i, len(trimmed));
  if projection == "" {
    give MirPlace { local: local, projection: "", valid: true };
  }
  give MirPlace {
    local: local,
    projection: projection,
    valid: true
  };
}

proc mir_operand_from_expr(expr: HirExpr) -> MirOperand {
  let place: MirPlace = mir_place_empty();
  if expr.binding != "" {
    set place = mir_place_from_name(expr.binding);
  }
  give MirOperand { text: expr.text, place: place, valid: expr.valid };
}

proc mir_rvalue_from_expr(expr: HirExpr) -> MirRvalue {
  let kind: MirRvalueKind = MirRvalueKind.Use;
  if expr.kind == HirExprKind.Binary {
    set kind = MirRvalueKind.Binary;
  } elif expr.kind == HirExprKind.BorrowShared {
    set kind = MirRvalueKind.BorrowShared;
  } elif expr.kind == HirExprKind.BorrowMut {
    set kind = MirRvalueKind.BorrowMut;
  } elif expr.kind == HirExprKind.Call {
    set kind = MirRvalueKind.Call;
  }

  let operands: [MirOperand] = [];
  let i: u64 = 0;
  while i < len(expr.children) {
    set operands = operands + [mir_operand_from_expr(expr.children[i])];
    set i = i + 1;
  }
  if len(operands) == 0 {
    set operands = [mir_operand_from_expr(expr)];
  }

  give MirRvalue {
    kind: kind,
    text: expr.text,
    operator: expr.operator,
    operands: operands,
    valid: expr.valid
  };
}

proc mir_statement_from_stmt(stmt: HirStmt) -> MirStatement {
  if stmt.kind == HirStmtKind.Give {
    give MirStatement { id: stmt.id, span: stmt.span, kind: MirStatementKind.Return, place: mir_place_empty(), rvalue: mir_rvalue_from_expr(stmt.expr), valid: stmt.valid };
  }
  if stmt.kind == HirStmtKind.StaticAssert {
    give MirStatement { id: stmt.id, span: stmt.span, kind: MirStatementKind.Assert, place: mir_place_empty(), rvalue: mir_rvalue_from_expr(stmt.expr), valid: stmt.valid };
  }
  let place: MirPlace = mir_place_from_name(stmt.target);
  if stmt.name != "" {
    set place = mir_place_from_name(stmt.name);
  }
  give MirStatement { id: stmt.id, span: stmt.span, kind: MirStatementKind.Assign, place: place, rvalue: mir_rvalue_from_expr(stmt.expr), valid: stmt.valid };
}

proc choose_entry(primary: u64, fallback: u64) -> u64 {
  if primary > 0 {
    give primary;
  }
  give fallback;
}

proc block_single(id: u64, stmt: MirStatement, terminator: MirTerminator) -> MirBlock {
  give MirBlock {
    id: id,
    statements: [stmt],
    terminator: terminator,
    valid: stmt.valid and terminator.valid
  };
}

proc build_stmt_sequence(hir_stmts: [HirStmt], fallthrough_block: u64, next_block_id: u64) -> MirSequence {
  let built: [MirBlock] = [];
  let current_entry: u64 = fallthrough_block;
  let next_id: u64 = next_block_id;
  let instruction_count: u64 = 0;
  let valid: bool = true;

  let i: int = len(hir_stmts) as int - 1;
  while i >= 0 {
    let stmt: HirStmt = hir_stmts[i as u64];

    if stmt.kind == HirStmtKind.If {
      let then_seq: MirSequence = build_stmt_sequence(stmt.then_stmts, current_entry, next_id + 1);
      let else_seq: MirSequence = build_stmt_sequence(stmt.else_stmts, current_entry, then_seq.next_block_id);
      let condition: MirOperand = mir_operand_from_expr(stmt.expr);
      let branch: MirBlock = MirBlock {
        id: next_id,
        statements: [],
        terminator: mir_terminator_branch(
          condition,
          choose_entry(then_seq.entry_block, current_entry),
          choose_entry(else_seq.entry_block, current_entry)
        ),
        valid: stmt.valid and condition.valid and then_seq.valid and else_seq.valid
      };
      set built = [branch] + then_seq.blocks + else_seq.blocks + built;
      set current_entry = branch.id;
      set next_id = else_seq.next_block_id;
      set instruction_count = instruction_count + then_seq.instruction_count + else_seq.instruction_count;
      set valid = valid and branch.valid and then_seq.valid and else_seq.valid;
      set i = i - 1;
      continue;
    }

    if stmt.kind == HirStmtKind.While {
      let header_id: u64 = next_id;
      let body_seq: MirSequence = build_stmt_sequence(stmt.then_stmts, header_id, header_id + 1);
      let condition: MirOperand = mir_operand_from_expr(stmt.expr);
      let header: MirBlock = MirBlock {
        id: header_id,
        statements: [],
        terminator: mir_terminator_branch(
          condition,
          choose_entry(body_seq.entry_block, header_id),
          current_entry
        ),
        valid: stmt.valid and condition.valid and body_seq.valid and current_entry > 0
      };
      set built = [header] + body_seq.blocks + built;
      set current_entry = header.id;
      set next_id = body_seq.next_block_id;
      set instruction_count = instruction_count + body_seq.instruction_count;
      set valid = valid and header.valid and body_seq.valid;
      set i = i - 1;
      continue;
    }

    let mir_stmt: MirStatement = mir_statement_from_stmt(stmt);
    let terminator: MirTerminator = mir_terminator_return();
    if stmt.kind != HirStmtKind.Give {
      set terminator = mir_terminator_goto(current_entry);
    }
    let block: MirBlock = block_single(next_id, mir_stmt, terminator);
    set built = [block] + built;
    set current_entry = block.id;
    set next_id = next_id + 1;
    set instruction_count = instruction_count + 1;
    set valid = valid and block.valid;
    set i = i - 1;
  }

  give MirSequence {
    blocks: built,
    entry_block: current_entry,
    next_block_id: next_id,
    instruction_count: instruction_count,
    valid: valid
  };
}

proc lower_hir_to_mir(hir: HirUnit) -> MirUnit {
  if not hir.valid or not hir.module.valid {
    give MirUnit {
      source_path: hir.source_path,
      module: mir_module_empty(),
      block_count: 0,
      instruction_count: 0,
      valid: false
    };
  }

  let functions: [MirFunction] = [];
  let block_count: u64 = 0;
  let instruction_count: u64 = 0;
  let next_block_id: u64 = 1;
  let i: u64 = 0;
  while i < len(hir.module.items) {
    let item = hir.module.items[i];
    if item.kind == HirItemKind.Proc {
      let exit_block: MirBlock = MirBlock { id: next_block_id, statements: [], terminator: mir_terminator_return(), valid: true };
      let sequence: MirSequence = build_stmt_sequence(item.stmts, exit_block.id, exit_block.id + 1);
      let entry_block: u64 = choose_entry(sequence.entry_block, exit_block.id);
      let blocks: [MirBlock] = sequence.blocks + [exit_block];
      set functions = functions + [MirFunction {
        id: item.id,
        name: item.name,
        entry_block: entry_block,
        blocks: blocks,
        valid: sequence.valid and entry_block > 0
      }];
      set block_count = block_count + len(blocks);
      set instruction_count = instruction_count + sequence.instruction_count;
      set next_block_id = sequence.next_block_id;
    }
    set i = i + 1;
  }

  if len(functions) == 0 {
    let entry = MirBlock { id: 1, statements: [], terminator: mir_terminator_return(), valid: true };
    set functions = [MirFunction { id: 1, name: "__module_init", entry_block: 1, blocks: [entry], valid: true }];
    set block_count = 1;
  }

  give MirUnit {
    source_path: hir.source_path,
    module: MirModule { functions: functions, valid: len(functions) > 0 },
    block_count: block_count,
    instruction_count: instruction_count,
    valid: len(functions) > 0
  };
}
