use vitte/compiler/middle/hir.{ HirItem, HirItemKind, HirNominalMember, HirNominalMemberKind }
use vitte/compiler/middle/mir.{ MirBlock, MirFunction, MirOperand, MirRvalue, MirRvalueKind, MirStatement, MirStatementKind, MirTerminator, MirTerminatorKind, MirUnit }

proc ir_visibility_for_function(name: string) -> IrVisibility {
    if name == "main" {
        give IrVisibility.Public;
    }
    give IrVisibility.Private;
}

proc ir_linkage_for_function(name: string) -> IrLinkage {
    if name == "main" {
        give IrLinkage.Exported;
    }
    give IrLinkage.Internal;
}

proc name_in_list(names: [string], name: string) -> bool {
    let i: u64 = 0;
    while i < len(names) {
        if names[i] == name {
            give true;
        }
        set i = i + 1;
    }
    give false;
}

proc ir_visibility_for_exports(name: string, exported_names: [string]) -> IrVisibility {
    if name == "main" or name_in_list(exported_names, name) {
        give IrVisibility.Public;
    }
    give IrVisibility.Private;
}

proc ir_linkage_for_exports(name: string, exported_names: [string]) -> IrLinkage {
    if name == "main" or name_in_list(exported_names, name) {
        give IrLinkage.Exported;
    }
    give IrLinkage.Internal;
}

proc ir_abi_symbol_part(text: string) -> string {
    let out: string = "";
    let i: u64 = 0;
    while i < len(text) {
        let ch: string = slice(text, i, i + 1);
        let valid: bool = (ch >= "a" and ch <= "z")
            or (ch >= "A" and ch <= "Z")
            or (ch >= "0" and ch <= "9")
            or ch == "_";
        set out = out + if valid { ch } else { "_" };
        set i = i + 1;
    }
    give if out != "" { out } else { "unknown" };
}

proc ir_impl_method_name(item: HirItem, member: HirNominalMember) -> string {
    give "vitte_impl_" + ir_abi_symbol_part(item.name) + "_for_" + ir_abi_symbol_part(item.target_type_text) + "_" + ir_abi_symbol_part(member.name);
}

proc ir_function_abi_from_hir(items: [HirItem], function_name: string) -> string {
    let i: u64 = 0;
    while i < len(items) {
        if items[i].kind == HirItemKind.Proc and items[i].name == function_name {
            give items[i].abi;
        }
        if items[i].kind == HirItemKind.Impl {
            let j: u64 = 0;
            while j < len(items[i].members) {
                if items[i].members[j].kind == HirNominalMemberKind.ImplMethod and ir_impl_method_name(items[i], items[i].members[j]) == function_name {
                    give items[i].abi;
                }
                set j = j + 1;
            }
        }
        set i = i + 1;
    }
    give "Vitte";
}

proc ir_function_is_external_from_hir(items: [HirItem], function_name: string) -> bool {
    let i: u64 = 0;
    while i < len(items) {
        if items[i].kind == HirItemKind.Proc and items[i].name == function_name {
            give items[i].abi != "" and items[i].abi != "Vitte" and len(items[i].stmts) == 0;
        }
        set i = i + 1;
    }
    give false;
}

proc ir_value_from_operand(id: u64, operand: MirOperand) -> IrValue {
    if operand.place.valid {
        let place_text: string = operand.place.local + operand.place.projection;
        give value_place(id, operand.place.local, place_text, operand.ty);
    }
    if operand.text != "" {
        give value_constant(id, operand.text, operand.ty);
    }
    give value_constant(id, "<invalid>", operand.ty);
}

proc operand_is_borrowed_param(fn0: MirFunction, operand: MirOperand) -> bool {
    if not operand.place.valid or operand.place.local == "" {
        give false;
    }
    let i: u64 = 0;
    while i < len(fn0.params) {
        if fn0.params[i].name == operand.place.local and fn0.params[i].borrowed {
            give true;
        }
        set i = i + 1;
    }
    give false;
}

proc ir_call_arg_value_from_operand(id: u64, operand: MirOperand, borrowed: bool, mutable: bool, fn0: MirFunction) -> IrValue {
    if borrowed and operand.place.valid and operand.place.local != "" {
        let place_text: string = operand.place.local + operand.place.projection;
        if operand_is_borrowed_param(fn0, operand) {
            give value_reference(id, operand.place.local, place_text, operand.ty, mutable, true);
        }
        give value_reference(id, operand.place.local, place_text, operand.ty, mutable, false);
    }
    give ir_value_from_operand(id, operand);
}

proc ir_instruction_kind_from_rvalue(rvalue: MirRvalue) -> IrInstructionKind {
    if rvalue.kind == MirRvalueKind.Binary {
        give IrInstructionKind.Binary;
    }
    if rvalue.kind == MirRvalueKind.BorrowShared {
        give IrInstructionKind.BorrowShared;
    }
    if rvalue.kind == MirRvalueKind.BorrowMut {
        give IrInstructionKind.BorrowMut;
    }
    if rvalue.kind == MirRvalueKind.Call {
        give IrInstructionKind.Call;
    }
    if rvalue.kind == MirRvalueKind.Aggregate or rvalue.kind == MirRvalueKind.Tuple or rvalue.kind == MirRvalueKind.Array or rvalue.kind == MirRvalueKind.Struct {
        give IrInstructionKind.Aggregate;
    }
    if rvalue.kind == MirRvalueKind.Discriminant {
        give IrInstructionKind.Discriminant;
    }
    give IrInstructionKind.Assign;
}

proc call_target_name(rvalue: MirRvalue) -> string {
    if rvalue.operator == "variant-ctor" or rvalue.operator == "method-dispatch" {
        give rvalue.text;
    }
    let open0: int = find(rvalue.text, "(");
    if open0 > 0 {
        give trim(slice(rvalue.text, 0, open0));
    }
    if len(rvalue.operands) > 0 and rvalue.operands[0].place.valid and rvalue.operands[0].place.local != "" {
        give rvalue.operands[0].place.local;
    }
    if len(rvalue.operands) > 0 and rvalue.operands[0].text != "" {
        give rvalue.operands[0].text;
    }
    give rvalue.text;
}

proc call_arg_start_index(rvalue: MirRvalue) -> u64 {
    if rvalue.operator == "variant-ctor" or rvalue.operator == "method-dispatch" {
        give 0;
    }
    if len(rvalue.operands) > 0 {
        give 1;
    }
    give 0;
}

proc mir_function_params_by_name(functions: [MirFunction], name: string) -> [IrFunctionParam] {
    let out: [IrFunctionParam] = [];
    let i: u64 = 0;
    while i < len(functions) {
        if functions[i].name == name {
            let j: u64 = 0;
            while j < len(functions[i].params) {
                set out = out + [ir_function_param(functions[i].params[j].name, functions[i].params[j].type_name, functions[i].params[j].mode, functions[i].params[j].mutable, functions[i].params[j].borrowed, functions[i].params[j].variadic, functions[i].params[j].valid)];
                set j = j + 1;
            }
            give out;
        }
        set i = i + 1;
    }
    give out;
}

proc call_arg_start_for_rvalue(rvalue: MirRvalue) -> u64 {
    give call_arg_start_index(rvalue);
}

proc ir_param_borrowed(params0: [IrFunctionParam], index: u64) -> bool {
    let param_index: u64 = 0;
    let i: u64 = 0;
    while i < len(params0) {
        if not params0[i].variadic {
            if param_index == index {
                give params0[i].borrowed;
            }
            set param_index = param_index + 1;
        }
        set i = i + 1;
    }
    give false;
}

proc ir_param_mutable(params0: [IrFunctionParam], index: u64) -> bool {
    let param_index: u64 = 0;
    let i: u64 = 0;
    while i < len(params0) {
        if not params0[i].variadic {
            if param_index == index {
                give params0[i].mutable;
            }
            set param_index = param_index + 1;
        }
        set i = i + 1;
    }
    give false;
}

proc call_param_borrowed_for_rvalue(rvalue: MirRvalue, functions: [MirFunction], arg_index: u64) -> bool {
    let target: string = call_target_name(rvalue);
    give ir_param_borrowed(mir_function_params_by_name(functions, target), arg_index);
}

proc call_param_mutable_for_rvalue(rvalue: MirRvalue, functions: [MirFunction], arg_index: u64) -> bool {
    let target: string = call_target_name(rvalue);
    give ir_param_mutable(mir_function_params_by_name(functions, target), arg_index);
}

proc ir_args_from_rvalue(statement_id: u64, rvalue: MirRvalue, call_arg_start: u64, functions: [MirFunction], fn0: MirFunction) -> [IrValue] {
    let args: [IrValue] = [];
    let i: u64 = 0;
    while i < len(rvalue.operands) {
        let arg_index: u64 = if i >= call_arg_start { i - call_arg_start } else { 0 };
        let borrowed: bool = i >= call_arg_start and call_param_borrowed_for_rvalue(rvalue, functions, arg_index);
        let mutable: bool = i >= call_arg_start and call_param_mutable_for_rvalue(rvalue, functions, arg_index);
        set args = args + [ir_call_arg_value_from_operand(statement_id + i + 1, rvalue.operands[i], borrowed, mutable, fn0)];
        set i = i + 1;
    }
    let aggregate: bool = rvalue.kind == MirRvalueKind.Aggregate or rvalue.kind == MirRvalueKind.Tuple or rvalue.kind == MirRvalueKind.Array or rvalue.kind == MirRvalueKind.Struct;
    if len(args) == 0 and rvalue.text != "" and not aggregate {
        set args = [value_constant(statement_id + 1, rvalue.text, "unknown")];
    }
    give args;
}

proc ir_instruction_from_mir(statement: MirStatement, functions: [MirFunction], fn0: MirFunction) -> IrInstruction {
    let call_arg_start: u64 = if statement.rvalue.kind == MirRvalueKind.Call { call_arg_start_for_rvalue(statement.rvalue) } else { 0 };
    let args: [IrValue] = ir_args_from_rvalue(statement.id, statement.rvalue, call_arg_start, functions, fn0);
    if statement.kind == MirStatementKind.Return {
        give instruction_create(
            statement.id,
            IrInstructionKind.ReturnValue,
            statement.rvalue.text,
            statement.rvalue.operator,
            value_place(statement.id, "__return", "__return", statement.rvalue.ty),
            args,
            statement.span
        );
    }
    if statement.kind == MirStatementKind.Assert {
        give instruction_create(
            statement.id,
            IrInstructionKind.Assert,
            statement.rvalue.text,
            statement.rvalue.operator,
            value_constant(statement.id, "assert", statement.rvalue.ty),
            args,
            statement.span
        );
    }
    let place_text: string = statement.place.local + statement.place.projection;
    let instruction0: IrInstruction = instruction_create(
        statement.id,
        ir_instruction_kind_from_rvalue(statement.rvalue),
        statement.rvalue.text,
        statement.rvalue.operator,
        value_place(statement.id, statement.place.local, place_text, statement.rvalue.ty),
        args,
        statement.span
    );
    if statement.rvalue.kind == MirRvalueKind.Call {
        give instruction_with_call_abi(instruction0, call_arg_start);
    }
    give instruction0;
}

proc borrow_instruction_id(statement_id: u64, arg_index: u64) -> u64 {
    give statement_id * 100 + arg_index + 1;
}

proc borrow_instruction_for_call_arg(statement: MirStatement, arg_index: u64, arg_value: IrValue) -> IrInstruction {
    let source: IrValue = ir_value_from_operand(borrow_instruction_id(statement.id, arg_index), statement.rvalue.operands[arg_index]);
    let kind: IrInstructionKind = if arg_value.ref_mutable { IrInstructionKind.BorrowMut } else { IrInstructionKind.BorrowShared };
    give instruction_create(
        borrow_instruction_id(statement.id, arg_index),
        kind,
        source.text,
        "",
        arg_value,
        [source],
        statement.span
    );
}

proc return_rvalue_requires_materialization(rvalue: MirRvalue) -> bool {
    give rvalue.kind != MirRvalueKind.Use and rvalue.kind != MirRvalueKind.Copy and rvalue.kind != MirRvalueKind.Move;
}

proc materialized_return_instruction(statement: MirStatement, functions: [MirFunction], fn0: MirFunction) -> IrInstruction {
    let call_arg_start: u64 = if statement.rvalue.kind == MirRvalueKind.Call { call_arg_start_for_rvalue(statement.rvalue) } else { 0 };
    let args: [IrValue] = ir_args_from_rvalue(statement.id, statement.rvalue, call_arg_start, functions, fn0);
    let temp_name: string = "__return_value_" + string(statement.id);
    let instruction0: IrInstruction = instruction_create(
        statement.id,
        ir_instruction_kind_from_rvalue(statement.rvalue),
        statement.rvalue.text,
        statement.rvalue.operator,
        value_place(statement.id, temp_name, temp_name, statement.rvalue.ty),
        args,
        statement.span
    );
    if statement.rvalue.kind == MirRvalueKind.Call {
        give instruction_with_call_abi(instruction0, call_arg_start);
    }
    give instruction0;
}

proc return_instruction_from_value(statement: MirStatement, value: IrValue) -> IrInstruction {
    give instruction_create(
        statement.id * 1000 + 999,
        IrInstructionKind.ReturnValue,
        value.text,
        "",
        value_place(statement.id, "__return", "__return", statement.rvalue.ty),
        [value],
        statement.span
    );
}

proc ir_terminator_from_mir(term: MirTerminator) -> IrInstruction {
    if term.kind == MirTerminatorKind.Goto {
        give terminator_jump(term.target_block);
    }
    if term.kind == MirTerminatorKind.Branch {
        give terminator_branch(ir_value_from_operand(0, term.condition), term.target_block, term.else_block);
    }
    if term.kind == MirTerminatorKind.Switch {
        give terminator_switch(ir_value_from_operand(0, term.condition), term.switch_values, term.switch_targets, term.else_block);
    }
    give terminator_return();
}

proc lower_mir_block(block: MirBlock, fn0: MirFunction, functions: [MirFunction]) -> IrBlock {
    let block_id_text: string = block.id as string;
    let block_name: string = fn0.name + "_bb" + block_id_text;
    let ir_block: IrBlock = block_create(block.id, block_name);
    let i: u64 = 0;
    let built: IrBlock = ir_block;
    while i < len(block.statements) {
        if block.statements[i].kind == MirStatementKind.Return and return_rvalue_requires_materialization(block.statements[i].rvalue) {
            let materialized: IrInstruction = materialized_return_instruction(block.statements[i], functions, fn0);
            if materialized.kind == IrInstructionKind.Call {
                let j: u64 = materialized.call_arg_start;
                while j < len(materialized.args) {
                    if materialized.args[j].kind == IrValueKind.Reference {
                        set built = block_add_instruction(built, borrow_instruction_for_call_arg(block.statements[i], j, materialized.args[j]));
                    }
                    set j = j + 1;
                }
            }
            set built = block_add_instruction(built, materialized);
            set built = block_add_instruction(built, return_instruction_from_value(block.statements[i], materialized.dest));
            set i = i + 1;
            continue;
        }
        let instruction0: IrInstruction = ir_instruction_from_mir(block.statements[i], functions, fn0);
        if instruction0.kind == IrInstructionKind.Call {
            let j: u64 = instruction0.call_arg_start;
            while j < len(instruction0.args) {
                if instruction0.args[j].kind == IrValueKind.Reference {
                    set built = block_add_instruction(built, borrow_instruction_for_call_arg(block.statements[i], j, instruction0.args[j]));
                }
                set j = j + 1;
            }
        }
        set built = block_add_instruction(built, instruction0);
        set i = i + 1;
    }
    give block_set_terminator(built, ir_terminator_from_mir(block.terminator));
}

proc lower_mir_function(module_name: string, fn0: MirFunction, functions: [MirFunction], typed_hir_items: [HirItem], exported_names: [string]) -> IrFunction {
    let external: bool = ir_function_is_external_from_hir(typed_hir_items, fn0.name);
    let lowered: IrFunction = function_with_abi(function_ref_create(
        fn0.id,
        fn0.name,
        module_name,
        if external { IrLinkage.External } else { ir_linkage_for_exports(fn0.name, exported_names) },
        if external { IrVisibility.Public } else { ir_visibility_for_exports(fn0.name, exported_names) },
        fn0.name == "main" and not external,
        span_empty()
    ), ir_function_abi_from_hir(typed_hir_items, fn0.name));
    let params: [IrFunctionParam] = [];
    let j: u64 = 0;
    while j < len(fn0.params) {
        set params = params + [ir_function_param(
          fn0.params[j].name,
          fn0.params[j].type_name,
          fn0.params[j].mode,
          fn0.params[j].mutable,
          fn0.params[j].borrowed,
          fn0.params[j].variadic,
          fn0.params[j].valid
        )];
        set j = j + 1;
    }
    let with_sig: IrFunction = IrFunction {
        id: lowered.id,
        name: lowered.name,
        module_name: lowered.module_name,
        linkage: lowered.linkage,
        visibility: lowered.visibility,
        is_entry: lowered.is_entry,
        abi: lowered.abi,
        span: lowered.span,
        params: params,
        return_type: fn0.return_type,
        blocks: lowered.blocks,
        valid: lowered.valid
    };
    let i: u64 = 0;
    let built: IrFunction = with_sig;
    while i < len(fn0.blocks) {
        set built = function_add_block(built, lower_mir_block(fn0.blocks[i], fn0, functions));
        set i = i + 1;
    }
    give built;
}

proc hir_item_is_nominal(item: HirItem) -> bool {
    give item.kind == HirItemKind.Form
        or item.kind == HirItemKind.Class
        or item.kind == HirItemKind.Union
        or item.kind == HirItemKind.Bits
        or item.kind == HirItemKind.Pick
        or item.kind == HirItemKind.Flags
        or item.kind == HirItemKind.Trait
        or item.kind == HirItemKind.Impl;
}

proc nominal_kind_name(kind: HirItemKind) -> string {
    if kind == HirItemKind.Form {
        give "form";
    }
    if kind == HirItemKind.Class {
        give "class";
    }
    if kind == HirItemKind.Union {
        give "union";
    }
    if kind == HirItemKind.Bits {
        give "bits";
    }
    if kind == HirItemKind.Pick {
        give "pick";
    }
    if kind == HirItemKind.Flags {
        give "flags";
    }
    if kind == HirItemKind.Trait {
        give "trait";
    }
    if kind == HirItemKind.Impl {
        give "impl";
    }
    give "item";
}

proc nominal_member_kind_name(kind: HirNominalMemberKind) -> string {
    if kind == HirNominalMemberKind.Field {
        give "field";
    }
    if kind == HirNominalMemberKind.Variant {
        give "variant";
    }
    if kind == HirNominalMemberKind.TraitMethod {
        give "trait-method";
    }
    if kind == HirNominalMemberKind.ImplMethod {
        give "impl-method";
    }
    give "member";
}

proc member_signature_text(params: [HirProcParam], return_type: string, drop_self: bool) -> string {
    let parts: [string] = [];
    let start_index: u64 = if drop_self and len(params) > 0 { 1 } else { 0 };
    let i: u64 = start_index;
    while i < len(params) {
        set parts = parts + [if params[i].annotation_text != "" { params[i].annotation_text } else { "opaque" }];
        set i = i + 1;
    }
    give "fn(" + join(parts, ", ") + ") -> " + if return_type != "" { return_type } else { "unit" };
}

proc nominal_member_type(item: HirItem, member: HirNominalMember) -> string {
    if member.kind == HirNominalMemberKind.Field {
        give if member.annotation_text != "" { member.annotation_text } else { "opaque" };
    }
    if member.kind == HirNominalMemberKind.Variant {
        if item.kind == HirItemKind.Bits or item.kind == HirItemKind.Flags {
            give if item.annotation_text != "" { item.annotation_text } else { item.name };
        }
        if member.annotation_text != "" {
            give "fn(" + member.annotation_text + ") -> " + item.name;
        }
        give item.name;
    }
    give member_signature_text(member.params, member.annotation_text, true);
}

proc nominal_member_names(members: [HirNominalMember]) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(members) {
        set out = out + [members[i].name];
        set i = i + 1;
    }
    give out;
}

proc nominal_member_kinds(members: [HirNominalMember]) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(members) {
        set out = out + [nominal_member_kind_name(members[i].kind)];
        set i = i + 1;
    }
    give out;
}

proc nominal_member_types(item: HirItem) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(item.members) {
        set out = out + [nominal_member_type(item, item.members[i])];
        set i = i + 1;
  }
  give out;
}

proc nominal_member_annotations(item: HirItem) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(item.members) {
        set out = out + [item.members[i].annotation_text];
        set i = i + 1;
    }
    give out;
}

proc nominal_member_param_names(item: HirItem) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(item.members) {
        let names: [string] = [];
        let j: u64 = 0;
        while j < len(item.members[i].params) {
            if item.members[i].params[j].name != "" {
                set names = names + [item.members[i].params[j].name];
            }
            set j = j + 1;
        }
        set out = out + [join(names, "|")];
        set i = i + 1;
    }
    give out;
}

proc nominal_member_param_types(item: HirItem) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(item.members) {
        let types0: [string] = [];
        let j: u64 = 0;
        while j < len(item.members[i].params) {
            set types0 = types0 + [if item.members[i].params[j].annotation_text != "" { item.members[i].params[j].annotation_text } else { "opaque" }];
            set j = j + 1;
        }
        set out = out + [join(types0, "|")];
        set i = i + 1;
    }
    give out;
}

proc nominal_member_param_modes(item: HirItem) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(item.members) {
        let modes: [string] = [];
        let j: u64 = 0;
        while j < len(item.members[i].params) {
            set modes = modes + [item.members[i].params[j].mode];
            set j = j + 1;
        }
        set out = out + [join(modes, "|")];
        set i = i + 1;
    }
    give out;
}

proc nominal_member_param_flags(item: HirItem, which: string) -> [string] {
    let out: [string] = [];
    let i: u64 = 0;
    while i < len(item.members) {
        let flags: [string] = [];
        let j: u64 = 0;
        while j < len(item.members[i].params) {
            if which == "mutable" {
                set flags = flags + [item.members[i].params[j].mutable as string];
            } elif which == "borrowed" {
                set flags = flags + [item.members[i].params[j].borrowed as string];
            } else {
                set flags = flags + [item.members[i].params[j].variadic as string];
            }
            set j = j + 1;
        }
        set out = out + [join(flags, "|")];
        set i = i + 1;
    }
    give out;
}

proc nominal_type_from_hir_item(item: HirItem) -> IrNominalType {
    let underlying_type: string = if item.kind == HirItemKind.Bits or item.kind == HirItemKind.Flags { item.annotation_text } else { "" };
    let target_type: string = if item.kind == HirItemKind.Impl { item.target_type_text } else { "" };
    give nominal_type_create(
        item.name,
        nominal_kind_name(item.kind),
        item.abi,
        underlying_type,
        target_type,
        item.generic_count,
        item.member_count,
        item.signature_param_count,
        nominal_member_names(item.members),
        nominal_member_kinds(item.members),
        nominal_member_annotations(item),
        nominal_member_types(item),
        nominal_member_param_names(item),
        nominal_member_param_types(item),
        nominal_member_param_modes(item),
        nominal_member_param_flags(item, "mutable"),
        nominal_member_param_flags(item, "borrowed"),
        nominal_member_param_flags(item, "variadic"),
        item.exported
    );
}

proc lower_mir_as_ir_module(module_id: u64, module_name: string, source_path: string, kind: IrModuleKind, target: IrTarget, mir: MirUnit, typed_hir_items: [HirItem], exported_names: [string], imported_names: [string], external_symbol_names: [string]) -> IrModule {
    let module0: IrModule = module_create(
        module_id,
        module_name,
        source_path,
        kind,
        target
    );
    let i: u64 = 0;
    let built: IrModule = module0;
    while i < len(imported_names) {
        set built = module_add_import(built, imported_names[i]);
        set i = i + 1;
    }
    set i = 0;
    while i < len(typed_hir_items) {
        if hir_item_is_nominal(typed_hir_items[i]) {
            set built = module_add_nominal_type(built, nominal_type_from_hir_item(typed_hir_items[i]));
        }
        set i = i + 1;
    }
    set i = 0;
    while i < len(mir.module.functions) {
        let lowered_fn: IrFunction = lower_mir_function(module_name, mir.module.functions[i], mir.module.functions, typed_hir_items, exported_names);
        set built = module_add_function(built, lowered_fn);
        if lowered_fn.linkage == IrLinkage.External or lowered_fn.linkage == IrLinkage.Imported {
            set built = module_add_external_symbol(built, lowered_fn.name);
        }
        set i = i + 1;
    }
    set i = 0;
    while i < len(external_symbol_names) {
        set built = module_add_external_symbol(built, external_symbol_names[i]);
        set i = i + 1;
    }
    set i = 0;
    while i < len(exported_names) {
        set built = module_add_export(built, exported_names[i]);
        set i = i + 1;
    }
    give built;
}

proc lower_mir_to_ir_for_target(mir: MirUnit, analysis: AnalysisOutput, target: IrTarget) -> IrUnit {
    let unit0: IrUnit = unit_with_source_path(unit_empty(target), analysis.source_path);

    if not mir.valid or not analysis.valid or not target.valid {
        give unit_with_state(unit0, IrUnitState.Invalid);
    }

    let module0: IrModule = lower_mir_as_ir_module(
        1,
        "main",
        analysis.source_path,
        IrModuleKind.Binary,
        target,
        mir,
        analysis.typed_hir.module.items,
        [],
        [],
        []
    );

    let i: u64 = 0;
    let entry_function_id: u64 = 0;
    while i < len(module0.functions) {
        let lowered: IrFunction = module0.functions[i];
        if lowered.is_entry and entry_function_id == 0 {
            set entry_function_id = lowered.id;
        }
        set i = i + 1;
    }

    let entry_id: u64 = mir.module.functions[0].id;
    if entry_function_id > 0 {
        set entry_id = entry_function_id;
    }
    let unit1: IrUnit = unit_add_module(unit0, module0);
    let unit2: IrUnit = unit_set_entry(unit1, entry_id);

    give unit_with_state(unit2, IrUnitState.Lowered);
}

proc lower_mir_to_ir(mir: MirUnit, analysis: AnalysisOutput) -> IrUnit {
    give lower_mir_to_ir_for_target(mir, analysis, target_native_x86_64_linux());
}
