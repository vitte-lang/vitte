space vitte/compiler/ast/arena/node_pool

use vitte/compiler/arena/api
use vitte/compiler/arena/contracts
use vitte/compiler/arena/diagnostics
use vitte/compiler/arena/manifest
use vitte/compiler/arena/metrics
use vitte/compiler/arena/pipeline
use vitte/compiler/ast/arena/ast_arena
use vitte/compiler/ast/arena/interning

const AST_NODE_POOL_VERSION: string = "0.1.0"
const AST_NODE_POOL_MAGIC: u32 = 0x41534E50
const AST_NODE_INVALID_ID: u32 = 0xffffffff
const AST_NODE_ROOT_PARENT: u32 = 0xffffffff

type AstNodeId = u32
type AstNodeGeneration = u32
type AstNodeDepth = usize

pick AstNodePoolStatus {
  Empty
  Alive
  Detached
  Tombstone
}

form AstNodeHandle {
  id: AstNodeId
  generation: AstNodeGeneration
  kind: AstArenaNodeKind
}

form AstNodeRecord {
  id: AstNodeId
  generation: AstNodeGeneration
  kind: AstArenaNodeKind
  status: AstNodePoolStatus
  name: AstInternHandle
  payload: ArenaHandle
  parent: AstNodeId
  first_child: AstNodeId
  last_child: AstNodeId
  prev_sibling: AstNodeId
  next_sibling: AstNodeId
  child_count: u32
  byte_size: usize
  flags: u64
}

form AstNodeKindIndex {
  kind: AstArenaNodeKind
  nodes: [AstNodeId]
}

form AstNodeNameIndex {
  hash: AstInternHash
  text: string
  nodes: [AstNodeId]
}

form AstNodePoolSnapshot {
  id: u32
  name: string
  node_count: usize
  free_count: usize
  arena_snapshot: ArenaSnapshot
}

form AstNodePoolStats {
  node_count: u32
  alive_count: u32
  detached_count: u32
  tombstone_count: u32
  free_count: u32
  root_count: u32
  edge_count: u32
  max_depth: usize
  total_payload_bytes: usize
  largest_payload: usize
}

form AstNodePool {
  magic: u32
  name: string
  arena: Arena
  interns: AstInternPool
  nodes: [AstNodeRecord]
  free_list: [AstNodeId]
  kind_indexes: [AstNodeKindIndex]
  name_indexes: [AstNodeNameIndex]
  snapshots: [AstNodePoolSnapshot]
  root: AstNodeId
  generation_counter: AstNodeGeneration
  sealed: bool
}

form AstNodeAllocResult {
  pool: AstNodePool
  handle: AstNodeHandle
}

form AstNodeSnapshotResult {
  pool: AstNodePool
  snapshot: AstNodePoolSnapshot
}

proc ast_node_pool_status_to_string(status: AstNodePoolStatus) -> string {
  select status {
    when AstNodePoolStatus::Empty { give "empty" }
    when AstNodePoolStatus::Alive { give "alive" }
    when AstNodePoolStatus::Detached { give "detached" }
    when AstNodePoolStatus::Tombstone { give "tombstone" }
    otherwise { give "unknown" }
  }
}

proc ast_node_invalid_handle() -> AstNodeHandle {
  give AstNodeHandle {
    id: AST_NODE_INVALID_ID,
    generation: 0,
    kind: AstArenaNodeKind::Empty
  }
}

proc ast_node_handle_is_valid(handle: AstNodeHandle) -> bool {
  give handle.id != AST_NODE_INVALID_ID
    && handle.kind != AstArenaNodeKind::Empty
}

proc ast_node_record_empty(id: AstNodeId) -> AstNodeRecord {
  give AstNodeRecord {
    id: id,
    generation: 0,
    kind: AstArenaNodeKind::Empty,
    status: AstNodePoolStatus::Empty,
    name: ast_intern_invalid_handle(),
    payload: arena_invalid_handle(),
    parent: AST_NODE_INVALID_ID,
    first_child: AST_NODE_INVALID_ID,
    last_child: AST_NODE_INVALID_ID,
    prev_sibling: AST_NODE_INVALID_ID,
    next_sibling: AST_NODE_INVALID_ID,
    child_count: 0,
    byte_size: 0,
    flags: 0
  }
}

proc ast_node_make_handle(node: AstNodeRecord) -> AstNodeHandle {
  give AstNodeHandle {
    id: node.id,
    generation: node.generation,
    kind: node.kind
  }
}

proc ast_node_pool_new(name: string) -> AstNodePool {
  let config: ArenaConfig =
    arena_config_new(
      ArenaKind::Ast,
      32768,
      8
    )

  give AstNodePool {
    magic: AST_NODE_POOL_MAGIC,
    name: name,
    arena: arena_with_config(name + "_nodes", config),
    interns: ast_intern_bootstrap(ast_intern_pool_new(name + "_interns")),
    nodes: [],
    free_list: [],
    kind_indexes: [],
    name_indexes: [],
    snapshots: [],
    root: AST_NODE_INVALID_ID,
    generation_counter: 1,
    sealed: false
  }
}

proc ast_node_pool_is_valid(pool: AstNodePool) -> bool {
  give pool.magic == AST_NODE_POOL_MAGIC
    && arena_validate(pool.arena)
    && ast_intern_validate(pool.interns)
}

proc ast_node_pool_is_empty(pool: AstNodePool) -> bool {
  give pool.nodes.len == 0
}

proc ast_node_pool_is_sealed(pool: AstNodePool) -> bool {
  give pool.sealed
}

proc ast_node_pool_count(pool: AstNodePool) -> u32 {
  give pool.nodes.len as u32
}

proc ast_node_pool_has_id(pool: AstNodePool, id: AstNodeId) -> bool {
  give id < pool.nodes.len as u32
}

proc ast_node_pool_get(pool: AstNodePool, handle: AstNodeHandle) -> AstNodeRecord {
  if !ast_node_handle_is_valid(handle) {
    give ast_node_record_empty(AST_NODE_INVALID_ID)
  }

  if !ast_node_pool_has_id(pool, handle.id) {
    give ast_node_record_empty(AST_NODE_INVALID_ID)
  }

  let node: AstNodeRecord = pool.nodes[handle.id as usize]

  if node.generation != handle.generation {
    give ast_node_record_empty(AST_NODE_INVALID_ID)
  }

  if node.kind != handle.kind {
    give ast_node_record_empty(AST_NODE_INVALID_ID)
  }

  give node
}

proc ast_node_pool_handle_alive(pool: AstNodePool, handle: AstNodeHandle) -> bool {
  let node: AstNodeRecord = ast_node_pool_get(pool, handle)

  give node.id != AST_NODE_INVALID_ID
    && node.status == AstNodePoolStatus::Alive
}

proc ast_node_pool_next_generation(pool: AstNodePool) -> AstNodeGeneration {
  if pool.generation_counter == 0 {
    give 1
  }

  give pool.generation_counter
}

proc ast_node_pool_bump_generation(pool: AstNodePool) -> AstNodePool {
  let next: AstNodePool = pool

  set next.generation_counter = next.generation_counter + 1

  if next.generation_counter == 0 {
    set next.generation_counter = 1
  }

  give next
}

proc ast_node_pool_take_free_id(pool: AstNodePool) -> AstNodeId {
  if pool.free_list.len == 0 {
    give pool.nodes.len as AstNodeId
  }

  give pool.free_list[pool.free_list.len - 1]
}

proc ast_node_pool_pop_free(pool: AstNodePool) -> AstNodePool {
  let next: AstNodePool = pool

  if next.free_list.len == 0 {
    give next
  }

  let out: [AstNodeId] = []
  let i: usize = 0

  while i + 1 < next.free_list.len {
    set out = out + [next.free_list[i]]
    set i = i + 1
  }

  set next.free_list = out

  give next
}

proc ast_node_kind_index_find(pool: AstNodePool, kind: AstArenaNodeKind) -> usize {
  let i: usize = 0

  while i < pool.kind_indexes.len {
    if pool.kind_indexes[i].kind == kind {
      give i
    }

    set i = i + 1
  }

  give pool.kind_indexes.len
}

proc ast_node_kind_index_add(pool: AstNodePool, kind: AstArenaNodeKind, id: AstNodeId) -> AstNodePool {
  let next: AstNodePool = pool
  let index: usize = ast_node_kind_index_find(next, kind)

  if index >= next.kind_indexes.len {
    set next.kind_indexes = next.kind_indexes + [
      AstNodeKindIndex {
        kind: kind,
        nodes: [id]
      }
    ]

    give next
  }

  set next.kind_indexes[index].nodes =
    next.kind_indexes[index].nodes + [id]

  give next
}

proc ast_node_name_index_find(pool: AstNodePool, hash: AstInternHash, text: string) -> usize {
  let i: usize = 0

  while i < pool.name_indexes.len {
    if pool.name_indexes[i].hash == hash && pool.name_indexes[i].text == text {
      give i
    }

    set i = i + 1
  }

  give pool.name_indexes.len
}

proc ast_node_name_index_add(
  pool: AstNodePool,
  name: AstInternHandle,
  text: string,
  id: AstNodeId
) -> AstNodePool {
  let next: AstNodePool = pool

  if !ast_intern_handle_is_valid(name) {
    give next
  }

  let index: usize = ast_node_name_index_find(next, name.hash, text)

  if index >= next.name_indexes.len {
    set next.name_indexes = next.name_indexes + [
      AstNodeNameIndex {
        hash: name.hash,
        text: text,
        nodes: [id]
      }
    ]

    give next
  }

  set next.name_indexes[index].nodes =
    next.name_indexes[index].nodes + [id]

  give next
}

proc ast_node_pool_index_node(pool: AstNodePool, node: AstNodeRecord) -> AstNodePool {
  let next: AstNodePool = pool

  set next = ast_node_kind_index_add(next, node.kind, node.id)

  if ast_intern_handle_is_valid(node.name) {
    let text: string = ast_intern_read(next.interns, node.name)
    set next = ast_node_name_index_add(next, node.name, text, node.id)
  }

  give next
}

proc ast_node_id_list_remove(list: [AstNodeId], id: AstNodeId) -> [AstNodeId] {
  let out: [AstNodeId] = []
  let i: usize = 0

  while i < list.len {
    if list[i] != id {
      set out = out + [list[i]]
    }

    set i = i + 1
  }

  give out
}

proc ast_node_pool_unindex_node(pool: AstNodePool, node: AstNodeRecord) -> AstNodePool {
  let next: AstNodePool = pool
  let kind_index: usize = ast_node_kind_index_find(next, node.kind)

  if kind_index < next.kind_indexes.len {
    set next.kind_indexes[kind_index].nodes =
      ast_node_id_list_remove(next.kind_indexes[kind_index].nodes, node.id)
  }

  if ast_intern_handle_is_valid(node.name) {
    let text: string = ast_intern_read(next.interns, node.name)
    let name_index: usize = ast_node_name_index_find(next, node.name.hash, text)

    if name_index < next.name_indexes.len {
      set next.name_indexes[name_index].nodes =
        ast_node_id_list_remove(next.name_indexes[name_index].nodes, node.id)
    }
  }

  give next
}

proc ast_node_pool_alloc_named(
  pool: AstNodePool,
  kind: AstArenaNodeKind,
  name_text: string,
  byte_size: usize,
  flags: u64
) -> AstNodeAllocResult {
  if pool.sealed {
    give AstNodeAllocResult {
      pool: pool,
      handle: ast_node_invalid_handle()
    }
  }

  if kind == AstArenaNodeKind::Empty {
    give AstNodeAllocResult {
      pool: pool,
      handle: ast_node_invalid_handle()
    }
  }

  let next: AstNodePool = pool
  let intern_result: AstInternResult =
    ast_intern_insert(next.interns, AstInternKind::Identifier, name_text)

  set next.interns = intern_result.pool

  let alloc_result: ArenaAllocResult =
    arena_alloc_node(
      next.arena,
      "ast/node/"
        + ast_arena_node_kind_to_string(kind)
        + "/"
        + name_text,
      byte_size
    )

  set next.arena = alloc_result.arena

  let id: AstNodeId = ast_node_pool_take_free_id(next)
  let generation: AstNodeGeneration = ast_node_pool_next_generation(next)

  set next = ast_node_pool_pop_free(next)
  set next = ast_node_pool_bump_generation(next)

  let node: AstNodeRecord = AstNodeRecord {
    id: id,
    generation: generation,
    kind: kind,
    status: AstNodePoolStatus::Alive,
    name: intern_result.handle,
    payload: alloc_result.handle,
    parent: AST_NODE_INVALID_ID,
    first_child: AST_NODE_INVALID_ID,
    last_child: AST_NODE_INVALID_ID,
    prev_sibling: AST_NODE_INVALID_ID,
    next_sibling: AST_NODE_INVALID_ID,
    child_count: 0,
    byte_size: byte_size,
    flags: flags
  }

  if id == next.nodes.len as u32 {
    set next.nodes = next.nodes + [node]
  } else {
    set next.nodes[id as usize] = node
  }

  if next.root == AST_NODE_INVALID_ID {
    set next.root = id
  }

  set next = ast_node_pool_index_node(next, node)

  give AstNodeAllocResult {
    pool: next,
    handle: ast_node_make_handle(node)
  }
}

proc ast_node_pool_alloc(
  pool: AstNodePool,
  kind: AstArenaNodeKind,
  byte_size: usize
) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, kind, "", byte_size, 0)
}

proc ast_node_pool_alloc_module(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Module, name, 128, 0)
}

proc ast_node_pool_alloc_import(pool: AstNodePool, path: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Import, path, 96, 0)
}

proc ast_node_pool_alloc_export(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Export, name, 96, 0)
}

proc ast_node_pool_alloc_attribute(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Attribute, name, 64, 0)
}

proc ast_node_pool_alloc_const(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Const, name, 128, 0)
}

proc ast_node_pool_alloc_type(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Type, name, 128, 0)
}

proc ast_node_pool_alloc_form(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Form, name, 192, 0)
}

proc ast_node_pool_alloc_pick(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Pick, name, 192, 0)
}

proc ast_node_pool_alloc_proc(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Proc, name, 256, 0)
}

proc ast_node_pool_alloc_entry(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Entry, name, 192, 0)
}

proc ast_node_pool_alloc_param(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Parameter, name, 96, 0)
}

proc ast_node_pool_alloc_block(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Block, name, 96, 0)
}

proc ast_node_pool_alloc_stmt(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Statement, name, 128, 0)
}

proc ast_node_pool_alloc_expr(pool: AstNodePool, name: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Expression, name, 128, 0)
}

proc ast_node_pool_alloc_literal(pool: AstNodePool, text: string) -> AstNodeAllocResult {
  give ast_node_pool_alloc_named(pool, AstArenaNodeKind::Literal, text, 96, 0)
}

proc ast_node_pool_detach(pool: AstNodePool, handle: AstNodeHandle) -> AstNodePool {
  let next: AstNodePool = pool

  if !ast_node_pool_handle_alive(next, handle) {
    give next
  }

  let id: AstNodeId = handle.id
  let node: AstNodeRecord = next.nodes[id as usize]

  if node.parent != AST_NODE_INVALID_ID && ast_node_pool_has_id(next, node.parent) {
    let parent: AstNodeRecord = next.nodes[node.parent as usize]

    if parent.first_child == id {
      set next.nodes[node.parent as usize].first_child = node.next_sibling
    }

    if parent.last_child == id {
      set next.nodes[node.parent as usize].last_child = node.prev_sibling
    }

    if parent.child_count > 0 {
      set next.nodes[node.parent as usize].child_count = parent.child_count - 1
    }
  }

  if node.prev_sibling != AST_NODE_INVALID_ID && ast_node_pool_has_id(next, node.prev_sibling) {
    set next.nodes[node.prev_sibling as usize].next_sibling = node.next_sibling
  }

  if node.next_sibling != AST_NODE_INVALID_ID && ast_node_pool_has_id(next, node.next_sibling) {
    set next.nodes[node.next_sibling as usize].prev_sibling = node.prev_sibling
  }

  set next.nodes[id as usize].parent = AST_NODE_INVALID_ID
  set next.nodes[id as usize].prev_sibling = AST_NODE_INVALID_ID
  set next.nodes[id as usize].next_sibling = AST_NODE_INVALID_ID
  set next.nodes[id as usize].status = AstNodePoolStatus::Detached

  give next
}

proc ast_node_pool_add_child(
  pool: AstNodePool,
  parent: AstNodeHandle,
  child: AstNodeHandle
) -> AstNodePool {
  let next: AstNodePool = pool

  if !ast_node_pool_handle_alive(next, parent) {
    give next
  }

  if !ast_node_pool_handle_alive(next, child) {
    give next
  }

  if parent.id == child.id {
    give next
  }

  set next = ast_node_pool_detach(next, child)

  let p: AstNodeRecord = next.nodes[parent.id as usize]
  let c: AstNodeRecord = next.nodes[child.id as usize]

  set next.nodes[child.id as usize].parent = parent.id
  set next.nodes[child.id as usize].status = AstNodePoolStatus::Alive
  set next.nodes[child.id as usize].prev_sibling = p.last_child
  set next.nodes[child.id as usize].next_sibling = AST_NODE_INVALID_ID

  if p.last_child != AST_NODE_INVALID_ID && ast_node_pool_has_id(next, p.last_child) {
    set next.nodes[p.last_child as usize].next_sibling = child.id
  }

  if p.first_child == AST_NODE_INVALID_ID {
    set next.nodes[parent.id as usize].first_child = child.id
  }

  set next.nodes[parent.id as usize].last_child = child.id
  set next.nodes[parent.id as usize].child_count = p.child_count + 1

  give next
}

proc ast_node_pool_add_children(
  pool: AstNodePool,
  parent: AstNodeHandle,
  children: [AstNodeHandle]
) -> AstNodePool {
  let next: AstNodePool = pool
  let i: usize = 0

  while i < children.len {
    set next = ast_node_pool_add_child(next, parent, children[i])
    set i = i + 1
  }

  give next
}

proc ast_node_pool_remove_node(pool: AstNodePool, handle: AstNodeHandle) -> AstNodePool {
  let next: AstNodePool = pool

  if !ast_node_pool_handle_alive(next, handle) {
    give next
  }

  let node: AstNodeRecord = next.nodes[handle.id as usize]

  set next = ast_node_pool_detach(next, handle)
  set next = ast_node_pool_unindex_node(next, node)

  set next.nodes[handle.id as usize].status = AstNodePoolStatus::Tombstone
  set next.nodes[handle.id as usize].kind = AstArenaNodeKind::Empty
  set next.nodes[handle.id as usize].name = ast_intern_invalid_handle()
  set next.nodes[handle.id as usize].payload = arena_invalid_handle()
  set next.nodes[handle.id as usize].first_child = AST_NODE_INVALID_ID
  set next.nodes[handle.id as usize].last_child = AST_NODE_INVALID_ID
  set next.nodes[handle.id as usize].child_count = 0
  set next.nodes[handle.id as usize].byte_size = 0
  set next.nodes[handle.id as usize].flags = 0

  set next.free_list = next.free_list + [handle.id]

  if next.root == handle.id {
    set next.root = AST_NODE_INVALID_ID
  }

  give next
}

proc ast_node_pool_find_by_kind(pool: AstNodePool, kind: AstArenaNodeKind) -> [AstNodeHandle] {
  let out: [AstNodeHandle] = []
  let index: usize = ast_node_kind_index_find(pool, kind)

  if index >= pool.kind_indexes.len {
    give out
  }

  let i: usize = 0

  while i < pool.kind_indexes[index].nodes.len {
    let id: AstNodeId = pool.kind_indexes[index].nodes[i]

    if ast_node_pool_has_id(pool, id) {
      let node: AstNodeRecord = pool.nodes[id as usize]

      if node.status == AstNodePoolStatus::Alive && node.kind == kind {
        set out = out + [ast_node_make_handle(node)]
      }
    }

    set i = i + 1
  }

  give out
}

proc ast_node_pool_find_by_name(pool: AstNodePool, text: string) -> [AstNodeHandle] {
  let out: [AstNodeHandle] = []
  let hash: AstInternHash = ast_intern_hash_string(text)
  let index: usize = ast_node_name_index_find(pool, hash, text)

  if index >= pool.name_indexes.len {
    give out
  }

  let i: usize = 0

  while i < pool.name_indexes[index].nodes.len {
    let id: AstNodeId = pool.name_indexes[index].nodes[i]

    if ast_node_pool_has_id(pool, id) {
      let node: AstNodeRecord = pool.nodes[id as usize]

      if node.status == AstNodePoolStatus::Alive {
        set out = out + [ast_node_make_handle(node)]
      }
    }

    set i = i + 1
  }

  give out
}

proc ast_node_pool_first_by_name(pool: AstNodePool, text: string) -> AstNodeHandle {
  let found: [AstNodeHandle] = ast_node_pool_find_by_name(pool, text)

  if found.len == 0 {
    give ast_node_invalid_handle()
  }

  give found[0]
}

proc ast_node_pool_parent(pool: AstNodePool, handle: AstNodeHandle) -> AstNodeHandle {
  let node: AstNodeRecord = ast_node_pool_get(pool, handle)

  if node.parent == AST_NODE_INVALID_ID {
    give ast_node_invalid_handle()
  }

  if !ast_node_pool_has_id(pool, node.parent) {
    give ast_node_invalid_handle()
  }

  give ast_node_make_handle(pool.nodes[node.parent as usize])
}

proc ast_node_pool_children(pool: AstNodePool, handle: AstNodeHandle) -> [AstNodeHandle] {
  let out: [AstNodeHandle] = []
  let node: AstNodeRecord = ast_node_pool_get(pool, handle)

  if node.id == AST_NODE_INVALID_ID {
    give out
  }

  let current: AstNodeId = node.first_child

  while current != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, current) {
      give out
    }

    let child: AstNodeRecord = pool.nodes[current as usize]
    set out = out + [ast_node_make_handle(child)]
    set current = child.next_sibling
  }

  give out
}

proc ast_node_pool_depth(pool: AstNodePool, handle: AstNodeHandle) -> AstNodeDepth {
  let node: AstNodeRecord = ast_node_pool_get(pool, handle)

  if node.id == AST_NODE_INVALID_ID {
    give 0
  }

  let depth: usize = 0
  let current: AstNodeId = node.parent

  while current != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, current) {
      give depth
    }

    set depth = depth + 1
    set current = pool.nodes[current as usize].parent
  }

  give depth
}

proc ast_node_pool_subtree_size(pool: AstNodePool, handle: AstNodeHandle) -> u32 {
  let node: AstNodeRecord = ast_node_pool_get(pool, handle)

  if node.id == AST_NODE_INVALID_ID {
    give 0
  }

  let count: u32 = 1
  let current: AstNodeId = node.first_child

  while current != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, current) {
      give count
    }

    set count = count + ast_node_pool_subtree_size(pool, ast_node_make_handle(pool.nodes[current as usize]))
    set current = pool.nodes[current as usize].next_sibling
  }

  give count
}

proc ast_node_pool_snapshot(pool: AstNodePool, name: string) -> AstNodeSnapshotResult {
  let next: AstNodePool = pool
  let arena_result: ArenaSnapshotResult = arena_snapshot(next.arena, name)

  set next.arena = arena_result.arena

  let snapshot: AstNodePoolSnapshot = AstNodePoolSnapshot {
    id: next.snapshots.len as u32,
    name: name,
    node_count: next.nodes.len,
    free_count: next.free_list.len,
    arena_snapshot: arena_result.snapshot
  }

  set next.snapshots = next.snapshots + [snapshot]

  give AstNodeSnapshotResult {
    pool: next,
    snapshot: snapshot
  }
}

proc ast_node_pool_truncate_nodes(nodes: [AstNodeRecord], count: usize) -> [AstNodeRecord] {
  let out: [AstNodeRecord] = []
  let i: usize = 0

  while i < count && i < nodes.len {
    set out = out + [nodes[i]]
    set i = i + 1
  }

  give out
}

proc ast_node_pool_truncate_free(list: [AstNodeId], count: usize) -> [AstNodeId] {
  let out: [AstNodeId] = []
  let i: usize = 0

  while i < count && i < list.len {
    set out = out + [list[i]]
    set i = i + 1
  }

  give out
}

proc ast_node_pool_rebuild_indexes(pool: AstNodePool) -> AstNodePool {
  let next: AstNodePool = pool

  set next.kind_indexes = []
  set next.name_indexes = []

  let i: usize = 0

  while i < next.nodes.len {
    let node: AstNodeRecord = next.nodes[i]

    if node.status == AstNodePoolStatus::Alive {
      set next = ast_node_pool_index_node(next, node)
    }

    set i = i + 1
  }

  give next
}

proc ast_node_pool_restore_snapshot(pool: AstNodePool, snapshot_id: u32) -> AstNodePool {
  if snapshot_id >= pool.snapshots.len as u32 {
    give pool
  }

  let next: AstNodePool = pool
  let snapshot: AstNodePoolSnapshot = next.snapshots[snapshot_id as usize]

  set next.nodes = ast_node_pool_truncate_nodes(next.nodes, snapshot.node_count)
  set next.free_list = ast_node_pool_truncate_free(next.free_list, snapshot.free_count)
  set next.arena = arena_restore(next.arena, snapshot.arena_snapshot)
  set next = ast_node_pool_rebuild_indexes(next)

  if next.root >= next.nodes.len as u32 {
    set next.root = AST_NODE_INVALID_ID
  }

  give next
}

proc ast_node_pool_seal(pool: AstNodePool) -> AstNodePool {
  let next: AstNodePool = pool

  set next.arena = arena_seal(next.arena)
  set next.interns = ast_intern_pool_seal(next.interns)
  set next.sealed = true

  give next
}

proc ast_node_pool_clear(pool: AstNodePool) -> AstNodePool {
  let next: AstNodePool = pool

  set next.arena = arena_reset(next.arena)
  set next.interns = ast_intern_clear(next.interns)
  set next.nodes = []
  set next.free_list = []
  set next.kind_indexes = []
  set next.name_indexes = []
  set next.snapshots = []
  set next.root = AST_NODE_INVALID_ID
  set next.generation_counter = 1
  set next.sealed = false

  give next
}

proc ast_node_pool_stats(pool: AstNodePool) -> AstNodePoolStats {
  let stats: AstNodePoolStats = AstNodePoolStats {
    node_count: pool.nodes.len as u32,
    alive_count: 0,
    detached_count: 0,
    tombstone_count: 0,
    free_count: pool.free_list.len as u32,
    root_count: 0,
    edge_count: 0,
    max_depth: 0,
    total_payload_bytes: 0,
    largest_payload: 0
  }

  let i: usize = 0

  while i < pool.nodes.len {
    let node: AstNodeRecord = pool.nodes[i]

    if node.status == AstNodePoolStatus::Alive {
      set stats.alive_count = stats.alive_count + 1
      set stats.edge_count = stats.edge_count + node.child_count
      set stats.total_payload_bytes = stats.total_payload_bytes + node.byte_size

      if node.byte_size > stats.largest_payload {
        set stats.largest_payload = node.byte_size
      }

      if node.parent == AST_NODE_INVALID_ID {
        set stats.root_count = stats.root_count + 1
      }

      let depth: usize = ast_node_pool_depth(pool, ast_node_make_handle(node))

      if depth > stats.max_depth {
        set stats.max_depth = depth
      }
    }

    if node.status == AstNodePoolStatus::Detached {
      set stats.detached_count = stats.detached_count + 1
    }

    if node.status == AstNodePoolStatus::Tombstone {
      set stats.tombstone_count = stats.tombstone_count + 1
    }

    set i = i + 1
  }

  give stats
}

proc ast_node_pool_validate_links(pool: AstNodePool, node: AstNodeRecord) -> bool {
  if node.parent != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, node.parent) {
      give false
    }

    let parent: AstNodeRecord = pool.nodes[node.parent as usize]

    if parent.status != AstNodePoolStatus::Alive {
      give false
    }
  }

  if node.prev_sibling != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, node.prev_sibling) {
      give false
    }
  }

  if node.next_sibling != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, node.next_sibling) {
      give false
    }
  }

  if node.first_child != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, node.first_child) {
      give false
    }
  }

  if node.last_child != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, node.last_child) {
      give false
    }
  }

  give true
}

proc ast_node_pool_validate_child_chain(pool: AstNodePool, node: AstNodeRecord) -> bool {
  let count: u32 = 0
  let current: AstNodeId = node.first_child
  let previous: AstNodeId = AST_NODE_INVALID_ID

  while current != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, current) {
      give false
    }

    let child: AstNodeRecord = pool.nodes[current as usize]

    if child.parent != node.id {
      give false
    }

    if child.prev_sibling != previous {
      give false
    }

    set previous = current
    set current = child.next_sibling
    set count = count + 1

    if count > pool.nodes.len as u32 {
      give false
    }
  }

  if count != node.child_count {
    give false
  }

  if count == 0 {
    if node.first_child != AST_NODE_INVALID_ID || node.last_child != AST_NODE_INVALID_ID {
      give false
    }
  } else {
    if previous != node.last_child {
      give false
    }
  }

  give true
}

proc ast_node_pool_validate_node(pool: AstNodePool, node: AstNodeRecord) -> bool {
  if node.id == AST_NODE_INVALID_ID {
    give false
  }

  if node.status == AstNodePoolStatus::Tombstone {
    give true
  }

  if node.status == AstNodePoolStatus::Empty {
    give false
  }

  if node.kind == AstArenaNodeKind::Empty {
    give false
  }

  if !ast_intern_validate_handle(pool.interns, node.name) {
    give false
  }

  if !arena_handle_belongs_to(pool.arena, node.payload) {
    give false
  }

  if !ast_node_pool_validate_links(pool, node) {
    give false
  }

  if !ast_node_pool_validate_child_chain(pool, node) {
    give false
  }

  give true
}

proc ast_node_pool_validate_indexes(pool: AstNodePool) -> bool {
  let i: usize = 0

  while i < pool.kind_indexes.len {
    let k: usize = 0

    while k < pool.kind_indexes[i].nodes.len {
      let id: AstNodeId = pool.kind_indexes[i].nodes[k]

      if !ast_node_pool_has_id(pool, id) {
        give false
      }

      let node: AstNodeRecord = pool.nodes[id as usize]

      if node.kind != pool.kind_indexes[i].kind {
        give false
      }

      set k = k + 1
    }

    set i = i + 1
  }

  let n: usize = 0

  while n < pool.name_indexes.len {
    let j: usize = 0

    while j < pool.name_indexes[n].nodes.len {
      let id: AstNodeId = pool.name_indexes[n].nodes[j]

      if !ast_node_pool_has_id(pool, id) {
        give false
      }

      let node: AstNodeRecord = pool.nodes[id as usize]
      let text: string = ast_intern_read(pool.interns, node.name)

      if node.name.hash != pool.name_indexes[n].hash || text != pool.name_indexes[n].text {
        give false
      }

      set j = j + 1
    }

    set n = n + 1
  }

  give true
}

proc ast_node_pool_validate(pool: AstNodePool) -> bool {
  if pool.magic != AST_NODE_POOL_MAGIC {
    give false
  }

  if !arena_validate(pool.arena) {
    give false
  }

  if !ast_intern_validate(pool.interns) {
    give false
  }

  let i: usize = 0

  while i < pool.nodes.len {
    if pool.nodes[i].id != i as u32 {
      give false
    }

    if !ast_node_pool_validate_node(pool, pool.nodes[i]) {
      give false
    }

    set i = i + 1
  }

  if !ast_node_pool_validate_indexes(pool) {
    give false
  }

  if pool.root != AST_NODE_INVALID_ID {
    if !ast_node_pool_has_id(pool, pool.root) {
      give false
    }

    if pool.nodes[pool.root as usize].status != AstNodePoolStatus::Alive {
      give false
    }
  }

  give true
}

proc ast_node_pool_to_ast_arena(pool: AstNodePool) -> AstArena {
  let ast: AstArena = ast_arena_new(pool.name + "_ast")
  let next: AstArena = ast

  let i: usize = 0

  while i < pool.nodes.len {
    let node: AstNodeRecord = pool.nodes[i]

    if node.status == AstNodePoolStatus::Alive {
      let name: string = ast_intern_read(pool.interns, node.name)

      set next = ast_arena_alloc_node(
        next,
        node.kind,
        name,
        node.byte_size
      )
    }

    set i = i + 1
  }

  let j: usize = 0

  while j < pool.nodes.len {
    let node: AstNodeRecord = pool.nodes[j]

    if node.status == AstNodePoolStatus::Alive && node.parent != AST_NODE_INVALID_ID {
      set next = ast_arena_add_child(next, node.parent, node.id)
    }

    set j = j + 1
  }

  give ast_arena_recompute_stats(next)
}

proc ast_node_pool_build_manifest(pool: AstNodePool) -> ArenaManifest {
  give arena_manifest_with_diagnostics(
    arena_manifest_from_arena(pool.arena)
  )
}

proc ast_node_pool_build_metrics(pool: AstNodePool) -> ArenaMetrics {
  give arena_metrics_from_arena(pool.arena)
}

proc ast_node_pool_build_diagnostics(pool: AstNodePool) -> ArenaDiagnosticReport {
  let report: ArenaDiagnosticReport =
    arena_diagnostics_check_arena(pool.arena)

  let next: ArenaDiagnosticReport = report

  if !ast_node_pool_validate(pool) {
    set next = arena_diagnostics_add(
      next,
      arena_diagnostic_new(
        ArenaDiagnosticSeverity::Error,
        ArenaDiagnosticDomain::Arena,
        "AST_NODE_POOL_INVALID",
        "invalid AST node pool",
        pool.name,
        "AST node pool validation failed"
      )
    )
  }

  give next
}

proc ast_node_pool_debug_handle(handle: AstNodeHandle) -> string {
  if !ast_node_handle_is_valid(handle) {
    give "AstNodeHandle(invalid)"
  }

  give "AstNodeHandle(id="
    + to_string(handle.id)
    + ", generation="
    + to_string(handle.generation)
    + ", kind="
    + ast_arena_node_kind_to_string(handle.kind)
    + ")"
}

proc ast_node_pool_debug_node(pool: AstNodePool, node: AstNodeRecord) -> string {
  let name: string = ""

  if ast_intern_handle_is_valid(node.name) {
    set name = ast_intern_read(pool.interns, node.name)
  }

  give "AstNodeRecord(id="
    + to_string(node.id)
    + ", gen="
    + to_string(node.generation)
    + ", kind="
    + ast_arena_node_kind_to_string(node.kind)
    + ", status="
    + ast_node_pool_status_to_string(node.status)
    + ", name="
    + name
    + ", parent="
    + to_string(node.parent)
    + ", first_child="
    + to_string(node.first_child)
    + ", last_child="
    + to_string(node.last_child)
    + ", prev="
    + to_string(node.prev_sibling)
    + ", next="
    + to_string(node.next_sibling)
    + ", children="
    + to_string(node.child_count)
    + ", bytes="
    + to_string(node.byte_size)
    + ", flags="
    + to_string(node.flags)
    + ", payload="
    + arena_debug_handle(node.payload)
    + ")"
}

proc ast_node_pool_debug_stats(stats: AstNodePoolStats) -> string {
  give "AstNodePoolStats(nodes="
    + to_string(stats.node_count)
    + ", alive="
    + to_string(stats.alive_count)
    + ", detached="
    + to_string(stats.detached_count)
    + ", tombstone="
    + to_string(stats.tombstone_count)
    + ", free="
    + to_string(stats.free_count)
    + ", roots="
    + to_string(stats.root_count)
    + ", edges="
    + to_string(stats.edge_count)
    + ", max_depth="
    + to_string(stats.max_depth)
    + ", payload_bytes="
    + to_string(stats.total_payload_bytes)
    + ", largest_payload="
    + to_string(stats.largest_payload)
    + ")"
}

proc ast_node_pool_debug_index(pool: AstNodePool) -> string {
  give "AstNodePoolIndex(kinds="
    + to_string(pool.kind_indexes.len)
    + ", names="
    + to_string(pool.name_indexes.len)
    + ", snapshots="
    + to_string(pool.snapshots.len)
    + ")"
}

proc ast_node_pool_debug(pool: AstNodePool) -> string {
  give "AstNodePool(version="
    + AST_NODE_POOL_VERSION
    + ", name="
    + pool.name
    + ", valid="
    + to_string(ast_node_pool_validate(pool))
    + ", sealed="
    + to_string(pool.sealed)
    + ", root="
    + to_string(pool.root)
    + ", generation="
    + to_string(pool.generation_counter)
    + ", "
    + ast_node_pool_debug_stats(ast_node_pool_stats(pool))
    + ", "
    + ast_node_pool_debug_index(pool)
    + ")"
}

proc ast_node_pool_dump(pool: AstNodePool) -> string {
  let text: string = ast_node_pool_debug(pool) + "\n"

  let i: usize = 0

  while i < pool.nodes.len {
    set text = text + "  " + ast_node_pool_debug_node(pool, pool.nodes[i]) + "\n"
    set i = i + 1
  }

  set text = text + ast_intern_debug(pool.interns) + "\n"
  set text = text + arena_metrics_dump(ast_node_pool_build_metrics(pool)) + "\n"
  set text = text + arena_manifest_dump(ast_node_pool_build_manifest(pool)) + "\n"

  give text
}

proc ast_node_pool_print(pool: AstNodePool) {
  emit ast_node_pool_dump(pool)
}