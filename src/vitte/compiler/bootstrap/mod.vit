space vitte/compiler/bootstrap

form BootstrapManifest {
  stage: string,
  language: string
}

proc manifest() -> BootstrapManifest {
  give BootstrapManifest {
    stage: "bootstrap-vitte",
    language: "vitte"
  }
}

proc bootstrap_stage() -> string {
  give manifest().stage
}

proc bootstrap_language() -> string {
  give manifest().language
}

proc source_of_truth(path: string) -> string {
  give path
}

export *
