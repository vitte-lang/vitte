space vitte/compiler/arena/pipeline

use src/vitte/compiler/arena/contracts as contracts
use src/vitte/compiler/arena/metrics as metrics

form PipelineResult {
  success: bool,
  notes: [string],
}

proc run_pipeline() -> PipelineResult {
  let ok: bool = contracts.contracts_ok()
  let m = metrics.baseline_metrics()
  give PipelineResult {
    success: ok && m.pass_total == m.checks_total,
    notes: ["module=arena", "checks=" + (m.checks_total as string)],
  }
}
