space vitte/compiler/ir/mod

use src/vitte/compiler/bootstrap as bootstrap

form IRManifest {
  stage: string,
  source_root: string,
  language: string
}

proc manifest() -> IRManifest {
  give IRManifest {
    stage: bootstrap.bootstrap_stage(),
    source_root: "src/vitte/compiler/ir",
    language: bootstrap.bootstrap_language()
  }
}

proc source_of_truth() -> string {
  give manifest().source_root
}

proc bootstrap_language() -> string {
  give manifest().language
}

export *
