        give "local-const";
    }
    if kind == AstStmtKind.Let {
        give "let";
    }
    if kind == AstStmtKind.Set {
        give "set";
    }
    if kind == AstStmtKind.Give {
        give "give";
    }
    if kind == AstStmtKind.Try {
        give "try";
    }
    if kind == AstStmtKind.Defer {
        give "defer";
    }
    if kind == AstStmtKind.Asm {
        give "asm";
    }
    if kind == AstStmtKind.Unsafe {
        give "unsafe";
    }
    if kind == AstStmtKind.Emit {
        give "emit";
    }
    if kind == AstStmtKind.Assert {
        give "assert";
    }
    if kind == AstStmtKind.Panic {
        give "panic";
    }
    if kind == AstStmtKind.Unreachable {
        give "unreachable";
    }
    if kind == AstStmtKind.If {
        give "if";
    }
    if kind == AstStmtKind.While {
        give "while";
    }
    if kind == AstStmtKind.Loop {
        give "loop";
    }
    if kind == AstStmtKind.For {
        give "for";
    }
    if kind == AstStmtKind.Break {
        give "break";
    }
    if kind == AstStmtKind.Continue {
        give "continue";
    }
    if kind == AstStmtKind.Select {
        give "select";
    }
    if kind == AstStmtKind.Match {
        give "match";
    }
    if kind == AstStmtKind.WhenMatch {
        give "when-match";
    }
    if kind == AstStmtKind.With {
        give "with";
    }
    if kind == AstStmtKind.Critical {
        give "critical";
    }
    if kind == AstStmtKind.Expr {
        give "expr";
    }

    give "unknown";
}

proc expr_kind_name(kind: AstExprKind) -> string {
    if kind == AstExprKind.Literal {
        give "literal";
    }
    if kind == AstExprKind.Variable {
        give "variable";
    }
    if kind == AstExprKind.Path {
        give "path";
    }
    if kind == AstExprKind.Call {
        give "call";
    }
    if kind == AstExprKind.Member {
        give "member";
    }
    if kind == AstExprKind.Index {
        give "index";
    }
    if kind == AstExprKind.Unary {
        give "unary";
    }
    if kind == AstExprKind.Binary {
        give "binary";
    }
    if kind == AstExprKind.Assign {
        give "assign";
    }
    if kind == AstExprKind.Cast {
        give "cast";
    }
    if kind == AstExprKind.Is {
        give "is";
    }
    if kind == AstExprKind.Range {
        give "range";
    }
    if kind == AstExprKind.IfExpr {
        give "if-expr";
    }
    if kind == AstExprKind.MatchExpr {
        give "match-expr";
    }
    if kind == AstExprKind.BlockExpr {
        give "block-expr";
    }

    give "unknown";
}

proc ast_surface_summary() -> string {
    let out: string = "";
    set out = out + slice("decls=x", 0, 6);
    set out = out + (decl_kind_count() as string);
    set out = out + slice(" stmts=x", 0, 7);
    set out = out + (stmt_kind_count() as string);
    set out = out + slice(" exprs=x", 0, 7);
    set out = out + (expr_kind_count() as string);
    set out = out + slice(" types=x", 0, 7);
    set out = out + (type_kind_count() as string);
    set out = out + slice(" patterns=x", 0, 10);
    set out = out + (pattern_kind_count() as string);
    give out;
}

proc ast_summary(module: AstModule) -> string {
    let out: string = module.name;
    let decl_count_text: string = module.decl_count as string;
    let stmt_count_text: string = module.stmt_count as string;
    let expr_count_text: string = module.expr_count as string;
    set out = out + slice(" decls=x", 0, 7);
    set out = out + decl_count_text;
    set out = out + slice(" stmts=x", 0, 7);
    set out = out + stmt_count_text;
    set out = out + slice(" exprs=x", 0, 7);
    set out = out + expr_count_text;
    give out;
}

proc ast_selftest() -> bool {
    let span: AstSpan = ast_span("main.vit", 1, 1, 1, 10);

    let decl: AstDecl = ast_decl(AstDeclKind.Proc, "main", public_visibility(), 0, 1, span);

    let expr: AstExpr = ast_expr(AstExprKind.Call, "print()", 1, span);

    let module: AstModule = ast_module("demo", 1, 2, 3, 1, 0, true);

    let stats: AstNodeStats = ast_node_stats(1, 2, 3, 1, 0);

    give ast_version() == "full-grammar-ast-v2"
        and decl_kind_name(decl.kind) == "proc"
        and expr_kind_name(expr.kind) == "call"
        and stats.total_count == 7
        and module.valid
        and ast_total_kind_count() == 117
        and ast_summary(module) != "";
}
