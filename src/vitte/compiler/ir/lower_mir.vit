space vitte/compiler/ir/lower_mir

form MirParam {
  name: string,
  type_name: string
}

form MirStmt {
  kind: string,
  name: string,
  type_name: string,
  raw_text: string
}

form MirFunction {
  name: string,
  return_type_name: string,
  params: [MirParam],
  body_stmts: [MirStmt]
}

form MirGlobal {
  name: string,
  type_name: string,
  is_const: bool
}

form MirModule {
  source_name: string,
  namespace_name: string,
  globals: [MirGlobal],
  functions: [MirFunction],
  notes: [string]
}

proc empty_module(namespace_name: string) -> MirModule {
  give MirModule {
    source_name: "",
    namespace_name: namespace_name,
    globals: [],
    functions: [],
    notes: ["bootstrap-mir"]
  }
}

proc append_note(module: MirModule, note: string) -> MirModule {
  set module.notes = module.notes + [note]
  give module
}

proc add_global(module: MirModule, name: string, type_name: string, is_const: bool) -> MirModule {
  set module.globals = module.globals + [MirGlobal {
    name: name,
    type_name: type_name,
    is_const: is_const
  }]
  give module
}

proc add_function(module: MirModule, name: string, return_type_name: string) -> MirModule {
  set module.functions = module.functions + [MirFunction {
    name: name,
    return_type_name: return_type_name,
    params: [],
    body_stmts: []
  }]
  give module
}

proc lower_mir(source_name: string, namespace_name: string) -> MirModule {
  let module: MirModule = empty_module(namespace_name)
  set module.source_name = source_name
  set module.notes = module.notes + ["source=" + source_name]
  set module.notes = module.notes + ["namespace=" + namespace_name]
  give module
}

proc is_empty(module: MirModule) -> bool {
  give module.globals.len == 0 and module.functions.len == 0
}

proc global_count(module: MirModule) -> int { give module.globals.len }
proc function_count(module: MirModule) -> int { give module.functions.len }

proc module_summary(module: MirModule) -> string {
  give module.namespace_name + " globals=" + (module.globals.len as string) + " functions=" + (module.functions.len as string) + " notes=" + (module.notes.len as string)
}

export *
