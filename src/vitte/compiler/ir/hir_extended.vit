    attrs: [],
    static_item: StaticItem {
      ty: Ty {
        hir_id: HirId { index: 0, local_index: 0 },
        kind: TyKind.Err,
        span: Span {
          lo: BytePos { value: 0 },
          hi: BytePos { value: 0 },
          ctxt: SyntaxContext { index: 0 },
          parent: Option.None
