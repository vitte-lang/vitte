space vitte/compiler/frontend/lexer/cursor

export *

form Cursor {
  text: string
  index: u64
  line: u64
  column: u64
  length: u64
  valid: bool
}

form CursorSnapshot {
  index: u64
  line: u64
  column: u64
}

proc cursor(text: string, index: u64, line: u64, column: u64, valid: bool) -> Cursor {
  give Cursor {
    text: text,
    index: index,
    line: line,
    column: column,
    length: len(text),
    valid: valid
  };
}

proc cursor_new(text: string) -> Cursor {
  give cursor(
    text,
    0,
    1,
    1,
    true
  );
}

proc cursor_snapshot(cursor: Cursor) -> CursorSnapshot {
  give CursorSnapshot {
    index: cursor.index,
    line: cursor.line,
    column: cursor.column
  };
}

proc cursor_restore(cursor: Cursor, snapshot: CursorSnapshot) -> Cursor {
  give Cursor {
    text: cursor.text,
    index: snapshot.index,
    line: snapshot.line,
    column: snapshot.column,
    length: cursor.length,
    valid: cursor.valid
  };
}

proc cursor_eof(cursor: Cursor) -> bool {
  give cursor.index >= cursor.length;
}

proc cursor_remaining(cursor: Cursor) -> u64 {
  if cursor.index >= cursor.length {
    give 0;
  }

  give cursor.length - cursor.index;
}

proc cursor_valid(cursor: Cursor) -> bool {
  give cursor.valid;
}

proc cursor_current(cursor: Cursor) -> string {
  if cursor_eof(cursor) {
    give "";
  }

  give slice(
    cursor.text,
    cursor.index,
    cursor.index + 1
  );
}

proc cursor_previous(cursor: Cursor) -> string {
  if cursor.index == 0 {
    give "";
  }

  give slice(
    cursor.text,
    cursor.index - 1,
    cursor.index
  );
}

proc cursor_peek(cursor: Cursor, offset: u64) -> string {
  let target: u64 =
    cursor.index + offset;

  if target >= cursor.length {
    give "";
  }

  give slice(
    cursor.text,
    target,
    target + 1
  );
}

proc cursor_slice(cursor: Cursor, start: u64, end0: u64) -> string {
  if start >= cursor.length {
    give "";
  }

  let safe_end: u64 =
    if end0 > cursor.length {
      cursor.length
    } else {
      end0
    };

  if start >= safe_end {
    give "";
  }

  give slice(
    cursor.text,
    start,
    safe_end
  );
}

proc cursor_starts_with(cursor: Cursor, needle: string) -> bool {
  if len(needle) == 0 {
    give true;
  }

  if cursor.index + len(needle) > cursor.length {
    give false;
  }

  give cursor_slice(
    cursor,
    cursor.index,
    cursor.index + len(needle)
  ) == needle;
}

proc cursor_match(cursor: Cursor, needle: string) -> bool {
  give cursor_starts_with(
    cursor,
    needle
  );
}

proc cursor_is_newline(cursor: Cursor) -> bool {
  give cursor_current(cursor) == "\n";
}

proc cursor_is_space(cursor: Cursor) -> bool {
  let ch: string =
    cursor_current(cursor);

  give ch == " "
    or ch == "\t"
    or ch == "\r"
    or ch == "\n";
}

proc cursor_is_digit(cursor: Cursor) -> bool {
  let ch: string =
    cursor_current(cursor);

  give ch >= "0"
    and ch <= "9";
}

proc cursor_is_alpha(cursor: Cursor) -> bool {
  let ch: string =
    cursor_current(cursor);

  give (ch >= "a" and ch <= "z")
    or (ch >= "A" and ch <= "Z")
    or ch == "_";
}

proc cursor_is_alnum(cursor: Cursor) -> bool {
  give cursor_is_alpha(cursor)
    or cursor_is_digit(cursor);
}

proc cursor_advance(cursor: Cursor) -> Cursor {
  if cursor_eof(cursor) {
    give cursor;
  }

  let ch: string =
    cursor_current(cursor);

  if ch == "\n" {
    give Cursor {
      text: cursor.text,
      index: cursor.index + 1,
      line: cursor.line + 1,
      column: 1,
      length: cursor.length,
      valid: cursor.valid
    };
  }

  give Cursor {
    text: cursor.text,
    index: cursor.index + 1,
    line: cursor.line,
    column: cursor.column + 1,
    length: cursor.length,
    valid: cursor.valid
  };
}

proc cursor_advance_n(cursor: Cursor, count: u64) -> Cursor {
  let current: Cursor =
    cursor;

  let i: u64 = 0;

  while i < count
    and not cursor_eof(current) {

    set current =
      cursor_advance(current);

    set i =
      i + 1;
  }

  give current;
}

proc cursor_skip_spaces(cursor: Cursor) -> Cursor {
  let current: Cursor =
    cursor;

  while not cursor_eof(current)
    and cursor_is_space(current) {

    set current =
      cursor_advance(current);
  }

  give current;
}

proc cursor_skip_until(cursor: Cursor, needle: string) -> Cursor {
  let current: Cursor =
    cursor;

  while not cursor_eof(current)
    and not cursor_starts_with(current, needle) {

    set current =
      cursor_advance(current);
  }

  give current;
}

proc cursor_consume(cursor: Cursor, needle: string) -> Cursor {
  if not cursor_starts_with(cursor, needle) {
    give cursor;
  }

  give cursor_advance_n(
    cursor,
    len(needle)
  );
}

proc cursor_distance(start: Cursor, end0: Cursor) -> u64 {
  if end0.index < start.index {
    give 0;
  }

  give end0.index - start.index;
}

proc cursor_location(cursor: Cursor) -> string {
  give (cursor.line as string)
    + ":"
    + (cursor.column as string);
}

proc cursor_summary(cursor: Cursor) -> string {
  give "index="
    + (cursor.index as string)
    + " line="
    + (cursor.line as string)
    + " column="
    + (cursor.column as string)
    + " remaining="
    + (cursor_remaining(cursor) as string)
    + " eof="
    + (cursor_eof(cursor) as string);
}

proc cursor_selftest() -> bool {
  let c0: Cursor =
    cursor_new("abc\n123");

  let c1: Cursor =
    cursor_advance(c0);

  let c2: Cursor =
    cursor_advance_n(c1, 3);

  let snap: CursorSnapshot =
    cursor_snapshot(c2);

  let c3: Cursor =
    cursor_restore(c2, snap);

  give cursor_current(c0) == "a"
    and cursor_peek(c0, 1) == "b"
    and cursor_previous(c1) == "a"
    and cursor_is_alpha(c0)
    and cursor_distance(c0, c1) == 1
    and cursor_location(c2) != ""
    and cursor_summary(c3) != ""
    and cursor_valid(c3);
}