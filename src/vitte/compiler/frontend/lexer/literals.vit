space vitte/compiler/frontend/lexer/literals

form LiteralValidation {
  valid: bool
  is_float: bool
  error_code: string
  error_message: string
}

proc literal_ok(is_float: bool) -> LiteralValidation {
  give LiteralValidation {
    valid: true,
    is_float: is_float,
    error_code: "",
    error_message: ""
  };
}

proc literal_invalid(code: string, message: string, is_float: bool) -> LiteralValidation {
  give LiteralValidation {
    valid: false,
    is_float: is_float,
    error_code: code,
    error_message: message
  };
}

proc is_letter(ch: string) -> bool {
  give (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_";
}

proc is_digit(ch: string) -> bool {
  give ch >= "0" and ch <= "9";
}

proc is_hex_digit(ch: string) -> bool {
  give is_digit(ch) or (ch >= "a" and ch <= "f") or (ch >= "A" and ch <= "F");
}

proc is_octal_digit(ch: string) -> bool {
  give ch >= "0" and ch <= "7";
}

proc is_binary_digit(ch: string) -> bool {
  give ch == "0" or ch == "1";
}

proc is_identifier_continue(ch: string) -> bool {
  give is_letter(ch) or is_digit(ch);
}

proc is_keyword(text: string) -> bool {
  if text == "space" or text == "use" or text == "export" or text == "const" or text == "static" or text == "global" { give true; }
  if text == "type" or text == "opaque" or text == "extern" or text == "form" or text == "class" or text == "union" { give true; }
  if text == "bits" or text == "pick" or text == "flags" or text == "trait" or text == "impl" or text == "proc" { give true; }
  if text == "intrinsic" or text == "compiler" or text == "query" or text == "pass" or text == "backend" { give true; }
  if text == "diagnostic" or text == "macro" or text == "comptime" or text == "static_assert" or text == "test" or text == "bench" or text == "entry" { give true; }
  if text == "pub" or text == "priv" or text == "unsafe" or text == "async" or text == "inline" or text == "noinline" { give true; }
  if text == "naked" or text == "interrupt" or text == "where" or text == "effects" or text == "requires" or text == "operator" { give true; }
  if text == "as" or text == "for" or text == "at" or text == "let" or text == "set" or text == "give" or text == "try" { give true; }
  if text == "defer" or text == "asm" or text == "emit" or text == "assert" or text == "panic" or text == "unreachable" { give true; }
  if text == "if" or text == "elif" or text == "else" or text == "while" or text == "loop" or text == "in" { give true; }
  if text == "break" or text == "continue" or text == "select" or text == "when" or text == "match" or text == "case" { give true; }
  if text == "with" or text == "critical" or text == "mut" or text == "owned" or text == "borrow" or text == "move" { give true; }
  if text == "await" or text == "not" or text == "and" or text == "or" or text == "is" or text == "self" or text == "ref" { give true; }
  if text == "dyn" or text == "true" or text == "false" or text == "null" or text == "sizeof" or text == "alignof" { give true; }
  if text == "offsetof" or text == "typeof" or text == "nameof" or text == "map" or text == "resource" or text == "volatile" { give true; }
  if text == "atomic" or text == "user" or text == "kernel" or text == "phys" or text == "mmio" or text == "dma" or text == "noexcept" { give true; }
  give false;
}

proc is_valid_escape_char(ch: string) -> bool {
  if ch == "n" or ch == "r" or ch == "t" or ch == "0" {
    give true;
  }
  if ch == "\\" or ch == "\"" or ch == "'" {
    give true;
  }
  give false;
}

proc validate_numeric_suffix(suffix: string) -> LiteralValidation {
  if suffix == "" {
    give literal_ok(false);
  }
  if not is_letter(slice(suffix, 0, 1)) {
    give literal_invalid("LEX_E_INVALID_NUMBER", "invalid numeric literal suffix", false);
  }
  let i: u64 = 0;
  while i < len(suffix) {
    if not is_identifier_continue(slice(suffix, i, i + 1)) {
      give literal_invalid("LEX_E_INVALID_NUMBER", "invalid numeric literal suffix", false);
    }
    set i = i + 1;
  }
  give literal_ok(false);
}

proc validate_number_lexeme(lexeme: string) -> LiteralValidation {
  let start: u64 = if starts_with(lexeme, "-") { 1 } else { 0 };
  let prefix: string = if len(lexeme) >= start + 2 and slice(lexeme, start, start + 1) == "0" { slice(lexeme, start + 1, start + 2) } else { "" };
  let base_mode: string = if prefix == "x" or prefix == "o" or prefix == "b" { prefix } else { "" };
  let i: u64 = if base_mode != "" { start + 2 } else { start };
  let suffix_start: u64 = len(lexeme);
  let saw_digit: bool = false;
  let saw_dot: bool = false;
  let prev_underscore: bool = false;

  while i < len(lexeme) {
    let ch: string = slice(lexeme, i, i + 1);
    let valid_digit: bool = false;
    if base_mode == "x" {
      set valid_digit = is_hex_digit(ch);
    } elif base_mode == "o" {
      set valid_digit = is_octal_digit(ch);
    } elif base_mode == "b" {
      set valid_digit = is_binary_digit(ch);
    } else {
      set valid_digit = is_digit(ch);
    }

    if valid_digit {
      set saw_digit = true;
      set prev_underscore = false;
      set i = i + 1;
      continue;
    }
    if ch == "_" {
      if not saw_digit or prev_underscore or i + 1 >= len(lexeme) {
        give literal_invalid("LEX_E_INVALID_NUMBER", "invalid underscore placement in numeric literal", saw_dot);
      }
      let next: string = slice(lexeme, i + 1, i + 2);
      let next_valid: bool = false;
      if base_mode == "x" {
        set next_valid = is_hex_digit(next);
      } elif base_mode == "o" {
        set next_valid = is_octal_digit(next);
      } elif base_mode == "b" {
        set next_valid = is_binary_digit(next);
      } else {
        set next_valid = is_digit(next);
      }
      if not next_valid {
        give literal_invalid("LEX_E_INVALID_NUMBER", "invalid underscore placement in numeric literal", saw_dot);
      }
      set prev_underscore = true;
      set i = i + 1;
      continue;
    }
    if base_mode == "" and ch == "." {
      if saw_dot or prev_underscore or i + 1 >= len(lexeme) or not is_digit(slice(lexeme, i + 1, i + 2)) {
        give literal_invalid("LEX_E_INVALID_NUMBER", "malformed float literal", true);
      }
      set saw_dot = true;
      set prev_underscore = false;
      set i = i + 1;
      continue;
    }
    if base_mode == "" and is_letter(ch) {
      set suffix_start = i;
      break;
    }
    if base_mode != "" and is_letter(ch) and not is_hex_digit(ch) {
      set suffix_start = i;
      break;
    }
    if base_mode != "" and is_digit(ch) {
      give literal_invalid("LEX_E_INVALID_NUMBER", "invalid digit for numeric base", false);
    }
    give literal_invalid("LEX_E_INVALID_NUMBER", "invalid numeric literal", saw_dot);
  }

  if not saw_digit or prev_underscore {
    if base_mode != "" {
      give literal_invalid("LEX_E_INVALID_NUMBER", "numeric base prefix requires digits", false);
    }
    give literal_invalid("LEX_E_INVALID_NUMBER", "invalid decimal literal", saw_dot);
  }

  let suffix: string = slice(lexeme, suffix_start, len(lexeme));
  let suffix_check: LiteralValidation = validate_numeric_suffix(suffix);
  if not suffix_check.valid {
    give suffix_check;
  }
  give literal_ok(saw_dot);
}

proc validate_string_lexeme(lexeme: string) -> LiteralValidation {
  let i: u64 = 1;
  while i + 1 < len(lexeme) {
    let ch: string = slice(lexeme, i, i + 1);
    if ch == "\\" {
      if i + 1 >= len(lexeme) - 1 {
        give literal_invalid("LEX_E_INVALID_ESCAPE", "truncated escape sequence", false);
      }
      let esc: string = slice(lexeme, i + 1, i + 2);
      if not is_valid_escape_char(esc) {
        give literal_invalid("LEX_E_INVALID_ESCAPE", "invalid escape sequence", false);
      }
      set i = i + 2;
    } else {
      set i = i + 1;
    }
  }
  give literal_ok(false);
}

proc validate_char_lexeme(lexeme: string) -> LiteralValidation {
  if len(lexeme) < 3 {
    give literal_invalid("LEX_E_INVALID_CHAR_LITERAL", "empty char literal", false);
  }
  let i: u64 = 1;
  let units: u64 = 0;
  while i + 1 < len(lexeme) {
    let ch: string = slice(lexeme, i, i + 1);
    if ch == "\\" {
      if i + 1 >= len(lexeme) - 1 {
        give literal_invalid("LEX_E_INVALID_ESCAPE", "truncated escape sequence", false);
      }
      let esc: string = slice(lexeme, i + 1, i + 2);
      if not is_valid_escape_char(esc) {
        give literal_invalid("LEX_E_INVALID_ESCAPE", "invalid escape sequence", false);
      }
      set units = units + 1;
      set i = i + 2;
    } else {
      set units = units + 1;
      set i = i + 1;
    }
  }
  if units != 1 {
    give literal_invalid("LEX_E_INVALID_CHAR_LITERAL", "char literal must contain exactly one character", false);
  }
  give literal_ok(false);
}
