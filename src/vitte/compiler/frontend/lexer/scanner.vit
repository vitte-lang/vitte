space vitte/compiler/frontend/lexer/scanner

use vitte/compiler/frontend/lexer/token.{ Token, TokenKind, token }
use vitte/compiler/frontend/lexer/cursor.{ Cursor, cursor_advance, cursor_advance_n, cursor_current, cursor_eof, cursor_new, cursor_peek, cursor_starts_with }
use vitte/compiler/frontend/lexer/comments.{ CommentSkipResult, is_block_comment_start, is_hash_line_comment_start, is_line_comment_start, is_region_comment_start, skip_block_comment, skip_line_comment, skip_region_comment }
use vitte/compiler/frontend/lexer/literals.{ LiteralValidation, is_digit, is_identifier_continue, is_keyword, is_letter, validate_char_lexeme, validate_number_lexeme, validate_string_lexeme }
use vitte/compiler/frontend/lexer/errors.{ LexerDiagnostic, lex_error }

form ScanResult {
  tokens: [Token]
  diagnostics: [LexerDiagnostic]
  valid: bool
}

proc scan_result(tokens: [Token], diagnostics: [LexerDiagnostic]) -> ScanResult {
  give ScanResult {
    tokens: tokens,
    diagnostics: diagnostics,
    valid: len(diagnostics) == 0
  };
}

proc lex_diag(code: string, message: string, line: u64, column: u64, width: u64) -> LexerDiagnostic {
  give lex_error(code, message, line, column, width);
}

proc scan_identifier_token(cursor: Cursor) -> Token {
  let current: Cursor = cursor;
  let start: u64 = current.index;
  let start_line: u64 = current.line;
  let start_col: u64 = current.column;
  let walk: Cursor = current;
  while not cursor_eof(walk) and is_identifier_continue(cursor_current(walk)) {
    set walk = cursor_advance(walk);
  }
  let lexeme: string = slice(current.text, start, walk.index);
  let kind: TokenKind = if is_keyword(lexeme) { TokenKind.Keyword } else { TokenKind.Ident };
  give token(kind, lexeme, start_line, start_col);
}

proc advance_identifier(cursor: Cursor) -> Cursor {
  let walk: Cursor = cursor;
  while not cursor_eof(walk) and is_identifier_continue(cursor_current(walk)) {
    set walk = cursor_advance(walk);
  }
  give walk;
}

proc advance_numeric_body(cursor: Cursor) -> Cursor {
  let walk: Cursor = cursor;
  let dot_seen: bool = false;
  let prefix_mode: string = "";
  if cursor_current(walk) == "-" {
    set walk = cursor_advance(walk);
  }
  if cursor_current(walk) == "0" {
    let next: string = cursor_peek(walk, 1);
    if next == "x" or next == "o" or next == "b" {
      set prefix_mode = next;
      set walk = cursor_advance_n(walk, 2);
    }
  }
  while not cursor_eof(walk) {
    let ch: string = cursor_current(walk);
    if is_digit(ch) or ch == "_" {
      set walk = cursor_advance(walk);
      continue;
    }
    if prefix_mode == "x" and ((ch >= "a" and ch <= "f") or (ch >= "A" and ch <= "F")) {
      set walk = cursor_advance(walk);
      continue;
    }
    if prefix_mode == "" and ch == "." and not dot_seen and not cursor_starts_with(walk, "..") {
      set dot_seen = true;
      set walk = cursor_advance(walk);
      continue;
    }
    break;
  }
  give walk;
}

proc advance_number(cursor: Cursor) -> Cursor {
  let walk: Cursor = advance_numeric_body(cursor);
  while not cursor_eof(walk) and is_identifier_continue(cursor_current(walk)) {
    set walk = cursor_advance(walk);
  }
  give walk;
}

proc scan_number_token(cursor: Cursor) -> Token {
  let current: Cursor = cursor;
  let start_line: u64 = current.line;
  let start_col: u64 = current.column;
  let walk: Cursor = advance_number(current);
  let lexeme: string = slice(current.text, current.index, walk.index);
  let check: LiteralValidation = validate_number_lexeme(lexeme);
  let kind: TokenKind = if check.is_float { TokenKind.Float } else { TokenKind.Integer };
  if not check.valid {
    give token(TokenKind.Invalid, lexeme, start_line, start_col);
  }
  give token(kind, lexeme, start_line, start_col);
}

proc scan_quoted_token(cursor: Cursor, quote: string, kind: TokenKind) -> ScanResult {
  let tokens: [Token] = [];
  let diagnostics: [LexerDiagnostic] = [];
  let start_line: u64 = cursor.line;
  let start_col: u64 = cursor.column;
  let walk: Cursor = cursor_advance(cursor);
  let closed: bool = false;
  while not cursor_eof(walk) {
    let ch: string = cursor_current(walk);
    if ch == "\\" and cursor_peek(walk, 1) != "" {
      set walk = cursor_advance_n(walk, 2);
      continue;
    }
    if ch == quote {
      set walk = cursor_advance(walk);
      set closed = true;
      break;
    }
    if quote == "'" and ch == "\n" {
      break;
    }
    set walk = cursor_advance(walk);
  }
  let lexeme: string = slice(cursor.text, cursor.index, walk.index);
  if not closed {
    let code: string = if quote == "\"" { "LEX_E_UNTERMINATED_STRING" } else { "LEX_E_UNTERMINATED_CHAR" };
    let message: string = if quote == "\"" { "unterminated string literal" } else { "unterminated char literal" };
    set diagnostics = diagnostics + [lex_diag(code, message, start_line, start_col, len(lexeme))];
    set tokens = tokens + [token(TokenKind.Invalid, lexeme, start_line, start_col)];
  } else {
    let validation: LiteralValidation = if quote == "\"" { validate_string_lexeme(lexeme) } else { validate_char_lexeme(lexeme) };
    if not validation.valid {
      set diagnostics = diagnostics + [lex_diag(validation.error_code, validation.error_message, start_line, start_col, len(lexeme))];
      set tokens = tokens + [token(TokenKind.Invalid, lexeme, start_line, start_col)];
    } else {
      set tokens = tokens + [token(kind, lexeme, start_line, start_col)];
    }
  }
  give scan_result(tokens, diagnostics);
}

proc is_two_char_symbol(cursor: Cursor) -> bool {
  if cursor_starts_with(cursor, "->") or cursor_starts_with(cursor, "::") or cursor_starts_with(cursor, "..") or cursor_starts_with(cursor, "==") or cursor_starts_with(cursor, "!=") or cursor_starts_with(cursor, "<=") or cursor_starts_with(cursor, ">=") or cursor_starts_with(cursor, "<<") or cursor_starts_with(cursor, ">>") or cursor_starts_with(cursor, "+=") or cursor_starts_with(cursor, "-=") or cursor_starts_with(cursor, "*=") or cursor_starts_with(cursor, "/=") or cursor_starts_with(cursor, "%=") or cursor_starts_with(cursor, "&=") or cursor_starts_with(cursor, "|=") or cursor_starts_with(cursor, "^=") or cursor_starts_with(cursor, "??") or cursor_starts_with(cursor, "=>") or cursor_starts_with(cursor, "#[") or cursor_starts_with(cursor, "#!") {
    give true;
  }
  give false;
}

proc is_valid_single_symbol(ch: string) -> bool {
  give
    ch == "(" or ch == ")" or ch == "{" or ch == "}" or ch == "[" or ch == "]" or
    ch == "," or ch == ";" or ch == ":" or ch == "." or ch == "+" or ch == "-" or
    ch == "*" or ch == "/" or ch == "%" or ch == "=" or ch == "<" or ch == ">" or
    ch == "!" or ch == "&" or ch == "|" or ch == "^";
}

proc scan_tokens(text: string) -> ScanResult {
  let tokens: [Token] = [];
  let diagnostics: [LexerDiagnostic] = [];
  let cursor: Cursor = cursor_new(text);
  let current: Cursor = cursor;

  while not cursor_eof(current) {
    let ch: string = cursor_current(current);

    if ch == " " or ch == "\t" or ch == "\r" or ch == "\n" {
      set current = cursor_advance(current);
      continue;
    }

    if is_hash_line_comment_start(current) {
      set current = skip_line_comment(current);
      continue;
    }

    let two: string = ch + cursor_peek(current, 1);
    if is_line_comment_start(two) {
      set current = skip_line_comment(current);
      continue;
    }

    if is_block_comment_start(current) {
      let start_line: u64 = current.line;
      let start_col: u64 = current.column;
      let skipped: CommentSkipResult = skip_block_comment(current);
      if not skipped.terminated {
        set diagnostics = diagnostics + [lex_diag("LEX_E_UNTERMINATED_BLOCK_COMMENT", "unterminated block comment", start_line, start_col, 2)];
        set tokens = tokens + [token(TokenKind.Invalid, "/*", start_line, start_col)];
      }
      set current = skipped.cursor;
      continue;
    }

    if is_region_comment_start(current) {
      let skipped: CommentSkipResult = skip_region_comment(current);
      set current = skipped.cursor;
      continue;
    }

    if is_letter(ch) {
      set tokens = tokens + [scan_identifier_token(current)];
      set current = advance_identifier(current);
      continue;
    }

    if is_digit(ch) or (ch == "-" and is_digit(cursor_peek(current, 1))) {
      let number_token: Token = scan_number_token(current);
      set tokens = tokens + [number_token];
      if number_token.kind == TokenKind.Invalid {
        let validation: LiteralValidation = validate_number_lexeme(number_token.lexeme);
        set diagnostics = diagnostics + [lex_diag(validation.error_code, validation.error_message, current.line, current.column, len(number_token.lexeme))];
      }
      set current = advance_number(current);
      continue;
    }

    if ch == "\"" {
      let scanned: ScanResult = scan_quoted_token(current, "\"", TokenKind.String);
      set tokens = tokens + scanned.tokens;
      set diagnostics = diagnostics + scanned.diagnostics;
      if len(scanned.tokens) > 0 {
        set current = cursor_advance_n(current, len(scanned.tokens[0].lexeme));
      } else {
        set current = cursor_advance(current);
      }
      continue;
    }

    if ch == "'" {
      let scanned: ScanResult = scan_quoted_token(current, "'", TokenKind.Char);
      set tokens = tokens + scanned.tokens;
      set diagnostics = diagnostics + scanned.diagnostics;
      if len(scanned.tokens) > 0 {
        set current = cursor_advance_n(current, len(scanned.tokens[0].lexeme));
      } else {
        set current = cursor_advance(current);
      }
      continue;
    }

    if cursor_starts_with(current, "...") {
      set tokens = tokens + [token(TokenKind.Symbol, "...", current.line, current.column)];
      set current = cursor_advance_n(current, 3);
      continue;
    }
    if cursor_starts_with(current, "..=") {
      set tokens = tokens + [token(TokenKind.Symbol, "..=", current.line, current.column)];
      set current = cursor_advance_n(current, 3);
      continue;
    }
    if is_two_char_symbol(current) {
      let sym: string = slice(current.text, current.index, current.index + 2);
      set tokens = tokens + [token(TokenKind.Symbol, sym, current.line, current.column)];
      set current = cursor_advance_n(current, 2);
      continue;
    }

    if is_valid_single_symbol(ch) {
      set tokens = tokens + [token(TokenKind.Symbol, ch, current.line, current.column)];
    } else {
      set diagnostics = diagnostics + [lex_diag("LEX_E_INVALID_CHAR", "invalid character `" + ch + "`", current.line, current.column, 1)];
      set tokens = tokens + [token(TokenKind.Invalid, ch, current.line, current.column)];
    }
    set current = cursor_advance(current);
  }

  set tokens = tokens + [token(TokenKind.Eof, "", current.line, current.column)];
  give scan_result(tokens, diagnostics);
}
