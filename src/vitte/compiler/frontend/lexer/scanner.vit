space vitte/compiler/frontend/lexer/scanner

use vitte/compiler/frontend/lexer/token.{ Token, TokenKind, token }

form LexDiagnostic {
  code: string
  message: string
  line: u64
  column: u64
  fatal: bool
}

form ScanResult {
  tokens: [Token]
  diagnostics: [LexDiagnostic]
  valid: bool
}

proc lex_diag(code: string, message: string, line: u64, column: u64, fatal: bool) -> LexDiagnostic {
  give LexDiagnostic {
    code: code,
    message: message,
    line: line,
    column: column,
    fatal: fatal
  };
}

proc scan_result(tokens: [Token], diagnostics: [LexDiagnostic]) -> ScanResult {
  give ScanResult {
    tokens: tokens,
    diagnostics: diagnostics,
    valid: len(diagnostics) == 0
  };
}

proc is_letter(ch: string) -> bool {
  give (ch >= "a" and ch <= "z") or (ch >= "A" and ch <= "Z") or ch == "_";
}

proc is_digit(ch: string) -> bool {
  give ch >= "0" and ch <= "9";
}

proc starts_with_at(text: string, i: u64, needle: string) -> bool {
  if i + len(needle) > len(text) {
    give false;
  }
  give slice(text, i, i + len(needle)) == needle;
}

proc is_keyword(text: string) -> bool {
  if text == "space" or text == "use" or text == "export" or text == "const" or text == "static" or text == "global" { give true; }
  if text == "type" or text == "opaque" or text == "extern" or text == "form" or text == "class" or text == "union" { give true; }
  if text == "bits" or text == "pick" or text == "flags" or text == "trait" or text == "impl" or text == "proc" { give true; }
  if text == "intrinsic" or text == "compiler" or text == "query" or text == "pass" or text == "backend" { give true; }
  if text == "diagnostic" or text == "macro" or text == "comptime" or text == "static_assert" or text == "test" or text == "bench" or text == "entry" { give true; }
  if text == "pub" or text == "priv" or text == "unsafe" or text == "async" or text == "inline" or text == "noinline" { give true; }
  if text == "naked" or text == "interrupt" or text == "where" or text == "effects" or text == "requires" or text == "operator" { give true; }
  if text == "as" or text == "for" or text == "at" or text == "let" or text == "set" or text == "give" or text == "try" { give true; }
  if text == "defer" or text == "asm" or text == "emit" or text == "assert" or text == "panic" or text == "unreachable" { give true; }
  if text == "if" or text == "elif" or text == "else" or text == "while" or text == "loop" or text == "in" { give true; }
  if text == "break" or text == "continue" or text == "select" or text == "when" or text == "match" or text == "case" { give true; }
  if text == "with" or text == "critical" or text == "mut" or text == "owned" or text == "borrow" or text == "move" { give true; }
  if text == "await" or text == "not" or text == "and" or text == "or" or text == "is" or text == "self" or text == "ref" { give true; }
  if text == "dyn" or text == "true" or text == "false" or text == "null" or text == "sizeof" or text == "alignof" { give true; }
  if text == "offsetof" or text == "typeof" or text == "nameof" or text == "map" or text == "resource" or text == "volatile" { give true; }
  if text == "atomic" or text == "user" or text == "kernel" or text == "phys" or text == "mmio" or text == "dma" or text == "noexcept" { give true; }
  give false;
}

proc scan_tokens(text: string) -> ScanResult {
  let tokens: [Token] = [];
  let diagnostics: [LexDiagnostic] = [];
  let i: u64 = 0;
  let line: u64 = 1;
  let col: u64 = 1;

  while i < len(text) {
    let ch: string = slice(text, i, i + 1);

    if ch == " " or ch == "\t" or ch == "\r" {
      set i = i + 1;
      set col = col + 1;
      continue;
    }

    if ch == "\n" {
      set i = i + 1;
      set line = line + 1;
      set col = 1;
      continue;
    }

    if ch == "#" {
      while i < len(text) and slice(text, i, i + 1) != "\n" {
        set i = i + 1;
        set col = col + 1;
      }
      continue;
    }

    if starts_with_at(text, i, "//") {
      while i < len(text) and slice(text, i, i + 1) != "\n" {
        set i = i + 1;
        set col = col + 1;
      }
      continue;
    }

    if starts_with_at(text, i, "/*") {
      let start_line: u64 = line;
      let start_col: u64 = col;
      set i = i + 2;
      set col = col + 2;
      while i + 1 < len(text) and not starts_with_at(text, i, "*/") {
        if slice(text, i, i + 1) == "\n" {
          set i = i + 1;
          set line = line + 1;
          set col = 1;
        } else {
          set i = i + 1;
          set col = col + 1;
        }
      }
      if i + 1 < len(text) {
        set i = i + 2;
        set col = col + 2;
      } else {
        set diagnostics = diagnostics + [lex_diag("LEX_E_UNTERMINATED_BLOCK_COMMENT", "unterminated block comment", start_line, start_col, true)];
        set tokens = tokens + [token(TokenKind.Invalid, "/*", start_line, start_col)];
      }
      continue;
    }

    if starts_with_at(text, i, "<<<") {
      set i = i + 3;
      set col = col + 3;
      while i + 2 < len(text) and not starts_with_at(text, i, ">>>") {
        if slice(text, i, i + 1) == "\n" {
          set i = i + 1;
          set line = line + 1;
          set col = 1;
        } else {
          set i = i + 1;
          set col = col + 1;
        }
      }
      if i + 2 < len(text) {
        set i = i + 3;
        set col = col + 3;
      }
      continue;
    }

    if is_letter(ch) {
      let start: u64 = i;
      let start_col: u64 = col;
      while i < len(text) {
        let c2: string = slice(text, i, i + 1);
        if is_letter(c2) or is_digit(c2) {
          set i = i + 1;
          set col = col + 1;
        } else {
          break;
        }
      }
      let lex: string = slice(text, start, i);
      if is_keyword(lex) {
        set tokens = tokens + [token(TokenKind.Keyword, lex, line, start_col)];
      } else {
        set tokens = tokens + [token(TokenKind.Ident, lex, line, start_col)];
      }
      continue;
    }

    if is_digit(ch) or (ch == "-" and i + 1 < len(text) and is_digit(slice(text, i + 1, i + 2))) {
      let start: u64 = i;
      let start_col: u64 = col;
      let dot_count: u64 = 0;
      if ch == "-" {
        set i = i + 1;
        set col = col + 1;
      }
      while i < len(text) {
        let c2: string = slice(text, i, i + 1);
        if is_digit(c2) or c2 == "_" or c2 == "x" or c2 == "o" or c2 == "b" {
          set i = i + 1;
          set col = col + 1;
        } elif c2 == "." and not starts_with_at(text, i, "..") {
          set dot_count = dot_count + 1;
          set i = i + 1;
          set col = col + 1;
        } else {
          break;
        }
      }
      let lexeme: string = slice(text, start, i);
      if dot_count > 0 {
        set tokens = tokens + [token(TokenKind.Float, lexeme, line, start_col)];
      } else {
        set tokens = tokens + [token(TokenKind.Integer, lexeme, line, start_col)];
      }
      continue;
    }

    if ch == "\"" {
      let start: u64 = i;
      let start_col: u64 = col;
      let start_line: u64 = line;
      set i = i + 1;
      set col = col + 1;
      let closed: bool = false;
      while i < len(text) {
        let c2: string = slice(text, i, i + 1);
        if c2 == "\\" and i + 1 < len(text) {
          set i = i + 2;
          set col = col + 2;
          continue;
        }
        if c2 == "\"" {
          set i = i + 1;
          set col = col + 1;
          set closed = true;
          break;
        }
        if c2 == "\n" {
          set i = i + 1;
          set line = line + 1;
          set col = 1;
        } else {
          set i = i + 1;
          set col = col + 1;
        }
      }
      if not closed {
        set diagnostics = diagnostics + [lex_diag("LEX_E_UNTERMINATED_STRING", "unterminated string literal", start_line, start_col, true)];
        set tokens = tokens + [token(TokenKind.Invalid, slice(text, start, i), start_line, start_col)];
      } else {
        set tokens = tokens + [token(TokenKind.String, slice(text, start, i), start_line, start_col)];
      }
      continue;
    }

    if ch == "'" {
      let start: u64 = i;
      let start_col: u64 = col;
      let start_line: u64 = line;
      set i = i + 1;
      set col = col + 1;
      let closed: bool = false;
      while i < len(text) {
        let c2: string = slice(text, i, i + 1);
        if c2 == "\\" and i + 1 < len(text) {
          set i = i + 2;
          set col = col + 2;
          continue;
        }
        if c2 == "'" {
          set i = i + 1;
          set col = col + 1;
          set closed = true;
          break;
        }
        if c2 == "\n" {
          break;
        }
        set i = i + 1;
        set col = col + 1;
      }
      if not closed {
        set diagnostics = diagnostics + [lex_diag("LEX_E_UNTERMINATED_CHAR", "unterminated char literal", start_line, start_col, true)];
        set tokens = tokens + [token(TokenKind.Invalid, slice(text, start, i), start_line, start_col)];
      } else {
        set tokens = tokens + [token(TokenKind.Char, slice(text, start, i), start_line, start_col)];
      }
      continue;
    }

    let start_col: u64 = col;
    if starts_with_at(text, i, "...") {
      set tokens = tokens + [token(TokenKind.Symbol, "...", line, start_col)];
      set i = i + 3;
      set col = col + 3;
      continue;
    }
    if starts_with_at(text, i, "..=") {
      set tokens = tokens + [token(TokenKind.Symbol, "..=", line, start_col)];
      set i = i + 3;
      set col = col + 3;
      continue;
    }
    if starts_with_at(text, i, "->") or starts_with_at(text, i, "::") or starts_with_at(text, i, "..") or starts_with_at(text, i, "==") or starts_with_at(text, i, "!=") or starts_with_at(text, i, "<=") or starts_with_at(text, i, ">=") or starts_with_at(text, i, "<<") or starts_with_at(text, i, ">>") or starts_with_at(text, i, "+=") or starts_with_at(text, i, "-=") or starts_with_at(text, i, "*=") or starts_with_at(text, i, "/=") or starts_with_at(text, i, "%=") or starts_with_at(text, i, "&=") or starts_with_at(text, i, "|=") or starts_with_at(text, i, "^=") or starts_with_at(text, i, "??") or starts_with_at(text, i, "=>") or starts_with_at(text, i, "#[") or starts_with_at(text, i, "#!") {
      let sym: string = slice(text, i, i + 2);
      set tokens = tokens + [token(TokenKind.Symbol, sym, line, start_col)];
      set i = i + 2;
      set col = col + 2;
      continue;
    }

    let sym: string = ch;
    let valid_symbol: bool =
      ch == "(" or ch == ")" or ch == "{" or ch == "}" or ch == "[" or ch == "]" or
      ch == "," or ch == ";" or ch == ":" or ch == "." or ch == "+" or ch == "-" or
      ch == "*" or ch == "/" or ch == "%" or ch == "=" or ch == "<" or ch == ">" or
      ch == "!" or ch == "&" or ch == "|" or ch == "^";
    if valid_symbol {
      set tokens = tokens + [token(TokenKind.Symbol, sym, line, col)];
    } else {
      set diagnostics = diagnostics + [lex_diag("LEX_E_INVALID_CHAR", "invalid character `" + sym + "`", line, col, true)];
      set tokens = tokens + [token(TokenKind.Invalid, sym, line, col)];
    }
    set i = i + 1;
    set col = col + 1;
  }

  set tokens = tokens + [token(TokenKind.Eof, "", line, col)];
  give scan_result(tokens, diagnostics);
}
