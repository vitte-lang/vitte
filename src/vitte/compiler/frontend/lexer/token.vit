space vitte/compiler/frontend/lexer/token

pick TokenKind {
  Eof,
  Ident,
  Keyword,
  String,
  Integer,
  Float,
  Char,
  Symbol,
  Invalid,
}

form Token {
  kind: TokenKind
  lexeme: string
  line: u64
  column: u64
}

proc token(kind: TokenKind, lexeme: string, line: u64, column: u64) -> Token {
  give Token { kind: kind, lexeme: lexeme, line: line, column: column };
}
