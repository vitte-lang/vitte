space vitte/compiler/frontend/mod

form FrontendManifest {
  stage: string,
  source_root: string,
  language: string
}

proc manifest() -> FrontendManifest {
  give FrontendManifest {
    stage: "bootstrap-vitte",
    source_root: "src/vitte/compiler/frontend",
    language: "vitte"
  }
}

proc source_of_truth() -> string {
  give manifest().source_root
}

proc bootstrap_language() -> string {
  give manifest().language
}

export *
