space vitte/compiler/frontend/token

pick TokenKind {
  Keyword,
  Ident,
  Number,
  String,
  Char,
  Symbol,
  Operator,
  Newline,
  Eof,
  Comment,
  Attribute,
  DocComment,
  Unknown
}

form Token {
  kind: TokenKind,
  text: string,
  line: int,
  column: int,
  length: int
}

proc new_token(kind: TokenKind, text: string, line: int, column: int) -> Token {
  give Token {
    kind: kind,
    text: text,
    line: line,
    column: column,
    length: text.len
  }
}

proc make_with_len(kind: TokenKind, text: string, line: int, column: int, length: int) -> Token {
  give Token {
    kind: kind,
    text: text,
    line: line,
    column: column,
    length: length
  }
}

proc eof(line: int, column: int) -> Token {
  give new_token(TokenKind.Eof, "", line, column)
}

proc newline(line: int, column: int) -> Token {
  give new_token(TokenKind.Newline, "\\n", line, column)
}

proc is_keyword_text(text: string) -> bool {
  if text == "space" { give true }
  if text == "use" { give true }
  if text == "export" { give true }
  if text == "const" { give true }
  if text == "static" { give true }
  if text == "global" { give true }
  if text == "type" { give true }
  if text == "opaque" { give true }
  if text == "extern" { give true }
  if text == "form" { give true }
  if text == "class" { give true }
  if text == "union" { give true }
  if text == "bits" { give true }
  if text == "pick" { give true }
  if text == "flags" { give true }
  if text == "trait" { give true }
  if text == "impl" { give true }
  if text == "proc" { give true }
  if text == "macro" { give true }
  if text == "comptime" { give true }
  if text == "static_assert" { give true }
  if text == "test" { give true }
  if text == "bench" { give true }
  if text == "entry" { give true }
  if text == "give" { give true }
  if text == "let" { give true }
  if text == "set" { give true }
  if text == "if" { give true }
  if text == "elif" { give true }
  if text == "else" { give true }
  if text == "while" { give true }
  if text == "loop" { give true }
  if text == "for" { give true }
  if text == "in" { give true }
  if text == "break" { give true }
  if text == "continue" { give true }
  if text == "return" { give true }
  if text == "emit" { give true }
  if text == "assert" { give true }
  if text == "panic" { give true }
  if text == "unreachable" { give true }
  if text == "true" { give true }
  if text == "false" { give true }
  if text == "null" { give true }
  if text == "and" { give true }
  if text == "or" { give true }
  if text == "not" { give true }
  if text == "as" { give true }
  if text == "is" { give true }
  if text == "where" { give true }
  give false
}

proc is_operator_text(text: string) -> bool {
  if text == "+" { give true }
  if text == "-" { give true }
  if text == "*" { give true }
  if text == "/" { give true }
  if text == "%" { give true }
  if text == "=" { give true }
  if text == "==" { give true }
  if text == "!=" { give true }
  if text == "<" { give true }
  if text == "<=" { give true }
  if text == ">" { give true }
  if text == ">=" { give true }
  if text == "&&" { give true }
  if text == "||" { give true }
  if text == "&" { give true }
  if text == "|" { give true }
  if text == "^" { give true }
  if text == "<<" { give true }
  if text == ">>" { give true }
  if text == "+=" { give true }
  if text == "-=" { give true }
  if text == "*=" { give true }
  if text == "/=" { give true }
  if text == "%=" { give true }
  give false
}

proc is_symbol_text(text: string) -> bool {
  if text == "{" { give true }
  if text == "}" { give true }
  if text == "(" { give true }
  if text == ")" { give true }
  if text == "[" { give true }
  if text == "]" { give true }
  if text == "," { give true }
  if text == ":" { give true }
  if text == ";" { give true }
  if text == "." { give true }
  give false
}

proc classify_word(text: string) -> TokenKind {
  if text == "" { give TokenKind.Unknown }

  if is_keyword_text(text) {
    give TokenKind.Keyword
  }

  let first: string = text[0] as string

  if first >= "0" and first <= "9" {
    give TokenKind.Number
  }

  if first == "\"" {
    give TokenKind.String
  }

  if first == "'" {
    give TokenKind.Char
  }

  give TokenKind.Ident
}

proc classify_symbol(text: string) -> TokenKind {
  if is_operator_text(text) {
    give TokenKind.Operator
  }

  if is_symbol_text(text) {
    give TokenKind.Symbol
  }

  give TokenKind.Unknown
}

proc is_identifier(value: Token) -> bool {
  give value.kind == TokenKind.Ident
}

proc is_keyword(value: Token) -> bool {
  give value.kind == TokenKind.Keyword
}

proc is_literal(value: Token) -> bool {
  give value.kind == TokenKind.Number or
       value.kind == TokenKind.String or
       value.kind == TokenKind.Char
}

proc is_eof(value: Token) -> bool {
  give value.kind == TokenKind.Eof
}

proc is_newline(value: Token) -> bool {
  give value.kind == TokenKind.Newline
}

proc debug_string(value: Token) -> string {
  give value.text
}

export *
