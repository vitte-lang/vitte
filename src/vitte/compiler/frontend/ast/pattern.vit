space vitte/compiler/frontend/ast/pattern

use vitte/compiler/frontend/ast/node.{ AstSpan, empty_span }

pick AstPatternKind {
  Bind,
  Constructor,
  Struct,
  Tuple,
  List,
  Range,
  Or,
  Mut,
  Ref,
  Wildcard,
  Literal,
  Raw,
  Unknown,
}

form AstPattern {
  kind: AstPatternKind
  text: string
  child_count: u64
  span: AstSpan
}

proc ast_pattern(kind: AstPatternKind, text: string) -> AstPattern {
  give AstPattern { kind: kind, text: text, child_count: 0, span: empty_span() };
}

proc pattern_kind_count() -> u64 {
  give 13;
}
