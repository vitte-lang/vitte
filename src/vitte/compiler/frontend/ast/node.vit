space vitte/compiler/frontend/ast/node

use vitte/compiler/source/span.{
  Span,
  merge_spans,
  span,
  span_contains,
  span_empty,
  span_height,
  span_is_empty,
  span_is_single_line,
  span_location,
  span_offsets,
  span_overlaps,
  span_range,
  span_summary,
  span_width
}

export *

form AstLoc {
  offset: u64
  line: u64
  column: u64
}

form AstId {
  value: u64
}

form AstNodeInfo {
  id: AstId
  span: Span
  kind: string
  valid: bool
}

proc ast_loc(offset: u64, line: u64, column: u64) -> AstLoc {
  give AstLoc {
    offset: offset,
    line: line,
    column: column
  };
}

proc ast_loc_empty() -> AstLoc {
  give ast_loc(0, 1, 1);
}

proc ast_id(value: u64) -> AstId {
  give AstId {
    value: value
  };
}

proc ast_id_empty() -> AstId {
  give ast_id(0);
}

proc ast_span(file: string, start_line: u64, start_column: u64, end_line: u64, end_column: u64) -> Span {
  give span(file, start_line, start_column, end_line, end_column);
}

proc ast_span_offsets(file: string, start_offset: u64, end_offset: u64, start_line: u64, start_column: u64, end_line: u64, end_column: u64) -> Span {
  give span_offsets(file, start_offset, end_offset, start_line, start_column, end_line, end_column);
}

proc ast_span_from_locs(file: string, start: AstLoc, end0: AstLoc) -> Span {
  give ast_span_offsets(file, start.offset, end0.offset, start.line, start.column, end0.line, end0.column);
}

proc ast_span_empty() -> Span {
  give span_empty();
}

proc ast_node_info(id: AstId, span: Span, kind: string, valid: bool) -> AstNodeInfo {
  give AstNodeInfo {
    id: id,
    span: span,
    kind: kind,
    valid: valid
  };
}

proc ast_node_info_empty() -> AstNodeInfo {
  give ast_node_info(
    ast_id_empty(),
    ast_span_empty(),
    "",
    false
  );
}

proc ast_node_summary(node: AstNodeInfo) -> string {
  let id: string = node.id.value as string;
  let valid_text: string = node.valid as string;
  give "id " + id + " kind " + node.kind + " location " + span_location(node.span) + " valid " + valid_text;
}

proc ast_node_selftest() -> bool {
  let s0: Span = ast_span("main.vit", 1, 1, 1, 10);
  let s1: Span = ast_span("main.vit", 1, 5, 2, 4);
  let merged: Span = merge_spans(s0, s1);
  let node: AstNodeInfo = ast_node_info(ast_id(1), merged, "proc", true);

  give s0.valid
    and span_is_single_line(s0)
    and span_contains(s0, 1, 4)
    and span_overlaps(s0, s1)
    and span_width(merged) > 0
    and span_height(merged) > 0
    and span_summary(merged) != ""
    and ast_node_summary(node) != "";
}
