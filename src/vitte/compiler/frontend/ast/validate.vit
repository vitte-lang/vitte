space vitte/compiler/frontend/ast/validate

use vitte/compiler/frontend/ast/node.{ AstModule }

form AstValidation {
  root: string
  valid: bool
  message: string
}

proc validate_ast_root(root: AstModule) -> AstValidation {
  if not root.valid {
    give AstValidation { root: "invalid", valid: false, message: "invalid ast module" };
  }
  give AstValidation { root: root.kind, valid: true, message: "ok" };
}
