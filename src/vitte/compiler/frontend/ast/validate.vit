space vitte/compiler/frontend/ast/validate

form AstValidation {
  root: string
  valid: bool
  message: string
}

proc validate_ast_root(root: string) -> AstValidation {
  if root == "" or root == "invalid" {
    give AstValidation { root: root, valid: false, message: "invalid ast root" };
  }
  give AstValidation { root: root, valid: true, message: "ok" };
}
