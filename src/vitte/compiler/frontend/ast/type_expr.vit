space vitte/compiler/frontend/ast/type_expr

use vitte/compiler/frontend/ast/node.{ AstSpan, empty_span }

pick AstTypeKind {
  Named,
  Primitive,
  Qualified,
  Reference,
  Pointer,
  Optional,
  FixedArray,
  Slice,
  Tuple,
  Proc,
  Dyn,
  ImplTrait,
  Generic,
  Union,
  Lifetime,
  Raw,
  Unknown,
}

form AstTypeExpr {
  kind: AstTypeKind
  text: string
  qualifier_text: string
  child_count: u64
  span: AstSpan
}

proc ast_type_expr(kind: AstTypeKind, text: string) -> AstTypeExpr {
  give AstTypeExpr {
    kind: kind,
    text: text,
    qualifier_text: "",
    child_count: 0,
    span: empty_span()
  };
}

proc type_kind_count() -> u64 {
  give 17;
}
