space vitte/compiler/frontend/ast/type_expr

use vitte/compiler/frontend/ast/node.{ AstId, AstSpan, ast_id, ast_span_empty }

pick AstTypeKind {
  Unknown,
  Name,
  Primitive,
  Pointer,
  Reference,
  MutableRef,
  Array,
  Slice,
  Tuple,
  Proc,
  Generic,
  Qualified,
  Union,
  Optional,
  Dyn,
  Impl,
}

form AstTypeExpr {
  id: AstId
  span: AstSpan
  kind: AstTypeKind
  text: string
  name: string
  children: [AstTypeExpr]
  mutable: bool
  valid: bool
}

proc ast_type_expr(id: u64, span: AstSpan, text: string) -> AstTypeExpr {
  let kind: AstTypeKind = AstTypeKind.Unknown;
  let name: string = "";
  if text != "" {
    set kind = AstTypeKind.Name;
    set name = text;
  }
  give AstTypeExpr { id: ast_id(id), span: span, kind: kind, text: text, name: name, children: [], mutable: false, valid: text != "" };
}

proc ast_type_node(id: u64, span: AstSpan, kind: AstTypeKind, text: string, name: string, children: [AstTypeExpr], mutable: bool) -> AstTypeExpr {
  give AstTypeExpr { id: ast_id(id), span: span, kind: kind, text: text, name: name, children: children, mutable: mutable, valid: true };
}

proc ast_type_empty() -> AstTypeExpr {
  give AstTypeExpr { id: ast_id(0), span: ast_span_empty(), kind: AstTypeKind.Unknown, text: "", name: "", children: [], mutable: false, valid: false };
}
