space vitte/compiler/frontend/ast/pretty

use vitte/compiler/frontend/ast/expr.{ AstExpr, AstExprKind }
use vitte/compiler/frontend/ast/item.{ AstGenericParam, AstItem, AstItemKind, AstModule, AstParam, AstProcSignature }
use vitte/compiler/frontend/ast/pattern.{ AstPattern, AstPatternKind }
use vitte/compiler/frontend/ast/stmt.{ AstStmt, AstStmtKind }
use vitte/compiler/frontend/ast/type_expr.{ AstTypeExpr, AstTypeKind }

proc indent(level: u64) -> string {
  let out: string = "";
  let i: u64 = 0;
  while i < level {
    set out = out + "  ";
    set i = i + 1;
  }
  give out;
}

proc type_kind_name(kind: AstTypeKind) -> string {
  if kind == AstTypeKind.Name {
    give "name";
  }
  if kind == AstTypeKind.Primitive {
    give "primitive";
  }
  if kind == AstTypeKind.Pointer {
    give "pointer";
  }
  if kind == AstTypeKind.Reference {
    give "ref";
  }
  if kind == AstTypeKind.MutableRef {
    give "mut-ref";
  }
  if kind == AstTypeKind.Array {
    give "array";
  }
  if kind == AstTypeKind.Slice {
    give "slice";
  }
  if kind == AstTypeKind.Tuple {
    give "tuple";
  }
  if kind == AstTypeKind.Proc {
    give "proc";
  }
  if kind == AstTypeKind.Generic {
    give "generic";
  }
  if kind == AstTypeKind.Qualified {
    give "qualified";
  }
  if kind == AstTypeKind.Union {
    give "union";
  }
  if kind == AstTypeKind.Optional {
    give "optional";
  }
  if kind == AstTypeKind.Dyn {
    give "dyn";
  }
  if kind == AstTypeKind.Impl {
    give "impl";
  }
  give "unknown";
}

