proc pretty_type_expr(node: AstTypeExpr, level: u64) -> string {
  let out: string = indent(level) + "type " + type_kind_name(node.kind) + " " + node.text;
  let i: u64 = 0;
  while i < len(node.children) {
    set out = out + "\n" + pretty_type_expr(node.children[i], level + 1);
    set i = i + 1;
  }
  give out;
}

proc pretty_pattern(node: AstPattern, level: u64) -> string {
  let out: string = indent(level) + "pattern " + pattern_kind_name(node.kind) + " " + node.text;
  let i: u64 = 0;
  while i < len(node.children) {
    set out = out + "\n" + pretty_pattern(node.children[i], level + 1);
    set i = i + 1;
  }
  give out;
}

proc pretty_expr(node: AstExpr, level: u64) -> string {
  let label: string = expr_kind_name(node.kind);
  let head: string = node.text;
  if node.binding_name != "" {
    set head = node.binding_name;
  } elif node.member_name != "" {
    set head = node.member_name;
  } elif node.name != "" {
    set head = node.name;
  }
  let out: string = indent(level) + "expr " + label + " " + head;
  let i: u64 = 0;
  while i < len(node.children) {
    set out = out + "\n" + pretty_expr(node.children[i], level + 1);
    set i = i + 1;
  }
  give out;
}

proc pretty_generic_param(node: AstGenericParam, level: u64) -> string {
  let out: string = indent(level) + "generic " + node.kind + " " + node.name;
  let child_level: u64 = level + 1;
  let grandchild_level: u64 = level + 2;
  if node.bound.valid {
    set out = out + "\n" + pretty_type_expr(node.bound, child_level);
  }
  if node.default_type.valid {
    set out = out + "\n" + indent(child_level) + "default";
    set out = out + "\n" + pretty_type_expr(node.default_type, grandchild_level);
  }
  give out;
}

proc pretty_param(node: AstParam, level: u64) -> string {
  let out: string = indent(level) + "param mode " + node.mode;
  if node.variadic {
    set out = out + " variadic";
  }
  set out = out + "\n" + pretty_pattern(node.pattern, level + 1);
  if node.annotation.valid {
    set out = out + "\n" + pretty_type_expr(node.annotation, level + 1);
  }
  if node.default_value.valid {
    set out = out + "\n" + pretty_expr(node.default_value, level + 1);
  }
  give out;
}

proc pretty_signature(node: AstProcSignature, level: u64) -> string {
  let out: string = indent(level) + "signature " + node.name;
  let child_level: u64 = level + 1;
  let grandchild_level: u64 = level + 2;
  if node.abi != "" {
    set out = out + " abi " + node.abi;
  }
  if node.noexcept {
    set out = out + " noexcept";
  }
  let i: u64 = 0;
  while i < len(node.generic_params) {
    set out = out + "\n" + pretty_generic_param(node.generic_params[i], child_level);
    set i = i + 1;
  }
  i = 0;
  while i < len(node.params) {
    set out = out + "\n" + pretty_param(node.params[i], child_level);
    set i = i + 1;
  }
  if node.return_type.valid {
    set out = out + "\n" + indent(child_level) + "return";
    set out = out + "\n" + pretty_type_expr(node.return_type, grandchild_level);
  }
  i = 0;
  while i < len(node.where_clauses) {
    set out = out + "\n" + indent(child_level) + "where " + node.where_clauses[i];
    set i = i + 1;
  }
  i = 0;
  while i < len(node.effects) {
    set out = out + "\n" + indent(child_level) + "effect " + node.effects[i];
    set i = i + 1;
  }
  i = 0;
  while i < len(node.requires) {
    set out = out + "\n" + indent(child_level) + "requires " + node.requires[i];
    set i = i + 1;
  }
  give out;
}

proc pretty_stmt(node: AstStmt, level: u64) -> string {
  let out: string = indent(level) + "stmt " + stmt_kind_name(node.kind);
  if node.pattern.valid {
    set out = out + "\n" + pretty_pattern(node.pattern, level + 1);
  }
  if node.target_expr.valid {
    set out = out + "\n" + pretty_expr(node.target_expr, level + 1);
  }
  if node.expr.valid {
    set out = out + "\n" + pretty_expr(node.expr, level + 1);
  }
  if node.annotation.valid {
    set out = out + "\n" + pretty_type_expr(node.annotation, level + 1);
  }
  let i: u64 = 0;
  while i < len(node.then_stmts) {
    set out = out + "\n" + pretty_stmt(node.then_stmts[i], level + 1);
    set i = i + 1;
  }
  i = 0;
  while i < len(node.else_stmts) {
    set out = out + "\n" + pretty_stmt(node.else_stmts[i], level + 1);
    set i = i + 1;
  }
  give out;
}

proc pretty_item(node: AstItem, level: u64) -> string {
  let out: string = indent(level) + "item " + item_kind_name(node) + " " + node.name;
  let child_level: u64 = level + 1;
  let grandchild_level: u64 = level + 2;
  if node.visibility != "" {
    set out = out + " visibility " + node.visibility;
  }
  if node.abi != "" {
    set out = out + " abi " + node.abi;
  }
  let i: u64 = 0;
  while i < len(node.attributes) {
    set out = out + "\n" + indent(child_level) + "attr " + node.attributes[i];
    set i = i + 1;
  }
  i = 0;
  while i < len(node.modifiers) {
    set out = out + "\n" + indent(child_level) + "modifier " + node.modifiers[i];
    set i = i + 1;
  }
  if node.signature.valid {
    set out = out + "\n" + pretty_signature(node.signature, child_level);
  }
  if node.annotation.valid {
    set out = out + "\n" + pretty_type_expr(node.annotation, child_level);
  }
  if node.target_type.valid {
    set out = out + "\n" + indent(child_level) + "target";
    set out = out + "\n" + pretty_type_expr(node.target_type, grandchild_level);
  }
  if node.expr.valid {
    set out = out + "\n" + pretty_expr(node.expr, child_level);
  }
  i = 0;
  while i < len(node.stmts) {
    set out = out + "\n" + pretty_stmt(node.stmts[i], child_level);
    set i = i + 1;
  }
  i = 0;
  while i < len(node.meta_args) {
    set out = out + "\n" + indent(child_level) + "meta " + node.meta_args[i];
    set i = i + 1;
  }
  give out;
}

proc ast_pretty_module(module0: AstModule) -> string {
  let out: string = "module " + module0.kind;
  let i: u64 = 0;
  while i < len(module0.items) {
    set out = out + "\n" + pretty_item(module0.items[i], 1);
    set i = i + 1;
  }
  give out;
}
