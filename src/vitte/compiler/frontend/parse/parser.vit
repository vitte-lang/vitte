space vitte/compiler/frontend/parse/parser

use vitte/compiler/frontend/lexer/token.{ Token, TokenKind, token }
use vitte/compiler/frontend/parse/errors.{ ParseDiagnostic, parse_error_with_span }
use vitte/compiler/frontend/parse/recovery.{ recover_decl_index, recover_expr_index, recover_pattern_index, recover_stmt_index, recover_type_index }
use vitte/compiler/frontend/ast/node.{ AstSpan, ast_span }
use vitte/compiler/frontend/ast/expr.{ AstExpr, AstExprKind, ast_expr_binary, ast_expr_call, ast_expr_index, ast_expr_leaf, ast_expr_member, ast_expr_node, ast_expr_typed, ast_expr_unary, ast_expr_unknown }
use vitte/compiler/frontend/ast/item.{ AstGenericParam, AstItem, AstItemKind, AstModule, AstNominalMember, AstNominalMemberKind, AstParam, AstProcSignature, ast_generic_param, ast_generic_param_empty, ast_item_create, ast_item_typed, ast_item_typed_with_members, ast_module, ast_module_empty, ast_nominal_member, ast_param, ast_param_empty, ast_proc_signature, ast_proc_signature_empty, count_module_exprs, count_module_patterns, count_module_stmts, count_module_types }
use vitte/compiler/frontend/ast/pattern.{ AstPattern, AstPatternKind, ast_pattern, ast_pattern_empty, ast_pattern_node }
use vitte/compiler/frontend/ast/stmt.{ AstStmt, AstStmtKind, ast_stmt_conditional, ast_stmt_create, ast_stmt_targeted }
use vitte/compiler/frontend/ast/type_expr.{ AstTypeExpr, AstTypeKind, ast_type_empty, ast_type_expr, ast_type_node }

form ParseResult {
  grammar_version: string
  ast_root: AstModule
  toplevel_count: u64
  stmt_count: u64
  expr_count: u64
  type_count: u64
  pattern_count: u64
  recovery_count: u64
  diagnostics: [ParseDiagnostic]
  valid: bool
}

form ParserState {
  source_name: string
  tokens: [Token]
  index: u64
  toplevel_count: u64
  stmt_count: u64
  expr_count: u64
  type_count: u64
  pattern_count: u64
  recovery_count: u64
  diagnostics: [ParseDiagnostic]
}

proc parse_diag(code: string, message: string, line: u64, column: u64, width: u64) -> ParseDiagnostic {
  give parse_error_with_span(code, message, line, column, width, 0, if width == 0 { 1 } else { width });
}

proc parser_state(source_name: string, tokens: [Token]) -> ParserState {
  give ParserState {
    source_name: source_name,
    tokens: tokens,
    index: 0,
    toplevel_count: 0,
    stmt_count: 0,
    expr_count: 0,
    type_count: 0,
    pattern_count: 0,
    recovery_count: 0,
    diagnostics: []
  };
}

proc token_diag_width(tok: Token) -> u64 {
  if len(tok.lexeme) == 0 {
    give 1;
  }
  give len(tok.lexeme);
}

proc last_token(tokens: [Token]) -> Token {
  if len(tokens) == 0 {
    give token(TokenKind.Eof, "", 1, 1);
  }
  give tokens[len(tokens) - 1];
}

proc current_token(state: ParserState) -> Token {
  if state.index < len(state.tokens) {
    give state.tokens[state.index];
  }
  give last_token(state.tokens);
}

proc peek_token(state: ParserState, offset: u64) -> Token {
  let target: u64 = state.index + offset;
  if target < len(state.tokens) {
    give state.tokens[target];
  }
  give last_token(state.tokens);
}

proc is_eof(state: ParserState) -> bool {
  give current_token(state).kind == TokenKind.Eof;
}

proc advance(state: ParserState) -> ParserState {
  if state.index < len(state.tokens) {
    give ParserState {
      source_name: state.source_name,
      tokens: state.tokens,
      index: state.index + 1,
      toplevel_count: state.toplevel_count,
      stmt_count: state.stmt_count,
      expr_count: state.expr_count,
      type_count: state.type_count,
      pattern_count: state.pattern_count,
      recovery_count: state.recovery_count,
      diagnostics: state.diagnostics
    };
  }
  give state;
}

proc with_diag(state: ParserState, code: string, message: string) -> ParserState {
  let tok: Token = current_token(state);
  let width0: u64 = token_diag_width(tok);
  let ds: [ParseDiagnostic] = state.diagnostics + [parse_error_with_span(code, message, tok.line, tok.column, width0, tok.offset, tok.offset + width0)];
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: state.index,
    toplevel_count: state.toplevel_count,
    stmt_count: state.stmt_count,
    expr_count: state.expr_count,
    type_count: state.type_count,
    pattern_count: state.pattern_count,
    recovery_count: state.recovery_count,
    diagnostics: ds
  };
}

proc with_index_and_recovery(state: ParserState, index: u64, recovered: bool) -> ParserState {
  let next_recovery_count: u64 = state.recovery_count;
  if recovered {
    set next_recovery_count = next_recovery_count + 1;
  }
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: index,
    toplevel_count: state.toplevel_count,
    stmt_count: state.stmt_count,
    expr_count: state.expr_count,
    type_count: state.type_count,
    pattern_count: state.pattern_count,
    recovery_count: next_recovery_count,
    diagnostics: state.diagnostics
  };
}

proc bump_toplevel(state: ParserState) -> ParserState {
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: state.index,
    toplevel_count: state.toplevel_count + 1,
    stmt_count: state.stmt_count,
    expr_count: state.expr_count,
    type_count: state.type_count,
    pattern_count: state.pattern_count,
    recovery_count: state.recovery_count,
    diagnostics: state.diagnostics
  };
}

proc bump_stmt(state: ParserState) -> ParserState {
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: state.index,
    toplevel_count: state.toplevel_count,
    stmt_count: state.stmt_count + 1,
    expr_count: state.expr_count,
    type_count: state.type_count,
    pattern_count: state.pattern_count,
    recovery_count: state.recovery_count,
    diagnostics: state.diagnostics
  };
}

proc bump_expr(state: ParserState) -> ParserState {
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: state.index,
    toplevel_count: state.toplevel_count,
    stmt_count: state.stmt_count,
    expr_count: state.expr_count + 1,
    type_count: state.type_count,
    pattern_count: state.pattern_count,
    recovery_count: state.recovery_count,
    diagnostics: state.diagnostics
  };
}

proc bump_type(state: ParserState) -> ParserState {
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: state.index,
    toplevel_count: state.toplevel_count,
    stmt_count: state.stmt_count,
    expr_count: state.expr_count,
    type_count: state.type_count + 1,
    pattern_count: state.pattern_count,
    recovery_count: state.recovery_count,
    diagnostics: state.diagnostics
  };
}

proc bump_pattern(state: ParserState) -> ParserState {
  give ParserState {
    source_name: state.source_name,
    tokens: state.tokens,
    index: state.index,
    toplevel_count: state.toplevel_count,
    stmt_count: state.stmt_count,
    expr_count: state.expr_count,
    type_count: state.type_count,
    pattern_count: state.pattern_count + 1,
    recovery_count: state.recovery_count,
    diagnostics: state.diagnostics
  };
}

proc recover_stmt_state(state: ParserState) -> ParserState {
  let index: u64 = recover_stmt_index(state.tokens, state.index);
  if index == state.index {
    give state;
  }
  give with_index_and_recovery(state, index, true);
}

proc recover_decl_state(state: ParserState) -> ParserState {
  let index: u64 = recover_decl_index(state.tokens, state.index);
  if index == state.index {
    give state;
  }
  give with_index_and_recovery(state, index, true);
}

proc recover_expr_state(state: ParserState) -> ParserState {
  let index: u64 = recover_expr_index(state.tokens, state.index);
  if index == state.index {
    give state;
  }
  give with_index_and_recovery(state, index, true);
}

proc recover_type_state(state: ParserState) -> ParserState {
  let index: u64 = recover_type_index(state.tokens, state.index);
  if index == state.index {
    give state;
  }
  give with_index_and_recovery(state, index, true);
}

proc recover_pattern_state(state: ParserState) -> ParserState {
  let index: u64 = recover_pattern_index(state.tokens, state.index);
  if index == state.index {
    give state;
  }
  give with_index_and_recovery(state, index, true);
}

proc at_text(state: ParserState, text: string) -> bool {
  give current_token(state).lexeme == text;
}

proc next_is_text(state: ParserState, text: string) -> bool {
  give peek_token(state, 1).lexeme == text;
}

proc at_kind(state: ParserState, kind: TokenKind) -> bool {
  give current_token(state).kind == kind;
}

proc is_ident_like(tok: Token) -> bool {
  give tok.kind == TokenKind.Ident or tok.kind == TokenKind.Keyword;
}

proc expect_text(state: ParserState, text: string, code: string) -> ParserState {
  if at_text(state, text) {
    give advance(state);
  }
  give with_diag(state, code, "expected `" + text + "`");
}

proc expect_ident(state: ParserState, code: string) -> ParserState {
  if is_ident_like(current_token(state)) {
    give advance(state);
  }
  give with_diag(state, code, "expected identifier");
}

proc optional_text(state: ParserState, text: string) -> ParserState {
  if at_text(state, text) {
    give advance(state);
  }
  give state;
}

proc is_toplevel_keyword(lex: string) -> bool {
  if lex == "space" or lex == "use" or lex == "export" or lex == "const" or lex == "static" or lex == "global" {
    give true;
  }
  if lex == "type" or lex == "opaque" or lex == "extern" or lex == "form" or lex == "class" or lex == "union" {
    give true;
  }
  if lex == "bits" or lex == "pick" or lex == "flags" or lex == "trait" or lex == "impl" or lex == "proc" {
    give true;
  }
  if lex == "intrinsic" or lex == "compiler" or lex == "query" or lex == "pass" or lex == "backend" {
    give true;
  }
  if lex == "diagnostic" or lex == "macro" or lex == "comptime" or lex == "static_assert" or lex == "test" or lex == "bench" or lex == "entry" {
    give true;
  }
  give false;
}

proc is_visibility(lex: string) -> bool {
  give lex == "pub" or lex == "priv";
}

proc is_proc_modifier(lex: string) -> bool {
  if lex == "async" or lex == "unsafe" or lex == "const" or lex == "inline" {
    give true;
  }
  if lex == "noinline" or lex == "naked" or lex == "interrupt" {
    give true;
  }
  give false;
}

proc is_literal_token(tok: Token) -> bool {
  if tok.kind == TokenKind.Integer or tok.kind == TokenKind.Float or tok.kind == TokenKind.String or tok.kind == TokenKind.Char {
    give true;
  }
  if tok.lexeme == "true" or tok.lexeme == "false" or tok.lexeme == "null" {
    give true;
  }
  give false;
}

proc skip_until_boundary(state: ParserState, a: string, b: string, c: string) -> ParserState {
  let current: ParserState = state;
  while not is_eof(current) {
    if a != "" and at_text(current, a) {
      give current;
    }
    if b != "" and at_text(current, b) {
      give current;
    }
    if c != "" and at_text(current, c) {
      give current;
    }
    set current = advance(current);
  }
  give current;
}

proc skip_balanced(state: ParserState, open_text: string, close_text: string, code: string) -> ParserState {
  let current: ParserState = expect_text(state, open_text, code);
  let depth: u64 = 1;
  while depth > 0 and not is_eof(current) {
    if at_text(current, open_text) {
      set depth = depth + 1;
      set current = advance(current);
      continue;
    }
    if at_text(current, close_text) {
      set depth = depth - 1;
      set current = advance(current);
      continue;
    }
    set current = advance(current);
  }
  if depth != 0 {
    give with_diag(current, "P000_UNBALANCED", "unclosed `" + open_text + "` block");
  }
  give current;
}

proc parse_path(state: ParserState) -> ParserState {
  let current: ParserState = expect_ident(state, "PPATH001");
  while at_text(current, ".") or at_text(current, "/") or at_text(current, "::") {
    if at_text(current, ".") and (next_is_text(current, "{") or next_is_text(current, "*")) {
      give current;
    }
    set current = advance(current);
    set current = expect_ident(current, "PPATH002");
  }
  give current;
}

proc parse_module_path(state: ParserState) -> ParserState {
  let current: ParserState = state;
  while at_text(current, ".") {
    set current = advance(current);
  }
  give parse_path(current);
}

proc parse_generic_params(state: ParserState) -> ParserState {
  if not at_text(state, "[") {
    give state;
  }
  let current: ParserState = advance(state);
  while not is_eof(current) and not at_text(current, "]") {
    if at_text(current, ",") {
      set current = advance(current);
      continue;
    }
    if at_text(current, "const") or at_text(current, "comptime") {
      set current = advance(current);
      set current = expect_ident(current, "PGEN001");
    } else {
      set current = expect_ident(current, "PGEN002");
    }
    if at_text(current, ":") {
      set current = advance(current);
      set current = parse_type_expr(current);
    }
    if at_text(current, assign_op_eq()) {
      set current = advance(current);
      set current = parse_type_expr(current);
    }
  }
  give expect_text(current, "]", "PGEN003");
}


proc parse_attrs(state: ParserState) -> ParserState {
  let current: ParserState = state;
  while at_text(current, "#[") or at_text(current, "#!") {
    set current = advance(current);
    set current = parse_path(current);
    if at_text(current, "(") {
      set current = skip_balanced(current, "(", ")", "PATTR001");
    }
    set current = expect_text(current, "]", "PATTR002");
  }
  give current;
}

proc assign_op_eq() -> string {
  give slice("=x", 0, 1);
}

proc assign_op_add() -> string {
  give slice("+=x", 0, 2);
}

proc assign_op_sub() -> string {
  give slice("-=x", 0, 2);
}

proc assign_op_mul() -> string {
  give slice("*=x", 0, 2);
}

proc assign_op_div() -> string {
  give slice("/=x", 0, 2);
}

proc assign_op_mod() -> string {
  give slice("%=x", 0, 2);
}

proc assign_op_and() -> string {
  give slice("&=x", 0, 2);
}

proc assign_op_or() -> string {
  give slice("|=x", 0, 2);
}

proc assign_op_xor() -> string {
  give slice("^=x", 0, 2);
}

proc assign_op_shl() -> string {
  give slice("<<=x", 0, 3);
}

proc assign_op_shr() -> string {
  give slice(">>=x", 0, 3);
}

proc op_eqeq() -> string {
  give slice("===x", 0, 2);
}

proc op_noteq() -> string {
  give slice("!==x", 0, 2);
}

proc op_lte() -> string {
  give slice("<=x", 0, 2);
}

proc op_gte() -> string {
  give slice(">=x", 0, 2);
}

proc op_range_inclusive() -> string {
  give slice("..=x", 0, 3);
}

proc parse_param_list(state: ParserState, closing: string) -> ParserState {
  let current: ParserState = state;
  while not is_eof(current) and not at_text(current, closing) {
    if at_text(current, "...") {
      set current = advance(current);
    } else {
      if at_text(current, "&") {
        set current = advance(current);
      }
      if at_text(current, "mut") or at_text(current, "owned") or at_text(current, "borrow") or at_text(current, "move") {
        set current = advance(current);
      }
      if at_text(current, "self") {
        set current = advance(current);
      } else {
        set current = parse_pattern(current);
      }
      if at_text(current, ":") {
        set current = advance(current);
        if at_text(current, "...") {
          set current = advance(current);
        }
        set current = parse_type_expr(current);
      }
    if at_text(current, assign_op_eq()) {
        set current = advance(current);
        set current = parse_expr(current);
      }
    }
    if at_text(current, ",") {
      set current = advance(current);
    } else {
      break;
    }
  }
  give current;
}

proc parse_proc_suffixes(state: ParserState) -> ParserState {
  let current: ParserState = state;
  while true {
    if at_text(current, "effects") or at_text(current, "requires") {
      set current = advance(current);
      set current = skip_balanced(current, "(", ")", "PSFX001");
      continue;
    }
    if at_text(current, "where") {
      set current = advance(current);
      while not is_eof(current) and not at_text(current, "{") and not at_text(current, ";") {
        if at_text(current, ",") {
          set current = advance(current);
        } else {
          set current = parse_type_expr(current);
          if at_text(current, ":") or at_text(current, op_eqeq()) {
            set current = advance(current);
            set current = parse_type_expr(current);
          }
        }
      }
      continue;
    }
    if at_text(current, "noexcept") {
      set current = advance(current);
      continue;
    }
    break;
  }
  give current;
}

proc parse_proc_decl(state: ParserState) -> ParserState {
  let current: ParserState = state;
  while is_visibility(current_token(current).lexeme) or is_proc_modifier(current_token(current).lexeme) or at_text(current, "extern") {
    let lex: string = current_token(current).lexeme;
    set current = advance(current);
    if lex == "pub" and at_text(current, "(") {
      set current = skip_balanced(current, "(", ")", "PVIS001");
    }
    if lex == "extern" and (at_kind(current, TokenKind.String) or at_text(current, "C") or at_text(current, "sysv64") or at_text(current, "win64")) {
      set current = advance(current);
    }
  }
  set current = expect_text(current, "proc", "PPROC001");
  if at_text(current, "operator") {
    set current = advance(current);
    if not is_eof(current) {
      set current = advance(current);
    }
  } else {
    set current = expect_ident(current, "PPROC002");
  }
  set current = parse_generic_params(current);
  set current = expect_text(current, "(", "PPROC003");
  set current = parse_param_list(current, ")");
  set current = expect_text(current, ")", "PPROC004");
  if at_text(current, "->") {
    set current = advance(current);
    set current = parse_type_expr(current);
  }
  set current = parse_proc_suffixes(current);
  if at_text(current, "{") {
    give parse_block(current);
  }
  give expect_text(current, ";", "PPROC005");
}

proc parse_type_primary(state: ParserState) -> ParserState {
  let current: ParserState = state;
  if at_text(current, "[") {
    set current = advance(current);
    set current = parse_type_expr(current);
    if at_text(current, ";") {
      set current = advance(current);
      set current = parse_expr(current);
    }
    give expect_text(current, "]", "PTYPE001");
  }
  if at_text(current, "(") {
    set current = advance(current);
    set current = parse_type_expr(current);
    if at_text(current, ",") {
      while at_text(current, ",") {
        set current = advance(current);
        if at_text(current, ")") {
          break;
        }
        set current = parse_type_expr(current);
      }
    }
    give expect_text(current, ")", "PTYPE002");
  }
  if at_text(current, "proc") {
    set current = advance(current);
    set current = expect_text(current, "(", "PTYPE003");
    set current = parse_param_list(current, ")");
    set current = expect_text(current, ")", "PTYPE004");
    if at_text(current, "->") {
      set current = advance(current);
      set current = parse_type_expr(current);
    }
    give current;
  }
  if at_text(current, "dyn") or at_text(current, "impl") {
    set current = advance(current);
    set current = parse_type_expr(current);
    while at_text(current, "+") {
      set current = advance(current);
      set current = parse_type_expr(current);
    }
    give current;
  }
  set current = parse_path(current);
  if at_text(current, "[") {
    set current = advance(current);
    while not is_eof(current) and not at_text(current, "]") {
      if at_text(current, ",") {
        set current = advance(current);
      } else {
        set current = parse_type_expr(current);
      }
    }
    set current = expect_text(current, "]", "PTYPE005");
  }
  give current;
}

proc parse_type_expr(state: ParserState) -> ParserState {
  let start_index: u64 = state.index;
  let start_diags: u64 = len(state.diagnostics);
  let current: ParserState = bump_type(state);
  while at_text(current, "const") or at_text(current, "volatile") or at_text(current, "atomic") or at_text(current, "mut") or at_text(current, "owned") or at_text(current, "borrow") or at_text(current, "user") or at_text(current, "kernel") or at_text(current, "phys") or at_text(current, "mmio") or at_text(current, "dma") {
    set current = advance(current);
  }
  if at_text(current, "&") {
    set current = advance(current);
    if current_token(current).kind == TokenKind.Symbol and len(current_token(current).lexeme) == 1 {
      set current = advance(current);
      set current = expect_ident(current, "PTYPE006");
    }
    if at_text(current, "mut") {
      set current = advance(current);
    }
    give parse_type_expr(current);
  }
  if at_text(current, "*") or at_text(current, "?") {
    set current = advance(current);
    give parse_type_expr(current);
  }
  set current = parse_type_primary(current);
  while at_text(current, "|") {
    set current = advance(current);
    set current = parse_type_primary(current);
  }
  if len(current.diagnostics) > start_diags and current.index == start_index {
    let recovered: ParserState = recover_type_state(current);
    if recovered.index == current.index and not is_eof(current) {
      give advance(current);
    }
    give recovered;
  }
  give current;
}

proc parse_pattern_atom(state: ParserState) -> ParserState {
  let current: ParserState = state;
  if at_text(current, "_") or is_literal_token(current_token(current)) {
    set current = advance(current);
    if at_text(current, "..") or at_text(current, op_range_inclusive()) {
      set current = advance(current);
      if is_literal_token(current_token(current)) {
        set current = advance(current);
      } else {
        set current = with_diag(current, "PPAT001", "expected range end literal");
      }
    }
    give current;
  }
  if at_text(current, "mut") or at_text(current, "ref") {
    set current = advance(current);
    give expect_ident(current, "PPAT002");
  }
  if at_text(current, "(") {
    set current = advance(current);
    set current = parse_pattern(current);
    if at_text(current, ",") {
      while at_text(current, ",") {
        set current = advance(current);
        if at_text(current, ")") {
          break;
        }
        set current = parse_pattern(current);
      }
    }
    give expect_text(current, ")", "PPAT003");
  }
  if at_text(current, "[") {
    set current = advance(current);
    while not is_eof(current) and not at_text(current, "]") {
      if at_text(current, ",") {
        set current = advance(current);
      } else {
        set current = parse_pattern(current);
      }
    }
    give expect_text(current, "]", "PPAT004");
  }
  set current = parse_path(current);
  if at_text(current, "(") {
    set current = advance(current);
    while not is_eof(current) and not at_text(current, ")") {
      if at_text(current, ",") {
        set current = advance(current);
      } else {
        set current = parse_pattern(current);
      }
    }
    give expect_text(current, ")", "PPAT005");
  }
  if at_text(current, "{") {
    set current = advance(current);
    while not is_eof(current) and not at_text(current, "}") {
      if at_text(current, ",") {
        set current = advance(current);
      } elif at_text(current, "..") {
        set current = advance(current);
      } else {
        set current = expect_ident(current, "PPAT006");
        if at_text(current, ":") {
          set current = advance(current);
          set current = parse_pattern(current);
        }
      }
    }
    give expect_text(current, "}", "PPAT007");
  }
  give current;
}

proc parse_pattern(state: ParserState) -> ParserState {
  let start_index: u64 = state.index;
  let start_diags: u64 = len(state.diagnostics);
  let current: ParserState = bump_pattern(state);
  set current = parse_pattern_atom(current);
  while at_text(current, "|") {
    set current = advance(current);
    set current = parse_pattern_atom(current);
  }
  if len(current.diagnostics) > start_diags and current.index == start_index {
    let recovered: ParserState = recover_pattern_state(current);
    if recovered.index == current.index and not is_eof(current) {
      give advance(current);
    }
    give recovered;
  }
  give current;
}

proc path_starts_struct_literal(state: ParserState) -> bool {
  if not at_text(state, "{") {
    give false;
  }
  let first: Token = peek_token(state, 1);
  let second: Token = peek_token(state, 2);
  if first.lexeme == "}" or first.lexeme == ".." {
    give true;
  }
  if not is_ident_like(first) {
    give false;
  }
  give second.lexeme == ":" or second.lexeme == "," or second.lexeme == "}";
}

proc parse_arg_list(state: ParserState, closing: string) -> ParserState {
  let current: ParserState = state;
  while not is_eof(current) and not at_text(current, closing) {
    if at_text(current, ",") {
      set current = advance(current);
    } else {
      set current = parse_expr(current);
    }
  }
  give current;
}

proc parse_if_expr(state: ParserState) -> ParserState {
  let current: ParserState = expect_text(state, "if", "PIF001");
  set current = parse_expr(current);
  set current = parse_block(current);
  while at_text(current, "elif") {
    set current = advance(current);
    set current = parse_expr(current);
    set current = parse_block(current);
  }
  if at_text(current, "else") {
    set current = advance(current);
    set current = parse_block(current);
  }
  give current;
}

proc parse_match_expr(state: ParserState) -> ParserState {
  let current: ParserState = expect_text(state, "match", "PMATCH001");
  set current = parse_expr(current);
  set current = expect_text(current, "{", "PMATCH002");
  while at_text(current, "case") {
    set current = advance(current);
    set current = parse_pattern(current);
    if at_text(current, "if") {
      set current = advance(current);
      set current = parse_expr(current);
    }
    if at_text(current, "=>") {
      set current = advance(current);
      set current = parse_expr(current);
      set current = expect_text(current, ";", "PMATCH003");
    } else {
      set current = parse_block(current);
    }
  }
  if at_text(current, "else") {
    set current = advance(current);
    if at_text(current, "=>") {
      set current = advance(current);
      set current = parse_expr(current);
      set current = expect_text(current, ";", "PMATCH004");
    } else {
      set current = parse_block(current);
    }
  }
  give expect_text(current, "}", "PMATCH005");
}

proc parse_primary(state: ParserState) -> ParserState {
  let current: ParserState = state;
  let tok: Token = current_token(current);
  if is_literal_token(tok) {
    give advance(current);
  }
  if at_text(current, "b") and at_kind(peek_token(current, 1), TokenKind.String) {
    give advance(advance(current));
  }
  if at_text(current, "if") {
    give parse_if_expr(current);
  }
  if at_text(current, "match") {
    give parse_match_expr(current);
  }
  if at_text(current, "{") {
    give parse_block(current);
  }
  if at_text(current, "(") {
    let nested: ParserState = advance(current);
    let parsed: ParserState = parse_expr(nested);
    let after_expr: ParserState = parsed;
    while at_text(after_expr, ",") {
      set after_expr = advance(after_expr);
      if at_text(after_expr, ")") {
        break;
      }
      set after_expr = parse_expr(after_expr);
    }
    give expect_text(after_expr, ")", "PPRIMARY001");
  }
  if at_text(current, "[") {
    let nested: ParserState = advance(current);
    let items: ParserState = parse_arg_list(nested, "]");
    give expect_text(items, "]", "PPRIMARY002");
  }
  if at_text(current, "map") or at_text(current, "resource") or at_text(current, "set") {
    let nested: ParserState = advance(current);
    if at_text(nested, "{") {
      give skip_balanced(nested, "{", "}", "PPRIMARY003");
    }
  }
  if at_text(current, "proc") {
    let nested: ParserState = advance(current);
    let with_open: ParserState = expect_text(nested, "(", "PPRIMARY004");
    let with_params: ParserState = parse_param_list(with_open, ")");
    let with_close: ParserState = expect_text(with_params, ")", "PPRIMARY005");
    let with_ret: ParserState = with_close;
    if at_text(with_ret, "->") {
      set with_ret = parse_type_expr(advance(with_ret));
    }
    let with_suffix: ParserState = parse_proc_suffixes(with_ret);
    give parse_block(with_suffix);
  }
  if at_text(current, "|") {
    let nested: ParserState = advance(current);
    let params: ParserState = parse_param_list(nested, "|");
    let with_bar: ParserState = expect_text(params, "|", "PLAMBDA001");
    if at_text(with_bar, "{") {
      give parse_block(with_bar);
    }
    give parse_expr(with_bar);
  }
  if at_text(current, "unsafe") {
    give parse_block(advance(current));
  }
  if at_text(current, "sizeof") or at_text(current, "alignof") or at_text(current, "offsetof") or at_text(current, "typeof") or at_text(current, "nameof") {
    let nested: ParserState = advance(current);
    let with_open: ParserState = expect_text(nested, "(", "PBUILTIN001");
    let with_arg: ParserState = parse_expr(with_open);
    give expect_text(with_arg, ")", "PBUILTIN002");
  }
  if is_ident_like(tok) {
    let with_path: ParserState = parse_path(current);
    if path_starts_struct_literal(with_path) {
      give skip_balanced(with_path, "{", "}", "PSTRUCT001");
    }
    if at_text(with_path, "[") {
      let nested: ParserState = advance(with_path);
      let args: ParserState = parse_arg_list(nested, "]");
      give expect_text(args, "]", "PSTRUCT002");
    }
    give with_path;
  }
  give with_diag(current, "PPRIMARY999", "unexpected expression token `" + tok.lexeme + "`");
}

proc parse_postfix_expr(state: ParserState) -> ParserState {
  let current: ParserState = parse_primary(state);
  while true {
    if at_text(current, "(") {
      let nested: ParserState = advance(current);
      let args: ParserState = parse_arg_list(nested, ")");
      set current = expect_text(args, ")", "PCALL001");
      continue;
    }
    if at_text(current, ".") {
      set current = advance(current);
      if at_text(current, "await") {
        set current = advance(current);
      } else {
        set current = expect_ident(current, "PMEMBER001");
      }
      continue;
    }
    if at_text(current, "[") {
      let nested: ParserState = advance(current);
      let idx: ParserState = parse_arg_list(nested, "]");
      set current = expect_text(idx, "]", "PINDEX001");
      continue;
    }
    if at_text(current, "?") {
      set current = advance(current);
      continue;
    }
    break;
  }
  give current;
}

proc parse_unary_expr(state: ParserState) -> ParserState {
  if at_text(state, "not") or at_text(state, "-") or at_text(state, "~") or at_text(state, "*") or at_text(state, "&") or at_text(state, "move") or at_text(state, "await") {
    give parse_unary_expr(advance(state));
  }
  give parse_postfix_expr(state);
}

proc parse_bin_expr(state: ParserState, op1: string, op2: string, op3: string) -> ParserState {
  let current: ParserState = parse_unary_expr(state);
  while at_text(current, op1) or (op2 != "" and at_text(current, op2)) or (op3 != "" and at_text(current, op3)) {
    set current = advance(current);
    set current = parse_unary_expr(current);
  }
  give current;
}

proc parse_expr(state: ParserState) -> ParserState {
  let start_index: u64 = state.index;
  let start_diags: u64 = len(state.diagnostics);
  let current: ParserState = bump_expr(state);
  let parsed: ParserState = parse_unary_expr(current);
  let walk: ParserState = parsed;
  while at_text(walk, "+") or at_text(walk, "-") or at_text(walk, "*") or at_text(walk, "/") or at_text(walk, "%") or at_text(walk, op_eqeq()) or at_text(walk, op_noteq()) or at_text(walk, "<") or at_text(walk, op_lte()) or at_text(walk, ">") or at_text(walk, op_gte()) or at_text(walk, "&&") or at_text(walk, "||") or at_text(walk, "and") or at_text(walk, "or") or at_text(walk, "|") or at_text(walk, "&") or at_text(walk, "^") or at_text(walk, "<<") or at_text(walk, ">>") or at_text(walk, "..") or at_text(walk, op_range_inclusive()) or at_text(walk, "??") or at_text(walk, "as") or at_text(walk, "is") {
    let op: string = current_token(walk).lexeme;
    set walk = advance(walk);
    if op == "as" {
      set walk = parse_type_expr(walk);
    } elif op == "is" {
      if at_text(walk, "not") {
        set walk = advance(walk);
      }
      set walk = parse_pattern(walk);
    } else {
      set walk = parse_unary_expr(walk);
    }
  }
  if at_text(walk, "?") {
    set walk = advance(walk);
    set walk = parse_expr(walk);
    set walk = expect_text(walk, ":", "PTERN001");
    set walk = parse_expr(walk);
  }
  if at_text(walk, assign_op_eq()) or at_text(walk, assign_op_add()) or at_text(walk, assign_op_sub()) or at_text(walk, assign_op_mul()) or at_text(walk, assign_op_div()) or at_text(walk, assign_op_mod()) or at_text(walk, assign_op_and()) or at_text(walk, assign_op_or()) or at_text(walk, assign_op_xor()) or at_text(walk, assign_op_shl()) or at_text(walk, assign_op_shr()) {
    set walk = advance(walk);
    set walk = parse_expr(walk);
  }
  if len(walk.diagnostics) > start_diags and walk.index == start_index {
    let recovered: ParserState = recover_expr_state(walk);
    if recovered.index == walk.index and not is_eof(walk) {
      give advance(walk);
    }
    give recovered;
  }
  give walk;
}

proc parse_stmt(state: ParserState) -> ParserState {
  let current: ParserState = bump_stmt(state);
  if at_text(current, "const") {
    let walk: ParserState = advance(current);
    let named: ParserState = expect_ident(walk, "PSTMT001");
    let typed: ParserState = named;
    if at_text(typed, ":") {
      set typed = parse_type_expr(advance(typed));
    }
    let assigned: ParserState = expect_text(typed, assign_op_eq(), "PSTMT002");
    let exprd: ParserState = parse_expr(assigned);
    give expect_text(exprd, ";", "PSTMT003");
  }
  if at_text(current, "let") {
    let walk: ParserState = advance(current);
    let with_mut: ParserState = walk;
    if at_text(with_mut, "mut") {
      set with_mut = advance(with_mut);
    }
    let pat: ParserState = parse_pattern(with_mut);
    let typed: ParserState = pat;
    if at_text(typed, ":") {
      set typed = parse_type_expr(advance(typed));
    }
    let assigned: ParserState = expect_text(typed, assign_op_eq(), "PSTMT004");
    let exprd: ParserState = parse_expr(assigned);
    give expect_text(exprd, ";", "PSTMT005");
  }
  if at_text(current, "set") {
    let walk: ParserState = advance(current);
    let target: ParserState = parse_unary_expr(walk);
    if at_text(target, assign_op_eq()) or at_text(target, assign_op_add()) or at_text(target, assign_op_sub()) or at_text(target, assign_op_mul()) or at_text(target, assign_op_div()) or at_text(target, assign_op_mod()) or at_text(target, assign_op_and()) or at_text(target, assign_op_or()) or at_text(target, assign_op_xor()) or at_text(target, assign_op_shl()) or at_text(target, assign_op_shr()) {
      let exprd: ParserState = parse_expr(advance(target));
      give expect_text(exprd, ";", "PSTMT006");
    }
    give with_diag(target, "PSTMT007", "expected assignment operator");
  }
  if at_text(current, "give") {
    let walk: ParserState = advance(current);
    let exprd: ParserState = walk;
    if not at_text(exprd, ";") {
      set exprd = parse_expr(exprd);
    }
    give expect_text(exprd, ";", "PSTMT008");
  }
  if at_text(current, "try") {
    let exprd: ParserState = parse_expr(advance(current));
    give expect_text(exprd, ";", "PSTMT009");
  }
  if at_text(current, "defer") {
    give parse_block(advance(current));
  }
  if at_text(current, "asm") {
    let walk: ParserState = skip_balanced(advance(current), "(", ")", "PSTMT010");
    give expect_text(walk, ";", "PSTMT011");
  }
  if at_text(current, "unsafe") {
    give parse_block(advance(current));
  }
  if at_text(current, "emit") or at_text(current, "panic") {
    let exprd: ParserState = parse_expr(advance(current));
    give expect_text(exprd, ";", "PSTMT012");
  }
  if at_text(current, "assert") {
    let walk: ParserState = parse_expr(advance(current));
    let with_more: ParserState = walk;
    if at_text(with_more, ",") {
      set with_more = parse_expr(advance(with_more));
    }
    give expect_text(with_more, ";", "PSTMT013");
  }
  if at_text(current, "unreachable") or at_text(current, "continue") {
    give expect_text(advance(current), ";", "PSTMT014");
  }
  if at_text(current, "break") {
    let walk: ParserState = advance(current);
    let exprd: ParserState = walk;
    if not at_text(exprd, ";") {
      set exprd = parse_expr(exprd);
    }
    give expect_text(exprd, ";", "PSTMT015");
  }
  if at_text(current, "if") {
    give parse_if_expr(current);
  }
  if at_text(current, "while") {
    let walk: ParserState = parse_expr(advance(current));
    give parse_block(walk);
  }
  if at_text(current, "loop") {
    give parse_block(advance(current));
  }
  if at_text(current, "for") {
    let walk: ParserState = parse_pattern(advance(current));
    let in_state: ParserState = expect_text(walk, "in", "PSTMT016");
    let exprd: ParserState = parse_expr(in_state);
    give parse_block(exprd);
  }
  if at_text(current, "select") {
    let walk: ParserState = parse_expr(advance(current));
    let opened: ParserState = expect_text(walk, "{", "PSTMT_SELECT001");
    let scan: ParserState = opened;
    while at_text(scan, "when") {
      set scan = advance(scan);
      set scan = parse_pattern(scan);
      set scan = parse_block(scan);
    }
    if at_text(scan, "else") {
      set scan = advance(scan);
      set scan = parse_block(scan);
    }
    give expect_text(scan, "}", "PSTMT_SELECT002");
  }
  if at_text(current, "match") {
    give parse_match_expr(current);
  }
  if at_text(current, "when") {
    let walk: ParserState = parse_unary_expr(advance(current));
    let is_state: ParserState = expect_text(walk, "is", "PSTMT017");
    let pat: ParserState = parse_pattern(is_state);
    give parse_block(pat);
  }
  if at_text(current, "with") {
    let walk: ParserState = parse_expr(advance(current));
    let with_pat: ParserState = walk;
    if at_text(with_pat, "as") {
      set with_pat = parse_pattern(advance(with_pat));
    }
    give parse_block(with_pat);
  }
  if at_text(current, "critical") {
    give parse_block(advance(current));
  }
  let exprd: ParserState = parse_expr(current);
  give expect_text(exprd, ";", "PSTMT018");
}

proc parse_block(state: ParserState) -> ParserState {
  let current: ParserState = expect_text(state, "{", "PBLOCK001");
  let walk: ParserState = current;
  while not is_eof(walk) and not at_text(walk, "}") {
    let before_index: u64 = walk.index;
    let before_diags: u64 = len(walk.diagnostics);
    set walk = parse_stmt(walk);
    if walk.index == before_index {
      set walk = with_diag(walk, "PLOOP", "statement parser made no progress");
    }
    if len(walk.diagnostics) > before_diags {
      let recovered: ParserState = recover_stmt_state(walk);
      if recovered.index == walk.index and walk.index == before_index and not at_text(walk, "}") and not is_eof(walk) {
        set walk = advance(walk);
      } else {
        set walk = recovered;
      }
    }
  }
  give expect_text(walk, "}", "PBLOCK002");
}

proc parse_const_decl(state: ParserState) -> ParserState {
  let walk: ParserState = advance(state);
  let named: ParserState = expect_ident(walk, "PDECL001");
  let typed: ParserState = named;
  if at_text(typed, ":") {
    set typed = parse_type_expr(advance(typed));
  }
  let assigned: ParserState = expect_text(typed, assign_op_eq(), "PDECL002");
  give parse_expr(assigned);
}

proc parse_type_decl(state: ParserState) -> ParserState {
  let walk: ParserState = advance(state);
  let named: ParserState = expect_ident(walk, "PDECL003");
  let generic: ParserState = parse_generic_params(named);
  let assigned: ParserState = expect_text(generic, assign_op_eq(), "PDECL004");
  give parse_type_expr(assigned);
}

proc parse_container_decl(state: ParserState) -> ParserState {
  let walk: ParserState = advance(state);
  let named: ParserState = expect_ident(walk, "PDECL005");
  let generic: ParserState = parse_generic_params(named);
  let current: ParserState = generic;
  if at_text(current, ":") {
    set current = parse_type_expr(advance(current));
  }
  while not is_eof(current) and not at_text(current, "{") and not at_text(current, ";") {
    if at_text(current, "where") {
      set current = parse_proc_suffixes(current);
    } else {
      set current = advance(current);
    }
  }
  if at_text(current, "{") {
    give skip_balanced(current, "{", "}", "PDECL006");
  }
  give current;
}

proc parse_meta_decl(state: ParserState) -> ParserState {
  let walk: ParserState = advance(state);
  let named: ParserState = expect_ident(walk, "PMETA001");
  let current: ParserState = named;
  if at_text(state, "macro") {
    set current = skip_balanced(current, "(", ")", "PMETA002");
  }
  while not is_eof(current) and not at_text(current, "{") and not at_text(current, ";") {
    set current = advance(current);
  }
  if at_text(current, "{") {
    give skip_balanced(current, "{", "}", "PMETA003");
  }
  give expect_text(current, ";", "PMETA004");
}

proc parse_decl(state: ParserState) -> ParserState {
  let current: ParserState = bump_toplevel(state);
  let prefixed: ParserState = parse_attrs(current);
  if is_visibility(current_token(prefixed).lexeme) {
    set prefixed = advance(prefixed);
    if at_text(prefixed, "(") {
      set prefixed = skip_balanced(prefixed, "(", ")", "PVIS_PREFIX001");
    }
  }
  let tok: Token = current_token(prefixed);
  if tok.kind == TokenKind.Eof {
    if prefixed.index > current.index {
      give with_diag(prefixed, "PATTR003", "attribute block must precede a declaration");
    }
    give prefixed;
  }
  if tok.lexeme == "space" {
    give parse_module_path(advance(prefixed));
  }
  if tok.lexeme == "use" {
    let walk: ParserState = parse_module_path(advance(prefixed));
    let imported: ParserState = walk;
    if at_text(imported, ".") {
      let after_dot: ParserState = advance(imported);
      if at_text(after_dot, "*") {
        give advance(after_dot);
      }
      if at_text(after_dot, "{") {
        give skip_balanced(after_dot, "{", "}", "PUSE001");
      }
    }
    if at_text(imported, "as") {
      give expect_ident(advance(imported), "PUSE002");
    }
    give imported;
  }
  if tok.lexeme == "export" {
    let walk: ParserState = advance(prefixed);
    if at_text(walk, "*") {
      give advance(walk);
    }
    if at_text(walk, "{") {
      give skip_balanced(walk, "{", "}", "PEXP001");
    }
    give skip_until_boundary(walk, ";", "{", "");
  }
  if tok.lexeme == "const" or tok.lexeme == "static" or tok.lexeme == "global" {
    give parse_const_decl(prefixed);
  }
  if tok.lexeme == "type" {
    give parse_type_decl(prefixed);
  }
  if tok.lexeme == "opaque" {
    let walk: ParserState = expect_text(advance(prefixed), "type", "POPAQUE001");
    let named: ParserState = expect_ident(walk, "POPAQUE002");
    let generic: ParserState = parse_generic_params(named);
    if at_text(generic, assign_op_eq()) {
      give parse_type_expr(advance(generic));
    }
    give generic;
  }
  if tok.lexeme == "extern" {
    let walk: ParserState = advance(prefixed);
    if at_text(walk, "type") {
      let named: ParserState = expect_ident(advance(walk), "PEXTERN001");
      give parse_generic_params(named);
    }
    if at_kind(walk, TokenKind.String) or at_text(walk, "C") or at_text(walk, "sysv64") or at_text(walk, "win64") or at_text(walk, "interrupt") or at_text(walk, "naked") {
      let abi: ParserState = advance(walk);
      give skip_balanced(abi, "{", "}", "PEXTERN002");
    }
    give with_diag(walk, "PEXTERN999", "expected extern type or extern block");
  }
  if tok.lexeme == "form" or tok.lexeme == "class" or tok.lexeme == "union" or tok.lexeme == "bits" or tok.lexeme == "pick" or tok.lexeme == "flags" or tok.lexeme == "trait" or tok.lexeme == "impl" {
    give parse_container_decl(prefixed);
  }
  if tok.lexeme == "proc" or is_visibility(tok.lexeme) or is_proc_modifier(tok.lexeme) {
    give parse_proc_decl(prefixed);
  }
  if tok.lexeme == "intrinsic" or tok.lexeme == "query" {
    let walk: ParserState = advance(prefixed);
    let named: ParserState = expect_ident(walk, "PQUERY001");
    let generic: ParserState = parse_generic_params(named);
    let with_open: ParserState = expect_text(generic, "(", "PQUERY002");
    let params: ParserState = parse_param_list(with_open, ")");
    let with_close: ParserState = expect_text(params, ")", "PQUERY003");
    let with_ret: ParserState = with_close;
    if at_text(with_ret, "->") {
      set with_ret = parse_type_expr(advance(with_ret));
    }
    let suffixed: ParserState = parse_proc_suffixes(with_ret);
    if tok.lexeme == "query" and at_text(suffixed, "{") {
      give parse_block(suffixed);
    }
    give expect_text(suffixed, ";", "PQUERY004");
  }
  if tok.lexeme == "compiler" or tok.lexeme == "pass" or tok.lexeme == "backend" or tok.lexeme == "diagnostic" or tok.lexeme == "macro" or tok.lexeme == "entry" {
    give parse_meta_decl(prefixed);
  }
  if tok.lexeme == "comptime" {
    give parse_block(advance(prefixed));
  }
  if tok.lexeme == "static_assert" {
    let walk: ParserState = expect_text(advance(prefixed), "(", "PASSERT001");
    let exprd: ParserState = parse_expr(walk);
    let more: ParserState = exprd;
    if at_text(more, ",") {
      set more = parse_expr(advance(more));
    }
    give expect_text(more, ")", "PASSERT002");
  }
  if tok.lexeme == "test" or tok.lexeme == "bench" {
    let walk: ParserState = advance(prefixed);
    let named: ParserState = walk;
    if at_kind(named, TokenKind.String) {
      set named = advance(named);
    }
    give parse_block(named);
  }
  if is_toplevel_keyword(tok.lexeme) {
    give skip_until_boundary(prefixed, ";", "{", "");
  }
  give with_diag(prefixed, "P0001", "unexpected top-level token `" + tok.lexeme + "`");
}

proc parse_source(source_name: string, tokens: [Token]) -> ParseResult {
  let current: ParserState = parser_state(source_name, tokens);
  let walk: ParserState = current;
  while not is_eof(walk) {
    let before: u64 = walk.index;
    let before_diags: u64 = len(walk.diagnostics);
    set walk = parse_decl(walk);
    if walk.index == before {
      set walk = with_diag(walk, "PLOOP", "parser made no progress");
    }
    if len(walk.diagnostics) > before_diags or walk.index == before {
      let recovered: ParserState = recover_decl_state(walk);
      if recovered.index == walk.index and walk.index == before and not is_eof(walk) {
        set walk = advance(walk);
      } else {
        set walk = recovered;
      }
    }
  }

  let module: AstModule = build_ast_module(source_name, tokens);
  give ParseResult {
    grammar_version: "vitte-core-2026-05",
    ast_root: module,
    toplevel_count: len(module.items),
    stmt_count: count_module_stmts(module),
    expr_count: count_module_exprs(module),
    type_count: count_module_types(module),
    pattern_count: count_module_patterns(module),
    recovery_count: walk.recovery_count,
    diagnostics: walk.diagnostics,
    valid: len(walk.diagnostics) == 0
  };
}

proc token_text(tokens: [Token], start: u64, end: u64) -> string {
  let out: string = "";
  let i: u64 = start;
  while i < end and i < len(tokens) {
    if tokens[i].kind == TokenKind.Eof {
      break;
    }
    if out != "" {
      set out = out + " ";
    }
    set out = out + tokens[i].lexeme;
    set i = i + 1;
  }
  give trim(out);
}

proc find_token_text(tokens: [Token], start: u64, end: u64, text: string) -> int {
  let i: u64 = start;
  while i < end and i < len(tokens) {
    if tokens[i].lexeme == text {
      give i as int;
    }
    set i = i + 1;
  }
  give -1;
}

proc find_matching(tokens: [Token], open_index: u64, open_text: string, close_text: string) -> int {
  let depth: int = 0;
  let i: u64 = open_index;
  while i < len(tokens) {
    if tokens[i].lexeme == open_text {
      set depth = depth + 1;
    } elif tokens[i].lexeme == close_text {
      set depth = depth - 1;
      if depth == 0 {
        give i as int;
      }
    }
    set i = i + 1;
  }
  give -1;
}

proc parser_lparen() -> string {
  give slice("()", 0, 1);
}

proc parser_rparen() -> string {
  give slice("()", 1, 2);
}

proc split_top_level_args(text: string) -> [string] {
  let lparen: string = parser_lparen();
  let rparen: string = parser_rparen();
  let parts: [string] = [];
  let current: string = "";
  let depth: int = 0;
  let in_string: bool = false;
  let i: int = 0;
  while i < len(text) {
    let ch: string = slice(text, i, i + 1);
    if ch == "\"" {
      set in_string = not in_string;
      set current = current + ch;
      set i = i + 1;
      continue;
    }
    if not in_string {
      if ch == lparen {
        set depth = depth + 1;
      } elif ch == rparen {
        set depth = depth - 1;
      } elif ch == "," and depth == 0 {
        set parts = parts + [trim(current)];
        set current = "";
        set i = i + 1;
        continue;
      }
    }
    set current = current + ch;
    set i = i + 1;
  }
  if trim(current) != "" {
    set parts = parts + [trim(current)];
  }
  give parts;
}

proc ends_with(text: string, suffix: string) -> bool {
  if len(suffix) > len(text) {
    give false;
  }
  give slice(text, len(text) - len(suffix), len(text)) == suffix;
}

proc trim_token_bounds(tokens: [Token], start: u64, end: u64) -> TokenRange {
  let left: u64 = start;
  let right: u64 = end;
  while left < right and left < len(tokens) and (tokens[left].lexeme == "," or tokens[left].lexeme == ";") {
    set left = left + 1;
  }
  while right > left and right - 1 < len(tokens) and (tokens[right - 1].lexeme == "," or tokens[right - 1].lexeme == ";") {
    set right = right - 1;
  }
  give TokenRange { start: left, end: right };
}

proc split_top_level_ranges(tokens: [Token], start: u64, end: u64, separator: string) -> [TokenRange] {
  let parts: [TokenRange] = [];
  let bounds: TokenRange = trim_token_bounds(tokens, start, end);
  if bounds.start >= bounds.end {
    give parts;
  }
  let part_start: u64 = bounds.start;
  let i: u64 = bounds.start;
  let paren_depth: int = 0;
  let bracket_depth: int = 0;
  let brace_depth: int = 0;
  while i < bounds.end {
    if tokens[i].lexeme == parser_lparen() {
      set paren_depth = paren_depth + 1;
    } elif tokens[i].lexeme == parser_rparen() {
      set paren_depth = paren_depth - 1;
    } elif tokens[i].lexeme == "[" {
      set bracket_depth = bracket_depth + 1;
    } elif tokens[i].lexeme == "]" {
      set bracket_depth = bracket_depth - 1;
    } elif tokens[i].lexeme == "{" {
      set brace_depth = brace_depth + 1;
    } elif tokens[i].lexeme == "}" {
      set brace_depth = brace_depth - 1;
    } elif tokens[i].lexeme == separator and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 {
      let part: TokenRange = trim_token_bounds(tokens, part_start, i);
      if part.start < part.end {
        set parts = parts + [part];
      }
      set part_start = i + 1;
    }
    set i = i + 1;
  }
  let tail: TokenRange = trim_token_bounds(tokens, part_start, bounds.end);
  if tail.start < tail.end {
    set parts = parts + [tail];
  }
  give parts;
}

proc find_top_level_token(tokens: [Token], start: u64, end: u64, text: string) -> int {
  let bounds: TokenRange = trim_token_bounds(tokens, start, end);
  let i: u64 = bounds.start;
  let paren_depth: int = 0;
  let bracket_depth: int = 0;
  let brace_depth: int = 0;
  while i < bounds.end and i < len(tokens) {
    if tokens[i].lexeme == parser_lparen() {
      set paren_depth = paren_depth + 1;
    } elif tokens[i].lexeme == parser_rparen() {
      set paren_depth = paren_depth - 1;
    } elif tokens[i].lexeme == "[" {
      set bracket_depth = bracket_depth + 1;
    } elif tokens[i].lexeme == "]" {
      set bracket_depth = bracket_depth - 1;
    } elif tokens[i].lexeme == "{" {
      set brace_depth = brace_depth + 1;
    } elif tokens[i].lexeme == "}" {
      set brace_depth = brace_depth - 1;
    } elif tokens[i].lexeme == text and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 {
      give i as int;
    }
    set i = i + 1;
  }
  give -1;
}

form ExprParseResult {
  expr: AstExpr
  next_index: u64
}

form StmtParseResult {
  stmt: AstStmt
  next_index: u64
}

form TokenRange {
  start: u64
  end: u64
}

form AstItemPrefix {
  start: u64
  index: u64
  attributes: [string]
  visibility: string
  modifiers: [string]
}

proc range_id(tag: u64, start: u64, end: u64) -> u64 {
  give tag * 1000000 + start * 1000 + end;
}

proc span_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstSpan {
  if len(tokens) == 0 or start >= len(tokens) or start >= end {
    give ast_span(source_name, 1, 1, 1, 1);
  }
  let first = tokens[start];
  let last_index: u64 = end - 1;
  if last_index >= len(tokens) {
    set last_index = len(tokens) - 1;
  }
  let last = tokens[last_index];
  let end_col: u64 = last.column + len(last.lexeme);
  if last.kind == TokenKind.Eof {
    set end_col = last.column;
  }
  give ast_span(source_name, first.line, first.column, last.line, end_col);
}

proc binary_precedence(op: string) -> u64 {
  if op == "or" {
    give 1;
  }
  if op == "and" {
    give 2;
  }
  if op == ".." or op == op_range_inclusive() {
    give 3;
  }
  if op == op_eqeq() or op == op_noteq() or op == "is" {
    give 4;
  }
  if op == "<" or op == op_lte() or op == ">" or op == op_gte() {
    give 5;
  }
  if op == "+" or op == "-" {
    give 6;
  }
  if op == "*" or op == "/" or op == "%" or op == "as" {
    give 7;
  }
  give 0;
}


proc expr_display_name(expr: AstExpr) -> string {
  if expr.name != "" {
    give expr.name;
  }
  give expr.text;
}

proc parse_expr_list(source_name: string, tokens: [Token], start: u64, end: u64) -> [AstExpr] {
  let exprs: [AstExpr] = [];
  if start >= end {
    give exprs;
  }
  let part_start: u64 = start;
  let i: u64 = start;
  let paren_depth: int = 0;
  let bracket_depth: int = 0;
  let brace_depth: int = 0;
  while i < end {
    if tokens[i].lexeme == parser_lparen() {
      set paren_depth = paren_depth + 1;
    } elif tokens[i].lexeme == parser_rparen() {
      set paren_depth = paren_depth - 1;
    } elif tokens[i].lexeme == "[" {
      set bracket_depth = bracket_depth + 1;
    } elif tokens[i].lexeme == "]" {
      set bracket_depth = bracket_depth - 1;
    } elif tokens[i].lexeme == "{" {
      set brace_depth = brace_depth + 1;
    } elif tokens[i].lexeme == "}" {
      set brace_depth = brace_depth - 1;
    } elif tokens[i].lexeme == "," and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 {
      if part_start < i {
        set exprs = exprs + [parse_expression_bp(source_name, tokens, part_start, i, 1).expr];
      }
      set part_start = i + 1;
    }
    set i = i + 1;
  }
  if part_start < end {
    set exprs = exprs + [parse_expression_bp(source_name, tokens, part_start, end, 1).expr];
  }
  give exprs;
}

proc parse_struct_field_exprs(source_name: string, tokens: [Token], start: u64, end: u64) -> [AstExpr] {
  let fields: [AstExpr] = [];
  let parts: [TokenRange] = split_top_level_ranges(tokens, start, end, ",");
  let i: u64 = 0;
  while i < len(parts) {
    let part: TokenRange = parts[i];
    let colon: int = find_top_level_token(tokens, part.start, part.end, ":");
    if colon >= 0 and colon as u64 + 1 < part.end {
      set fields = fields + [parse_ast_expr_from_tokens(source_name, tokens, colon as u64 + 1, part.end)];
    } else {
      set fields = fields + [parse_ast_expr_from_tokens(source_name, tokens, part.start, part.end)];
    }
    set i = i + 1;
  }
  give fields;
}


proc prefix_abi(modifiers: [string]) -> string {
  let i: u64 = 0;
  while i < len(modifiers) {
    if starts_with(modifiers[i], "abi:") {
      give slice(modifiers[i], 4, len(modifiers[i]));
    }
    set i = i + 1;
  }
  let has_extern: bool = false;
  i = 0;
  while i < len(modifiers) {
    if modifiers[i] == "extern" {
      set has_extern = true;
      break;
    }
    set i = i + 1;
  }
  if has_extern {
    give "extern";
  }
  give "";
}

proc parse_text_parts(text: string) -> [string] {
  let parts: [string] = [];
  if trim(text) == "" {
    give parts;
  }
  let raw: [string] = split_top_level_args(text);
  let i: u64 = 0;
  while i < len(raw) {
    let part: string = trim(raw[i]);
    if part != "" {
      set parts = parts + [part];
    }
    set i = i + 1;
  }
  give parts;
}

proc parse_ast_type_list(source_name: string, tokens: [Token], start: u64, end: u64) -> [AstTypeExpr] {
  let out: [AstTypeExpr] = [];
  let parts: [TokenRange] = split_top_level_ranges(tokens, start, end, ",");
  let i: u64 = 0;
  while i < len(parts) {
    set out = out + [parse_ast_type_from_tokens(source_name, tokens, parts[i].start, parts[i].end)];
    set i = i + 1;
  }
  give out;
}

proc parse_ast_generic_param_list(source_name: string, tokens: [Token], start: u64, end: u64) -> [AstGenericParam] {
  let out: [AstGenericParam] = [];
  let parts: [TokenRange] = split_top_level_ranges(tokens, start, end, ",");
  let i: u64 = 0;
  while i < len(parts) {
    set out = out + [parse_ast_generic_param_from_tokens(source_name, tokens, parts[i].start, parts[i].end)];
    set i = i + 1;
  }
  give out;
}

proc parse_ast_param_list(source_name: string, tokens: [Token], start: u64, end: u64) -> [AstParam] {
  let out: [AstParam] = [];
  let parts: [TokenRange] = split_top_level_ranges(tokens, start, end, ",");
  let i: u64 = 0;
  while i < len(parts) {
    set out = out + [parse_ast_param_from_tokens(source_name, tokens, parts[i].start, parts[i].end)];
    set i = i + 1;
  }
  give out;
}

proc parse_ast_pattern_list(source_name: string, tokens: [Token], start: u64, end: u64) -> [AstPattern] {
  let out: [AstPattern] = [];
  let parts: [TokenRange] = split_top_level_ranges(tokens, start, end, ",");
  let i: u64 = 0;
  while i < len(parts) {
    set out = out + [parse_ast_pattern_from_tokens(source_name, tokens, parts[i].start, parts[i].end)];
    set i = i + 1;
  }
  give out;
}

proc parse_ast_type_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstTypeExpr {
  let bounds: TokenRange = trim_token_bounds(tokens, start, end);
  if bounds.start >= bounds.end {
    give ast_type_empty();
  }
  let text: string = token_text(tokens, bounds.start, bounds.end);
  let span: AstSpan = span_from_tokens(source_name, tokens, bounds.start, bounds.end);
  if tokens[bounds.start].lexeme == "&" and bounds.start + 1 < bounds.end and tokens[bounds.start + 1].lexeme == "mut" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.MutableRef, text, "", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 2, bounds.end)], true);
  }
  if tokens[bounds.start].lexeme == "&" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Reference, text, "", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, bounds.end)], false);
  }
  if tokens[bounds.start].lexeme == "*" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Pointer, text, "", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, bounds.end)], false);
  }
  if tokens[bounds.start].lexeme == "?" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Optional, text, "", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, bounds.end)], false);
  }
  if tokens[bounds.start].lexeme == "dyn" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Dyn, text, "dyn", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, bounds.end)], false);
  }
  if tokens[bounds.start].lexeme == "impl" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Impl, text, "impl", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, bounds.end)], false);
  }
  if bounds.end > bounds.start and tokens[bounds.end - 1].lexeme == "?" {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Optional, text, "", [parse_ast_type_from_tokens(source_name, tokens, bounds.start, bounds.end - 1)], false);
  }
  let union_parts: [TokenRange] = split_top_level_ranges(tokens, bounds.start, bounds.end, "|");
  if len(union_parts) > 1 {
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Union, text, "", parse_ast_type_list(source_name, tokens, bounds.start, bounds.end), false);
  }
  if tokens[bounds.start].lexeme == "[" and bounds.end > bounds.start + 1 and tokens[bounds.end - 1].lexeme == "]" {
    let semi: int = find_top_level_token(tokens, bounds.start + 1, bounds.end - 1, ";");
    if semi >= 0 {
      let element: AstTypeExpr = parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, semi as u64);
      give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Array, text, "", [element], false);
    }
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Slice, text, "", [parse_ast_type_from_tokens(source_name, tokens, bounds.start + 1, bounds.end - 1)], false);
  }
  if tokens[bounds.start].lexeme == parser_lparen() and bounds.end > bounds.start + 1 and tokens[bounds.end - 1].lexeme == parser_rparen() {
    let parts: [TokenRange] = split_top_level_ranges(tokens, bounds.start + 1, bounds.end - 1, ",");
    if len(parts) > 1 {
      give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Tuple, text, "", parse_ast_type_list(source_name, tokens, bounds.start + 1, bounds.end - 1), false);
    }
  }
  if tokens[bounds.start].lexeme == "proc" {
    let children: [AstTypeExpr] = [];
    let open: int = find_token_text(tokens, bounds.start, bounds.end, "(");
    let close: int = -1;
    if open >= 0 {
      set close = find_matching(tokens, open as u64, "(", ")");
    }
    if open >= 0 and close >= 0 and close as u64 <= bounds.end {
      let params: [AstTypeExpr] = parse_ast_type_list(source_name, tokens, open as u64 + 1, close as u64);
      let pi: u64 = 0;
      while pi < len(params) {
        set children = children + [params[pi]];
        set pi = pi + 1;
      }
      let arrow: int = find_top_level_token(tokens, close as u64 + 1, bounds.end, "->");
      if arrow >= 0 and arrow as u64 + 1 < bounds.end {
        set children = children + [parse_ast_type_from_tokens(source_name, tokens, arrow as u64 + 1, bounds.end)];
      }
    }
    give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Proc, text, "proc", children, false);
  }
  let generic_open: int = find_top_level_token(tokens, bounds.start, bounds.end, "[");
  if generic_open > bounds.start and bounds.end > bounds.start + 1 and tokens[bounds.end - 1].lexeme == "]" {
    let close_generic: int = find_matching(tokens, generic_open as u64, "[", "]");
    if close_generic as u64 == bounds.end - 1 {
      let base: AstTypeExpr = parse_ast_type_from_tokens(source_name, tokens, bounds.start, generic_open as u64);
      let args: [AstTypeExpr] = parse_ast_type_list(source_name, tokens, generic_open as u64 + 1, close_generic as u64);
      let children: [AstTypeExpr] = [base];
      let ai: u64 = 0;
      while ai < len(args) {
        set children = children + [args[ai]];
        set ai = ai + 1;
      }
      give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Generic, text, base.name, children, false);
    }
  }
  if find_top_level_token(tokens, bounds.start, bounds.end, "::") >= 0 or find_top_level_token(tokens, bounds.start, bounds.end, ".") >= 0 {
    let parts: [TokenRange] = split_top_level_ranges(tokens, bounds.start, bounds.end, "::");
    let children: [AstTypeExpr] = [];
    if len(parts) > 1 {
      let pi: u64 = 0;
      while pi < len(parts) {
        set children = children + [parse_ast_type_from_tokens(source_name, tokens, parts[pi].start, parts[pi].end)];
        set pi = pi + 1;
      }
      give ast_type_node(range_id(4, bounds.start, bounds.end), span, AstTypeKind.Qualified, text, token_text(tokens, bounds.start, bounds.end), children, false);
    }
  }
  give ast_type_expr(range_id(4, bounds.start, bounds.end), span, text);
}

proc parse_ast_pattern_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstPattern {
  let bounds: TokenRange = trim_token_bounds(tokens, start, end);
  if bounds.start >= bounds.end {
    give ast_pattern_empty();
  }
  let text: string = token_text(tokens, bounds.start, bounds.end);
  let span: AstSpan = span_from_tokens(source_name, tokens, bounds.start, bounds.end);
  if tokens[bounds.start].lexeme == "&" and bounds.start + 1 < bounds.end and tokens[bounds.start + 1].lexeme == "mut" {
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.MutableRef, text, "", true, [parse_ast_pattern_from_tokens(source_name, tokens, bounds.start + 2, bounds.end)]);
  }
  if tokens[bounds.start].lexeme == "&" or tokens[bounds.start].lexeme == "ref" {
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Ref, text, "", false, [parse_ast_pattern_from_tokens(source_name, tokens, bounds.start + 1, bounds.end)]);
  }
  let or_parts: [TokenRange] = split_top_level_ranges(tokens, bounds.start, bounds.end, "|");
  if len(or_parts) > 1 {
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Or, text, "", false, parse_ast_pattern_list(source_name, tokens, bounds.start, bounds.end));
  }
  let range_sep: int = find_top_level_token(tokens, bounds.start, bounds.end, "..");
  if range_sep < 0 {
    set range_sep = find_top_level_token(tokens, bounds.start, bounds.end, op_range_inclusive());
  }
  if range_sep >= 0 {
    let left: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, bounds.start, range_sep as u64);
    let right: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, range_sep as u64 + 1, bounds.end);
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Range, text, "", false, [left, right]);
  }
  if tokens[bounds.start].lexeme == parser_lparen() and bounds.end > bounds.start + 1 and tokens[bounds.end - 1].lexeme == parser_rparen() {
    let children: [AstPattern] = parse_ast_pattern_list(source_name, tokens, bounds.start + 1, bounds.end - 1);
    if len(children) > 1 {
      give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Tuple, text, "", false, children);
    }
  }
  if tokens[bounds.start].lexeme == "[" and bounds.end > bounds.start + 1 and tokens[bounds.end - 1].lexeme == "]" {
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Array, text, "", false, parse_ast_pattern_list(source_name, tokens, bounds.start + 1, bounds.end - 1));
  }
  if tokens[bounds.start].lexeme == "_" {
    give ast_pattern(range_id(3, bounds.start, bounds.end), span, "_", false);
  }
  if bounds.start + 1 < bounds.end and tokens[bounds.start + 1].lexeme == "{" and tokens[bounds.end - 1].lexeme == "}" {
    let children: [AstPattern] = [];
    let fields: [TokenRange] = split_top_level_ranges(tokens, bounds.start + 2, bounds.end - 1, ",");
    let fi: u64 = 0;
    while fi < len(fields) {
      let colon: int = find_top_level_token(tokens, fields[fi].start, fields[fi].end, ":");
      if colon >= 0 {
        set children = children + [parse_ast_pattern_from_tokens(source_name, tokens, colon as u64 + 1, fields[fi].end)];
      } else {
        set children = children + [parse_ast_pattern_from_tokens(source_name, tokens, fields[fi].start, fields[fi].end)];
      }
      set fi = fi + 1;
    }
    let kind: AstPatternKind = if find_top_level_token(tokens, bounds.start, bounds.end, "::") >= 0 { AstPatternKind.Enum } else { AstPatternKind.Struct };
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, kind, text, tokens[bounds.start].lexeme, false, children);
  }
  let tok: Token = tokens[bounds.start];
  if is_literal_token(tok) and bounds.end == bounds.start + 1 {
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Literal, text, "", false, []);
  }
  let name: string = token_text(tokens, bounds.start, bounds.end);
  if find_top_level_token(tokens, bounds.start, bounds.end, "::") >= 0 {
    give ast_pattern_node(range_id(3, bounds.start, bounds.end), span, AstPatternKind.Enum, text, name, false, []);
  }
  give ast_pattern(range_id(3, bounds.start, bounds.end), span, name, false);
}

proc parse_ast_generic_param_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstGenericParam {
  let bounds: TokenRange = trim_token_bounds(tokens, start, end);
  if bounds.start >= bounds.end {
    give ast_generic_param_empty();
  }
  let kind: string = "type";
  let name_index: u64 = bounds.start;
  if tokens[name_index].lexeme == "const" or tokens[name_index].lexeme == "comptime" {
    set kind = tokens[name_index].lexeme;
    set name_index = name_index + 1;
  }
  if name_index >= bounds.end {
    give ast_generic_param_empty();
  }
  let name: string = tokens[name_index].lexeme;
  let colon: int = find_top_level_token(tokens, name_index + 1, bounds.end, ":");
  let eq: int = find_top_level_token(tokens, name_index + 1, bounds.end, assign_op_eq());
  let bound: AstTypeExpr = ast_type_empty();
  let default_type: AstTypeExpr = ast_type_empty();
  if colon >= 0 {
    let bound_end: u64 = if eq >= 0 and eq > colon { eq as u64 } else { bounds.end };
    set bound = parse_ast_type_from_tokens(source_name, tokens, colon as u64 + 1, bound_end);
  }
  if eq >= 0 and eq as u64 + 1 < bounds.end {
    set default_type = parse_ast_type_from_tokens(source_name, tokens, eq as u64 + 1, bounds.end);
  }
  give ast_generic_param(range_id(6, bounds.start, bounds.end), span_from_tokens(source_name, tokens, bounds.start, bounds.end), kind, name, bound, default_type);
}

proc parse_ast_param_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstParam {
  let bounds: TokenRange = trim_token_bounds(tokens, start, end);
  if bounds.start >= bounds.end {
    give ast_param_empty();
  }
  let variadic: bool = find_top_level_token(tokens, bounds.start, bounds.end, "...") >= 0;
  let mode_parts: [string] = [];
  let cursor: u64 = bounds.start;
  while cursor < bounds.end {
    if tokens[cursor].lexeme == "&" or tokens[cursor].lexeme == "mut" or tokens[cursor].lexeme == "owned" or tokens[cursor].lexeme == "borrow" or tokens[cursor].lexeme == "move" {
      set mode_parts = mode_parts + [tokens[cursor].lexeme];
      set cursor = cursor + 1;
      continue;
    }
    break;
  }
  let mode: string = trim(token_text(tokens, bounds.start, cursor));
  let colon: int = find_top_level_token(tokens, cursor, bounds.end, ":");
  let eq: int = find_top_level_token(tokens, cursor, bounds.end, assign_op_eq());
  let pattern_end: u64 = if colon >= 0 { colon as u64 } elif eq >= 0 { eq as u64 } else { bounds.end };
  let annotation: AstTypeExpr = ast_type_empty();
  if colon >= 0 {
    let annotation_end: u64 = if eq >= 0 and eq > colon { eq as u64 } else { bounds.end };
    set annotation = parse_ast_type_from_tokens(source_name, tokens, colon as u64 + 1, annotation_end);
  }
  let default_value: AstExpr = if eq >= 0 and eq as u64 + 1 < bounds.end { parse_ast_expr_from_tokens(source_name, tokens, eq as u64 + 1, bounds.end) } else { ast_expr_unknown(0, ast_span_empty(), "") };
  let pattern: AstPattern = if variadic { ast_pattern(range_id(3, bounds.start, bounds.end), span_from_tokens(source_name, tokens, bounds.start, bounds.end), "...", false) } else { parse_ast_pattern_from_tokens(source_name, tokens, cursor, pattern_end) };
  give ast_param(range_id(7, bounds.start, bounds.end), span_from_tokens(source_name, tokens, bounds.start, bounds.end), pattern, annotation, default_value, mode, variadic);
}

proc parse_ast_proc_signature_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64, abi: string) -> AstProcSignature {
  let proc_index: u64 = start;
  let name_index: u64 = proc_index + 1;
  let name: string = if name_index < end { tokens[name_index].lexeme } else { "" };
  let open_params: int = find_top_level_token(tokens, proc_index, end, "(");
  let close_params: int = -1;
  if open_params >= 0 {
    set close_params = find_matching(tokens, open_params as u64, "(", ")");
  }
  let generic_params: [AstGenericParam] = [];
  if name_index + 1 < end and tokens[name_index + 1].lexeme == "[" {
    let generic_close: int = find_matching(tokens, name_index + 1, "[", "]");
    if generic_close >= 0 and generic_close as u64 < end {
      set generic_params = parse_ast_generic_param_list(source_name, tokens, name_index + 2, generic_close as u64);
    }
  }
  let params: [AstParam] = [];
  if open_params >= 0 and close_params >= 0 and close_params as u64 <= end {
    set params = parse_ast_param_list(source_name, tokens, open_params as u64 + 1, close_params as u64);
  }
  let return_type: AstTypeExpr = ast_type_empty();
  let where_clauses: [string] = [];
  let effects: [string] = [];
  let requires: [string] = [];
  let noexcept: bool = false;
  let search_start: u64 = if close_params >= 0 { close_params as u64 + 1 } else { proc_index + 1 };
  let arrow: int = find_top_level_token(tokens, search_start, end, "->");
  if arrow >= 0 and arrow as u64 + 1 < end {
    let return_end: u64 = end;
    let where_index: int = find_top_level_token(tokens, arrow as u64 + 1, end, "where");
    let effects_index: int = find_top_level_token(tokens, arrow as u64 + 1, end, "effects");
    let requires_index: int = find_top_level_token(tokens, arrow as u64 + 1, end, "requires");
    let noexcept_index: int = find_top_level_token(tokens, arrow as u64 + 1, end, "noexcept");
    if where_index >= 0 and where_index as u64 < return_end {
      set return_end = where_index as u64;
    }
    if effects_index >= 0 and effects_index as u64 < return_end {
      set return_end = effects_index as u64;
    }
    if requires_index >= 0 and requires_index as u64 < return_end {
      set return_end = requires_index as u64;
    }
    if noexcept_index >= 0 and noexcept_index as u64 < return_end {
      set return_end = noexcept_index as u64;
    }
    set return_type = parse_ast_type_from_tokens(source_name, tokens, arrow as u64 + 1, return_end);
  }
  let where_index: int = find_top_level_token(tokens, search_start, end, "where");
  if where_index >= 0 {
    let where_end: u64 = end;
    let effects_index: int = find_top_level_token(tokens, where_index as u64 + 1, end, "effects");
    let requires_index: int = find_top_level_token(tokens, where_index as u64 + 1, end, "requires");
    let noexcept_index: int = find_top_level_token(tokens, where_index as u64 + 1, end, "noexcept");
    if effects_index >= 0 and effects_index as u64 < where_end {
      set where_end = effects_index as u64;
    }
    if requires_index >= 0 and requires_index as u64 < where_end {
      set where_end = requires_index as u64;
    }
    if noexcept_index >= 0 and noexcept_index as u64 < where_end {
      set where_end = noexcept_index as u64;
    }
    set where_clauses = parse_text_parts(token_text(tokens, where_index as u64 + 1, where_end));
  }
  let effects_index: int = find_top_level_token(tokens, search_start, end, "effects");
  if effects_index >= 0 and effects_index as u64 + 1 < end and tokens[effects_index as u64 + 1].lexeme == parser_lparen() {
    let effects_close: int = find_matching(tokens, effects_index as u64 + 1, "(", ")");
    if effects_close >= 0 {
      set effects = parse_text_parts(token_text(tokens, effects_index as u64 + 2, effects_close as u64));
    }
  }
  let requires_index: int = find_top_level_token(tokens, search_start, end, "requires");
  if requires_index >= 0 and requires_index as u64 + 1 < end and tokens[requires_index as u64 + 1].lexeme == parser_lparen() {
    let requires_close: int = find_matching(tokens, requires_index as u64 + 1, "(", ")");
    if requires_close >= 0 {
      set requires = parse_text_parts(token_text(tokens, requires_index as u64 + 2, requires_close as u64));
    }
  }
  if find_top_level_token(tokens, search_start, end, "noexcept") >= 0 {
    set noexcept = true;
  }
  give ast_proc_signature(range_id(8, start, end), span_from_tokens(source_name, tokens, start, end), name, abi, params, return_type, generic_params, where_clauses, effects, requires, noexcept);
}

proc collect_item_prefix(tokens: [Token], index: u64) -> AstItemPrefix {
  let current: u64 = index;
  let attributes: [string] = [];
  let modifiers: [string] = [];
  let visibility: string = "private";
  while current < len(tokens) {
    if tokens[current].lexeme == "#[" or tokens[current].lexeme == "#!" {
      let close: int = find_token_text(tokens, current + 1, len(tokens), "]");
      if close < 0 {
        break;
      }
      set attributes = attributes + [token_text(tokens, current, close as u64 + 1)];
      set current = close as u64 + 1;
      continue;
    }
    if tokens[current].kind == TokenKind.String and (starts_with(tokens[current].lexeme, "r\"") or starts_with(tokens[current].lexeme, "\"\"\"")) {
      set attributes = attributes + [tokens[current].lexeme];
      set current = current + 1;
      continue;
    }
    if is_visibility(tokens[current].lexeme) {
      if tokens[current].lexeme == "pub" {
        set visibility = "public";
      } else {
        set visibility = "private";
      }
      if current + 1 < len(tokens) and tokens[current + 1].lexeme == parser_lparen() {
        let close: int = find_matching(tokens, current + 1, "(", ")");
        if close < 0 {
          break;
        }
        set modifiers = modifiers + [token_text(tokens, current, close as u64 + 1)];
        set current = close as u64 + 1;
      } else {
        set current = current + 1;
      }
      continue;
    }
    if is_proc_modifier(tokens[current].lexeme) {
      set modifiers = modifiers + [tokens[current].lexeme];
      set current = current + 1;
      continue;
    }
    if tokens[current].lexeme == "extern" and current + 1 < len(tokens) and tokens[current + 1].lexeme == "proc" {
      set modifiers = modifiers + ["extern"];
      set current = current + 1;
      continue;
    }
    let extern_with_abi: bool = tokens[current].lexeme == "extern" and current + 2 < len(tokens) and tokens[current + 2].lexeme == "proc";
    let abi_token_allowed: bool = tokens[current + 1].kind == TokenKind.String or tokens[current + 1].lexeme == "C" or tokens[current + 1].lexeme == "sysv64" or tokens[current + 1].lexeme == "win64";
    if extern_with_abi and abi_token_allowed {
      set modifiers = modifiers + ["extern", "abi:" + tokens[current + 1].lexeme];
      set current = current + 2;
      continue;
    }
    break;
  }
  give AstItemPrefix { start: index, index: current, attributes: attributes, visibility: visibility, modifiers: modifiers };
}

proc parse_atom_expr(source_name: string, tokens: [Token], index: u64, end: u64) -> ExprParseResult {
  if index >= end {
    let span: AstSpan = span_from_tokens(source_name, tokens, index, index);
    give ExprParseResult { expr: ast_expr_unknown(range_id(1, index, index), span, ""), next_index: index };
  }

  if tokens[index].lexeme == parser_lparen() {
    let inner: ExprParseResult = parse_expression_bp(source_name, tokens, index + 1, end, 1);
    if inner.next_index < end and tokens[inner.next_index].lexeme == parser_rparen() {
      give ExprParseResult { expr: inner.expr, next_index: inner.next_index + 1 };
    }
    give inner;
  }

  let tok: Token = tokens[index];
  let span: AstSpan = span_from_tokens(source_name, tokens, index, index + 1);
  if tok.kind == TokenKind.String {
    give ExprParseResult { expr: ast_expr_leaf(range_id(1, index, index + 1), span, AstExprKind.String, tok.lexeme, ""), next_index: index + 1 };
  }
  if tok.kind == TokenKind.Char {
    give ExprParseResult { expr: ast_expr_leaf(range_id(1, index, index + 1), span, AstExprKind.Char, tok.lexeme, ""), next_index: index + 1 };
  }
  if tok.lexeme == "true" or tok.lexeme == "false" {
    give ExprParseResult { expr: ast_expr_leaf(range_id(1, index, index + 1), span, AstExprKind.Bool, tok.lexeme, ""), next_index: index + 1 };
  }
  if tok.kind == TokenKind.Float {
    give ExprParseResult { expr: ast_expr_leaf(range_id(1, index, index + 1), span, AstExprKind.Float, tok.lexeme, ""), next_index: index + 1 };
  }
  if tok.kind == TokenKind.Integer {
    give ExprParseResult { expr: ast_expr_leaf(range_id(1, index, index + 1), span, AstExprKind.Int, tok.lexeme, ""), next_index: index + 1 };
  }

  let base: AstExpr = ast_expr_leaf(range_id(1, index, index + 1), span, AstExprKind.Name, tok.lexeme, tok.lexeme);
  give ExprParseResult { expr: base, next_index: index + 1 };
}

proc parse_postfix_expr_ast(source_name: string, tokens: [Token], index: u64, end: u64) -> ExprParseResult {
  let current: ExprParseResult = parse_atom_expr(source_name, tokens, index, end);
  while current.next_index < end {
    if tokens[current.next_index].lexeme == "{" {
      let close: int = find_matching(tokens, current.next_index, "{", "}");
      if close < 0 or close as u64 >= end {
        break;
      }
      let field_exprs: [AstExpr] = parse_struct_field_exprs(source_name, tokens, current.next_index + 1, close as u64);
      let children: [AstExpr] = [current.expr];
      let field_index: u64 = 0;
      while field_index < len(field_exprs) {
        set children = children + [field_exprs[field_index]];
        set field_index = field_index + 1;
      }
      let struct_expr: AstExpr = ast_expr_node(
        range_id(1, index, close as u64 + 1),
        span_from_tokens(source_name, tokens, index, close as u64 + 1),
        AstExprKind.Struct,
        token_text(tokens, index, close as u64 + 1),
        expr_display_name(current.expr),
        "struct",
        children
      );
      set current = ExprParseResult { expr: struct_expr, next_index: close as u64 + 1 };
      continue;
    }
    if tokens[current.next_index].lexeme == parser_lparen() {
      let close: int = find_matching(tokens, current.next_index, "(", ")");
      if close < 0 or close as u64 >= end {
        break;
      }
      let args: [AstExpr] = [current.expr];
      let parsed_args: [AstExpr] = parse_expr_list(source_name, tokens, current.next_index + 1, close as u64);
      let arg_index: u64 = 0;
      while arg_index < len(parsed_args) {
        set args = args + [parsed_args[arg_index]];
        set arg_index = arg_index + 1;
      }
      let call_expr: AstExpr = ast_expr_call(
        range_id(1, index, close as u64 + 1),
        span_from_tokens(source_name, tokens, index, close as u64 + 1),
        token_text(tokens, index, close as u64 + 1),
        expr_display_name(current.expr),
        current.expr,
        parsed_args
      );
      set current = ExprParseResult { expr: call_expr, next_index: close as u64 + 1 };
      continue;
    }
    let has_member_suffix: bool = tokens[current.next_index].lexeme == "." and current.next_index + 1 < end;
    let next_member_token: Token = tokens[current.next_index + 1];
    let member_is_ident: bool = is_ident_like(next_member_token);
    if has_member_suffix and member_is_ident {
      let member_name: Token = next_member_token;
      let member_expr: AstExpr = ast_expr_member(
        range_id(1, index, current.next_index + 2),
        span_from_tokens(source_name, tokens, index, current.next_index + 2),
        token_text(tokens, index, current.next_index + 2),
        current.expr,
        member_name.lexeme
      );
      set current = ExprParseResult { expr: member_expr, next_index: current.next_index + 2 };
      continue;
    }
    if tokens[current.next_index].lexeme == "[" {
      let close: int = find_matching(tokens, current.next_index, "[", "]");
      if close < 0 or close as u64 >= end {
        break;
      }
      let inside: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, current.next_index + 1, close as u64);
      let indexed_expr: AstExpr = ast_expr_index(
        range_id(1, index, close as u64 + 1),
        span_from_tokens(source_name, tokens, index, close as u64 + 1),
        token_text(tokens, index, close as u64 + 1),
        current.expr,
        inside
      );
      set current = ExprParseResult { expr: indexed_expr, next_index: close as u64 + 1 };
      continue;
    }
    break;
  }
  give current;
}

proc parse_prefix_expr(source_name: string, tokens: [Token], index: u64, end: u64) -> ExprParseResult {
  if index >= end {
    let span: AstSpan = span_from_tokens(source_name, tokens, index, index);
    give ExprParseResult { expr: ast_expr_unknown(range_id(1, index, index), span, ""), next_index: index };
  }
  if tokens[index].lexeme == "&" and index + 1 < end and tokens[index + 1].lexeme == "mut" {
    let inner: ExprParseResult = parse_prefix_expr(source_name, tokens, index + 2, end);
    let expr: AstExpr = ast_expr_unary(range_id(1, index, inner.next_index), span_from_tokens(source_name, tokens, index, inner.next_index), AstExprKind.BorrowMut, token_text(tokens, index, inner.next_index), "&mut", inner.expr);
    give ExprParseResult { expr: expr, next_index: inner.next_index };
  }
  if tokens[index].lexeme == "&" and index + 1 < end {
    let inner: ExprParseResult = parse_prefix_expr(source_name, tokens, index + 1, end);
    let expr: AstExpr = ast_expr_unary(range_id(1, index, inner.next_index), span_from_tokens(source_name, tokens, index, inner.next_index), AstExprKind.BorrowShared, token_text(tokens, index, inner.next_index), "&", inner.expr);
    give ExprParseResult { expr: expr, next_index: inner.next_index };
  }
  if tokens[index].lexeme == "-" or tokens[index].lexeme == "!" or tokens[index].lexeme == "not" {
    let inner: ExprParseResult = parse_prefix_expr(source_name, tokens, index + 1, end);
    let expr: AstExpr = ast_expr_unary(range_id(1, index, inner.next_index), span_from_tokens(source_name, tokens, index, inner.next_index), AstExprKind.Unary, token_text(tokens, index, inner.next_index), tokens[index].lexeme, inner.expr);
    give ExprParseResult { expr: expr, next_index: inner.next_index };
  }
  if tokens[index].lexeme == "*" {
    let inner: ExprParseResult = parse_prefix_expr(source_name, tokens, index + 1, end);
    let expr: AstExpr = ast_expr_unary(range_id(1, index, inner.next_index), span_from_tokens(source_name, tokens, index, inner.next_index), AstExprKind.Deref, token_text(tokens, index, inner.next_index), "*", inner.expr);
    give ExprParseResult { expr: expr, next_index: inner.next_index };
  }
  if tokens[index].lexeme == "try" {
    let inner: ExprParseResult = parse_prefix_expr(source_name, tokens, index + 1, end);
    let expr: AstExpr = ast_expr_unary(range_id(1, index, inner.next_index), span_from_tokens(source_name, tokens, index, inner.next_index), AstExprKind.Try, token_text(tokens, index, inner.next_index), "try", inner.expr);
    give ExprParseResult { expr: expr, next_index: inner.next_index };
  }
  give parse_postfix_expr_ast(source_name, tokens, index, end);
}

proc parse_expression_bp(source_name: string, tokens: [Token], index: u64, end: u64, min_prec: u64) -> ExprParseResult {
  let left: ExprParseResult = parse_prefix_expr(source_name, tokens, index, end);
  let current: ExprParseResult = left;
  while current.next_index < end {
    let op_tok: Token = tokens[current.next_index];
    let prec: u64 = binary_precedence(op_tok.lexeme);
    if prec < min_prec or prec == 0 {
      break;
    }
    let right: ExprParseResult = parse_expression_bp(source_name, tokens, current.next_index + 1, end, prec + 1);
    let kind: AstExprKind = AstExprKind.Binary;
    if op_tok.lexeme == ".." or op_tok.lexeme == op_range_inclusive() {
      set kind = AstExprKind.Range;
    } elif op_tok.lexeme == "is" {
      set kind = AstExprKind.Is;
    } elif op_tok.lexeme == "as" {
      set kind = AstExprKind.Cast;
    }
    let expr: AstExpr = ast_expr_binary(range_id(1, index, right.next_index), span_from_tokens(source_name, tokens, index, right.next_index), kind, token_text(tokens, index, right.next_index), op_tok.lexeme, current.expr, right.expr);
    set current = ExprParseResult { expr: expr, next_index: right.next_index };
  }
  give current;
}

proc parse_ast_expr_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstExpr {
  let parsed: ExprParseResult = parse_expression_bp(source_name, tokens, start, end, 1);
  give parsed.expr;
}

proc parse_stmt_from_tokens(source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  let stmt_span: AstSpan = span_from_tokens(source_name, tokens, start, end);
  let stmt_id: u64 = range_id(2, start, end);
  if start >= end {
    give ast_stmt_create(stmt_id, stmt_span, AstStmtKind.Unknown, ast_pattern_empty(), "", ast_expr_unknown(0, stmt_span, ""), ast_type_empty(), "", [], []);
  }
  let first: string = tokens[start].lexeme;
  if first == "let" {
    let eq: int = find_top_level_token(tokens, start, end, assign_op_eq());
    let colon: int = find_top_level_token(tokens, start, if eq >= 0 { eq as u64 } else { end }, ":");
    let pattern_start: u64 = start + 1;
    let pattern_end: u64 = if colon >= 0 { colon as u64 } elif eq >= 0 { eq as u64 } else { end };
    let pattern: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, pattern_start, pattern_end);
    let annotation: AstTypeExpr = ast_type_empty();
    if colon >= 0 and eq > colon {
      set annotation = parse_ast_type_from_tokens(source_name, tokens, colon as u64 + 1, eq as u64);
    }
    let expr: AstExpr = ast_expr_unknown(range_id(1, start, end), stmt_span, "");
    if eq >= 0 {
      set expr = parse_ast_expr_from_tokens(source_name, tokens, eq as u64 + 1, end);
    }
    give ast_stmt_create(stmt_id, stmt_span, AstStmtKind.Let, pattern, "", expr, annotation, "", [], []);
  }
  if first == "const" {
    let eq: int = find_top_level_token(tokens, start, end, assign_op_eq());
    let colon: int = find_top_level_token(tokens, start, if eq >= 0 { eq as u64 } else { end }, ":");
    let pattern_end: u64 = if colon >= 0 { colon as u64 } elif eq >= 0 { eq as u64 } else { end };
    let pattern: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, start + 1, pattern_end);
    let annotation: AstTypeExpr = ast_type_empty();
    if colon >= 0 and eq > colon {
      set annotation = parse_ast_type_from_tokens(source_name, tokens, colon as u64 + 1, eq as u64);
    }
    let expr: AstExpr = ast_expr_unknown(range_id(1, start, end), stmt_span, "");
    if eq >= 0 {
      set expr = parse_ast_expr_from_tokens(source_name, tokens, eq as u64 + 1, end);
    }
    give ast_stmt_create(stmt_id, stmt_span, AstStmtKind.Const, pattern, "", expr, annotation, "", [], []);
  }
  if first == "set" {
    let eq: int = find_token_text(tokens, start, end, assign_op_eq());
    let target: string = "";
    let target_expr: AstExpr = ast_expr_unknown(range_id(1, start, end), stmt_span, "");
    let expr: AstExpr = ast_expr_unknown(range_id(1, start, end), stmt_span, "");
    if eq >= 0 {
      set target = trim(token_text(tokens, start + 1, eq as u64));
      set target_expr = parse_ast_expr_from_tokens(source_name, tokens, start + 1, eq as u64);
      set expr = parse_ast_expr_from_tokens(source_name, tokens, eq as u64 + 1, end);
    }
    give ast_stmt_targeted(stmt_id, stmt_span, AstStmtKind.Set, ast_pattern_empty(), target, target_expr, expr, ast_type_empty(), "", [], []);
  }
  if first == "give" {
    give ast_stmt_create(stmt_id, stmt_span, AstStmtKind.Give, ast_pattern_empty(), "", parse_ast_expr_from_tokens(source_name, tokens, start + 1, end), ast_type_empty(), "", [], []);
  }
  if first == "static_assert" {
    let open: int = find_token_text(tokens, start, end, "(");
    let close: int = find_matching(tokens, open as u64, "(", ")");
    let inside: string = "";
    if open >= 0 and close > open {
      set inside = token_text(tokens, open as u64 + 1, close as u64);
    }
    let args: [string] = split_top_level_args(inside);
    let expr: AstExpr = ast_expr_unknown(range_id(1, start, end), stmt_span, "");
    let message: string = "";
    if len(args) > 0 {
      set expr = parse_ast_expr_from_tokens(source_name, tokens, open as u64 + 1, close as u64);
    }
    if len(args) > 1 {
      set message = args[1];
    }
    give ast_stmt_create(stmt_id, stmt_span, AstStmtKind.StaticAssert, ast_pattern_empty(), "", expr, ast_type_empty(), message, [], []);
  }
  give ast_stmt_create(stmt_id, stmt_span, AstStmtKind.ExprStmt, ast_pattern_empty(), "", parse_ast_expr_from_tokens(source_name, tokens, start, end), ast_type_empty(), "", [], []);
}

proc parse_block_stmts(source_name: string, tokens: [Token], body_start: u64, body_end: u64) -> [AstStmt] {
  let stmts: [AstStmt] = [];
  let i: u64 = body_start;
  while i < body_end and i < len(tokens) {
    if tokens[i].lexeme == ";" {
      set i = i + 1;
      continue;
    }
    if tokens[i].lexeme == "if" {
      let open_cond: u64 = i + 1;
      if open_cond < body_end and tokens[open_cond].lexeme == parser_lparen() {
        let close_cond: int = find_matching(tokens, open_cond, "(", ")");
        let open_body: u64 = close_cond as u64 + 1;
        if close_cond >= 0 and open_body < body_end and tokens[open_body].lexeme == "{" {
          let close_body: int = find_matching(tokens, open_body, "{", "}");
          let then_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body + 1, close_body as u64);
          let else_stmts: [AstStmt] = [];
          let next_index: u64 = close_body as u64 + 1;
          if next_index < body_end and tokens[next_index].lexeme == "else" {
            let else_open: u64 = next_index + 1;
            if else_open < body_end and tokens[else_open].lexeme == "{" {
              let else_close: int = find_matching(tokens, else_open, "{", "}");
              set else_stmts = parse_block_stmts(source_name, tokens, else_open + 1, else_close as u64);
              set next_index = else_close as u64 + 1;
            }
          }
          let cond_expr: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, open_cond + 1, close_cond as u64);
          let stmt: AstStmt = ast_stmt_conditional(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.If, cond_expr, then_stmts, else_stmts);
          set stmts = stmts + [stmt];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "while" {
      let open_cond: u64 = i + 1;
      if open_cond < body_end and tokens[open_cond].lexeme == parser_lparen() {
        let close_cond: int = find_matching(tokens, open_cond, "(", ")");
        let open_body: u64 = close_cond as u64 + 1;
        if close_cond >= 0 and open_body < body_end and tokens[open_body].lexeme == "{" {
          let close_body: int = find_matching(tokens, open_body, "{", "}");
          let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body + 1, close_body as u64);
          let cond_expr: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, open_cond + 1, close_cond as u64);
          let next_index: u64 = close_body as u64 + 1;
          let stmt: AstStmt = ast_stmt_conditional(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.While, cond_expr, body_stmts, []);
          set stmts = stmts + [stmt];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "for" {
      let in_index: int = find_top_level_token(tokens, i + 1, body_end, "in");
      let open_body: int = find_top_level_token(tokens, i + 1, body_end, "{");
      if in_index >= 0 and open_body >= 0 and in_index < open_body {
        let close_body: int = find_matching(tokens, open_body as u64, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let pattern: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, i + 1, in_index as u64);
          let iter_expr: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, in_index as u64 + 1, open_body as u64);
          let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body as u64 + 1, close_body as u64);
          let next_index: u64 = close_body as u64 + 1;
          let stmt: AstStmt = ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.For, pattern, "", iter_expr, ast_type_empty(), "", body_stmts, []);
          set stmts = stmts + [stmt];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "match" {
      let expr_start: u64 = i + 1;
      let open_body: int = find_top_level_token(tokens, expr_start, body_end, "{");
      if open_body >= 0 {
        let close_body: int = find_matching(tokens, open_body as u64, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let matched_expr: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, expr_start, open_body as u64);
          let arms: [AstStmt] = [];
          let arm_start: u64 = open_body as u64 + 1;
          let j: u64 = arm_start;
          let depth: int = 0;
          while j < close_body as u64 {
            if tokens[j].lexeme == "{" {
              set depth = depth + 1;
            } elif tokens[j].lexeme == "}" {
              set depth = depth - 1;
            } elif (tokens[j].lexeme == "," or tokens[j].lexeme == ";") and depth == 0 {
              let arrow: int = find_top_level_token(tokens, arm_start, j, "=>");
              if arrow >= 0 {
                let pattern_start: u64 = if tokens[arm_start].lexeme == "case" { arm_start + 1 } else { arm_start };
                let pattern: AstPattern = if tokens[arm_start].lexeme == "else" { ast_pattern(range_id(3, arm_start, arm_start + 1), span_from_tokens(source_name, tokens, arm_start, arm_start + 1), "_", false) } else { parse_ast_pattern_from_tokens(source_name, tokens, pattern_start, arrow as u64) };
                let arm_body_expr: AstExpr = ast_expr_node(range_id(1, arrow as u64 + 1, j), span_from_tokens(source_name, tokens, arrow as u64 + 1, j), AstExprKind.Block, token_text(tokens, arrow as u64 + 1, j), "", "", []);
                let arm_then: [AstStmt] = [];
                if arrow as u64 + 1 < j and tokens[arrow as u64 + 1].lexeme == "{" and j > arrow + 1 {
                  set arm_then = parse_block_stmts(source_name, tokens, arrow as u64 + 2, j - 1);
                } elif arrow as u64 + 1 < j {
                  set arm_body_expr = parse_ast_expr_from_tokens(source_name, tokens, arrow as u64 + 1, j);
                }
                let arm_stmt: AstStmt = ast_stmt_create(range_id(2, arm_start, j), span_from_tokens(source_name, tokens, arm_start, j), AstStmtKind.When, pattern, "", arm_body_expr, ast_type_empty(), "", arm_then, []);
                set arms = arms + [arm_stmt];
              }
              set arm_start = j + 1;
            }
            set j = j + 1;
          }
          if arm_start < close_body as u64 {
            let arrow: int = find_top_level_token(tokens, arm_start, close_body as u64, "=>");
            if arrow >= 0 {
              let pattern_start: u64 = if tokens[arm_start].lexeme == "case" { arm_start + 1 } else { arm_start };
              let pattern: AstPattern = if tokens[arm_start].lexeme == "else" { ast_pattern(range_id(3, arm_start, arm_start + 1), span_from_tokens(source_name, tokens, arm_start, arm_start + 1), "_", false) } else { parse_ast_pattern_from_tokens(source_name, tokens, pattern_start, arrow as u64) };
              let arm_body_expr: AstExpr = ast_expr_node(range_id(1, arrow as u64 + 1, close_body as u64), span_from_tokens(source_name, tokens, arrow as u64 + 1, close_body as u64), AstExprKind.Block, token_text(tokens, arrow as u64 + 1, close_body as u64), "", "", []);
              let arm_then: [AstStmt] = [];
              if arrow as u64 + 1 < close_body as u64 and tokens[arrow as u64 + 1].lexeme == "{" and close_body as u64 > arrow as u64 + 2 {
                set arm_then = parse_block_stmts(source_name, tokens, arrow as u64 + 2, close_body as u64 - 1);
              } elif arrow as u64 + 1 < close_body as u64 {
                set arm_body_expr = parse_ast_expr_from_tokens(source_name, tokens, arrow as u64 + 1, close_body as u64);
              }
              set arms = arms + [ast_stmt_create(range_id(2, arm_start, close_body as u64), span_from_tokens(source_name, tokens, arm_start, close_body as u64), AstStmtKind.When, pattern, "", arm_body_expr, ast_type_empty(), "", arm_then, [])];
            }
          }
          let next_index: u64 = close_body as u64 + 1;
          set stmts = stmts + [ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.Match, ast_pattern_empty(), "", matched_expr, ast_type_empty(), "", arms, [])];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "unsafe" or tokens[i].lexeme == "critical" {
      let open_body: u64 = i + 1;
      if open_body < body_end and tokens[open_body].lexeme == "{" {
        let close_body: int = find_matching(tokens, open_body, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body + 1, close_body as u64);
          let next_index: u64 = close_body as u64 + 1;
          let kind: AstStmtKind = if tokens[i].lexeme == "unsafe" { AstStmtKind.Unsafe } else { AstStmtKind.Critical };
          let body_expr: AstExpr = ast_expr_node(range_id(1, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstExprKind.Block, token_text(tokens, i, next_index), "", "", []);
          set stmts = stmts + [ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), kind, ast_pattern_empty(), "", body_expr, ast_type_empty(), "", body_stmts, [])];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "loop" or tokens[i].lexeme == "defer" {
      let open_body: u64 = i + 1;
      if open_body < body_end and tokens[open_body].lexeme == "{" {
        let close_body: int = find_matching(tokens, open_body, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body + 1, close_body as u64);
          let next_index: u64 = close_body as u64 + 1;
          let kind: AstStmtKind = if tokens[i].lexeme == "loop" { AstStmtKind.Loop } else { AstStmtKind.Defer };
          let body_expr: AstExpr = ast_expr_node(range_id(1, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstExprKind.Block, token_text(tokens, i, next_index), "", "", []);
          set stmts = stmts + [ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), kind, ast_pattern_empty(), "", body_expr, ast_type_empty(), "", body_stmts, [])];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "when" {
      let is_index: int = find_top_level_token(tokens, i + 1, body_end, "is");
      let open_body: int = find_top_level_token(tokens, i + 1, body_end, "{");
      if is_index >= 0 and open_body >= 0 and is_index < open_body {
        let close_body: int = find_matching(tokens, open_body as u64, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let cond_expr: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, i + 1, is_index as u64);
          let pattern: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, is_index as u64 + 1, open_body as u64);
          let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body as u64 + 1, close_body as u64);
          let next_index: u64 = close_body as u64 + 1;
          set stmts = stmts + [ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.When, pattern, "", cond_expr, ast_type_empty(), "", body_stmts, [])];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "with" {
      let open_body: int = find_top_level_token(tokens, i + 1, body_end, "{");
      if open_body >= 0 {
        let close_body: int = find_matching(tokens, open_body as u64, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let as_index: int = find_top_level_token(tokens, i + 1, open_body as u64, "as");
          let value_end: u64 = if as_index >= 0 { as_index as u64 } else { open_body as u64 };
          let value_expr: AstExpr = parse_ast_expr_from_tokens(source_name, tokens, i + 1, value_end);
          let pattern: AstPattern = if as_index >= 0 { parse_ast_pattern_from_tokens(source_name, tokens, as_index as u64 + 1, open_body as u64) } else { ast_pattern_empty() };
          let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open_body as u64 + 1, close_body as u64);
          let next_index: u64 = close_body as u64 + 1;
          set stmts = stmts + [ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.With, pattern, "", value_expr, ast_type_empty(), "", body_stmts, [])];
          set i = next_index;
          continue;
        }
      }
    }
    if tokens[i].lexeme == "select" {
      let open_body: int = find_top_level_token(tokens, i + 1, body_end, "{");
      if open_body >= 0 {
        let close_body: int = find_matching(tokens, open_body as u64, "{", "}");
        if close_body >= 0 and close_body as u64 <= body_end {
          let base_expr: AstExpr = if i + 1 < open_body as u64 { parse_ast_expr_from_tokens(source_name, tokens, i + 1, open_body as u64) } else { ast_expr_unknown(0, span_from_tokens(source_name, tokens, i, i + 1), "") };
          let branches: [AstStmt] = [];
          let else_stmts: [AstStmt] = [];
          let cursor: u64 = open_body as u64 + 1;
          while cursor < close_body as u64 {
            if tokens[cursor].lexeme == "when" {
              let branch_open: int = find_top_level_token(tokens, cursor + 1, close_body as u64, "{");
              if branch_open >= 0 {
                let branch_close: int = find_matching(tokens, branch_open as u64, "{", "}");
                if branch_close >= 0 and branch_close as u64 <= close_body as u64 {
                  let pattern: AstPattern = parse_ast_pattern_from_tokens(source_name, tokens, cursor + 1, branch_open as u64);
                  let body_stmts: [AstStmt] = parse_block_stmts(source_name, tokens, branch_open as u64 + 1, branch_close as u64);
                  set branches = branches + [ast_stmt_create(range_id(2, cursor, branch_close as u64 + 1), span_from_tokens(source_name, tokens, cursor, branch_close as u64 + 1), AstStmtKind.When, pattern, "", ast_expr_unknown(0, span_from_tokens(source_name, tokens, cursor, cursor + 1), ""), ast_type_empty(), "", body_stmts, [])];
                  set cursor = branch_close as u64 + 1;
                  continue;
                }
              }
            }
            if tokens[cursor].lexeme == "else" {
              let else_open: int = find_top_level_token(tokens, cursor + 1, close_body as u64, "{");
              if else_open >= 0 {
                let else_close: int = find_matching(tokens, else_open as u64, "{", "}");
                if else_close >= 0 and else_close as u64 <= close_body as u64 {
                  set else_stmts = parse_block_stmts(source_name, tokens, else_open as u64 + 1, else_close as u64);
                  set cursor = else_close as u64 + 1;
                  continue;
                }
              }
            }
            set cursor = cursor + 1;
          }
          let next_index: u64 = close_body as u64 + 1;
          set stmts = stmts + [ast_stmt_create(range_id(2, i, next_index), span_from_tokens(source_name, tokens, i, next_index), AstStmtKind.Select, ast_pattern_empty(), "", base_expr, ast_type_empty(), "", branches, else_stmts)];
          set i = next_index;
          continue;
        }
      }
    }

    let start: u64 = i;
    let depth: int = 0;
    while i < body_end and i < len(tokens) {
      if tokens[i].lexeme == parser_lparen() or tokens[i].lexeme == "{" {
        set depth = depth + 1;
      } elif tokens[i].lexeme == parser_rparen() or tokens[i].lexeme == "}" {
        set depth = depth - 1;
      } elif tokens[i].lexeme == ";" and depth == 0 {
        break;
      }
      set i = i + 1;
    }
    set stmts = stmts + [parse_stmt_from_tokens(source_name, tokens, start, i)];
    if i < body_end and tokens[i].lexeme == ";" {
      set i = i + 1;
    }
  }
  give stmts;
}

proc placeholder_member_expr(member_name: string, span: AstSpan, id: u64) -> AstExpr {
  give ast_expr_leaf(id, span, AstExprKind.String, "\"" + member_name + "\"", "");
}

proc nominal_member_kind_for_keyword(keyword: string) -> AstNominalMemberKind {
  if keyword == "form" or keyword == "class" or keyword == "union" {
    give AstNominalMemberKind.Field;
  }
  if keyword == "bits" or keyword == "pick" or keyword == "flags" {
    give AstNominalMemberKind.Variant;
  }
  if keyword == "trait" {
    give AstNominalMemberKind.TraitMethod;
  }
  if keyword == "impl" {
    give AstNominalMemberKind.ImplMethod;
  }
  give AstNominalMemberKind.Unknown;
}

proc nominal_member_from_stmt(keyword: string, stmt: AstStmt) -> AstNominalMember {
  give ast_nominal_member(
    stmt.id.value,
    stmt.span,
    nominal_member_kind_for_keyword(keyword),
    stmt.pattern.name,
    stmt.annotation,
    stmt.expr,
    ast_proc_signature_empty(),
    stmt.then_stmts,
    stmt.message
  );
}

proc parse_surface_field_stmt(source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  let stmt_span: AstSpan = span_from_tokens(source_name, tokens, start, end);
  let stmt_id: u64 = range_id(2, start, end);
  let colon: int = find_top_level_token(tokens, start, end, ":");
  let name_end: u64 = if colon >= 0 { colon as u64 } else { end };
  let name: string = trim(token_text(tokens, start, name_end));
  let annotation: AstTypeExpr = if colon >= 0 and colon as u64 + 1 < end {
    parse_ast_type_from_tokens(source_name, tokens, colon as u64 + 1, end)
  } else {
    ast_type_empty()
  };
  give ast_stmt_create(
    stmt_id,
    stmt_span,
    AstStmtKind.ExprStmt,
    ast_pattern(stmt_id, stmt_span, name, false),
    "",
    placeholder_member_expr(name, stmt_span, range_id(1, start, end)),
    annotation,
    token_text(tokens, start, end),
    [],
    []
  );
}

proc parse_surface_bits_or_flags_stmt(source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  let stmt_span: AstSpan = span_from_tokens(source_name, tokens, start, end);
  let stmt_id: u64 = range_id(2, start, end);
  let colon: int = find_top_level_token(tokens, start, end, ":");
  let eq: int = find_top_level_token(tokens, start, end, "=");
  let split_at: int = if colon >= 0 { colon } else { eq };
  let name_end: u64 = if split_at >= 0 { split_at as u64 } else { end };
  let name: string = trim(token_text(tokens, start, name_end));
  let expr: AstExpr = if split_at >= 0 and split_at as u64 + 1 < end {
    parse_ast_expr_from_tokens(source_name, tokens, split_at as u64 + 1, end)
  } else {
    placeholder_member_expr(name, stmt_span, range_id(1, start, end))
  };
  give ast_stmt_create(
    stmt_id,
    stmt_span,
    AstStmtKind.ExprStmt,
    ast_pattern(stmt_id, stmt_span, name, false),
    "",
    expr,
    ast_type_empty(),
    token_text(tokens, start, end),
    [],
    []
  );
}

proc parse_surface_bitfield_stmt(source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  give parse_surface_bits_or_flags_stmt(source_name, tokens, start, end);
}

proc parse_surface_bitfield_list(source_name: string, tokens: [Token], body_start: u64, body_end: u64) -> [AstStmt] {
  let stmts: [AstStmt] = [];
  let i: u64 = body_start;

  while i < body_end and i < len(tokens) {
    while i < body_end and (tokens[i].lexeme == "," or tokens[i].lexeme == ";") {
      set i = i + 1;
    }

    if i >= body_end {
      break;
    }

    let start: u64 = i;
    let paren_depth: int = 0;
    let bracket_depth: int = 0;
    let brace_depth: int = 0;

    while i < body_end and i < len(tokens) {
      if tokens[i].lexeme == parser_lparen() {
        set paren_depth = paren_depth + 1;
      } elif tokens[i].lexeme == parser_rparen() {
        set paren_depth = paren_depth - 1;
      } elif tokens[i].lexeme == "[" {
        set bracket_depth = bracket_depth + 1;
      } elif tokens[i].lexeme == "]" {
        set bracket_depth = bracket_depth - 1;
      } elif tokens[i].lexeme == "{" {
        set brace_depth = brace_depth + 1;
      } elif tokens[i].lexeme == "}" {
        set brace_depth = brace_depth - 1;
      } elif (tokens[i].lexeme == "," or tokens[i].lexeme == ";") and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 {
        break;
      }
      set i = i + 1;
    }

    if start < i {
      set stmts = stmts + [parse_surface_bitfield_stmt(source_name, tokens, start, i)];
    }

    if i < body_end and (tokens[i].lexeme == "," or tokens[i].lexeme == ";") {
      set i = i + 1;
    }
  }

  give stmts;
}

proc parse_surface_pick_stmt(source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  let stmt_span: AstSpan = span_from_tokens(source_name, tokens, start, end);
  let stmt_id: u64 = range_id(2, start, end);
  let open: int = find_top_level_token(tokens, start, end, "(");
  let name_end: u64 = if open >= 0 { open as u64 } else { end };
  let name: string = trim(token_text(tokens, start, name_end));
  let annotation: AstTypeExpr = if open >= 0 {
    let close: int = find_matching(tokens, open as u64, "(", ")");
    if close > open {
      parse_ast_type_from_tokens(source_name, tokens, open as u64 + 1, close as u64)
    } else {
      ast_type_empty()
    }
  } else {
    ast_type_empty()
  };
  give ast_stmt_create(
    stmt_id,
    stmt_span,
    AstStmtKind.ExprStmt,
    ast_pattern(stmt_id, stmt_span, name, false),
    "",
    placeholder_member_expr(name, stmt_span, range_id(1, start, end)),
    annotation,
    token_text(tokens, start, end),
    [],
    []
  );
}

proc parse_surface_proc_member_stmt(source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  let stmt_span: AstSpan = span_from_tokens(source_name, tokens, start, end);
  let stmt_id: u64 = range_id(2, start, end);
  let open_body: int = find_item_body_open(tokens, start, end);
  let close_body: int = if open_body >= 0 { find_matching(tokens, open_body as u64, "{", "}") } else { -1 };
  let sig_end: u64 = if open_body >= 0 { open_body as u64 } else { end };
  let signature: AstProcSignature = parse_ast_proc_signature_from_tokens(source_name, tokens, start, sig_end, "");
  let body_stmts: [AstStmt] = if open_body >= 0 and close_body >= 0 {
    parse_block_stmts(source_name, tokens, open_body as u64 + 1, close_body as u64)
  } else {
    []
  };
  give ast_stmt_create(
    stmt_id,
    stmt_span,
    AstStmtKind.ExprStmt,
    ast_pattern(stmt_id, stmt_span, signature.name, false),
    "",
    placeholder_member_expr(signature.name, stmt_span, range_id(1, start, end)),
    signature.return_type,
    token_text(tokens, start, end),
    body_stmts,
    []
  );
}

proc parse_surface_proc_member_node(keyword: string, source_name: string, tokens: [Token], start: u64, end: u64) -> AstNominalMember {
  let stmt_span: AstSpan = span_from_tokens(source_name, tokens, start, end);
  let stmt_id: u64 = range_id(2, start, end);
  let open_body: int = find_item_body_open(tokens, start, end);
  let close_body: int = if open_body >= 0 { find_matching(tokens, open_body as u64, "{", "}") } else { -1 };
  let sig_end: u64 = if open_body >= 0 { open_body as u64 } else { end };
  let signature: AstProcSignature = parse_ast_proc_signature_from_tokens(source_name, tokens, start, sig_end, "");
  let body_stmts: [AstStmt] = if open_body >= 0 and close_body >= 0 {
    parse_block_stmts(source_name, tokens, open_body as u64 + 1, close_body as u64)
  } else {
    []
  };
  give ast_nominal_member(
    stmt_id,
    stmt_span,
    nominal_member_kind_for_keyword(keyword),
    signature.name,
    signature.return_type,
    placeholder_member_expr(signature.name, stmt_span, range_id(1, start, end)),
    signature,
    body_stmts,
    token_text(tokens, start, end)
  );
}

proc parse_surface_member_stmt(keyword: string, source_name: string, tokens: [Token], start: u64, end: u64) -> AstStmt {
  if keyword == "form" or keyword == "class" or keyword == "union" {
    give parse_surface_field_stmt(source_name, tokens, start, end);
  }
  if keyword == "bits" or keyword == "flags" {
    give parse_surface_bits_or_flags_stmt(source_name, tokens, start, end);
  }
  if keyword == "pick" {
    give parse_surface_pick_stmt(source_name, tokens, start, end);
  }
  if keyword == "trait" or keyword == "impl" {
    give parse_surface_proc_member_stmt(source_name, tokens, start, end);
  }
  give parse_stmt_from_tokens(source_name, tokens, start, end);
}

proc parse_surface_item_members(keyword: string, source_name: string, tokens: [Token], body_start: u64, body_end: u64) -> [AstStmt] {
  if keyword == "bits" {
    give parse_surface_bitfield_list(source_name, tokens, body_start, body_end);
  }

  let stmts: [AstStmt] = [];
  let i: u64 = body_start;
  while i < body_end and i < len(tokens) {
    while i < body_end and (tokens[i].lexeme == "," or tokens[i].lexeme == ";") {
      set i = i + 1;
    }
    if i >= body_end {
      break;
    }
    if (keyword == "trait" or keyword == "impl") and tokens[i].lexeme == "proc" {
      let open_body: int = find_item_body_open(tokens, i, body_end);
      let end_i: u64 = if open_body >= 0 and find_matching(tokens, open_body as u64, "{", "}") >= 0 {
        find_matching(tokens, open_body as u64, "{", "}") as u64 + 1
      } else {
        if find_top_level_token(tokens, i, body_end, ";") >= 0 {
          find_top_level_token(tokens, i, body_end, ";") as u64
        } else {
          body_end
        }
      };
      if end_i > i {
        set stmts = stmts + [parse_surface_member_stmt(keyword, source_name, tokens, i, end_i)];
      }
      if end_i < body_end and (tokens[end_i].lexeme == ";" or tokens[end_i].lexeme == ",") {
        set i = end_i + 1;
      } else {
        set i = end_i;
      }
      continue;
    }
    let start: u64 = i;
    let paren_depth: int = 0;
    let bracket_depth: int = 0;
    let brace_depth: int = 0;
    while i < body_end and i < len(tokens) {
      if tokens[i].lexeme == parser_lparen() {
        set paren_depth = paren_depth + 1;
      } elif tokens[i].lexeme == parser_rparen() {
        set paren_depth = paren_depth - 1;
      } elif tokens[i].lexeme == "[" {
        set bracket_depth = bracket_depth + 1;
      } elif tokens[i].lexeme == "]" {
        set bracket_depth = bracket_depth - 1;
      } elif tokens[i].lexeme == "{" {
        set brace_depth = brace_depth + 1;
      } elif tokens[i].lexeme == "}" {
        set brace_depth = brace_depth - 1;
      } elif (tokens[i].lexeme == "," or tokens[i].lexeme == ";") and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 {
        break;
      }
      set i = i + 1;
    }
    if start < i {
      set stmts = stmts + [parse_surface_member_stmt(keyword, source_name, tokens, start, i)];
    }
    if i < body_end and (tokens[i].lexeme == "," or tokens[i].lexeme == ";") {
      set i = i + 1;
    }
  }
  give stmts;
}

proc parse_surface_item_member_nodes(keyword: string, source_name: string, tokens: [Token], body_start: u64, body_end: u64) -> [AstNominalMember] {
  let members: [AstNominalMember] = [];
  let i: u64 = body_start;
  while i < body_end and i < len(tokens) {
    while i < body_end and (tokens[i].lexeme == "," or tokens[i].lexeme == ";") {
      set i = i + 1;
    }
    if i >= body_end {
      break;
    }
    if (keyword == "trait" or keyword == "impl") and tokens[i].lexeme == "proc" {
      let open_body: int = find_item_body_open(tokens, i, body_end);
      let end_i: u64 = if open_body >= 0 and find_matching(tokens, open_body as u64, "{", "}") >= 0 {
        find_matching(tokens, open_body as u64, "{", "}") as u64 + 1
      } else {
        if find_top_level_token(tokens, i, body_end, ";") >= 0 {
          find_top_level_token(tokens, i, body_end, ";") as u64
        } else {
          body_end
        }
      };
      if end_i > i {
        set members = members + [parse_surface_proc_member_node(keyword, source_name, tokens, i, end_i)];
      }
      if end_i < body_end and (tokens[end_i].lexeme == ";" or tokens[end_i].lexeme == ",") {
        set i = end_i + 1;
      } else {
        set i = end_i;
      }
      continue;
    }
    let start: u64 = i;
    let paren_depth: int = 0;
    let bracket_depth: int = 0;
    let brace_depth: int = 0;
    while i < body_end and i < len(tokens) {
      if tokens[i].lexeme == parser_lparen() {
        set paren_depth = paren_depth + 1;
      } elif tokens[i].lexeme == parser_rparen() {
        set paren_depth = paren_depth - 1;
      } elif tokens[i].lexeme == "[" {
        set bracket_depth = bracket_depth + 1;
      } elif tokens[i].lexeme == "]" {
        set bracket_depth = bracket_depth - 1;
      } elif tokens[i].lexeme == "{" {
        set brace_depth = brace_depth + 1;
      } elif tokens[i].lexeme == "}" {
        set brace_depth = brace_depth - 1;
      } elif (tokens[i].lexeme == "," or tokens[i].lexeme == ";") and paren_depth == 0 and bracket_depth == 0 and brace_depth == 0 {
        break;
      }
      set i = i + 1;
    }
    if start < i {
      let member_stmt: AstStmt = parse_surface_member_stmt(keyword, source_name, tokens, start, i);
      set members = members + [nominal_member_from_stmt(keyword, member_stmt)];
    }
    if i < body_end and (tokens[i].lexeme == "," or tokens[i].lexeme == ";") {
      set i = i + 1;
    }
  }
  give members;
}

proc item_kind_for_keyword(keyword: string) -> AstItemKind {
  if keyword == "space" {
    give AstItemKind.Space;
  }
  if keyword == "use" {
    give AstItemKind.Use;
  }
  if keyword == "export" {
    give AstItemKind.Export;
  }
  if keyword == "const" {
    give AstItemKind.Const;
  }
  if keyword == "static" {
    give AstItemKind.Static;
  }
  if keyword == "type" {
    give AstItemKind.Type;
  }
  if keyword == "opaque" {
    give AstItemKind.Opaque;
  }
  if keyword == "extern" {
    give AstItemKind.Extern;
  }
  if keyword == "form" {
    give AstItemKind.Form;
  }
  if keyword == "class" {
    give AstItemKind.Class;
  }
  if keyword == "union" {
    give AstItemKind.Union;
  }
  if keyword == "bits" {
    give AstItemKind.Bits;
  }
  if keyword == "pick" {
    give AstItemKind.Pick;
  }
  if keyword == "flags" {
    give AstItemKind.Flags;
  }
  if keyword == "trait" {
    give AstItemKind.Trait;
  }
  if keyword == "impl" {
    give AstItemKind.Impl;
  }
  if keyword == "proc" {
    give AstItemKind.Proc;
  }
  if keyword == "intrinsic" {
    give AstItemKind.Intrinsic;
  }
  if keyword == "query" {
    give AstItemKind.Query;
  }
  if keyword == "compiler" {
    give AstItemKind.Compiler;
  }
  if keyword == "pass" {
    give AstItemKind.Pass;
  }
  if keyword == "backend" {
    give AstItemKind.Backend;
  }
  if keyword == "diagnostic" {
    give AstItemKind.Diagnostic;
  }
  if keyword == "macro" {
    give AstItemKind.Macro;
  }
  if keyword == "entry" {
    give AstItemKind.Entry;
  }
  if keyword == "test" {
    give AstItemKind.Test;
  }
  if keyword == "bench" {
    give AstItemKind.Bench;
  }
  if keyword == "static_assert" {
    give AstItemKind.StaticAssert;
  }
  give AstItemKind.Unknown;
}

proc parse_item_type_params(source_name: string, tokens: [Token], name_index: u64, limit: u64) -> [AstTypeExpr] {
  let params: [AstTypeExpr] = [];
  if name_index + 1 >= limit or name_index + 1 >= len(tokens) or tokens[name_index + 1].lexeme != "[" {
    give params;
  }
  let close: int = find_matching(tokens, name_index + 1, "[", "]");
  if close < 0 or close as u64 >= limit {
    give params;
  }
  give parse_ast_type_list(source_name, tokens, name_index + 2, close as u64);
}

proc find_item_body_open(tokens: [Token], start: u64, end: u64) -> int {
  give find_top_level_token(tokens, start, end, "{");
}

proc parse_item_meta_args(tokens: [Token], name_index: u64, limit: u64) -> [string] {
  let args: [string] = [];
  if name_index + 1 >= limit or name_index + 1 >= len(tokens) or tokens[name_index + 1].lexeme != "(" {
    give args;
  }
  let close: int = find_matching(tokens, name_index + 1, "(", ")");
  if close < 0 or close as u64 >= limit {
    give args;
  }
  give parse_text_parts(token_text(tokens, name_index + 2, close as u64));
}

proc build_ast_module(source_name: string, tokens: [Token]) -> AstModule {
  let items: [AstItem] = [];
  let i: u64 = 0;

  while i < len(tokens) and tokens[i].kind != TokenKind.Eof {
    let prefix: AstItemPrefix = collect_item_prefix(tokens, i);
    if prefix.index >= len(tokens) or tokens[prefix.index].kind == TokenKind.Eof {
      break;
    }
    let actual: u64 = prefix.index;
    let keyword: string = tokens[actual].lexeme;

    if keyword == "space" or keyword == "use" or keyword == "export" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let name: string = token_text(tokens, actual + 1, end_i);
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), item_kind_for_keyword(keyword), name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], ast_type_empty(), ast_type_empty(), [], [], ast_proc_signature_empty(), [], "")];
      set i = end_i + 1;
      continue;
    }

    if keyword == "const" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let stmt: AstStmt = parse_stmt_from_tokens(source_name, tokens, actual, end_i);
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), AstItemKind.Const, stmt.pattern.name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), stmt.expr, [], stmt.annotation, ast_type_empty(), [], [], ast_proc_signature_empty(), [], "")];
      set i = end_i + 1;
      continue;
    }

    if keyword == "static" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let name: string = if actual + 1 < end_i { tokens[actual + 1].lexeme } else { "" };
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), AstItemKind.Static, name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], ast_type_empty(), ast_type_empty(), [], [], ast_proc_signature_empty(), [], token_text(tokens, actual, end_i))];
      set i = end_i + 1;
      continue;
    }

    if keyword == "static_assert" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let stmt: AstStmt = parse_stmt_from_tokens(source_name, tokens, actual, end_i);
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), AstItemKind.StaticAssert, "", prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), stmt.expr, [], ast_type_empty(), ast_type_empty(), [], [], ast_proc_signature_empty(), [], stmt.message)];
      set i = end_i + 1;
      continue;
    }

    if keyword == "type" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let name: string = if actual + 1 < end_i { tokens[actual + 1].lexeme } else { "" };
      let eq: int = find_top_level_token(tokens, actual, end_i, assign_op_eq());
      let annotation: AstTypeExpr = if eq >= 0 { parse_ast_type_from_tokens(source_name, tokens, eq as u64 + 1, end_i) } else { ast_type_empty() };
      let type_params: [AstTypeExpr] = parse_item_type_params(source_name, tokens, actual + 1, end_i);
      let generic_params: [AstGenericParam] = if actual + 2 < end_i and tokens[actual + 2].lexeme == "[" {
        parse_ast_generic_param_list(source_name, tokens, actual + 3, find_matching(tokens, actual + 2, "[", "]") as u64)
      } else {
        []
      };
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), AstItemKind.Type, name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], annotation, annotation, type_params, generic_params, ast_proc_signature_empty(), [], "")];
      set i = end_i + 1;
      continue;
    }

    if keyword == "opaque" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let name_index: u64 = if actual + 1 < end_i and tokens[actual + 1].lexeme == "type" { actual + 2 } else { actual + 1 };
      let name: string = if name_index < end_i { tokens[name_index].lexeme } else { "" };
      let eq: int = find_top_level_token(tokens, actual, end_i, assign_op_eq());
      let annotation: AstTypeExpr = if eq >= 0 { parse_ast_type_from_tokens(source_name, tokens, eq as u64 + 1, end_i) } else { ast_type_empty() };
      let type_params: [AstTypeExpr] = parse_item_type_params(source_name, tokens, name_index, end_i);
      let generic_params: [AstGenericParam] = if name_index + 1 < end_i and tokens[name_index + 1].lexeme == "[" {
        parse_ast_generic_param_list(source_name, tokens, name_index + 2, find_matching(tokens, name_index + 1, "[", "]") as u64)
      } else {
        []
      };
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), AstItemKind.Opaque, name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], annotation, annotation, type_params, generic_params, ast_proc_signature_empty(), [], "")];
      set i = end_i + 1;
      continue;
    }

    if keyword == "extern" {
      if actual + 1 < len(tokens) and tokens[actual + 1].lexeme == "type" {
        let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
        let name: string = if actual + 2 < end_i { tokens[actual + 2].lexeme } else { "" };
        let type_params: [AstTypeExpr] = parse_item_type_params(source_name, tokens, actual + 2, end_i);
        let generic_params: [AstGenericParam] = if actual + 3 < end_i and tokens[actual + 3].lexeme == "[" {
          parse_ast_generic_param_list(source_name, tokens, actual + 4, find_matching(tokens, actual + 3, "[", "]") as u64)
        } else {
          []
        };
        set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), AstItemKind.Extern, name, prefix.attributes, "", prefix.visibility, prefix.modifiers + ["extern-type"], "extern", ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], ast_type_empty(), ast_type_empty(), type_params, generic_params, ast_proc_signature_empty(), [], "")];
        set i = end_i + 1;
        continue;
      }
      let open: int = find_item_body_open(tokens, actual, len(tokens));
      if open >= 0 {
        let close: int = find_matching(tokens, open as u64, "{", "}");
        if close >= 0 {
          let abi: string = if actual + 1 < open as u64 { token_text(tokens, actual + 1, open as u64) } else { "extern" };
          set items = items + [ast_item_typed(range_id(5, prefix.start, close as u64 + 1), span_from_tokens(source_name, tokens, prefix.start, close as u64 + 1), AstItemKind.Extern, abi, prefix.attributes, "", prefix.visibility, prefix.modifiers + [abi], abi, ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, close as u64 + 1), ""), [], ast_type_empty(), ast_type_empty(), [], [], ast_proc_signature_empty(), [], token_text(tokens, actual, close as u64 + 1))];
          set i = close as u64 + 1;
          continue;
        }
      }
    }

    if keyword == "form" or keyword == "class" or keyword == "union" or keyword == "bits" or keyword == "pick" or keyword == "flags" or keyword == "trait" or keyword == "impl" {
      let open: int = find_item_body_open(tokens, actual, len(tokens));
      let end_i: u64 = if open >= 0 and find_matching(tokens, open as u64, "{", "}") >= 0 { find_matching(tokens, open as u64, "{", "}") as u64 + 1 } else { if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 + 1 } else { len(tokens) } };
      let name: string = "";
      let annotation: AstTypeExpr = ast_type_empty();
      let type_params: [AstTypeExpr] = [];
      let generic_params: [AstGenericParam] = [];
      if keyword == "impl" {
        if open >= 0 and open as u64 > actual + 1 {
          set annotation = parse_ast_type_from_tokens(source_name, tokens, actual + 1, open as u64);
          set name = annotation.text;
        }
      } else {
        if actual + 1 < end_i {
          set name = tokens[actual + 1].lexeme;
          set type_params = parse_item_type_params(source_name, tokens, actual + 1, end_i);
          if actual + 2 < end_i and tokens[actual + 2].lexeme == "[" {
            set generic_params = parse_ast_generic_param_list(source_name, tokens, actual + 3, find_matching(tokens, actual + 2, "[", "]") as u64);
          }
        }
      }
      let stmts: [AstStmt] = if open >= 0 and find_matching(tokens, open as u64, "{", "}") >= 0 {
        parse_surface_item_members(keyword, source_name, tokens, open as u64 + 1, find_matching(tokens, open as u64, "{", "}") as u64)
      } else {
        []
      };
      let members: [AstNominalMember] = if open >= 0 and find_matching(tokens, open as u64, "{", "}") >= 0 {
        parse_surface_item_member_nodes(keyword, source_name, tokens, open as u64 + 1, find_matching(tokens, open as u64, "{", "}") as u64)
      } else {
        []
      };
      set items = items + [ast_item_typed_with_members(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), item_kind_for_keyword(keyword), name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), stmts, members, annotation, annotation, type_params, generic_params, ast_proc_signature_empty(), [], "")];
      set i = end_i;
      continue;
    }

    if keyword == "proc" {
      let open: int = find_item_body_open(tokens, actual, len(tokens));
      if open < 0 {
        set i = actual + 1;
        continue;
      }
      let close: int = find_matching(tokens, open as u64, "{", "}");
      if close < 0 {
        set i = actual + 1;
        continue;
      }
      let name: string = if actual + 1 < open as u64 { tokens[actual + 1].lexeme } else { "" };
      let stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open as u64 + 1, close as u64);
      let annotation: AstTypeExpr = ast_type_empty();
      let arrow: int = find_top_level_token(tokens, actual, open as u64, "->");
      if arrow >= 0 and arrow as u64 + 1 < open as u64 {
        set annotation = parse_ast_type_from_tokens(source_name, tokens, arrow as u64 + 1, open as u64);
      }
      let type_params: [AstTypeExpr] = parse_item_type_params(source_name, tokens, actual + 1, open as u64);
      let generic_params: [AstGenericParam] = if actual + 2 < open as u64 and tokens[actual + 2].lexeme == "[" {
        parse_ast_generic_param_list(source_name, tokens, actual + 3, find_matching(tokens, actual + 2, "[", "]") as u64)
      } else {
        []
      };
      let abi: string = prefix_abi(prefix.modifiers);
      let signature: AstProcSignature = parse_ast_proc_signature_from_tokens(source_name, tokens, actual, open as u64, abi);
      set items = items + [ast_item_typed(range_id(5, prefix.start, close as u64 + 1), span_from_tokens(source_name, tokens, prefix.start, close as u64 + 1), AstItemKind.Proc, name, prefix.attributes, "", prefix.visibility, prefix.modifiers, abi, ast_expr_unknown(range_id(1, actual, actual + 1), span_from_tokens(source_name, tokens, actual, actual + 1), ""), stmts, annotation, ast_type_empty(), type_params, generic_params, signature, [], "")];
      set i = close as u64 + 1;
      continue;
    }

    if keyword == "intrinsic" or keyword == "query" {
      let end_i: u64 = if find_top_level_token(tokens, actual, len(tokens), ";") >= 0 { find_top_level_token(tokens, actual, len(tokens), ";") as u64 } else { len(tokens) };
      let name: string = if actual + 1 < end_i { tokens[actual + 1].lexeme } else { "" };
      let arrow: int = find_top_level_token(tokens, actual, end_i, "->");
      let annotation: AstTypeExpr = if arrow >= 0 and arrow as u64 + 1 < end_i { parse_ast_type_from_tokens(source_name, tokens, arrow as u64 + 1, end_i) } else { ast_type_empty() };
      let type_params: [AstTypeExpr] = parse_item_type_params(source_name, tokens, actual + 1, end_i);
      let generic_params: [AstGenericParam] = if actual + 2 < end_i and tokens[actual + 2].lexeme == "[" {
        parse_ast_generic_param_list(source_name, tokens, actual + 3, find_matching(tokens, actual + 2, "[", "]") as u64)
      } else {
        []
      };
      let signature: AstProcSignature = parse_ast_proc_signature_from_tokens(source_name, tokens, actual, end_i, prefix_abi(prefix.modifiers));
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), item_kind_for_keyword(keyword), name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], annotation, ast_type_empty(), type_params, generic_params, signature, [], "")];
      set i = end_i + 1;
      continue;
    }

    if keyword == "compiler" or keyword == "pass" or keyword == "backend" or keyword == "diagnostic" or keyword == "macro" or keyword == "entry" {
      let open: int = find_item_body_open(tokens, actual, len(tokens));
      let has_block: bool = open >= 0 and find_matching(tokens, open as u64, "{", "}") >= 0;
      let end_i: u64 = len(tokens);
      if has_block {
        set end_i = find_matching(tokens, open as u64, "{", "}") as u64 + 1;
      } else {
        let end_token_index: int = find_top_level_token(tokens, actual, len(tokens), ";");
        if end_token_index >= 0 {
          set end_i = end_token_index as u64;
        }
      }
      let name: string = keyword;
      let has_name_token: bool = actual + 1 < len(tokens);
      if has_name_token {
        let candidate_name: Token = tokens[actual + 1];
        let name_kind_ok: bool = candidate_name.kind == TokenKind.Ident or candidate_name.kind == TokenKind.Keyword or candidate_name.kind == TokenKind.String;
        if name_kind_ok {
          set name = candidate_name.lexeme;
        }
      }
      let meta_args: [string] = parse_item_meta_args(tokens, actual + 1, end_i);
      set items = items + [ast_item_typed(range_id(5, prefix.start, end_i), span_from_tokens(source_name, tokens, prefix.start, end_i), item_kind_for_keyword(keyword), name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, end_i), ""), [], ast_type_empty(), ast_type_empty(), [], [], ast_proc_signature_empty(), meta_args, token_text(tokens, actual, end_i))];
      if has_block {
        set i = end_i;
      } else {
        set i = end_i + 1;
      }
      continue;
    }

    if keyword == "test" or keyword == "bench" {
      let open: int = find_item_body_open(tokens, actual, len(tokens));
      if open < 0 {
        set i = actual + 1;
        continue;
      }
      let close: int = find_matching(tokens, open as u64, "{", "}");
      if close < 0 {
        set i = actual + 1;
        continue;
      }
      let name: string = if actual + 1 < open as u64 and tokens[actual + 1].kind == TokenKind.String { tokens[actual + 1].lexeme } else { keyword };
      let stmts: [AstStmt] = parse_block_stmts(source_name, tokens, open as u64 + 1, close as u64);
      set items = items + [ast_item_typed(range_id(5, prefix.start, close as u64 + 1), span_from_tokens(source_name, tokens, prefix.start, close as u64 + 1), item_kind_for_keyword(keyword), name, prefix.attributes, "", prefix.visibility, prefix.modifiers, prefix_abi(prefix.modifiers), ast_expr_unknown(0, span_from_tokens(source_name, tokens, prefix.start, close as u64 + 1), ""), stmts, ast_type_empty(), ast_type_empty(), [], [], ast_proc_signature_empty(), [], "")];
      set i = close as u64 + 1;
      continue;
    }

    set i = actual + 1;
  }

  if len(items) == 0 {
    give ast_module_empty();
  }
  give ast_module(9000000 + len(items), span_from_tokens(source_name, tokens, 0, len(tokens) - 1), items);
}
