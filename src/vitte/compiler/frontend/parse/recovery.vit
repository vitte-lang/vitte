space vitte/compiler/frontend/parse/recovery

use vitte/compiler/frontend/lexer/token.{ Token, TokenKind }

const PARSE_DIAG_CAP: u64 = 3

proc capped_diag_count(count: u64) -> u64 {
  if count > PARSE_DIAG_CAP { give PARSE_DIAG_CAP; }
  give count;
}

proc recovery_applied(diagnostic_count: u64, recovery_count: u64) -> bool {
  give recovery_count > 0 or diagnostic_count > PARSE_DIAG_CAP;
}

proc is_toplevel_sync_keyword(lex: string) -> bool {
  if lex == "space" or lex == "use" or lex == "export" or lex == "const" or lex == "static" or lex == "global" { give true; }
  if lex == "type" or lex == "opaque" or lex == "extern" or lex == "form" or lex == "class" or lex == "union" { give true; }
  if lex == "bits" or lex == "pick" or lex == "flags" or lex == "trait" or lex == "impl" or lex == "proc" { give true; }
  if lex == "intrinsic" or lex == "compiler" or lex == "query" or lex == "pass" or lex == "backend" { give true; }
  if lex == "diagnostic" or lex == "macro" or lex == "comptime" or lex == "static_assert" or lex == "test" or lex == "bench" or lex == "entry" { give true; }
  give false;
}

proc recover_stmt_index(tokens: [Token], start: u64) -> u64 {
  let i: u64 = start;
  while i < len(tokens) {
    let tok: Token = tokens[i];
    if tok.kind == TokenKind.Eof or tok.lexeme == "}" or is_toplevel_sync_keyword(tok.lexeme) {
      give i;
    }
    if tok.lexeme == ";" {
      give i + 1;
    }
    set i = i + 1;
  }
  give len(tokens);
}

proc recover_block_index(tokens: [Token], start: u64) -> u64 {
  let i: u64 = start;
  while i < len(tokens) {
    let tok: Token = tokens[i];
    if tok.kind == TokenKind.Eof or tok.lexeme == "}" {
      give i;
    }
    set i = i + 1;
  }
  give len(tokens);
}

proc recover_decl_index(tokens: [Token], start: u64) -> u64 {
  let i: u64 = start;
  while i < len(tokens) {
    let tok: Token = tokens[i];
    if tok.kind == TokenKind.Eof or tok.lexeme == "}" or is_toplevel_sync_keyword(tok.lexeme) {
      give i;
    }
    if tok.lexeme == ";" {
      give i + 1;
    }
    set i = i + 1;
  }
  give len(tokens);
}

proc recover_expr_index(tokens: [Token], start: u64) -> u64 {
  let i: u64 = start;
  while i < len(tokens) {
    let tok: Token = tokens[i];
    if tok.kind == TokenKind.Eof or tok.lexeme == ";" or tok.lexeme == "," or tok.lexeme == ")" or tok.lexeme == "]" or tok.lexeme == "}" or tok.lexeme == ":" {
      give i;
    }
    set i = i + 1;
  }
  give len(tokens);
}

proc recover_type_index(tokens: [Token], start: u64) -> u64 {
  let i: u64 = start;
  while i < len(tokens) {
    let tok: Token = tokens[i];
    if tok.kind == TokenKind.Eof or tok.lexeme == "," or tok.lexeme == ")" or tok.lexeme == "]" or tok.lexeme == "}" or tok.lexeme == ";" or tok.lexeme == "=" or tok.lexeme == "{" {
      give i;
    }
    set i = i + 1;
  }
  give len(tokens);
}

proc recover_pattern_index(tokens: [Token], start: u64) -> u64 {
  let i: u64 = start;
  while i < len(tokens) {
    let tok: Token = tokens[i];
    if tok.kind == TokenKind.Eof or tok.lexeme == "," or tok.lexeme == ")" or tok.lexeme == "]" or tok.lexeme == "}" or tok.lexeme == ":" or tok.lexeme == "=" or tok.lexeme == "in" {
      give i;
    }
    set i = i + 1;
  }
  give len(tokens);
}
