space vitte/compiler/frontend/parse/errors

form ParseDiagnostic {
  code: string
  message: string
  line: u64
  column: u64
  width: u64
}

proc parse_error(code: string, message: string, line: u64, column: u64, width: u64) -> ParseDiagnostic {
  give ParseDiagnostic { code: code, message: message, line: line, column: column, width: width };
}
