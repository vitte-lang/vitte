    blockers: ["Expression parsing", "Block parsing"]
  }
  set rules = rules + [s4]

  let s5: GrammarRule = GrammarRule {
    name: "while_stmt",
    kind: "statement",
    status: ImplementationStatus.NotStarted,
    parser_function: "",
    ast_type: "Stmt.While",
    test_coverage: 0,
    notes: "while COND BLOCK",
    blockers: ["Expression parsing", "Block parsing"]
  }
  set rules = rules + [s5]

  let s6: GrammarRule = GrammarRule {
    name: "for_stmt",
    kind: "statement",
    status: ImplementationStatus.NotStarted,
    parser_function: "",
    ast_type: "Stmt.For",
    test_coverage: 0,
    notes: "for PATTERN in EXPR BLOCK",
    blockers: ["Pattern parsing", "Expression parsing", "Block parsing"]
  }
  set rules = rules + [s6]

  let s7: GrammarRule = GrammarRule {
    name: "match_stmt",
    kind: "statement",
    status: ImplementationStatus.NotStarted,
    parser_function: "",
    ast_type: "Stmt.Match",
    test_coverage: 0,
    notes: "match EXPR { case PATTERN [if COND] => EXPR; ... }",
    blockers: ["Pattern parsing", "Expression parsing", "Arm parsing"]
  }
  set rules = rules + [s7]

  // ... continue with remaining statement types
  // This is a partial list - full version has all 25

  give rules
}

// ============================================================================
// EXPRESSION RULES (27+ from grammar)
// ============================================================================

proc _get_expression_rules() -> [GrammarRule] {
  let rules: [GrammarRule] = []

  // Partial list - showing structure
  let e1: GrammarRule = GrammarRule {
    name: "binary_expr",
    kind: "expression",
    status: ImplementationStatus.Partial,
    parser_function: "_parse_binary_expr",
    ast_type: "Expr.Binary",
    test_coverage: 50,
    notes: "Basic binary operators, missing some precedence",
    blockers: ["Operator precedence verification"]
  }
  set rules = rules + [e1]

  give rules
}

// ============================================================================
// SUMMARY AND REPORTING
// ============================================================================

proc generate_alignment_report() -> AlignmentReport {
  let decl_rules: [GrammarRule] = _get_declaration_rules()
  let stmt_rules: [GrammarRule] = _get_statement_rules()
  let expr_rules: [GrammarRule] = _get_expression_rules()

  let all_rules: [GrammarRule] = decl_rules + stmt_rules + expr_rules

  let total: int = all_rules.len
  let not_started: int = 0
  let partial: int = 0
  let complete: int = 0
  let tested: int = 0

  let i: int = 0
  while i < all_rules.len {
    let rule: GrammarRule = all_rules[i]
    if rule.status == ImplementationStatus.NotStarted {
      set not_started = not_started + 1
    }
    if rule.status == ImplementationStatus.Partial {
      set partial = partial + 1
    }
    if rule.status == ImplementationStatus.Complete {
      set complete = complete + 1
    }
    if rule.status == ImplementationStatus.Tested {
      set tested = tested + 1
    }
    set i = i + 1
  }

  let coverage_percent: int = (tested * 100) / total
  if coverage_percent < 0 { set coverage_percent = 0 }

  let report: AlignmentReport = AlignmentReport {
    grammar_file: "src/vitte/grammar/vitte.ebnf",
    parser_module: "src/vitte/compiler/frontend/parser_extended.vit",
    total_rules: total,
    rules_by_status: [
      (ImplementationStatus.NotStarted, not_started),
      (ImplementationStatus.Partial, partial),
      (ImplementationStatus.Complete, complete),
      (ImplementationStatus.Tested, tested)
    ],
    coverage_percent: coverage_percent,
    critical_gaps: [],
    high_priority_gaps: [],
    medium_priority_gaps: [],
    all_rules: all_rules,
    generated_at: ""
  }

  give report
}

export *
