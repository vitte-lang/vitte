space vitte/compiler/frontend/grammar_alignment_checker

// ============================================================================
// GRAMMAR-PARSER ALIGNMENT VERIFICATION TOOL
// ============================================================================
// This module verifies that the parser implementation covers all rules
// defined in src/vitte/grammar/vitte.ebnf
//
// Purpose: Detect gaps between grammar and parser, track implementation status,
// and guide incremental implementation of missing features.

use ast_extended
use diagnostics

// ============================================================================
// ALIGNMENT STATUS TYPES
// ============================================================================

pick ImplementationStatus {
  NotStarted,           // No parsing for this rule
  Partial,              // Basic parsing, minimal AST
  Complete,             // Full parsing and AST building
  Tested                // Fully tested and validated
}

form GrammarRule {
  name: string,         // Rule name from grammar
  kind: string,         // "declaration" | "statement" | "expression" | "type" | "pattern" | "other"
  status: ImplementationStatus,
  parser_function: string,     // Name of parser function, empty if not started
  ast_type: string,    // Name of AST type used
  test_coverage: int,  // % of test cases passing
  notes: string,       // Implementation notes
  blockers: [string]   // Things blocking implementation
}

form AlignmentReport {
  grammar_file: string,
  parser_module: string,
  total_rules: int,
  rules_by_status: [(ImplementationStatus, int)],
  coverage_percent: int,
  critical_gaps: [GrammarRule],
  high_priority_gaps: [GrammarRule],
  medium_priority_gaps: [GrammarRule],
  all_rules: [GrammarRule],
  generated_at: string
}

// ============================================================================
// DECLARATION RULES (31 from grammar)
// ============================================================================

