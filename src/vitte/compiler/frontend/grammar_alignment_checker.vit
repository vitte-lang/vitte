space vitte/compiler/frontend/grammar_alignment_checker

use vitte/compiler/frontend/lexer/token.{ Token, TokenKind }

export *

const PARSE_DIAG_CAP: u64 = 3
const RECOVERY_WINDOW_LIMIT: u64 = 64

pick RecoveryKind {
    None
    Statement
    Block
    Declaration
    Expression
    Type
    Pattern
    Toplevel
}

pick RecoveryReason {
    UnexpectedToken
    MissingToken
    InvalidExpression
    InvalidType
    InvalidPattern
    UnterminatedBlock
    UnexpectedEof
}

form RecoveryPoint {
    index: u64
    kind: RecoveryKind
    recovered: bool
}

form RecoveryStats {
    diagnostic_count: u64
    recovery_count: u64
    skipped_token_count: u64
    capped: bool
}

form RecoveryWindow {
    start: u64
    current: u64
    limit: u64
}

form RecoveryEvent {
    kind: RecoveryKind
    reason: RecoveryReason
    start: u64
    recovered_index: u64
}

proc recovery_point(index: u64, kind: RecoveryKind, recovered: bool) -> RecoveryPoint {
    give RecoveryPoint {
        index: index,
        kind: kind,
        recovered: recovered
    };
}

proc recovery_stats(diagnostic_count: u64, recovery_count: u64, skipped_token_count: u64) -> RecoveryStats {
    give RecoveryStats {
        diagnostic_count: diagnostic_count,
        recovery_count: recovery_count,
        skipped_token_count: skipped_token_count,
        capped: diagnostic_count > PARSE_DIAG_CAP
    };
}

proc recovery_window(start: u64) -> RecoveryWindow {
    give RecoveryWindow {
        start: start,
        current: start,
        limit: RECOVERY_WINDOW_LIMIT
    };
}

proc recovery_event(kind: RecoveryKind, reason: RecoveryReason, start: u64, recovered_index: u64) -> RecoveryEvent {
    give RecoveryEvent {
        kind: kind,
        reason: reason,
        start: start,
        recovered_index: recovered_index
    };
}

proc parse_diag_cap() -> u64 {
    give PARSE_DIAG_CAP;
}

proc recovery_window_limit() -> u64 {
    give RECOVERY_WINDOW_LIMIT;
}

proc recovery_eq() -> string {
    give slice("x=y", 1, 2);
}

proc capped_diag_count(count: u64) -> u64 {
    if count > PARSE_DIAG_CAP {
        give PARSE_DIAG_CAP;
    }

    give count;
}

proc recovery_applied(diagnostic_count: u64, recovery_count: u64) -> bool {
    give recovery_count > 0
        or diagnostic_count > PARSE_DIAG_CAP;
}

proc eof_token(tok: Token) -> bool {
    give tok.kind == TokenKind.Eof;
}

proc newline_token(tok: Token) -> bool {
    give tok.kind == TokenKind.Newline;
}

proc comment_token(tok: Token) -> bool {
    give tok.kind == TokenKind.Comment;
}

proc trivia_token(tok: Token) -> bool {
    give newline_token(tok)
        or comment_token(tok);
}

proc block_end_token(tok: Token) -> bool {
    give tok.lexeme == "}";
}

proc expression_boundary(tok: Token) -> bool {
    give eof_token(tok)
        or tok.lexeme == ";"
        or tok.lexeme == ","
        or tok.lexeme == ":"
        or tok.lexeme == ")"
        or tok.lexeme == "]"
        or tok.lexeme == "}";
}

proc type_boundary(tok: Token) -> bool {
    give eof_token(tok)
        or tok.lexeme == ","
        or tok.lexeme == ";"
        or tok.lexeme == recovery_eq()
        or tok.lexeme == "{"
        or tok.lexeme == ")"
        or tok.lexeme == "]"
        or tok.lexeme == "}";
}

proc pattern_boundary(tok: Token) -> bool {
    give eof_token(tok)
        or tok.lexeme == ","
        or tok.lexeme == ":"
        or tok.lexeme == recovery_eq()
        or tok.lexeme == "in"
        or tok.lexeme == ")"
        or tok.lexeme == "]"
        or tok.lexeme == "}";
}

proc statement_boundary(tok: Token) -> bool {
    give eof_token(tok)
        or tok.lexeme == ";"
        or tok.lexeme == "}";
}

proc declaration_boundary(tok: Token) -> bool {
    give eof_token(tok)
        or tok.lexeme == ";"
        or tok.lexeme == "}"
        or is_toplevel_sync_keyword(tok.lexeme);
}

proc is_toplevel_sync_keyword(lex: string) -> bool {
    if lex == "space" or lex == "use" or lex == "export" {
        give true;
    }

    if lex == "const" or lex == "static" or lex == "global" {
        give true;
    }

    if lex == "type" or lex == "opaque" or lex == "extern" {
        give true;
    }

    if lex == "form" or lex == "class" or lex == "union" {
        give true;
    }

    if lex == "bits" or lex == "pick" or lex == "flags" {
        give true;
    }

    if lex == "trait" or lex == "impl" or lex == "proc" {
        give true;
    }

    if lex == "intrinsic" or lex == "compiler" or lex == "query" {
        give true;
    }

    if lex == "pass" or lex == "backend" or lex == "diagnostic" {
        give true;
    }

    if lex == "macro" or lex == "comptime" or lex == "static_assert" {
        give true;
    }

    if lex == "test" or lex == "bench" or lex == "entry" {
        give true;
    }

    give false;
}

proc token_at(tokens: [Token], index: u64) -> Token {
    if index >= len(tokens) {
        give Token {
            kind: TokenKind.Eof,
            lexeme: "",
            line: 0,
            column: 0
        };
    }

    give tokens[index];
}

proc skip_trivia(tokens: [Token], start: u64) -> u64 {
    let i: u64 = start;

    while i < len(tokens) {
        if not trivia_token(tokens[i]) {
            break;
        }

        set i = i + 1;
    }

    give i;
}

proc recover_stmt_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);

        if declaration_boundary(tok) {
            if tok.lexeme == ";" {
                give i + 1;
            }

            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_block_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    let depth: u64 = 0;

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);

        if tok.lexeme == "{" {
            set depth = depth + 1;
        }

        if tok.lexeme == "}" {
            if depth == 0 {
                give i;
            }

            set depth = depth - 1;
        }

        if eof_token(tok) {
            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_decl_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);

        if declaration_boundary(tok) {
            if tok.lexeme == ";" {
                give i + 1;
            }

            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_expr_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);

        if expression_boundary(tok) {
            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_type_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);

        if type_boundary(tok) {
            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_pattern_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);

        if pattern_boundary(tok) {
            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_toplevel_index(tokens: [Token], start: u64) -> u64 {
    let i: u64 = skip_trivia(tokens, start);

    while i < len(tokens) {
        let tok: Token = token_at(tokens, i);
        let sync_point: bool = eof_token(tok) or is_toplevel_sync_keyword(tok.lexeme);

        if sync_point {
            give i;
        }

        set i = i + 1;
    }

    give len(tokens);
}

proc recover_statement(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_stmt_index(tokens, start),
        RecoveryKind.Statement,
        true
    );
}

proc recover_block(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_block_index(tokens, start),
        RecoveryKind.Block,
        true
    );
}

proc recover_declaration(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_decl_index(tokens, start),
        RecoveryKind.Declaration,
        true
    );
}

proc recover_expression(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_expr_index(tokens, start),
        RecoveryKind.Expression,
        true
    );
}

proc recover_type(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_type_index(tokens, start),
        RecoveryKind.Type,
        true
    );
}

proc recover_pattern(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_pattern_index(tokens, start),
        RecoveryKind.Pattern,
        true
    );
}

proc recover_toplevel(tokens: [Token], start: u64) -> RecoveryPoint {
    give recovery_point(
        recover_toplevel_index(tokens, start),
        RecoveryKind.Toplevel,
        true
    );
}

proc skipped_token_count(start: u64, recovered: u64) -> u64 {
    if recovered <= start {
        give 0;
    }

    give recovered - start;
}

proc recovery_reason_name(reason: RecoveryReason) -> string {
    if reason == RecoveryReason.UnexpectedToken {
        give "unexpected-token";
    }

    if reason == RecoveryReason.MissingToken {
        give "missing-token";
    }

    if reason == RecoveryReason.InvalidExpression {
        give "invalid-expression";
    }

    if reason == RecoveryReason.InvalidType {
        give "invalid-type";
    }

    if reason == RecoveryReason.InvalidPattern {
        give "invalid-pattern";
    }

    if reason == RecoveryReason.UnterminatedBlock {
        give "unterminated-block";
    }

    give "unexpected-eof";
}

proc recovery_kind_name(kind: RecoveryKind) -> string {
    if kind == RecoveryKind.Statement {
        give "statement";
    }

    if kind == RecoveryKind.Block {
        give "block";
    }

    if kind == RecoveryKind.Declaration {
        give "declaration";
    }

    if kind == RecoveryKind.Expression {
        give "expression";
    }

    if kind == RecoveryKind.Type {
        give "type";
    }

    if kind == RecoveryKind.Pattern {
        give "pattern";
    }

    if kind == RecoveryKind.Toplevel {
        give "toplevel";
    }

    give "none";
}

proc format_recovery_event(event: RecoveryEvent) -> string {
    let start_text: string = event.start as string;
    let recovered_text: string = event.recovered_index as string;
    give recovery_kind_name(event.kind)
        + ":"
        + recovery_reason_name(event.reason)
        + "@"
        + start_text
        + "->"
        + recovered_text;
}

proc recovery_selftest() -> bool {
    let tokens: [Token] = [
        Token {
            kind: TokenKind.Identifier,
            lexeme: "let",
            line: 1,
            column: 1
        },

        Token {
            kind: TokenKind.Identifier,
            lexeme: "x",
            line: 1,
            column: 5
        },

        Token {
            kind: TokenKind.Symbol,
            lexeme: ";",
            line: 1,
            column: 6
        },

        Token {
            kind: TokenKind.Identifier,
            lexeme: "proc",
            line: 2,
            column: 1
        }
    ];

    let stmt: RecoveryPoint = recover_statement(tokens, 0);

    let top: RecoveryPoint = recover_toplevel(tokens, 1);

    let stats: RecoveryStats = recovery_stats(10, 1, skipped_token_count(0, stmt.index));

    let event: RecoveryEvent = recovery_event(RecoveryKind.Statement, RecoveryReason.UnexpectedToken, 0, stmt.index);

    give stmt.index == 3
        and top.index == 3
        and stats.capped
        and stats.skipped_token_count == 3
        and recovery_applied(10, 1)
        and is_toplevel_sync_keyword("proc")
        and parse_diag_cap() == 3
        and recovery_window_limit() == 64
        and format_recovery_event(event)
            == "statement:unexpected-token@0->3";
}
