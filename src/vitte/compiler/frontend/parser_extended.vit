// ============================================================================
// MAIN PARSING INTERFACE
// ============================================================================

proc parse_with_extended_ast(
  tokens: [token.Token],
  source_name: string,
  module_name: string
) -> (ast_extended.ExtendedModule, diagnostics.DiagnosticBag) {
  let module: ast_extended.ExtendedModule = ast_extended.ExtendedModule {
    source_name: source_name,
    space_name: "",
    imports: [],
    exports: [],
    declarations: [],
    diagnostics: [],
    decl_count_by_kind: [],
    stmt_count: 0,
    expr_count: 0
  }

  let bag: diagnostics.DiagnosticBag = diagnostics.new_bag()
  let state: ParserState = ParserState {
    tokens: tokens,
    current_index: 0,
    current_line: 1,
    current_column: 1,
    module_name: module_name,
    diagnostics: bag
  }

  // Parse all top-level declarations
  while state.current_index < state.tokens.len {
    let tok: token.Token = _current_token(state)

    if tok.kind == token.TokenKind.Eof {
      give (module, bag)
    }

    let result: (ParserState, ast_extended.Decl, bool) = _parse_toplevel_decl(state)
    let state = result.0
    let decl: ast_extended.Decl = result.1
    let success: bool = result.2

    if success {
      set module.declarations = module.declarations + [decl]
      if decl.kind == ast_extended.DeclKind.Use {
        set module.imports = module.imports + [decl]
      }
    }
  }

  give (module, bag)
}

export *
