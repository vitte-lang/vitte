  let tok: token.Token = _current_token(state_after_kw)
  let decl: ast_extended.Decl = ast_extended.empty_decl(ast_extended.DeclKind.TypeAlias, tok.text)
  give (_advance(state_after_kw), decl, true)
}

proc _parse_opaque_type_decl(state: ParserState) -> (ParserState, ast_extended.Decl, bool) {
  let state_after_kw: ParserState = _advance(state)
  let state_after_type: ParserState = _advance(state_after_kw)
  let tok: token.Token = _current_token(state_after_type)
  let decl: ast_extended.Decl = ast_extended.empty_decl(ast_extended.DeclKind.OpaqueType, tok.text)
  give (_advance(state_after_type), decl, true)
}

proc _parse_extern_decl(state: ParserState) -> (ParserState, ast_extended.Decl, bool) {
  let state_after_kw: ParserState = _advance(state)
  let tok: token.Token = _current_token(state_after_kw)

  if tok.text == "type" {
    let state_after_type: ParserState = _advance(state_after_kw)
    let name_tok: token.Token = _current_token(state_after_type)
    let decl: ast_extended.Decl = ast_extended.empty_decl(ast_extended.DeclKind.ExternType, name_tok.text)
    give (_advance(state_after_type), decl, true)
  }

  if tok.text == "{" {
    let decl: ast_extended.Decl = ast_extended.empty_decl(ast_extended.DeclKind.ExternBlock, "extern")
    give (state_after_kw, decl, true)
  }

  let decl: ast_extended.Decl = ast_extended.empty_decl(ast_extended.DeclKind.Unknown, tok.text)
  give (state_after_kw, decl, false)
}

proc _parse_form_decl(state: ParserState) -> (ParserState, ast_extended.Decl, bool) {
  let state_after_kw: ParserState = _advance(state)
