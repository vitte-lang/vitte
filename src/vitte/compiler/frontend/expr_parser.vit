  give Expr {
    kind: kind,
    text: text,
    left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [], left: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] }, line: 0, column: 0, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } },
    right: Expr { kind: ExprKind.Unknown, text: "", left: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } }, line: 0, column: 0, operator: "", args: [], right: Expr { kind: ExprKind.Unknown, text: "", line: 0, column: 0, operator: "", args: [] } },
    operator: "",
    args: [],
    line: line,
    column: column
  }
}

export *
