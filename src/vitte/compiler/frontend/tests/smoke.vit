space vitte/compiler/frontend/tests/smoke

use src/vitte/compiler/bootstrap as bootstrap
use src/vitte/compiler/frontend/diagnostics as diagnostics
use src/vitte/compiler/frontend/lexer as lexer
use src/vitte/compiler/frontend/parser as parser
use src/vitte/compiler/frontend/token as token

form FrontendManifest {
  stage: string,
  source_root: string,
  language: string
}

proc frontend_manifest_stays_stable() -> bool {
  let info: FrontendManifest = FrontendManifest {
    stage: bootstrap.bootstrap_stage(),
    source_root: "src/vitte/compiler/frontend",
    language: bootstrap.bootstrap_language()
  }
  if info.stage != bootstrap.bootstrap_stage() { give false }
  if info.source_root != "src/vitte/compiler/frontend" { give false }
  if info.language != bootstrap.bootstrap_language() { give false }
  give true
}

proc frontend_lexer_reports_empty_source_diagnostics() -> bool {
  let lexed: lexer.LexedSource = lexer.lex_source("demo.vit", "")
  if lexed.source_name != "demo.vit" { give false }
  if lexed.token_count != 0 { give false }
  if diagnostics.count(lexed.diagnostics) != 1 { give false }
  if diagnostics.count_errors(lexed.diagnostics) != 0 { give false }
  if diagnostics.count_warnings(lexed.diagnostics) != 1 { give false }
  if diagnostics.count_infos(lexed.diagnostics) != 0 { give false }
  if not diagnostics.has_warnings(lexed.diagnostics) { give false }
  if diagnostics.has_errors(lexed.diagnostics) { give false }
  give true
}

proc frontend_lexer_recognizes_doc_comments_and_attributes() -> bool {
  let source: string = "/// documentation\n#[attr(name = \"value\")]\n#![inner_attr]\n"
  let lexed: lexer.LexedSource = lexer.lex_source("demo.vit", source)
  if lexed.token_count != 6 { give false }
  if lexed.tokens[0].kind != token.TokenKind.DocComment { give false }
  if lexed.tokens[2].kind != token.TokenKind.Attribute { give false }
  if lexed.tokens[4].kind != token.TokenKind.Attribute { give false }
  give true
}

proc frontend_lexer_recognizes_raw_docstring_literals() -> bool {
  let source: string = "r\"\"\"docstring\"\"\""
  let lexed: lexer.LexedSource = lexer.lex_source("demo.vit", source)
  if lexed.token_count != 1 { give false }
  if lexed.tokens[0].kind != token.TokenKind.String { give false }
  if lexed.tokens[0].text != source { give false }
  give true
}

proc frontend_parser_captures_declarations_and_diagnostics() -> bool {
  let parsed: parser.ParsedSource = parser.parse_source(
    "demo.vit",
    "space demo/app\nuse vitte/io\nproc main {\n  give 1\n}\n"
  )
  if parsed.source_name != "demo.vit" { give false }
  if parsed.module_name != "demo/app" { give false }
  if parsed.space_name != "demo/app" { give false }
  if parsed.space_count != 1 { give false }
  if parsed.use_count != 1 { give false }
  if parsed.proc_count != 1 { give false }
  if parsed.decl_count != 3 { give false }
  if parsed.unknown_count != 0 { give false }
  if parsed.line_count != parser.count_lines("space demo/app\nuse vitte/io\nproc main {\n  give 1\n}\n") { give false }
  if parsed.token_count != lexer.count_tokens("space demo/app\nuse vitte/io\nproc main {\n  give 1\n}\n") { give false }
  if diagnostics.count(parsed.diagnostics) != 0 { give false }
  if diagnostics.count_errors(parsed.diagnostics) != 0 { give false }
  give true
}

proc frontend_parser_warns_on_unknown_top_level_lines() -> bool {
  let parsed: parser.ParsedSource = parser.parse_source("demo.vit", "mystery line\n")
  if parsed.unknown_count != 1 { give false }
  if diagnostics.count(parsed.diagnostics) != 2 { give false }
  if diagnostics.count_notes(parsed.diagnostics) != 1 { give false }
  if diagnostics.is_empty(parsed.diagnostics) { give false }
  if not diagnostics.has_notes(parsed.diagnostics) { give false }
  if not diagnostics.has_warnings(parsed.diagnostics) { give false }
  give true
}

proc frontend_diagnostics_empty_bag_stays_empty() -> bool {
  let bag: diagnostics.DiagnosticBag = diagnostics.new_bag()
  if not diagnostics.is_empty(bag) { give false }
  if diagnostics.count(bag) != 0 { give false }
  if diagnostics.count_notes(bag) != 0 { give false }
  if diagnostics.has_notes(bag) { give false }
  give true
}

proc frontend_diagnostics_note_bag_is_not_empty() -> bool {
  let bag: diagnostics.DiagnosticBag = diagnostics.add_note(
    diagnostics.new_bag(),
    "N0001",
    "note only",
    "demo.vit",
    1,
    1
  )
  if diagnostics.is_empty(bag) { give false }
  if diagnostics.count_notes(bag) != 1 { give false }
  if not diagnostics.has_notes(bag) { give false }
  if diagnostics.count_errors(bag) != 0 { give false }
  give true
}

export *
