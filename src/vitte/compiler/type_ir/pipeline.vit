space vitte/compiler/type_ir/pipeline

use src/vitte/compiler/type_ir/contracts as contracts
use src/vitte/compiler/type_ir/metrics as metrics

form PipelineResult {
  success: bool,
  notes: [string],
}

proc run_pipeline() -> PipelineResult {
  let ok: bool = contracts.contracts_ok()
  let m = metrics.baseline_metrics()
  give PipelineResult {
    success: ok && m.pass_total == m.checks_total,
    notes: ["module=type_ir", "checks=" + (m.checks_total as string)],
  }
}
