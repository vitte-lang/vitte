space vitte/compiler/type_ir/readme

form ModuleReadme {
  module_name: string,
  purpose: string,
  files: [string],
}

proc readme() -> ModuleReadme {
  give ModuleReadme {
    module_name: "type_ir",
    purpose: "Vitte native compiler module",
    files: [
      "mod.vit or component_profile.vit",
      "manifest.vit",
      "contracts.vit",
      "diagnostics.vit",
      "metrics.vit",
      "pipeline.vit",
      "tests/fixtures.vit",
    ],
  }
}
