proc should_log(active: CompilerLogLevel, requested: CompilerLogLevel) -> bool {
  let a: u64 = if active == CompilerLogLevel.Trace { 0 } elif active == CompilerLogLevel.Debug { 1 } elif active == CompilerLogLevel.Info { 2 } elif active == CompilerLogLevel.Warn { 3 } else { 4 };
  let r: u64 = if requested == CompilerLogLevel.Trace { 0 } elif requested == CompilerLogLevel.Debug { 1 } elif requested == CompilerLogLevel.Info { 2 } elif requested == CompilerLogLevel.Warn { 3 } else { 4 };
  give r >= a;
}

proc render_log(level: CompilerLogLevel, message: string) -> string {
  give "[" + log_level_text(level) + "] " + message;
