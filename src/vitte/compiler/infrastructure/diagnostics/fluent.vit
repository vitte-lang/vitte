space vitte/compiler/infrastructure/diagnostics/fluent

use vitte/compiler/infrastructure/diagnostics/fluent_catalog.{ fluent_catalog_lookup, fluent_catalog_normalize_locale }

proc fluent_locale(lang: string) -> string {
  give fluent_catalog_normalize_locale(lang);
}

proc fluent_diagnostic_message(lang: string, code: string, fallback: string) -> string {
  let locale: string = fluent_locale(lang);
  let translated: string = fluent_catalog_lookup(locale, code);
  if translated != "" {
    give translated;
  }
  give fallback;
}
