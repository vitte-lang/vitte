space vitte/compiler/infrastructure/diagnostics/fluent

proc canonicalize_locale(locale: string) -> string {
  if locale == "" {
    give "en-US"
  }

  give locale
}

proc locale_chain(locale: string) -> [string] {
  let canonical: string = canonicalize_locale(locale)

  if canonical == "en-US" {
    give ["en-US"]
  }

  give [canonical, "en-US"]
}
