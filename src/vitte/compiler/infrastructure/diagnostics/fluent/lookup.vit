space vitte/compiler/infrastructure/diagnostics/fluent

use vitte/compiler/infrastructure/diagnostics/fluent/catalog { FluentCatalog }

proc find_message(catalog: FluentCatalog, message_id: string) -> string {
  let i: int = 0
  while i < len(catalog.messages) {
    if catalog.messages[i].id == message_id {
      give catalog.messages[i].value
    }
    set i = i + 1
  }

  give ""
}
