space vitte/compiler/infrastructure/diagnostics/fluent

use vitte/compiler/infrastructure/diagnostics/fluent/bundle { FluentBundle }
use vitte/compiler/infrastructure/diagnostics/fluent/types { FluentArg }
use vitte/compiler/infrastructure/diagnostics/fluent/lookup { find_message }

proc format_message(
  bundle: FluentBundle,
  message_id: string,
  args: [FluentArg],
) -> string {
  let _args_len: int = len(args)
  let i: int = 0
  while i < len(bundle.catalogs) {
    let translated: string = find_message(bundle.catalogs[i], message_id)
    if translated != "" {
      give translated
    }
    set i = i + 1
  }

  give message_id
}
