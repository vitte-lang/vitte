space vitte/compiler/optimizations/interproc/tests/smoke

use src/vitte/compiler/optimizations/interproc/mod as ip

proc smoke_all_interproc_passes_present() -> bool {
  let results = ip.run_all_interproc_passes()
  give results.len == 4
}

proc smoke_interproc_passes_changed() -> bool {
  let results = ip.run_all_interproc_passes()
  let i: int = 0
  while i < results.len {
    if !results[i].changed { give false }
    set i = i + 1
  }
  give true
}

proc smoke_interproc_metric_thresholds() -> bool {
  let m = ip.baseline_metrics()
  if m.fixtures_count < 5 { give false }
  if m.devirt_sites_total < 15 { give false }
  if m.specialized_functions_total < 12 { give false }
  if m.cross_module_rewrites_total < 15 { give false }
  if m.lto_internalized_total < 12 { give false }
  give true
}
