space vitte/compiler/optimizations/mir/tests/smoke

use src/vitte/compiler/optimizations/mir/mod as mir_opt

proc smoke_all_passes_present() -> bool {
  let results = mir_opt.run_all_mir_passes()
  give results.len == 6
}

proc smoke_passes_changed() -> bool {
  let results = mir_opt.run_all_mir_passes()
  let i: int = 0
  while i < results.len {
    if !results[i].changed { give false }
    set i = i + 1
  }
  give true
}

proc smoke_mir_metric_thresholds() -> bool {
  let m = mir_opt.baseline_metrics()
  if m.fixtures_count < 5 { give false }
  if m.constants_folded_total < 30 { give false }
  if m.dce_removed_ops_total < 25 { give false }
  if m.inlined_calls_total < 15 { give false }
  if m.loop_transforms_total < 10 { give false }
  if m.escapes_promoted_total < 12 { give false }
  if m.memory_allocs_reduced_total < 20 { give false }
  give true
}
