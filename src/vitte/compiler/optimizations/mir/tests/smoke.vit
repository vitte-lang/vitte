space vitte/compiler/optimizations/mir/tests/smoke

use src/vitte/compiler/optimizations/mir/mod as mir_opt

proc smoke_all_passes_present() -> bool {
  let results = mir_opt.run_all_mir_passes()
  give results.len == 6
}

proc smoke_passes_changed() -> bool {
  let results = mir_opt.run_all_mir_passes()
  let i: int = 0
  while i < results.len {
    if !results[i].changed { give false }
    set i = i + 1
  }
  give true
}
