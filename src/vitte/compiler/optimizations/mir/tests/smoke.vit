space vitte/compiler/optimizations/mir/tests/smoke

use vitte/compiler/optimizations/mir

proc smoke_all_passes_present() -> bool {
  let pipeline: mir.MirOptimizationPipeline = mir.run_all_mir_passes()
  give len(pipeline.passes) == 6
}

proc smoke_passes_changed() -> bool {
  let pipeline: mir.MirOptimizationPipeline = mir.run_all_mir_passes()
  give pipeline.changed and pipeline.valid
}

proc smoke_mir_metric_thresholds() -> bool {
  let metrics: mir.MirOptimizationMetrics = mir.run_all_mir_passes().metrics
  give metrics.constants_folded >= 12
    and metrics.dce_removed_ops >= 11
    and metrics.inlined_calls >= 8
    and metrics.loop_transforms >= 5
    and metrics.escapes_promoted >= 7
    and metrics.memory_allocs_reduced >= 9
}

proc smoke_test() -> bool {
  give smoke_all_passes_present()
    and smoke_passes_changed()
    and smoke_mir_metric_thresholds()
}

export *
