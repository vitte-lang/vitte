space vitte/compiler/backends/ast/target_decl

form TargetParam {
  type_name: string,
  name: string
}

form TargetFunction {
  name: string,
  return_type_name: string,
  params: [TargetParam],
  body_count: int,
  is_inline: bool,
  is_extern: bool,
  abi: string,
  link_name: string
}

form TargetGlobal {
  type_name: string,
  name: string,
  init_text: string,
  is_const: bool,
  is_extern: bool
}

form TargetStruct {
  name: string,
  field_count: int
}

form TargetEnum {
  name: string,
  item_count: int
}

form TargetNamespace {
  name: string,
  function_count: int
}

form TargetUnit {
  includes: [string],
  namespaces: [TargetNamespace],
  globals: [TargetGlobal],
  functions: [TargetFunction]
}

export *
