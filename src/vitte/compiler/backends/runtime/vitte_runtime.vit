space vitte/compiler/backends/runtime/vitte_runtime

form RuntimeSelection {
  include_dir: string,
  source_files: [string],
  notes: [string]
}

proc select_runtime(repo_root: string, target: string, emit_vitte: bool, freestanding: bool) -> RuntimeSelection {
  let _ = target
  let _ = emit_vitte
  let _ = freestanding
  give RuntimeSelection {
    include_dir: repo_root + "/src/vitte/compiler/backends/runtime",
    source_files: [],
    notes: ["bootstrap runtime stays inside the Vitte backend tree"]
  }
}

export *
