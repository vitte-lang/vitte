space vitte/compiler/backends/emit/c

use src/vitte/compiler/ir/mir as mir

form CEmitOptions {
  include_guard: string,
  indent_size: int,
  max_line_length: int,
  emit_debug_info: bool,
  target_c_standard: string
}

form CEmitContext {
  options: CEmitOptions,
  indent_level: int,
  output: string
}

proc default_c_emit_options() -> CEmitOptions {
  give CEmitOptions {
    include_guard: "",
    indent_size: 2,
    max_line_length: 100,
    emit_debug_info: false,
    target_c_standard: "c11"
  }
}

proc create_emit_context(options: CEmitOptions) -> CEmitContext {
  give CEmitContext {
    options: options,
    indent_level: 0,
    output: ""
  }
}

proc indent(ctx: CEmitContext) -> string {
  let result: string = ""
  let i: int = 0
  while i < ctx.indent_level {
    let j: int = 0
    while j < ctx.options.indent_size {
      set result = result + " "
      set j = j + 1
    }
    set i = i + 1
  }
  give result
}

proc emit_line(ctx: CEmitContext, line: string) -> CEmitContext {
  set ctx.output = ctx.output + indent(ctx) + line + "\n"
  give ctx
}

proc emit_blank_line(ctx: CEmitContext) -> CEmitContext {
  set ctx.output = ctx.output + "\n"
  give ctx
}

proc increase_indent(ctx: CEmitContext) -> CEmitContext {
  set ctx.indent_level = ctx.indent_level + 1
  give ctx
}

proc decrease_indent(ctx: CEmitContext) -> CEmitContext {
  if ctx.indent_level > 0 {
    set ctx.indent_level = ctx.indent_level - 1
  }
  give ctx
}

proc map_vitte_type_to_c(type_name: string) -> string {
  if type_name == "i8" { give "int8_t" }
  if type_name == "i16" { give "int16_t" }
  if type_name == "i32" { give "int32_t" }
  if type_name == "i64" { give "int64_t" }
  if type_name == "u8" { give "uint8_t" }
  if type_name == "u16" { give "uint16_t" }
  if type_name == "u32" { give "uint32_t" }
  if type_name == "u64" { give "uint64_t" }
  if type_name == "f32" { give "float" }
  if type_name == "f64" { give "double" }
  if type_name == "bool" { give "bool" }
  if type_name == "string" { give "const char*" }
  if type_name == "void" { give "void" }
  # For complex types, return as-is for now
  give type_name
}

proc emit_includes(ctx: CEmitContext) -> CEmitContext {
  # Standard includes
  set ctx = emit_line(ctx, "#include <stdint.h>")
  set ctx = emit_line(ctx, "#include <stdbool.h>")
  set ctx = emit_line(ctx, "#include <stdlib.h>")
  set ctx = emit_line(ctx, "#include <string.h>")
  set ctx = emit_blank_line(ctx)

  # Include guard if specified
  if ctx.options.include_guard != "" {
    set ctx = emit_line(ctx, "#ifndef " + ctx.options.include_guard)
    set ctx = emit_line(ctx, "#define " + ctx.options.include_guard)
    set ctx = emit_blank_line(ctx)
  }

  give ctx
}

proc emit_function_declaration(ctx: CEmitContext, func: mir.MirFunction) -> CEmitContext {
  let return_type: string = map_vitte_type_to_c(func.return_type_name)
  let func_decl: string = return_type + " " + func.name + "("

  # Parameters
  let i: int = 0
  while i < func.params.len {
    let param: mir.MirParam = func.params[i]
    let param_type: string = map_vitte_type_to_c(param.type_name)
    set func_decl = func_decl + param_type + " " + param.name
    if i < func.params.len - 1 {
      set func_decl = func_decl + ", "
    }
    set i = i + 1
  }

  set func_decl = func_decl + ");"
  set ctx = emit_line(ctx, func_decl)

  give ctx
}

proc emit_function_definition(ctx: CEmitContext, func: mir.MirFunction) -> CEmitContext {
  let return_type: string = map_vitte_type_to_c(func.return_type_name)
  let func_def: string = return_type + " " + func.name + "("

  # Parameters
  let i: int = 0
  while i < func.params.len {
    let param: mir.MirParam = func.params[i]
    let param_type: string = map_vitte_type_to_c(param.type_name)
    set func_def = func_def + param_type + " " + param.name
    if i < func.params.len - 1 {
      set func_def = func_def + ", "
    }
    set i = i + 1
  }

  set func_def = func_def + ") {"
  set ctx = emit_line(ctx, func_def)

  # Function body - for now, just a placeholder
  set ctx = increase_indent(ctx)
  set ctx = emit_line(ctx, "// TODO: Implement function body")
  if func.return_type_name != "void" {
    set ctx = emit_line(ctx, "return 0; // Placeholder")
  }
  set ctx = decrease_indent(ctx)
  set ctx = emit_line(ctx, "}")

  give ctx
}

proc emit_global_declaration(ctx: CEmitContext, global: mir.MirGlobal) -> CEmitContext {
  let c_type: string = map_vitte_type_to_c(global.type_name)
  let decl: string = "extern " + c_type + " " + global.name + ";"
  set ctx = emit_line(ctx, decl)
  give ctx
}

proc emit_global_definition(ctx: CEmitContext, global: mir.MirGlobal) -> CEmitContext {
  let c_type: string = map_vitte_type_to_c(global.type_name)
  let def: string = c_type + " " + global.name
  if global.init_expr != "" {
    set def = def + " = " + global.init_expr
  }
  set def = def + ";"
  set ctx = emit_line(ctx, def)
  give ctx
}

proc emit_module_header(ctx: CEmitContext, module: mir.MirModule) -> CEmitContext {
  set ctx = emit_includes(ctx)

  # Module comment
  set ctx = emit_line(ctx, "// Vitte module: " + module.namespace_name)
  set ctx = emit_line(ctx, "// Generated by Vitte compiler")
  set ctx = emit_blank_line(ctx)

  give ctx
}

proc emit_module_declarations(ctx: CEmitContext, module: mir.MirModule) -> CEmitContext {
  # Forward declarations for functions
  let i: int = 0
  while i < module.functions.len {
    set ctx = emit_function_declaration(ctx, module.functions[i])
    set i = i + 1
  }

  if module.functions.len > 0 {
    set ctx = emit_blank_line(ctx)
  }

  # External declarations for globals
  let i: int = 0
  while i < module.globals.len {
    set ctx = emit_global_declaration(ctx, module.globals[i])
    set i = i + 1
  }

  give ctx
}

proc emit_module_definitions(ctx: CEmitContext, module: mir.MirModule) -> CEmitContext {
  # Global definitions
  let i: int = 0
  while i < module.globals.len {
    set ctx = emit_global_definition(ctx, module.globals[i])
    set i = i + 1
  }

  if module.globals.len > 0 {
    set ctx = emit_blank_line(ctx)
  }

  # Function definitions
  let i: int = 0
  while i < module.functions.len {
    set ctx = emit_function_definition(ctx, module.functions[i])
    if i < module.functions.len - 1 {
      set ctx = emit_blank_line(ctx)
    }
    set i = i + 1
  }

  give ctx
}

proc emit_module_footer(ctx: CEmitContext) -> CEmitContext {
  if ctx.options.include_guard != "" {
    set ctx = emit_blank_line(ctx)
    set ctx = emit_line(ctx, "#endif // " + ctx.options.include_guard)
  }
  give ctx
}

proc emit_c_header(module: mir.MirModule, options: CEmitOptions) -> string {
  let ctx: CEmitContext = create_emit_context(options)
  set ctx = emit_module_header(ctx, module)
  set ctx = emit_module_declarations(ctx, module)
  set ctx = emit_module_footer(ctx)
  give ctx.output
}

proc emit_c_source(module: mir.MirModule, options: CEmitOptions) -> string {
  let ctx: CEmitContext = create_emit_context(options)
  set ctx = emit_module_header(ctx, module)
  set ctx = emit_module_definitions(ctx, module)
  give ctx.output
}

const VERSION_TEXT: string = "vitte-c-emit 0.1.0"
const BANNER_TEXT: string = "Vitte C Code Emitter"

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: [string]) -> int {
  give 0
}

export *