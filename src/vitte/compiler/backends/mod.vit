space vitte/compiler/backends/mod

use src/vitte/compiler/bootstrap as bootstrap

form BackendManifest {
  stage: string,
  source_root: string,
  language: string,
  family: string,
  bootstrap: bool
}

proc manifest() -> BackendManifest {
  give BackendManifest {
    stage: bootstrap.bootstrap_stage(),
    source_root: "src/vitte/compiler/backends",
    language: bootstrap.bootstrap_language(),
    family: "target-emission-from-vitte",
    bootstrap: true
  }
}

proc migration_stage() -> string {
  give manifest().stage
}

proc source_of_truth() -> string {
  give manifest().source_root
}

proc is_bootstrap() -> bool {
  give manifest().bootstrap
}

proc backend_family() -> string {
  give manifest().family
}

proc bootstrap_language() -> string {
  give manifest().language
}

export *
