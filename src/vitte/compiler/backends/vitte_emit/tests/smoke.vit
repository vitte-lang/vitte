space vitte/compiler/backends/vitte_emit/tests/smoke

use src/vitte/compiler/backends/vitte_emit/types as types
use src/vitte/compiler/backends/vitte_emit/emit as emit
use src/vitte/compiler/backends/vitte_emit/cfg as cfg
use src/vitte/compiler/backends/vitte_emit/ir as ir
use src/vitte/compiler/backends/vitte_emit/passes as passes

proc smoke_types_count() -> bool {
  give types.primitive_type_count() == 9
}

proc smoke_emit() -> bool {
  let u = emit.emit_unit("demo/module")
  if u.vitir == "" { give false }
  if u.vasm == "" { give false }
  give true
}

proc smoke_cfg() -> bool {
  let blocks: [cfg.CFGBlock] = [
    cfg.CFGBlock { label: "entry", terminated: true },
    cfg.CFGBlock { label: "exit", terminated: true },
  ]
  give cfg.cfg_all_terminated(blocks)
}

proc smoke_passes() -> bool {
  let func = ir.Function {
    name: "add",
    params: ["a", "b"],
    body: [
      ir.BasicBlock {
        label: "add_body",
        instructions: [
          ir.Instruction { kind: "assign", operands: ["result", "a", "+", "b"] },
          ir.Instruction { kind: "return", operands: ["result"] },
        ],
        successors: [],
      }
    ],
    pure: true,
  }
  let module = ir.IRModule {
    name: "test",
    functions: [func],
    blocks: [
      ir.BasicBlock {
        label: "main",
        instructions: [
          ir.Instruction { kind: "assign", operands: ["x", "5"] },
          ir.Instruction { kind: "assign", operands: ["y", "x"] },
          ir.Instruction { kind: "call", operands: ["add", "x", "3"] },
        ],
        successors: [],
      }
    ],
  }
  let opt_module = passes.constant_propagation(module)
  // Check if y is replaced with 5
  let main_block = opt_module.blocks[0]
  let y_inst = main_block.instructions[1]
  if y_inst.operands[1] != "5" { give false }
  give true
}
