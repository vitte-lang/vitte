space vitte/compiler/backends/vitte_emit/tests

use vitte/compiler/backends/vitte_emit.{ api_manifest, contracts, ir, pipeline, vitte_emit_root }

proc smoke_vitte_emit_types_mapped() -> string {
  give ir()
}

proc smoke_vitte_emit_cfg_terminated() -> string {
  give pipeline()
}

proc smoke_vitte_emit_abi_metadata() -> string {
  give vitte_emit_root() + " | " + contracts() + " | " + api_manifest()
}
