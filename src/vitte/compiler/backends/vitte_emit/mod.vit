space vitte/compiler/backends/vitte_emit

use vitte/compiler/backends/vitte_emit/abi_bridge
use vitte/compiler/backends/vitte_emit/cfg
use vitte/compiler/backends/vitte_emit/config
use vitte/compiler/backends/vitte_emit/contracts
use vitte/compiler/backends/vitte_emit/emit
use vitte/compiler/backends/vitte_emit/intrinsics
use vitte/compiler/backends/vitte_emit/ir
use vitte/compiler/backends/vitte_emit/lowering
use vitte/compiler/backends/vitte_emit/passes
use vitte/compiler/backends/vitte_emit/pipeline
use vitte/compiler/backends/vitte_emit/types
use vitte/compiler/backends/vitte_emit/validate

proc backend_mode() -> string {
  give "specialized-adapter";
}

proc canonical_backend_surface() -> string {
  give "src/vitte/compiler/backend/" + "*";
}

proc vitte_emit_root() -> string {
  give "vitte_emit adapter -> " + canonical_backend_surface();
}
