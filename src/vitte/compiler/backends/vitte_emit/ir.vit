space vitte/compiler/backends/vitte_emit/ir

// Intermediate Representation for Vitte Backend Optimizations

form Instruction {
  kind: string, // "assign", "call", "branch", "return", etc.
  operands: [string],
}

form BasicBlock {
  label: string,
  instructions: [Instruction],
  successors: [string], // labels of successor blocks
}

form IRModule {
  name: string,
  functions: [Function],
  blocks: [BasicBlock],
}

// Helper to find a block by label
proc find_block(blocks: [BasicBlock], label: string) -> BasicBlock? {
  let i: int = 0
  while i < blocks.len {
    if blocks[i].label == label {
      give blocks[i]
    }
    set i = i + 1
  }
  give none
}

form Function {
  name: string,
  params: [string],
  body: [BasicBlock],
  pure: bool, // if true, can be inlined
}