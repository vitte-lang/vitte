space vitte/compiler/backends/vitte_emit/api_manifest

form ExportSymbol {
  name: string,
  signature: string,
}

form ModuleExports {
  module_name: string,
  abi_version: string,
  symbols: [ExportSymbol],
}

proc default_exports(module_name: string) -> ModuleExports {
  give ModuleExports {
    module_name: module_name,
    abi_version: "v1",
    symbols: [
      ExportSymbol { name: "main", signature: "proc main() -> i32" },
    ],
  }
}
