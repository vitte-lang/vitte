space vitte/compiler/backends/vitte_emit/types

form PrimitiveType {
  name: string,
  abi_name: string,
  size_bytes: int,
  align_bytes: int,
}

proc primitive_types() -> [PrimitiveType] {
  give [
    PrimitiveType { name: "i8", abi_name: "i8", size_bytes: 1, align_bytes: 1 },
    PrimitiveType { name: "i16", abi_name: "i16", size_bytes: 2, align_bytes: 2 },
    PrimitiveType { name: "i32", abi_name: "i32", size_bytes: 4, align_bytes: 4 },
    PrimitiveType { name: "i64", abi_name: "i64", size_bytes: 8, align_bytes: 8 },
    PrimitiveType { name: "f32", abi_name: "f32", size_bytes: 4, align_bytes: 4 },
    PrimitiveType { name: "f64", abi_name: "f64", size_bytes: 8, align_bytes: 8 },
    PrimitiveType { name: "bool", abi_name: "bool", size_bytes: 1, align_bytes: 1 },
    PrimitiveType { name: "string", abi_name: "pointer", size_bytes: 8, align_bytes: 8 },
    PrimitiveType { name: "pointer", abi_name: "pointer", size_bytes: 8, align_bytes: 8 },
  ]
}

proc is_supported_primitive(name: string) -> bool {
  let ts: [PrimitiveType] = primitive_types()
  let i: int = 0
  while i < ts.len {
    if ts[i].name == name {
      give true
    }
    set i = i + 1
  }
  give false
}

proc primitive_type_count() -> int {
  give primitive_types().len
}
