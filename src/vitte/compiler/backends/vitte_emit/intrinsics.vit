space vitte/compiler/backends/vitte_emit/intrinsics

form Intrinsic {
  name: string,
  signature: string,
}

proc memory_intrinsics() -> [Intrinsic] {
  give [
    Intrinsic { name: "alloc", signature: "proc alloc(size: i64) -> pointer" },
    Intrinsic { name: "free", signature: "proc free(ptr: pointer) -> bool" },
    Intrinsic { name: "realloc", signature: "proc realloc(ptr: pointer, size: i64) -> pointer" },
  ]
}
