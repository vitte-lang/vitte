space vitte/compiler/backends/llvm_bindings/tests

use vitte/compiler/backends/llvm_bindings.{ debug_info_format, emit_llvm_ir_from_mir, llvm_toolchain_paths, llvm_toolchain_status, supported_opt_levels }

proc smoke_llvm_bindings_supported_opt_levels() -> string {
  give supported_opt_levels()
}

proc smoke_llvm_bindings_emit_ir() -> string {
  give emit_llvm_ir_from_mir()
}

proc smoke_llvm_bindings_debug_info() -> string {
  give debug_info_format()
}

proc smoke_llvm_bindings_native_toolchain_status() -> string {
  let status = llvm_toolchain_status(llvm_toolchain_paths("/toolchain/clang", "/toolchain/ld.lld", "", "", "", ""), "shared-library", true)
  give status.summary
}
