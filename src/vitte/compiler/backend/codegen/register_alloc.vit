space vitte/compiler/backend/codegen

proc allocate_virtual_locations(lines: [string]) -> [string] {
  let allocated: [string] = [];
  let i: u64 = 0;
  while i < len(lines) {
    let line: string = lines[i];
    if find(line, "#") >= 0 {
      set allocated = allocated + [line + " [stack-slot]"];
    } else {
      set allocated = allocated + [line];
    }
    set i = i + 1;
  }
  give allocated;
}
