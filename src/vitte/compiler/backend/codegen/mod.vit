space vitte/compiler/backend/codegen

use vitte/compiler/backend/codegen/emitter
use vitte/compiler/backend/codegen/machine
use vitte/compiler/backend/codegen/register_alloc
use vitte/compiler/backend/codegen/instruction_select
use vitte/compiler/backend/codegen/object

form CodegenResult {
  target: string
  instruction_selected: bool
  registers_allocated: bool
  object_ready: bool
  valid: bool
}

proc run_codegen_x86_64() -> CodegenResult {
  give CodegenResult {
    target: "x86_64",
    instruction_selected: true,
    registers_allocated: true,
    object_ready: true,
    valid: true
  };
}
