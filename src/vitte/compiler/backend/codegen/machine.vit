<<< ========================================================= >>>
<<< Vitte 2026 — Official Compiler Source                    >>>
<<< Component: Compiler / Backend / Code Generation          >>>
<<< File: compiler/backend/codegen/machine.vit               >>>
<<< Module: vitte/compiler/backend/codegen/machine           >>>
<<< Purpose: machine model, registers, operands and blocks    >>>
<<< ========================================================= >>>

space vitte/compiler/backend/codegen/machine

const MACHINE_VERSION: u32 = 2026
const MACHINE_INVALID_ID: u64 = 18446744073709551615
const MACHINE_MAX_REGISTERS: u64 = 4096
const MACHINE_MAX_OPERANDS: u64 = 16
const MACHINE_MAX_INSTRUCTIONS: u64 = 16777216
const MACHINE_MAX_BLOCKS: u64 = 1048576
const MACHINE_MAX_FUNCTIONS: u64 = 262144

pick MachineArch {
    Unknown,
    X86_64,
    AArch64,
    RiscV64,
    ARM,
    I386,
    Wasm32,
}

pick RegisterClass {
    Unknown,
    General,
    Float,
    Vector,
    Predicate,
    Stack,
    Frame,
    Link,
    ProgramCounter,
    Flags,
}

pick OperandKind {
    None,
    Register,
    VirtualRegister,
    Immediate,
    Memory,
    Symbol,
    Label,
    Block,
}

pick MachineOpcode {
    Invalid,
    Nop,
    Mov,
    Lea,
    Add,
    Sub,
    Mul,
    Div,
    Mod,
    Neg,
    And,
    Or,
    Xor,
    Shl,
    Shr,
    Cmp,
    Test,
    Load,
    Store,
    Push,
    Pop,
    Call,
    Ret,
    Jmp,
    Jcc,
    Phi,
    Spill,
    Reload,
    Label,
}

pick MachineErrorKind {
    None,
    InvalidArch,
    InvalidRegister,
    InvalidOperand,
    InvalidInstruction,
    InvalidBlock,
    InvalidFunction,
    RegisterLimitExceeded,
    OperandLimitExceeded,
    InstructionLimitExceeded,
    BlockLimitExceeded,
    FunctionLimitExceeded,
    InternalFailure,
}

form MachineSpan {
    file: string
    line: u64
    column: u64
    length: u64
}

form MachineRegister {
    id: u64
    name: string
    class: RegisterClass
    width: u64
    physical: bool
    reserved: bool
    caller_saved: bool
    callee_saved: bool
    valid: bool
}

form MachineOperand {
    kind: OperandKind
    register_id: u64
    immediate: i64
    symbol: string
    base: u64
    offset: i64
    scale: u64
    valid: bool
}

form MachineInstruction {
    id: u64
    opcode: MachineOpcode
    operands: [MachineOperand]
    block: u64
    span: MachineSpan
    valid: bool
}

form MachineBlock {
    id: u64
    name: string
    instructions: [MachineInstruction]
    predecessors: [u64]
    successors: [u64]
    valid: bool
}

form MachineFunction {
    id: u64
    name: string
    arch: MachineArch
    registers: [MachineRegister]
    blocks: [MachineBlock]
    entry_block: u64
    stack_size: u64
    valid: bool
}

form MachineDiagnostic {
    kind: MachineErrorKind
    message: string
    span: MachineSpan
    entity: u64
}

form MachineModule {
    arch: MachineArch
    functions: [MachineFunction]
    diagnostics: [MachineDiagnostic]
    valid: bool
}

proc span_empty() -> MachineSpan {
    give MachineSpan {
        file: "compiler/backend/codegen/machine.vit",
        line: 0,
        column: 0,
        length: 0
    };
}

proc register_invalid() -> MachineRegister {
    give MachineRegister {
        id: MACHINE_INVALID_ID,
        name: "invalid",
        class: RegisterClass.Unknown,
        width: 0,
        physical: false,
        reserved: false,
        caller_saved: false,
        callee_saved: false,
        valid: false
    };
}

proc operand_none() -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.None,
        register_id: MACHINE_INVALID_ID,
        immediate: 0,
        symbol: "",
        base: MACHINE_INVALID_ID,
        offset: 0,
        scale: 1,
        valid: false
    };
}

proc operand_register(id: u64) -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.Register,
        register_id: id,
        immediate: 0,
        symbol: "",
        base: MACHINE_INVALID_ID,
        offset: 0,
        scale: 1,
        valid: true
    };
}

proc operand_virtual_register(id: u64) -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.VirtualRegister,
        register_id: id,
        immediate: 0,
        symbol: "",
        base: MACHINE_INVALID_ID,
        offset: 0,
        scale: 1,
        valid: true
    };
}

proc operand_immediate(value: i64) -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.Immediate,
        register_id: MACHINE_INVALID_ID,
        immediate: value,
        symbol: "",
        base: MACHINE_INVALID_ID,
        offset: 0,
        scale: 1,
        valid: true
    };
}

proc operand_symbol(name: string) -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.Symbol,
        register_id: MACHINE_INVALID_ID,
        immediate: 0,
        symbol: name,
        base: MACHINE_INVALID_ID,
        offset: 0,
        scale: 1,
        valid: true
    };
}

proc operand_label(name: string) -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.Label,
        register_id: MACHINE_INVALID_ID,
        immediate: 0,
        symbol: name,
        base: MACHINE_INVALID_ID,
        offset: 0,
        scale: 1,
        valid: true
    };
}

proc operand_memory(
    base: u64,
    offset: i64,
    scale: u64
) -> MachineOperand {
    give MachineOperand {
        kind: OperandKind.Memory,
        register_id: MACHINE_INVALID_ID,
        immediate: 0,
        symbol: "",
        base: base,
        offset: offset,
        scale: scale,
        valid: true
    };
}

proc register_create(
    id: u64,
    name: string,
    class: RegisterClass,
    width: u64,
    physical: bool,
    reserved: bool,
    caller_saved: bool,
    callee_saved: bool
) -> MachineRegister {
    give MachineRegister {
        id: id,
        name: name,
        class: class,
        width: width,
        physical: physical,
        reserved: reserved,
        caller_saved: caller_saved,
        callee_saved: callee_saved,
        valid: true
    };
}

proc instruction_create(
    id: u64,
    opcode: MachineOpcode,
    operands: [MachineOperand],
    block: u64,
    span: MachineSpan
) -> MachineInstruction {
    give MachineInstruction {
        id: id,
        opcode: opcode,
        operands: operands,
        block: block,
        span: span,
        valid: true
    };
}

proc block_create(
    id: u64,
    name: string
) -> MachineBlock {
    give MachineBlock {
        id: id,
        name: name,
        instructions: [],
        predecessors: [],
        successors: [],
        valid: true
    };
}

proc function_create(
    id: u64,
    name: string,
    arch: MachineArch
) -> MachineFunction {
    give MachineFunction {
        id: id,
        name: name,
        arch: arch,
        registers: default_registers(arch),
        blocks: [],
        entry_block: MACHINE_INVALID_ID,
        stack_size: 0,
        valid: true
    };
}

proc diagnostic_create(
    kind: MachineErrorKind,
    message: string,
    span: MachineSpan,
    entity: u64
) -> MachineDiagnostic {
    give MachineDiagnostic {
        kind: kind,
        message: message,
        span: span,
        entity: entity
    };
}

proc module_empty(arch: MachineArch) -> MachineModule {
    give MachineModule {
        arch: arch,
        functions: [],
        diagnostics: [],
        valid: true
    };
}

proc default_registers(arch: MachineArch) -> [MachineRegister] {
    if arch == MachineArch.X86_64 {
        give default_registers_x86_64();
    }

    if arch == MachineArch.AArch64 {
        give default_registers_aarch64();
    }

    give [];
}

proc default_registers_x86_64() -> [MachineRegister] {
    give [
        register_create(0, "rax", RegisterClass.General, 64, true, false, true, false),
        register_create(1, "rbx", RegisterClass.General, 64, true, false, false, true),
        register_create(2, "rcx", RegisterClass.General, 64, true, false, true, false),
        register_create(3, "rdx", RegisterClass.General, 64, true, false, true, false),
        register_create(4, "rsi", RegisterClass.General, 64, true, false, true, false),
        register_create(5, "rdi", RegisterClass.General, 64, true, false, true, false),
        register_create(6, "rbp", RegisterClass.Frame, 64, true, true, false, true),
        register_create(7, "rsp", RegisterClass.Stack, 64, true, true, false, true),
        register_create(8, "r8", RegisterClass.General, 64, true, false, true, false),
        register_create(9, "r9", RegisterClass.General, 64, true, false, true, false),
        register_create(10, "r10", RegisterClass.General, 64, true, false, true, false),
        register_create(11, "r11", RegisterClass.General, 64, true, false, true, false),
        register_create(12, "r12", RegisterClass.General, 64, true, false, false, true),
        register_create(13, "r13", RegisterClass.General, 64, true, false, false, true),
        register_create(14, "r14", RegisterClass.General, 64, true, false, false, true),
        register_create(15, "r15", RegisterClass.General, 64, true, false, false, true)
    ];
}

proc default_registers_aarch64() -> [MachineRegister] {
    give [
        register_create(0, "x0", RegisterClass.General, 64, true, false, true, false),
        register_create(1, "x1", RegisterClass.General, 64, true, false, true, false),
        register_create(2, "x2", RegisterClass.General, 64, true, false, true, false),
        register_create(3, "x3", RegisterClass.General, 64, true, false, true, false),
        register_create(4, "x4", RegisterClass.General, 64, true, false, true, false),
        register_create(5, "x5", RegisterClass.General, 64, true, false, true, false),
        register_create(6, "x6", RegisterClass.General, 64, true, false, true, false),
        register_create(7, "x7", RegisterClass.General, 64, true, false, true, false),
        register_create(8, "x8", RegisterClass.General, 64, true, false, true, false),
        register_create(29, "x29", RegisterClass.Frame, 64, true, true, false, true),
        register_create(30, "x30", RegisterClass.Link, 64, true, true, false, false),
        register_create(31, "sp", RegisterClass.Stack, 64, true, true, false, true)
    ];
}

proc module_add_diagnostic(
    module: MachineModule,
    diagnostic: MachineDiagnostic
) -> MachineModule {
    give MachineModule {
        arch: module.arch,
        functions: module.functions,
        diagnostics: module.diagnostics + [diagnostic],
        valid: false
    };
}

proc module_add_function(
    module: MachineModule,
    function: MachineFunction
) -> MachineModule {
    if vector_len(module.functions) >= MACHINE_MAX_FUNCTIONS {
        give module_add_diagnostic(
            module,
            diagnostic_create(
                MachineErrorKind.FunctionLimitExceeded,
                "too many machine functions",
                span_empty(),
                function.id
            )
        );
    }

    give MachineModule {
        arch: module.arch,
        functions: module.functions + [function],
        diagnostics: module.diagnostics,
        valid: module.valid
    };
}

proc function_add_block(
    function: MachineFunction,
    block: MachineBlock
) -> MachineFunction {
    if vector_len(function.blocks) >= MACHINE_MAX_BLOCKS {
        give MachineFunction {
            id: function.id,
            name: function.name,
            arch: function.arch,
            registers: function.registers,
            blocks: function.blocks,
            entry_block: function.entry_block,
            stack_size: function.stack_size,
            valid: false
        };
    }

    let entry = function.entry_block;

    if entry == MACHINE_INVALID_ID {
        set entry = block.id;
    }

    give MachineFunction {
        id: function.id,
        name: function.name,
        arch: function.arch,
        registers: function.registers,
        blocks: function.blocks + [block],
        entry_block: entry,
        stack_size: function.stack_size,
        valid: function.valid
    };
}

proc block_add_instruction(
    block: MachineBlock,
    instruction: MachineInstruction
) -> MachineBlock {
    if vector_len(block.instructions) >= MACHINE_MAX_INSTRUCTIONS {
        give MachineBlock {
            id: block.id,
            name: block.name,
            instructions: block.instructions,
            predecessors: block.predecessors,
            successors: block.successors,
            valid: false
        };
    }

    give MachineBlock {
        id: block.id,
        name: block.name,
        instructions: block.instructions + [instruction],
        predecessors: block.predecessors,
        successors: block.successors,
        valid: block.valid
    };
}

proc block_add_successor(
    block: MachineBlock,
    successor: u64
) -> MachineBlock {
    give MachineBlock {
        id: block.id,
        name: block.name,
        instructions: block.instructions,
        predecessors: block.predecessors,
        successors: block.successors + [successor],
        valid: block.valid
    };
}

proc block_add_predecessor(
    block: MachineBlock,
    predecessor: u64
) -> MachineBlock {
    give MachineBlock {
        id: block.id,
        name: block.name,
        instructions: block.instructions,
        predecessors: block.predecessors + [predecessor],
        successors: block.successors,
        valid: block.valid
    };
}

proc find_register(
    function: MachineFunction,
    id: u64
) -> MachineRegister {
    let i: u64 = 0;

    while i < vector_len(function.registers) {
        if function.registers[i].id == id {
            give function.registers[i];
        }

        set i = i + 1;
    }

    give register_invalid();
}

proc find_block(
    function: MachineFunction,
    id: u64
) -> MachineBlock {
    let i: u64 = 0;

    while i < vector_len(function.blocks) {
        if function.blocks[i].id == id {
            give function.blocks[i];
        }

        set i = i + 1;
    }

    give MachineBlock {
        id: MACHINE_INVALID_ID,
        name: "invalid",
        instructions: [],
        predecessors: [],
        successors: [],
        valid: false
    };
}

proc replace_block(
    function: MachineFunction,
    block: MachineBlock
) -> MachineFunction {
    let next: [MachineBlock] = [];
    let replaced = false;
    let i: u64 = 0;

    while i < vector_len(function.blocks) {
        if function.blocks[i].id == block.id {
            set next = next + [block];
            set replaced = true;
        } else {
            set next = next + [function.blocks[i]];
        }

        set i = i + 1;
    }

    if replaced == false {
        give function_add_block(function, block);
    }

    give MachineFunction {
        id: function.id,
        name: function.name,
        arch: function.arch,
        registers: function.registers,
        blocks: next,
        entry_block: function.entry_block,
        stack_size: function.stack_size,
        valid: function.valid
    };
}

proc function_add_instruction(
    function: MachineFunction,
    block_id: u64,
    instruction: MachineInstruction
) -> MachineFunction {
    let block = find_block(function, block_id);

    if block.valid == false {
        give MachineFunction {
            id: function.id,
            name: function.name,
            arch: function.arch,
            registers: function.registers,
            blocks: function.blocks,
            entry_block: function.entry_block,
            stack_size: function.stack_size,
            valid: false
        };
    }

    let updated = block_add_instruction(block, instruction);

    give replace_block(function, updated);
}

proc instruction_operand_count(instruction: MachineInstruction) -> u64 {
    give vector_len(instruction.operands);
}

proc instruction_has_register_operand(instruction: MachineInstruction) -> bool {
    let i: u64 = 0;

    while i < vector_len(instruction.operands) {
        if instruction.operands[i].kind == OperandKind.Register {
            give true;
        }

        if instruction.operands[i].kind == OperandKind.VirtualRegister {
            give true;
        }

        set i = i + 1;
    }

    give false;
}

proc instruction_is_terminator(instruction: MachineInstruction) -> bool {
    if instruction.opcode == MachineOpcode.Ret {
        give true;
    }

    if instruction.opcode == MachineOpcode.Jmp {
        give true;
    }

    if instruction.opcode == MachineOpcode.Jcc {
        give true;
    }

    give false;
}

proc validate_operand(
    function: MachineFunction,
    operand: MachineOperand
) -> bool {
    if operand.valid == false {
        give false;
    }

    if operand.kind == OperandKind.Register {
        give find_register(function, operand.register_id).valid;
    }

    if operand.kind == OperandKind.VirtualRegister {
        give operand.register_id != MACHINE_INVALID_ID;
    }

    if operand.kind == OperandKind.Memory {
        give operand.base != MACHINE_INVALID_ID;
    }

    give true;
}

proc validate_instruction(
    function: MachineFunction,
    instruction: MachineInstruction
) -> bool {
    if instruction.valid == false {
        give false;
    }

    if instruction.opcode == MachineOpcode.Invalid {
        give false;
    }

    if vector_len(instruction.operands) > MACHINE_MAX_OPERANDS {
        give false;
    }

    let i: u64 = 0;

    while i < vector_len(instruction.operands) {
        if validate_operand(function, instruction.operands[i]) == false {
            give false;
        }

        set i = i + 1;
    }

    give true;
}

proc validate_block(
    function: MachineFunction,
    block: MachineBlock
) -> bool {
    if block.valid == false {
        give false;
    }

    let i: u64 = 0;

    while i < vector_len(block.instructions) {
        if validate_instruction(function, block.instructions[i]) == false {
            give false;
        }

        set i = i + 1;
    }

    give true;
}

proc validate_function(function: MachineFunction) -> bool {
    if function.valid == false {
        give false;
    }

    if function.entry_block == MACHINE_INVALID_ID {
        give false;
    }

    let i: u64 = 0;

    while i < vector_len(function.blocks) {
        if validate_block(function, function.blocks[i]) == false {
            give false;
        }

        set i = i + 1;
    }

    give true;
}

proc validate_module(module: MachineModule) -> MachineModule {
    let current = module;
    let i: u64 = 0;

    while i < vector_len(current.functions) {
        if validate_function(current.functions[i]) == false {
            give module_add_diagnostic(
                current,
                diagnostic_create(
                    MachineErrorKind.InvalidFunction,
                    "invalid machine function",
                    span_empty(),
                    current.functions[i].id
                )
            );
        }

        set i = i + 1;
    }

    give current;
}

proc machine_error_count(module: MachineModule) -> u64 {
    give vector_len(module.diagnostics);
}

proc machine_module_is_valid(module: MachineModule) -> bool {
    give module.valid and vector_len(module.diagnostics) == 0;
}

proc arch_name(arch: MachineArch) -> string {
    if arch == MachineArch.X86_64 {
        give "x86_64";
    }

    if arch == MachineArch.AArch64 {
        give "aarch64";
    }

    if arch == MachineArch.RiscV64 {
        give "riscv64";
    }

    if arch == MachineArch.ARM {
        give "arm";
    }

    if arch == MachineArch.I386 {
        give "i386";
    }

    if arch == MachineArch.Wasm32 {
        give "wasm32";
    }

    give "unknown";
}

proc opcode_name(opcode: MachineOpcode) -> string {
    if opcode == MachineOpcode.Nop {
        give "nop";
    }

    if opcode == MachineOpcode.Mov {
        give "mov";
    }

    if opcode == MachineOpcode.Add {
        give "add";
    }

    if opcode == MachineOpcode.Sub {
        give "sub";
    }

    if opcode == MachineOpcode.Mul {
        give "mul";
    }

    if opcode == MachineOpcode.Div {
        give "div";
    }

    if opcode == MachineOpcode.Load {
        give "load";
    }

    if opcode == MachineOpcode.Store {
        give "store";
    }

    if opcode == MachineOpcode.Call {
        give "call";
    }

    if opcode == MachineOpcode.Ret {
        give "ret";
    }

    give "invalid";
}

proc register_class_name(class: RegisterClass) -> string {
    if class == RegisterClass.General {
        give "general";
    }

    if class == RegisterClass.Float {
        give "float";
    }

    if class == RegisterClass.Vector {
        give "vector";
    }

    if class == RegisterClass.Stack {
        give "stack";
    }

    if class == RegisterClass.Frame {
        give "frame";
    }

    if class == RegisterClass.Link {
        give "link";
    }

    give "unknown";
}

proc print_register(register: MachineRegister) {
    emit "register";
    emit register.id;
    emit register.name;
    emit register_class_name(register.class);
    emit register.width;
}

proc print_operand(operand: MachineOperand) {
    emit "operand";
    emit operand.kind;
    emit operand.register_id;
    emit operand.immediate;
    emit operand.symbol;
}

proc print_instruction(instruction: MachineInstruction) {
    emit "machine instruction";
    emit instruction.id;
    emit opcode_name(instruction.opcode);
    emit instruction.block;

    let i: u64 = 0;

    while i < vector_len(instruction.operands) {
        print_operand(instruction.operands[i]);
        set i = i + 1;
    }
}

proc print_block(block: MachineBlock) {
    emit "machine block";
    emit block.id;
    emit block.name;
    emit vector_len(block.instructions);
    emit vector_len(block.predecessors);
    emit vector_len(block.successors);

    let i: u64 = 0;

    while i < vector_len(block.instructions) {
        print_instruction(block.instructions[i]);
        set i = i + 1;
    }
}

proc print_function(function: MachineFunction) {
    emit "machine function";
    emit function.id;
    emit function.name;
    emit arch_name(function.arch);
    emit function.entry_block;
    emit function.stack_size;
    emit vector_len(function.blocks);

    let i: u64 = 0;

    while i < vector_len(function.blocks) {
        print_block(function.blocks[i]);
        set i = i + 1;
    }
}

proc print_module(module: MachineModule) {
    emit "machine module";
    emit arch_name(module.arch);
    emit vector_len(module.functions);
    emit vector_len(module.diagnostics);

    let i: u64 = 0;

    while i < vector_len(module.functions) {
        print_function(module.functions[i]);
        set i = i + 1;
    }
}

proc vector_len[T](items: [T]) -> u64 {
    give 0;
}
