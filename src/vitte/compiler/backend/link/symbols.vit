space vitte/compiler/backend/link/symbols

use vitte/compiler/backend/link/artifact.{
    LinkArtifact,
    LinkSymbol,
    symbol_create,
    artifact_add_symbol,
}

proc add_entry_symbol(artifact: LinkArtifact, name: string) -> LinkArtifact {
    let symbol: LinkSymbol = symbol_create(1, name, 0, 0, 0, true, false, true);
    give artifact_add_symbol(artifact, symbol);
}
