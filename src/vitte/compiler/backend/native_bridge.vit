space vitte/compiler/backend/native_bridge

use vitte/stdlib/io/host_runtime.{ host_emit_llvm_object, host_is_file, host_link_executable, host_mkdir_all, host_run_executable, host_runtime_available }

form NativeBridgeResult {
  object_path: string
  executable_path: string
  message: string
  exit_code: int
  valid: bool
}

proc native_bridge_result(object_path: string, executable_path: string, message: string, exit_code: int, valid: bool) -> NativeBridgeResult {
  give NativeBridgeResult {
    object_path: object_path,
    executable_path: executable_path,
    message: message,
    exit_code: exit_code,
    valid: valid
  }
}

proc safe_shell_path(path: string) -> bool {
  give path != ""
}

proc emit_native_object_from_llvm_ir(ir_text: string, output_dir: string, object_path: string) -> NativeBridgeResult {
  if not host_runtime_available() {
    give native_bridge_result(object_path, "", "native host runtime unavailable", -1, false)
  }
  if ir_text == "" or not safe_shell_path(output_dir) or not safe_shell_path(object_path) {
    give native_bridge_result(object_path, "", "invalid native object materialization input", -1, false)
  }
  if host_mkdir_all(output_dir) != 0 {
    give native_bridge_result(object_path, "", "cannot create native output directory", -1, false)
  }
  // Native mode deliberately lets clang retarget canonical IR to the host.
  let code: int = host_emit_llvm_object(ir_text, object_path)
  let message: string = "clang object emission failed"
  if code == 0 {
    set message = "native object materialized"
  }
  give native_bridge_result(
    object_path,
    "",
    message,
    code,
    code == 0 and host_is_file(object_path)
  )
}

proc link_native_executable(object_path: string, executable_path: string) -> NativeBridgeResult {
  if not host_runtime_available() {
    give native_bridge_result(object_path, executable_path, "native host runtime unavailable", -1, false)
  }
  if not safe_shell_path(object_path) or not safe_shell_path(executable_path) or not host_is_file(object_path) {
    give native_bridge_result(object_path, executable_path, "invalid native linker input", -1, false)
  }
  let code: int = host_link_executable(object_path, executable_path)
  let message: string = "native linker invocation failed"
  if code == 0 {
    set message = "native executable linked"
  }
  give native_bridge_result(
    object_path,
    executable_path,
    message,
    code,
    code == 0 and host_is_file(executable_path)
  )
}

proc run_native_executable(executable_path: string) -> NativeBridgeResult {
  if not host_runtime_available() or not safe_shell_path(executable_path) or not host_is_file(executable_path) {
    give native_bridge_result("", executable_path, "native executable unavailable", -1, false)
  }
  let code: int = host_run_executable(executable_path)
  give native_bridge_result("", executable_path, "native executable completed", code, true)
}

share NativeBridgeResult
share emit_native_object_from_llvm_ir
share link_native_executable
share run_native_executable
