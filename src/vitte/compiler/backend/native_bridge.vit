space vitte/compiler/backend/native_bridge

use vitte/stdlib/io/host_runtime.{ host_emit_assembly_object, host_emit_llvm_object, host_is_file, host_link_executable, host_mkdir_all, host_run_executable, host_runtime_available, host_verify_native_object }

form NativeBridgeResult {
  object_path: string
  executable_path: string
  message: string
  diagnostic_code: string
  tool: string
  command_text: string
  stderr_text: string
  symbol: string
  exit_code: int
  valid: bool
}

proc native_bridge_result(object_path: string, executable_path: string, message: string, exit_code: int, valid: bool) -> NativeBridgeResult {
  give NativeBridgeResult {
    object_path: object_path,
    executable_path: executable_path,
    message: message,
    diagnostic_code: "",
    tool: "",
    command_text: "",
    stderr_text: "",
    symbol: "",
    exit_code: exit_code,
    valid: valid
  }
}

proc native_bridge_command_result(object_path: string, executable_path: string, message: string, diagnostic_code: string, tool: string, command_text: string, stderr_text: string, symbol: string, exit_code: int, valid: bool) -> NativeBridgeResult {
  give NativeBridgeResult {
    object_path: object_path,
    executable_path: executable_path,
    message: message,
    diagnostic_code: diagnostic_code,
    tool: tool,
    command_text: command_text,
    stderr_text: stderr_text,
    symbol: symbol,
    exit_code: exit_code,
    valid: valid
  }
}

proc native_object_command(object_path: string) -> string {
  give "clang -Wno-override-module -c " + object_path + ".ll -o " + object_path;
}

proc native_assembly_target(target_name: string) -> string {
  if target_name == "x86_64-linux" or target_name == "x86_64-unknown-linux-gnu" {
    give "x86_64-unknown-linux-gnu";
  }
  if target_name == "aarch64-linux" or target_name == "aarch64-unknown-linux-gnu" {
    give "aarch64-unknown-linux-gnu";
  }
  if target_name == "x86_64-windows" or target_name == "x86_64-pc-windows-msvc" {
    give "x86_64-pc-windows-msvc";
  }
  if target_name == "apple-silicon-macos" or target_name == "arm64-apple-macos" {
    give "arm64-apple-macos";
  }
  give "";
}

proc native_assembly_object_command(target_name: string, object_path: string, debug_enabled: bool) -> string {
  let target: string = native_assembly_target(target_name);
  let debug_flag: string = if debug_enabled { " -g" } else { "" };
  give "clang -target " + target + debug_flag + " -x assembler -c " + object_path + ".s -o " + object_path;
}

proc native_object_verification_message(code: int) -> string {
  if code == 1 { give "invalid object verification input"; }
  if code == 2 { give "unsupported object target"; }
  if code == 3 { give "invalid object magic"; }
  if code == 4 { give "unsupported object class or endianness"; }
  if code == 5 { give "object is not relocatable"; }
  if code == 6 { give "object machine does not match the target"; }
  if code == 7 { give "invalid object section table"; }
  if code == 8 { give "object has no executable text section"; }
  if code == 9 { give "object has no symbol table"; }
  if code == 10 { give "object has no string table"; }
  if code == 11 { give "expected entry symbol is absent or undefined"; }
  if code == 12 { give "expected object relocations are absent"; }
  if code == 13 { give "object has no stack unwind information"; }
  if code == 14 { give "object has incomplete debug information"; }
  give "native object verification failed";
}

proc native_link_command(object_path: string, executable_path: string) -> string {
  give "cc " + object_path + " src/vitte/compiler/backends/runtime_c/vitte_runtime.c -I src/vitte/compiler/backends/runtime_c -o " + executable_path;
}

proc safe_shell_path(path: string) -> bool {
  give path != ""
}

proc emit_native_object_from_llvm_ir(ir_text: string, output_dir: string, object_path: string) -> NativeBridgeResult {
  let command_text: string = native_object_command(object_path);
  if not host_runtime_available() {
    give native_bridge_command_result(object_path, "", "required C compiler `clang` is unavailable", "BACKEND_E_NATIVE_TOOL_MISSING", "clang", command_text, "native host runtime unavailable", "", -1, false)
  }
  if ir_text == "" or not safe_shell_path(output_dir) or not safe_shell_path(object_path) {
    give native_bridge_command_result(object_path, "", "invalid native object materialization input", "BACKEND_E_CODEGEN_FAILED", "clang", command_text, "invalid LLVM IR or output path", "", -1, false)
  }
  if host_mkdir_all(output_dir) != 0 {
    give native_bridge_command_result(object_path, "", "permission denied while creating native output directory", "BACKEND_E_OBJECT_WRITE_FAILED", "clang", command_text, "output directory is not writable", "", -1, false)
  }
  // Native mode deliberately lets clang retarget canonical IR to the host.
  let code: int = host_emit_llvm_object(ir_text, object_path)
  if code == 0 and host_is_file(object_path) {
    give native_bridge_command_result(object_path, "", "native object materialized", "", "clang", command_text, "", "", code, true)
  }
  if code == 127 {
    give native_bridge_command_result(object_path, "", "required C compiler `clang` was not found", "BACKEND_E_NATIVE_TOOL_MISSING", "clang", command_text, "clang command was not found", "", code, false)
  }
  if code == 0 {
    give native_bridge_command_result(object_path, "", "native compiler did not write the object file", "BACKEND_E_OBJECT_WRITE_FAILED", "clang", command_text, "expected object file is absent", "", code, false)
  }
  give native_bridge_command_result(object_path, "", "clang object emission failed", "BACKEND_E_CODEGEN_FAILED", "clang", command_text, "native host runtime does not capture stderr", "", code, false)
}

proc emit_native_object_from_assembly(assembly_text: string, target_name: string, entry_symbol: string, require_relocations: bool, debug_enabled: bool, output_dir: string, object_path: string) -> NativeBridgeResult {
  let target: string = native_assembly_target(target_name);
  let command_text: string = native_assembly_object_command(target_name, object_path, debug_enabled);
  if not host_runtime_available() {
    give native_bridge_command_result(object_path, "", "required native assembler `clang` is unavailable", "BACKEND_E_NATIVE_TOOL_MISSING", "clang", command_text, "native host runtime unavailable", "", -1, false)
  }
  if assembly_text == "" or target == "" or entry_symbol == "" or not safe_shell_path(output_dir) or not safe_shell_path(object_path) {
    give native_bridge_command_result(object_path, "", "invalid native assembly object input", "BACKEND_E_CODEGEN_FAILED", "clang", command_text, "invalid assembly, target, or output path", "", -1, false)
  }
  if host_mkdir_all(output_dir) != 0 {
    give native_bridge_command_result(object_path, "", "permission denied while creating native output directory", "BACKEND_E_OBJECT_WRITE_FAILED", "clang", command_text, "output directory is not writable", "", -1, false)
  }
  let code: int = host_emit_assembly_object(assembly_text, target, object_path, debug_enabled)
  if code == 0 and host_is_file(object_path) {
    let verification_code: int = host_verify_native_object(object_path, target, entry_symbol, require_relocations, debug_enabled)
    if verification_code == 0 {
      give native_bridge_command_result(object_path, "", "deterministic native assembly object materialized and verified", "", "clang", command_text, "", entry_symbol, code, true)
    }
    give native_bridge_command_result(object_path, "", native_object_verification_message(verification_code), "BACKEND_E_CODEGEN_FAILED", "object-verifier", command_text, "object verification code " + string(verification_code), entry_symbol, verification_code, false)
  }
  if code == 127 {
    give native_bridge_command_result(object_path, "", "required native assembler `clang` was not found", "BACKEND_E_NATIVE_TOOL_MISSING", "clang", command_text, "clang command was not found", "", code, false)
  }
  if code == 0 {
    give native_bridge_command_result(object_path, "", "native assembler did not write the object file", "BACKEND_E_OBJECT_WRITE_FAILED", "clang", command_text, "expected object file is absent", "", code, false)
  }
  give native_bridge_command_result(object_path, "", "native assembly object emission failed", "BACKEND_E_CODEGEN_FAILED", "clang", command_text, "native host runtime does not capture stderr", "", code, false)
}

proc link_native_executable(object_path: string, executable_path: string) -> NativeBridgeResult {
  let command_text: string = native_link_command(object_path, executable_path);
  if not host_runtime_available() {
    give native_bridge_command_result(object_path, executable_path, "required C compiler `cc` is unavailable", "BACKEND_E_NATIVE_TOOL_MISSING", "cc", command_text, "native host runtime unavailable", "", -1, false)
  }
  if not safe_shell_path(object_path) or not host_is_file(object_path) {
    give native_bridge_command_result(object_path, executable_path, "native linker input object was not found", "LINK_E_OBJECT_NOT_FOUND", "cc", command_text, "object file is absent", "", -1, false)
  }
  if not safe_shell_path(executable_path) {
    give native_bridge_command_result(object_path, executable_path, "invalid native linker output path", "BACKEND_E_OBJECT_WRITE_FAILED", "cc", command_text, "output path is empty", "", -1, false)
  }
  let code: int = host_link_executable(object_path, executable_path)
  if code == 0 and host_is_file(executable_path) {
    give native_bridge_command_result(object_path, executable_path, "native executable linked", "", "cc", command_text, "", "", code, true)
  }
  if code == 127 {
    give native_bridge_command_result(object_path, executable_path, "required C compiler `cc` was not found", "BACKEND_E_NATIVE_TOOL_MISSING", "cc", command_text, "cc command was not found", "", code, false)
  }
  if code == 0 {
    give native_bridge_command_result(object_path, executable_path, "linker did not write the executable", "BACKEND_E_OBJECT_WRITE_FAILED", "cc", command_text, "expected executable is absent", "", code, false)
  }
  give native_bridge_command_result(object_path, executable_path, "native linker invocation failed", "LINK_E_SYSTEM_LINKER_FAILED", "cc", command_text, "native host runtime does not capture stderr", "", code, false)
}

proc run_native_executable(executable_path: string) -> NativeBridgeResult {
  if not host_runtime_available() or not safe_shell_path(executable_path) or not host_is_file(executable_path) {
    give native_bridge_result("", executable_path, "native executable unavailable", -1, false)
  }
  let code: int = host_run_executable(executable_path)
  give native_bridge_result("", executable_path, "native executable completed", code, true)
}

share NativeBridgeResult
share native_bridge_result
share native_bridge_command_result
share native_object_command
share native_assembly_target
share native_assembly_object_command
share native_object_verification_message
share native_link_command
share emit_native_object_from_llvm_ir
share emit_native_object_from_assembly
share link_native_executable
share run_native_executable
