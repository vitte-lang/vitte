space vitte/compiler/backend/target

use vitte/compiler/backend/target/triple.{ TargetTriple, triple_aarch64_linux }

form Aarch64Target {
  triple: TargetTriple
  pointer_width: u64
  little_endian: bool
  valid: bool
}

proc target_aarch64_default() -> Aarch64Target {
  give Aarch64Target {
    triple: triple_aarch64_linux(),
    pointer_width: 64,
    little_endian: true,
    valid: true
  };
}
