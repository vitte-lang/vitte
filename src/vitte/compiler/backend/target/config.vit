space vitte/compiler/backend/target

form TargetConfig {
  name: string,
  pointer_size: u64,
  endianness: string,
  abi: string,
  linker_path: string,
  object_format: string,
  backend_name: string,
  target_triple: string,
  valid: bool,
}

proc target_config(name: string, pointer_size: u64, endianness: string, abi: string, linker_path: string, object_format: string, backend_name: string, target_triple: string) -> TargetConfig {
  give TargetConfig {
    name: name,
    pointer_size: pointer_size,
    endianness: endianness,
    abi: abi,
    linker_path: linker_path,
    object_format: object_format,
    backend_name: backend_name,
    target_triple: target_triple,
    valid: name != "" and pointer_size > 0 and endianness != "" and abi != "" and object_format != "" and target_triple != "",
  };
}

proc target_config_x86_64_linux_gnu() -> TargetConfig {
  give target_config("x86_64-linux-gnu", 64, "little", "sysv", "ld", "elf", "x86_64", "x86_64-linux");
}

proc target_config_i386_linux_gnu() -> TargetConfig {
  give target_config("i386-linux-gnu", 32, "little", "sysv", "ld", "elf", "x86_64", "i386-linux");
}

proc target_config_riscv64_linux_gnu() -> TargetConfig {
  give target_config("riscv64-linux-gnu", 64, "little", "lp64d", "ld", "elf", "llvm", "riscv64-linux");
}

proc target_config_aarch64_linux_gnu() -> TargetConfig {
  give target_config("aarch64-linux-gnu", 64, "little", "aapcs64", "ld", "elf", "llvm", "aarch64-linux");
}

proc target_config_legacy_compatible(name: string) -> TargetConfig {
  give target_config(name, 32, "little", "sysv", "ld", "elf", "x86_64", "i386-linux");
}

proc target_config_from_name(name: string) -> TargetConfig {
  if name == "x86_64-linux-gnu" or name == "x86_64-linux" or name == "native" or name == "x86_64-unknown-linux-gnu" or name == "x86_64-pc-linux-gnu" or name == "x86_64-linux-musl" or name == "x86_64-unknown-linux-musl" or name == "x86_64-unknown-freebsd" or name == "x86_64-apple-darwin" or name == "x86_64-pc-windows-msvc" or name == "x86_64-pc-windows-gnu" or name == "amd64-linux-gnu" or name == "x64-linux-gnu" {
    give target_config_x86_64_linux_gnu();
  }
  if name == "i386-linux-gnu" or name == "i386-linux" or name == "x86-linux-gnu" or name == "i486-linux-gnu" or name == "i586-linux-gnu" or name == "i686-linux-gnu" or name == "i686-unknown-linux-gnu" or name == "i686-unknown-linux-musl" or name == "x86-unknown-linux-gnu" {
    give target_config_i386_linux_gnu();
  }
  if name == "aarch64-linux-gnu" or name == "aarch64-linux" or name == "aarch64-unknown-linux-gnu" or name == "aarch64-unknown-linux-musl" or name == "aarch64-linux-musl" or name == "aarch64-apple-darwin" or name == "aarch64-linux-android" or name == "arm64-linux-gnu" {
    give target_config_aarch64_linux_gnu();
  }
  if name == "riscv64-linux-gnu" or name == "riscv64-linux" or name == "riscv64gc-unknown-linux-gnu" or name == "riscv64gc-unknown-linux-musl" or name == "riscv64-unknown-none-elf" {
    give target_config_riscv64_linux_gnu();
  }
  if name == "m68k-linux-gnu" or name == "m68k-retro" or name == "powerpc-linux-gnu" or name == "ppc-linux-gnu" or name == "powerpc-g3" or name == "powerpc-g4" or name == "powerpc-g5" or name == "sparc-linux-gnu" or name == "sparc-retro" or name == "mips-linux-gnu" or name == "mipsel-linux-gnu" or name == "armv7-linux-gnueabihf" or name == "arm-linux-gnueabihf" or name == "z80-retro" or name == "mos6502-retro" or name == "avr-embedded" or name == "sh4-retro" or name == "mips64el-linux-gnuabi64" or name == "alpha-linux-gnu" or name == "hppa-linux-gnu" or name == "s390x-linux-gnu" or name == "loongarch64-linux-gnu" {
    give target_config_legacy_compatible(name);
  }
  give target_config("", 0, "", "", "", "", "", "");
}

share TargetConfig
share target_config
share target_config_x86_64_linux_gnu
share target_config_i386_linux_gnu
share target_config_aarch64_linux_gnu
share target_config_riscv64_linux_gnu
share target_config_legacy_compatible
share target_config_from_name
