space vitte/compiler/backend/target

use vitte/compiler/backend/target/triple.{ TargetTriple, triple_i386_linux }

form I386Target {
  triple: TargetTriple
  pointer_width: u64
  little_endian: bool
  valid: bool
}

proc target_i386_default() -> I386Target {
  give I386Target {
    triple: triple_i386_linux(),
    pointer_width: 32,
    little_endian: true,
    valid: true
  };
}
