space vitte/compiler/backend/target/x86_64

use vitte/compiler/backend/target/triple.{ TargetTriple, triple_x86_64_linux }

form X86_64Target {
  triple: TargetTriple
  pointer_width: u64
  little_endian: bool
  valid: bool
}

proc target_x86_64_default() -> X86_64Target {
  give X86_64Target {
    triple: triple_x86_64_linux(),
    pointer_width: 64,
    little_endian: true,
    valid: true
  };
}
