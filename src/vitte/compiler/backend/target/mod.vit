proc backend_target_apple_silicon() -> BackendTarget {

  let triple: TargetTriple =
    triple_macos_apple_silicon();

  give backend_target(
    BackendTargetKind.AppleSilicon,
    triple,
    "apple-m4",
    "",
    ".a",
    ".dylib",
    true,
    true,
    true,
    false,
    false
  );
}

proc backend_target_wasm32() -> BackendTarget {

  let triple: TargetTriple =
    triple_wasm32();

  give backend_target(
    BackendTargetKind.Wasm32,
    triple,
    "wasm32",
    ".wasm",
    ".a",
    ".wasm",
    false,
    true,
    true,
    false,
    false
  );
}

proc backend_target_native() -> BackendTarget {
  give backend_target_x86_64_linux();
}

proc target_is_native(
  target: BackendTarget
) -> bool {

  let native: BackendTarget =
    backend_target_native();

  give triple_text(target.triple)
    == triple_text(native.triple);
}

proc target_supports_parallel_codegen(
  target: BackendTarget
) -> bool {

  give target.supports_threads
    and target.pointer_width >= 8;
}

proc target_supports_jit(
  target: BackendTarget
) -> bool {

  give not target.embedded
    and not target.retro
    and not triple_is_wasm(target.triple);
}

proc target_supports_shared_objects(
  target: BackendTarget
) -> bool {

  give target.dynamic_library_extension != "";
}

proc target_supports_advanced_optimizations(
  target: BackendTarget
) -> bool {

  give target.supports_simd
    and target.supports_vectors
    and not target.retro;
}

proc target_architecture_name(
  target: BackendTarget
) -> string {

  give backend_target_kind_name(
    target.kind
  );
}

proc target_feature_text(
  target: BackendTarget
) -> string {

  let text: string = "";

  let i: u64 = 0;

  while i < len(target.features) {

    if i > 0 {
      set text =
        text + ",";
    }

    set text =
      text + target.features[i];

    set i =
      i + 1;
  }

  give text;
}

proc target_summary(
  target: BackendTarget
) -> string {

  give "kind="
    + backend_target_kind_name(target.kind)
    + " triple="
    + triple_text(target.triple)
    + " cpu="
    + target.cpu
    + " features="
    + (target.feature_count as string)
    + " ptr="
    + (target.pointer_width as string)
    + " endian="
    + if target.little_endian { "little" } else { "big" }
    + " simd="
    + (target.supports_simd as string)
    + " vectors="
    + (target.supports_vectors as string)
    + " retro="
    + (target.retro as string)
    + " embedded="
    + (target.embedded as string)
    + " object="
    + target.object_format
    + " valid="
    + (target.valid as string);
}

proc target_extended_summary(
  target: BackendTarget
) -> string {

  give target_summary(target)
    + " layout={"
    + layout_summary(target.layout)
    + "} triple={"
    + triple_summary(target.triple)
    + "} features={"
    + feature_summary(target.triple)
    + "}";
}

proc target_selftest() -> bool {

  let native: BackendTarget =
    backend_target_native();

  let retro: BackendTarget =
    backend_target_x86_64_retro();

  let apple: BackendTarget =
    backend_target_apple_silicon();

  let wasm: BackendTarget =
    backend_target_wasm32();

  give native.valid
    and retro.valid
    and apple.valid
    and wasm.valid
    and target_supports_parallel_codegen(native)
    and target_supports_jit(native)
    and not target_supports_jit(wasm)
    and target_extended_summary(native) != "";
}