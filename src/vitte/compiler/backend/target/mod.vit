space vitte/compiler/backend/target/mod

use vitte/compiler/backend/target/triple.{
  TargetTriple,

  target_triple,

  triple_x86_64_linux,
  triple_aarch64_linux,
  triple_riscv64_linux,
  triple_i386_linux,

  triple_windows_x86_64,
  triple_macos_apple_silicon,
  triple_wasm32,

  triple_text,
  triple_summary,

  triple_is_unix,
  triple_is_windows,
  triple_is_apple,
  triple_is_wasm,
  triple_is_retro
}

use vitte/compiler/backend/target/layout.{
  TargetLayout,

  target_layout_for,

  pointer_size,
  stack_alignment,
  simd_alignment,

  is_little_endian,

  layout_summary
}

use vitte/compiler/backend/target/x86_64.{
  X8664Target,

  target_x86_64_linux,
  target_x86_64_windows,
  target_x86_64_macos,
  target_x86_64_retro,
  target_x86_64_modern,

  target_supports_modern_isa
}

use vitte/compiler/backend/target/riscv64.{
  Riscv64Target,

  target_riscv64_linux,
  target_riscv64_embedded,
  target_riscv64_vector,

  target_supports_vectors
}

use vitte/compiler/backend/target.{
  default_feature_set,
  feature_count,
  feature_summary
}

export *

pick BackendTargetKind {
  Unknown,

  X8664,
  Aarch64,
  Riscv64,
  I386,

  Wasm32,
  Wasm64,

  M68k,
  PowerPc,
  Sparc,

  AppleSilicon,

  Embedded,
  Retro,
  Experimental,
}

form BackendTarget {
  kind: BackendTargetKind

  triple: TargetTriple
  layout: TargetLayout

  cpu: string

  features: [string]

  feature_count: u64

  object_format: string

  executable_extension: string
  static_library_extension: string
  dynamic_library_extension: string

  pointer_width: u64

  little_endian: bool

  supports_threads: bool
  supports_simd: bool
  supports_vectors: bool

  retro: bool
  embedded: bool

  valid: bool
}

proc backend_target_kind_name(
  kind: BackendTargetKind
) -> string {

  if kind == BackendTargetKind.X8664 {
    give "x86_64";
  }

  if kind == BackendTargetKind.Aarch64 {
    give "aarch64";
  }

  if kind == BackendTargetKind.Riscv64 {
    give "riscv64";
  }

  if kind == BackendTargetKind.I386 {
    give "i386";
  }

  if kind == BackendTargetKind.Wasm32 {
    give "wasm32";
  }

  if kind == BackendTargetKind.Wasm64 {
    give "wasm64";
  }

  if kind == BackendTargetKind.M68k {
    give "m68k";
  }

  if kind == BackendTargetKind.PowerPc {
    give "powerpc";
  }

  if kind == BackendTargetKind.Sparc {
    give "sparc";
  }

  if kind == BackendTargetKind.AppleSilicon {
    give "apple-silicon";
  }

  if kind == BackendTargetKind.Embedded {
    give "embedded";
  }

  if kind == BackendTargetKind.Retro {
    give "retro";
  }

  if kind == BackendTargetKind.Experimental {
    give "experimental";
  }

  give "unknown";
}

proc backend_target(
  kind: BackendTargetKind,
  triple: TargetTriple,
  cpu: string,
  executable_extension: string,
  static_library_extension: string,
  dynamic_library_extension: string,
  supports_threads: bool,
  supports_simd: bool,
  supports_vectors0: bool,
  retro: bool,
  embedded: bool
) -> BackendTarget {

  let layout: TargetLayout =
    target_layout_for(triple);

  let features: [string] =
    default_feature_set(triple);

  give BackendTarget {
    kind: kind,

    triple: triple,
    layout: layout,

    cpu: cpu,

    features: features,

    feature_count:
      feature_count(features),

    object_format:
      triple.object_format,

    executable_extension:
      executable_extension,

    static_library_extension:
      static_library_extension,

    dynamic_library_extension:
      dynamic_library_extension,

    pointer_width:
      pointer_size(layout),

    little_endian:
      is_little_endian(layout),

    supports_threads:
      supports_threads,

    supports_simd:
      supports_simd,

    supports_vectors:
      supports_vectors0,

    retro: retro,
    embedded: embedded,

    valid:
      triple.valid
      and layout.valid
  };
}

proc backend_target_x86_64_linux() -> BackendTarget {

  let target: X8664Target =
    target_x86_64_linux();

  give backend_target(
    BackendTargetKind.X8664,
    target.triple,
    target.cpu,
    target.executable_extension,
    target.static_library_extension,
    target.dynamic_library_extension,
    true,
    true,
    true,
    false,
    false
  );
}

proc backend_target_x86_64_windows() -> BackendTarget {

  let target: X8664Target =
    target_x86_64_windows();

  give backend_target(
    BackendTargetKind.X8664,
    target.triple,
    target.cpu,
    target.executable_extension,
    target.static_library_extension,
    target.dynamic_library_extension,
    true,
    true,
    true,
    false,
    false
  );
}

proc backend_target_x86_64_macos() -> BackendTarget {

  let target: X8664Target =
    target_x86_64_macos();

  give backend_target(
    BackendTargetKind.X8664,
    target.triple,
    target.cpu,
    target.executable_extension,
    target.static_library_extension,
    target.dynamic_library_extension,
    true,
    true,
    true,
    false,
    false
  );
}

proc backend_target_x86_64_retro() -> BackendTarget {

  let target: X8664Target =
    target_x86_64_retro();

  give backend_target(
    BackendTargetKind.Retro,
    target.triple,
    target.cpu,
    target.executable_extension,
    target.static_library_extension,
    target.dynamic_library_extension,
