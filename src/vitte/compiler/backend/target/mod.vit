proc backend_target_riscv64_vector() -> BackendTarget {

  let target: Riscv64Target =
    target_riscv64_vector();

  give backend_target(
    BackendTargetKind.Riscv64,
    target.triple,
    target.cpu,
    target.executable_extension,
    target.static_library_extension,
    target.dynamic_library_extension,
    true,
    true,
    true,
