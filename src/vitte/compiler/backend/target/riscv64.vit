space vitte/compiler/backend/target

use vitte/compiler/backend/target/triple.{ TargetTriple, triple_riscv64_linux }

form Riscv64Target {
  triple: TargetTriple
  pointer_width: u64
  little_endian: bool
  valid: bool
}

proc target_riscv64_default() -> Riscv64Target {
  give Riscv64Target {
    triple: triple_riscv64_linux(),
    pointer_width: 64,
    little_endian: true,
    valid: true
  };
}
