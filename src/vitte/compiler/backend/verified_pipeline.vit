space vitte/compiler/backend/verified_pipeline

use vitte/compiler/backend/pipeline.{ BackendPipelineResult }
use vitte/compiler/backend/ir/verify.{ verify_backend_ir }
use vitte/compiler/backend/link/artifact.{ artifact_is_valid }

form BackendVerificationReport {
  mir_backend_invariants: bool
  abi_assertions: bool
  stack_safety_checks: bool
  control_flow_verification: bool
  object_validation: bool
  violations: [string]
  valid: bool
}

proc append_violation(items: [string], enabled: bool, message: string) -> [string] {
  if enabled {
    give items;
  }
  give items + [message];
}

proc check_mir_backend_invariants(result: BackendPipelineResult) -> bool {
  give result.ir_unit.valid and result.codegen.instruction_selected and result.codegen.registers_allocated;
}

proc check_abi_assertions(result: BackendPipelineResult) -> bool {
  let target_ok: bool = result.ir_unit.target.triple.arch != "" and result.ir_unit.target.triple.os != "";
  let format_ok: bool = result.codegen.object_format != "";
  give target_ok and format_ok;
}

proc check_stack_safety(result: BackendPipelineResult) -> bool {
  give result.ir_unit.target.pointer_width >= 32 and result.ir_unit.target.data_layout != "";
}

proc check_control_flow_verification(result: BackendPipelineResult) -> bool {
  give verify_backend_ir(result.ir_unit);
}

proc check_object_validation(result: BackendPipelineResult) -> bool {
  give result.codegen.object_ready and artifact_is_valid(result.artifact);
}

proc verify_backend_pipeline(result: BackendPipelineResult) -> BackendVerificationReport {
  let inv: bool = check_mir_backend_invariants(result);
  let abi: bool = check_abi_assertions(result);
  let stack: bool = check_stack_safety(result);
  let cfg: bool = check_control_flow_verification(result);
  let obj: bool = check_object_validation(result);

  let issues0: [string] = [];
  let issues1: [string] = append_violation(issues0, inv, "mir-backend invariants failed");
  let issues2: [string] = append_violation(issues1, abi, "abi assertions failed");
  let issues3: [string] = append_violation(issues2, stack, "stack safety checks failed");
  let issues4: [string] = append_violation(issues3, cfg, "control-flow verification failed");
  let issues5: [string] = append_violation(issues4, obj, "object validation failed");

  give BackendVerificationReport {
    mir_backend_invariants: inv,
    abi_assertions: abi,
    stack_safety_checks: stack,
    control_flow_verification: cfg,
    object_validation: obj,
    violations: issues5,
    valid: inv and abi and stack and cfg and obj
  };
}

export *
