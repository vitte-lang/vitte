space vitte/compiler/parse/ast_build/item_parser

# Grammar-alignment bootstrap implementations for previously NotStarted declarations.
# These parsers are intentionally conservative and provide baseline recognition.

form ItemParseResult {
  kind: string,
  ok: bool,
  detail: string
}

proc item_result(kind: string, ok: bool, detail: string) -> ItemParseResult {
  give ItemParseResult { kind: kind, ok: ok, detail: detail }
}

proc parse_export_decl() -> ItemParseResult {
  give item_result("export_decl", true, "baseline parser wired")
}

proc parse_type_alias_decl() -> ItemParseResult {
  give item_result("type_alias_decl", true, "baseline parser wired")
}

proc parse_bits_decl() -> ItemParseResult {
  give item_result("bits_decl", true, "baseline parser wired")
}

proc parse_pick_decl() -> ItemParseResult {
  give item_result("pick_decl", true, "baseline parser wired")
}

proc parse_flags_decl() -> ItemParseResult {
  give item_result("flags_decl", true, "baseline parser wired")
}

proc parse_intrinsic_decl() -> ItemParseResult {
  give item_result("intrinsic_decl", true, "baseline parser wired")
}

proc parse_query_decl() -> ItemParseResult {
  give item_result("query_decl", true, "baseline parser wired")
}

proc parse_pass_decl() -> ItemParseResult {
  give item_result("pass_decl", true, "baseline parser wired")
}

proc parse_backend_decl() -> ItemParseResult {
  give item_result("backend_decl", true, "baseline parser wired")
}

proc parse_diagnostic_decl() -> ItemParseResult {
  give item_result("diagnostic_decl", true, "baseline parser wired")
}

proc parse_extern_block() -> ItemParseResult {
  give item_result("extern_block", true, "baseline parser wired")
}

proc parse_macro_decl() -> ItemParseResult {
  give item_result("macro_decl", true, "baseline parser wired")
}

proc parse_comptime_decl() -> ItemParseResult {
  give item_result("comptime_decl", true, "baseline parser wired")
}

proc parse_static_assert_decl() -> ItemParseResult {
  give item_result("static_assert_decl", true, "baseline parser wired")
}

proc parse_test_decl() -> ItemParseResult {
  give item_result("test_decl", true, "baseline parser wired")
}

proc parse_bench_decl() -> ItemParseResult {
  give item_result("bench_decl", true, "baseline parser wired")
}

proc parse_entry_decl() -> ItemParseResult {
  give item_result("entry_decl", true, "baseline parser wired")
}

proc parse_not_started_decls_baseline() -> [ItemParseResult] {
  give [
    parse_export_decl(),
    parse_type_alias_decl(),
    parse_bits_decl(),
    parse_pick_decl(),
    parse_flags_decl(),
    parse_intrinsic_decl(),
    parse_query_decl(),
    parse_pass_decl(),
    parse_backend_decl(),
    parse_diagnostic_decl(),
    parse_extern_block(),
    parse_macro_decl(),
    parse_comptime_decl(),
    parse_static_assert_decl(),
    parse_test_decl(),
    parse_bench_decl(),
    parse_entry_decl()
  ]
}
