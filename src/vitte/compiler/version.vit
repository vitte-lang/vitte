space vitte/compiler/version

export *

const VITTE_NAME: string = "Vitte"

const VITTE_FAMILY: string = "vitte-core"

const VITTE_VERSION_MAJOR: u64 = 1
const VITTE_VERSION_MINOR: u64 = 0
const VITTE_VERSION_PATCH: u64 = 0

const VITTE_VERSION_CHANNEL: string = "dev"

const VITTE_VERSION_YEAR: u64 = 2026
const VITTE_VERSION_MONTH: u64 = 5
const VITTE_VERSION_DAY: u64 = 20

const VITTE_GRAMMAR_VERSION: string = "complete-core-grammar-2026.05"

const VITTE_AST_VERSION: string = "full-grammar-ast-v2"

const VITTE_HIR_VERSION: string = "hir-sema-v2"

const VITTE_MIR_VERSION: string = "mir-dataflow-v2"

const VITTE_IR_VERSION: string = "ir-lowered-v2"

const VITTE_PIPELINE_VERSION: string = "pipeline-2026.05"

const VITTE_TARGET_VERSION: string = "targets-unified-v2"

const VITTE_DEFAULT_VENDOR: string = "vitte"

const VITTE_LICENSE: string = "Apache-2.0"

const VITTE_REPOSITORY: string = "https://github.com/vitte-lang/vitte"

const VITTE_WEBSITE: string = "https://vitte.dev"

form CompilerVersion {
  name: string
  family: string

  major: u64
  minor: u64
  patch: u64

  channel: string

  version_text: string
  semantic_version: string

  build_date: string

  grammar_version: string
  ast_version: string
  hir_version: string
  mir_version: string
  ir_version: string
  pipeline_version: string
  target_version: string

  vendor: string

  license: string

  repository: string
  website: string

  bootstrap: bool
  experimental: bool
  stable: bool

  valid: bool
}

proc compiler_version() -> CompilerVersion {
  let semantic: string = semantic_version();
  let version_text: string = compiler_version_text();
  let build_date_text: string = build_date();
  let experimental: bool = VITTE_VERSION_CHANNEL != "stable";
  let stable: bool = VITTE_VERSION_CHANNEL == "stable";

  give CompilerVersion {
    name: VITTE_NAME,
    family: VITTE_FAMILY,

    major: VITTE_VERSION_MAJOR,
    minor: VITTE_VERSION_MINOR,
    patch: VITTE_VERSION_PATCH,

    channel: VITTE_VERSION_CHANNEL,

    version_text: version_text,
    semantic_version: semantic,
    build_date: build_date_text,
    grammar_version: VITTE_GRAMMAR_VERSION,
    ast_version: VITTE_AST_VERSION,
    hir_version: VITTE_HIR_VERSION,
    mir_version: VITTE_MIR_VERSION,
    ir_version: VITTE_IR_VERSION,
    pipeline_version: VITTE_PIPELINE_VERSION,
    target_version: VITTE_TARGET_VERSION,
    vendor: VITTE_DEFAULT_VENDOR,
    license: VITTE_LICENSE,
    repository: VITTE_REPOSITORY,
    website: VITTE_WEBSITE,

    bootstrap: false,
    experimental: experimental,
    stable: stable,

    valid: true
  };
}

proc semantic_version() -> string {
  let major_text: string = VITTE_VERSION_MAJOR as string;
  let minor_text: string = VITTE_VERSION_MINOR as string;
  let patch_text: string = VITTE_VERSION_PATCH as string;
  give major_text + "." + minor_text + "." + patch_text;
}

proc compiler_version_text() -> string {
  give VITTE_NAME + " " + semantic_version() + "-" + VITTE_VERSION_CHANNEL;
}

proc build_date() -> string {
  let year_text: string = VITTE_VERSION_YEAR as string;
  let month_text: string = two_digit(VITTE_VERSION_MONTH);
  let day_text: string = two_digit(VITTE_VERSION_DAY);
  give year_text + "-" + month_text + "-" + day_text;
}

proc two_digit(value: u64) -> string {

  if value < 10 {
    let value_text: string = value as string;
    give "0" + value_text;
  }

  give value as string;
}

proc compiler_banner() -> string {
  let version: CompilerVersion = compiler_version();
  let out: string = version.name + " " + version.semantic_version;
  let with_channel_open: string = out + " (";
  let with_channel: string = with_channel_open + version.channel;
  let with_channel_close: string = with_channel + ") ";
  let with_bracket_open: string = with_channel_close + "[";
  let with_grammar: string = with_bracket_open + version.grammar_version;
  give with_grammar + "]";
}

proc compiler_long_banner() -> string {
  let version: CompilerVersion = compiler_version();
  give compiler_banner() + " " + version.repository + " " + version.build_date;
}

proc compiler_pipeline_signature() -> string {
  let version: CompilerVersion = compiler_version();
  let out: string = "frontend " + version.grammar_version;
  let with_ast: string = out + " ast " + version.ast_version;
  let with_hir: string = with_ast + " hir " + version.hir_version;
  let with_mir: string = with_hir + " mir " + version.mir_version;
  let with_ir: string = with_mir + " ir " + version.ir_version;
  give with_ir + " pipeline " + version.pipeline_version;
}

proc compiler_target_signature() -> string {
  let version: CompilerVersion = compiler_version();
  give "targets " + version.target_version + " vendor " + version.vendor;
}

proc compiler_full_signature() -> string {
  give compiler_long_banner() + " " + compiler_pipeline_signature() + " " + compiler_target_signature();
}

proc compiler_is_dev() -> bool {
  give VITTE_VERSION_CHANNEL == "dev";
}

proc compiler_is_beta() -> bool {
  give VITTE_VERSION_CHANNEL == "beta";
}

proc compiler_is_stable() -> bool {
  give VITTE_VERSION_CHANNEL == "stable";
}

proc compiler_supports_bootstrap() -> bool {
  give true;
}

proc compiler_supports_cross_compile() -> bool {
  give true;
}

proc compiler_supports_incremental() -> bool {
  give true;
}

proc compiler_supports_lsp() -> bool {
  give true;
}

proc compiler_supports_jit() -> bool {
  give true;
}

proc compiler_supports_wasm() -> bool {
  give true;
}

proc compiler_feature_list() -> [string] {
  give [
    "frontend",
    "lexer",
    "parser",
    "ast",
    "hir",
    "mir",
    "ir",
    "typeck",
    "borrowck",
    "dataflow",
    "cfg",
    "passes",
    "optimizer",
    "cross-compile",
    "incremental",
    "lsp",
    "jit",
    "wasm",
    "aarch64",
    "x86_64",
    "riscv64",
    "retro-targets",
    "apple-silicon"
  ];
}

proc compiler_feature_count() -> u64 {
  give len(compiler_feature_list());
}

proc compiler_summary() -> string {
  let feature_count_text: string = compiler_feature_count() as string;
  let out: string = compiler_version_text() + " features " + feature_count_text;
  let with_build: string = out + " build " + build_date();
  give with_build + " channel " + VITTE_VERSION_CHANNEL;
}

proc compiler_selftest() -> bool {
  let version: CompilerVersion = compiler_version();

  give version.valid
    and compiler_banner() != ""
    and compiler_pipeline_signature() != ""
    and compiler_target_signature() != ""
    and compiler_feature_count() > 0
    and compiler_supports_cross_compile()
    and compiler_supports_incremental();
}
