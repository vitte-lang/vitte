space vitte/compiler/tests/smoke

use src/vitte/compiler/driver/compiler
use src/vitte/compiler/driver/options
use src/vitte/compiler/driver/pipeline
use src/vitte/compiler/backends/backend
use src/vitte/compiler/frontend/diagnostics as diagnostics
use src/vitte/compiler/ir/hir
use src/vitte/compiler/ir/mir
use src/vitte/compiler/mod

proc compiler_root_ok() -> bool {
  if mod.implementation_language() != "vitte" { give false }
  if mod.compiler_stage() != "bootstrap-vitte" { give false }
  if mod.source_root() != "src/vitte/compiler" { give false }
  give true
}

proc _diag_has(report: compiler.CompileReport, index: int, expected: string) -> bool {
  if diagnostics.count(report.diagnostics) <= index { give false }
  if diagnostics.format(report.diagnostics.items[index]) != expected { give false }
  give true
}

proc pipeline_lowering_ok() -> bool {
  let source_text: string = "space demo/app\nuse vitte/io\nform payload\nconst answer = 42\nstatic limit = 7\nglobal counter = 0\nproc main(argc: i32, argv: string) -> i32 {\n  give argc\n}\n"
  let artifacts: pipeline.PipelineArtifacts = pipeline.run("demo.vit", source_text)
  if artifacts.parsed_module.space_name != "demo/app" { give false }
  if artifacts.parsed_module.uses.len != 1 { give false }
  if artifacts.parsed_module.decls.len != 7 { give false }
  if artifacts.parsed_module.decls[2].name != "payload" { give false }
  if artifacts.parsed_module.proc_count != 1 { give false }
  if artifacts.parsed_module.global_count != 3 { give false }
  if hir.function_count(artifacts.real_hir) != 1 { give false }
  if hir.decl_count(artifacts.real_hir) != 7 { give false }
  if artifacts.real_hir.decls[2].kind != hir.HirDeclKind.Form { give false }
  if artifacts.real_hir.decls[4].kind != hir.HirDeclKind.Static { give false }
  if artifacts.real_hir.functions[0].stmts.len != 1 { give false }
  if artifacts.real_hir.functions[0].stmts[0].kind != hir.HirStmtKind.Give { give false }
  if artifacts.real_hir.functions[0].stmts[0].expr.kind != hir.HirExprKind.Variable { give false }
  if mir.function_count(artifacts.real_mir) != 1 { give false }
  if mir.global_count(artifacts.real_mir) != 3 { give false }
  if artifacts.real_mir.globals[1].name != "limit" { give false }
  if artifacts.real_mir.globals[1].init_literal != "7" { give false }
  if artifacts.real_mir.globals[1].is_const { give false }
  if artifacts.real_mir.functions[0].params.len != 2 { give false }
  if artifacts.real_hir.functions[0].stmts[0].kind != hir.HirStmtKind.Give { give false }
  if artifacts.real_mir.functions[0].body_stmts[0].kind != mir.MirStmtKind.Give { give false }
  give true
}

proc compiler_emit_ok() -> bool {
  let source_text: string = "space demo/app\nuse vitte/io\nconst answer = 42\nglobal counter = 0\nproc main(argc: i32) -> i32 {\n  give argc\n}\n"
  let opts: options.DriverOptions = options.default_options()
  let artifacts: compiler.PipelineArtifacts = compiler.pipeline_run("demo.vit", source_text)
  let report: compiler.CompileReport = compiler.compile_source("demo.vit", source_text, opts)
  if artifacts.real_hir.functions.len != 1 { give false }
  if artifacts.real_mir.functions.len != 1 { give false }
  if artifacts.real_mir.functions[0].params.len != 1 { give false }
  if artifacts.real_mir.functions[0].params[0].type_name != "i32" { give false }
  if artifacts.real_mir.functions[0].body_stmts[0].kind != mir.MirStmtKind.Give { give false }
  if not report.success { give false }
  if report.output_path != "a.out" { give false }
  if report.emitted_source != "#include <vitte/io>\n\nconst i32 answer = 42;\ni32 counter = 0;\n\ni32 main(i32 argc) {\n  return argc;\n}\n" { give false }
  if report.diag_count != 0 { give false }
  if report.global_count != 2 { give false }
  if report.function_count != 1 { give false }
  if report.emit_kind != "bootstrap-vitte-c-like" { give false }
  if report.notes.len != 7 { give false }
  give true
}

proc statement_lowering_ok() -> bool {
  let source_text: string = "space demo/app\nproc main() -> i32 {\n  let value: i32 = 1\n  set value = ping(value)\n  give value\n}\n"
  let opts: options.DriverOptions = options.default_options()
  let report: compiler.CompileReport = compiler.compile_source("demo.vit", source_text, opts)
  let artifacts: pipeline.PipelineArtifacts = pipeline.run("demo.vit", source_text)
  if not report.success { give false }
  if artifacts.real_mir.functions[0].body_stmts.len != 3 { give false }
  if artifacts.real_mir.functions[0].body_stmts[0].kind != mir.MirStmtKind.Let { give false }
  if artifacts.real_mir.functions[0].body_stmts[1].kind != mir.MirStmtKind.Set { give false }
  if artifacts.real_mir.functions[0].body_stmts[2].kind != mir.MirStmtKind.Give { give false }
  if artifacts.real_mir.functions[0].body_stmts[1].expr.kind != mir.MirExprKind.Call { give false }
  if artifacts.real_mir.functions[0].body_stmts[1].expr.callee != "ping" { give false }
  if artifacts.real_mir.functions[0].body_stmts[1].expr.args.len != 1 { give false }
  if artifacts.real_hir.functions[0].stmts[1].expr.kind != hir.HirExprKind.Call { give false }
  if artifacts.real_mir.functions[0].body_stmts[1].expr.kind != mir.MirExprKind.Call { give false }
  if report.emitted_source != "i32 main() {\n  i32 value = 1;\n  value = ping(value);\n  return value;\n}\n" { give false }
  give true
}

proc globals_only_emit_ok() -> bool {
  let source_text: string = "space demo/app\nconst answer = 42\nglobal counter = 0\n"
  let opts: options.DriverOptions = options.default_options()
  let report: compiler.CompileReport = compiler.compile_source("globals-only.vit", source_text, opts)
  if not report.success { give false }
  if report.emitted_source != "const i32 answer = 42;\ni32 counter = 0;\n" { give false }
  if report.diag_count != 0 { give false }
  if report.global_count != 2 { give false }
  if report.function_count != 0 { give false }
  give true
}

proc backend_mir_adapter_ok() -> bool {
  let source_text: string = "space demo/app\nconst answer = 42\nproc main() -> i32 {\n  give answer\n}\n"
  let artifacts: pipeline.PipelineArtifacts = pipeline.run("demo.vit", source_text)
  let opts: backend.BackendOptions = backend.default_options()
  let result: backend.BackendCompileResult = backend.compile_mir_backend(artifacts.real_mir, "demo.out", opts)
  if not backend.backend_ready_for_mir(artifacts.real_mir) { give false }
  if backend.backend_summary_from_mir(artifacts.real_mir) != "demo/app globals=1 functions=1" { give false }
  if result.output_path != "demo.out" { give false }
  if result.emitted_source != "backend(demo/app)" { give false }
  if result.tool_command != "vitte -o demo.out demo.vit" { give false }
  if not backend.result_is_success(result) { give false }
  give true
}

proc diagnostics_ok() -> bool {
  let opts: options.DriverOptions = options.default_options()
  let missing_space: compiler.CompileReport = compiler.compile_source(
    "missing-space.vit",
    "proc main() -> i32 {\n  give 0\n}\n",
    opts
  )
  let invalid_proc: compiler.CompileReport = compiler.compile_source(
    "invalid-proc.vit",
    "space demo/app\nproc main -> i32 {\n  give 0\n}\n",
    opts
  )
  let missing_proc_name: compiler.CompileReport = compiler.compile_source(
    "missing-proc-name.vit",
    "space demo/app\nproc (argc: i32) -> i32 {\n  give 0\n}\n",
    opts
  )
  let invalid_proc_params: compiler.CompileReport = compiler.compile_source(
    "invalid-proc-params.vit",
    "space demo/app\nproc main(argc: i32 -> i32 {\n  give 0\n}\n",
    opts
  )
  let invalid_proc_return: compiler.CompileReport = compiler.compile_source(
    "invalid-proc-return.vit",
    "space demo/app\nproc main(argc: i32) -> {\n  give 0\n}\n",
    opts
  )
  let unterminated_proc: compiler.CompileReport = compiler.compile_source(
    "unterminated-proc.vit",
    "space demo/app\nproc main() -> i32 {\n  give 0\n",
    opts
  )
  let invalid_statement: compiler.CompileReport = compiler.compile_source(
    "invalid-statement.vit",
    "space demo/app\nproc main() -> i32 {\n  let\n  set value =\n  give\n}\n",
    opts
  )
  let unknown_proc_like: compiler.CompileReport = compiler.compile_source(
    "unknown-proc-like.vit",
    "space demo/app\nprocmain\n",
    opts
  )
  if missing_space.success { give false }
  if diagnostics.count(missing_space.diagnostics) != 1 { give false }
  if not _diag_has(missing_space, 0, "error[E1000]: missing space declaration\n  --> missing-space.vit:1:1") { give false }
  if missing_space.emitted_source != "" { give false }
  if invalid_proc.success { give false }
  if diagnostics.count(invalid_proc.diagnostics) != 1 { give false }
  if not _diag_has(invalid_proc, 0, "error[E1002]: missing proc parameter list\n  --> invalid-proc.vit:2:1") { give false }
  if invalid_proc.emitted_source != "" { give false }
  if missing_proc_name.success { give false }
  if diagnostics.count(missing_proc_name.diagnostics) != 1 { give false }
  if not _diag_has(missing_proc_name, 0, "error[E1002]: missing proc name\n  --> missing-proc-name.vit:2:1") { give false }
  if missing_proc_name.emitted_source != "" { give false }
  if invalid_proc_params.success { give false }
  if diagnostics.count(invalid_proc_params.diagnostics) != 1 { give false }
  if not _diag_has(invalid_proc_params, 0, "error[E1002]: invalid proc parameter list\n  --> invalid-proc-params.vit:2:1") { give false }
  if invalid_proc_params.emitted_source != "" { give false }
  if invalid_proc_return.success { give false }
  if diagnostics.count(invalid_proc_return.diagnostics) != 1 { give false }
  if not _diag_has(invalid_proc_return, 0, "error[E1002]: invalid proc return type\n  --> invalid-proc-return.vit:2:1") { give false }
  if invalid_proc_return.emitted_source != "" { give false }
  if unterminated_proc.success { give false }
  if diagnostics.count(unterminated_proc.diagnostics) != 1 { give false }
  if not _diag_has(unterminated_proc, 0, "error[E1004]: proc body is not closed starting\n  --> unterminated-proc.vit:2:1") { give false }
  if unterminated_proc.emitted_source != "" { give false }
  if invalid_statement.success { give false }
  if diagnostics.count(invalid_statement.diagnostics) != 3 { give false }
  if not _diag_has(invalid_statement, 0, "error[E1006]: let statement requires a binding name\n  --> invalid-statement.vit:2:1") { give false }
  if not _diag_has(invalid_statement, 1, "error[E1007]: set statement requires an assignment target\n  --> invalid-statement.vit:3:1") { give false }
  if not _diag_has(invalid_statement, 2, "error[E1005]: give statement requires an expression\n  --> invalid-statement.vit:4:1") { give false }
  if invalid_statement.emitted_source != "" { give false }
  if unknown_proc_like.success { give false }
  if diagnostics.count(unknown_proc_like.diagnostics) != 2 { give false }
  if not _diag_has(unknown_proc_like, 0, "warning[W1001]: unparsed top-level line kept as unknown declaration\n  --> unknown-proc-like.vit:2:1") { give false }
  if not _diag_has(unknown_proc_like, 1, "error[E1003]: missing proc declaration\n  --> unknown-proc-like.vit:1:1") { give false }
  give true
}

proc smoke_ok() -> bool {
  if not compiler_root_ok() { give false }
  if not pipeline_lowering_ok() { give false }
  if not compiler_emit_ok() { give false }
  if not statement_lowering_ok() { give false }
  if not globals_only_emit_ok() { give false }
  if not backend_mir_adapter_ok() { give false }
  if not diagnostics_ok() { give false }
  give true
}

export *
