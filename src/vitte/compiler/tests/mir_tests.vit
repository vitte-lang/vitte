      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [],
      ty: "unit",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let block0: MirBlock = MirBlock { id: 1, label: "bb0", predecessors: [], statements: [nop_stmt], terminator: mir_terminator_return(), sealed: true, reachable: true, valid: true };
  let block1: MirBlock = MirBlock { id: 2, label: "dead", predecessors: [], statements: [], terminator: mir_terminator_return(), sealed: true, reachable: false, valid: true };
  let before: MirFunction = MirFunction { id: 1, name: "main", entry_block: 1, params: [], return_type: "unit", local_count: 0, temporary_count: 0, blocks: [block0, block1], valid: true };
  let after: MirFunction = optimize_function(before);
  let report: MirTransformReport = transform_report_for(before, after);
  give mir_transform_selftest()
    and after.valid
    and len(after.blocks) == 1
    and len(after.blocks[0].statements) == 0
    and report.changed
    and report.stats.removed_blocks == 1
    and report.stats.removed_statements == 1
    and transform_kind_name(MirTransformKind.SimplifyCfg) == "simplify-cfg"
    and transform_result_name(MirTransformResultKind.Changed) == "changed"
    and find(report_summary(report), "removed-blocks 1") >= 0;
}

proc test_mir_pretty_helpers_are_covered() -> bool {
  let stmt: MirStatement = MirStatement {
    id: 33,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "x", projection: ".field", deref_depth: 1, mutable: true, moved: false, valid: true },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Use,
      text: "x",
      operator: "",
      binary_operator: 0 as MirBinaryOperator,
      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [named_operand("x", "int")],
      ty: "int",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let fn0: MirFunction = minimal_valid_function("main", [], stmt);
  let unit0: MirUnit = unit_with_functions("pretty_surface.vit", [fn0]);
  let rendered_unit: string = pretty_unit(unit0);
  let rendered_fn: string = pretty_function(fn0, 0);
  give mir_pretty_selftest()
    and find(rendered_unit, "source: pretty_surface.vit") >= 0
    and find(rendered_unit, "module manual") >= 0
    and find(rendered_fn, "fn main -> int") >= 0
    and find(rendered_fn, "bb1") >= 0
    and find(rendered_fn, "assign") >= 0;
}

proc test_mir_pass_manager_validates_each_boundary() -> bool {
  let nop: MirStatement = MirStatement {
    id: 40,
    span: ast_span_empty(),
    kind: MirStatementKind.Nop,
    place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false },
    rvalue: MirRvalue { kind: MirRvalueKind.Use, text: "", operands: [], ty: "unit", temporary: false, valid: true },
    reachable: true,
    valid: true
  };
  let fn0: MirFunction = minimal_valid_function("main", [], nop);
  let unit0: MirUnit = unit_with_functions("mir_pass_validation.vit", [fn0]);
  let result: PassRunResult = run_passes(unit0);
  let invalid: MirUnit = MirUnit {
    source_path: unit0.source_path,
    module: unit0.module,
    function_count: unit0.function_count,
    block_count: 0,
    instruction_count: unit0.instruction_count,
    lowered: unit0.lowered,
    valid: unit0.valid
  };
  let rejected: PassRunResult = run_passes(invalid);

  give result.valid
    and result.completed_passes == 2
    and len(result.validations) == 4
    and result.validations[0].phase == PassValidationPhase.Before
    and result.validations[0].valid
    and result.validations[1].phase == PassValidationPhase.After and result.validations[1].valid
    and result.validations[2].phase == PassValidationPhase.Before and result.validations[2].valid
    and result.validations[3].phase == PassValidationPhase.After and result.validations[3].valid
    and result.mir.instruction_count == 0
    and not rejected.valid
    and rejected.completed_passes == 0
    and len(rejected.validations) == 1
    and rejected.validations[0].reason == "invalid-module";
}

proc binary_constant_statement(id: u64, left: string, right: string, ty: string, operator: MirBinaryOperator) -> MirStatement {
  give MirStatement {
    id: id,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "result", projection: "", deref_depth: 0, mutable: true, moved: false, valid: true },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Binary,
      text: left + " op " + right,
      operator: "binary",
      binary_operator: operator,
      operands: [
        MirOperand { text: left, place: MirPlace { valid: false }, ty: ty, constant: true, move: false, valid: true },
        MirOperand { text: right, place: MirPlace { valid: false }, ty: ty, constant: true, move: false, valid: true }
      ],
      ty: ty,
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
}

proc test_mir_constant_folding_is_typed_and_checked() -> bool {
  let foldable: MirUnit = unit_with_functions(
    "mir_fold_constants.vit",
    [minimal_valid_function("main", [], binary_constant_statement(50, "6", "7", "i32", MirBinaryOperator.Mul))]
  );
  let folded: PassRunResult = run_passes(foldable);
  let folded_rvalue: MirRvalue = folded.mir.module.functions[0].blocks[0].statements[0].rvalue;
  let overflow: MirUnit = unit_with_functions(
    "mir_fold_overflow.vit",
    [minimal_valid_function("main", [], binary_constant_statement(51, "127", "1", "i8", MirBinaryOperator.Add))]
  );
  let overflow_result: PassRunResult = run_passes(overflow);
  let overflow_rvalue: MirRvalue = overflow_result.mir.module.functions[0].blocks[0].statements[0].rvalue;
  let division_zero: MirUnit = unit_with_functions(
    "mir_fold_div_zero.vit",
    [minimal_valid_function("main", [], binary_constant_statement(52, "8", "0", "i32", MirBinaryOperator.Div))]
  );
  let division_result: PassRunResult = run_passes(division_zero);

  give folded.valid
    and folded_rvalue.kind == MirRvalueKind.Use
    and folded_rvalue.text == "42"
    and folded_rvalue.ty == "i32"
    and folded.stats[0].stats.folded_constants == 1
    and overflow_result.valid
    and overflow_rvalue.kind == MirRvalueKind.Binary
    and overflow_result.stats[0].stats.folded_constants == 0
    and division_result.valid
    and division_result.mir.module.functions[0].blocks[0].statements[0].rvalue.kind == MirRvalueKind.Binary;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_mir_lowering() {
    set failures = failures + 1;
  }
  if not test_mir_cfg_if_while() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_binary_and_unary_operators() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_projected_place() {
    set failures = failures + 1;
  }
  if not test_mir_lowers_struct_and_surface_items() {
    set failures = failures + 1;
  }
  if not test_mir_classifies_variant_ctor_and_method_dispatch_calls() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_proc_params_for_regular_functions() {
    set failures = failures + 1;
  }
  if not test_mir_accepts_borrow_passthrough_call_contract() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_and_validates_generic_instances() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_missing_generic_call_arguments() {
    set failures = failures + 1;
  }
  if not test_mir_monomorphizes_nested_generic_calls_once() {
    set failures = failures + 1;
  }
  if not test_mir_materializes_nested_generic_call_arguments() {
    set failures = failures + 1;
  }
  if not test_mir_materializes_calls_in_control_flow_conditions() {
    set failures = failures + 1;
  }
  if not test_mir_deduplicates_equal_instances_and_separates_types() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_duplicate_blocks_and_invalid_assign_place() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_unresolved_method_dispatch_target() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_invalid_param_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_duplicate_param_name_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_malformed_variant_ctor() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_method_dispatch_arity_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_regular_call_arity_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_regular_call_borrow_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_method_dispatch_param_type_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_borrow_with_wrong_arity() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_borrow_of_constant() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_invalid_borrow_operand() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_regular_call_param_type_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_empty_goto_block() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_return_terminator_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_invalid_entry_block() {
    set failures = failures + 1;
  }
  if not test_mir_builder_helpers_are_covered() {
    set failures = failures + 1;
  }
  if not test_mir_dataflow_helpers_are_covered() {
    set failures = failures + 1;
  }
  if not test_mir_transform_helpers_are_covered() {
    set failures = failures + 1;
  }
  if not test_mir_pretty_helpers_are_covered() {
    set failures = failures + 1;
  }
  if not test_mir_pass_manager_validates_each_boundary() {
    set failures = failures + 1;
  }
  if not test_mir_constant_folding_is_typed_and_checked() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
