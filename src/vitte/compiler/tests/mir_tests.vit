proc test_validate_mir_rejects_method_dispatch_param_type_mismatch() -> bool {
  let bad_stmt: MirStatement = MirStatement {
    id: 20,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "shown", projection: "", deref_depth: 0, mutable: false, moved: false, valid: true },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Call,
      text: "vitte_impl_Show_for_Point_show",
      operator: "method-dispatch",
      binary_operator: 0 as MirBinaryOperator,
      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [named_operand("point", "Point"), named_operand("flag", "bool")],
      ty: "string",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let main_fn: MirFunction = minimal_valid_function("main", [], bad_stmt);
  let impl_fn: MirFunction = minimal_valid_function(
    "vitte_impl_Show_for_Point_show",
    [
      MirFunctionParam { name: "self", type_name: "Point", mode: "", mutable: false, borrowed: false, variadic: false, valid: true },
      MirFunctionParam { name: "level", type_name: "int", mode: "", mutable: false, borrowed: false, variadic: false, valid: true }
    ],
    MirStatement {
      id: 21,
      span: ast_span_empty(),
      kind: MirStatementKind.Return,
      place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false },
      rvalue: MirRvalue {
        kind: MirRvalueKind.Use,
        text: "\"point\"",
        operator: "",
        binary_operator: 0 as MirBinaryOperator,
        unary_operator: 0 as MirUnaryOperator,
        borrow_kind: 0 as MirBorrowKind,
        operands: [MirOperand { text: "\"point\"", place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false }, ty: "string", constant: true, move: false, valid: true }],
        ty: "string",
        temporary: false,
        valid: true
      },
      reachable: true,
      valid: true
    }
  );
  let bad: MirUnit = unit_with_functions("manual_bad_dispatch_type_mir.vit", [main_fn, impl_fn]);
  give not validate_mir(bad).valid and mir_validation_reason(bad) == "invalid-method-dispatch-param-type";
}

proc test_validate_mir_rejects_borrow_with_wrong_arity() -> bool {
  let bad_stmt: MirStatement = MirStatement {
    id: 15,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "r", projection: "", deref_depth: 0, mutable: false, moved: false, valid: true },
    rvalue: MirRvalue {
      kind: MirRvalueKind.BorrowShared,
      text: "&x",
      operator: "",
      binary_operator: 0 as MirBinaryOperator,
      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [],
      ty: "int",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let bad: MirUnit = unit_with_functions("manual_bad_borrow_arity_mir.vit", [minimal_valid_function("main", [], bad_stmt)]);
  give not validate_mir(bad).valid and mir_validation_reason(bad) == "invalid-borrow-arity";
}

proc test_validate_mir_rejects_borrow_of_constant() -> bool {
  let bad_stmt: MirStatement = MirStatement {
    id: 16,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "r", projection: "", deref_depth: 0, mutable: false, moved: false, valid: true },
    rvalue: MirRvalue {
      kind: MirRvalueKind.BorrowMut,
      text: "&mut 1",
      operator: "",
      binary_operator: 0 as MirBinaryOperator,
      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [int_constant_operand("1")],
      ty: "int",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let bad: MirUnit = unit_with_functions("manual_bad_borrow_target_mir.vit", [minimal_valid_function("main", [], bad_stmt)]);
  give not validate_mir(bad).valid and mir_validation_reason(bad) == "invalid-borrow-target";
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_mir_lowering() {
    set failures = failures + 1;
  }
  if not test_mir_cfg_if_while() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_projected_place() {
    set failures = failures + 1;
  }
  if not test_mir_lowers_struct_and_surface_items() {
    set failures = failures + 1;
  }
  if not test_mir_classifies_variant_ctor_and_method_dispatch_calls() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_proc_params_for_regular_functions() {
    set failures = failures + 1;
  }
  if not test_mir_accepts_borrow_passthrough_call_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_duplicate_blocks_and_invalid_assign_place() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_unresolved_method_dispatch_target() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_invalid_param_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_duplicate_param_name_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_malformed_variant_ctor() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_method_dispatch_arity_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_regular_call_arity_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_regular_call_borrow_contract() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_method_dispatch_param_type_mismatch() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_borrow_with_wrong_arity() {
    set failures = failures + 1;
  }
  if not test_validate_mir_rejects_borrow_of_constant() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
