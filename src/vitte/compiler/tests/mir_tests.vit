proc test_mir_builder_helpers_are_covered() -> bool {
  let ctx0 = mir_builder_context("builder_surface.vit");
  let ctx1 = enter_function(ctx0, "main");
  let ctx2 = allocate_block(ctx1, "then");
  let ctx3 = allocate_value(ctx2, MirBuilderValueKind.Temporary, "int");
  let ctx4 = increment_statement_count(ctx3);
  let ctx5 = mark_terminated(ctx4);
  let summary: string = builder_summary(ctx5);
  give mir_builder_selftest()
    and builder_phase_name(MirBuilderPhase.Function) == "function"
    and builder_value_kind_name(MirBuilderValueKind.Temporary) == "temporary"
    and ctx5.current_function == "main"
    and len(ctx5.blocks) == 2
    and len(ctx5.values) == 1
    and ctx5.statement_count == 1
    and ctx5.terminator_count == 1
    and find(summary, "phase=function") >= 0
    and find(summary, "blocks=2") >= 0;
}

proc test_mir_dataflow_helpers_are_covered() -> bool {
  let stmt: MirStatement = MirStatement {
    id: 31,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "x", projection: "", deref_depth: 0, mutable: false, moved: false, valid: true },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Use,
      text: "1",
      operator: "",
      binary_operator: 0 as MirBinaryOperator,
      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [int_constant_operand("1")],
      ty: "int",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let fn0: MirFunction = minimal_valid_function("main", [], stmt);
  let result: DataflowResult = analyze_function(fn0, DataflowDirection.Forward);
  let summary: DataflowSummary = build_summary(result);
  give dataflow_selftest()
    and result.valid
    and result.converged
    and len(result.blocks) == 1
    and summary.block_count == 1
    and summary.fact_count >= 2
    and direction_name(DataflowDirection.Forward) == "forward"
    and state_name(DataflowStateKind.Initialized) == "initialized"
    and fact_kind_name(DataflowFactKind.Definition) == "definition"
    and find(summary_string(summary), "facts=") >= 0;
}

proc test_mir_transform_helpers_are_covered() -> bool {
  let nop_stmt: MirStatement = MirStatement {
    id: 32,
    span: ast_span_empty(),
    kind: MirStatementKind.Nop,
    place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Use,
      text: "",
      operator: "",
