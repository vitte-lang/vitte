use vitte/compiler/middle/mir/builder.{ MirBuilderPhase, MirBuilderValueKind, allocate_block, allocate_value, builder_phase_name, builder_summary, builder_value_kind_name, enter_function, increment_statement_count, mark_terminated, mir_builder_context, mir_builder_selftest }
use vitte/compiler/middle/mir/dataflow.{ DataflowDirection, DataflowFactKind, DataflowResult, DataflowSummary, DataflowStateKind, analyze_function, build_summary, dataflow_selftest, direction_name, fact_kind_name, state_name, summary_string }
use vitte/compiler/middle/mir/pretty.{ mir_pretty_selftest, pretty_function, pretty_unit }
use vitte/compiler/middle/mir/transform.{ MirTransformKind, MirTransformReport, MirTransformResultKind, mir_transform_selftest, optimize_function, report_summary, transform_kind_name, transform_report_for, transform_result_name }
use vitte/compiler/middle/mir/validate.{ mir_validation_reason, validate_mir }
use vitte/compiler/middle/passes/pass_manager.{ run_passes }
use vitte/compiler/middle/passes/pass_result.{ PassRunResult, PassValidationPhase }
use vitte/compiler/middle/lower/hir_to_mir.{ lower_hir_to_mir_templates, mir_binary_operator_from_text, mir_binary_operator_supported, mir_unary_operator_from_text, mir_unary_operator_supported }
use vitte/compiler/middle/pipeline.{ MiddleOutput, middle_run }

const VERSION_TEXT: string = "middle mir tests 0.2.0"
const BANNER_TEXT: string = "middle mir tests"

proc int_constant_operand(text: string) -> MirOperand {
  give MirOperand { text: text, place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false }, ty: "int", constant: true, move: false, valid: true };
}

proc named_operand(name: string, ty: string) -> MirOperand {
  give MirOperand { text: name, place: MirPlace { local: name, projection: "", deref_depth: 0, mutable: false, moved: false, valid: true }, ty: ty, constant: false, move: false, valid: true };
}

proc minimal_valid_function(name: string, params: [MirFunctionParam], stmt: MirStatement) -> MirFunction {
  let block0 = MirBlock { id: 1, label: "bb0", predecessors: [], statements: [stmt], terminator: mir_terminator_return(), sealed: true, reachable: true, valid: true };
  give MirFunction { id: 1, name: name, entry_block: 1, params: params, return_type: "int", local_count: 1, temporary_count: 0, blocks: [block0], valid: true };
}

proc unit_with_functions(path: string, functions: [MirFunction]) -> MirUnit {
  give MirUnit {
    source_path: path,
    module: MirModule { name: "manual", functions: functions, valid: true },
    function_count: len(functions),
    block_count: 1,
    instruction_count: 1,
    lowered: true,
    valid: true
  };
}

proc test_mir_lowering() -> bool {
  let source: string = "proc main() { let x = 1; set x = x + 1; give x; }\n";
  let fe: FrontendOutput = frontend_run("mir_test.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir = middle.mir;
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }
  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) != 4 {
    give false;
  }
  let block = fn0.blocks[0];
  if fn0.entry_block != block.id {
    give false;
  }
  if block.statements[0].place.local != "x" {
    give false;
  }
  give fn0.blocks[2].statements[0].kind == MirStatementKind.Return and fn0.blocks[2].terminator.kind == MirTerminatorKind.Return;
}

proc test_mir_cfg_if_while() -> bool {
  let source: string = "proc main() { let x = 1; if x { set x = x + 1; } else { set x = x + 2; } while x { set x = x - 1; } give x; }\n";
  let fe: FrontendOutput = frontend_run("mir_cfg_test.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir = middle.mir;
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }

  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) < 7 {
    give false;
  }

  let branch_count: u64 = 0;
  let goto_count: u64 = 0;
  let i: u64 = 0;
  while i < len(fn0.blocks) {
    let term = fn0.blocks[i].terminator;
    if term.kind == MirTerminatorKind.Branch {
      set branch_count = branch_count + 1;
      if not term.condition.valid or term.target_block == 0 or term.else_block == 0 {
        give false;
      }
    } elif term.kind == MirTerminatorKind.Goto {
      set goto_count = goto_count + 1;
      if term.target_block == 0 {
        give false;
      }
    }
    set i = i + 1;
  }

  give branch_count >= 2 and goto_count >= 2;
}

proc test_mir_preserves_binary_and_unary_operators() -> bool {
  let source: string =
    "proc main() { let value = 3; let product = value * 7; let difference = value - 3; " +
    "let negative = -value; let inverted = not false; give 0; }\n";
  let fe: FrontendOutput = frontend_run("mir_operators.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  if not middle.valid or len(middle.mir.module.functions) == 0 {
    give false;
  }
  let product_seen: bool = false;
  let difference_seen: bool = false;
  let negative_seen: bool = false;
  let inverted_seen: bool = false;
  let i: u64 = 0;
  while i < len(middle.mir.module.functions[0].blocks) {
    let j: u64 = 0;
    while j < len(middle.mir.module.functions[0].blocks[i].statements) {
      let rvalue: MirRvalue = middle.mir.module.functions[0].blocks[i].statements[j].rvalue;
      if rvalue.operator == "*" {
        set product_seen = rvalue.kind == MirRvalueKind.Binary and rvalue.binary_operator == MirBinaryOperator.Mul;
      } elif rvalue.operator == "-" and rvalue.kind == MirRvalueKind.Binary {
        set difference_seen = rvalue.binary_operator == MirBinaryOperator.Sub;
      } elif rvalue.operator == "-" and rvalue.kind == MirRvalueKind.Unary {
        set negative_seen = rvalue.unary_operator == MirUnaryOperator.Neg;
      } elif rvalue.operator == "not" {
        set inverted_seen = rvalue.kind == MirRvalueKind.Unary and rvalue.unary_operator == MirUnaryOperator.Not;
      }
      set j = j + 1;
    }
    set i = i + 1;
  }

  give middle.valid
    and product_seen and difference_seen and negative_seen and inverted_seen
    and mir_binary_operator_from_text("+") == MirBinaryOperator.Add
    and mir_binary_operator_from_text("/") == MirBinaryOperator.Div
    and mir_binary_operator_from_text("%") == MirBinaryOperator.Rem
    and mir_binary_operator_from_text("==") == MirBinaryOperator.Eq
    and mir_binary_operator_from_text("!=") == MirBinaryOperator.Ne
    and mir_binary_operator_from_text("<") == MirBinaryOperator.Lt
    and mir_binary_operator_from_text("<=") == MirBinaryOperator.Le
    and mir_binary_operator_from_text(">") == MirBinaryOperator.Gt
    and mir_binary_operator_from_text(">=") == MirBinaryOperator.Ge
    and mir_binary_operator_from_text("&") == MirBinaryOperator.BitAnd
    and mir_binary_operator_from_text("|") == MirBinaryOperator.BitOr
    and mir_binary_operator_from_text("^") == MirBinaryOperator.BitXor
    and mir_binary_operator_from_text("<<") == MirBinaryOperator.ShiftLeft
    and mir_binary_operator_from_text(">>") == MirBinaryOperator.ShiftRight
    and mir_binary_operator_from_text("and") == MirBinaryOperator.And
    and mir_binary_operator_from_text("||") == MirBinaryOperator.Or
    and mir_unary_operator_from_text("*") == MirUnaryOperator.Deref
    and mir_binary_operator_supported("or")
    and not mir_binary_operator_supported("??")
    and mir_unary_operator_supported("!")
    and not mir_unary_operator_supported("~");
}

proc test_mir_preserves_projected_place() -> bool {
  let source: string = "proc main() { set x.field = x.field; give x.field; }\n";
  let fe: FrontendOutput = frontend_run("mir_projection_test.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir = middle.mir;
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }
  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) == 0 or len(fn0.blocks[0].statements) == 0 {
    give false;
  }
  let stmt0 = fn0.blocks[0].statements[0];
  give stmt0.place.local == "x" and stmt0.place.projection == "field";
}

proc test_mir_lowers_struct_and_surface_items() -> bool {
  let source: string =
    "form Point { x: int, y: int }\n" +
    "bits Mode: u8 {\n" +
    "  read: 0 .. 1,\n" +
    "}\n" +
    "pick Option[T] {\n" +
    "  None,\n" +
    "  Some(T),\n" +
    "}\n" +
    "flags Access: u8 {\n" +
    "  read = 1,\n" +
    "}\n" +
    "trait Show {\n" +
    "  proc show(self: Self) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self) -> string { give \"point\"; }\n" +
    "}\n" +
    "proc main() -> int { let point = Point { x: 1, y: 2 }; give 0; }\n";
  let fe: FrontendOutput = frontend_run("mir_surface_items.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir = middle.mir;
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }
  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) == 0 or len(fn0.blocks[0].statements) == 0 {
    give false;
  }
  let stmt0 = fn0.blocks[0].statements[0];
  let stmt1 = fn0.blocks[1].statements[0];
  give stmt0.place.local == "point"
    and stmt0.rvalue.kind == MirRvalueKind.Struct
    and stmt0.rvalue.ty == "Point"
    and len(stmt0.rvalue.operands) >= 3
    and stmt1.rvalue.ty == "int"
    and stmt1.rvalue.operands[0].ty == "Point"
    and fn0.entry_block == fn0.blocks[0].id;
}

proc test_mir_classifies_variant_ctor_and_method_dispatch_calls() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "pick Option {\n" +
    "  None,\n" +
    "  Some(int),\n" +
    "}\n" +
    "trait Show {\n" +
    "  proc show(self: Self, level: int) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self, level: int) -> string { give \"point\"; }\n" +
    "}\n" +
    "proc main() { let point = Point { x: 1 }; let opt = Option.Some(7); let shown = point.show(7); give shown; }\n";
  let fe: FrontendOutput = frontend_run("mir_nominal_calls.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir = middle.mir;
  if not mir.valid or len(mir.module.functions) < 2 or len(mir.module.functions[0].blocks) < 3 {
    give false;
  }
  let fn0 = mir.module.functions[0];
  let impl_fn = mir.module.functions[1];
  let variant_stmt = fn0.blocks[1].statements[0];
  let dispatch_stmt = fn0.blocks[2].statements[0];
  give variant_stmt.rvalue.kind == MirRvalueKind.Call
    and variant_stmt.rvalue.operator == "variant-ctor"
    and variant_stmt.rvalue.text == "Option::Some"
    and len(variant_stmt.rvalue.operands) == 1
    and dispatch_stmt.rvalue.kind == MirRvalueKind.Call
    and dispatch_stmt.rvalue.operator == "method-dispatch"
    and dispatch_stmt.rvalue.text == "vitte_impl_Show_for_Point_show"
    and len(dispatch_stmt.rvalue.operands) == 2
    and impl_fn.name == "vitte_impl_Show_for_Point_show"
    and len(impl_fn.params) == 2
    and impl_fn.params[0].type_name == "Point"
    and impl_fn.params[1].type_name == "int"
    and impl_fn.return_type == "string";
}

proc test_mir_preserves_proc_params_for_regular_functions() -> bool {
  let source: string = "proc add(borrow value: int, mut flag: bool, ...) -> int { if flag { give value; } give 0; }\n";
  let fe: FrontendOutput = frontend_run("mir_proc_params.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir = middle.mir;
  let fn0 = mir.module.functions[0];
  give mir.valid
    and fn0.name == "add"
    and len(fn0.params) == 3
    and fn0.params[0].name == "value"
    and fn0.params[0].type_name == "int"
    and fn0.params[0].mode == "borrow"
    and fn0.params[0].borrowed
    and fn0.params[1].name == "flag"
    and fn0.params[1].type_name == "bool"
    and fn0.params[1].mode == "mut"
    and fn0.params[1].mutable
    and fn0.params[2].variadic
    and fn0.return_type == "int";
}

proc test_mir_accepts_borrow_passthrough_call_contract() -> bool {
  let source: string =
    "proc keep(borrow value: int) -> int { give value; }\n" +
    "proc main() -> int { let value = 1; give keep(value); }\n";
  let fe: FrontendOutput = frontend_run("mir_borrow_passthrough.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir: MirUnit = middle.mir;
  give mir.valid and len(mir.module.functions) == 2 and validate_mir(mir).valid;
}

proc test_mir_preserves_and_validates_generic_instances() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc main() -> int { let value = identity(7); give value; }\n";
  let fe: FrontendOutput = frontend_run("mir_generic_instance.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let templates: MirUnit = lower_hir_to_mir_templates(middle.typed_hir);
  let mir: MirUnit = middle.mir;
  if not templates.valid or not mir.valid or len(templates.module.functions) != 2 or len(mir.module.functions) != 2 {
    give false;
  }
  let generic_template: MirFunction = templates.module.functions[0];
  let template_main: MirFunction = templates.module.functions[1];
  let template_call: MirRvalue = template_main.blocks[0].statements[0].rvalue;
  let concrete_main: MirFunction = mir.module.functions[0];
  let concrete_fn: MirFunction = mir.module.functions[1];
  let concrete_call: MirRvalue = concrete_main.blocks[0].statements[0].rvalue;
  give middle.valid
    and len(generic_template.generic_params) == 1
    and generic_template.generic_params[0] == "T"
    and template_call.kind == MirRvalueKind.Call
    and len(template_call.generic_arguments) == 1
    and template_call.generic_arguments[0] == "int"
    and concrete_fn.name == "vitte_mono_identity__3_int"
    and len(concrete_fn.generic_params) == 0
    and concrete_fn.params[0].type_name == "int"
    and concrete_fn.return_type == "int"
    and concrete_call.text == concrete_fn.name
    and concrete_call.operator == "monomorphized"
    and len(concrete_call.generic_arguments) == 0
    and concrete_call.operands[0].place.local == concrete_fn.name
    and validate_mir(mir).valid
    and find(pretty_function(generic_template, 0), "identity[T]") >= 0;
}

proc test_validate_mir_rejects_missing_generic_call_arguments() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc main() -> int { let value = identity(7); give value; }\n";
  let fe: FrontendOutput = frontend_run("mir_generic_arity_invalid.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let bad: MirUnit = lower_hir_to_mir_templates(middle.typed_hir);
  if not bad.valid or len(bad.module.functions) != 2 {
    give false;
  }
  set bad.module.functions[1].blocks[0].statements[0].rvalue.generic_arguments = [];
  give not validate_mir(bad).valid
    and mir_validation_reason(bad) == "invalid-regular-call-generic-arity";
}

proc test_mir_monomorphizes_nested_generic_calls_once() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc twice[T](value: T) -> T { give identity(value); }\n" +
    "proc main() -> int { let first = twice(7); let second = twice(9); give first; }\n";
  let fe: FrontendOutput = frontend_run("mir_nested_generic_instances.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir: MirUnit = middle.mir;
  if not middle.valid or not mir.valid or len(mir.module.functions) != 3 {
    give false;
  }
  let main_fn: MirFunction = mir.module.functions[0];
  let twice_fn: MirFunction = mir.module.functions[1];
  let identity_fn: MirFunction = mir.module.functions[2];
  let first_call: MirRvalue = main_fn.blocks[0].statements[0].rvalue;
  let second_call: MirRvalue = main_fn.blocks[1].statements[0].rvalue;
  let nested_call: MirRvalue = twice_fn.blocks[0].statements[0].rvalue;
  give twice_fn.name == "vitte_mono_twice__3_int"
    and identity_fn.name == "vitte_mono_identity__3_int"
    and first_call.text == twice_fn.name
    and second_call.text == twice_fn.name
    and nested_call.text == identity_fn.name
    and twice_fn.params[0].type_name == "int"
    and twice_fn.return_type == "int"
    and identity_fn.params[0].type_name == "int"
    and identity_fn.return_type == "int"
    and validate_mir(mir).valid;
}

proc test_mir_materializes_nested_generic_call_arguments() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc add(left: int, right: int) -> int { give left + right; }\n" +
    "proc main() -> int { give add(identity(1), identity(2)); }\n";
  let fe: FrontendOutput = frontend_run("mir_nested_generic_arguments.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let templates: MirUnit = lower_hir_to_mir_templates(middle.typed_hir);
  let mir: MirUnit = middle.mir;
  if not middle.valid or not templates.valid or not mir.valid or len(templates.module.functions) != 3 or len(mir.module.functions) != 3 {
    give false;
  }
  let template_main: MirFunction = templates.module.functions[2];
  if len(template_main.blocks) == 0 or len(template_main.blocks[0].statements) != 3 {
    give false;
  }
  let first: MirStatement = template_main.blocks[0].statements[0];
  let second: MirStatement = template_main.blocks[0].statements[1];
  let outer: MirStatement = template_main.blocks[0].statements[2];
  let concrete_main: MirFunction = mir.module.functions[1];
  let identity_fn: MirFunction = mir.module.functions[2];
  give first.rvalue.kind == MirRvalueKind.Call
    and second.rvalue.kind == MirRvalueKind.Call
    and first.rvalue.temporary
    and second.rvalue.temporary
    and starts_with(first.place.local, "__mir_tmp_")
    and starts_with(second.place.local, "__mir_tmp_")
    and first.place.local != second.place.local
    and outer.rvalue.kind == MirRvalueKind.Call
    and outer.kind == MirStatementKind.Return
    and len(outer.rvalue.operands) == 3
    and outer.rvalue.operands[1].place.local == first.place.local
    and outer.rvalue.operands[2].place.local == second.place.local
    and template_main.temporary_count == 2
    and templates.instruction_count == 5
    and concrete_main.blocks[0].statements[0].rvalue.text == identity_fn.name
    and concrete_main.blocks[0].statements[1].rvalue.text == identity_fn.name
    and concrete_main.blocks[0].statements[2].rvalue.text == "add"
    and validate_mir(templates).valid
    and validate_mir(mir).valid;
}

proc test_mir_materializes_calls_in_control_flow_conditions() -> bool {
  let source: string =
    "proc positive(value: int) -> bool { give value > 0; }\n" +
    "proc main() -> int { let value = 1; if positive(value) { give value; } give 0; }\n";
  let fe: FrontendOutput = frontend_run("mir_call_condition.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir: MirUnit = middle.mir;
  if not middle.valid or not mir.valid or len(mir.module.functions) != 2 {
    give false;
  }
  let main_fn: MirFunction = mir.module.functions[1];
  let i: u64 = 0;
  while i < len(main_fn.blocks) {
    if main_fn.blocks[i].terminator.kind == MirTerminatorKind.Branch {
      give len(main_fn.blocks[i].statements) == 1
        and main_fn.blocks[i].statements[0].rvalue.kind == MirRvalueKind.Call
        and main_fn.blocks[i].statements[0].rvalue.temporary
        and main_fn.blocks[i].terminator.condition.place.local == main_fn.blocks[i].statements[0].place.local
        and main_fn.temporary_count == 1
        and validate_mir(mir).valid;
    }
    set i = i + 1;
  }
  give false;
}

proc test_mir_deduplicates_equal_instances_and_separates_types() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc main() -> int { let first = identity(7); let second = identity(9); let text = identity<string>(\"value\"); give first; }\n";
  let fe: FrontendOutput = frontend_run("mir_generic_instance_dedup.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  let mir: MirUnit = middle.mir;
  if not middle.valid or not mir.valid or len(mir.module.functions) != 3 {
    give false;
  }
  let main_fn: MirFunction = mir.module.functions[0];
  let int_fn: MirFunction = mir.module.functions[1];
  let string_fn: MirFunction = mir.module.functions[2];
  give int_fn.name == "vitte_mono_identity__3_int"
    and int_fn.params[0].type_name == "int"
    and string_fn.name == "vitte_mono_identity__6_string"
    and string_fn.params[0].type_name == "string"
    and main_fn.blocks[0].statements[0].rvalue.text == int_fn.name
    and main_fn.blocks[1].statements[0].rvalue.text == int_fn.name
    and main_fn.blocks[2].statements[0].rvalue.text == string_fn.name
    and validate_mir(mir).valid;
}

proc test_validate_mir_rejects_duplicate_blocks_and_invalid_assign_place() -> bool {
  let bad_stmt: MirStatement = MirStatement {
    id: 1,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
    place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false },
    rvalue: MirRvalue {
      kind: MirRvalueKind.Use,
      text: "1",
      operator: "",
      binary_operator: 0 as MirBinaryOperator,
      unary_operator: 0 as MirUnaryOperator,
      borrow_kind: 0 as MirBorrowKind,
      operands: [MirOperand { text: "1", place: MirPlace { local: "", projection: "", deref_depth: 0, mutable: false, moved: false, valid: false }, ty: "int", constant: true, move: false, valid: true }],
      ty: "int",
      temporary: false,
      valid: true
    },
    reachable: true,
    valid: true
  };
  let block0 = MirBlock { id: 1, label: "bb0", predecessors: [], statements: [bad_stmt], terminator: mir_terminator_return(), sealed: true, reachable: true, valid: true };
  let block1 = MirBlock { id: 1, label: "bb1", predecessors: [], statements: [], terminator: mir_terminator_return(), sealed: true, reachable: true, valid: true };
  let bad: MirUnit = MirUnit {
    source_path: "manual_bad_mir.vit",
    module: MirModule {
      name: "manual",
      functions: [MirFunction { id: 1, name: "main", entry_block: 1, params: [], return_type: "int", local_count: 1, temporary_count: 0, blocks: [block0, block1], valid: true }],
      valid: true
    },
    function_count: 1,
    block_count: 2,
    instruction_count: 1,
    lowered: true,
    valid: true
  };
  give not validate_mir(bad).valid and mir_validation_reason(bad) == "duplicate-block-id";
}

proc test_validate_mir_rejects_unresolved_method_dispatch_target() -> bool {
  let bad_stmt: MirStatement = MirStatement {
    id: 7,
    span: ast_span_empty(),
    kind: MirStatementKind.Assign,
