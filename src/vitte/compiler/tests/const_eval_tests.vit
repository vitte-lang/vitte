space vitte/compiler/tests/const_eval_tests

use vitte/compiler/analysis/const_eval.{ ConstEvalRunResult, run_const_eval, run_const_eval_ast }
use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }

const VERSION_TEXT: string = "analysis const_eval tests 0.2.0"
const BANNER_TEXT: string = "analysis const_eval tests"

proc has_code(result: ConstEvalRunResult, code: string) -> bool {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc test_valid_arithmetic_chain() -> bool {
  let source: string = "const A = 2;\nconst B = A + 3;\nconst C = B * 4;\nstatic_assert(C == 20);\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_valid_chain.vit", source);
  give result.valid and len(result.bindings) == 3 and result.assert_count == 1;
}

proc test_division_by_zero() -> bool {
  let source: string = "const X = 8 / 0;\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_div_zero.vit", source);
  give has_code(result, "CONST_EVAL_E_DIVISION_BY_ZERO");
}

proc test_typed_integer_boundaries() -> bool {
  let source: string =
    "const I8_MIN: i8 = -128;\n" +
    "const I8_MAX: i8 = 127;\n" +
    "const U8_MAX: u8 = 255;\n" +
    "const I16_MIN: i16 = -32768;\n" +
    "const I16_MAX: i16 = 32767;\n" +
    "const U16_MAX: u16 = 65535;\n" +
    "const I32_MIN: i32 = -2147483648;\n" +
    "const I32_MAX: i32 = 2147483647;\n" +
    "const U32_MAX: u32 = 4294967295;\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_integer_boundaries.vit", source);
  give result.valid and len(result.bindings) == 9;
}

proc test_typed_integer_overflow() -> bool {
  let source: string = "const TOO_LARGE: u8 = 200 + 56;\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_u8_overflow.vit", source);
  give not result.valid and has_code(result, "CONST_EVAL_E_OVERFLOW");
}

proc test_typed_integer_underflow() -> bool {
  let source: string = "const NEGATIVE: u8 = -1;\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_u8_underflow.vit", source);
  give not result.valid and has_code(result, "CONST_EVAL_E_OVERFLOW");
}

proc test_ast_typed_integer_overflow() -> bool {
  let source: string = "const TOO_LARGE: i16 = 30000 + 2768;\n";
  let fe: FrontendOutput = frontend_run("const_eval_ast_i16_overflow.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_ast_i16_overflow.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_OVERFLOW");
}

proc test_ast_typed_integer_underflow() -> bool {
  let source: string = "const NEGATIVE: u8 = -1;\n";
  let fe: FrontendOutput = frontend_run("const_eval_ast_u8_underflow.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_ast_u8_underflow.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_OVERFLOW");
}

proc test_ast_signed_integer_minimum() -> bool {
  let source: string = "const MINIMUM: i8 = -128;\nstatic_assert(MINIMUM == -128);\n";
  let fe: FrontendOutput = frontend_run("const_eval_ast_i8_minimum.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_ast_i8_minimum.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 1 and result.assert_count == 1;
}

proc test_ast_invalid_unary_operand() -> bool {
  let source: string = "const BAD: bool = -true;\n";
  let fe: FrontendOutput = frontend_run("const_eval_ast_invalid_unary.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_ast_invalid_unary.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_UNSUPPORTED_EXPR");
}

proc test_ast_forbidden_const_reference() -> bool {
  let source: string = "const VALUE: int = 1;\nconst BAD: &int = &VALUE;\n";
  let fe: FrontendOutput = frontend_run("const_eval_ast_reference.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_ast_reference.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_UNSUPPORTED_EXPR");
}

proc test_unknown_name() -> bool {
  let source: string = "const X = Y + 1;\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_unknown_name.vit", source);
  give has_code(result, "CONST_EVAL_E_UNKNOWN_NAME");
}

proc test_non_const_call() -> bool {
  let source: string = "const X = make_value();\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_non_const_call.vit", source);
  give has_code(result, "CONST_EVAL_E_NON_CONST_CALL");
}

proc test_static_assert_failure() -> bool {
  let source: string = "const A = 1 + 1;\nstatic_assert(A == 3, \"bad math\");\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_assert_fail.vit", source);
  give has_code(result, "CONST_EVAL_E_STATIC_ASSERT_FAILED");
}

proc test_compile_time_simulation_detects_impossible_branch() -> bool {
  let source: string = "const READY = false;\nif READY { static_assert(true); }\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_impossible_branch.vit", source);
  give has_code(result, "CONST_EVAL_E_IMPOSSIBLE_BRANCH")
    and result.simulation_count == 1
    and result.impossible_branch_count == 1;
}

proc test_compile_time_simulation_accepts_reachable_constant_branch() -> bool {
  let source: string = "const READY = true;\nif READY { static_assert(true); }\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_reachable_branch.vit", source);
  give result.valid
    and result.simulation_count == 1
    and result.impossible_branch_count == 0;
}

proc test_cycle_detection() -> bool {
  let source: string = "const A = B + 1;\nconst B = A + 1;\n";
  let result: ConstEvalRunResult = run_const_eval("const_eval_cycle.vit", source);
  give has_code(result, "CONST_EVAL_E_CYCLE");
}

proc test_ast_const_eval_path() -> bool {
  let source: string = "const A = 2;\nconst B = A + 3;\nstatic_assert(B == 5);\n";
  let fe: FrontendOutput = frontend_run("const_eval_ast.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_ast.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 2 and result.assert_count == 1;
}

proc test_ast_const_procedure_call() -> bool {
  let source: string =
    "const proc add(left: int, right: int) -> int { give left + right; }\n" +
    "const ANSWER: int = add(20, 22);\n" +
    "static_assert(ANSWER == 42);\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_call.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_call.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 1 and result.assert_count == 1;
}

proc test_ast_nested_const_procedure_calls() -> bool {
  let source: string =
    "const proc double(value: int) -> int { give value + value; }\n" +
    "const proc answer() -> int { give double(21); }\n" +
    "const ANSWER: int = answer();\n";
  let fe: FrontendOutput = frontend_run("const_eval_nested_proc_call.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_nested_proc_call.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 1;
}

proc test_ast_const_procedure_unary_result() -> bool {
  let source: string =
    "const proc negate(value: int) -> int { give -value; }\n" +
    "const NEGATIVE: int = negate(7);\n" +
    "static_assert(NEGATIVE == -7);\n" +
    "static_assert(not false);\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_unary.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_unary.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 1 and result.assert_count == 2;
}

proc test_ast_const_procedure_arity_mismatch() -> bool {
  let source: string =
    "const proc identity(value: int) -> int { give value; }\n" +
    "const BAD: int = identity();\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_arity.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_arity.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_NON_CONST_CALL");
}

proc test_ast_const_procedure_local_binding() -> bool {
  let source: string =
    "const proc increment(value: int) -> int { let next: int = value + 1; give next; }\n" +
    "const ANSWER: int = increment(41);\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_local.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_local.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 1;
}

proc test_ast_non_const_procedure_call_is_rejected() -> bool {
  let source: string =
    "proc runtime_only() -> int { give 1; }\n" +
    "const BAD: int = runtime_only();\n";
  let fe: FrontendOutput = frontend_run("const_eval_runtime_proc.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_runtime_proc.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_NON_CONST_CALL");
}

proc test_ast_const_procedure_cycle() -> bool {
  let source: string =
    "const proc cycle(value: int) -> int { give cycle(value); }\n" +
    "const BAD: int = cycle(1);\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_cycle.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_cycle.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_CYCLE");
}

proc test_ast_recursive_const_procedure() -> bool {
  let source: string =
    "const proc factorial(value: int) -> int {\n" +
    "  if value <= 1 { give 1; }\n" +
    "  give value * factorial(value - 1);\n" +
    "}\n" +
    "const VALUE: int = factorial(5);\n" +
    "static_assert(VALUE == 120);\n";
  let fe: FrontendOutput = frontend_run("const_eval_recursive_proc.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_recursive_proc.vit", fe.ast_root);
  give fe.valid and result.valid and len(result.bindings) == 1 and result.assert_count == 1;
}

proc test_ast_const_procedure_mutation_is_rejected() -> bool {
  let source: string =
    "const proc mutate(value: int) -> int { set value = value + 1; give value; }\n" +
    "const BAD: int = mutate(1);\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_mutation.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_mutation.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_MUTATION_IN_CONST");
}

proc test_ast_const_procedure_loop_is_rejected() -> bool {
  let source: string =
    "const proc forbidden() -> int { while true { give 1; } give 0; }\n" +
    "const BAD: int = forbidden();\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_loop.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_loop.vit", fe.ast_root);
  give fe.valid and not result.valid and has_code(result, "CONST_EVAL_E_UNSUPPORTED_EXPR");
}

proc test_ast_compile_time_simulation_detects_proc_impossible_branch() -> bool {
  let source: string =
    "const READY = false;\n" +
    "proc main() -> int {\n" +
    "  if (READY) { give 1; }\n" +
    "  give 0;\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_impossible_branch.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_impossible_branch.vit", fe.ast_root);
  give fe.valid
    and has_code(result, "CONST_EVAL_E_IMPOSSIBLE_BRANCH")
    and result.simulation_count == 1
    and result.impossible_branch_count == 1;
}

proc test_ast_compile_time_simulation_tracks_local_constants() -> bool {
  let source: string =
    "proc main() -> int {\n" +
    "  let ready = true;\n" +
    "  if (ready) { give 1; }\n" +
    "  give 0;\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_local_const.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_local_const.vit", fe.ast_root);
  give fe.valid
    and result.valid
    and result.simulation_count == 1
    and result.impossible_branch_count == 0;
}

proc test_ast_compile_time_simulation_detects_constant_assert_failure() -> bool {
  let source: string =
    "proc main() -> int {\n" +
    "  assert(false);\n" +
    "  give 0;\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("const_eval_proc_assert_fail.vit", source);
  let result: ConstEvalRunResult = run_const_eval_ast("const_eval_proc_assert_fail.vit", fe.ast_root);
  give fe.valid
    and has_code(result, "CONST_EVAL_E_STATIC_ASSERT_FAILED")
    and result.simulation_count == 1;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_valid_arithmetic_chain() {
    set failures = failures + 1;
  }
  if not test_division_by_zero() {
    set failures = failures + 1;
  }
  if not test_typed_integer_boundaries() {
    set failures = failures + 1;
  }
  if not test_typed_integer_overflow() {
    set failures = failures + 1;
  }
  if not test_typed_integer_underflow() {
    set failures = failures + 1;
  }
  if not test_ast_typed_integer_overflow() {
    set failures = failures + 1;
  }
  if not test_ast_typed_integer_underflow() {
    set failures = failures + 1;
  }
  if not test_ast_signed_integer_minimum() {
    set failures = failures + 1;
  }
  if not test_ast_invalid_unary_operand() {
    set failures = failures + 1;
  }
  if not test_ast_forbidden_const_reference() {
    set failures = failures + 1;
  }
  if not test_unknown_name() {
    set failures = failures + 1;
  }
  if not test_non_const_call() {
    set failures = failures + 1;
  }
  if not test_static_assert_failure() {
    set failures = failures + 1;
  }
  if not test_compile_time_simulation_detects_impossible_branch() {
    set failures = failures + 1;
  }
  if not test_compile_time_simulation_accepts_reachable_constant_branch() {
    set failures = failures + 1;
  }
  if not test_cycle_detection() {
    set failures = failures + 1;
  }
  if not test_ast_const_eval_path() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_call() {
    set failures = failures + 1;
  }
  if not test_ast_nested_const_procedure_calls() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_unary_result() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_arity_mismatch() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_local_binding() {
    set failures = failures + 1;
  }
  if not test_ast_non_const_procedure_call_is_rejected() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_cycle() {
    set failures = failures + 1;
  }
  if not test_ast_recursive_const_procedure() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_mutation_is_rejected() {
    set failures = failures + 1;
  }
  if not test_ast_const_procedure_loop_is_rejected() {
    set failures = failures + 1;
  }
  if not test_ast_compile_time_simulation_detects_proc_impossible_branch() {
    set failures = failures + 1;
  }
  if not test_ast_compile_time_simulation_tracks_local_constants() {
    set failures = failures + 1;
  }
  if not test_ast_compile_time_simulation_detects_constant_assert_failure() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
