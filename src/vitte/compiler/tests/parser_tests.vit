space vitte/compiler/tests/parser_tests

use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run, frontend_run_with_lang }
use vitte/compiler/frontend/lexer/scanner.{ ScanResult, scan_tokens }
use vitte/compiler/frontend/ast/item.{ AstItemKind }
use vitte/compiler/frontend/parse/recovery.{ recover_decl_index, recover_stmt_index }
use vitte/compiler/frontend/grammar_alignment_checker.{ GrammarAlignmentReport, grammar_alignment_report, grammar_alignment_summary }
use vitte/compiler/tests/frontend_fixtures/valid/parser.{ grammar_surface_source }
use vitte/compiler/tests/frontend_fixtures/invalid/parser.{ recover_decl_source, recover_stmt_source }
use vitte/compiler/tests/frontend_fixtures/invalid/lexer.{ invalid_char_source }

const VERSION_TEXT: string = "frontend parser tests 0.3.0"
const BANNER_TEXT: string = "frontend parser tests"

proc token_index(result: ScanResult, lexeme: string) -> int {
  let i: u64 = 0;
  while i < len(result.tokens) {
    if result.tokens[i].lexeme == lexeme {
      give i as int;
    }
    set i = i + 1;
  }
  give -1;
}

proc test_frontend_preserves_diagnostic_span_and_locale() -> bool {
  let fe: FrontendOutput = frontend_run_with_lang("bad_frontend.vit", invalid_char_source(), "fr");
  if fe.valid or len(fe.diagnostics) == 0 {
    give false;
  }
  let diag = fe.diagnostics[0];
  give diag.code == "LEX_E_INVALID_CHAR" and diag.file == "bad_frontend.vit" and diag.line == 1 and diag.column == 15 and diag.span.start_line == 1 and diag.span.start_column == 15 and diag.span.end_column == 16 and diag.locale == "fr" and diag.localized_message == "caractere invalide";
}

proc test_recovery_syncs_statement_boundary() -> bool {
  let scanned: ScanResult = scan_tokens(recover_stmt_source());
  let semi_index: int = token_index(scanned, ";");
  if semi_index < 0 {
    give false;
  }
  let recovered: u64 = recover_stmt_index(scanned.tokens, semi_index as u64);
  give recovered < len(scanned.tokens) and scanned.tokens[recovered].lexeme == "give";
}

proc test_recovery_syncs_toplevel_boundary() -> bool {
  let scanned: ScanResult = scan_tokens(recover_decl_source());
  let semi_index: int = token_index(scanned, ";");
  if semi_index < 0 {
    give false;
  }
  let recovered: u64 = recover_decl_index(scanned.tokens, semi_index as u64);
  give recovered < len(scanned.tokens) and scanned.tokens[recovered].lexeme == "proc";
}

proc test_frontend_marks_recovery_usage() -> bool {
  let fe: FrontendOutput = frontend_run("recover_stmt.vit", recover_stmt_source());
  if fe.valid or not fe.recovery_used or fe.diagnostics_total == 0 {
    give false;
  }
  let diag = fe.diagnostics[0];
  give diag.line == 1 and diag.column > 0 and diag.span.start_line == 1;
}

proc test_frontend_accepts_valid_surface_fixture() -> bool {
  let fe: FrontendOutput = frontend_run("grammar_surface.vit", grammar_surface_source());
  give fe.valid and fe.toplevel_count >= 2 and fe.stmt_count >= 3 and fe.expr_count >= 4;
}

proc test_frontend_accepts_intrinsic_toplevel_decl() -> bool {
  let source_text: string = "intrinsic vitte_host_runtime_available() -> bool;\nproc main() -> int { give 0; }\n";
  let fe: FrontendOutput = frontend_run("intrinsic_surface.vit", source_text);
  give fe.valid
    and len(fe.ast_root.items) >= 2
    and fe.ast_root.items[0].kind == AstItemKind.Intrinsic
    and fe.ast_root.items[0].name == "vitte_host_runtime_available"
    and fe.ast_root.items[1].kind == AstItemKind.Proc;
}

proc test_grammar_alignment_report_is_computed() -> bool {
  let report: GrammarAlignmentReport = grammar_alignment_report();
  let summary: string = grammar_alignment_summary();
  give report.declaration_count > 0 and report.complete_count >= report.tested_count and find(summary, report.grammar_version) >= 0;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_frontend_preserves_diagnostic_span_and_locale() {
    set failures = failures + 1;
  }
  if not test_recovery_syncs_statement_boundary() {
    set failures = failures + 1;
  }
  if not test_recovery_syncs_toplevel_boundary() {
    set failures = failures + 1;
  }
  if not test_frontend_marks_recovery_usage() {
    set failures = failures + 1;
  }
  if not test_frontend_accepts_valid_surface_fixture() {
    set failures = failures + 1;
  }
  if not test_frontend_accepts_intrinsic_toplevel_decl() {
    set failures = failures + 1;
  }
  if not test_grammar_alignment_report_is_computed() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
