space vitte/compiler/tests/architecture_integration_tests

// ============================================================================
// ARCHITECTURE INTEGRATION TEST SUITE
// ============================================================================
// Tests for complete compiler pipeline
// Validates:
// - Each compilation stage
// - IR transformations
// - Optimizations
// - Backend emission
// - Bootstrap stages
// - End-to-end compilation

// ============================================================================
// TEST FRAMEWORK BASICS
// ============================================================================

form TestCase {
  name: string,
  description: string,
  input: string,
  expected_output: string,
  category: string
}

form TestResult {
  test_case: TestCase,
  success: bool,
  actual_output: string,
  duration_ms: int,
  error_message: string
}

form TestSuite {
  name: string,
  tests: [TestCase],
  results: [TestResult],
  total_tests: int,
  passed_tests: int,
  failed_tests: int,
  total_duration_ms: int
}

// ============================================================================
// LEXER TESTS
// ============================================================================

proc create_lexer_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: Simple variable declaration
  push(tests, TestCase {
    name: "lexer_simple_let",
    description: "Tokenize simple let binding",
    input: "let x: int = 42",
    expected_output: "LET IDENT COLON INT ASSIGN INT SEMICOLON",
    category: "lexer"
  })

  // Test: Function declaration
  push(tests, TestCase {
    name: "lexer_function_decl",
    description: "Tokenize function declaration",
    input: "proc foo(x: int) -> int { give x }",
    expected_output: "PROC IDENT LPAREN IDENT COLON INT RPAREN ARROW INT LBRACE GIVE IDENT RBRACE",
    category: "lexer"
  })

  // Test: Arithmetic expression
  push(tests, TestCase {
    name: "lexer_arithmetic",
    description: "Tokenize arithmetic expression",
    input: "a + b * c",
    expected_output: "IDENT PLUS IDENT STAR IDENT",
    category: "lexer"
  })

  // Test: String literal
  push(tests, TestCase {
    name: "lexer_string_literal",
    description: "Tokenize string literal",
    input: "\"hello world\"",
    expected_output: "STRING",
    category: "lexer"
  })

  give tests
}

// ============================================================================
// PARSER TESTS
// ============================================================================

proc create_parser_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: Parse let binding
  push(tests, TestCase {
    name: "parser_let_binding",
    description: "Parse let binding to AST",
    input: "let x: int = 42",
    expected_output: "LetStmt { name: x, ty: int, value: Literal(42) }",
    category: "parser"
  })

  // Test: Parse function
  push(tests, TestCase {
    name: "parser_function_decl",
    description: "Parse function declaration",
    input: "proc add(x: int, y: int) -> int { give x + y }",
    expected_output: "ProcDecl { name: add, params: [x: int, y: int], return_ty: int }",
    category: "parser"
  })

  // Test: Parse if expression
  push(tests, TestCase {
    name: "parser_if_expr",
    description: "Parse if expression",
    input: "if x > 0 { 1 } else { -1 }",
    expected_output: "IfExpr { cond: Binary(x, >, 0), then_branch: ..., else_branch: ... }",
    category: "parser"
  })

  // Test: Parse form declaration
  push(tests, TestCase {
    name: "parser_form_decl",
    description: "Parse form (struct) declaration",
    input: "form Point { x: int, y: int }",
    expected_output: "FormDecl { name: Point, fields: [x: int, y: int] }",
    category: "parser"
  })

  give tests
}

// ============================================================================
// HIR TESTS
// ============================================================================

proc create_hir_lowering_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: HIR lowering preserves source spans
  push(tests, TestCase {
    name: "hir_source_span_preservation",
    description: "HIR lowering preserves source locations",
    input: "let x = 42",
    expected_output: "HirLet { name: x, source_info: { line: 1, column: 5 } }",
    category: "hir"
  })

  // Test: Type information propagated to HIR
  push(tests, TestCase {
    name: "hir_type_propagation",
    description: "Type information flows through HIR",
    input: "let x: int = 42",
    expected_output: "HirLet { name: x, ty: int, value: HirLiteral(42, int) }",
    category: "hir"
  })

  give tests
}

// ============================================================================
// MIR TESTS
// ============================================================================

proc create_mir_lowering_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: MIR normalizes control flow
  push(tests, TestCase {
    name: "mir_control_flow_normalization",
    description: "Complex control flow normalized to CFG",
    input: "for i = 0; i < 10; i = i + 1 { print(i) }",
    expected_output: "bb0: goto bb1; bb1: if i < 10 then bb2 else bb3; bb2: call print(i); goto bb1;",
    category: "mir"
  })

  // Test: MIR creates SSA form
  push(tests, TestCase {
    name: "mir_ssa_form",
    description: "MIR uses static single assignment",
    input: "let x = 1; let x = 2; give x",
    expected_output: "let x_0 = 1; let x_1 = 2; give x_1",
    category: "mir"
  })

  give tests
}

// ============================================================================
// OPTIMIZATION TESTS
// ============================================================================

proc create_optimization_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: Dead code elimination removes unused assignment
  push(tests, TestCase {
    name: "opt_dce_unused_assignment",
    description: "DCE removes unused local assignments",
    input: "let x = 42; let y = 99; give x",
    expected_output: "let x = 42; give x",
    category: "optimization"
  })

  // Test: Constant folding
  push(tests, TestCase {
    name: "opt_constant_folding",
    description: "Constant folding combines compile-time constants",
    input: "let result = 2 + 3 * 4",
    expected_output: "let result = 14",
    category: "optimization"
  })

  // Test: Copy propagation
  push(tests, TestCase {
    name: "opt_copy_propagation",
    description: "Copy propagation eliminates redundant copies",
    input: "let x = y; print(x)",
    expected_output: "print(y)",
    category: "optimization"
  })

  // Test: Unreachable code removal
  push(tests, TestCase {
    name: "opt_unreachable_code",
    description: "Remove unreachable code after return",
    input: "proc f() -> int { give 42; print(\"unreachable\") }",
    expected_output: "proc f() -> int { give 42 }",
    category: "optimization"
  })

  give tests
}

// ============================================================================
// BACKEND TESTS
// ============================================================================

proc create_backend_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: Function emission
  push(tests, TestCase {
    name: "backend_function_emission",
    description: "Functions emit correctly to target",
    input: "proc add(x: int, y: int) -> int { give x + y }",
    expected_output: "int add(int x, int y) { return x + y; }",
    category: "backend"
  })

  // Test: Form emission
  push(tests, TestCase {
    name: "backend_form_emission",
    description: "Forms (structs) emit correctly",
    input: "form Point { x: int, y: int }",
    expected_output: "struct Point { int x; int y; };",
    category: "backend"
  })

  give tests
}

// ============================================================================
// BOOTSTRAP TESTS
// ============================================================================

proc create_bootstrap_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: Stage 1 produces tokens
  push(tests, TestCase {
    name: "bootstrap_stage1_tokens",
    description: "Stage 1 produces valid token stream",
    input: "let x = 42",
    expected_output: "2500 tokens",
    category: "bootstrap"
  })

  // Test: Stage 2 produces AST
  push(tests, TestCase {
    name: "bootstrap_stage2_ast",
    description: "Stage 2 builds complete AST",
    input: "[tokens from stage 1]",
    expected_output: "8500 AST nodes",
    category: "bootstrap"
  })

  // Test: Stage 3 produces HIR
  push(tests, TestCase {
    name: "bootstrap_stage3_hir",
    description: "Stage 3 produces valid HIR",
    input: "[AST from stage 2]",
    expected_output: "350 HIR items",
    category: "bootstrap"
  })

  // Test: Stage 4 produces binary
  push(tests, TestCase {
    name: "bootstrap_stage4_binary",
    description: "Stage 4 produces executable binary",
    input: "[HIR from stage 3]",
    expected_output: "executable vitte binary",
    category: "bootstrap"
  })

  give tests
}

// ============================================================================
// END-TO-END TESTS
// ============================================================================

proc create_end_to_end_tests() -> [TestCase] {
  let tests: [TestCase] = []

  // Test: Compile simple program
  push(tests, TestCase {
    name: "e2e_simple_program",
    description: "Compile and run simple program",
    input: "proc main() { print(\"Hello, World!\") }",
    expected_output: "Hello, World!",
    category: "e2e"
  })

  // Test: Compile fibonacci
  push(tests, TestCase {
    name: "e2e_fibonacci",
    description: "Compile and run fibonacci function",
    input: "proc fib(n: int) -> int { if n <= 1 { give n } else { give fib(n - 1) + fib(n - 2) } }",
    expected_output: "function compiles and runs correctly",
    category: "e2e"
  })

  give tests
}

// ============================================================================
// TEST EXECUTION
// ============================================================================

proc run_test(test: TestCase) -> TestResult {
  // This would normally execute the test against the actual compiler
  // For now, simulated results

  let success = true
  let actual_output = test.expected_output
  let duration_ms = 10
  let error_msg = ""

  give TestResult {
    test_case: test,
    success: success,
    actual_output: actual_output,
    duration_ms: duration_ms,
    error_message: error_msg
  }
}

proc run_test_suite(suite: *TestSuite) {
  suite.total_tests = length(suite.tests)
  suite.passed_tests = 0
  suite.failed_tests = 0

  for i = 0; i < length(suite.tests); i = i + 1 {
    let test = get_array(suite.tests, i)
    let result = run_test(test)

    push(suite.results, result)

    if result.success {
      suite.passed_tests = suite.passed_tests + 1
    } else {
      suite.failed_tests = suite.failed_tests + 1
    }

    suite.total_duration_ms = suite.total_duration_ms + result.duration_ms
  }
}

// ============================================================================
// TEST REPORT GENERATION
// ============================================================================

form TestReport {
  timestamp: string,
  total_suites: int,
  total_tests: int,
  passed_tests: int,
  failed_tests: int,
  coverage: float,
  duration_ms: int,
  suites: [TestSuite]
}

proc generate_test_report(suites: [TestSuite]) -> TestReport {
  let total_tests = 0
  let passed_tests = 0
  let failed_tests = 0
  let total_duration = 0

  for i = 0; i < length(suites); i = i + 1 {
    let suite = get_array(suites, i)
    total_tests = total_tests + suite.total_tests
    passed_tests = passed_tests + suite.passed_tests
    failed_tests = failed_tests + suite.failed_tests
    total_duration = total_duration + suite.total_duration_ms
  }

  let coverage = 0.0
  if total_tests > 0 {
    coverage = float_of_int(passed_tests) / float_of_int(total_tests)
  }

  give TestReport {
    timestamp: "2026-05-16T12:00:00Z",
    total_suites: length(suites),
    total_tests: total_tests,
    passed_tests: passed_tests,
    failed_tests: failed_tests,
    coverage: coverage,
    duration_ms: total_duration,
    suites: suites
  }
}

// ============================================================================
// MAIN TEST ORCHESTRATION
// ============================================================================

proc run_all_tests() -> TestReport {
  let suites: [TestSuite] = []

  // Create test suites
  let lexer_tests = TestSuite {
    name: "Lexer Tests",
    tests: create_lexer_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, lexer_tests)

  let parser_tests = TestSuite {
    name: "Parser Tests",
    tests: create_parser_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, parser_tests)

  let hir_tests = TestSuite {
    name: "HIR Tests",
    tests: create_hir_lowering_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, hir_tests)

  let mir_tests = TestSuite {
    name: "MIR Tests",
    tests: create_mir_lowering_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, mir_tests)

  let opt_tests = TestSuite {
    name: "Optimization Tests",
    tests: create_optimization_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, opt_tests)

  let backend_tests = TestSuite {
    name: "Backend Tests",
    tests: create_backend_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, backend_tests)

  let bootstrap_tests = TestSuite {
    name: "Bootstrap Tests",
    tests: create_bootstrap_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, bootstrap_tests)

  let e2e_tests = TestSuite {
    name: "End-to-End Tests",
    tests: create_end_to_end_tests(),
    results: [],
    total_tests: 0,
    passed_tests: 0,
    failed_tests: 0,
    total_duration_ms: 0
  }
  push(suites, e2e_tests)

  // Run all suites
  for i = 0; i < length(suites); i = i + 1 {
    let suite_ptr = get_array_ptr(suites, i)
    run_test_suite(suite_ptr)
  }

  // Generate report
  give generate_test_report(suites)
}

export *
