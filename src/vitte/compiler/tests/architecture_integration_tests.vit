space vitte/compiler/tests/architecture_integration_tests

use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/middle/pipeline.{ MiddleOutput, middle_run }
use vitte/compiler/middle/mir/mir.{ MirTerminatorKind }

const VERSION_TEXT: string = "compiler architecture integration tests 0.3.0"
const BANNER_TEXT: string = "compiler architecture integration tests"

proc test_frontend_to_ast_contract() -> bool {
  let source: string =
    "const ANSWER = 42;\n" +
    "proc main() { let x = ANSWER; give x; }\n";
  let fe: FrontendOutput = frontend_run("architecture_frontend.vit", source);
  if not fe.valid {
    give false;
  }
  if len(fe.ast_root.items) != 2 {
    give false;
  }
  give fe.toplevel_count == 2 and fe.stmt_count >= 2 and fe.expr_count >= 2;
}

proc test_middle_pipeline_builds_cfg() -> bool {
  let source: string =
    "proc main() { let x = 1; if x { set x = x + 1; } else { set x = x + 2; } while x { set x = x - 1; } give x; }\n";
  let fe: FrontendOutput = frontend_run("architecture_middle_cfg.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  if not middle.hir.valid or not middle.mir.valid {
    give false;
  }
  if len(middle.mir.module.functions) != 1 {
    give false;
  }

  let fn0 = middle.mir.module.functions[0];
  if len(fn0.blocks) < 7 {
    give false;
  }

  let branch_count: u64 = 0;
  let i: u64 = 0;
  while i < len(fn0.blocks) {
    if fn0.blocks[i].terminator.kind == MirTerminatorKind.Branch {
      set branch_count = branch_count + 1;
    }
    set i = i + 1;
  }

  give middle.analysis.valid and fn0.entry_block == fn0.blocks[0].id and branch_count >= 2;
}

proc test_borrowck_failure_stops_pipeline() -> bool {
  let source: string =
    "proc main() { let x = make_box(); let a = &x; let b = &mut x; give x; }\n";
  let fe: FrontendOutput = frontend_run("architecture_borrowck_fail.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  give fe.valid and not middle.analysis.valid and not middle.analysis.borrowck_ok and not middle.valid;
}

proc test_const_eval_and_analysis_success() -> bool {
  let source: string =
    "const X = 1 + 2;\n" +
    "static_assert(X == 3);\n" +
    "proc main() { give X; }\n";
  let fe: FrontendOutput = frontend_run("architecture_const_eval.vit", source);
  let middle: MiddleOutput = middle_run(fe);
  give fe.valid and middle.analysis.const_eval_ok and middle.analysis.valid and middle.hir.valid;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_frontend_to_ast_contract() { set failures = failures + 1; }
  if not test_middle_pipeline_builds_cfg() { set failures = failures + 1; }
  if not test_borrowck_failure_stops_pipeline() { set failures = failures + 1; }
  if not test_const_eval_and_analysis_success() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
