    and item_bench.kind == HirItemKind.Bench
    and item_bits.kind == HirItemKind.Bits
    and item_class.kind == HirItemKind.Class
    and item_compiler.kind == HirItemKind.Compiler
    and item_comptime.kind == HirItemKind.Comptime
    and item_diag.kind == HirItemKind.Diagnostic
    and item_entry.kind == HirItemKind.Entry
    and item_export.kind == HirItemKind.Export
    and item_flags.kind == HirItemKind.Flags
    and item_global.kind == HirItemKind.Global
    and item_intrinsic.kind == HirItemKind.Intrinsic
    and item_macro.kind == HirItemKind.Macro
    and item_opaque.kind == HirItemKind.Opaque
    and item_pass.kind == HirItemKind.Pass
    and item_query.kind == HirItemKind.Query
    and item_region.kind == HirItemKind.Region
    and item_static_assert.kind == HirItemKind.StaticAssert
    and item_test.kind == HirItemKind.Test
    and item_union.kind == HirItemKind.Union
    and item_unknown.kind == HirItemKind.Unknown
    and module.name == "surface"
    and unit.source_path == "surface.vit";
}

proc test_hir_to_mir_fixture_nodes_survive() -> bool {
  let source: string =
    "form Point { x: int, y: int }\n" +
    "proc add(left: int, right: int) -> int { let total = left + right; give total; }\n" +
    "proc main() -> int { let point = Point { x: 1, y: 2 }; give add(point.x, point.y); }\n";
  let fe: FrontendOutput = frontend_run("hir_to_mir_fixture.vit", source);
  let hir: HirUnit = lower_ast_to_hir(fe);
  let mir: MirUnit = lower_hir_to_mir(hir);
  give hir.valid
    and mir.valid
    and mir.function_count >= 2
    and mir.block_count >= 2
    and mir.instruction_count > 0
    and mir.module.functions[0].name == "add"
    and mir.module.functions[1].name == "main";
}

proc test_hir_validation_rejects_empty_trait_and_impl() -> bool {
  let source: string =
    "trait Empty {}\n" +
    "impl Empty for Point {}\n" +
    "proc main() -> int { give 0; }\n";
  let fe: FrontendOutput = frontend_run("hir_empty_trait_impl.vit", source);
  let hir: HirUnit = lower_ast_to_hir(fe);
  let checked_again: HirUnit = validate_hir(hir);
  give hir.analyzed
    and not hir.valid
    and len(hir.module.diagnostics) >= 2
    and len(checked_again.module.diagnostics) == len(hir.module.diagnostics);
}

proc test_hir_validation_rejects_invalid_member_and_param_surface() -> bool {
  let bad_param: HirProcParam = hir_proc_param("", "", "", false, false, false, false);
  let bad_member = hir_nominal_member(
    2,
    ast_span_empty(),
    HirNominalMemberKind.ImplMethod,
    "",
    "",
    hir_expr_empty(),
    [bad_param],
    [],
    "",
    false
  );
  let item = hir_item_with_members(
    1,
    ast_span_empty(),
    HirItemKind.Impl,
    "Show",
    0,
    "",
    "public",
    true,
    "",
    1,
    [],
    0,
    0,
    0,
    1,
    1,
    [bad_param],
    "",
    "",
    hir_expr_empty(),
    [],
    [bad_member],
    "",
    0,
    [],
    true
  );
  let unit: HirUnit = validate_hir(hir_unit("hir_invalid_member.vit", hir_module("hir_invalid_member.vit", [item], [], 0, 1, true), 2, 1, 1, 0, 0, 1, true, false, true));

  give not unit.valid and len(unit.module.diagnostics) >= 5;
}

proc test_hir_validation_rejects_unit_count_mismatch() -> bool {
  let fe: FrontendOutput = frontend_run("hir_count_mismatch.vit", "proc main() { give 0; }\n");
  let lowered: HirUnit = lower_ast_to_hir(fe);
  let malformed: HirUnit = HirUnit {
    source_path: lowered.source_path,
    module: lowered.module,
    node_count: lowered.node_count,
    symbol_count: lowered.symbol_count,
    scope_count: lowered.scope_count,
    expr_count: lowered.expr_count,
    stmt_count: lowered.stmt_count,
    item_count: lowered.item_count + 1,
    lowered: lowered.lowered,
    analyzed: false,
    valid: lowered.valid
  };
  let checked: HirUnit = validate_hir(malformed);

  give not checked.valid
    and checked.analyzed
    and len(checked.module.diagnostics) > 0
    and checked.module.diagnostics[0].code == "HIRV0401";
}

proc test_hir_builder_helpers_selftest() -> bool {
  give hir_builder_selftest();
}

proc test_hir_control_flow_helpers_selftest() -> bool {
  give control_flow_selftest();
}

proc test_hir_pretty_surface_selftest() -> bool {
  give pretty_selftest();
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_hir_lowering() {
    set failures = failures + 1;
  }
  if not test_hir_if_while_lowering() {
    set failures = failures + 1;
  }
  if not test_hir_extended_expr_kind_lowering() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_surface_items_and_struct_expr() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_proc_params() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_proc_generic_params() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_call_generic_arguments() {
    set failures = failures + 1;
  }
  if not test_hir_minimal_item_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_import_and_module_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_function_shape_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_return_and_extern_function_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_impl_method_receiver_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_block_and_let_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_pattern_source_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_expr_kind_surface_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_stmt_kind_surface_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_binding_value_and_place_surface_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_span_surface_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_invalid_surface_diagnostics() {
    set failures = failures + 1;
  }
  if not test_hir_recovery_partial_unit_after_frontend_error() {
    set failures = failures + 1;
  }
  if not test_hir_stable_order_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_decl_use_links_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_precise_import_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_multifile_and_import_cycle_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_remaining_declared_surface_coverage() {
    set failures = failures + 1;
  }
  if not test_hir_to_mir_fixture_nodes_survive() {
    set failures = failures + 1;
  }
  if not test_hir_validation_rejects_empty_trait_and_impl() {
    set failures = failures + 1;
  }
  if not test_hir_validation_rejects_invalid_member_and_param_surface() {
    set failures = failures + 1;
  }
  if not test_hir_validation_rejects_unit_count_mismatch() {
    set failures = failures + 1;
  }
  if not test_hir_builder_helpers_selftest() {
    set failures = failures + 1;
  }
  if not test_hir_control_flow_helpers_selftest() {
    set failures = failures + 1;
  }
  if not test_hir_pretty_surface_selftest() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
