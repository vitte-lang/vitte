space vitte/compiler/tests/hir_tests

use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/frontend/ast.expr.{ AstExprKind }
use vitte/compiler/frontend/ast.pattern.{ AstPatternKind }
use vitte/compiler/analysis/sema.{ SemaResult, run_sema_hir }
use vitte/compiler/driver/compile.{ DriverModuleSetArtifacts, analyze_source_set, driver_module_input }
use vitte/compiler/middle/hir/lower_ast.{ lower_ast_to_hir, lower_expr_kind }
use vitte/compiler/middle/lower/hir_to_mir.{ lower_hir_to_mir }
use vitte/compiler/middle/hir.{ HirBinding, HirBindingKind, HirExpr, HirExprKind, HirGenericParam, HirItem, HirItemKind, HirModule, HirNominalMember, HirNominalMemberKind, HirPlaceCategory, HirProcParam, HirStmt, HirStmtKind, HirTypeInfo, HirUnit, HirValueMode, SemanticDiagnostic, SemanticSeverity, hir_binding, hir_expr, hir_expr_empty, hir_generic_param_with_span, hir_item_with_members, hir_module, hir_nominal_member, hir_proc_param, hir_stmt, hir_type_info, hir_unit, semantic_diagnostic }
use vitte/compiler/middle/mir.{ MirUnit }
