    and stmt_asm.kind == HirStmtKind.Asm
    and binding_unknown.kind == HirBindingKind.Unknown
    and type_info.name == "i32"
    and diagnostic.code == "HIR_TEST"
    and member_field.kind == HirNominalMemberKind.Field
    and member_variant.kind == HirNominalMemberKind.Variant
    and member_trait.kind == HirNominalMemberKind.TraitMethod
    and member_unknown.kind == HirNominalMemberKind.Unknown
