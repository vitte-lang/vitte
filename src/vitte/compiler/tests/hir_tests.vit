  let member_field: HirNominalMember = hir_nominal_member(901, ast_span_empty(), HirNominalMemberKind.Field, "field", "int", hir_expr_empty(), [], [], "", true);
  let member_variant: HirNominalMember = hir_nominal_member(902, ast_span_empty(), HirNominalMemberKind.Variant, "Some", "int", hir_expr_empty(), [], [], "", true);
  let member_trait: HirNominalMember = hir_nominal_member(903, ast_span_empty(), HirNominalMemberKind.TraitMethod, "show", "string", hir_expr_empty(), [hir_proc_param("self", "Self", "", false, false, false, true)], [], "", true);
  let member_unknown: HirNominalMember = hir_nominal_member(904, ast_span_empty(), HirNominalMemberKind.Unknown, "unknown", "int", hir_expr_empty(), [], [], "", true);
  let item_backend: HirItem = hir_item_with_members(910, ast_span_empty(), HirItemKind.Backend, "Backend", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_bench: HirItem = hir_item_with_members(911, ast_span_empty(), HirItemKind.Bench, "bench", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_bits: HirItem = hir_item_with_members(912, ast_span_empty(), HirItemKind.Bits, "Bits", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "u8", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_class: HirItem = hir_item_with_members(913, ast_span_empty(), HirItemKind.Class, "Class", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_compiler: HirItem = hir_item_with_members(914, ast_span_empty(), HirItemKind.Compiler, "Compiler", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_comptime: HirItem = hir_item_with_members(915, ast_span_empty(), HirItemKind.Comptime, "Comptime", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_diag: HirItem = hir_item_with_members(916, ast_span_empty(), HirItemKind.Diagnostic, "Diagnostic", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_entry: HirItem = hir_item_with_members(917, ast_span_empty(), HirItemKind.Entry, "Entry", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_export: HirItem = hir_item_with_members(918, ast_span_empty(), HirItemKind.Export, "Export", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_flags: HirItem = hir_item_with_members(919, ast_span_empty(), HirItemKind.Flags, "Flags", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "u8", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_global: HirItem = hir_item_with_members(920, ast_span_empty(), HirItemKind.Global, "Global", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "int", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_intrinsic: HirItem = hir_item_with_members(921, ast_span_empty(), HirItemKind.Intrinsic, "intrinsic", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_macro: HirItem = hir_item_with_members(922, ast_span_empty(), HirItemKind.Macro, "Macro", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_opaque: HirItem = hir_item_with_members(923, ast_span_empty(), HirItemKind.Opaque, "Opaque", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "u64", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_pass: HirItem = hir_item_with_members(924, ast_span_empty(), HirItemKind.Pass, "Pass", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_query: HirItem = hir_item_with_members(925, ast_span_empty(), HirItemKind.Query, "Query", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_region: HirItem = hir_item_with_members(926, ast_span_empty(), HirItemKind.Region, "Region", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_static_assert: HirItem = hir_item_with_members(927, ast_span_empty(), HirItemKind.StaticAssert, "StaticAssert", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", test_hir_expr(HirExprKind.Bool), [], [], "", 0, [], true);
  let item_test: HirItem = hir_item_with_members(928, ast_span_empty(), HirItemKind.Test, "Test", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_union: HirItem = hir_item_with_members(929, ast_span_empty(), HirItemKind.Union, "Union", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], true);
  let item_unknown: HirItem = hir_item_with_members(930, ast_span_empty(), HirItemKind.Unknown, "Unknown", 0, "", "public", true, "", 0, [], 0, 0, 0, 0, 0, [], "", "", hir_expr_empty(), [], [], "", 0, [], false);
  let module: HirModule = hir_module("surface", [item_backend], [diagnostic], 0, 1, true);
