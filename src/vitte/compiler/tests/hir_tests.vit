space vitte/compiler/tests/hir_tests

use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/frontend/ast.expr.{ AstExprKind }
use vitte/compiler/middle/hir/lower_ast.{ lower_ast_to_hir, lower_expr_kind }
use vitte/compiler/middle/hir.{ HirExprKind, HirItemKind, HirNominalMemberKind, HirProcParam, HirStmtKind, HirUnit, hir_expr_empty, hir_item_with_members, hir_module, hir_nominal_member, hir_proc_param, hir_unit }
use vitte/compiler/middle/hir/builder.{ hir_builder_selftest }
use vitte/compiler/middle/hir/control_flow.{ control_flow_selftest }
use vitte/compiler/middle/hir/pretty.{ pretty_selftest }
use vitte/compiler/middle/hir/validate.{ validate_hir }
use vitte/compiler/frontend/ast.node.{ ast_span_empty }

const VERSION_TEXT: string = "middle hir tests 0.2.0"
const BANNER_TEXT: string = "middle hir tests"

proc test_hir_lowering() -> bool {
  let source: string = "const ANSWER = 42;\nproc main() { let x = ANSWER; give x; }\n";
  let fe: FrontendOutput = frontend_run("hir_test.vit", source);
  let hir = lower_ast_to_hir(fe);
  if not hir.valid or len(hir.module.items) != 2 {
    give false;
  }
  if hir.module.items[0].kind != HirItemKind.Const {
    give false;
  }
  if hir.symbol_count < 2 or hir.scope_count != 1 {
    give false;
  }
  if hir.module.items[1].stmts[0].scope_depth != 1 {
    give false;
  }
  give hir.module.items[1].kind == HirItemKind.Proc and hir.module.items[1].stmts[1].kind == HirStmtKind.Give;
}

proc test_hir_if_while_lowering() -> bool {
  let source: string = "proc main() { if (true) { let x = 1; } else { while (false) { give 0; } } }\n";
  let fe: FrontendOutput = frontend_run("hir_if_while.vit", source);
  let hir = lower_ast_to_hir(fe);
  if not hir.valid or len(hir.module.items) != 1 {
    give false;
  }
  if len(hir.module.items[0].stmts) != 1 {
    give false;
  }
  if hir.module.items[0].stmts[0].kind != HirStmtKind.If {
    give false;
  }
  if len(hir.module.items[0].stmts[0].else_stmts) != 1 {
    give false;
  }
  give hir.module.items[0].stmts[0].else_stmts[0].kind == HirStmtKind.While;
}

proc test_hir_extended_expr_kind_lowering() -> bool {
  give lower_expr_kind(AstExprKind.Move) == HirExprKind.Move
    and lower_expr_kind(AstExprKind.AddressOf) == HirExprKind.AddressOf
    and lower_expr_kind(AstExprKind.Await) == HirExprKind.Await
    and lower_expr_kind(AstExprKind.Yield) == HirExprKind.Yield
    and lower_expr_kind(AstExprKind.Path) == HirExprKind.Path
    and lower_expr_kind(AstExprKind.Closure) == HirExprKind.Closure
    and lower_expr_kind(AstExprKind.Assign) == HirExprKind.Assign
    and lower_expr_kind(AstExprKind.CompoundAssign) == HirExprKind.CompoundAssign
    and lower_expr_kind(AstExprKind.Slice) == HirExprKind.Slice
    and lower_expr_kind(AstExprKind.TupleIndex) == HirExprKind.TupleIndex
    and lower_expr_kind(AstExprKind.Macro) == HirExprKind.Macro
    and lower_expr_kind(AstExprKind.Comptime) == HirExprKind.Comptime
    and lower_expr_kind(AstExprKind.Unsafe) == HirExprKind.Unsafe
    and lower_expr_kind(AstExprKind.Resource) == HirExprKind.Resource
    and lower_expr_kind(AstExprKind.Invalid) == HirExprKind.Invalid;
}

proc test_hir_preserves_surface_items_and_struct_expr() -> bool {
  let source: string =
    "form Point { x: int, y: int }\n" +
    "bits Mode: u8 {\n" +
    "  read: 0 .. 1,\n" +
    "}\n" +
    "pick Option[T] {\n" +
    "  None,\n" +
    "  Some(T),\n" +
    "}\n" +
    "flags Access: u8 {\n" +
    "  read = 1,\n" +
    "}\n" +
    "trait Show {\n" +
    "  proc show(self: Self) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self) -> string { give \"point\"; }\n" +
    "}\n" +
    "proc main() -> int { let point = Point { x: 1, y: 2 }; give 0; }\n";
  let fe: FrontendOutput = frontend_run("hir_surface_items.vit", source);
  let hir = lower_ast_to_hir(fe);
  if not hir.valid or len(hir.module.items) < 7 {
    give false;
  }
  if hir.module.items[1].kind != HirItemKind.Bits or hir.module.items[2].kind != HirItemKind.Pick {
    give false;
  }
  if hir.module.items[3].kind != HirItemKind.Flags or hir.module.items[4].kind != HirItemKind.Trait or hir.module.items[5].kind != HirItemKind.Impl {
    give false;
  }
  if hir.module.items[1].annotation_text != "u8" or hir.module.items[3].annotation_text != "u8" {
    give false;
  }
  if hir.module.items[2].generic_count != 1 or len(hir.module.items[2].generic_params) != 1 or hir.module.items[2].generic_params[0] != "T" or hir.module.items[5].target_type_text != "Point" {
    give false;
  }
  if hir.module.items[1].member_count == 0 or hir.module.items[4].member_count == 0 or hir.module.items[5].member_count == 0 {
    give false;
  }
  if len(hir.module.items[0].members) < 2 or hir.module.items[0].members[0].kind != HirNominalMemberKind.Field {
    give false;
  }
  if len(hir.module.items[2].members) < 2 or hir.module.items[2].members[1].kind != HirNominalMemberKind.Variant {
    give false;
  }
  if len(hir.module.items[4].members) == 0 or hir.module.items[4].members[0].kind != HirNominalMemberKind.TraitMethod {
    give false;
  }
  if len(hir.module.items[5].members) == 0 or hir.module.items[5].members[0].kind != HirNominalMemberKind.ImplMethod {
    give false;
  }
  if hir.module.items[0].stmts[0].name != "x" or hir.module.items[0].stmts[0].annotation_text != "int" {
    give false;
  }
  if hir.module.items[2].stmts[1].name != "Some" or hir.module.items[2].stmts[1].annotation_text != "T" {
    give false;
  }
  if hir.module.items[4].stmts[0].name != "show" or hir.module.items[4].stmts[0].annotation_text != "string" {
    give false;
  }
  if hir.module.items[4].members[0].name != "show" or hir.module.items[4].members[0].annotation_text != "string" {
    give false;
  }
  if len(hir.module.items[4].members[0].params) != 1 or hir.module.items[4].members[0].params[0].annotation_text != "Self" {
    give false;
  }
  if hir.module.items[5].members[0].body_stmts[0].kind != HirStmtKind.Give {
    give false;
  }
  let main_item = hir.module.items[6];
  if main_item.kind != HirItemKind.Proc or len(main_item.stmts) < 2 {
    give false;
  }
  let point_stmt = main_item.stmts[0];
  give point_stmt.kind == HirStmtKind.Let
    and point_stmt.name == "point"
    and main_item.annotation_text == "int"
    and main_item.signature_param_count == 0
    and point_stmt.expr.kind == HirExprKind.Struct
    and point_stmt.expr.inferred_type == "Point"
    and len(point_stmt.expr.children) >= 3;
}

proc test_hir_preserves_proc_params() -> bool {
  let source: string = "proc add(borrow value: int, mut flag: bool, ...) -> int { if flag { give value; } give 0; }\n";
  let fe: FrontendOutput = frontend_run("hir_proc_params.vit", source);
  let hir: HirUnit = lower_ast_to_hir(fe);
  let item = hir.module.items[0];
  give hir.valid
    and item.kind == HirItemKind.Proc
    and item.signature_param_count == 3
    and len(item.params) == 3
    and item.params[0].name == "value"
    and item.params[0].annotation_text == "int"
    and item.params[0].mode == "borrow"
    and item.params[0].borrowed
    and item.params[1].name == "flag"
    and item.params[1].annotation_text == "bool"
    and item.params[1].mode == "mut"
    and item.params[1].mutable
    and item.params[2].variadic
    and item.params[2].name == "...";
}

proc test_hir_preserves_proc_generic_params() -> bool {
  let source: string = "proc identity<T>(value: T) -> T { give value; }\n";
  let fe: FrontendOutput = frontend_run("hir_proc_generics.vit", source);
  let hir: HirUnit = lower_ast_to_hir(fe);
  let item = hir.module.items[0];
  give hir.valid
    and item.kind == HirItemKind.Proc
    and item.generic_count == 1
    and len(item.generic_params) == 1
    and item.generic_params[0] == "T"
    and item.params[0].annotation_text == "T"
    and item.annotation_text == "T";
}

proc test_hir_validation_rejects_empty_trait_and_impl() -> bool {
  let source: string =
    "trait Empty {}\n" +
    "impl Empty for Point {}\n" +
    "proc main() -> int { give 0; }\n";
  let fe: FrontendOutput = frontend_run("hir_empty_trait_impl.vit", source);
  let hir: HirUnit = validate_hir(lower_ast_to_hir(fe));
  give not hir.valid and len(hir.module.diagnostics) >= 2;
}

proc test_hir_validation_rejects_invalid_member_and_param_surface() -> bool {
  let bad_param: HirProcParam = hir_proc_param("", "", "", false, false, false, false);
  let bad_member = hir_nominal_member(
    2,
    ast_span_empty(),
    HirNominalMemberKind.ImplMethod,
    "",
    "",
    hir_expr_empty(),
    [bad_param],
    [],
    "",
    false
  );
  let item = hir_item_with_members(
    1,
    ast_span_empty(),
    HirItemKind.Impl,
    "Show",
    0,
    "",
    "public",
    true,
    "",
    1,
    [],
    0,
    0,
    0,
    1,
    1,
    [bad_param],
    "",
    "",
    hir_expr_empty(),
    [],
    [bad_member],
    "",
    0,
    [],
    true
  );
  let unit: HirUnit = validate_hir(hir_unit("hir_invalid_member.vit", hir_module("hir_invalid_member.vit", [item], [], 0, 1, true), 2, 1, 1, 0, 0, 1, true, false, true));

  give not unit.valid and len(unit.module.diagnostics) >= 5;
}

proc test_hir_builder_helpers_selftest() -> bool {
  give hir_builder_selftest();
}

proc test_hir_control_flow_helpers_selftest() -> bool {
  give control_flow_selftest();
}

proc test_hir_pretty_surface_selftest() -> bool {
  give pretty_selftest();
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_hir_lowering() {
    set failures = failures + 1;
  }
  if not test_hir_if_while_lowering() {
    set failures = failures + 1;
  }
  if not test_hir_extended_expr_kind_lowering() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_surface_items_and_struct_expr() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_proc_params() {
    set failures = failures + 1;
  }
  if not test_hir_preserves_proc_generic_params() {
    set failures = failures + 1;
  }
  if not test_hir_validation_rejects_empty_trait_and_impl() {
    set failures = failures + 1;
  }
  if not test_hir_validation_rejects_invalid_member_and_param_surface() {
    set failures = failures + 1;
  }
  if not test_hir_builder_helpers_selftest() {
    set failures = failures + 1;
  }
  if not test_hir_control_flow_helpers_selftest() {
    set failures = failures + 1;
  }
  if not test_hir_pretty_surface_selftest() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
