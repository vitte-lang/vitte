space vitte/compiler/tests/ast_tests

use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/frontend/ast/node.{ AstExprKind, AstItemKind, AstStmtKind }

const VERSION_TEXT: string = "frontend ast tests 0.2.0"
const BANNER_TEXT: string = "frontend ast tests"

proc test_ast_module_structure() -> bool {
  let source: string =
    "const ANSWER = 42;\n" +
    "static_assert(ANSWER == 42);\n" +
    "proc main() { let x = ANSWER; set x = ANSWER + 1; give x; }\n";
  let fe: FrontendOutput = frontend_run("ast_test.vit", source);
  if not fe.valid or len(fe.ast_root.items) != 3 {
    give false;
  }
  if fe.ast_root.items[0].kind != AstItemKind.Const {
    give false;
  }
  if fe.ast_root.items[1].kind != AstItemKind.StaticAssert {
    give false;
  }
  if fe.ast_root.items[2].kind != AstItemKind.Proc {
    give false;
  }
  if len(fe.ast_root.items[2].stmts) != 3 {
    give false;
  }
  if fe.ast_root.id.value == 0 or fe.ast_root.items[0].id.value == 0 {
    give false;
  }
  if fe.ast_root.items[0].span.file != "ast_test.vit" {
    give false;
  }
  give fe.ast_root.items[2].stmts[1].kind == AstStmtKind.Set and fe.ast_root.items[0].expr.kind == AstExprKind.Int;
}

proc test_ast_if_while_and_lex_diagnostics() -> bool {
  let source: string =
    "proc main() { if (true) { let x = 1; } else { while (false) { let y = 2; } } }\n";
  let fe: FrontendOutput = frontend_run("ast_if_while.vit", source);
  if not fe.valid or len(fe.ast_root.items) != 1 {
    give false;
  }
  if len(fe.ast_root.items[0].stmts) != 1 {
    give false;
  }
  if fe.ast_root.items[0].stmts[0].kind != AstStmtKind.If {
    give false;
  }
  if len(fe.ast_root.items[0].stmts[0].else_stmts) != 1 {
    give false;
  }
  if fe.ast_root.items[0].stmts[0].else_stmts[0].kind != AstStmtKind.While {
    give false;
  }

  let bad: FrontendOutput = frontend_run("ast_bad_lex.vit", "@");
  give not bad.valid and bad.diagnostics_total > 0;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_ast_module_structure() { set failures = failures + 1; }
  if not test_ast_if_while_and_lex_diagnostics() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
