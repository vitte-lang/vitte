space vitte/compiler/tests/diagnostic_snapshot_tests

use vitte/compiler/diagnostics/diagnostic.{
  Diagnostic,
  DiagnosticApplicability,
  DiagnosticPhase,
  DiagnosticStyle,
  DiagnosticSuggestion,
  DiagnosticSuggestionKind,
  DiagnosticReport,
  DiagnosticRenderConfig,
  diagnostic_fix_plans,
  diagnostic_quality_score,
  default_render_config,
  diagnostic_add_pipeline_context,
  backend_command_failed,
  diagnostic_error,
  diagnostic_explain_text_lang,
  diagnostic_report,
  diagnostic_explain_text,
  diagnostic_with_documentation,
  diagnostic_with_explanation,
  diagnostic_with_label,
  diagnostic_with_probable_fix,
  diagnostic_with_suggestion_detail,
  primary_label,
  previous_label,
  render_report,
  span_create,
  span_range,
  parser_unclosed_block,
  lexer_unterminated_string
}
use vitte/compiler/diagnostics/json.{ json_diagnostic }
use vitte/compiler/diagnostics/lsp.{ LspCanonicalContext, LspCodeAction, LspDiagnostic, LspPublishDiagnosticsParams, lsp_canonical_context, lsp_code_actions, lsp_diagnostic, lsp_diagnostic_with_canonical_context, lsp_publish_report_with_canonical_context, lsp_report_code_actions }

const VERSION_TEXT: string = "diagnostic snapshot tests 0.1.0"
const BANNER_TEXT: string = "diagnostic snapshot tests"

proc human_config() -> DiagnosticRenderConfig {
  let config: DiagnosticRenderConfig = default_render_config();
  set config.style = DiagnosticStyle.Human;
  set config.color = false;
  set config.show_phase = false;
  give config;
}

proc color_human_config() -> DiagnosticRenderConfig {
  let config: DiagnosticRenderConfig = default_render_config();
  set config.style = DiagnosticStyle.Human;
  set config.color = true;
  set config.show_phase = false;
  give config;
}

proc sample_typeck_diagnostic() -> Diagnostic {
  let file: string = "src/vitte/compiler/tests/diagnostics/typeck/assign_mismatch.vit";
  let diag: Diagnostic = diagnostic_error("TYPECK_E_ASSIGN_MISMATCH", DiagnosticPhase.Typeck, "cannot assign string to i32", span_range(file, 8, 9, 8, 16));
  set diag.labels = [
    previous_label("variable declared here as i32", span_create(file, 4, 5, 1)),
    primary_label("expected i32, found string", span_range(file, 8, 9, 8, 16))
  ];
  set diag = diagnostic_with_explanation(diag, "Vitte does not implicitly convert string to i32");
  set diag = diagnostic_with_probable_fix(diag, "use an integer literal, or change x to string");
  set diag = diagnostic_with_documentation(diag, "docs://language/type-system/assignment-compatibility");
  set diag = diagnostic_with_suggestion_detail(diag, DiagnosticSuggestionKind.Replace, "replace the string literal with an integer literal", "0", span_range(file, 8, 9, 8, 16), true, "medium", "the target binding `x` is declared as `i32`");
  set diag = diagnostic_add_pipeline_context(diag, "lexer");
  set diag = diagnostic_add_pipeline_context(diag, "parser");
  set diag = diagnostic_add_pipeline_context(diag, "AST");
  set diag = diagnostic_add_pipeline_context(diag, "HIR");
  set diag = diagnostic_add_pipeline_context(diag, "sema");
  set diag = diagnostic_add_pipeline_context(diag, "typeck [FAILED]");
  give diag;
}

proc sample_lexer_diagnostic() -> Diagnostic {
  give lexer_unterminated_string(span_range("src/vitte/compiler/tests/diagnostics/lexer/unterminated_string.vit", 1, 9, 1, 22));
}

proc sample_borrowck_diagnostic() -> Diagnostic {
  let file: string = "src/vitte/compiler/tests/diagnostics/borrowck/use_after_move.vit";
  let diag: Diagnostic = diagnostic_error("BORROW_E_USE_AFTER_MOVE", DiagnosticPhase.Borrowck, "value `value` used after move", span_create(file, 3, 6, 5));
  set diag.labels = [
    previous_label("move happened here", span_create(file, 2, 13, 5)),
    primary_label("use after move is forbidden", span_create(file, 3, 6, 5))
  ];
  set diag = diagnostic_with_explanation(diag, "ownership moved at line 2 and the later use happens after that transfer");
  set diag = diagnostic_with_probable_fix(diag, "clone `value`, borrow it, or reinitialize it before the later use");
  set diag = diagnostic_add_pipeline_context(diag, "lexer");
  set diag = diagnostic_add_pipeline_context(diag, "parser");
  set diag = diagnostic_add_pipeline_context(diag, "AST");
  set diag = diagnostic_add_pipeline_context(diag, "HIR");
  set diag = diagnostic_add_pipeline_context(diag, "sema");
  set diag = diagnostic_add_pipeline_context(diag, "borrowck [FAILED]");
  give diag;
}

proc sample_backend_diagnostic() -> Diagnostic {
  give backend_command_failed(
    DiagnosticPhase.Linker,
    "LINKER_E_OBJECT_FILE_ABSENT",
    "linker could not find the object file",
    "llvm",
    "x86_64-linux",
    "ld build/main.o -o build/main",
    "ld: cannot find build/main.o",
    "build/main",
    span_create(
      "src/vitte/compiler/tests/diagnostics/backend/link_failure.vit",
      1,
      1,
      12
    )
  );
}

proc sample_parser_diagnostic() -> Diagnostic {
  give parser_unclosed_block(
    span_create("src/vitte/compiler/tests/diagnostics/parser/unclosed_block.vit", 1, 1, 5),
    span_create("src/vitte/compiler/tests/diagnostics/parser/unclosed_block.vit", 2, 1, 1)
  );
}

proc diagnostic_has_default_context(diag: Diagnostic) -> bool {
  give diag.rule != ""
    and diag.explanation != ""
    and diag.root_cause != ""
    and diag.probable_fix != ""
    and diag.documentation_url != ""
    and len(diag.pipeline_context) >= 6
    and len(diag.notes) > 0
    and len(diag.helps) > 0
    and len(diag.suggestions) > 0
    and len(diagnostic_fix_plans(diag)) > 0
    and diagnostic_quality_score(diag) >= 70;
}

proc rendered_has_default_context(diag: Diagnostic) -> bool {
  let actual: string = render_report(diagnostic_report([diag]), human_config());
  give find(actual, "clear, contextual, and correction-oriented diagnostics") >= 0
    and find(actual, "Pipeline:") >= 0
    and find(actual, "correction_strategy") >= 0
    and find(actual, "recovery_scope") >= 0
    and find(actual, "confidence") >= 0
    and find(actual, "docs: docs://") >= 0
    and find(actual, "step 1: ") >= 0
    and find(actual, "help: ") >= 0
    and find(actual, "suggestion:") >= 0;
}

proc json_has_default_context(diag: Diagnostic) -> bool {
  let actual: string = json_diagnostic(diag);
  give find(actual, "\"explanation\": \"") >= 0
    and find(actual, "\"root_cause\": \"") >= 0
    and find(actual, "\"probable_fix\": \"") >= 0
    and find(actual, "\"documentation_url\": \"docs://") >= 0
    and find(actual, "\"pipeline_context\": [") >= 0
    and find(actual, "correction_strategy") >= 0
    and find(actual, "\"family\": \"") >= 0
    and find(actual, "\"strategy\": \"") >= 0
    and find(actual, "\"recovery_scope\": \"") >= 0
    and find(actual, "\"fixes\": [") >= 0
    and find(actual, "\"quality\": {") >= 0
    and find(actual, "\"suggestions\": [") >= 0
    and find(actual, "\"confidence\": \"") >= 0;
}

proc lsp_has_machine_context(diag: Diagnostic) -> bool {
  let actual: LspDiagnostic = lsp_diagnostic(diag);
  give find(actual.data, "family") >= 0
    and find(actual.data, "strategy") >= 0
    and find(actual.data, "recovery_scope") >= 0
    and find(actual.data, "confidence") >= 0
    and find(actual.data, "quality") >= 0
    and find(actual.data, "fixes") >= 0;
}

proc lsp_has_canonical_context(diag: Diagnostic) -> bool {
  let context: LspCanonicalContext = lsp_canonical_context("ir_validate", "invalid-method-dispatch-target", "invalid-method-dispatch-target");
  let actual: LspDiagnostic = lsp_diagnostic_with_canonical_context(diag, context);
  let params: LspPublishDiagnosticsParams = lsp_publish_report_with_canonical_context("file:///tmp/sample.vit", diagnostic_report([diag]), 7, context);
  give actual.canonical_context.pipeline_failed_at == "ir_validate"
    and actual.canonical_context.pipeline_failure_reason == "invalid-method-dispatch-target"
    and actual.canonical_context.validation_reason == "invalid-method-dispatch-target"
    and find(actual.data, "pipeline_failed_at=ir_validate") >= 0
    and find(actual.data, "pipeline_failure_reason=invalid-method-dispatch-target") >= 0
    and find(actual.data, "validation_reason=invalid-method-dispatch-target") >= 0
    and params.canonical_context.pipeline_failed_at == "ir_validate"
    and len(params.diagnostics) == 1
    and params.diagnostics[0].canonical_context.validation_reason == "invalid-method-dispatch-target";
}

proc diagnostic_has_suggestion_text(diag: Diagnostic, text: string) -> bool {
  let i: u64 = 0;
  while i < len(diag.suggestions) {
    if find(diag.suggestions[i].message, text) >= 0 {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc test_parser_suggestion_list_contract() -> bool {
  let diag: Diagnostic = sample_parser_diagnostic();
  if len(diag.suggestions) < 2 {
    give false;
  }

  let first: DiagnosticSuggestion = diag.suggestions[0];
  give first.applicability == DiagnosticApplicability.Machine
    and first.machine_applicable
    and first.replacement == "}"
    and diagnostic_has_suggestion_text(diag, "nearest opened block")
    and len(diag.suggestions) <= 5;
}

proc test_json_suggestion_applicability_contract() -> bool {
  let parser_json: string = json_diagnostic(sample_parser_diagnostic());
  let typeck_json: string = json_diagnostic(sample_typeck_diagnostic());
  give find(parser_json, "\"applicability\": \"machine\"") >= 0
    and find(parser_json, "\"machine_applicable\": true") >= 0
    and find(typeck_json, "\"applicability\": \"maybe_machine\"") >= 0
    and find(typeck_json, "\"confidence\": \"medium\"") >= 0;
}

proc test_lsp_code_action_contract() -> bool {
  let diag: Diagnostic = sample_parser_diagnostic();
  let actions: [LspCodeAction] = lsp_code_actions(diag);
  if len(actions) == 0 {
    give false;
  }

  give actions[0].kind == "quickfix"
    and actions[0].replacement == "}"
    and actions[0].applicability == "machine"
    and actions[0].diagnostic_code == "P000_UNBALANCED";
}

proc test_typeck_and_borrowck_suggestion_catalog_contract() -> bool {
  let typeck: Diagnostic = sample_typeck_diagnostic();
  let borrowck: Diagnostic = sample_borrowck_diagnostic();
  let report: DiagnosticReport = diagnostic_report([typeck, borrowck]);
  let actions: [LspCodeAction] = lsp_report_code_actions(report);
  give diagnostic_has_suggestion_text(typeck, "expected type")
    and diagnostic_has_suggestion_text(typeck, "broader API contract")
    and diagnostic_has_suggestion_text(borrowck, "borrow the value before the move")
    and diagnostic_has_suggestion_text(borrowck, "reorder this use before the move")
    and len(actions) >= len(typeck.suggestions) + len(borrowck.suggestions);
}

proc test_rendered_suggestion_applicability_contract() -> bool {
  let actual: string = render_report(diagnostic_report([sample_parser_diagnostic()]), human_config());
  give find(actual, "[machine]") >= 0
    and find(actual, "high confidence") >= 0
    and find(actual, "suggestion: insert") >= 0;
}

proc test_colored_diagnostic_output() -> bool {
  let actual: string = render_report(diagnostic_report([sample_parser_diagnostic()]), color_human_config());
  give find(actual, "\u001b[1m") >= 0
    and find(actual, "\u001b[31m") >= 0
    and find(actual, "\u001b[36m") >= 0
    and find(actual, "help: ") >= 0;
}

proc explain_has_actionable_context(code: string) -> bool {
  let actual: string = diagnostic_explain_text(code);
  give find(actual, "error code: ") >= 0
    and find(actual, "lang: en") >= 0
    and find(actual, "message: ") >= 0
    and find(actual, "summary: ") >= 0
    and find(actual, "cause: ") >= 0
    and find(actual, "step 1: ") >= 0
    and find(actual, "correction strategy: ") >= 0
    and find(actual, "recovery scope: ") >= 0
    and find(actual, "fix: ") >= 0
    and find(actual, "example: ") >= 0
    and find(actual, "quick fix: ") >= 0;
}

proc explain_has_localized_context(code: string, lang: string) -> bool {
  let actual: string = diagnostic_explain_text_lang(code, lang);
  give find(actual, "error code: " + code) >= 0
    and find(actual, "lang: ") >= 0
    and find(actual, "message: ") >= 0
    and find(actual, "summary: ") >= 0
    and find(actual, "cause: ") >= 0
    and find(actual, "step 1: ") >= 0
    and find(actual, "fix: ") >= 0
    and find(actual, "example: ") >= 0;
}

proc test_typeck_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_typeck_diagnostic();
  give diagnostic_has_default_context(diag) and rendered_has_default_context(diag) and json_has_default_context(diag);
}

proc test_lexer_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_lexer_diagnostic();
  give diagnostic_has_default_context(diag) and rendered_has_default_context(diag) and json_has_default_context(diag);
}

proc test_parser_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_parser_diagnostic();
  give diagnostic_has_default_context(diag) and rendered_has_default_context(diag) and json_has_default_context(diag) and diag.documentation_url == "docs://language/parser";
}

proc test_borrowck_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_borrowck_diagnostic();
  give diagnostic_has_default_context(diag) and rendered_has_default_context(diag) and json_has_default_context(diag);
}

proc test_backend_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_backend_diagnostic();
  give diagnostic_has_default_context(diag) and rendered_has_default_context(diag) and json_has_default_context(diag);
}

proc test_machine_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_parser_diagnostic();
  let report: DiagnosticReport = diagnostic_report([sample_parser_diagnostic(), sample_typeck_diagnostic()]);
  give lsp_has_machine_context(diag)
    and lsp_has_canonical_context(diag)
    and explain_has_actionable_context("E0001")
    and explain_has_actionable_context("P000_UNBALANCED")
    and explain_has_actionable_context("TYPECK_E_ASSIGN_MISMATCH")
    and explain_has_actionable_context("BORROWCK_E_USE_AFTER_MOVE")
    and explain_has_localized_context("E0001", "fr")
    and report.root_count >= 1
    and report.quality_score >= 70;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  let typeck_ok: bool = test_typeck_diagnostic_contract();
  let lexer_ok: bool = test_lexer_diagnostic_contract();
  let parser_ok: bool = test_parser_diagnostic_contract();
  let borrowck_ok: bool = test_borrowck_diagnostic_contract();
  let backend_ok: bool = test_backend_diagnostic_contract();
  let machine_ok: bool = test_machine_diagnostic_contract();
  let parser_suggestions_ok: bool = test_parser_suggestion_list_contract();
  let json_suggestions_ok: bool = test_json_suggestion_applicability_contract();
  let lsp_actions_ok: bool = test_lsp_code_action_contract();
  let catalog_ok: bool = test_typeck_and_borrowck_suggestion_catalog_contract();
  let rendered_suggestions_ok: bool = test_rendered_suggestion_applicability_contract();
  if typeck_ok == false {
    set failures = failures + 1;
  }
  if lexer_ok == false {
    set failures = failures + 1;
  }
  if parser_ok == false {
    set failures = failures + 1;
  }
  if borrowck_ok == false {
    set failures = failures + 1;
  }
  if backend_ok == false {
    set failures = failures + 1;
  }
  if machine_ok == false {
    set failures = failures + 1;
  }
  if parser_suggestions_ok == false {
    set failures = failures + 1;
  }
  if json_suggestions_ok == false {
    set failures = failures + 1;
  }
  if lsp_actions_ok == false {
    set failures = failures + 1;
  }
  if catalog_ok == false {
    set failures = failures + 1;
  }
  if rendered_suggestions_ok == false {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
