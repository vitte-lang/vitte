proc test_machine_diagnostic_contract() -> bool {
  let diag: Diagnostic = sample_parser_diagnostic();
  let report: DiagnosticReport = diagnostic_report([sample_parser_diagnostic(), sample_typeck_diagnostic()]);
  give lsp_has_machine_context(diag)
    and lsp_has_canonical_context(diag)
    and explain_has_actionable_context("E0001")
    and explain_has_actionable_context("P000_UNBALANCED")
    and explain_has_actionable_context("TYPECK_E_ASSIGN_MISMATCH")
    and explain_has_actionable_context("BORROWCK_E_USE_AFTER_MOVE")
    and explain_has_localized_context("E0001", "fr")
    and report.root_count >= 1
    and report.quality_score >= 70;
}

proc sample_cascade_diagnostic(line: u64, message: string) -> Diagnostic {
  give diagnostic_error(
    "TYPECK_E_ASSIGN_MISMATCH",
    DiagnosticPhase.Typeck,
    message,
    span_range("src/vitte/compiler/tests/diagnostics/parser/cascade.vit", line, 3, line, 9)
  );
}

proc test_report_deduplicates_and_limits_cascades() -> bool {
  let root: Diagnostic = parser_unclosed_block(
    span_create("src/vitte/compiler/tests/diagnostics/parser/cascade.vit", 1, 1, 5),
    span_create("src/vitte/compiler/tests/diagnostics/parser/cascade.vit", 2, 1, 1)
  );
  let duplicate: Diagnostic = parser_unclosed_block(
    span_create("src/vitte/compiler/tests/diagnostics/parser/cascade.vit", 1, 1, 5),
    span_create("src/vitte/compiler/tests/diagnostics/parser/cascade.vit", 2, 1, 1)
  );
  let report: DiagnosticReport = diagnostic_report([
    root,
    duplicate,
    sample_cascade_diagnostic(2, "derived mismatch one"),
    sample_cascade_diagnostic(3, "derived mismatch two"),
    sample_cascade_diagnostic(4, "derived mismatch three"),
    sample_cascade_diagnostic(5, "derived mismatch four")
  ]);
  let rendered: string = render_report(report, human_config());
  let encoded: string = json_diagnostic(report.diagnostics[0]);
  give len(report.diagnostics) == 4
    and report.duplicate_count == 1
    and report.suppressed_cascade_count == 1
    and report.cascade_count == 3
    and report.recovery_possible
    and report.diagnostics[1].cascade
    and report.diagnostics[1].cascade_of == report.diagnostics[0].primary_error_key
    and find(rendered, "cascade-of: ") >= 0
    and find(encoded, "\"valid_example\": \"") >= 0
    and find(encoded, "\"invalid_example\": \"") >= 0;
}

proc test_report_orders_diagnostics_by_file_and_position() -> bool {
  let first: Diagnostic = diagnostic_error("TYPECK_E_LATE", DiagnosticPhase.Typeck, "late", span_create("b.vit", 1, 1, 1));
  let second: Diagnostic = diagnostic_error("LEX_E_FIRST", DiagnosticPhase.Lexer, "first", span_create("a.vit", 4, 9, 1));
  let third: Diagnostic = diagnostic_error("PARSE_E_EARLIER", DiagnosticPhase.Parser, "earlier", span_create("a.vit", 2, 3, 1));
  let report: DiagnosticReport = diagnostic_report([first, second, third]);
  give len(report.diagnostics) == 3
    and report.diagnostics[0].code == "PARSE_E_EARLIER"
    and report.diagnostics[1].code == "LEX_E_FIRST"
    and report.diagnostics[2].code == "TYPECK_E_LATE";
}

proc test_text_diagnostic_format_is_stable() -> bool {
  let diag: Diagnostic = diagnostic_error("TYPECK_E_TEXT", DiagnosticPhase.Typeck, "text format", span_create("text.vit", 3, 5, 1));
  let config: DiagnosticRenderConfig = default_render_config();
  set config.style = DiagnosticStyle.Text;
  set config.color = false;
  let line: string = diagnostic_text_line(diag);
  let rendered: string = render_report(diagnostic_report([diag]), config);
  give line == "severity=error code=TYPECK_E_TEXT phase=typeck span=text.vit:3:5 message=text format"
    and rendered == line;
}

proc test_single_diagnostic_architecture_covers_compiler_pipeline() -> bool {
  let span0 = span_create("architecture.vit", 1, 1, 1);
  let lexer: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Lexer, "LEX_E_ARCH", "lexer contract", span0);
  let parser: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Parser, "PARSE_E_ARCH", "parser contract", span0);
  let resolver: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Resolver, "SEMA_E_UNKNOWN_SYMBOL", "resolver contract", span0);
  let sema: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Sema, "SEMA_E_ARCH", "sema contract", span0);
  let typeck: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.TypeChecker, "TYPECK_E_ARCH", "type contract", span0);
  let borrowck: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.BorrowChecker, "BORROWCK_E_ARCH", "borrow contract", span0);
  let mir: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Mir, "MIR_E_ARCH", "mir contract", span0);
  let backend: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Backend, "BACKEND_E_ARCH", "backend contract", span0);
  let linker: Diagnostic = compiler_diagnostic_error(CompilerDiagnosticStage.Linker, "LINK_E_ARCH", "linker contract", span0);
  let report: DiagnosticReport = compiler_diagnostic_report([lexer, parser, resolver, sema, typeck, borrowck, mir, backend, linker]);
  give diagnostic_architecture_covers_required_stages()
    and canonical_diagnostic_stage_count() == 9
    and len(report.diagnostics) == 9
    and lexer.phase == DiagnosticPhase.Lexer
    and parser.phase == DiagnosticPhase.Parser
    and resolver.phase == DiagnosticPhase.SymbolResolution
    and sema.phase == DiagnosticPhase.Sema
    and typeck.phase == DiagnosticPhase.Typeck
    and borrowck.phase == DiagnosticPhase.Borrowck
    and mir.phase == DiagnosticPhase.Mir
    and backend.phase == DiagnosticPhase.Backend
    and linker.phase == DiagnosticPhase.Linker
    and stage_phase(CompilerDiagnosticStage.TypeChecker) == DiagnosticPhase.Typeck
    and stage_component(CompilerDiagnosticStage.Linker) == "backend.linker"
    and find(linker.pipeline_context[6], "stage=linker") >= 0
    and find(typeck.probable_fix, "type contract") >= 0;
}

proc test_phase_policy_defines_blocking_errors_precisely() -> bool {
  let lexer: DiagnosticPhasePolicy = diagnostic_phase_policy(DiagnosticPhase.Lexer);
  let typeck: DiagnosticPhasePolicy = diagnostic_phase_policy(DiagnosticPhase.Typeck);
  let borrowck: DiagnosticPhasePolicy = diagnostic_phase_policy(DiagnosticPhase.Borrowck);
  let linker: DiagnosticPhasePolicy = diagnostic_phase_policy(DiagnosticPhase.Linker);
  let lexer_blocks: [string] = diagnostic_phase_blocks(DiagnosticPhase.Lexer);
  let typeck_roots: [string] = diagnostic_phase_root_error_codes(DiagnosticPhase.Typeck);
  give lexer.blocking_after_error
    and lexer.may_continue_after_error
    and lexer.independent_after_error == false
    and len(lexer.blocks) == 9
    and lexer_blocks[0] == "parser"
    and lexer_blocks[8] == "linker"
    and lexer.root_error_codes[0] == "LEX_E_INVALID_CHAR"
    and typeck.independent_after_error
    and typeck.blocks[0] == "borrowck"
    and typeck_roots[2] == "TYPECK_E_MISSING_GIVE"
    and borrowck.blocks[0] == "mir"
    and borrowck.root_error_codes[0] == "BORROWCK_E_USE_AFTER_MOVE"
    and linker.may_continue_after_error == false
    and linker.root_error_codes[2] == "LINK_E_SYSTEM_LINKER_FAILED";
}

proc test_ice_is_internal_and_carries_required_context() -> bool {
  let span0 = span_range("src/main.vit", 4, 3, 4, 8);
  let diag: Diagnostic = diagnostic_ice("TYPECK_E_WRONG_KIND", DiagnosticPhase.Typeck, "", "lower give expression", "assertion failed: inferred type slot empty\nstack frame detail", "", span0);
  give diag.code == "ICE0001"
    and diag.kind == DiagnosticKind.InternalCompiler
    and diag.phase == DiagnosticPhase.Internal
    and diag.span.file == "src/main.vit"
    and diag.internal_operation == "lower give expression"
    and diag.internal_cause == "assertion failed: inferred type slot empty"
    and diag.reproduction == "rerun the same command with the same source file"
    and diag.root_cause == "internal compiler defect during lower give expression"
    and find(diag.pipeline_context[0], "stable_id=ICE0001") >= 0
    and find(diag.pipeline_context[1], "ice_phase=typeck") >= 0
    and find(diag.pipeline_context[2], "vitte_file=src/main.vit") >= 0;
}

proc test_diagnostic_position_policy_is_explicit() -> bool {
  let mono: DiagnosticRenderConfig = monochrome_render_config();
  let terminal: DiagnosticRenderConfig = terminal_render_config();
  let ide: DiagnosticRenderConfig = ide_render_config();
  give DIAGNOSTIC_USER_COLUMN_BASE == 1
    and DIAGNOSTIC_USER_COLUMN_UNIT == "visual_unicode_column"
    and DIAGNOSTIC_INTERNAL_OFFSET_UNIT == "utf8_byte_offset"
    and DIAGNOSTIC_TAB_WIDTH == 4
    and find(diagnostic_position_policy_text(), "user columns start at 1") >= 0
    and find(diagnostic_position_policy_text(), "UTF-8 bytes") >= 0
    and diagnostic_internal_offset_text(12) == "utf8_byte_offset: 12"
    and mono.color == false
    and terminal.style == DiagnosticStyle.Human
    and terminal.color
    and ide.style == DiagnosticStyle.Lsp
    and ide.color == false;
}

proc test_all_renderers_share_the_same_diagnostic_object() -> bool {
  let diag0: Diagnostic = diagnostic_error("TYPECK_E_RENDER_SHARED", DiagnosticPhase.Typeck, "unicode café tab\tshape", span_create("unicode.vit", 2, 5, 4));
  let diag: Diagnostic = diagnostic_with_explanation(diag0, "same Diagnostic object feeds every renderer");
  let report: DiagnosticReport = diagnostic_report([diag]);
  let short_config: DiagnosticRenderConfig = monochrome_render_config();
  set short_config.style = DiagnosticStyle.Short;
  let human_config: DiagnosticRenderConfig = monochrome_render_config();
  set human_config.style = DiagnosticStyle.Human;
  let short_text: string = render_report(report, short_config);
  let human_text: string = render_report(report, human_config);
  let json_text: string = json_report(report);
  let lsp_actual: LspDiagnostic = lsp_diagnostic(diag);
  let lsp_text: string = lsp_diagnostic_summary(lsp_actual);
  let sarif_text: string = sarif_report(report);
  give find(short_text, "TYPECK_E_RENDER_SHARED") >= 0
    and find(human_text, "unicode café tab") >= 0
    and find(json_text, "\"code\": \"TYPECK_E_RENDER_SHARED\"") >= 0
    and find(json_text, "\"message\": \"unicode café tab\\tshape\"") >= 0
    and find(lsp_text, "TYPECK_E_RENDER_SHARED") >= 0
    and find(sarif_text, "\"ruleId\": \"TYPECK_E_RENDER_SHARED\"") >= 0
    and find(sarif_text, "\"text\": \"unicode café tab\\tshape\"") >= 0;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  let typeck_ok: bool = test_typeck_diagnostic_contract();
  let lexer_ok: bool = test_lexer_diagnostic_contract();
  let parser_ok: bool = test_parser_diagnostic_contract();
  let borrowck_ok: bool = test_borrowck_diagnostic_contract();
  let backend_ok: bool = test_backend_diagnostic_contract();
  let machine_ok: bool = test_machine_diagnostic_contract();
  let parser_suggestions_ok: bool = test_parser_suggestion_list_contract();
  let json_suggestions_ok: bool = test_json_suggestion_applicability_contract();
  let lsp_actions_ok: bool = test_lsp_code_action_contract();
  let catalog_ok: bool = test_typeck_and_borrowck_suggestion_catalog_contract();
  let rendered_suggestions_ok: bool = test_rendered_suggestion_applicability_contract();
  let report_cascade_ok: bool = test_report_deduplicates_and_limits_cascades();
  let report_order_ok: bool = test_report_orders_diagnostics_by_file_and_position();
  let text_format_ok: bool = test_text_diagnostic_format_is_stable();
  let architecture_ok: bool = test_single_diagnostic_architecture_covers_compiler_pipeline();
  let phase_policy_ok: bool = test_phase_policy_defines_blocking_errors_precisely();
  let ice_context_ok: bool = test_ice_is_internal_and_carries_required_context();
  let position_policy_ok: bool = test_diagnostic_position_policy_is_explicit();
  let shared_render_ok: bool = test_all_renderers_share_the_same_diagnostic_object();
  if typeck_ok == false {
    set failures = failures + 1;
  }
  if lexer_ok == false {
    set failures = failures + 1;
  }
  if parser_ok == false {
    set failures = failures + 1;
  }
  if borrowck_ok == false {
    set failures = failures + 1;
  }
  if backend_ok == false {
    set failures = failures + 1;
  }
  if machine_ok == false {
    set failures = failures + 1;
  }
  if parser_suggestions_ok == false {
    set failures = failures + 1;
  }
  if json_suggestions_ok == false {
    set failures = failures + 1;
  }
  if lsp_actions_ok == false {
    set failures = failures + 1;
  }
  if catalog_ok == false {
    set failures = failures + 1;
  }
  if rendered_suggestions_ok == false {
    set failures = failures + 1;
  }
  if report_cascade_ok == false {
    set failures = failures + 1;
  }
  if report_order_ok == false {
    set failures = failures + 1;
  }
  if text_format_ok == false {
    set failures = failures + 1;
  }
  if architecture_ok == false {
    set failures = failures + 1;
  }
  if phase_policy_ok == false {
    set failures = failures + 1;
  }
  if ice_context_ok == false {
    set failures = failures + 1;
  }
  if position_policy_ok == false {
    set failures = failures + 1;
  }
  if shared_render_ok == false {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
