const VERSION_TEXT: string = "diagnostic snapshot tests 0.1.0"
const BANNER_TEXT: string = "diagnostic snapshot tests"

proc human_config() -> DiagnosticRenderConfig {
  let config: DiagnosticRenderConfig = default_render_config();
  set config.style = DiagnosticStyle.Human;
  set config.color = false;
  set config.show_phase = false;
  give config;
}

proc color_human_config() -> DiagnosticRenderConfig {
  let config: DiagnosticRenderConfig = default_render_config();
  set config.style = DiagnosticStyle.Human;
  set config.color = true;
  set config.show_phase = false;
  give config;
}

proc sample_typeck_diagnostic() -> Diagnostic {
  let file: string = "src/vitte/compiler/tests/diagnostics/typeck/assign_mismatch.vit";
  let diag: Diagnostic = diagnostic_error("TYPECK_E_ASSIGN_MISMATCH", DiagnosticPhase.Typeck, "cannot assign string to i32", span_range(file, 8, 9, 8, 16));
  set diag.labels = [
    previous_label("variable declared here as i32", span_create(file, 4, 5, 1)),
    primary_label("expected i32, found string", span_range(file, 8, 9, 8, 16))
  ];
  set diag = diagnostic_with_explanation(diag, "Vitte does not implicitly convert string to i32");
  set diag = diagnostic_with_probable_fix(diag, "use an integer literal, or change x to string");
  set diag = diagnostic_with_documentation(diag, "docs://language/type-system/assignment-compatibility");
  set diag = diagnostic_with_suggestion_detail(diag, DiagnosticSuggestionKind.Replace, "replace the string literal with an integer literal", "0", span_range(file, 8, 9, 8, 16), true, "medium", "the target binding `x` is declared as `i32`");
  set diag = diagnostic_add_pipeline_context(diag, "lexer");
  set diag = diagnostic_add_pipeline_context(diag, "parser");
  set diag = diagnostic_add_pipeline_context(diag, "AST");
  set diag = diagnostic_add_pipeline_context(diag, "HIR");
  set diag = diagnostic_add_pipeline_context(diag, "sema");
  set diag = diagnostic_add_pipeline_context(diag, "typeck [FAILED]");
  give diag;
}

proc sample_lexer_diagnostic() -> Diagnostic {
  give lexer_unterminated_string(span_range("src/vitte/compiler/tests/diagnostics/lexer/unterminated_string.vit", 1, 9, 1, 22));
}

proc sample_borrowck_diagnostic() -> Diagnostic {
  let file: string = "src/vitte/compiler/tests/diagnostics/borrowck/use_after_move.vit";
  let diag: Diagnostic = diagnostic_error("BORROW_E_USE_AFTER_MOVE", DiagnosticPhase.Borrowck, "value `value` used after move", span_create(file, 3, 6, 5));
  set diag.labels = [
    previous_label("move happened here", span_create(file, 2, 13, 5)),
    primary_label("use after move is forbidden", span_create(file, 3, 6, 5))
  ];
  set diag = diagnostic_with_explanation(diag, "ownership moved at line 2 and the later use happens after that transfer");
  set diag = diagnostic_with_probable_fix(diag, "clone `value`, borrow it, or reinitialize it before the later use");
  set diag = diagnostic_add_pipeline_context(diag, "lexer");
  set diag = diagnostic_add_pipeline_context(diag, "parser");
  set diag = diagnostic_add_pipeline_context(diag, "AST");
  set diag = diagnostic_add_pipeline_context(diag, "HIR");
  set diag = diagnostic_add_pipeline_context(diag, "sema");
  set diag = diagnostic_add_pipeline_context(diag, "borrowck [FAILED]");
  give diag;
}

