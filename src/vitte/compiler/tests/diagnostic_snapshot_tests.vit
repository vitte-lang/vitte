    and find(actual, "cause: ") >= 0
    and find(actual, "step 1: ") >= 0
    and find(actual, "correction strategy: ") >= 0
    and find(actual, "recovery scope: ") >= 0
    and find(actual, "fix: ") >= 0
    and find(actual, "example: ") >= 0
    and find(actual, "quick fix: ") >= 0;
}

