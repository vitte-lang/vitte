space vitte/compiler/tests/borrowck_tests

use vitte/compiler/analysis/borrowck.{ BorrowCheckResult, borrow_check_hir, borrow_check_hir_mir, borrow_check_source }
use vitte/compiler/diagnostics/diagnostic.{ Diagnostic, DiagnosticPhase, DiagnosticSeverity, SourceSpan }
use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/middle/hir/lower_ast.{ lower_ast_to_hir }
use vitte/compiler/middle/lower/hir_to_mir.{ lower_hir_to_mir }

const VERSION_TEXT: string = "analysis borrowck tests 0.2.0"
const BANNER_TEXT: string = "analysis borrowck tests"

proc has_code(result: BorrowCheckResult, code: string) -> bool {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc diagnostic_by_code(result: BorrowCheckResult, code: string) -> Diagnostic {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give result.diagnostics[i];
    }
    set i = i + 1;
  }
  give Diagnostic {
    code: "",
    phase: DiagnosticPhase.Unknown,
    severity: DiagnosticSeverity.Error,
    rule: "",
    message: "",
    explanation: "",
    technical_note: "",
    labels: [],
    notes: [],
    helps: [],
    suggestions: [],
    documentation_url: "",
    root_cause: "",
    cause_chain: [],
    pipeline_context: [],
    related_errors: [],
    probable_fix: "",
    subject_symbol: "",
    subject_type: "",
    subject_borrow: "",
    span: SourceSpan { file: "", start_line: 0, start_column: 0, end_line: 0, end_column: 0, length: 0, valid: false },
    deprecated: false,
    unnecessary: false,
    fatal: false,
    valid: false
  };
}

proc same_codes(left: BorrowCheckResult, right: BorrowCheckResult) -> bool {
  let i: u64 = 0;
  while i < len(left.diagnostics) {
    if not has_code(right, left.diagnostics[i].code) {
      give false;
    }
    set i = i + 1;
  }
  i = 0;
  while i < len(right.diagnostics) {
    if not has_code(left, right.diagnostics[i].code) {
      give false;
    }
    set i = i + 1;
  }
  give left.valid == right.valid;
}

proc borrow_check_frontend_hir_mir(path: string, source: string) -> BorrowCheckResult {
  let fe: FrontendOutput = frontend_run(path, source);
  let hir = lower_ast_to_hir(fe);
  let mir = lower_hir_to_mir(hir);
  give borrow_check_hir_mir(path, hir, mir);
}

proc test_valid_reinit_after_move() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let y = x\n" +
    "set x = make_box()\n" +
    "let z = x\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_valid_reinit.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_move_after_move() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let y = x\n" +
    "let z = x\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_move_after_move.vit", source);
  give has_code(result, "BORROWCK_E_MOVE_AFTER_MOVE");
}

proc test_move_after_move_tells_temporal_story() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let y = x\n" +
    "let z = x\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_move_after_move_story.vit", source);
  let diag = diagnostic_by_code(result, "BORROWCK_E_MOVE_AFTER_MOVE");
  give diag.valid
    and find(diag.rule, "borrowed values") >= 0
    and diag.subject_symbol == "x"
    and len(diag.cause_chain) >= 3
    and find(diag.probable_fix, "reinitialize") >= 0;
}

proc test_write_while_borrowed() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let r = &x\n" +
    "set x = make_box()\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_write_while_borrowed.vit", source);
  give has_code(result, "BORROWCK_E_WRITE_WHILE_BORROWED");
}

proc test_mutable_borrow_conflict() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let a = &x\n" +
    "let b = &mut x\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_mut_conflict.vit", source);
  give has_code(result, "BORROWCK_E_MUTABLE_BORROW_CONFLICT");
}

proc test_mutable_borrow_conflict_reports_borrow_window() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let a = &x\n" +
    "let b = &mut x\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_mut_conflict_story.vit", source);
  let diag = diagnostic_by_code(result, "BORROWCK_E_MUTABLE_BORROW_CONFLICT");
  give diag.valid
    and diag.subject_symbol == "x"
    and diag.subject_borrow != ""
    and len(diag.cause_chain) >= 3
    and find(diag.probable_fix, "scope") >= 0;
}

proc test_return_ref_to_local() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "give &x\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_return_ref.vit", source);
  give has_code(result, "BORROWCK_E_RETURN_REF_TO_LOCAL");
}

proc test_return_borrow_of_local() -> bool {
  let source: string =
    "let x = make_box()\n" +
    "let r = &x\n" +
    "give r\n";
  let result: BorrowCheckResult = borrow_check_source("borrowck_return_alias.vit", source);
  give has_code(result, "BORROWCK_E_RETURN_BORROW_OF_LOCAL");
}

proc test_hir_borrowck_path() -> bool {
  let source: string =
    "proc main() { let x = make_box(); let r = &x; give r; }\n";
  let fe: FrontendOutput = frontend_run("borrowck_hir_path.vit", source);
  let hir = lower_ast_to_hir(fe);
  let mir = lower_hir_to_mir(hir);
  let canonical: BorrowCheckResult = borrow_check_hir_mir("borrowck_hir_path.vit", hir, mir);
  let wrapped: BorrowCheckResult = borrow_check_hir("borrowck_hir_path.vit", hir);
  give has_code(canonical, "BORROWCK_E_RETURN_BORROW_OF_LOCAL")
    and same_codes(canonical, wrapped);
}

proc test_branch_borrow_conflict_after_join() -> bool {
  let source: string =
    "proc main() { let x = make_box(); if flag { let a = &x; } else { let b = &x; } set x = make_box(); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_branch_join_conflict.vit", source);
  give has_code(result, "BORROWCK_E_WRITE_WHILE_BORROWED");
}

proc test_branch_move_after_join() -> bool {
  let source: string =
    "proc main() { let x = make_box(); if flag { let y = x; } else { let z = make_box(); } give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_branch_move_join.vit", source);
  give has_code(result, "BORROWCK_E_USE_AFTER_MOVE");
}

proc test_use_after_move_reports_previous_move() -> bool {
  let source: string =
    "proc main() { let x = make_box(); if flag { let y = x; } else { let z = make_box(); } give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_use_after_move_story.vit", source);
  let diag = diagnostic_by_code(result, "BORROWCK_E_USE_AFTER_MOVE");
  give diag.valid
    and diag.subject_symbol == "x"
    and len(diag.cause_chain) >= 3
    and find(diag.probable_fix, "reinitialize") >= 0;
}

proc test_field_borrow_blocks_root_write() -> bool {
  let source: string =
    "proc main() { let x = make_box(); let r = &x.field; set x = make_box(); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_field_borrow_write.vit", source);
  give has_code(result, "BORROWCK_E_WRITE_WHILE_BORROWED");
}

proc test_binary_assignment_does_not_move_operand() -> bool {
  let source: string =
    "proc main() { let x = 1; let y = x + 1; give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_binary_no_move.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_copy_binding_does_not_move_source() -> bool {
  let source: string =
    "proc main() { let x = 1; let y = x; give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_copy_binding.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_branch_loan_expires_at_scope_end() -> bool {
  let source: string =
    "proc main() { let x = make_box(); if true { let r = &x; let keep = 0; } set x = make_box(); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_branch_scope_end.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_partial_move_preserves_disjoint_field() -> bool {
  let source: string =
    "proc main() { let x = make_box(); let y = x.left; give x.right; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_partial_move_field.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_hir_and_lowered_mir_agree_on_copy_and_scope() -> bool {
  let source: string =
    "proc main() { let x = 1; if true { let r = &x; let keep = 0; } let y = x; give x; }\n";
  let fe: FrontendOutput = frontend_run("borrowck_hir_mir_agree.vit", source);
  let hir = lower_ast_to_hir(fe);
  let mir = lower_hir_to_mir(hir);
  let hir_result: BorrowCheckResult = borrow_check_hir("borrowck_hir_mir_agree.vit", hir);
  let mir_result: BorrowCheckResult = borrow_check_hir_mir("borrowck_hir_mir_agree.vit", hir, mir);
  give same_codes(hir_result, mir_result);
}

proc test_borrow_param_call_does_not_move_source() -> bool {
  let source: string =
    "proc keep(borrow value: Box) -> int { give 0; }\n" +
    "proc main() { let x = make_box(); let y = keep(x); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_borrow_param_call.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_owned_param_call_moves_source() -> bool {
  let source: string =
    "proc take(value: Box) -> int { give 0; }\n" +
    "proc main() { let x = make_box(); let y = take(x); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_owned_param_call.vit", source);
  give has_code(result, "BORROWCK_E_USE_AFTER_MOVE");
}

proc test_impl_borrow_param_call_uses_canonical_mir_signature() -> bool {
  let source: string =
    "form Box { value: int }\n" +
    "trait Keep {\n" +
    "  proc keep(self: Self, borrow value: Box) -> int;\n" +
    "}\n" +
    "impl Keep for Box {\n" +
    "  proc keep(self: Self, borrow value: Box) -> int { give 0; }\n" +
    "}\n" +
    "proc main() { let recv = Box { value: 1 }; let x = Box { value: 2 }; let y = recv.keep(x); set x = Box { value: 3 }; give y; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_impl_borrow_param_call.vit", source);
  give has_code(result, "BORROWCK_E_WRITE_WHILE_BORROWED");
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_valid_reinit_after_move() { set failures = failures + 1; }
  if not test_move_after_move() { set failures = failures + 1; }
  if not test_move_after_move_tells_temporal_story() { set failures = failures + 1; }
  if not test_write_while_borrowed() { set failures = failures + 1; }
  if not test_mutable_borrow_conflict() { set failures = failures + 1; }
  if not test_mutable_borrow_conflict_reports_borrow_window() { set failures = failures + 1; }
  if not test_return_ref_to_local() { set failures = failures + 1; }
  if not test_return_borrow_of_local() { set failures = failures + 1; }
  if not test_hir_borrowck_path() { set failures = failures + 1; }
  if not test_branch_borrow_conflict_after_join() { set failures = failures + 1; }
  if not test_branch_move_after_join() { set failures = failures + 1; }
  if not test_use_after_move_reports_previous_move() { set failures = failures + 1; }
  if not test_field_borrow_blocks_root_write() { set failures = failures + 1; }
  if not test_binary_assignment_does_not_move_operand() { set failures = failures + 1; }
  if not test_copy_binding_does_not_move_source() { set failures = failures + 1; }
  if not test_branch_loan_expires_at_scope_end() { set failures = failures + 1; }
  if not test_partial_move_preserves_disjoint_field() { set failures = failures + 1; }
  if not test_hir_and_lowered_mir_agree_on_copy_and_scope() { set failures = failures + 1; }
  if not test_borrow_param_call_does_not_move_source() { set failures = failures + 1; }
  if not test_owned_param_call_moves_source() { set failures = failures + 1; }
  if not test_impl_borrow_param_call_uses_canonical_mir_signature() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
