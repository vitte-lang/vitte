    "proc main() { let x = make_box(); let y = keep(x); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_borrow_param_call.vit", source);
  give result.valid and len(result.diagnostics) == 0;
}

proc test_owned_param_call_moves_source() -> bool {
  let source: string =
    "proc take(value: Box) -> int { give 0; }\n" +
    "proc main() { let x = make_box(); let y = take(x); give x; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_owned_param_call.vit", source);
  give has_code(result, "BORROWCK_E_USE_AFTER_MOVE");
}

proc test_impl_borrow_param_call_uses_canonical_mir_signature() -> bool {
  let source: string =
    "form Box { value: int }\n" +
    "trait Keep {\n" +
    "  proc keep(self: Self, borrow value: Box) -> int;\n" +
    "}\n" +
    "impl Keep for Box {\n" +
    "  proc keep(self: Self, borrow value: Box) -> int { give 0; }\n" +
    "}\n" +
    "proc main() { let recv = Box { value: 1 }; let x = Box { value: 2 }; let y = recv.keep(x); set x = Box { value: 3 }; give y; }\n";
  let result: BorrowCheckResult = borrow_check_frontend_hir_mir("borrowck_impl_borrow_param_call.vit", source);
  give has_code(result, "BORROWCK_E_WRITE_WHILE_BORROWED");
}

proc test_ownership_helpers_track_places_and_borrows() -> bool {
  let table0: OwnershipTable = ownership_table_empty();
  let table1: OwnershipTable = declare_local(table0, "value.field", 1, true);
  let table2: OwnershipTable = add_shared_borrow(table1, "value.field", 2);
  let table3: OwnershipTable = set_mutable_borrow(table2, "value.field", true, 3);
  let table4: OwnershipTable = release_shared_borrow(table3, "value.field", 4);
  let table5: OwnershipTable = mark_moved(table4, "value.field", 5);
  let table6: OwnershipTable = mark_reinitialized(table5, "value.field", 6);
  give place_key(place_named("*value.field[0]")) == "*value.field[0]"
    and place_prefix(place_named("value"), place_named("value.field"))
    and place_overlap(place_named("value.field"), place_named("value.field.inner"))
    and shared_borrow_count(table3, "value.field") == 1
    and shared_borrow_count(table4, "value.field") == 0
    and is_mutably_borrowed(table3, "value.field")
    and is_moved(table5, "value.field")
    and not is_moved(table6, "value.field");
}

proc test_move_tracker_helpers_report_state_and_conflicts() -> bool {
  let tracker0: MoveTracker = move_tracker_empty();
  let tracker1: MoveTracker = tracker_record_move(tracker0, "value", 1);
  let tracker2: MoveTracker = tracker_record_use(tracker1, "value", 2);
  let tracker3: MoveTracker = tracker_record_reinit(tracker2, "value", 3);
  let tracker4: MoveTracker = tracker_record_shared_borrow(tracker3, "value", 4);
  let tracker5: MoveTracker = tracker_record_storage_dead(tracker4, "value", 5);
  give move_kind_name(MoveEventKind.BorrowShared) == "borrow_shared"
    and move_state_name(MoveState.Dead) == "dead"
    and event_consumes_value(MoveEventKind.Move)
    and event_reads_value(MoveEventKind.BorrowShared)
    and move_source_from_expr("value.field + 1") == "value.field"
    and tracker_has_conflicts(tracker2)
    and tracker_conflict_count(tracker2) == 1
    and tracker_is_valid(tracker3) == false
    and last_state_for(tracker5, "value") == MoveState.Dead;
}

proc test_loan_table_helpers_track_aliases_and_conflicts() -> bool {
  let table0: LoanTable = add_loan_auto(loan_table_empty(), "shared_ref", "value", LoanKind.Shared, 1, 10);
  let table1: LoanTable = add_loan_checked(table0, loan_create(9, "mut_ref", "value", LoanKind.Mutable, 2));
  let table2: LoanTable = deactivate_alias(table0, "shared_ref", 3);
  let table3: LoanTable = add_loan_auto(loan_table_empty(), "short_ref", "value", LoanKind.Shared, 1, 2);
  let table4: LoanTable = deactivate_expired_loans(table3, 5);
  give loan_kind_name(LoanKind.Mutable) == "mutable"
    and alias_is_active(table0, "shared_ref")
    and owner_for_alias(table0, "shared_ref") == "value"
    and kind_for_alias(table0, "shared_ref") == LoanKind.Shared
    and owner_has_conflict(table0, "value", LoanKind.Mutable)
    and not owner_has_active_mutable(table0, "value")
    and loan_table_has_conflicts(table1)
    and conflict_count(table1) == 1
    and not loan_table_is_valid(table1)
    and active_loan_count(table2) == 0
    and active_loan_count(table4) == 0;
}

proc test_lifetime_and_region_helpers_summarize_failures() -> bool {
  let regions0: RegionSolution = region_solution_empty();
  let regions1: RegionSolution = close_region(close_region(regions0, "missing", 2), "also_missing", 3);
  let lifetimes0: LifetimeResult = lifetime_result_empty(regions1);
  let lifetimes1: LifetimeResult = add_borrow_fact(lifetimes0, "alias", "owner", "alias_region", "owner_region", 4);
  let lifetimes2: LifetimeResult = add_return_fact(lifetimes1, "alias", "owner", "local_region", "return_region", 5);
  let lifetimes3: LifetimeResult = finalize_lifetimes(lifetimes2);
  let fact = lifetime_fact_full("alias", "owner", "escaped_region", "owner_region", 6, LifetimeFactKind.Escape, LifetimeEscapeKind.Return);
  let merged: RegionSolution = merge_region_solutions(lifetimes1.regions, lifetimes2.regions);
  give fact_kind_name(LifetimeFactKind.Borrow) == "borrow"
    and escape_kind_name(LifetimeEscapeKind.Return) == "return"
    and fact_is_escape(fact)
    and find(lifetime_fact_summary(fact), "escape return") >= 0
    and len(merged.regions) >= len(lifetimes1.regions)
    and not lifetimes3.valid
    and find(lifetime_result_summary(lifetimes3), "lifetimes failed") >= 0;
}

proc test_temporal_ownership_windows_enforce_alias_duration() -> bool {
  let valid_window: TemporalOwnershipWindow = temporal_ownership_window("value", "alias", 1, 10, 2, 8, false);
  let invalid_window: TemporalOwnershipWindow = temporal_ownership_window("value", "escaped_alias", 1, 5, 2, 9, false);
  let lifetimes0: LifetimeResult = lifetime_result_empty(region_solution_empty());
  let lifetimes1: LifetimeResult = add_temporal_ownership_fact(lifetimes0, valid_window);
  let lifetimes2: LifetimeResult = add_temporal_ownership_fact(lifetimes1, invalid_window);
  let finalized: LifetimeResult = finalize_lifetimes(lifetimes2);
  give temporal_window_valid(valid_window)
    and not temporal_window_valid(invalid_window)
    and find(temporal_window_summary(invalid_window), "invalid") >= 0
    and not finalized.valid
    and len(finalized.diagnostics) > 0
    and find(lifetime_result_summary(finalized), "lifetimes failed") >= 0;
}

proc test_lifetime_escape_detects_dangling_reference() -> bool {
  let lifetimes0: LifetimeResult = lifetime_result_empty(region_solution_empty());
  let lifetimes1: LifetimeResult = add_escape_fact(lifetimes0, "escaped_alias", "owner", "global_region", "owner_region", 7, LifetimeEscapeKind.StoreGlobal);
  let finalized: LifetimeResult = finalize_lifetimes(lifetimes1);
  give not finalized.valid
    and len(finalized.diagnostics) > 0
    and finalized.diagnostics[0].code == "BORROWCK_E_DANGLING_REFERENCE"
    and find(finalized.diagnostics[0].message, "escaped_alias") >= 0;
}

proc test_first_class_memory_regions_bind_places_to_declared_regions() -> bool {
  let heap_decl: MemoryRegionDecl = memory_region_decl("heap", MemoryRegionKind.Arena, 1, 10);
  let valid_binding: MemoryRegionBinding = memory_region_binding("buffer", "heap", 2, 8);
  let escaped_binding: MemoryRegionBinding = memory_region_binding("escaped", "heap", 3, 12);
  let missing_binding: MemoryRegionBinding = memory_region_binding("ghost", "missing", 4, 5);
  let model0: MemoryRegionModel = memory_region_model_empty();
  let model1: MemoryRegionModel = declare_memory_region(model0, heap_decl);
  let model2: MemoryRegionModel = bind_place_to_memory_region(model1, valid_binding);
  let model3: MemoryRegionModel = bind_place_to_memory_region(model2, escaped_binding);
  let model4: MemoryRegionModel = bind_place_to_memory_region(model3, missing_binding);
  let finalized: MemoryRegionModel = finalize_memory_regions(model4);
  give memory_region_kind_name(memory_region_kind_from_text("arena")) == "arena"
    and model2.valid
    and not finalized.valid
    and len(finalized.violations) == 2
    and find(finalized.violations[0], "outlives memory region") >= 0
    and find(finalized.violations[1], "not declared") >= 0
    and find(memory_region_summary(finalized), "memory regions failed") >= 0;
}

proc test_borrow_diagnostic_helpers_build_reports() -> bool {
  let span: SourceSpan = span_with_length(span_create("borrowck_helpers.vit", 3, 5, 0), 7);
  let diag: Diagnostic = borrow_error_lifetime_too_short_story("borrowck_helpers.vit", "value", 3, 4, "alias outlives owner", 42);
  let internal: Diagnostic = borrow_error_internal("borrowck_helpers.vit", 9, "broken borrowck invariant");
  let dangling: Diagnostic = borrow_error_dangling_reference("borrowck_helpers.vit", 7, 43);
  let wrapped = borrow_diagnostic_result(diag, BorrowErrorKind.LifetimeTooShort, BorrowPhase.RegionCheck, 42);
  let report0: DiagnosticReport = borrow_report_empty();
  let report1: DiagnosticReport = borrow_report_add(report0, diag);
  let report2: DiagnosticReport = borrow_report_add(report1, internal);
  give span.length == 7
    and error_code(BorrowErrorKind.LifetimeTooShort) == "BORROWCK_E_LIFETIME_TOO_SHORT"
    and dangling.code == "BORROWCK_E_DANGLING_REFERENCE"
    and find(dangling.message, "reference") >= 0
    and wrapped.valid
    and diagnostics_have_errors(report2.diagnostics)
    and not diagnostics_valid(report2.diagnostics)
    and find(diagnostic_summary(diag), "BORROWCK_E_LIFETIME_TOO_SHORT") >= 0
    and find(report_summary(report2), "borrowck failed") >= 0;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_valid_reinit_after_move() { set failures = failures + 1; }
  if not test_move_after_move() { set failures = failures + 1; }
  if not test_move_after_move_tells_temporal_story() { set failures = failures + 1; }
  if not test_write_while_borrowed() { set failures = failures + 1; }
  if not test_mutable_borrow_conflict() { set failures = failures + 1; }
  if not test_mutable_borrow_conflict_reports_borrow_window() { set failures = failures + 1; }
  if not test_return_ref_to_local() { set failures = failures + 1; }
  if not test_return_borrow_of_local() { set failures = failures + 1; }
  if not test_hir_borrowck_path() { set failures = failures + 1; }
  if not test_branch_borrow_conflict_after_join() { set failures = failures + 1; }
  if not test_branch_move_after_join() { set failures = failures + 1; }
  if not test_use_after_move_reports_previous_move() { set failures = failures + 1; }
  if not test_field_borrow_blocks_root_write() { set failures = failures + 1; }
  if not test_binary_assignment_does_not_move_operand() { set failures = failures + 1; }
  if not test_copy_binding_does_not_move_source() { set failures = failures + 1; }
  if not test_branch_loan_expires_at_scope_end() { set failures = failures + 1; }
  if not test_partial_move_preserves_disjoint_field() { set failures = failures + 1; }
  if not test_hir_and_lowered_mir_agree_on_copy_and_scope() { set failures = failures + 1; }
  if not test_borrow_param_call_does_not_move_source() { set failures = failures + 1; }
  if not test_owned_param_call_moves_source() { set failures = failures + 1; }
  if not test_impl_borrow_param_call_uses_canonical_mir_signature() { set failures = failures + 1; }
  if not test_ownership_helpers_track_places_and_borrows() { set failures = failures + 1; }
  if not test_move_tracker_helpers_report_state_and_conflicts() { set failures = failures + 1; }
  if not test_loan_table_helpers_track_aliases_and_conflicts() { set failures = failures + 1; }
  if not test_lifetime_and_region_helpers_summarize_failures() { set failures = failures + 1; }
  if not test_temporal_ownership_windows_enforce_alias_duration() { set failures = failures + 1; }
  if not test_lifetime_escape_detects_dangling_reference() { set failures = failures + 1; }
  if not test_first_class_memory_regions_bind_places_to_declared_regions() { set failures = failures + 1; }
  if not test_borrow_diagnostic_helpers_build_reports() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
