  if not test_reference_assignment_mismatch() {
    set failures = failures + 1;
  }
  if not test_typeck_annotates_hir_expr_type_and_copyable() {
    set failures = failures + 1;
  }
  if not test_typeck_preserves_trait_impl_method_signatures_and_body_types() {
    set failures = failures + 1;
  }
  if not test_typeck_reports_impl_return_signature_mismatch() {
    set failures = failures + 1;
  }
  if not test_typeck_reports_impl_parameter_signature_mismatch() {
    set failures = failures + 1;
  }
  if not test_typeck_api_pipeline_helpers_report_production_status() {
    set failures = failures + 1;
  }
  if not test_typeck_trait_helpers_cover_core_type_surface() {
    set failures = failures + 1;
  }
  if not test_typeck_coercion_helpers_cover_projection_surface() {
    set failures = failures + 1;
  }
  if not test_numeric_coercions_are_directional_in_production() {
    set failures = failures + 1;
  }
  if not test_typeck_unify_helpers_cover_numeric_and_reference_surface() {
    set failures = failures + 1;
  }
  if not test_typeck_infer_env_helpers_cover_binding_lifecycle() {
    set failures = failures + 1;
  }
  if not test_typeck_error_helpers_cover_result_and_summary_surface() {
    set failures = failures + 1;
  }
  if not test_typeck_result_enforces_diagnostic_cause_chains() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
