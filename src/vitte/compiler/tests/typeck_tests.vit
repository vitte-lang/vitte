proc test_match_non_exhaustive_requires_fallback_arm() -> bool {
  let source: string = "proc main() { match value { 1 => { give 1; } } }\n";
  let fe: FrontendOutput = frontend_run("typeck_match_non_exhaustive.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_MATCH_NON_EXHAUSTIVE");
  give diag.valid
    and diag.rule == "pattern coverage completeness"
    and find(diag.probable_fix, "fallback") >= 0;
}

proc test_match_with_fallback_arm_is_not_reported_non_exhaustive() -> bool {
  let source: string = "proc main() { match value { 1 => { give 1; } else => { give 0; } } }\n";
  let fe: FrontendOutput = frontend_run("typeck_match_exhaustive.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  give has_code(result, "TYPECK_E_MATCH_NON_EXHAUSTIVE") == false;
}

proc test_reference_assignment_mismatch() -> bool {
  let source: string = "proc main() { let x = 1; let r = &x; set r = 1; give r; }\n";
  let fe: FrontendOutput = frontend_run("typeck_ref_assign_mismatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  give has_code(result, "TYPECK_E_ASSIGN_MISMATCH");
}

proc test_typeck_annotates_hir_expr_type_and_copyable() -> bool {
  let source: string = "proc main() { let x = 1; let r = &x; give r; }\n";
  let fe: FrontendOutput = frontend_run("typeck_hir_annotation.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let binding_expr = result.hir.module.items[0].stmts[1].expr;
  let return_expr = result.hir.module.items[0].stmts[2].expr;
  give has_code(result, "TYPECK_E_ASSIGN_MISMATCH") == false and binding_expr.inferred_type == "&int" and binding_expr.copyable and return_expr.inferred_type == "&int" and return_expr.copyable;
}

proc test_typeck_preserves_trait_impl_method_signatures_and_body_types() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "trait Show {\n" +
    "  proc show(self: Self, level: int) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self, level: int) -> string { give \"point\"; }\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("typeck_trait_impl_ok.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let trait_member = result.hir.module.items[1].members[0];
  let impl_member = result.hir.module.items[2].members[0];
  give result.valid
    and len(result.diagnostics) == 0
    and trait_member.kind == HirNominalMemberKind.TraitMethod
    and impl_member.kind == HirNominalMemberKind.ImplMethod
    and len(trait_member.params) == 2
    and trait_member.params[0].annotation_text == "Self"
    and trait_member.params[1].annotation_text == "int"
    and impl_member.annotation_text == "string"
    and len(impl_member.body_stmts) == 1
    and impl_member.body_stmts[0].expr.inferred_type == "string";
}

proc test_typeck_reports_impl_return_signature_mismatch() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "trait Show {\n" +
    "  proc show(self: Self) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self) -> int { give 0; }\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("typeck_trait_impl_return_mismatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_IMPL_SIGNATURE_MISMATCH");
  give diag.valid
    and find(diag.message, "return type") >= 0
    and len(diag.labels) >= 3
    and diag.labels[0] == "show"
    and diag.labels[1] == "string"
    and diag.labels[2] == "int";
}

proc test_typeck_reports_impl_parameter_signature_mismatch() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "trait Show {\n" +
    "  proc show(self: Self, level: int) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self, level: bool) -> string { give \"point\"; }\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("typeck_trait_impl_param_mismatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_IMPL_SIGNATURE_MISMATCH");
  give diag.valid
    and find(diag.message, "parameter type") >= 0
    and len(diag.labels) >= 3
    and diag.labels[0] == "show"
    and diag.labels[1] == "int"
    and diag.labels[2] == "bool";
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_valid_numeric_flow() {
    set failures = failures + 1;
  }
  if not test_assign_mismatch() {
    set failures = failures + 1;
  }
  if not test_assign_mismatch_carries_rich_diagnostic_context() {
    set failures = failures + 1;
  }
  if not test_binary_mismatch() {
    set failures = failures + 1;
  }
  if not test_binary_mismatch_carries_expected_found_context() {
    set failures = failures + 1;
  }
  if not test_invalid_deref() {
    set failures = failures + 1;
  }
  if not test_condition_type_carries_rule_and_fix() {
    set failures = failures + 1;
  }
  if not test_invalid_call_target_carries_callable_rule() {
    set failures = failures + 1;
  }
  if not test_struct_literal_keeps_named_type_in_typed_hir() {
    set failures = failures + 1;
  }
  if not test_nominal_field_access_resolves_from_member_table() {
    set failures = failures + 1;
  }
  if not test_nominal_variant_and_flag_access_resolve_from_member_table() {
    set failures = failures + 1;
  }
  if not test_impl_method_dispatch_binds_self_away_for_call_type() {
    set failures = failures + 1;
  }
  if not test_proc_params_typecheck_body_without_unresolved_names() {
    set failures = failures + 1;
  }
  if not test_immutable_param_rejects_assignment() {
    set failures = failures + 1;
  }
  if not test_proc_call_uses_canonical_signature_modes() {
    set failures = failures + 1;
  }
  if not test_call_arity_carries_signature_context() {
    set failures = failures + 1;
  }
  if not test_argument_mismatch_carries_expected_found_context() {
    set failures = failures + 1;
  }
  if not test_typed_call_returns_signature_result_type() {
    set failures = failures + 1;
  }
  if not test_if_branch_mismatch_carries_unification_rule() {
    set failures = failures + 1;
  }
  if not test_invalid_index_target_carries_container_rule() {
    set failures = failures + 1;
  }
  if not test_compare_mismatch_carries_operand_rule() {
    set failures = failures + 1;
  }
  if not test_invalid_cast_carries_cast_rule() {
    set failures = failures + 1;
  }
  if not test_match_non_exhaustive_requires_fallback_arm() {
    set failures = failures + 1;
  }
  if not test_match_with_fallback_arm_is_not_reported_non_exhaustive() {
    set failures = failures + 1;
  }
  if not test_reference_assignment_mismatch() {
    set failures = failures + 1;
  }
  if not test_typeck_annotates_hir_expr_type_and_copyable() {
    set failures = failures + 1;
  }
  if not test_typeck_preserves_trait_impl_method_signatures_and_body_types() {
    set failures = failures + 1;
  }
  if not test_typeck_reports_impl_return_signature_mismatch() {
    set failures = failures + 1;
  }
  if not test_typeck_reports_impl_parameter_signature_mismatch() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
