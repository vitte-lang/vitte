proc test_valid_numeric_flow() -> bool {
  let source: string = "proc main() { let x = 1; set x = x + 1; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_valid_numeric.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  give fe.valid and result.valid and len(result.diagnostics) == 0;
}

proc test_assign_mismatch() -> bool {
  let source: string = "proc main() { let x = 1; set x = \"oops\"; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_assign_mismatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  give has_code(result, "TYPECK_E_ASSIGN_MISMATCH");
}

proc test_assign_mismatch_carries_rich_diagnostic_context() -> bool {
  let source: string = "proc main() { let x = 1; set x = \"oops\"; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_assign_mismatch_rich.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  if len(result.diagnostics) == 0 {
    give false;
  }
  let diag = result.diagnostics[0];
  give diag.code == "TYPECK_E_ASSIGN_MISMATCH"
    and diag.rule == "assignment type compatibility"
    and find(diag.explanation, "expects `int`") >= 0
    and find(diag.explanation, "produces `string`") >= 0
    and diag.documentation_url == "docs://language/type-system/assignment-compatibility"
    and diag.root_cause == "assignment target type and expression type are incompatible"
    and len(diag.cause_chain) >= 2
    and len(diag.pipeline_context) >= 2
    and diag.subject_symbol == "x"
    and diag.subject_type == "int"
    and find(diag.probable_fix, "`int`") >= 0;
}

proc test_return_mismatch_carries_rich_diagnostic_context() -> bool {
  let source: string = "proc answer() -> int { give \"oops\"; }\n";
  let fe: FrontendOutput = frontend_run("typeck_return_mismatch_rich.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_RETURN_MISMATCH");
  give diag.valid
    and diag.rule == "procedure return compatibility"
    and find(diag.explanation, "promises `int`") >= 0
    and find(diag.explanation, "produces `string`") >= 0
    and len(diag.cause_chain) >= 2
    and diag.subject_symbol == "answer"
    and diag.subject_type == "int"
    and find(diag.probable_fix, "`int`") >= 0;
}

proc test_binary_mismatch() -> bool {
  let source: string = "proc main() { let x = 1 + \"oops\"; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_binary_mismatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  give has_code(result, "TYPECK_E_BINARY_MISMATCH");
}

proc test_binary_mismatch_carries_expected_found_context() -> bool {
  let source: string = "proc main() { let x = 1 + \"oops\"; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_binary_mismatch_rich.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_BINARY_MISMATCH");
  give diag.valid
    and diag.rule == "binary operator operand compatibility"
    and find(diag.explanation, "expected `int`") >= 0
    and find(diag.explanation, "got `string`") >= 0
    and len(diag.cause_chain) >= 2
    and find(diag.probable_fix, "operator") >= 0;
}

proc test_invalid_deref() -> bool {
  let source: string = "proc main() { let x = 1; let y = *x; give y; }\n";
  let fe: FrontendOutput = frontend_run("typeck_invalid_deref.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  give has_code(result, "TYPECK_E_INVALID_DEREF");
}

proc test_condition_type_carries_rule_and_fix() -> bool {
  let source: string = "proc main() { if \"oops\" { give 1; } give 0; }\n";
  let fe: FrontendOutput = frontend_run("typeck_condition_type_rich.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_CONDITION_TYPE");
  give diag.valid
    and diag.rule == "condition truthiness"
    and find(diag.explanation, "expected `truthy`") >= 0
    and find(diag.explanation, "got `string`") >= 0
    and find(diag.probable_fix, "`bool`") >= 0;
}

proc test_invalid_call_target_carries_callable_rule() -> bool {
  let source: string = "proc main() { let x = 1; let y = x(); give y; }\n";
  let fe: FrontendOutput = frontend_run("typeck_invalid_call_target.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_INVALID_CALL_TARGET");
  give diag.valid
    and diag.rule == "call target must be callable"
    and len(diag.cause_chain) >= 2
    and find(diag.probable_fix, "call syntax") >= 0;
}

proc test_struct_literal_keeps_named_type_in_typed_hir() -> bool {
  let source: string = "form Point { x: int, y: int }\nproc main() { let point = Point { x: 1, y: 2 }; give point; }\n";
  let fe: FrontendOutput = frontend_run("typeck_struct_literal.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  if not fe.valid or not result.valid or len(result.hir.module.items) < 2 {
    give false;
  }
  let main_item = result.hir.module.items[1];
  if len(main_item.stmts) == 0 {
    give false;
  }
  let point_stmt = main_item.stmts[0];
  give point_stmt.name == "point"
    and point_stmt.expr.kind == HirExprKind.Struct
    and point_stmt.expr.inferred_type == "Point";
}

proc test_nominal_field_access_resolves_from_member_table() -> bool {
  let source: string = "form Point { x: int, y: int }\nproc main() { let point = Point { x: 1, y: 2 }; let value = point.x; give value; }\n";
  let fe: FrontendOutput = frontend_run("typeck_nominal_field_access.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let value_expr = result.hir.module.items[1].stmts[1].expr;
  give result.valid
    and len(result.diagnostics) == 0
    and value_expr.kind == HirExprKind.Member
    and value_expr.inferred_type == "int";
}

proc test_nominal_variant_and_flag_access_resolve_from_member_table() -> bool {
  let source: string =
    "bits Mode: u8 {\n" +
    "  read: 0 .. 1,\n" +
    "}\n" +
    "pick Option {\n" +
    "  None,\n" +
    "  Some(int),\n" +
    "}\n" +
    "proc main() { let mask = Mode.read; let ctor = Option.Some; give mask; }\n";
  let fe: FrontendOutput = frontend_run("typeck_nominal_variant_access.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let mask_expr = result.hir.module.items[2].stmts[0].expr;
  let ctor_expr = result.hir.module.items[2].stmts[1].expr;
  give result.valid
    and mask_expr.inferred_type == "u8"
    and ctor_expr.inferred_type == "fn(int) -> Option";
}

proc test_impl_method_dispatch_binds_self_away_for_call_type() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "trait Show {\n" +
    "  proc show(self: Self, level: int) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self, level: int) -> string { let field = self.x; give \"point\"; }\n" +
    "}\n" +
    "proc main() { let point = Point { x: 1 }; let shown = point.show(7); give shown; }\n";
  let fe: FrontendOutput = frontend_run("typeck_impl_dispatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let impl_body_field = result.hir.module.items[2].members[0].body_stmts[0].expr;
  let shown_expr = result.hir.module.items[3].stmts[1].expr;
  give result.valid
    and len(result.diagnostics) == 0
    and impl_body_field.inferred_type == "int"
    and shown_expr.inferred_type == "string";
}

proc test_impl_method_dispatch_rejects_ambiguous_traits() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "trait Show { proc render(self: Self) -> string; }\n" +
    "trait Debug { proc render(self: Self) -> string; }\n" +
    "impl Show for Point { proc render(self: Self) -> string { give \"show\"; } }\n" +
    "impl Debug for Point { proc render(self: Self) -> string { give \"debug\"; } }\n" +
    "proc main() { let point = Point { x: 1 }; let text = point.render(); give text; }\n";
  let fe: FrontendOutput = frontend_run("typeck_ambiguous_method.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_AMBIGUOUS_METHOD");
  give fe.valid
    and not result.valid
    and diag.valid
    and diag.rule == "unique method candidate"
    and diag.subject_symbol == "render"
    and diag.subject_type == "Point"
    and find(diag.explanation, "Show") >= 0
    and find(diag.explanation, "Debug") >= 0
    and len(diag.cause_chain) >= 2;
}

proc test_proc_params_typecheck_body_without_unresolved_names() -> bool {
  let source: string = "proc add(borrow value: int, mut flag: bool, ...) -> int { if flag { give value; } give 0; }\n";
  let fe: FrontendOutput = frontend_run("typeck_proc_params.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  give result.valid
    and len(result.hir.module.items[0].params) == 3
    and result.hir.module.items[0].params[0].borrowed
    and result.hir.module.items[0].params[1].mutable
    and result.hir.module.items[0].params[2].variadic
    and result.hir.module.items[0].stmts[0].expr.inferred_type == "bool"
    and result.hir.module.items[0].stmts[0].then_stmts[0].expr.inferred_type == "int";
}

proc test_immutable_param_rejects_assignment() -> bool {
  let source: string = "proc keep(borrow value: int) -> int { set value = 1; give value; }\n";
  let fe: FrontendOutput = frontend_run("typeck_immutable_param_assign.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  give has_code(result, "TYPECK_E_IMMUTABLE_ASSIGN");
}

proc test_proc_call_uses_canonical_signature_modes() -> bool {
  let source: string =
    "proc keep(borrow value: int) -> int { give value; }\n" +
    "proc main() -> int { let x = 1; let y = keep(x); give y; }\n";
  let fe: FrontendOutput = frontend_run("typeck_proc_call_signature_modes.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  give result.valid
    and len(result.diagnostics) == 0
    and result.hir.module.items[1].stmts[1].expr.inferred_type == "int";
}

proc test_call_arity_carries_signature_context() -> bool {
  let env = [type_binding("f", "fn(int) -> int")];
  let call_expr: HirExpr = hir_expr(
    10,
    ast_span("typeck_call_arity.vit", 1, 1, 1, 10),
    HirExprKind.Call,
    "f(1, 2)",
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    [],
    [expr_name(1, "f"), expr_int(2, "1"), expr_int(3, "2")],
    true
  );
  let result: ExprTypeResult = infer_call_type(env, call_expr);
  let diag = expr_diagnostic_by_code(result, "TYPECK_E_CALL_ARITY");
  give diag.valid
    and diag.rule == "function call arity"
    and find(diag.explanation, "expects 1 argument") >= 0
    and find(diag.explanation, "provides 2") >= 0
    and find(diag.probable_fix, "matches the declared signature") >= 0;
}

proc test_argument_mismatch_carries_expected_found_context() -> bool {
  let env = [type_binding("f", "fn(int, bool) -> int")];
  let call_expr: HirExpr = hir_expr(
    11,
    ast_span("typeck_argument_mismatch.vit", 1, 1, 1, 14),
    HirExprKind.Call,
    "f(1, \"oops\")",
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    [],
    [expr_name(1, "f"), expr_int(2, "1"), expr_string(3, "\"oops\"")],
    true
  );
  let result: ExprTypeResult = infer_call_type(env, call_expr);
  let diag = expr_diagnostic_by_code(result, "TYPECK_E_ARGUMENT_MISMATCH");
  give diag.valid
    and diag.rule == "function argument compatibility"
    and find(diag.explanation, "expects `bool`") >= 0
    and find(diag.explanation, "passes `string`") >= 0
    and len(diag.cause_chain) >= 2
    and find(diag.probable_fix, "widen the callee signature") >= 0;
}

proc test_typed_call_returns_signature_result_type() -> bool {
  let env = [type_binding("f", "fn(int, bool) -> string")];
  let call_expr: HirExpr = hir_expr(
    12,
    ast_span("typeck_call_result.vit", 1, 1, 1, 11),
    HirExprKind.Call,
    "f(1, true)",
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    [],
    [expr_name(1, "f"), expr_int(2, "1"), expr_bool(3, "true")],
    true
  );
  let result: ExprTypeResult = infer_call_type(env, call_expr);
  give result.valid and result.ty == "string" and len(result.diagnostics) == 0;
}

proc test_generic_call_infers_and_substitutes_return_type() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc main() -> int { let value = identity(7); give value; }\n";
  let fe: FrontendOutput = frontend_run("typeck_generic_inference.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let call = result.hir.module.items[1].stmts[0].expr;
  give result.valid
    and len(result.diagnostics) == 0
    and call.kind == HirExprKind.Call
    and call.inferred_type == "int"
    and len(call.generic_arguments) == 1
    and call.generic_arguments[0] == "int";
}

proc test_typed_hir_preserves_explicit_generic_instance() -> bool {
  let source: string =
    "proc identity[T](value: T) -> T { give value; }\n" +
    "proc main() -> string { let value = identity<string>(\"value\"); give value; }\n";
  let fe: FrontendOutput = frontend_run("typeck_generic_explicit_hir.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let result: TypeckResult = run_production_typeck_hir(sema.hir);
  let call = result.hir.module.items[1].stmts[0].expr;
  give result.valid
    and len(result.diagnostics) == 0
    and call.inferred_type == "string"
    and len(call.generic_arguments) == 1
    and call.generic_arguments[0] == "string";
}

proc test_generic_call_honors_explicit_type_argument() -> bool {
  let env = [generic_type_binding("identity", "fn(T) -> T", ["T"])];
  let call_expr: HirExpr = hir_expr_with_generic_arguments(
    13,
    ast_span("typeck_generic_explicit.vit", 1, 1, 1, 25),
    HirExprKind.Call,
    "identity<string>(\"value\")",
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    ["string"],
    [],
    [expr_name(1, "identity"), expr_string(2, "\"value\"")],
    true
  );
  let result: ExprTypeResult = infer_call_type(env, call_expr);
  give result.valid and result.ty == "string" and len(result.diagnostics) == 0;
}

proc test_generic_call_rejects_explicit_argument_mismatch() -> bool {
  let env = [generic_type_binding("identity", "fn(T) -> T", ["T"])];
  let call_expr: HirExpr = hir_expr_with_generic_arguments(
    14,
    ast_span("typeck_generic_explicit_mismatch.vit", 1, 1, 1, 20),
    HirExprKind.Call,
    "identity<string>(7)",
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    ["string"],
    [],
    [expr_name(1, "identity"), expr_int(2, "7")],
    true
  );
  let result: ExprTypeResult = infer_call_type(env, call_expr);
  give not result.valid and expr_diagnostic_by_code(result, "TYPECK_E_ARGUMENT_MISMATCH").valid;
}

proc test_generic_call_reports_unconstrained_parameter() -> bool {
  let env = [generic_type_binding("make", "fn() -> T", ["T"])];
  let call_expr: HirExpr = hir_expr(
    15,
    ast_span("typeck_generic_unconstrained.vit", 1, 1, 1, 6),
    HirExprKind.Call,
    "make()",
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    [],
    [expr_name(1, "make")],
    true
  );
  let result: ExprTypeResult = infer_call_type(env, call_expr);
  let diag = expr_diagnostic_by_code(result, "TYPECK_E_GENERIC_INFERENCE");
