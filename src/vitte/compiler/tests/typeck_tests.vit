const VERSION_TEXT: string = "analysis typeck tests 0.2.0"
const BANNER_TEXT: string = "analysis typeck tests"

proc has_code(result: TypeckResult, code: string) -> bool {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc diagnostic_by_code(result: TypeckResult, code: string) -> Diagnostic {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give result.diagnostics[i];
    }
    set i = i + 1;
  }
  give Diagnostic {
    code: "",
    phase: DiagnosticPhase.Unknown,
    severity: DiagnosticSeverity.Error,
    rule: "",
    message: "",
    explanation: "",
    technical_note: "",
    labels: [],
    notes: [],
    helps: [],
    suggestions: [],
    documentation_url: "",
    root_cause: "",
    cause_chain: [],
    pipeline_context: [],
    related_errors: [],
    probable_fix: "",
    subject_symbol: "",
    subject_type: "",
    subject_borrow: "",
    span: SourceSpan { file: "", start_line: 0, start_column: 0, end_line: 0, end_column: 0, length: 0, valid: false },
    deprecated: false,
    unnecessary: false,
    fatal: false,
    valid: false
  };
}

proc expr_diagnostic_by_code(result: ExprTypeResult, code: string) -> Diagnostic {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give result.diagnostics[i];
    }
    set i = i + 1;
  }
  give Diagnostic {
    code: "",
    phase: DiagnosticPhase.Unknown,
    severity: DiagnosticSeverity.Error,
    rule: "",
    message: "",
    explanation: "",
    technical_note: "",
    labels: [],
    notes: [],
    helps: [],
    suggestions: [],
    documentation_url: "",
    root_cause: "",
    cause_chain: [],
    pipeline_context: [],
    related_errors: [],
    probable_fix: "",
    subject_symbol: "",
    subject_type: "",
    subject_borrow: "",
    span: SourceSpan { file: "", start_line: 0, start_column: 0, end_line: 0, end_column: 0, length: 0, valid: false },
    deprecated: false,
    unnecessary: false,
    fatal: false,
    valid: false
  };
}

proc expr_name(id: u64, text: string) -> HirExpr {
  give hir_expr(
    id,
    ast_span("typeck_call_manual.vit", 1, 1, 1, 1),
    HirExprKind.Name,
    text,
    text,
    "",
    text,
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    false,
    false,
    false,
    false,
    [],
    [],
    true
  );
}

