proc test_if_branch_mismatch_carries_unification_rule() -> bool {
  let source: string = "proc main() { let x = if true { 1 } else { \"oops\" }; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_if_branch_mismatch.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: TypeckResult = run_production_typeck_hir(hir);
  let diag = diagnostic_by_code(result, "TYPECK_E_IF_BRANCH_MISMATCH");
  give diag.valid
    and diag.rule == "if expression branch unification"
    and find(diag.explanation, "expected `int`") >= 0
    and find(diag.explanation, "got `string`") >= 0
    and find(diag.probable_fix, "branches") >= 0;
}

