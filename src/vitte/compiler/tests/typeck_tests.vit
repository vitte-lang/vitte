proc test_typeck_api_pipeline_helpers_report_production_status() -> bool {
  give production_typeck_pipeline_name() == "hir"
    and production_typeck_pipeline_status() == "canonical";
}

proc test_typeck_trait_helpers_cover_core_type_surface() -> bool {
  let info = type_trait_info("&int");
  give type_class_name(type_class("u64")) == "unsigned_integer"
    and type_is_reference("&int")
    and type_is_pointer("*const int")
    and type_is_slice("[int]")
    and type_is_array("[int; 4]")
    and type_is_tuple("(int, bool)")
    and type_is_function("fn(int) -> bool")
    and type_is_copy("&int")
    and type_allows_arithmetic("u32")
    and type_allows_bitwise("bool")
    and type_allows_comparison("*const int")
    and type_can_assign_without_move("&int")
    and type_requires_drop("string")
    and info.reference
    and info.copy
    and info.truthy;
}

proc test_typeck_coercion_helpers_cover_projection_surface() -> bool {
  let projection = project_place_type_result("&int", "*value");
  let numeric_widening = coerce_type("i64", "u8");
  let numeric_narrowing = coerce_type("i8", "i64");
  let shared_reborrow = coerce_type("&int", "&mut int");
  give type_deref_target("&mut int") == "int"
    and type_index_element("[int; 4]") == "int"
    and type_member_result("string", "len") == "int"
    and types_compatible("i64", "u8")
    and not types_compatible("i8", "i64")
    and numeric_widening.success
    and not numeric_widening.lossy
    and not numeric_narrowing.success
    and shared_reborrow.success
    and type_cast_allowed("i64", "i8")
    and not type_cast_allowed("string", "i8")
    and projection_member_name("point.x", "") == "x"
    and projection.valid
    and projection.ty == "int"
    and project_place_type("string", "value.len") == "int"
    and projection_is_valid("string", "value.len");
}

proc test_numeric_coercions_are_directional_in_production() -> bool {
  let widening_source: string = "proc widen(value: u8) -> i64 { give value; }\nproc literal() -> i8 { give 1; }\n";
  let narrowing_source: string = "proc narrow(value: i64) -> i8 { give value; }\n";
  let explicit_source: string = "proc narrow(value: i64) -> i8 { give value as i8; }\n";
  let annotation_source: string = "proc main() { let value: i8 = \"oops\"; give 0; }\n";
  let widening_fe: FrontendOutput = frontend_run("typeck_numeric_widening.vit", widening_source);
  let narrowing_fe: FrontendOutput = frontend_run("typeck_numeric_narrowing.vit", narrowing_source);
  let explicit_fe: FrontendOutput = frontend_run("typeck_numeric_explicit_cast.vit", explicit_source);
  let annotation_fe: FrontendOutput = frontend_run("typeck_annotated_let_mismatch.vit", annotation_source);
  let widening: TypeckResult = run_production_typeck_hir(lower_ast_to_hir(widening_fe));
  let narrowing: TypeckResult = run_production_typeck_hir(lower_ast_to_hir(narrowing_fe));
  let explicit: TypeckResult = run_production_typeck_hir(lower_ast_to_hir(explicit_fe));
  let annotation: TypeckResult = run_production_typeck_hir(lower_ast_to_hir(annotation_fe));
  give widening.valid
    and not narrowing.valid
    and has_code(narrowing, "TYPECK_E_RETURN_MISMATCH")
    and explicit.valid
    and has_code(annotation, "TYPECK_E_ASSIGN_MISMATCH");
}

proc test_typeck_unify_helpers_cover_numeric_and_reference_surface() -> bool {
  let assign = unify_assignment_type("i32", "u8");
  let binary = unify_binary_result_type("int", "==", "u8");
  let refs = unify_types_result("&mut int", "&int");
  give unify_types("i32", "u8") == "i32"
    and can_unify_types("&int", "&mut int")
    and unify_or_fallback("string", "bool", "fallback") == "fallback"
    and assign.success
    and assign.ty == "i32"
    and binary.success
    and binary.ty == "bool"
    and refs.success
    and refs.ty == "&int"
    and refs.lossy;
}

proc test_typeck_infer_env_helpers_cover_binding_lifecycle() -> bool {
  let env0 = type_env_set(empty_type_env(), uninitialized_type_binding("x", "int"));
  let before = type_env_get_binding(env0, "x");
  let env1 = type_env_mark_initialized(env0, "x");
  let env2 = type_env_mark_moved(env1, "x");
  let after = type_env_get_binding(env2, "x");
  let mutable0 = mutable_type_binding("y", "int");
  let infer_before = infer_name_type(env0.bindings, expr_name(20, "x"));
  let infer_after = infer_name_type(env2.bindings, expr_name(21, "x"));
  let before_diag = expr_diagnostic_by_code(infer_before, "TYPECK_E_USE_BEFORE_INIT");
  let after_diag = expr_diagnostic_by_code(infer_after, "TYPECK_E_USE_AFTER_MOVE");
  give before.valid
    and not before.initialized
    and mutable0.mutable
    and before_diag.valid
    and after.moved
    and after_diag.valid;
}

proc test_typeck_error_helpers_cover_result_and_summary_surface() -> bool {
  let source: string = "proc main() { give 0; }\n";
  let fe: FrontendOutput = frontend_run("typeck_error_helpers.vit", source);
  let hir = lower_ast_to_hir(fe);
  let invalid0: TypeckResult = typeck_invalid_hir_result(hir);
  let internal0: TypeckResult = typeck_internal_error(hir, "boom");
  let diag = internal0.report.diagnostics[0];
  give not invalid0.valid
    and not internal0.valid
    and diagnostic_summary(diag) != ""
    and find(result_summary(invalid0), "typeck failed:") >= 0;
}

proc test_typeck_result_enforces_diagnostic_cause_chains() -> bool {
  let source: string = "proc main() { let x = 1; set x = \"oops\"; give x; }\n";
  let fe: FrontendOutput = frontend_run("typeck_cause_chain_guard.vit", source);
  let hir = lower_ast_to_hir(fe);
  let complete: TypeckResult = run_production_typeck_hir(hir);
  let malformed: Diagnostic = typeck_diag(
    "TYPECK_E_ARGUMENT_MISMATCH",
    "call argument type mismatch",
    ["f", "int", "string"],
    "align the argument with the parameter type",
    ast_span("typeck_cause_chain_guard.vit", 1, 1, 1, 5),
    false
  );
  let guarded: TypeckResult = typeck_result(hir, [malformed]);
  give has_code(complete, "TYPECK_E_ASSIGN_MISMATCH")
    and not has_code(complete, "TYPECK_E_CAUSE_CHAIN_MISSING")
    and not guarded.valid
    and len(guarded.diagnostics) == 2
    and len(guarded.report.diagnostics) == len(guarded.diagnostics)
    and guarded.diagnostics[0].code == "TYPECK_E_ARGUMENT_MISMATCH"
    and guarded.diagnostics[1].code == "TYPECK_E_CAUSE_CHAIN_MISSING"
    and len(guarded.diagnostics[1].cause_chain) >= 2;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_valid_numeric_flow() {
    set failures = failures + 1;
  }
  if not test_assign_mismatch() {
    set failures = failures + 1;
  }
  if not test_assign_mismatch_carries_rich_diagnostic_context() {
    set failures = failures + 1;
  }
  if not test_return_mismatch_carries_rich_diagnostic_context() {
    set failures = failures + 1;
  }
  if not test_binary_mismatch() {
    set failures = failures + 1;
  }
  if not test_binary_mismatch_carries_expected_found_context() {
    set failures = failures + 1;
  }
  if not test_invalid_deref() {
    set failures = failures + 1;
  }
  if not test_condition_type_carries_rule_and_fix() {
    set failures = failures + 1;
  }
  if not test_invalid_call_target_carries_callable_rule() {
    set failures = failures + 1;
  }
  if not test_struct_literal_keeps_named_type_in_typed_hir() {
    set failures = failures + 1;
  }
  if not test_nominal_field_access_resolves_from_member_table() {
    set failures = failures + 1;
  }
  if not test_nominal_variant_and_flag_access_resolve_from_member_table() {
    set failures = failures + 1;
  }
  if not test_impl_method_dispatch_binds_self_away_for_call_type() {
    set failures = failures + 1;
  }
  if not test_impl_method_dispatch_rejects_ambiguous_traits() {
    set failures = failures + 1;
  }
  if not test_proc_params_typecheck_body_without_unresolved_names() {
    set failures = failures + 1;
  }
  if not test_immutable_param_rejects_assignment() {
    set failures = failures + 1;
  }
  if not test_proc_call_uses_canonical_signature_modes() {
    set failures = failures + 1;
  }
  if not test_call_arity_carries_signature_context() {
    set failures = failures + 1;
  }
  if not test_argument_mismatch_carries_expected_found_context() {
    set failures = failures + 1;
  }
  if not test_typed_call_returns_signature_result_type() {
    set failures = failures + 1;
  }
  if not test_generic_call_infers_and_substitutes_return_type() {
    set failures = failures + 1;
  }
  if not test_typed_hir_preserves_explicit_generic_instance() {
    set failures = failures + 1;
  }
  if not test_generic_call_honors_explicit_type_argument() {
    set failures = failures + 1;
  }
  if not test_generic_call_rejects_explicit_argument_mismatch() {
    set failures = failures + 1;
  }
  if not test_generic_call_reports_unconstrained_parameter() {
    set failures = failures + 1;
  }
  if not test_generic_substitution_replaces_identifiers_only() {
    set failures = failures + 1;
  }
  if not test_generic_trait_bound_accepts_visible_impl() {
    set failures = failures + 1;
  }
  if not test_generic_trait_bound_reports_unsatisfied_impl() {
    set failures = failures + 1;
  }
  if not test_typeck_rejects_conflicting_trait_impls() {
    set failures = failures + 1;
  }
  if not test_typeck_rejects_cyclic_generic_constraints() {
    set failures = failures + 1;
  }
  if not test_declared_types_accept_nominals_generics_and_compounds() {
    set failures = failures + 1;
  }
  if not test_declared_field_reports_unknown_nested_type() {
    set failures = failures + 1;
  }
  if not test_declared_signature_and_impl_target_report_unknown_types() {
    set failures = failures + 1;
  }
  if not test_local_annotation_reports_unknown_type() {
    set failures = failures + 1;
  }
  if not test_if_branch_mismatch_carries_unification_rule() {
    set failures = failures + 1;
  }
  if not test_invalid_index_target_carries_container_rule() {
    set failures = failures + 1;
  }
  if not test_compare_mismatch_carries_operand_rule() {
    set failures = failures + 1;
  }
  if not test_invalid_cast_carries_cast_rule() {
    set failures = failures + 1;
  }
  if not test_match_non_exhaustive_requires_fallback_arm() {
    set failures = failures + 1;
  }
  if not test_match_with_fallback_arm_is_not_reported_non_exhaustive() {
    set failures = failures + 1;
  }
  if not test_match_pick_variants_can_be_exhaustive_without_fallback() {
