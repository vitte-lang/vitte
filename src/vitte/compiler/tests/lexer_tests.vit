space vitte/compiler/tests/lexer_tests

use vitte/compiler/frontend/lexer/scanner.{ ScanResult, scan_tokens }
use vitte/compiler/frontend/lexer/errors.{ LexerDiagnostic, invalid_character, invalid_char_literal, invalid_number, invalid_unicode_escape, lexer_diagnostic_as_diagnostic, token_too_large, unterminated_block_comment, unterminated_string }
use vitte/compiler/frontend/lexer/literals.{ BINDIGIT, DIGIT, HEXDIGIT, OCTDIGIT }
use vitte/compiler/frontend/lexer/token.{ TokenKind }
use vitte/compiler/diagnostics/diagnostic.{ Diagnostic, DiagnosticPhase }
use vitte/compiler/tests/frontend_fixtures/valid/lexer.{ attributes_source, number_suffix_source, positions_source }
use vitte/compiler/tests/frontend_fixtures/invalid/lexer.{ invalid_char_literal_source, invalid_escape_source, invalid_number_source, invalid_prefixed_numbers_source }

const VERSION_TEXT: string = "frontend lexer tests 0.3.0"
const BANNER_TEXT: string = "frontend lexer tests"

proc token_index(result: ScanResult, lexeme: string) -> int {
  let i: u64 = 0;
  while i < len(result.tokens) {
    if result.tokens[i].lexeme == lexeme {
      give i as int;
    }
    set i = i + 1;
  }
  give -1;
}

proc test_scanner_preserves_positions_after_comments() -> bool {
  let result: ScanResult = scan_tokens(positions_source());
  let proc_index: int = token_index(result, "proc");
  if not result.valid or proc_index < 0 {
    give false;
  }
  let proc_token = result.tokens[proc_index as u64];
  give proc_token.line == 3 and proc_token.column == 1;
}

proc test_scanner_preserves_exact_token_spans() -> bool {
  let result: ScanResult = scan_tokens("alpha \"\"\"x\ny\"\"\" omega");
  let alpha_index: int = token_index(result, "alpha");
  let string_index: int = token_index(result, "\"\"\"x\ny\"\"\"");
  let omega_index: int = token_index(result, "omega");
  if not result.valid or alpha_index < 0 or string_index < 0 or omega_index < 0 {
    give false;
  }

  let alpha = result.tokens[alpha_index as u64].span;
  let string_span = result.tokens[string_index as u64].span;
  let omega = result.tokens[omega_index as u64].span;
  give alpha.valid
    and alpha.start_offset == 0
    and alpha.end_offset == 5
    and alpha.start_line == 1
    and alpha.start_column == 1
    and alpha.end_line == 1
    and alpha.end_column == 6
    and string_span.start_offset == 6
    and string_span.end_offset == 15
    and string_span.start_line == 1
    and string_span.start_column == 7
    and string_span.end_line == 2
    and string_span.end_column == 5
    and omega.start_offset == 16
    and omega.end_offset == 21
    and omega.start_line == 2
    and omega.start_column == 6
    and omega.end_line == 2
    and omega.end_column == 11;
}

proc test_scanner_reports_precise_invalid_number() -> bool {
  let result: ScanResult = scan_tokens(invalid_number_source());
  if result.valid or len(result.diagnostics) == 0 {
    give false;
  }
  let diag = result.diagnostics[0];
  give diag.code == "LEX_E_INVALID_NUMBER" and diag.line == 1 and diag.column == 28 and diag.width >= 4;
}

proc test_digit_helpers_match_ebnf_classes() -> bool {
  give DIGIT("7")
    and not DIGIT("x")
    and BINDIGIT("0")
    and BINDIGIT("1")
    and not BINDIGIT("2")
    and OCTDIGIT("7")
    and not OCTDIGIT("8")
    and HEXDIGIT("9")
    and HEXDIGIT("a")
    and HEXDIGIT("F")
    and not HEXDIGIT("g");
}

proc test_scanner_reports_precise_invalid_escape_and_char_literal() -> bool {
  let escape_result: ScanResult = scan_tokens(invalid_escape_source());
  let char_result: ScanResult = scan_tokens(invalid_char_literal_source());
  if escape_result.valid or char_result.valid or len(escape_result.diagnostics) == 0 or len(char_result.diagnostics) == 0 {
    give false;
  }
  let escape_diag = escape_result.diagnostics[0];
  let char_diag = char_result.diagnostics[0];
  give escape_diag.code == "LEX_E_INVALID_ESCAPE" and escape_diag.line == 1 and char_diag.code == "LEX_E_INVALID_CHAR_LITERAL" and char_diag.line == 1;
}

proc test_scanner_keeps_attribute_tokens() -> bool {
  let result: ScanResult = scan_tokens(attributes_source());
  let attr_index: int = token_index(result, "#[");
  give result.valid and attr_index >= 0 and token_index(result, "entry") >= 0;
}

proc test_scanner_recognizes_region_keyword() -> bool {
  let result: ScanResult = scan_tokens("region heap: arena;\n");
  let region_index: int = token_index(result, "region");
  if not result.valid or region_index < 0 {
    give false;
  }
  give result.tokens[region_index as u64].kind == TokenKind.Keyword;
}

proc test_scanner_accepts_number_prefixes_and_suffixes() -> bool {
  let result: ScanResult = scan_tokens(number_suffix_source());
  let hex_index: int = token_index(result, "0xFFu32");
  let bin_index: int = token_index(result, "0b10_01");
  if not result.valid or hex_index < 0 or bin_index < 0 {
    give false;
  }
  give result.tokens[hex_index as u64].kind == TokenKind.Integer and result.tokens[bin_index as u64].kind == TokenKind.Integer;
}

proc test_scanner_reports_precise_invalid_char() -> bool {
  let result: ScanResult = scan_tokens("proc main() { @ }\n");
  if result.valid or len(result.diagnostics) == 0 {
    give false;
  }
  let diag = result.diagnostics[0];
  give diag.code == "LEX_E_INVALID_CHAR" and diag.line == 1 and diag.column == 15 and diag.width == 1;
}

proc test_scanner_accepts_char_literals() -> bool {
  let result: ScanResult = scan_tokens("const c = 'x'; const nl = '\\n';\n");
  let plain_index: int = token_index(result, "'x'");
  let escape_index: int = token_index(result, "'\\n'");
  if not result.valid or plain_index < 0 or escape_index < 0 {
    give false;
  }

  give result.tokens[plain_index as u64].kind == TokenKind.Char
    and result.tokens[escape_index as u64].kind == TokenKind.Char;
}

proc test_scanner_accepts_ebnf_operator_surface() -> bool {
  let result: ScanResult = scan_tokens("let x = ~a && b || c; x <<= 1; x >>= 2;\n");
  let tilde_index: int = token_index(result, "~");
  let and_index: int = token_index(result, "&&");
  let or_index: int = token_index(result, "||");
  let lshift_assign_index: int = token_index(result, "<<=");
  let rshift_assign_index: int = token_index(result, ">>=");
  if not result.valid
    or tilde_index < 0
    or and_index < 0
    or or_index < 0
    or lshift_assign_index < 0
    or rshift_assign_index < 0 {

    give false;
  }

  give result.tokens[tilde_index as u64].kind == TokenKind.Symbol
    and result.tokens[and_index as u64].kind == TokenKind.Symbol
    and result.tokens[or_index as u64].kind == TokenKind.Symbol
    and result.tokens[lshift_assign_index as u64].kind == TokenKind.Symbol
    and result.tokens[rshift_assign_index as u64].kind == TokenKind.Symbol;
}

proc test_scanner_accepts_full_ebnf_symbol_surface() -> bool {
  let source: string =
    "() [] { } , ; : :: . .. ... ..= -> => " +
    "+ += - -= * *= / /= % %= " +
    "& &= && | |= || ^ ^= ! != = == < <= << <<= > >= >> >>= ? ?? ~\n";
  let result: ScanResult = scan_tokens(source);
  let symbols: [string] = [
    "(", ")", "[", "]", "{", "}", ",", ";", ":", "::", ".", "..", "...", "..=", "->", "=>",
    "+", "+=", "-", "-=", "*", "*=", "/", "/=", "%", "%=",
    "&", "&=", "&&", "|", "|=", "||", "^", "^=", "!", "!=", "=", "==", "<", "<=", "<<", "<<=", ">", ">=", ">>", ">>=", "?", "??", "~"
  ];
  if not result.valid {
    give false;
  }

  let i: u64 = 0;
  while i < len(symbols) {
    let index: int = token_index(result, symbols[i]);
    if index < 0 or result.tokens[index as u64].kind != TokenKind.Symbol {
      give false;
    }
    set i = i + 1;
  }

  give true;
}

proc test_scanner_skips_all_ebnf_comment_forms() -> bool {
  let result: ScanResult = scan_tokens(
    "# hash comment\n" +
    "// slash comment\n" +
    "/// doc comment\n" +
    "/* block comment */\n" +
    "<<< region comment >>>\n" +
    "proc main() { give 0; }\n"
  );
  let proc_index: int = token_index(result, "proc");
  give result.valid
    and result.metrics.comment_count == 5
    and proc_index >= 0
    and result.tokens[proc_index as u64].line == 6;
}

proc test_scanner_accepts_float_exponents() -> bool {
  let result: ScanResult = scan_tokens("const a = 1.5e10; const b = 2E-3; const c = 6.02e+23;\n");
  let a_index: int = token_index(result, "1.5e10");
  let b_index: int = token_index(result, "2E-3");
  let c_index: int = token_index(result, "6.02e+23");
  if not result.valid or a_index < 0 or b_index < 0 or c_index < 0 {
    give false;
  }

  give result.tokens[a_index as u64].kind == TokenKind.Float
    and result.tokens[b_index as u64].kind == TokenKind.Float
    and result.tokens[c_index as u64].kind == TokenKind.Float;
}

proc test_scanner_rejects_invalid_prefixed_numbers() -> bool {
  let result: ScanResult = scan_tokens(invalid_prefixed_numbers_source());
  if result.valid or len(result.diagnostics) < 3 {
    give false;
  }

  give result.diagnostics[0].code == "LEX_E_INVALID_NUMBER"
    and result.diagnostics[1].code == "LEX_E_INVALID_NUMBER"
    and result.diagnostics[2].code == "LEX_E_INVALID_NUMBER";
}

proc test_scanner_accepts_raw_string_literals() -> bool {
  let result: ScanResult = scan_tokens("const a = r\"doc\"; const b = \"\"\"multi\nline\"\"\";\n");
  let raw_index: int = token_index(result, "r\"doc\"");
  let triple_index: int = token_index(result, "\"\"\"multi\nline\"\"\"");
  if not result.valid or raw_index < 0 or triple_index < 0 {
    give false;
  }

  give result.tokens[raw_index as u64].kind == TokenKind.String
    and result.tokens[triple_index as u64].kind == TokenKind.String;
}

proc test_lexer_canonical_diagnostic_declares_phase_and_fix() -> bool {
  let raw: LexerDiagnostic = invalid_character("@", 1, 15);
  let diag: Diagnostic = lexer_diagnostic_as_diagnostic("lexer_phase.vit", raw);
  give diag.phase == DiagnosticPhase.Lexer
    and diag.rule == "source character set"
    and diag.probable_fix != ""
    and len(diag.pipeline_context) >= 2;
}

proc test_lexer_expected_error_kinds_have_rich_diagnostics() -> bool {
  let diags: [LexerDiagnostic] = [
    invalid_number("1__2", 1, 1),
    unterminated_string(1, 5),
    invalid_char_literal("'ab'", 2, 3),
    unterminated_block_comment(3, 1),
    invalid_unicode_escape("\\u{ZZ}", 4, 6),
    token_too_large("payload", 5, 2, 17)
  ];

  let i: u64 = 0;
  while i < len(diags) {
    let diag: Diagnostic = lexer_diagnostic_as_diagnostic("lexer_rich.vit", diags[i]);
    if diag.phase != DiagnosticPhase.Lexer
      or diag.explanation == ""
      or diag.documentation_url == ""
      or diag.probable_fix == "" {

      give false;
    }

    set i = i + 1;
  }

  give true;
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_scanner_preserves_positions_after_comments() {
    set failures = failures + 1;
  }
  if not test_scanner_preserves_exact_token_spans() {
    set failures = failures + 1;
  }
  if not test_scanner_accepts_number_prefixes_and_suffixes() {
    set failures = failures + 1;
  }
  if not test_scanner_reports_precise_invalid_number() {
    set failures = failures + 1;
  }
  if not test_digit_helpers_match_ebnf_classes() {
    set failures = failures + 1;
  }
  if not test_scanner_reports_precise_invalid_char() {
    set failures = failures + 1;
  }
  if not test_scanner_accepts_char_literals() {
    set failures = failures + 1;
  }
  if not test_scanner_accepts_ebnf_operator_surface() {
    set failures = failures + 1;
  }
  if not test_scanner_accepts_full_ebnf_symbol_surface() {
    set failures = failures + 1;
  }
  if not test_scanner_skips_all_ebnf_comment_forms() {
    set failures = failures + 1;
  }
  if not test_scanner_accepts_float_exponents() {
    set failures = failures + 1;
  }
  if not test_scanner_rejects_invalid_prefixed_numbers() {
    set failures = failures + 1;
  }
  if not test_scanner_accepts_raw_string_literals() {
    set failures = failures + 1;
  }
  if not test_scanner_reports_precise_invalid_escape_and_char_literal() {
    set failures = failures + 1;
  }
  if not test_lexer_canonical_diagnostic_declares_phase_and_fix() {
    set failures = failures + 1;
  }
  if not test_lexer_expected_error_kinds_have_rich_diagnostics() {
    set failures = failures + 1;
  }
  if not test_scanner_keeps_attribute_tokens() {
    set failures = failures + 1;
  }
  if not test_scanner_recognizes_region_keyword() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
