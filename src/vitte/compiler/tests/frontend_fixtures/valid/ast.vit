space vitte/compiler/tests/frontend_fixtures/valid/ast

proc structured_expr_source() -> string {
  give
    "proc main() -> i64 {\n" +
    "  let value = foo.bar[0](x + 1);\n" +
    "  let point = Point { x: value, y };\n" +
    "  set foo.bar[0] = value;\n" +
    "  give value;\n" +
    "}\n";
}

proc control_flow_source() -> string {
  give
    "proc main() {\n" +
    "  if (ready) { let x = 1; } else { while (waiting) { set waiting = false; } }\n" +
    "}\n";
}

proc rich_surface_source() -> string {
  give
    "#[entry]\n" +
    "pub async unsafe extern C proc main[T](value: &mut [foo::Bar[T]]) -> ?foo::Result[i64] {\n" +
    "  let (left, right): (i64, i64) = pair;\n" +
    "  for (item, next) in pairs { give item; }\n" +
    "  match value { case Some { inner } => inner; else => 0; };\n" +
    "  unsafe { give left; }\n" +
    "  with value as inner { give inner; }\n" +
    "  select ready { when _ { give left; } else { give right; } }\n" +
    "}\n" +
    "type Result[T] = ?foo::Bar[T];\n" +
    "opaque type Handle[T];\n" +
    "extern type Ctx[T];\n" +
    "impl foo::Bar[T] {}\n" +
    "compiler pipeline;\n" +
    "pass lower;\n" +
    "backend llvm;\n" +
    "diagnostic unused_value;\n" +
    "macro trace(node);\n" +
    "entry startup;\n";
}
