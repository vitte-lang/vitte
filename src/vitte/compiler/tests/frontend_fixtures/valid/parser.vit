space vitte/compiler/tests/frontend_fixtures/valid/parser

proc grammar_surface_source() -> string {
  give
    "space demo/app;\n" +
    "use demo/math as math;\n" +
    "proc main() -> int { let x: int = 1; if x { set x = math.sum(x, 1); } give x; }\n";
}

proc bits_surface_source() -> string {
  give
    "bits Mode: u8 {\n" +
    "  read: 0 .. 1,\n" +
    "  write: 1 .. 2,\n" +
    "  exec: 2 .. 3,\n" +
    "}\n";
}

export *
