space vitte/compiler/tests/sema_tests

use vitte/compiler/analysis/sema.{ SemaResult, run_sema_hir }
use vitte/compiler/analysis/sema/errors.{ SemaDiagnosticKind, SemaPhase, sema_context_error, sema_context_result, sema_context_with_phase, sema_invalid_import, sema_kind_name, sema_nearby_symbol, sema_phase_name, sema_result_summary, sema_string_distance, sema_summary, sema_unknown_symbol_with_candidates }
use vitte/compiler/analysis/sema/modules.{ imported_symbols_from_summary, module_import_from_use, summarize_module_hir }
use vitte/compiler/analysis/sema/names.{ PlaceRootKind, place_root_is_builtin, place_root_is_self, place_root_kind_name, place_root_name, sema_builtin_name, sema_is_ident_char }
use vitte/compiler/analysis/sema/scopes.{ SemaSymbolKind, SemaSymbolTable, SemaVisibility, symbol_kind_name, symbol_table_add_builtin, symbol_table_count_kind, symbol_table_enter_scope, symbol_table_import, symbol_table_insert, symbol_table_leave_scope, symbol_table_resolve }
use vitte/compiler/analysis/sema/visibility.{ normalize_visibility, visibility_exported, visibility_externally_visible, visibility_info, visibility_is_internal_only, visibility_less_permissive, visibility_merge, visibility_more_permissive, visibility_valid }
use vitte/compiler/driver/compile.{ DriverModuleSetArtifacts, analyze_source_set, driver_module_input }
use vitte/compiler/diagnostics/diagnostic.{ DiagnosticPhase }
use vitte/compiler/frontend/ast.node.{ ast_span_empty }
use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/middle/hir/lower_ast.{ lower_ast_to_hir }

const VERSION_TEXT: string = "analysis sema tests 0.1.0"
const BANNER_TEXT: string = "analysis sema tests"

proc has_code(result: SemaResult, code: string) -> bool {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc test_duplicate_binding() -> bool {
  let source: string = "proc main() { let x = 1; let x = 2; give x; }\n";
  let fe: FrontendOutput = frontend_run("sema_duplicate_binding.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  give has_code(result, "SEMA_E_DUPLICATE_BINDING");
}

proc test_undeclared_target() -> bool {
  let source: string = "proc main() { set x = 1; }\n";
  let fe: FrontendOutput = frontend_run("sema_undeclared_target.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  give has_code(result, "SEMA_E_UNDECLARED_TARGET");
}

proc test_unknown_identifier_suggests_nearby_symbol() -> bool {
  let source: string = "proc main() { let count = 1; give cout; }\n";
  let fe: FrontendOutput = frontend_run("sema_unknown_identifier.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    let diagnostic = result.diagnostics[i];
    if diagnostic.code == "SEMA_E_UNKNOWN_SYMBOL" {
      give fe.valid
        and not result.valid
        and find(diagnostic.message, "cout") >= 0
        and len(diagnostic.suggestions) >= 2
        and diagnostic.suggestions[1].replacement == "count";
    }
    set i = i + 1;
  }
  give false;
}

proc test_resolves_local_name_on_hir() -> bool {
  let source: string = "proc main() { let x = 1; give x; }\n";
  let fe: FrontendOutput = frontend_run("sema_resolve_local.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  let give_expr = result.hir.module.items[0].stmts[1].expr;
  give result.valid and give_expr.binding == "x" and give_expr.resolved_kind == "local" and give_expr.resolved_id > 0 and not give_expr.external;
}

proc test_resolves_set_target_projection() -> bool {
  let source: string = "proc main() { let x = make_box(); set x.field = 1; }\n";
  let fe: FrontendOutput = frontend_run("sema_set_projection.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  let set_stmt = result.hir.module.items[0].stmts[1];
  give result.valid and set_stmt.target_binding == "x.field" and set_stmt.target_resolved_kind == "local" and set_stmt.target_resolved_id > 0;
}

proc test_resolves_imported_proc_from_another_module() -> bool {
  let dep: string = "space demo/math;\nexport *;\nproc sum() -> int { give 0; }\n";
  let root: string = "space demo/app;\nuse demo/math { * };\nproc main() -> int { give sum(); }\n";
  let artifacts: DriverModuleSetArtifacts = analyze_source_set([
    driver_module_input("demo_math.vit", dep),
    driver_module_input("demo_app.vit", root)
  ]);
  let call_expr = artifacts.modules[1].resolved_hir.module.items[2].stmts[0].expr;
  give artifacts.valid and call_expr.resolved_kind == "import" and call_expr.resolved_id > 0;
}

proc test_resolves_imported_proc_through_module_alias_member_call() -> bool {
  let dep: string = "space demo/math;\nexport *;\nproc sum() -> int { give 0; }\n";
  let root: string = "space demo/app;\nuse demo/math as math;\nproc main() -> int { give math.sum(); }\n";
  let artifacts: DriverModuleSetArtifacts = analyze_source_set([
    driver_module_input("demo_math_alias.vit", dep),
    driver_module_input("demo_app_alias.vit", root)
  ]);
  let call_expr = artifacts.modules[1].resolved_hir.module.items[2].stmts[0].expr;
  let callee = call_expr.children[0];
  give artifacts.valid
    and callee.binding == "sum"
    and callee.resolved_kind == "import"
    and callee.resolved_id > 0
    and not callee.external;
}

proc test_non_exported_proc_stays_unresolved_across_modules() -> bool {
  let dep: string = "space demo/math;\nproc hidden() -> int { give 0; }\n";
  let root: string = "space demo/app;\nuse demo/math as math;\nproc main() -> int { give math.hidden(); }\n";
  let artifacts: DriverModuleSetArtifacts = analyze_source_set([
    driver_module_input("demo_math_hidden.vit", dep),
    driver_module_input("demo_app_hidden.vit", root)
  ]);
  let call_expr = artifacts.modules[1].resolved_hir.module.items[2].stmts[0].expr;
  let callee = call_expr.children[0];
  give artifacts.modules[1].analysis.sema_ok
    and not artifacts.modules[1].valid
    and callee.binding == "hidden"
    and callee.external;
}

proc test_missing_module_reports_tested_paths() -> bool {
  let root: string = "space demo/app;\nuse demo/missing as missing;\nproc main() -> int { give 0; }\n";
  let artifacts: DriverModuleSetArtifacts = analyze_source_set([
    driver_module_input("demo_app_missing.vit", root)
  ]);
  let diagnostics = artifacts.modules[0].analysis.diagnostics;
  let i: u64 = 0;
  while i < len(diagnostics) {
    let diagnostic = diagnostics[i];
    if diagnostic.code == "MOD_E_MODULE_NOT_FOUND" {
      give not artifacts.valid
        and not artifacts.modules[0].valid
        and diagnostic.file == "demo_app_missing.vit"
        and find(diagnostic.labels[1], "tested paths: ./demo/missing.vit") >= 0
        and find(diagnostic.labels[1], "src/demo/missing/mod.vit") >= 0;
    }
    set i = i + 1;
  }
  give false;
}

proc test_missing_module_suggests_nearby_module() -> bool {
  let dep: string = "space demo/math;\nexport *;\nproc sum() -> int { give 0; }\n";
  let root: string = "space demo/app;\nuse demo/maths as math;\nproc main() -> int { give 0; }\n";
  let artifacts: DriverModuleSetArtifacts = analyze_source_set([
    driver_module_input("demo_math.vit", dep),
    driver_module_input("demo_app_misspelled_module.vit", root)
  ]);
  let diagnostics = artifacts.modules[1].analysis.diagnostics;
  let i: u64 = 0;
  while i < len(diagnostics) {
    let diagnostic = diagnostics[i];
    if diagnostic.code == "MOD_E_MODULE_NOT_FOUND" {
      give not artifacts.valid
        and find(diagnostic.labels[2], "closest module: `demo/math`") >= 0
        and find(diagnostic.help, "did you mean module `demo/math`?") >= 0;
    }
    set i = i + 1;
  }
  give false;
}

proc test_invalid_visibility_is_rejected() -> bool {
  let source: string = "weird proc main() -> int { give 0; }\n";
  let fe: FrontendOutput = frontend_run("sema_invalid_visibility.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  give not result.valid and has_code(result, "SEMA_E_INVALID_VISIBILITY");
}

proc test_sema_name_helpers_cover_place_root_surface() -> bool {
  give place_root_name("self.field") == "self"
    and place_root_is_self("self.field")
    and place_root_is_builtin("argc")
    and sema_builtin_name("target")
    and sema_is_ident_char("7")
    and place_root_kind_name(PlaceRootKind.Builtin) == "builtin";
}

proc test_sema_visibility_helpers_cover_supported_surface() -> bool {
  let info = visibility_info("pub");
  give normalize_visibility("pub") == "public"
    and visibility_valid("protected")
    and visibility_exported("export")
    and visibility_externally_visible("external")
    and visibility_is_internal_only("package")
    and visibility_merge("", "") == "private"
    and visibility_more_permissive("internal", "public") == "public"
    and visibility_less_permissive("public", "package") == "package"
    and info.valid
    and info.normalized == "public"
    and info.exported
    and info.externally_visible;
}

proc test_sema_scope_helpers_cover_insert_import_and_scope_exit() -> bool {
  let table0: SemaSymbolTable = symbol_table_add_builtin(
    symbol_table_import(
      symbol_table_insert(
        symbol_table_enter_scope(
          symbol_table_insert(
            symbol_table_insert(
              SemaSymbolTable { symbols: [], next_id: 1, scope_depth: 0, module_path: "demo/app" },
              "sum",
              SemaSymbolKind.Function,
              false,
              SemaVisibility.Public,
              "fn() -> int",
              1,
              1
            ),
            "Point",
            SemaSymbolKind.Form,
            false,
            SemaVisibility.Public,
            "type",
            1,
            1
          )
        ),
        "value",
        SemaSymbolKind.Local,
        false,
        SemaVisibility.Private,
        "int",
        2,
        3
      ),
      "imported_sum",
      "demo/math",
      "fn() -> int",
      1
    ),
    "argc",
    "int"
  );
  let local0 = symbol_table_resolve(table0, "value");
  let imported0 = symbol_table_resolve(table0, "demo/math::imported_sum");
  let builtin0 = symbol_table_resolve(table0, "argc");
  let table1: SemaSymbolTable = symbol_table_leave_scope(table0);
  let dropped_local = symbol_table_resolve(table1, "value");
  give local0.valid
    and local0.kind == SemaSymbolKind.Local
    and imported0.valid
    and imported0.kind == SemaSymbolKind.Imported
    and builtin0.valid
    and builtin0.kind == SemaSymbolKind.Builtin
    and symbol_table_count_kind(table0, SemaSymbolKind.Imported) == 1
    and symbol_kind_name(SemaSymbolKind.Form) == "form"
    and not dropped_local.valid;
}

proc test_sema_module_helpers_cover_alias_and_export_summary() -> bool {
  let source: string =
    "space demo/app;\n" +
    "use demo/math as math;\n" +
    "public proc sum() -> int { give 0; }\n" +
    "internal proc hidden() -> int { give 0; }\n";
  let fe: FrontendOutput = frontend_run("sema_module_helpers.vit", source);
  let hir = lower_ast_to_hir(fe);
  let summary = summarize_module_hir(hir, 1000);
  let imported = module_import_from_use("demo/math as math");
  let symbols = imported_symbols_from_summary(summary);
  give fe.valid
    and summary.valid
    and summary.module_path == "demo/app"
    and len(summary.imports) == 1
    and summary.imports[0].module_path == "demo/math"
    and summary.imports[0].alias == "math"
    and not summary.imports[0].import_all
    and imported.valid
    and imported.alias == "math"
    and len(summary.exports) == 1
    and summary.exports[0].name == "sum"
    and len(symbols) == 1
    and symbols[0].qualified_name == "demo/app::sum"
    and symbols[0].module_path == "demo/app";
}

proc test_sema_error_helpers_cover_context_and_summary() -> bool {
  let diag = sema_invalid_import("demo/bad", ast_span_empty());
  let ctx = sema_context_error(
    sema_context_with_phase(SemaPhase.ImportResolution),
    "SEMA_E_INVALID_IMPORT",
    SemaDiagnosticKind.InvalidImport,
    "invalid import `demo/bad`",
    ["demo/bad"],
    "use a canonical module path",
    ast_span_empty()
  );
  let report = sema_context_result(ctx);
  give diag.code == "SEMA_E_INVALID_IMPORT"
    and diag.phase == DiagnosticPhase.ModuleResolution
    and sema_phase_name(SemaPhase.TraitResolution) == "trait_resolution"
    and sema_kind_name(SemaDiagnosticKind.InvalidVisibility) == "invalid_visibility"
    and sema_summary(diag) != ""
    and not report.valid
    and find(sema_result_summary(report), "sema failed:") >= 0;
}

proc test_unknown_symbol_suggests_nearby_visible_symbol() -> bool {
  let diag = sema_unknown_symbol_with_candidates("cout", ["count", "value", "counter"], ast_span_empty());
  give sema_string_distance("cout", "count") == 1
    and sema_nearby_symbol("cout", ["count", "value"]) == "count"
    and sema_nearby_symbol("unknown", ["count", "value"]) == ""
    and diag.code == "SEMA_E_UNKNOWN_SYMBOL"
    and len(diag.suggestions) == 2
    and diag.suggestions[1].replacement == "count";
}

proc test_resolves_type_level_surface_item_kinds() -> bool {
  let source: string =
    "form Point { x: int, y: int }\n" +
    "bits Mode: u8 {\n" +
    "  read: 0 .. 1,\n" +
    "}\n" +
    "pick Option[T] {\n" +
    "  None,\n" +
    "  Some(T),\n" +
    "}\n" +
    "flags Access: u8 {\n" +
    "  read = 1,\n" +
    "}\n" +
    "trait Show {\n" +
    "  proc show(self: Self) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self) -> string { give \"point\"; }\n" +
    "}\n" +
    "proc main() -> int { give 0; }\n";
  let fe: FrontendOutput = frontend_run("sema_surface_items.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  give result.valid
    and result.hir.module.items[0].resolved_kind == "form"
    and result.hir.module.items[1].resolved_kind == "type"
    and result.hir.module.items[2].resolved_kind == "pick"
    and result.hir.module.items[3].resolved_kind == "type"
    and result.hir.module.items[6].resolved_kind == "function"
    and result.hir.module.items[1].annotation_text == "u8"
    and result.hir.module.items[5].target_type_text == "Point";
}

proc test_sema_preserves_member_params_without_duplicate_symbol_growth() -> bool {
  let source: string =
    "form Point { x: int }\n" +
    "trait Show {\n" +
    "  proc show(self: Self, level: int) -> string;\n" +
    "}\n" +
    "impl Show for Point {\n" +
    "  proc show(self: Self, level: int) -> string { give \"point\"; }\n" +
    "}\n";
  let fe: FrontendOutput = frontend_run("sema_member_params.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: SemaResult = run_sema_hir(hir);
  let trait_member = result.hir.module.items[1].members[0];
  let impl_member = result.hir.module.items[2].members[0];
  give result.valid
    and result.symbol_count == 8
    and len(trait_member.params) == 2
    and trait_member.params[0].name == "self"
    and trait_member.params[0].annotation_text == "Self"
    and trait_member.params[1].name == "level"
    and trait_member.params[1].annotation_text == "int"
    and len(impl_member.params) == 2
    and impl_member.body_stmts[0].expr.text == "\"point\"";
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_duplicate_binding() {
    set failures = failures + 1;
  }
  if not test_undeclared_target() {
    set failures = failures + 1;
  }
  if not test_unknown_identifier_suggests_nearby_symbol() {
    set failures = failures + 1;
  }
  if not test_resolves_local_name_on_hir() {
    set failures = failures + 1;
  }
  if not test_resolves_set_target_projection() {
    set failures = failures + 1;
  }
  if not test_resolves_imported_proc_from_another_module() {
    set failures = failures + 1;
  }
  if not test_resolves_imported_proc_through_module_alias_member_call() {
    set failures = failures + 1;
  }
  if not test_non_exported_proc_stays_unresolved_across_modules() {
    set failures = failures + 1;
  }
  if not test_missing_module_reports_tested_paths() {
    set failures = failures + 1;
  }
  if not test_missing_module_suggests_nearby_module() {
    set failures = failures + 1;
  }
  if not test_invalid_visibility_is_rejected() {
    set failures = failures + 1;
  }
  if not test_sema_name_helpers_cover_place_root_surface() {
    set failures = failures + 1;
  }
  if not test_sema_visibility_helpers_cover_supported_surface() {
    set failures = failures + 1;
  }
  if not test_sema_scope_helpers_cover_insert_import_and_scope_exit() {
    set failures = failures + 1;
  }
  if not test_sema_module_helpers_cover_alias_and_export_summary() {
    set failures = failures + 1;
  }
  if not test_sema_error_helpers_cover_context_and_summary() {
    set failures = failures + 1;
  }
  if not test_unknown_symbol_suggests_nearby_visible_symbol() {
    set failures = failures + 1;
  }
  if not test_resolves_type_level_surface_item_kinds() {
    set failures = failures + 1;
  }
  if not test_sema_preserves_member_params_without_duplicate_symbol_growth() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
