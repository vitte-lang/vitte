space vitte/compiler/tests/lint_tests

use vitte/compiler/analysis/lint.{ LintResult, run_lint_hir }
use vitte/compiler/analysis/sema.{ SemaResult, run_sema_hir }
use vitte/compiler/analysis/typeck.checker.{ run_typeck_hir }
use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/middle/hir/lower_ast.{ lower_ast_to_hir }

const VERSION_TEXT: string = "analysis lint tests 0.1.0"
const BANNER_TEXT: string = "analysis lint tests"

proc has_code(result: LintResult, code: string) -> bool {
  let i: u64 = 0;
  while i < len(result.diagnostics) {
    if result.diagnostics[i].code == code {
      give true;
    }
    set i = i + 1;
  }
  give false;
}

proc test_unused_mut_and_local() -> bool {
  let source: string = "proc main() { let mut x = 1; give 0; }\n";
  let fe: FrontendOutput = frontend_run("lint_unused_mut.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: LintResult = run_lint_hir("lint_unused_mut.vit", hir);
  give has_code(result, "LINT_W_UNUSED_MUT") and has_code(result, "LINT_W_UNUSED_LOCAL");
}

proc test_constant_condition() -> bool {
  let source: string = "proc main() { if true { give 1; } else { give 0; } }\n";
  let fe: FrontendOutput = frontend_run("lint_constant_condition.vit", source);
  let hir = lower_ast_to_hir(fe);
  let result: LintResult = run_lint_hir("lint_constant_condition.vit", hir);
  give has_code(result, "LINT_W_CONSTANT_CONDITION");
}

proc test_projected_set_counts_as_mutation() -> bool {
  let source: string = "proc main() { let mut x = make_box(); set x.field = 1; give x; }\n";
  let fe: FrontendOutput = frontend_run("lint_projected_set.vit", source);
  let hir = lower_ast_to_hir(fe);
  let sema: SemaResult = run_sema_hir(hir);
  let typed = run_typeck_hir(sema.hir);
  let result: LintResult = run_lint_hir("lint_projected_set.vit", typed.hir);
  give not has_code(result, "LINT_W_UNUSED_MUT");
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_unused_mut_and_local() { set failures = failures + 1; }
  if not test_constant_condition() { set failures = failures + 1; }
  if not test_projected_set_counts_as_mutation() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
