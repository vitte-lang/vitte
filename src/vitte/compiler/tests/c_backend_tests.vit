proc test_c_backend_rejects_invalid_target_with_diagnostic() -> bool {
  let source: string = "proc main() -> int { give 0; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_backend_bad_target.vit", source, "bogus-target", "build/c_backend_bad_target", "executable");
