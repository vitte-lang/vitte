use vitte/compiler/backend/c/abi.{ C_ABI_NAME, C_ABI_SCHEMA_VERSION, CAbiPassMode, c_abi_contract, c_abi_function, c_abi_header_prelude, c_abi_param_value }
use vitte/compiler/backend/ir.{ IrUnit, target_native_x86_64_linux, unit_empty, unit_with_source_path }
use vitte/compiler/frontend/ast/node.{ ast_span_empty }
use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/middle/mir.{ MirBinaryOperator, MirBlock, MirBorrowKind, MirFunction, MirModule, MirOperand, MirPlace, MirRvalue, MirRvalueKind, MirStatement, MirStatementKind, MirTerminatorKind, MirUnaryOperator, MirUnit, mir_terminator_return }
use vitte/compiler/middle/mir/validate.{ validate_mir }
use vitte/compiler/middle/pipeline.{ MiddleOutput, middle_run_frontend }

const VERSION_TEXT: string = "c backend tests 0.1.0"
const BANNER_TEXT: string = "c backend tests"

proc test_emit_simple_main() -> bool {
  let source: string = "proc main() -> int { give 0; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_backend_main.vit", source, "c11", "build/c_backend_main", "executable");
  give result.valid
    and find(result.emitted.source_text, "main") >= 0
    and find(result.link_plan.command_line, "cc") >= 0
    and find(result.link_plan.command_line, "vitte_generated.c") >= 0;
}

proc test_emit_branching_function() -> bool {
  let source: string = "proc main() -> int { let flag = true; if flag { give 1; } give 0; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_backend_branch.vit", source, "x86_64-linux", "build/c_backend_branch", "executable");
  give result.valid
    and find(result.emitted.source_text, "goto bb_") >= 0
    and find(result.emitted.source_text, "if (") >= 0;
}

proc test_c_backend_wrappers_match_canonical_frontend_entry() -> bool {
  let source: string = "proc main() -> int { give 0; }\n";
  let frontend: FrontendOutput = frontend_run("c_backend_canonical.vit", source);
  let canonical: CBackendPipelineResult = run_c_backend_frontend(frontend, "c11", "build/c_backend_canonical", "executable");
  let wrapper: CBackendPipelineResult = run_c_backend_source("c_backend_canonical.vit", source, "c11", "build/c_backend_canonical", "executable");
  give canonical.valid
    and wrapper.valid
    and canonical.middle.valid == wrapper.middle.valid
    and canonical.middle.mir.function_count == wrapper.middle.mir.function_count
    and canonical.lowered.function_count == wrapper.lowered.function_count
    and canonical.emitted.valid == wrapper.emitted.valid
    and canonical.link_plan.valid == wrapper.link_plan.valid
    and canonical.message == wrapper.message;
}

proc test_c_backend_emits_regular_proc_signature_from_canonical_mir() -> bool {
  let source: string = "proc add(borrow value: int, mut flag: bool, ...) -> int { if flag { give value; } give 0; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_backend_proc_signature.vit", source, "c11", "build/c_backend_proc_signature", "executable");
  give result.valid
    and len(result.middle.mir.module.functions[0].params) == 3
    and result.middle.mir.module.functions[0].params[0].name == "value"
    and result.middle.mir.module.functions[0].params[0].borrowed
    and result.middle.mir.module.functions[0].params[1].mutable
    and result.middle.mir.module.functions[0].params[2].variadic
    and find(result.emitted.header_text, "VITTE_ABI_VITTE int64_t add(const int64_t* value, bool flag, ...);") >= 0
    and find(result.emitted.source_text, "VITTE_ABI_VITTE int64_t add(const int64_t* value, bool flag, ...) {") >= 0;
}

proc test_c_abi_v1_contract_is_explicit_and_checked() -> bool {
  let profile = c_target_x86_64_linux();
  let contract = c_abi_contract(profile);
  let borrowed = c_abi_param_value("int", "const int64_t*", true, false, false);
  let mutable_borrow = c_abi_param_value("int", "int64_t*", true, true, false);
  let direct = c_abi_param_value("bool", "bool", false, false, false);
  let variadic = c_abi_param_value("...", "...", false, false, true);
  let c_signature = c_abi_function(profile, "C", "int", "int64_t", [borrowed, direct, variadic], false);
  let wrong_target_signature = c_abi_function(profile, "win64", "int", "int64_t", [direct], false);
  give contract.valid
    and contract.name == C_ABI_NAME
    and contract.schema_version == C_ABI_SCHEMA_VERSION
    and contract.calling_convention == "sysv64"
    and contract.pointer_width == 64
    and contract.stack_alignment == 16
    and contract.shadow_space == 0
    and contract.integer_argument_register_count == 6
    and contract.floating_argument_register_count == 8
    and c_type_for_vitte_type(profile, "char") == "uint32_t"
    and borrowed.pass_mode == CAbiPassMode.Indirect and borrowed.readonly
    and mutable_borrow.pass_mode == CAbiPassMode.Indirect and not mutable_borrow.readonly
    and direct.pass_mode == CAbiPassMode.Direct
    and variadic.pass_mode == CAbiPassMode.Variadic
    and c_signature.valid and c_signature.canonical_abi == "c" and c_signature.declaration_macro == "VITTE_ABI_C" and c_signature.variadic
    and not wrong_target_signature.valid
    and find(c_abi_header_prelude(), "#define VITTE_ABI_VITTE VITTE_ABI_C") >= 0;
}

proc test_c_abi_is_preserved_from_hir_to_canonical_ir() -> bool {
  let source: string =
    "extern C proc host_add(left: int, right: int) -> int;\n" +
    "proc main() -> int { give 0; }\n";
  let frontend: FrontendOutput = frontend_run("c_abi_propagation.vit", source);
  let middle: MiddleOutput = middle_run_frontend(frontend);
  give frontend.valid
    and middle.valid
    and len(middle.ir.modules) == 1
    and len(middle.ir.modules[0].functions) >= 2
    and middle.ir.modules[0].functions[0].name == "host_add"
    and middle.ir.modules[0].functions[0].abi == "C"
    and middle.ir.modules[0].functions[1].name == "main"
    and middle.ir.modules[0].functions[1].abi == "Vitte";
}

proc test_c_backend_emits_external_calls_as_declarations_only() -> bool {
  let source: string =
    "extern C proc host_add(left: int, right: int) -> int;\n" +
    "proc main() -> int { give 0; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_external_declaration.vit", source, "c11", "build/c_external_declaration", "executable");
  give result.valid
    and len(result.lowered.functions) == 2
    and result.lowered.functions[0].name == "host_add"
    and result.lowered.functions[0].declaration_only
    and find(result.emitted.header_text, "VITTE_ABI_C int64_t host_add(int64_t left, int64_t right);") >= 0
    and find(result.emitted.source_text, "host_add(int64_t left, int64_t right) {") < 0
    and len(result.middle.ir.modules[0].external_symbols) >= 1
    and result.middle.ir.modules[0].external_symbols[0] == "host_add";
}

proc test_c_backend_lowers_struct_tuple_and_array_values() -> bool {
  let source: string =
    "form Point { x: int, y: int }\n" +
    "proc main() -> int { let point = Point { x: 1, y: 2 }; let values = [3, 4, 5]; let pair = (6, 7); give 0; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_aggregate_values.vit", source, "c11", "build/c_aggregate_values", "executable");
  give result.valid
    and find(result.emitted.header_text, "typedef struct VitteAggregate VitteAggregate;") >= 0
    and find(result.emitted.source_text, "point = ((struct Point){ .x = 1, .y = 2 });") >= 0
    and find(result.emitted.source_text, "values = (VitteAggregate){ .length = 3") >= 0
    and find(result.emitted.source_text, "pair = (VitteAggregate){ .length = 2") >= 0
    and find(result.emitted.source_text, "return 0;\n  return;") < 0;
}

proc test_c_backend_calls_use_borrow_abi_shape() -> bool {
  let source: string =
    "proc keep(borrow value: int) -> int { give value; }\n" +
    "proc main() -> int { let x = 1; let y = keep(x); give y; }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_backend_borrow_call_abi.vit", source, "c11", "build/c_backend_borrow_call_abi", "executable");
  give result.valid
    and find(result.emitted.header_text, "VITTE_ABI_VITTE int64_t keep(const int64_t* value);") >= 0
    and find(result.emitted.source_text, "const int64_t* vitte_borrow_") >= 0
    and find(result.emitted.source_text, " = (&x);") >= 0
    and find(result.emitted.source_text, "y = keep(vitte_borrow_") >= 0;
}

proc test_c_backend_preserves_borrow_passthrough_call_shape() -> bool {
  let source: string =
    "proc keep(borrow value: int) -> int { give value; }\n" +
    "proc forward(borrow value: int) -> int { give keep(value); }\n";
  let result: CBackendPipelineResult = run_c_backend_source("c_backend_borrow_passthrough.vit", source, "c11", "build/c_backend_borrow_passthrough", "executable");
  give result.valid
    and find(result.emitted.source_text, "VITTE_ABI_VITTE int64_t forward(const int64_t* value)") >= 0
    and find(result.emitted.source_text, "return keep(value);") >= 0
    and find(result.emitted.source_text, "vitte_borrow_") < 0;
}

