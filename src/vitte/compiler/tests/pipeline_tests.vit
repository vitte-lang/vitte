proc test_actual_invalid_source_colorized_diagnostics() -> bool {
  let source_text: string = invalid_escape_source();
  let result = check_source("pipeline_invalid_escape.vit", source_text);
  if result.status == DriverExitStatus.Ok {
    give false;
  }

  let i: u64 = 0;
  let diagnostics: [Diagnostic] = [];
  while i < len(result.frontend.diagnostics) {
    set diagnostics = diagnostics + [frontend_diag_as_diagnostic(result.frontend.diagnostics[i])];
    set i = i + 1;
  }

  let color_config: DiagnosticRenderConfig = default_render_config();
  set color_config.style = DiagnosticStyle.Human;
  set color_config.color = true;
  set color_config.show_phase = false;
  let rendered: string = render_report(diagnostic_report(diagnostics), color_config);
  give find(rendered, "\u001b[1m") >= 0
    and find(rendered, "\u001b[31m") >= 0
    and find(rendered, "help: ") >= 0;
}

proc test_cli_typed_diag_text_colorizes_severity() -> bool {
  let output: string = typed_diag_text("error", "DRIVER_E_TEST", "foo.vit", 1, 1, "message");
  give find(output, "\u001b[1m") >= 0
    and find(output, "\u001b[91m") >= 0
    and find(output, "\u001b[0m") >= 0;
}

proc test_driver_report_render_text_colorizes_severity() -> bool {
  let diag: diag_report.Diagnostic = diag_report.diagnostic("error", "DRIVER_E_TEST", "foo.vit", 1, 1, "message");
  let rendered: string = diag_report.render_text(diag);
  give find(rendered, "\u001b[1m") >= 0
    and find(rendered, "\u001b[91m") >= 0
    and find(rendered, "\u001b[0m") >= 0;
}

