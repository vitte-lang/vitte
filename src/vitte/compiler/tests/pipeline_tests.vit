space vitte/compiler/tests/pipeline_tests

use vitte/compiler/driver/compile.{ compile_source }
use vitte/compiler/driver/exit_status.{ DriverExitStatus }

const VERSION_TEXT: string = "compiler pipeline tests 0.1.0"
const BANNER_TEXT: string = "compiler pipeline tests"
const EXIT_CODE_OK: int = 0
const EXIT_CODE_FAIL: int = 1

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  let source_text: string = "proc main() -> int { give 0 }"
  let result = compile_source("pipeline_test.vit", source_text)

  if result.status == DriverExitStatus.Ok {
    give EXIT_CODE_OK
  }

  give EXIT_CODE_FAIL
}

export *
