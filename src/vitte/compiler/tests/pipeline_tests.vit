proc test_unix_exit_code_contract() -> bool {
  give exit_code(DriverExitStatus.Ok) == 0
    and exit_code(DriverExitStatus.ParseFailure) == 1
    and exit_code(DriverExitStatus.AnalysisFailure) == 1
    and exit_code(DriverExitStatus.InternalError) == 2
    and exit_code(DriverExitStatus.CodegenFailure) == 3
    and exit_code(DriverExitStatus.ObjectEmissionFailure) == 3
    and exit_code(DriverExitStatus.LinkFailure) == 4;
}

proc test_internal_compiler_error_renderer_contract() -> bool {
  let err: ice.InternalCompilerError = ice.internal_compiler_error(
    "typeck",
    "stack:run_compiler>run_analysis",
    "tests/pipeline/type_error.vit:1:1",
    "vittec2 stage2-vitte 0.1.0"
  );
  let text: string = ice.render_internal_compiler_error_text(err);
  let json: string = ice.render_internal_compiler_error_json(err);
  give err.valid
    and find(text, "error: internal compiler error") >= 0
    and find(text, "phase: typeck") >= 0
    and find(text, "stack trace: stack:run_compiler>run_analysis") >= 0
    and find(text, "source location: tests/pipeline/type_error.vit:1:1") >= 0
    and find(text, "compiler version: vittec2 stage2-vitte 0.1.0") >= 0
    and find(json, "\"error\":\"internal compiler error\"") >= 0
    and find(json, "\"phase\":\"typeck\"") >= 0
    and find(json, "\"stack_trace\":\"stack:run_compiler>run_analysis\"") >= 0;
}

proc test_native_panic_boundary_contract_surface() -> bool {
  let b0: panic_boundary.PanicBoundaryState = panic_boundary.native_panic_boundary_begin();
  let b1: panic_boundary.PanicBoundaryState = panic_boundary.native_panic_boundary_mark_triggered(b0, 2);
  let b2: panic_boundary.PanicBoundaryState = panic_boundary.native_panic_boundary_end(b1);
  give b0.active
    and b0.valid
    and b2.triggered
    and b2.panic_code == 2
    and not panic_boundary.native_panic_boundary_ok(b2);
}

proc test_runtime_c_native_contract_is_wired() -> bool {
  let runtime0: backend_infrastructure.RuntimeLibrary = backend_infrastructure.create_vitte_runtime();
  let saw_begin: bool = false;
  let saw_end: bool = false;
  let saw_triggered: bool = false;
  let saw_code: bool = false;
  let saw_reset: bool = false;
  let j: int = 0;
  while j < len(runtime0.functions) {
    let link_name: string = runtime0.functions[j].link_name;
    if link_name == "vitte_runtime_panic_boundary_begin" { set saw_begin = true; }
    if link_name == "vitte_runtime_panic_boundary_end" { set saw_end = true; }
    if link_name == "vitte_runtime_panic_boundary_triggered" { set saw_triggered = true; }
    if link_name == "vitte_runtime_panic_boundary_code" { set saw_code = true; }
    if link_name == "vitte_runtime_panic_boundary_reset" { set saw_reset = true; }
    set j = j + 1;
  }
  give runtime0.name == "vitte_runtime"
    and runtime0.c_header_path == "src/vitte/compiler/backends/runtime_c/vitte_runtime.h"
    and runtime0.c_source_path == "src/vitte/compiler/backends/runtime_c/vitte_runtime.c"
    and saw_begin and saw_end and saw_triggered and saw_code and saw_reset;
}

proc test_linker_auto_wires_runtime_c_payload() -> bool {
  let result: BackendPipelineResult = compile_to_valid_ir_with_profile_and_packaging(
    "tests/pipeline/hello_world.vit",
    "proc main() -> int { give 0; }",
    "x86_64",
    "x86_64-linux",
    "enterprise-default",
    true,
    true,
    "executable",
    false,
    default_llvm_toolchain_paths()
  );
  let runtime_output_ok: bool = len(result.artifact.outputs) >= 2
    and find(result.artifact.outputs[1].path, ".runtime.o") >= 0
    and result.artifact.outputs[1].ready;
  let runtime_section_ok: bool = len(result.artifact.sections) >= 6
    and result.artifact.sections[5].name == ".vitte.runtime"
    and find(result.artifact.sections[5].content, "runtime_c_source=src/vitte/compiler/backends/runtime_c/vitte_runtime.c") >= 0
    and find(result.artifact.sections[5].content, "runtime_symbol=vitte_runtime_panic_boundary_begin") >= 0;
  give result.valid and runtime_output_ok and runtime_section_ok;
}

proc test_compiler_logger_levels_contract() -> bool {
  let log0: logger.CompilerLogger = logger.compiler_logger(true, true);
  let log1: logger.CompilerLogger = logger.trace(log0, "trace event");
  let log2: logger.CompilerLogger = logger.debug(log1, "debug event");
  let log3: logger.CompilerLogger = logger.info(log2, "info event");
  let log4: logger.CompilerLogger = logger.warn(log3, "warn event");
  let log5: logger.CompilerLogger = logger.error(log4, "error event");
  give len(log5.entries) == 5
    and logger.level_text(log5.entries[0].level) == "trace"
    and logger.level_text(log5.entries[4].level) == "error";
}

proc test_target_config_profiles_contract() -> bool {
  let x64: config.TargetConfig = config.target_config_from_name("x86_64-linux-gnu");
  let arm64: config.TargetConfig = config.target_config_from_name("aarch64-linux-gnu");
  let i386: config.TargetConfig = config.target_config_from_name("i386-linux-gnu");
  let riscv64: config.TargetConfig = config.target_config_from_name("riscv64-linux-gnu");
  let m68k: config.TargetConfig = config.target_config_from_name("m68k-retro");
  let z80: config.TargetConfig = config.target_config_from_name("z80-retro");
  let x64_musl: config.TargetConfig = config.target_config_from_name("x86_64-linux-musl");
  let x64_win: config.TargetConfig = config.target_config_from_name("x86_64-pc-windows-msvc");
  let arm64_android: config.TargetConfig = config.target_config_from_name("aarch64-linux-android");
  let i686_musl: config.TargetConfig = config.target_config_from_name("i686-unknown-linux-musl");
  let riscv_gc: config.TargetConfig = config.target_config_from_name("riscv64gc-unknown-linux-gnu");
  let ppc64: config.TargetConfig = config.target_config_from_name("powerpc64le-unknown-linux-gnu");
  give x64.valid
    and arm64.valid
    and i386.valid
    and riscv64.valid
    and m68k.valid
    and z80.valid
    and x64_musl.valid
    and x64_win.valid
    and arm64_android.valid
    and i686_musl.valid
    and riscv_gc.valid
    and ppc64.valid
    and x64.pointer_size == 64
    and arm64.pointer_size == 64
    and i386.pointer_size == 32
    and riscv64.pointer_size == 64
    and x64.object_format == "elf"
    and arm64.object_format == "elf"
    and riscv64.object_format == "elf"
    and x64.abi == "sysv"
    and arm64.abi == "aapcs64"
    and m68k.target_triple == "i386-linux"
    and z80.target_triple == "i386-linux"
    and x64_musl.target_triple == "x86_64-linux"
    and x64_win.target_triple == "x86_64-linux"
    and arm64_android.target_triple == "aarch64-linux"
    and i686_musl.target_triple == "i386-linux"
    and riscv_gc.target_triple == "riscv64-linux"
    and ppc64.target_triple == "i386-linux";
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_compile_source_success() { set failures = failures + 1; }
  if not test_compiler_main_dispatches_inline_check() { set failures = failures + 1; }
  if not test_compiler_main_dispatches_inline_build() { set failures = failures + 1; }
  if not test_compiler_main_accepts_verbose_flag() { set failures = failures + 1; }
  if not test_compiler_main_refuses_file_without_loader() { set failures = failures + 1; }
  if not test_check_source_uses_validated_middle_path() { set failures = failures + 1; }
  if not test_lint_warning_is_nonfatal() { set failures = failures + 1; }
  if not test_check_source_uses_copy_aware_borrowck() { set failures = failures + 1; }
  if not test_check_source_releases_branch_borrow_at_scope_end() { set failures = failures + 1; }
  if not test_check_source_allows_partial_move_of_disjoint_field() { set failures = failures + 1; }
  if not test_check_source_resolved_reference_flow() { set failures = failures + 1; }
  if not test_analyze_source_exposes_resolved_and_typed_hir() { set failures = failures + 1; }
  if not test_native_spans_are_emitted_for_frontend_and_analysis_diagnostics() { set failures = failures + 1; }
  if not test_dump_hir_and_lower_mir_helpers() { set failures = failures + 1; }
  if not test_stop_after_parse_exact() { set failures = failures + 1; }
  if not test_stop_after_hir_exact() { set failures = failures + 1; }
  if not test_stop_after_typeck_exact() { set failures = failures + 1; }
  if not test_stop_after_mir_exact() { set failures = failures + 1; }
  if not test_stop_after_ir_exact() { set failures = failures + 1; }
  if not test_stop_after_codegen_exact() { set failures = failures + 1; }
  if not test_stop_after_link_exact() { set failures = failures + 1; }
  if not test_stop_after_run_exact() { set failures = failures + 1; }
  if not test_session_source_manager_does_not_duplicate_input_snapshot() { set failures = failures + 1; }
  if not test_incremental_invalidation_targets_dependents() { set failures = failures + 1; }
  if not test_incremental_local_change_minimal_recompile() { set failures = failures + 1; }
  if not test_analyze_source_set_resolves_imported_module() { set failures = failures + 1; }
  if not test_real_pipeline_json_dumps() { set failures = failures + 1; }
  if not test_cli_json_dump_routes() { set failures = failures + 1; }
  if not test_runtime_surface_dispatch_prefers_pipeline_json() { set failures = failures + 1; }
  if not test_runtime_surface_dispatch_from_args() { set failures = failures + 1; }
  if not test_runtime_surface_dispatch_rejects_unsupported_combo() { set failures = failures + 1; }
  if not test_driver_report_includes_registry_sections() { set failures = failures + 1; }
  if not test_driver_report_includes_stage_logs() { set failures = failures + 1; }
  if not test_pipeline_fixture_hello_world_builds() { set failures = failures + 1; }
  if not test_pipeline_fixture_syntax_error_fails_before_sema() { set failures = failures + 1; }
  if not test_pipeline_fixture_type_error_fails_in_analysis() { set failures = failures + 1; }
  if not test_pipeline_fixture_borrow_error_fails_in_analysis() { set failures = failures + 1; }
  if not test_pipeline_fixture_backend_failure_fails_build() { set failures = failures + 1; }
  if not test_unix_exit_code_contract() { set failures = failures + 1; }
  if not test_internal_compiler_error_renderer_contract() { set failures = failures + 1; }
  if not test_native_panic_boundary_contract_surface() { set failures = failures + 1; }
  if not test_runtime_c_native_contract_is_wired() { set failures = failures + 1; }
  if not test_linker_auto_wires_runtime_c_payload() { set failures = failures + 1; }
  if not test_compiler_logger_levels_contract() { set failures = failures + 1; }
  if not test_target_config_profiles_contract() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
