proc test_compiler_result_json_includes_canonical_validation_reason() -> bool {
  let result: CompilerResult = CompilerResult {
    status: DriverExitStatus.IrValidationFailure,
    code: exit_code(DriverExitStatus.IrValidationFailure),
    message: structured_validation_failure_message("IR lowering/verification failed in middle pipeline", "ir_validate", "invalid-method-dispatch-target"),
    stage: CompilerStage.IrValidate,
    output: CompilerOutput {
      executable_path: "build/app",
      object_path: "build/app.o",
      assembly_path: "",
      ir_path: "",
      report_path: "",
      program_exit_code: 0
    },
    diagnostics: [],
    stage_logs: ["enter:13.backend_emit+14.object_file"],
    phase_results: ["MIR verify=Success"]
  };
  let report_json: string = compiler_result_json("build", result);
  give find(report_json, "\"command\":\"build\"") >= 0
    and find(report_json, "\"pipeline_failed_at\":\"ir_validate\"") >= 0
    and find(report_json, "\"pipeline_failure_reason\":\"invalid-method-dispatch-target\"") >= 0
    and find(report_json, "\"validation_reason\":\"invalid-method-dispatch-target\"") >= 0
    and find(report_json, "\"object_path\":\"build/app.o\"") >= 0
    and find(report_json, "\"executable_path\":\"build/app\"") >= 0;
}

