proc test_analyze_source_set_resolves_imported_module() -> bool {
  let dep: string = "space demo/math;\nexport *;\nproc sum() -> int { give 0; }\n";
  let root: string = "space demo/app;\nuse demo/math { * };\nproc main() -> int { give sum(); }\n";
  let artifacts: DriverModuleSetArtifacts = analyze_source_set([
    driver_module_input("demo_math.vit", dep),
    driver_module_input("demo_app.vit", root)
  ]);
  give artifacts.valid and len(artifacts.modules[1].imports) == 1 and artifacts.modules[1].imports[0] == "demo/math";
}

proc test_real_pipeline_json_dumps() -> bool {
  let source_text: string = "proc main() -> int { let x = 1; set x = \"oops\"; give x; }\n";
  let ast_json: string = dump_ast_json("pipeline_ast_json.vit", source_text);
  let hir_json: string = dump_hir_json("pipeline_hir_json.vit", source_text);
  let mir_json: string = dump_mir_json("pipeline_mir_json.vit", source_text);
  let diag_json: string = dump_diagnostics_json("pipeline_diag_json.vit", source_text);
  give find(ast_json, "\"surface\":\"ast\"") >= 0
    and find(ast_json, "\"token_count\":") >= 0
    and find(ast_json, "\"producer\":\"vitte-driver-native\"") >= 0
    and find(ast_json, "\"command\":\"parse\"") >= 0
    and find(ast_json, "\"status\":\"ok\"") >= 0
    and find(ast_json, "\"source\":{\"path\":\"pipeline_ast_json.vit\",\"bytes\":") >= 0
    and find(ast_json, "\"summary\":{\"token_count\":") >= 0
    and find(ast_json, "\"ast\":{\"kind\":\"native-structural\"") >= 0
    and find(ast_json, "\"macro_trace\":\"macro:") >= 0
    and find(hir_json, "\"surface\":\"hir\"") >= 0
    and find(hir_json, "\"node_count\":") >= 0
    and find(hir_json, "\"producer\":\"vitte-driver-native\"") >= 0
    and find(hir_json, "\"command\":\"check\"") >= 0
    and find(hir_json, "\"summary\":{\"node_count\":") >= 0
    and find(hir_json, "\"hir\":{\"kind\":\"native-typed\"") >= 0
    and find(hir_json, "\"first_item_name\":\"main\"") >= 0
    and find(mir_json, "\"surface\":\"mir\"") >= 0
    and find(mir_json, "\"instruction_count\":") >= 0
    and find(mir_json, "\"producer\":\"vitte-driver-native\"") >= 0
    and find(mir_json, "\"summary\":{\"function_count\":") >= 0
    and find(mir_json, "\"mir\":{\"kind\":\"native-lowered\"") >= 0
    and find(mir_json, "\"first_function_name\":\"main\"") >= 0
    and find(mir_json, "\"entry_block\":") >= 0
    and find(diag_json, "\"surface\":\"diagnostics\"") >= 0
    and find(diag_json, "\"analysis_diagnostic_count\":") >= 0
    and find(diag_json, "\"producer\":\"vitte-driver-native\"") >= 0
    and find(diag_json, "\"summary\":{\"frontend_diagnostic_count\":") >= 0
    and find(diag_json, "\"source\":{\"path\":\"pipeline_diag_json.vit\",\"bytes\":") >= 0
    and find(diag_json, "\"primary_report\":") >= 0
    and find(diag_json, "\"phase_reports\":") >= 0
    and find(diag_json, "\"module_resolution\":") >= 0
    and find(diag_json, "\"symbol_resolution\":") >= 0
    and find(diag_json, "\"sema\":") >= 0
    and find(diag_json, "\"mir_lowering\":") >= 0
    and find(diag_json, "\"mir_verification\":") >= 0
    and find(diag_json, "\"backend\":") >= 0
    and find(diag_json, "\"linker\":") >= 0
    and find(diag_json, "\"runtime_execution\":") >= 0
    and find(diag_json, "\"pipeline_failed_at\":\"typeck\"") >= 0
    and find(diag_json, "\"rule\": \"assignment type compatibility\"") >= 0
    and find(diag_json, "\"subject_symbol\": \"x\"") >= 0
    and find(diag_json, "\"documentation_url\": \"docs://language/type-system/assignment-compatibility\"") >= 0
    and find(diag_json, "\"text_output\":") >= 0
    and find(ast_json, "bootstrap-json-v1") < 0
    and find(ast_json, "ast-json-missing") < 0;
}

