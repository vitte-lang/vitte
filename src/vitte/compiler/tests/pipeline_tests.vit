proc canonical_impl_borrowck_source() -> string {
  give "form Box { value: int }\n"
    + "trait Keep {\n"
    + "  proc keep(self: Self, borrow value: Box) -> int;\n"
    + "}\n"
    + "impl Keep for Box {\n"
    + "  proc keep(self: Self, borrow value: Box) -> int { give 0; }\n"
    + "}\n"
    + "proc main() -> int {\n"
    + "  let recv = Box { value: 1 };\n"
    + "  let x = Box { value: 2 };\n"
    + "  let y = recv.keep(x);\n"
    + "  set x = Box { value: 3 };\n"
    + "  give y;\n"
    + "}\n";
}

proc test_diagnostics_json_uses_canonical_hir_mir_borrowck_path() -> bool {
  let source_text: string = canonical_impl_borrowck_source();
  let artifacts: DriverAnalysisArtifacts = analyze_source("pipeline_borrowck_hir_mir_json.vit", source_text);
  let diag_json: string = dump_diagnostics_json("pipeline_borrowck_hir_mir_json.vit", source_text);
  give artifacts.frontend.valid
    and artifacts.typed_hir.valid
    and artifacts.mir.valid
    and not artifacts.analysis.borrowck_ok
    and find(diag_json, "\"pipeline_failed_at\":\"borrowck\"") >= 0
    and find(diag_json, "\"borrowck_ok\":false") >= 0
    and find(diag_json, "\"borrowck\":") >= 0
    and find(diag_json, "BORROWCK_E_WRITE_WHILE_BORROWED") >= 0
    and find(diag_json, "\"subject_symbol\": \"x\"") >= 0
    and find(diag_json, "\"phase\":\"borrowck\"") >= 0;
}

proc test_diagnostics_quality_score_uses_canonical_hir_mir_borrowck_path() -> bool {
  let source_text: string = canonical_impl_borrowck_source();
