proc test_metrics_and_health_include_canonical_validation_reason() -> bool {
  let ok_source: string = "proc main() -> int { give 0; }\n";
  let ok_result = compile_source_with_config("pipeline_metrics_ok.vit", ok_source, default_compile_config());
  let ok_metrics: CompilerMetricsReport = compile_metrics_report("build", "pipeline_metrics_ok.vit", ok_result);
  let ok_health: HealthDashboard = health_dashboard_from_metrics(ok_metrics);
  let ok_metrics_json: string = metrics_report_json(ok_metrics);
  let ok_health_json: string = health_dashboard_json(ok_health);

  let bad_result: DriverCompileResult = DriverCompileResult {
    status: DriverExitStatus.IrFailure,
    message: "IR verification failed: invalid-method-dispatch-target",
    ir_valid: false,
    backend_name: "llvm",
    target_name: "x86_64-linux",
    profile_name: "enterprise-default",
    opt_level: "O2",
    packaging: "executable",
    deterministic: true,
    debug_enabled: true,
    emit_debug_sections: true,
    lto_enabled: false,
    pgo_mode: "off",
    prefer_native_toolchain: true,
    llvm_toolchain_summary: "",
    codegen_object_format: "",
    codegen_section_count: 0,
    diagnostics: [],
    grammar_version: "",
    token_count: 1,
    toplevel_count: 1,
    stmt_count: 1,
    expr_count: 1,
    type_count: 1,
    pattern_count: 0
  };
  let bad_metrics: CompilerMetricsReport = compile_metrics_report("build", "pipeline_metrics_bad.vit", bad_result);
  let bad_health: HealthDashboard = health_dashboard_from_metrics(bad_metrics);
  let bad_metrics_json: string = metrics_report_json(bad_metrics);
  let bad_health_json: string = health_dashboard_json(bad_health);

  give find(ok_metrics_json, "\"pipeline_failed_at\":\"none\"") >= 0
    and find(ok_metrics_json, "\"pipeline_failure_reason\":\"none\"") >= 0
    and find(ok_metrics_json, "\"validation_reason\":\"none\"") >= 0
    and find(ok_health_json, "\"pipeline_failed_at\":\"none\"") >= 0
    and find(ok_health_json, "\"pipeline_failure_reason\":\"none\"") >= 0
    and find(ok_health_json, "\"validation_reason\":\"none\"") >= 0
    and find(bad_metrics_json, "\"pipeline_failed_at\":\"ir_validate\"") >= 0
    and find(bad_metrics_json, "\"pipeline_failure_reason\":\"invalid-method-dispatch-target\"") >= 0
    and find(bad_metrics_json, "\"validation_reason\":\"invalid-method-dispatch-target\"") >= 0
    and find(bad_health_json, "\"pipeline_failed_at\":\"ir_validate\"") >= 0
    and find(bad_health_json, "\"pipeline_failure_reason\":\"invalid-method-dispatch-target\"") >= 0
    and find(bad_health_json, "\"validation_reason\":\"invalid-method-dispatch-target\"") >= 0;
}

proc test_health_and_quality_scores_distinguish_mir_vs_ir_validation() -> bool {
  let backend0: BackendTiming = BackendTiming { codegen_ms: 1, backend_emit_ms: 1, valid: true };
  let linker0: LinkerTiming = LinkerTiming { link_ms: 1, artifact_ms: 1, valid: true };
  let mir_metrics: CompilerMetricsReport = CompilerMetricsReport {
    command: "build",
    source_path: "pipeline_health_mir.vit",
    status: "error",
    exit_code: exit_code(DriverExitStatus.MirValidationFailure),
    pipeline_failed_at: "mir_validate",
    pipeline_failure_reason: "invalid-param-contract",
    validation_reason: "invalid-param-contract",
    phase_metrics: [],
    cache_hits: 10,
    cache_misses: 2,
    mir_size: 1,
    ast_size: 1,
    diagnostics_count: 0,
    backend: backend0,
    linker: linker0,
    total_time_ms: 10,
    total_memory_kb: 128,
    valid: true
  };
  let ir_metrics: CompilerMetricsReport = CompilerMetricsReport {
    command: "build",
    source_path: "pipeline_health_ir.vit",
    status: "error",
    exit_code: exit_code(DriverExitStatus.IrFailure),
    pipeline_failed_at: "ir_validate",
    pipeline_failure_reason: "invalid-method-dispatch-target",
    validation_reason: "invalid-method-dispatch-target",
    phase_metrics: [],
    cache_hits: 10,
    cache_misses: 2,
    mir_size: 1,
    ast_size: 1,
    diagnostics_count: 0,
    backend: backend0,
    linker: linker0,
    total_time_ms: 10,
    total_memory_kb: 128,
    valid: true
  };
  let mir_health: HealthDashboard = health_dashboard_from_metrics(mir_metrics);
  let ir_health: HealthDashboard = health_dashboard_from_metrics(ir_metrics);
  let ok_quality: u64 = quality_score_with_canonical_context(80, "none", "none");
  let mir_quality: u64 = quality_score_with_canonical_context(80, "mir_validate", "invalid-param-contract");
  let ir_quality: u64 = quality_score_with_canonical_context(80, "ir_validate", "invalid-method-dispatch-target");
  give mir_health.score > ir_health.score
    and mir_health.benchmark_trends == "blocked-mir"
    and ir_health.benchmark_trends == "blocked-ir"
    and contains(mir_health.regression_alerts, "mir_validation_failure")
    and contains(ir_health.regression_alerts, "ir_validation_failure")
    and ok_quality > mir_quality
    and mir_quality > ir_quality;
}

proc test_incremental_invalidation_targets_dependents() -> bool {
  let graph: IncrementalGraph = incremental_analysis_graph("pipeline_incremental.vit");
  let result: InvalidationResult = invalidate_graph_from_key(graph, analysis_node_key("pipeline_incremental.vit", "typed_hir"));
  let saw_ir: bool = false;
  let saw_codegen: bool = false;
  let saw_link: bool = false;
  let i: int = 0;
  while i < len(result.invalidated_keys) {
    if result.invalidated_keys[i] == analysis_node_key("pipeline_incremental.vit", "ir") {
      set saw_ir = true;
    }
    if result.invalidated_keys[i] == analysis_node_key("pipeline_incremental.vit", "codegen") {
      set saw_codegen = true;
    }
    if result.invalidated_keys[i] == analysis_node_key("pipeline_incremental.vit", "link") {
      set saw_link = true;
    }
    set i = i + 1;
  }
  give result.valid and len(result.invalidated_keys) >= 6 and saw_ir and saw_codegen and saw_link;
}

proc test_incremental_local_change_minimal_recompile() -> bool {
  let graph: IncrementalGraph = incremental_analysis_graph("pipeline_incremental.vit");
  let result: InvalidationResult = invalidate_for_local_change(graph, "pipeline_incremental.vit");
  let domains: InvalidationDomains = invalidation_domains(result);
  give result.valid
    and len(result.invalidated_keys) > 0
    and domains.query_invalidated
    and domains.mir_cache_invalidated
    and domains.backend_cache_invalidated
    and domains.diagnostics_invalidated
    and domains.symbol_invalidated;
}

proc test_distributed_build_foundation_contract() -> bool {
  let h0: string = compile_unit_hash("a.vit", "proc main() -> int { give 0; }", "x86_64-linux", "enterprise-default");
  let h1: string = compile_unit_hash("b.vit", "proc util() -> int { give 1; }", "x86_64-linux", "enterprise-default");
  let deps: DependencySnapshot = dependency_snapshot("a.vit", ["b.vit"]);
  let j0: BuildJob = build_job("job-a", "a.vit", h0, ["job-b"]);
  let j1: BuildJob = build_job("job-b", "b.vit", h1, []);
  let graph = export_job_graph([j0, j1]);
  give distributed_build_foundation_ready([j0, j1], deps)
    and graph.valid
    and find(graph.exported, "job-a|a.vit|") >= 0;
}

proc test_formal_type_soundness_roadmap_contract() -> bool {
  let j0: TypingJudgment = typing_judgment("Gamma", "x + 1", "int");
  let own0: OwnershipSemanticsRule = ownership_semantics_rule("move", "moved value is unavailable after move");
  let status: SoundnessCheckpoint = soundness_checkpoint([j0], [own0], "function main block return", ["safe borrow"]);
  give status.valid
    and status.typing_judgments
    and status.ownership_semantics
    and status.progress_preservation_groundwork
    and status.mir_semantic_mapping
    and status.unsafe_escape_analysis
    and formal_type_soundness_roadmap_status() != "";
}

proc test_verified_backend_pipeline_contract() -> bool {
  let result: BackendPipelineResult = compile_to_valid_ir_with_profile_and_packaging(
    "verified_backend.vit",
    "proc main() -> int { give 0; }",
    "llvm",
    "x86_64-linux",
    "enterprise-default",
    true,
    true,
    "executable",
    false,
    default_llvm_toolchain_paths()
  );
  let report: BackendVerificationReport = verify_backend_pipeline(result);
  if report.valid {
    give result.valid and len(report.violations) == 0;
  }
  give not result.valid and len(report.violations) > 0;
}

proc native_backend_test_config() -> DriverCompileConfig {
  let config: DriverCompileConfig = default_compile_config();
  set config.backend_name = "llvm";
  set config.target_name = "x86_64-linux";
  set config.packaging = "executable";
  set config.prefer_native_toolchain = true;
  give config;
}

