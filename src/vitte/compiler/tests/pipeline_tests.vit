    and find(diag_json, "\"lexer\":") >= 0
    and find(diag_json, "\"phase\":\"lexer\"") >= 0
    and find(diag_json, "\"rule\":\"source character set\"") >= 0
    and find(diag_json, "\"documentation_url\":\"docs://language/lexer/source-characters\"") >= 0
