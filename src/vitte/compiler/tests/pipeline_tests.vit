}

proc test_cli_json_dump_routes() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let ast_report: CliReportResult = run_parse_ast_json_cli("pipeline_cli_ast.vit", source_text);
  let hir_report: CliReportResult = run_check_hir_json_cli("pipeline_cli_hir.vit", source_text);
  let mir_report: CliReportResult = run_check_mir_json_cli("pipeline_cli_mir.vit", source_text);
  let diag_report: CliReportResult = run_check_diagnostics_json_cli("pipeline_cli_diag.vit", source_text);
  give ast_report.code == 0
    and hir_report.code == 0
    and mir_report.code == 0
    and diag_report.code == 0
    and find(ast_report.report_json, "\"surface\":\"ast\"") >= 0
    and find(ast_report.report_json, "\"source\":{\"path\":\"pipeline_cli_ast.vit\",\"bytes\":") >= 0
    and find(ast_report.report_json, "\"ast\":{\"kind\":\"native-structural\"") >= 0
    and find(hir_report.report_json, "\"surface\":\"hir\"") >= 0
    and find(hir_report.report_json, "\"hir\":{\"kind\":\"native-typed\"") >= 0
    and find(mir_report.report_json, "\"surface\":\"mir\"") >= 0
    and find(mir_report.report_json, "\"mir\":{\"kind\":\"native-lowered\"") >= 0
    and find(diag_report.report_json, "\"surface\":\"diagnostics\"") >= 0
    and find(diag_report.report_json, "\"summary\":{\"frontend_diagnostic_count\":0") >= 0;
}

proc test_runtime_surface_dispatch_prefers_pipeline_json() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let ast_report: CliReportResult = main_driver_surface_report_json("parse", "--dump-ast-json", "pipeline_dispatch_ast.vit", source_text);
  let hir_report: CliReportResult = main_driver_surface_report_json("check", "--dump-hir-json", "pipeline_dispatch_hir.vit", source_text);
  let mir_report: CliReportResult = main_driver_surface_report_json("check", "--dump-mir-json", "pipeline_dispatch_mir.vit", source_text);
  let diag_report: CliReportResult = main_driver_surface_report_json("check", "--diagnostics-json", "pipeline_dispatch_diag.vit", source_text);
  let unsupported_report: CliReportResult = main_driver_surface_report_json("check", "--unknown-flag", "pipeline_dispatch_fallback.vit", source_text);
  give find(ast_report.report_json, "\"schema\":\"vitte.compiler.surface\"") >= 0
    and find(ast_report.report_json, "\"schema_version\":\"1.0.0\"") >= 0
    and find(ast_report.report_json, "\"producer\":\"vitte-driver-native\"") >= 0
    and find(ast_report.report_json, "\"summary\":{\"token_count\":") >= 0
    and find(hir_report.report_json, "\"surface\":\"hir\"") >= 0
    and find(hir_report.report_json, "\"schema\":\"vitte.compiler.surface\"") >= 0
    and find(hir_report.report_json, "\"hir\":{\"kind\":\"native-typed\"") >= 0
    and find(mir_report.report_json, "\"surface\":\"mir\"") >= 0
    and find(mir_report.report_json, "\"schema\":\"vitte.compiler.surface\"") >= 0
    and find(mir_report.report_json, "\"mir\":{\"kind\":\"native-lowered\"") >= 0
    and find(diag_report.report_json, "\"surface\":\"diagnostics\"") >= 0
    and find(diag_report.report_json, "\"schema\":\"vitte.compiler.surface\"") >= 0
    and find(diag_report.report_json, "\"source\":{\"path\":\"pipeline_dispatch_diag.vit\",\"bytes\":") >= 0
    and unsupported_report.code == 1
    and find(unsupported_report.report_json, "\"code\":\"E_DRIVER_SURFACE_UNAVAILABLE\"") >= 0;
}

proc test_runtime_surface_dispatch_from_args() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let ast_args_report: CliReportResult = main_driver_surface_report_json_from_args("parse", ["parse", "--dump-ast-json", "--deterministic"], "pipeline_args_ast.vit", source_text);
  let hir_args_report: CliReportResult = main_driver_surface_report_json_from_args("check", ["check", "--dump-hir-json"], "pipeline_args_hir.vit", source_text);
  let fallback_args_report: CliReportResult = main_driver_surface_report_json_from_args("check", ["check", "--strict"], "pipeline_args_fallback.vit", source_text);
  give find(ast_args_report.report_json, "\"surface\":\"ast\"") >= 0
    and find(ast_args_report.report_json, "\"command\":\"parse\"") >= 0
    and find(hir_args_report.report_json, "\"surface\":\"hir\"") >= 0
    and find(hir_args_report.report_json, "\"command\":\"check\"") >= 0
    and find(hir_args_report.report_json, "\"first_item_name\":\"main\"") >= 0
    and fallback_args_report.code == 1
    and find(fallback_args_report.report_json, "\"code\":\"E_DRIVER_SURFACE_UNAVAILABLE\"") >= 0;
}

proc test_driver_report_includes_registry_sections() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let report_json: string = main_driver_report_json("check", "pipeline_registry_report.vit", source_text);
  give find(report_json, "driver:integration_registry=active") >= 0
    and find(report_json, "frontend:parse=active") >= 0
    and find(report_json, "analysis:typeck=active") >= 0
    and find(report_json, "middle:hir=active") >= 0
    and find(report_json, "backend:codegen=active") >= 0
    and find(report_json, "infra:session=active") >= 0
    and find(report_json, "infra:diagnostic_session=active") >= 0;
}

proc test_driver_report_includes_stage_logs() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let report_json: string = main_driver_report_json("check", "pipeline_stage_logs_report.vit", source_text);
  give find(report_json, "\"stage_logs\":") >= 0
    and find(report_json, "enter:1.load_source") >= 0
    and find(report_json, "enter:2.lex+3.parse+4.validate_ast") >= 0
    and find(report_json, "enter:10.lower_mir+11.verify_mir+12.optimize") >= 0;
}

proc test_runtime_surface_dispatch_rejects_unsupported_combo() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let bad_parse: CliReportResult = main_driver_surface_report_json_from_args("parse", ["parse", "--dump-hir-json"], "pipeline_bad_parse_hir.vit", source_text);
  let bad_check: CliReportResult = main_driver_surface_report_json_from_args("check", ["check", "--dump-ast-json"], "pipeline_bad_check_ast.vit", source_text);
  give bad_parse.code == 1
    and bad_check.code == 1
    and find(bad_parse.report_json, "\"code\":\"E_DRIVER_SURFACE_UNAVAILABLE\"") >= 0
    and find(bad_check.report_json, "\"code\":\"E_DRIVER_SURFACE_UNAVAILABLE\"") >= 0;
}

proc test_pipeline_fixture_hello_world_builds() -> bool {
  let result = compile_source_with_config("tests/pipeline/hello_world.vit", "proc main() -> int { give 0; }", default_compile_config());
  give result.status == DriverExitStatus.Ok;
}

proc test_pipeline_fixture_syntax_error_fails_before_sema() -> bool {
  let options: CompilerOptions = default_options();
  set options.mode = CompilerMode::Build;
  let compiler = compiler_from_source("tests/pipeline/syntax_error.vit", "proc main( -> int { give 0; }", options);
  let result: CompilerResult = run_compiler(compiler);
  give result.status == DriverExitStatus.ParseFailure and result.stage == CompilerStage::Parse;
}

proc test_pipeline_fixture_type_error_fails_during_typeck() -> bool {
  let options: CompilerOptions = default_options();
  set options.mode = CompilerMode::Check;
  let compiler = compiler_from_source("tests/pipeline/type_error.vit", "proc main() -> int { give true; }", options);
  let result: CompilerResult = run_compiler(compiler);
  give result.status == DriverExitStatus.TypeFailure and result.stage == CompilerStage::Typeck;
}

proc test_pipeline_fixture_borrow_error_fails_during_borrowck() -> bool {
  let options: CompilerOptions = default_options();
  set options.mode = CompilerMode::Check;
  let compiler = compiler_from_source("tests/pipeline/borrow_error.vit", "proc main() { let x = make_box(); let y = x; give x; }", options);
  let result: CompilerResult = run_compiler(compiler);
  give result.status == DriverExitStatus.BorrowckFailure and result.stage == CompilerStage::Borrowck;
}

proc test_pipeline_fixture_backend_failure_fails_build() -> bool {
  let options: CompilerOptions = default_options();
  set options.mode = CompilerMode::Build;
  let compiler = compiler_from_source("tests/pipeline/backend_failure.vit", "proc helper() -> int { give 0; }", options);
  let result: CompilerResult = run_compiler(compiler);
  give result.status != DriverExitStatus.Ok;
}

proc test_unix_exit_code_contract() -> bool {
  give exit_code(DriverExitStatus.Ok) == 0
    and exit_code(DriverExitStatus.ParseFailure) == 1
    and exit_code(DriverExitStatus.AnalysisFailure) == 1
    and exit_code(DriverExitStatus.InternalError) == 2
    and exit_code(DriverExitStatus.CodegenFailure) == 3
    and exit_code(DriverExitStatus.ObjectEmissionFailure) == 3
    and exit_code(DriverExitStatus.LinkFailure) == 4;
}

proc test_internal_compiler_error_renderer_contract() -> bool {
  let err: ice.InternalCompilerError = ice.internal_compiler_error(
    "typeck",
    "stack:run_compiler>run_analysis",
    "tests/pipeline/type_error.vit:1:1",
    "vittec2 stage2-vitte 0.1.0"
  );
  let text: string = ice.render_internal_compiler_error_text(err);
  let json: string = ice.render_internal_compiler_error_json(err);
  give err.valid
    and find(text, "error: internal compiler error") >= 0
    and find(text, "phase: typeck") >= 0
    and find(text, "stack trace: stack:run_compiler>run_analysis") >= 0
    and find(text, "source location: tests/pipeline/type_error.vit:1:1") >= 0
    and find(text, "compiler version: vittec2 stage2-vitte 0.1.0") >= 0
    and find(json, "\"error\":\"internal compiler error\"") >= 0
    and find(json, "\"phase\":\"typeck\"") >= 0
    and find(json, "\"stack_trace\":\"stack:run_compiler>run_analysis\"") >= 0;
}

proc test_native_panic_boundary_contract_surface() -> bool {
  let b0: panic_boundary.PanicBoundaryState = panic_boundary.native_panic_boundary_begin();
  let b1: panic_boundary.PanicBoundaryState = panic_boundary.native_panic_boundary_mark_triggered(b0, 2);
  let b2: panic_boundary.PanicBoundaryState = panic_boundary.native_panic_boundary_end(b1);
  give b0.active
    and b0.valid
    and b2.triggered
    and b2.panic_code == 2
    and not panic_boundary.native_panic_boundary_ok(b2);
}

proc test_runtime_c_native_contract_is_wired() -> bool {
  let runtime0: backend_infrastructure.RuntimeLibrary = backend_infrastructure.create_vitte_runtime();
  let saw_begin: bool = false;
  let saw_end: bool = false;
  let saw_triggered: bool = false;
  let saw_code: bool = false;
  let saw_reset: bool = false;
  let saw_read_file: bool = false;
  let saw_write_file: bool = false;
  let saw_system: bool = false;
  let saw_emit_object: bool = false;
  let saw_link_executable: bool = false;
  let saw_run_executable: bool = false;
  let j: int = 0;
  while j < len(runtime0.functions) {
    let link_name: string = runtime0.functions[j].link_name;
    if link_name == "vitte_runtime_panic_boundary_begin" {
      set saw_begin = true;
    }
    if link_name == "vitte_runtime_panic_boundary_end" {
      set saw_end = true;
    }
    if link_name == "vitte_runtime_panic_boundary_triggered" {
      set saw_triggered = true;
    }
    if link_name == "vitte_runtime_panic_boundary_code" {
      set saw_code = true;
    }
    if link_name == "vitte_runtime_panic_boundary_reset" {
      set saw_reset = true;
    }
    if link_name == "vitte_host_read_file" {
      set saw_read_file = true;
    }
    if link_name == "vitte_host_write_file" {
      set saw_write_file = true;
    }
    if link_name == "vitte_host_system" {
      set saw_system = true;
    }
    if link_name == "vitte_host_emit_llvm_object" {
      set saw_emit_object = true;
    }
    if link_name == "vitte_host_link_executable" {
      set saw_link_executable = true;
    }
    if link_name == "vitte_host_run_executable" {
      set saw_run_executable = true;
    }
    set j = j + 1;
  }
  give runtime0.name == "vitte_runtime"
    and runtime0.c_header_path == "src/vitte/compiler/backends/runtime_c/vitte_runtime.h"
    and runtime0.c_source_path == "src/vitte/compiler/backends/runtime_c/vitte_runtime.c"
    and saw_begin and saw_end and saw_triggered and saw_code and saw_reset
    and saw_read_file and saw_write_file and saw_system
    and saw_emit_object and saw_link_executable and saw_run_executable;
}

proc test_linker_auto_wires_runtime_c_payload() -> bool {
  let result: BackendPipelineResult = compile_to_valid_ir_with_profile_and_packaging(
    "tests/pipeline/hello_world.vit",
    "proc main() -> int { give 0; }",
    "x86_64",
    "x86_64-linux",
    "enterprise-default",
    true,
    true,
    "executable",
    false,
    default_llvm_toolchain_paths()
  );
  let runtime_output_ok: bool = len(result.artifact.outputs) >= 2
    and find(result.artifact.outputs[1].path, ".runtime.o") >= 0
    and result.artifact.outputs[1].ready;
  let runtime_section_ok: bool = len(result.artifact.sections) >= 6
    and result.artifact.sections[5].name == ".vitte.runtime"
    and find(result.artifact.sections[5].content, "runtime_c_source=src/vitte/compiler/backends/runtime_c/vitte_runtime.c") >= 0
    and find(result.artifact.sections[5].content, "runtime_symbol=vitte_runtime_panic_boundary_begin") >= 0;
  give result.valid and runtime_output_ok and runtime_section_ok;
}

proc test_structured_driver_failure_message_contract() -> bool {
  let text: string = structured_driver_failure_message(
    "native linker invocation failed",
    "x86_64-linux",
    "llvm",
    "host_link_executable(build/main.o, build/main)",
    "stderr unavailable from native host runtime bridge",
    "build/main"
  );
  give find(text, "native linker invocation failed") >= 0
    and find(text, "target: x86_64-linux") >= 0
    and find(text, "backend: llvm") >= 0
    and find(text, "command: host_link_executable") >= 0
    and find(text, "stderr: stderr unavailable from native host runtime bridge") >= 0
    and find(text, "expected_artifact: build/main") >= 0;
}

proc test_compiler_logger_levels_contract() -> bool {
  let log0: logger.CompilerLogger = logger.compiler_logger(true, true);
  let log1: logger.CompilerLogger = logger.trace(log0, "trace event");
  let log2: logger.CompilerLogger = logger.debug(log1, "debug event");
  let log3: logger.CompilerLogger = logger.info(log2, "info event");
  let log4: logger.CompilerLogger = logger.warn(log3, "warn event");
  let log5: logger.CompilerLogger = logger.error(log4, "error event");
  give len(log5.entries) == 5
    and logger.level_text(log5.entries[0].level) == "trace"
    and logger.level_text(log5.entries[4].level) == "error";
}

proc test_target_config_profiles_contract() -> bool {
  let x64: config.TargetConfig = config.target_config_from_name("x86_64-linux-gnu");
  let arm64: config.TargetConfig = config.target_config_from_name("aarch64-linux-gnu");
  let i386: config.TargetConfig = config.target_config_from_name("i386-linux-gnu");
  let riscv64: config.TargetConfig = config.target_config_from_name("riscv64-linux-gnu");
  let m68k: config.TargetConfig = config.target_config_from_name("m68k-retro");
  let z80: config.TargetConfig = config.target_config_from_name("z80-retro");
  let x64_musl: config.TargetConfig = config.target_config_from_name("x86_64-linux-musl");
  let x64_win: config.TargetConfig = config.target_config_from_name("x86_64-pc-windows-msvc");
  let arm64_android: config.TargetConfig = config.target_config_from_name("aarch64-linux-android");
  let i686_musl: config.TargetConfig = config.target_config_from_name("i686-unknown-linux-musl");
  let riscv_gc: config.TargetConfig = config.target_config_from_name("riscv64gc-unknown-linux-gnu");
  let ppc64: config.TargetConfig = config.target_config_from_name("powerpc64le-unknown-linux-gnu");
  give x64.valid
    and arm64.valid
    and i386.valid
    and riscv64.valid
    and m68k.valid
    and z80.valid
    and x64_musl.valid
    and x64_win.valid
    and arm64_android.valid
    and i686_musl.valid
    and riscv_gc.valid
    and ppc64.valid
    and x64.pointer_size == 64
    and arm64.pointer_size == 64
    and i386.pointer_size == 32
    and riscv64.pointer_size == 64
    and x64.object_format == "elf"
    and arm64.object_format == "elf"
    and riscv64.object_format == "elf"
    and x64.abi == "sysv"
    and arm64.abi == "aapcs64"
    and m68k.target_triple == "i386-linux"
    and z80.target_triple == "i386-linux"
    and x64_musl.target_triple == "x86_64-linux"
    and x64_win.target_triple == "x86_64-linux"
    and arm64_android.target_triple == "aarch64-linux"
    and i686_musl.target_triple == "i386-linux"
    and riscv_gc.target_triple == "riscv64-linux"
    and ppc64.target_triple == "i386-linux";
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_compile_source_success() {
    set failures = failures + 1;
  }
  if not test_compiler_main_dispatches_inline_check() {
    set failures = failures + 1;
  }
  if not test_compiler_main_builds_native_output() {
    set failures = failures + 1;
  }
  if not test_compiler_main_runs_native_output() {
    set failures = failures + 1;
  }
  if not test_compiler_main_accepts_verbose_flag() {
    set failures = failures + 1;
  }
  if not test_compiler_main_loads_file_through_host_runtime() {
    set failures = failures + 1;
  }
  if not test_check_source_accepts_intrinsic_surface() {
    set failures = failures + 1;
  }
  if not test_compiler_check_stops_after_borrowck() {
    set failures = failures + 1;
  }
  if not test_critical_skipped_or_unimplemented_phase_fails() {
    set failures = failures + 1;
  }
  if not test_check_source_uses_validated_middle_path() {
    set failures = failures + 1;
  }
  if not test_lint_warning_is_nonfatal() {
    set failures = failures + 1;
  }
  if not test_check_source_uses_copy_aware_borrowck() {
    set failures = failures + 1;
  }
  if not test_check_source_releases_branch_borrow_at_scope_end() {
    set failures = failures + 1;
  }
  if not test_check_source_allows_partial_move_of_disjoint_field() {
    set failures = failures + 1;
  }
  if not test_check_source_resolved_reference_flow() {
    set failures = failures + 1;
  }
  if not test_analyze_source_exposes_resolved_and_typed_hir() {
    set failures = failures + 1;
  }
  if not test_native_spans_are_emitted_for_frontend_and_analysis_diagnostics() {
    set failures = failures + 1;
  }
  if not test_dump_hir_and_lower_mir_helpers() {
    set failures = failures + 1;
  }
  if not test_stop_after_parse_exact() {
    set failures = failures + 1;
  }
  if not test_stop_after_hir_exact() {
    set failures = failures + 1;
  }
  if not test_stop_after_typeck_exact() {
    set failures = failures + 1;
  }
  if not test_stop_after_mir_exact() {
