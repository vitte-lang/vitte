proc run_stop_after(stage: CompilerStage, mode: CompilerMode) -> CompilerResult {
  let options: CompilerOptions = default_options();
  set options.mode = mode;
  set options.stop_after = stage;
  let compiler = compiler_from_source(
    "pipeline_stop_after.vit",
    "proc main() -> int { give 0; }",
    options
  );
  give run_compiler(compiler);
}

proc test_compiler_check_stops_after_borrowck() -> bool {
  let options: CompilerOptions = default_options();
  set options.mode = CompilerMode::Check;
  let compiler = compiler_from_source(
    "pipeline_check_only.vit",
    "proc main() -> int { give 0; }",
    options
  );
  let result: CompilerResult = run_compiler(compiler);
  let saw_borrowck: bool = false;
  let saw_mir: bool = false;
  let saw_backend: bool = false;
  let i: u64 = 0;
  while i < len(result.phase_results) {
    if result.phase_results[i] == "borrowck=Success" {
      set saw_borrowck = true;
    }
    if result.phase_results[i] == "MIR lowering=Success" {
      set saw_mir = true;
    }
    if result.phase_results[i] == "backend=Success" {
      set saw_backend = true;
    }
    set i = i + 1;
  }
  give result.status == DriverExitStatus.Ok and saw_borrowck and not saw_mir and not saw_backend;
}

proc test_critical_skipped_or_unimplemented_phase_fails() -> bool {
  let compiler0 = new_compiler(default_options());
  let skipped = record_phase_result(compiler0, "borrowck", PhaseResult::Skipped, true);
  let unimplemented = record_phase_result(compiler0, "backend", PhaseResult::Unimplemented, true);
  give not skipped.state.ok and not unimplemented.state.ok;
}

proc assert_stop_after(stage: CompilerStage, mode: CompilerMode) -> bool {
  let result: CompilerResult = run_stop_after(stage, mode);
  give result.status == DriverExitStatus.Ok and result.stage == stage;
}

proc test_stop_after_parse_exact() -> bool {
  give assert_stop_after(CompilerStage::Parse, CompilerMode::Build);
}

proc test_stop_after_hir_exact() -> bool {
  give assert_stop_after(CompilerStage::Hir, CompilerMode::Build);
}

proc test_stop_after_typeck_exact() -> bool {
  give assert_stop_after(CompilerStage::Typeck, CompilerMode::Build);
}

proc test_stop_after_mir_exact() -> bool {
  give assert_stop_after(CompilerStage::Mir, CompilerMode::Build);
}

proc test_stop_after_ir_exact() -> bool {
  give assert_stop_after(CompilerStage::Ir, CompilerMode::Build);
}

proc test_stop_after_codegen_exact() -> bool {
  give assert_stop_after(CompilerStage::Codegen, CompilerMode::Build);
}

proc test_stop_after_link_exact() -> bool {
  give assert_stop_after(CompilerStage::Link, CompilerMode::Build);
}

proc test_stop_after_run_exact() -> bool {
  give assert_stop_after(CompilerStage::Run, CompilerMode::Run);
}

proc test_session_source_manager_does_not_duplicate_input_snapshot() -> bool {
  let options: CompilerOptions = default_options();
  let source_text: string = "proc main() -> int { give 0; }\n";
  let path: string = "pipeline_session_snapshot.vit";
  let compiler0 = compiler_from_source(path, source_text, options);

  let compiler1 = configure_compiler(compiler0);
  if not compiler1.state.ok {
    give false;
  }

  let compiler2 = validate_input(compiler1);
  if not compiler2.state.ok {
    give false;
  }

  let compiler3 = validate_compiler_links(compiler2);
  if not compiler3.state.ok {
    give false;
  }

  let compiler4 = run_frontend(compiler3);
  if not compiler4.state.ok {
    give false;
  }

  let compiler5 = run_analysis(compiler4);
  if not compiler5.state.ok {
    give false;
  }

  let compiler6 = run_mir_pipeline(compiler5);
  if not compiler6.state.ok {
    give false;
  }

  let compiler7 = run_ir_pipeline(compiler6);
  give compiler7.state.ok
    and len(compiler7.session.source_manager.files) == 1
    and compiler7.session.source_manager.files[0].path == path
    and compiler7.session.source_manager.files[0].text == source_text;
}

