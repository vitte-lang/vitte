  if not test_internal_compiler_error_renderer_contract() {
    set failures = failures + 1;
  }
  if not test_native_panic_boundary_contract_surface() {
    set failures = failures + 1;
  }
  if not test_runtime_c_native_contract_is_wired() {
    set failures = failures + 1;
  }
  if not test_linker_auto_wires_runtime_c_payload() {
    set failures = failures + 1;
  }
  if not test_structured_driver_failure_message_contract() {
    set failures = failures + 1;
  }
  if not test_compiler_logger_levels_contract() {
    set failures = failures + 1;
  }
  if not test_target_config_profiles_contract() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
