  if not test_session_source_manager_does_not_duplicate_input_snapshot() {
    set failures = failures + 1;
  }
  if not test_incremental_invalidation_targets_dependents() {
    set failures = failures + 1;
  }
  if not test_incremental_local_change_minimal_recompile() {
    set failures = failures + 1;
  }
  if not test_distributed_build_foundation_contract() {
    set failures = failures + 1;
  }
  if not test_formal_type_soundness_roadmap_contract() {
    set failures = failures + 1;
  }
  if not test_verified_backend_pipeline_contract() {
    set failures = failures + 1;
  }
  if not test_driver_native_object_materialization_contract() {
    set failures = failures + 1;
