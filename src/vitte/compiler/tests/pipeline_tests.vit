  let diag_json: string = dump_diagnostics_json("pipeline_borrowck_quality.vit", source_text);
  give score > 0
    and find(diag_json, "\"pipeline_failed_at\":\"borrowck\"") >= 0
    and find(diag_json, "BORROWCK_E_WRITE_WHILE_BORROWED") >= 0;
}

