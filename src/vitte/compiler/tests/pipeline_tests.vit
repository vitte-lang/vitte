  let source_text: string = "intrinsic vitte_host_runtime_available() -> bool;\nproc main() -> int { give 0; }\n";
  let result = check_source("pipeline_intrinsic_surface.vit", source_text);
  let ast_json: string = dump_ast_json("pipeline_intrinsic_surface.vit", source_text);
  give result.status == DriverExitStatus.Ok
    and find(ast_json, "vitte_host_runtime_available") >= 0
    and find(ast_json, "\"surface\":\"ast\"") >= 0;
}

