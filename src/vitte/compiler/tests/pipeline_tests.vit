  let source_text: string = "proc main() { let x = make_box(); if true { let r = &x; let keep = 0; } set x = make_box(); give x; }\n";
  let result = check_source("pipeline_scope_aware_borrowck.vit", source_text);
  give result.status == DriverExitStatus.Ok;
}

