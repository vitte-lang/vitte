proc test_diagnostic_cli_commands() -> bool {
  let source_text: string = "proc main() -> int { give 0; }\n";
  let explain_ok: bool = run_cli_main(["explain", "TYPECK_E_ASSIGN_MISMATCH"]) == 0;
  let quality_ok: bool = run_cli_main(["check", "--diagnostic-quality", "--fail-under", "1", "--source", source_text]) == 0;
  let fix_dry_run_ok: bool = run_cli_main(["fix", "--dry-run", "--source", source_text]) == 0;
  let fix_apply_blocked: bool = run_cli_main(["fix", "--apply", "--source", source_text]) == exit_code(DriverExitStatus.UnsupportedFeature);
  let reduce_blocked: bool = run_cli_main(["reduce", "--source", source_text]) == exit_code(DriverExitStatus.UnsupportedFeature);
  give explain_ok and quality_ok and fix_dry_run_ok and fix_apply_blocked and reduce_blocked;
}

