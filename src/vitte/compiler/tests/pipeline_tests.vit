proc test_analyze_source_exposes_resolved_and_typed_hir() -> bool {
  let source_text: string = "proc main() { let x = 1; let y = x; give y; }\n";
  let result: DriverAnalysisArtifacts = analyze_source("pipeline_analyze_hir.vit", source_text);
  let resolved_expr = result.resolved_hir.module.items[0].stmts[1].expr;
  let typed_expr = result.typed_hir.module.items[0].stmts[1].expr;
  give result.valid and resolved_expr.resolved_id > 0 and resolved_expr.binding == "x" and typed_expr.inferred_type == "int" and typed_expr.copyable;
}

proc test_native_spans_are_emitted_for_frontend_and_analysis_diagnostics() -> bool {
  let source_text: string = "proc main() { let x = ; }\n";
  let result: DriverAnalysisArtifacts = analyze_source("pipeline_native_spans.vit", source_text);
  let has_frontend: bool = len(result.frontend.diagnostics) > 0;
  let has_analysis: bool = len(result.analysis.diagnostics) > 0;
  let frontend_ok: bool = has_frontend
    and result.frontend.diagnostics[0].file_id > 0
    and result.frontend.diagnostics[0].span_end >= result.frontend.diagnostics[0].span_start;
  let analysis_ok: bool = has_analysis
    and result.analysis.diagnostics[0].file_id > 0
    and result.analysis.diagnostics[0].span_end >= result.analysis.diagnostics[0].span_start;
  give frontend_ok and analysis_ok;
}

proc test_dump_hir_and_lower_mir_helpers() -> bool {
  let source_text: string = "proc main() { let x = make_box(); set x.field = 1; give x; }\n";
  let resolved = dump_hir_resolved("pipeline_dump_resolved.vit", source_text);
  let typed = dump_hir_typed("pipeline_dump_typed.vit", source_text);
  let mir = lower_mir_source("pipeline_dump_mir.vit", source_text);
  give resolved.module.items[0].stmts[1].target_binding == "x.field" and typed.module.items[0].stmts[0].expr.inferred_type != "unknown" and mir.valid and mir.module.functions[0].blocks[0].statements[0].place.projection != "";
}

