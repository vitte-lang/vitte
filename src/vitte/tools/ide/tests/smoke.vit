space vitte/tools/ide/tests

use vitte/tools/ide

proc smoke() -> string {
  give ide.ide_integration_summary();
}

proc semantic_smoke() -> string {
  let dep: string = "space demo/math;\nexport *;\nproc sum() -> int { give 0; }\n";
  let root: string = "space demo/app;\nuse demo/math { * };\nproc main() -> int { give sum(); }\n";
  give ide.ide_semantic_summary("demo_app.vit", root, "demo_math.vit", dep);
}
