space vitte/tools/lsp/mod

export *

use vitte/compiler/driver/compile.{
  DriverDiagnosticSurface,
  DriverCanonicalContext,
  driver_diagnostic_surface_from_source,
  driver_canonical_context_from_source
}
use vitte/compiler/diagnostics/diagnostic.{
  Diagnostic as CanonicalDiagnostic,
  DiagnosticReport as CanonicalDiagnosticReport,
  phase_name as canonical_phase_name
}
use vitte/compiler/diagnostics/lsp as compiler_lsp

