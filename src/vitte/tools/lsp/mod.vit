proc phase_status(
  phase: string,
  diagnostic_count: int,
  quality_score: int,
  has_fatal: bool,
  selected_as_primary: bool
) -> DiagnosticPhaseStatus {

  give DiagnosticPhaseStatus {
    phase: phase,
    diagnostic_count: diagnostic_count,
    quality_score: quality_score,
    has_fatal: has_fatal,
    selected_as_primary: selected_as_primary,
    valid: phase != ""
  };
}

proc phase_status_from_report(
  phase: string,
  report: CanonicalDiagnosticReport,
  primary_phase: string
) -> DiagnosticPhaseStatus {

  give phase_status(
    phase,
    len(report.diagnostics) as int,
    report.quality_score as int,
    report.fatal_count > 0,
    phase == primary_phase
  );
}

<<< ========================================================= >>>
<<< Symbol helpers                                            >>>
<<< ========================================================= >>>

proc classify_symbol(
  symbol: string
) -> SymbolKind {

  if symbol == "proc" {
    give SymbolKind.Keyword;
  }

  if symbol == "form" {
    give SymbolKind.Keyword;
  }

  if symbol == "pick" {
    give SymbolKind.Keyword;
  }

  if starts_with(symbol, "ast_") {
    give SymbolKind.Function;
  }

  if starts_with(symbol, "hir_") {
    give SymbolKind.Function;
  }

  if starts_with(symbol, "mir_") {
    give SymbolKind.Function;
  }

  if starts_with(symbol, "Ir") {
    give SymbolKind.Type;
  }

  if starts_with(symbol, "Ast") {
    give SymbolKind.Type;
  }

  if starts_with(symbol, "Hir") {
    give SymbolKind.Type;
  }

  if starts_with(symbol, "Mir") {
    give SymbolKind.Type;
  }

  give SymbolKind.Unknown;
}

proc symbol_kind_name(
  kind: SymbolKind
) -> string {

  if kind == SymbolKind.Proc {
    give "proc";
  }

  if kind == SymbolKind.Variable {
    give "variable";
  }

  if kind == SymbolKind.Const {
    give "const";
  }

  if kind == SymbolKind.Type {
    give "type";
  }

  if kind == SymbolKind.Keyword {
    give "keyword";
  }

  if kind == SymbolKind.Module {
    give "module";
  }

  give "unknown";
}

<<< ========================================================= >>>
<<< Hover                                                     >>>
<<< ========================================================= >>>

proc hover_provider(
  symbol: string
) -> HoverInfo {

  let kind: SymbolKind =
    classify_symbol(symbol);

  let content: string =
    "symbol: "
    + symbol
    + "\nkind: "
    + symbol_kind_name(kind);

  give HoverInfo {
    content: content,

    symbol: symbol,

    kind: kind,

    range:
      range(
        0,
        len(symbol)
      ),

    markdown: true,

    valid:
      symbol != ""
  };
}

proc diagnostic_hover_range(
  diagnostic: CanonicalDiagnostic
) -> Range {

  if diagnostic.span.valid {
    let start0: int = diagnostic.span.start_column as int;
    let end0: int = diagnostic.span.end_column as int;
    if start0 >= 0 and end0 >= start0 {
      give range(start0, end0);
    }
  }

  give range(
    0,
    len(diagnostic.code)
  );
}

proc diagnostic_hover_content(
  diagnostic: CanonicalDiagnostic,
  context: DriverCanonicalContext
) -> string {

  let content: string =
    "code: "
    + diagnostic.code
    + "\nphase: "
    + canonical_phase_name(diagnostic.phase)
    + "\nmessage: "
    + diagnostic.message;

  if diagnostic.explanation != "" {
    set content =
      content
      + "\nsummary: "
      + diagnostic.explanation;
  }

  if diagnostic.root_cause != "" {
    set content =
      content
      + "\ncause: "
      + diagnostic.root_cause;
  }

  if diagnostic.probable_fix != "" {
    set content =
      content
      + "\nfix: "
      + diagnostic.probable_fix;
  }

  if diagnostic.documentation_url != "" {
    set content =
      content
      + "\ndocs: "
      + diagnostic.documentation_url;
  }

  if context.pipeline_failed_at != "none" {
    set content =
      content
      + "\npipeline_failed_at: "
      + context.pipeline_failed_at;
  }

  if context.validation_reason != "none" {
    set content =
      content
      + "\nvalidation_reason: "
      + context.validation_reason;
  }

  if diagnostic.subject_symbol != "" {
    set content =
      content
      + "\nsubject: "
      + diagnostic.subject_symbol;
  }

  if len(diagnostic.cause_chain) > 0 {
    set content =
      content
      + "\ntrace: "
      + diagnostic.cause_chain[0];
  }

  give content;
}

proc diagnostic_hover_from_surface(
  surface: DriverDiagnosticSurface
) -> HoverInfo {

  if len(surface.primary_report.diagnostics) == 0 {
    give HoverInfo {
      content: "",
      symbol: "",
      kind: SymbolKind.Unknown,
      range: empty_range(),
      markdown: true,
      valid: false
    };
  }

  let diagnostic: CanonicalDiagnostic =
    surface.primary_report.diagnostics[0];

  give HoverInfo {
    content: diagnostic_hover_content(
      diagnostic,
      surface.canonical_context
    ),
    symbol: diagnostic.code,
    kind: SymbolKind.Keyword,
    range: diagnostic_hover_range(diagnostic),
    markdown: true,
    valid: diagnostic.valid
  };
}

proc diagnostic_details_invalid() -> DiagnosticDetails {

  give DiagnosticDetails {
    code: "",
    phase: "",
    message: "",
    explanation: "",
    root_cause: "",
    probable_fix: "",
    documentation_url: "",
    subject_symbol: "",
    pipeline_failed_at: "none",
    pipeline_failure_reason: "none",
    validation_reason: "none",
    cause_chain: [],
    pipeline_context: [],
    range: empty_range(),
    index: -1,

    valid: false
  };
}

proc report_for_phase(
  surface: DriverDiagnosticSurface,
  phase: string
) -> CanonicalDiagnosticReport {

  if phase == "lexer" {
    give surface.phase_reports.lexer;
  }
  if phase == "parser" {
    give surface.phase_reports.parser;
  }
  if phase == "ast_validation" {
    give surface.phase_reports.ast_validation;
  }
  if phase == "module_resolution" {
    give surface.phase_reports.module_resolution;
  }
  if phase == "symbol_resolution" {
    give surface.phase_reports.symbol_resolution;
  }
  if phase == "sema" {
    give surface.phase_reports.sema;
  }
  if phase == "typeck" {
    give surface.phase_reports.typeck;
  }
  if phase == "borrowck" {
    give surface.phase_reports.borrowck;
  }
  if phase == "mir_lowering" {
    give surface.phase_reports.mir_lowering;
  }
  if phase == "mir_verification" {
    give surface.phase_reports.mir_verification;
  }
  if phase == "backend" {
    give surface.phase_reports.backend;
  }
  if phase == "linker" {
    give surface.phase_reports.linker;
  }
  if phase == "runtime_execution" {
    give surface.phase_reports.runtime_execution;
  }
  give surface.primary_report;
}

proc surface_with_phase_report(
  surface: DriverDiagnosticSurface,
  phase: string
) -> DriverDiagnosticSurface {

  let selected: CanonicalDiagnosticReport = report_for_phase(surface, phase);
  give DriverDiagnosticSurface {
    primary_report: selected,
    phase_reports: surface.phase_reports,
    canonical_context: surface.canonical_context,
    valid: surface.valid and selected.valid
  };
}

proc diagnostic_details_from_parts(
  diagnostic: CanonicalDiagnostic,
  context: DriverCanonicalContext,
  index: int
) -> DiagnosticDetails {

  give DiagnosticDetails {
    code: diagnostic.code,
    phase: canonical_phase_name(diagnostic.phase),
    message: diagnostic.message,
    explanation: diagnostic.explanation,
    root_cause: diagnostic.root_cause,
    probable_fix: diagnostic.probable_fix,
    documentation_url: diagnostic.documentation_url,
    subject_symbol: diagnostic.subject_symbol,
    pipeline_failed_at: context.pipeline_failed_at,
    pipeline_failure_reason: context.pipeline_failure_reason,
    validation_reason: context.validation_reason,
    cause_chain: diagnostic.cause_chain,
    pipeline_context: diagnostic.pipeline_context,
    range: diagnostic_hover_range(diagnostic),
    index: index,

    valid: diagnostic.valid
  };
}

proc diagnostic_details_from_surface_index(
  surface: DriverDiagnosticSurface,
  index: int
) -> DiagnosticDetails {

  if index < 0 {
    give diagnostic_details_invalid();
  }

  let index0: u64 = index as u64;
  if index0 >= len(surface.primary_report.diagnostics) {
    give diagnostic_details_invalid();
  }

  give diagnostic_details_from_parts(
    surface.primary_report.diagnostics[index0],
    surface.canonical_context,
    index
  );
}

proc diagnostic_details_from_surface_code(
  surface: DriverDiagnosticSurface,
  code: string
) -> DiagnosticDetails {

  let i: u64 = 0;
  while i < len(surface.primary_report.diagnostics) {
    if surface.primary_report.diagnostics[i].code == code {
      give diagnostic_details_from_parts(
        surface.primary_report.diagnostics[i],
        surface.canonical_context,
        i as int
      );
    }
    set i = i + 1;
  }

  give diagnostic_details_invalid();
}

proc range_contains(value: Range, point: int) -> bool {
  give value.valid and point >= value.start and point <= value.end;
}

proc diagnostic_details_from_surface_span(
  surface: DriverDiagnosticSurface,
  start: int,
  end0: int
) -> DiagnosticDetails {

  let i: u64 = 0;
  while i < len(surface.primary_report.diagnostics) {
    let current: CanonicalDiagnostic = surface.primary_report.diagnostics[i];
    let current_range: Range = diagnostic_hover_range(current);
    if current_range.valid
      and (
        range_contains(current_range, start)
        or range_contains(current_range, end0)
        or (start <= current_range.start and end0 >= current_range.end)
      ) {
      give diagnostic_details_from_parts(
        current,
        surface.canonical_context,
        i as int
      );
    }
    set i = i + 1;
  }

  give diagnostic_details_invalid();
}

proc diagnostic_hover_for_source(
  path: string,
  text: string
) -> HoverInfo {

  give diagnostic_hover_from_surface(
    driver_diagnostic_surface_from_source(
      path,
      text
