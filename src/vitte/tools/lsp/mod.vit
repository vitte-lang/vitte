proc completion_item(
  label: string,
  detail: string,
  insert_text: string,
  documentation: string,
  kind: CompletionKind,
  score: int
) -> CompletionItem {

  give CompletionItem {
    label: label,

    detail: detail,

    insert_text: insert_text,

    documentation: documentation,

    kind: kind,

    deprecated: false,

    score: score,

    valid:
      label != ""
  };
}

proc keyword_completions() -> [CompletionItem] {

  give [
    completion_item(
      "space",
      "Declare module namespace",
      "space ",
      "Top-level namespace declaration",
      CompletionKind.Keyword,
      100
    ),

    completion_item(
      "use",
      "Import module",
      "use ",
      "Import external symbols",
      CompletionKind.Keyword,
      100
    ),

    completion_item(
      "proc",
      "Procedure declaration",
      "proc ",
      "Declare a procedure",
      CompletionKind.Keyword,
      100
    ),

    completion_item(
      "form",
      "Record declaration",
      "form ",
      "Structured record type",
      CompletionKind.Keyword,
      100
    ),

    completion_item(
      "pick",
      "Tagged union declaration",
      "pick ",
      "Variant enumeration type",
      CompletionKind.Keyword,
      100
    )
  ];
}

proc completion_provider(
  prefix: string
) -> [CompletionItem] {

  let items: [CompletionItem] =
    keyword_completions();

  if prefix == "ast" {

    give items + [
      completion_item(
        "ast_span",
        "AST span constructor",
        "ast_span(",
        "Create AST source span",
        CompletionKind.Function,
        90
      ),

      completion_item(
        "ast_expr",
        "AST expression",
        "ast_expr(",
        "Create AST expression node",
        CompletionKind.Function,
        90
      )
    ];
  }

  if prefix == "hir" {

    give items + [
      completion_item(
        "hir_expr",
        "HIR expression",
        "hir_expr(",
        "Create HIR expression node",
        CompletionKind.Function,
        90
      )
    ];
  }

  if prefix == "mir" {

    give items + [
      completion_item(
        "mir_block",
        "MIR block",
        "mir_block(",
        "Create MIR basic block",
        CompletionKind.Function,
        90
      )
    ];
  }

  give items + [
    completion_item(
      prefix + "foo",
      "Generated function completion",
      prefix + "foo",
      "Example completion",
      CompletionKind.Function,
      10
    ),

    completion_item(
      prefix + "bar",
      "Generated variable completion",
      prefix + "bar",
      "Example variable completion",
      CompletionKind.Variable,
      5
    )
  ];
}

