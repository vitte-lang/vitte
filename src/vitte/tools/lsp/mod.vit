proc range(
  start: int,
  end0: int
) -> Range {

  give Range {
    start: start,
    end: end0,

    valid:
      start >= 0
      and end0 >= start
  };
}

proc empty_range() -> Range {

  give Range {
    start: 0,
    end: 0,

    valid: false
  };
}

proc position(
  line: int,
  column: int,
  offset: int
) -> Position {

  give Position {
    line: line,
    column: column,

    offset: offset,

    valid:
      line >= 0
      and column >= 0
      and offset >= 0
  };
}

proc location(
  file: string,
  line: int,
  column: int,
  symbol: string
) -> Location {

  give Location {
    file: file,

    line: line,
    column: column,

    symbol: symbol,

    valid:
      file != ""
  };
}

proc canonical_context(
  pipeline_failed_at: string,
  pipeline_failure_reason: string,
  validation_reason: string,
  frontend_ok: bool,
  typeck_ok: bool,
  borrowck_ok: bool
) -> CanonicalContext {

  give CanonicalContext {
    pipeline_failed_at: pipeline_failed_at,
    pipeline_failure_reason: pipeline_failure_reason,
    validation_reason: validation_reason,
    frontend_ok: frontend_ok,
    typeck_ok: typeck_ok,
    borrowck_ok: borrowck_ok,

    valid:
      pipeline_failed_at != ""
      and pipeline_failure_reason != ""
      and validation_reason != ""
  };
}

proc canonical_context_none() -> CanonicalContext {

  give canonical_context(
    "none",
    "none",
    "none",
    true,
    true,
    true
  );
}

proc canonical_context_for_stage(
  stage: string
) -> CanonicalContext {

  if stage == "frontend"
    or stage == "lexer"
    or stage == "parser"
    or stage == "ast_validation" {

    give canonical_context(
      stage,
      "none",
      "none",
      false,
      false,
      false
    );
  }

  if stage == "typeck" {

    give canonical_context(
      "typeck",
      "none",
      "none",
      true,
      false,
      false
    );
  }

  if stage == "borrowck" {

    give canonical_context(
      "borrowck",
      "none",
      "none",
      true,
      true,
      false
    );
  }

  if stage == "mir_validate" {

    give canonical_context(
      "mir_validate",
      "invalid-param-contract",
      "invalid-param-contract",
      true,
      true,
      true
    );
  }

  if stage == "ir_validate" {

    give canonical_context(
      "ir_validate",
      "invalid-method-dispatch-target",
      "invalid-method-dispatch-target",
      true,
      true,
      true
    );
  }

  give canonical_context_none();
}

proc status_health_from_context(
  context: CanonicalContext
) -> StatusHealth {

  let status: string = "ok";
  let health: string = "green";
  let summary: string = "pipeline healthy";
  let score: int = 100;

  if context.pipeline_failed_at == "frontend"
    or context.pipeline_failed_at == "lexer"
    or context.pipeline_failed_at == "parser"
    or context.pipeline_failed_at == "ast_validation" {

    set status = "error";
    set health = "frontend-blocked";
    set summary = "frontend failed at " + context.pipeline_failed_at;
    set score = 25;
  } elif context.pipeline_failed_at == "typeck" {
    set status = "error";
    set health = "typeck-blocked";
    set summary = "type checking failed";
    set score = 45;
  } elif context.pipeline_failed_at == "borrowck" {
    set status = "error";
    set health = "borrowck-blocked";
    set summary = "borrow checking failed";
    set score = 55;
  } elif context.pipeline_failed_at == "mir_validate" {
    set status = "error";
    set health = "mir-invalid";
    set summary = "MIR validation failed: " + context.validation_reason;
    set score = 35;
  } elif context.pipeline_failed_at == "ir_validate" {
    set status = "error";
    set health = "ir-invalid";
    set summary = "IR validation failed: " + context.validation_reason;
    set score = 30;
  }

  give StatusHealth {
    status: status,
    health: health,
    pipeline_failed_at: context.pipeline_failed_at,
    pipeline_failure_reason: context.pipeline_failure_reason,
    validation_reason: context.validation_reason,
    summary: summary,
    score: score,

    valid: context.valid and status != "" and health != ""
  };
}

proc canonical_context_from_driver_context(
  context: DriverCanonicalContext
) -> CanonicalContext {

  give canonical_context(
    context.pipeline_failed_at,
    context.pipeline_failure_reason,
    context.validation_reason,
    context.frontend_ok,
    context.typeck_ok,
    context.borrowck_ok
  );
}

proc source_uri(
  path: string
) -> string {

  if starts_with(path, "file://") {
    give path;
  }

  if starts_with(path, "/") {
    give "file://" + path;
  }

  give "file:///" + path;
}

proc status_health_json(
  report: StatusHealth
) -> string {

  give "{"
    + "\"schema\":\"vitte.lsp.status\","
    + "\"status\":\"" + report.status + "\","
    + "\"health\":\"" + report.health + "\","
    + "\"pipeline_failed_at\":\"" + report.pipeline_failed_at + "\","
    + "\"pipeline_failure_reason\":\"" + report.pipeline_failure_reason + "\","
    + "\"validation_reason\":\"" + report.validation_reason + "\","
    + "\"summary\":\"" + report.summary + "\","
    + "\"score\":" + (report.score as string)
    + "}";
}

proc json_escape(
  text: string
) -> string {

  let out: string = "";
  let i: int = 0;
  while i < len(text) {
    let ch: string = slice(text, i, i + 1);
    if ch == "\\" {
      set out = out + "\\\\";
    } elif ch == "\"" {
      set out = out + "\\\"";
    } elif ch == "\n" {
      set out = out + "\\n";
    } elif ch == "\r" {
      set out = out + "\\r";
    } elif ch == "\t" {
      set out = out + "\\t";
    } else {
      set out = out + ch;
    }
    set i = i + 1;
  }
  give out;
}

proc json_bool(
  value: bool
) -> string {

  if value {
    give "true";
  }
  give "false";
}

proc json_string(
  value: string
) -> string {

  give "\"" + json_escape(value) + "\"";
}

proc json_range(
  value: Range
) -> string {

  give "{"
    + "\"start\":" + (value.start as string) + ","
    + "\"end\":" + (value.end as string) + ","
    + "\"valid\":" + json_bool(value.valid)
    + "}";
}

proc canonical_context_json(
  context: CanonicalContext
) -> string {

  give "{"
    + "\"pipeline_failed_at\":" + json_string(context.pipeline_failed_at) + ","
    + "\"pipeline_failure_reason\":" + json_string(context.pipeline_failure_reason) + ","
    + "\"validation_reason\":" + json_string(context.validation_reason) + ","
    + "\"frontend_ok\":" + json_bool(context.frontend_ok) + ","
    + "\"typeck_ok\":" + json_bool(context.typeck_ok) + ","
    + "\"borrowck_ok\":" + json_bool(context.borrowck_ok) + ","
    + "\"valid\":" + json_bool(context.valid)
    + "}";
}

