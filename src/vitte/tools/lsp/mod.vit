proc diagnostic_phase_statuses_json(
  statuses: [DiagnosticPhaseStatus]
) -> string {

  let out: string = "";
  let i: int = 0;
  while i < len(statuses) {
    if i > 0 {
      set out = out + ",";
    }
    set out = out + diagnostic_phase_status_json(statuses[i]);
    set i = i + 1;
  }
  give "[" + out + "]";
}

