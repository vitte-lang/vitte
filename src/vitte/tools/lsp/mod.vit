pick SymbolKind {
  Unknown,

  Space,
  Module,
  Use,

  Proc,
  Variable,
  Const,
  Type,

  Form,
  Class,
  Pick,
  Trait,

  Parameter,
  Field,

  Keyword,

  Macro,
}

pick DiagnosticSeverity {
  Error,
  Warning,
  Info,
  Hint,
}

pick CompletionKind {
  Unknown,

  Function,
  Variable,
  Constant,
  Type,

  Keyword,
  Module,

  Field,
  Snippet,
}

form Range {
  start: int
  end: int

  valid: bool
}

form Position {
  line: int
  column: int

  offset: int

  valid: bool
}

form HoverInfo {
  content: string

  symbol: string

  kind: SymbolKind

  range: Range

  markdown: bool

  valid: bool
}

form CompletionItem {
  label: string

  detail: string

  insert_text: string

  documentation: string

  kind: CompletionKind

  deprecated: bool

  score: int

  valid: bool
}

form Diagnostic {
  severity: DiagnosticSeverity

  code: string

  message: string

  source: string

  range: Range

  fix_hint: string

  valid: bool
}

form Location {
  file: string

  line: int
  column: int

  symbol: string

  valid: bool
}

form SymbolInfo {
  name: string

  kind: SymbolKind

  location: Location

  exported: bool

  valid: bool
}

form SemanticToken {
  kind: string

  range: Range

  valid: bool
}

form LspCapabilities {
  hover: bool
  completion: bool
  diagnostics: bool
  goto_definition: bool
  references: bool
  semantic_tokens: bool
  rename: bool
  formatting: bool

  valid: bool
}

form CanonicalContext {
  pipeline_failed_at: string
  pipeline_failure_reason: string
  validation_reason: string
  frontend_ok: bool
  typeck_ok: bool
  borrowck_ok: bool

  valid: bool
}

form StatusHealth {
  status: string
  health: string
  pipeline_failed_at: string
  pipeline_failure_reason: string
  validation_reason: string
  summary: string
  score: int

  valid: bool
}

form DiagnosticPhaseStatus {
  phase: string
  diagnostic_count: int
  quality_score: int
  has_fatal: bool
  selected_as_primary: bool
  valid: bool
}

form DiagnosticDetails {
  code: string
  phase: string
  message: string
  explanation: string
  root_cause: string
  probable_fix: string
  documentation_url: string
  subject_symbol: string
  pipeline_failed_at: string
  pipeline_failure_reason: string
  validation_reason: string
  cause_chain: [string]
  pipeline_context: [string]
  range: Range
  index: int

  valid: bool
}

form DiagnosticPanel {
  canonical_context: CanonicalContext
  status_health: StatusHealth
  phase_statuses: [DiagnosticPhaseStatus]
  published: compiler_lsp.LspPublishDiagnosticsParams
  code_actions: [compiler_lsp.LspCodeAction]
  primary_details: DiagnosticDetails
  valid: bool
}

form LspStreamingDiagnosticBatch {
  uri: string
  batch_index: int
  diagnostics: [Diagnostic]
  final_batch: bool
  valid: bool
}

form LspDocumentSyncState {
  uri: string
  version: int
  full_text_hash: string
  incremental: bool
  valid: bool
}

form WorkspaceSymbolResult {
  query: string
  roots: [string]
  symbols: [SymbolInfo]
  multi_root: bool
  valid: bool
}

form LspClientCompatibility {
  client_name: string
  references: bool
  code_actions: bool
  diagnostics_streaming: bool
  semantic_tokens: bool
  incremental_sync: bool
  valid: bool
}

form LspStressProject {
  root_count: int
  file_count: int
  symbol_count: int
  diagnostics_streamed: int
  valid: bool
}

