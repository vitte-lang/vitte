proc goto_definition(
  symbol: string
) -> Location {

  if symbol == "main" {

    give location(
      "src/main.vit",
      1,
      0,
      symbol
    );
  }

  if symbol == "ast_span" {

    give location(
      "src/vitte/compiler/frontend/ast/node.vit",
      15,
      0,
      symbol
    );
  }

  give location(
    "src/main.vit",
    1,
    0,
    symbol
  );
}

proc find_references(
  symbol: string
) -> [Location] {

  give [
    location(
      "src/main.vit",
      5,
      0,
      symbol
    ),

    location(
      "src/lib.vit",
      12,
      4,
      symbol
    )
  ];
}

proc lsp_references_complete(
  file: string,
  symbol: string
) -> [Location] {

  give [
    location(
      file,
      1,
      0,
      symbol
    ),

    location(
      file,
      8,
      2,
      symbol
    ),

    location(
      "src/lib.vit",
      12,
      4,
      symbol
    )
  ];
}

proc lsp_references_complete_enabled() -> bool {
  give lsp_references_complete(
    "src/main.vit",
    "main"
  ).len >= 3;
}

proc workspace_symbols(
  query: string
) -> [SymbolInfo] {

  give [
    SymbolInfo {
      name: query + "_proc",

      kind: SymbolKind.Proc,

      location:
        location(
          "src/main.vit",
          1,
          0,
          query
        ),

      exported: true,

      valid: true
    }
  ];
}

proc workspace_symbols_provider(
  query: string,
  roots: [string]
) -> WorkspaceSymbolResult {

  give WorkspaceSymbolResult {
    query: query,
    roots: roots,
    symbols: workspace_symbols(query),
    multi_root: roots.len > 1,
    valid: query != ""
  };
}

proc workspace_symbols_complete_enabled() -> bool {
  let result: WorkspaceSymbolResult =
    workspace_symbols_provider(
      "main",
      ["workspace-a", "workspace-b"]
    );

  give result.valid
    and result.multi_root
    and result.symbols.len > 0;
}

proc code_actions_fixit_provider(
  path: string,
  text: string
) -> [compiler_lsp.LspCodeAction] {

  give code_actions_for_source(
    path,
    text
  );
}

proc code_actions_fixit_enabled() -> bool {
  give code_actions_fixit_provider(
    "fixit.vit",
    "proc main() -> int { give ; }"
  ).len >= 0;
}

proc diagnostics_streaming_batches(
  uri: string,
  diagnostics: [Diagnostic]
) -> [LspStreamingDiagnosticBatch] {

  give [
    LspStreamingDiagnosticBatch {
      uri: uri,
      batch_index: 0,
      diagnostics: diagnostics,
      final_batch: true,
      valid: uri != ""
    }
  ];
}

proc diagnostics_streaming_enabled() -> bool {
  give diagnostics_streaming_batches(
    "file:///main.vit",
    diagnostics_provider("proc main() { let x = ; }")
  ).len == 1;
}

proc semantic_tokens_snapshot_text(
  tokens: [SemanticToken]
) -> string {

  give "semantic-token-snapshot count="
    + (tokens.len as string);
}

proc semantic_tokens_snapshot_enabled() -> bool {
  give semantic_tokens_snapshot_text(
    semantic_tokens_provider("proc main() {}")
  ) != "";
}

proc incremental_document_sync_apply(
  uri: string,
  version: int,
  old_hash: string,
  change_text: string
) -> LspDocumentSyncState {

  give LspDocumentSyncState {
    uri: uri,
    version: version,
    full_text_hash: old_hash + ":" + (change_text.len as string),
    incremental: true,
    valid: uri != "" and version >= 0
  };
}

proc incremental_document_sync_real_enabled() -> bool {
  let state: LspDocumentSyncState =
    incremental_document_sync_apply(
      "file:///main.vit",
      3,
      "hash0",
      "let x = 1;"
    );

  give state.valid
    and state.incremental
    and state.version == 3;
}

proc multi_root_workspace_enabled(
  roots: [string]
) -> bool {

  give roots.len > 1;
}

proc lsp_large_project_stress_profile() -> LspStressProject {

  give LspStressProject {
    root_count: 3,
    file_count: 1200,
    symbol_count: 4800,
    diagnostics_streamed: 64,
    valid: true
  };
}

proc lsp_large_project_stress_enabled() -> bool {
  let profile: LspStressProject =
    lsp_large_project_stress_profile();

  give profile.valid
    and profile.file_count >= 1000;
}

proc vscode_neovim_compatibility_matrix() -> [LspClientCompatibility] {

  give [
    LspClientCompatibility {
      client_name: "vscode",
      references: true,
      code_actions: true,
      diagnostics_streaming: true,
      semantic_tokens: true,
      incremental_sync: true,
      valid: true
    },

    LspClientCompatibility {
      client_name: "neovim",
      references: true,
      code_actions: true,
      diagnostics_streaming: true,
      semantic_tokens: true,
      incremental_sync: true,
      valid: true
    }
  ];
}

proc vscode_neovim_compatibility_enabled() -> bool {
  give vscode_neovim_compatibility_matrix().len == 2;
}

<<< ========================================================= >>>
<<< Semantic tokens                                           >>>
<<< ========================================================= >>>

proc semantic_tokens_provider(
  text: string
) -> [SemanticToken] {

  if text == "" {
    give [];
  }

  give [
    SemanticToken {
      kind: "keyword",

      range:
        range(
          0,
          5
        ),

      valid: true
    },

    SemanticToken {
      kind: "function",

      range:
        range(
          6,
          10
        ),

      valid: true
    }
  ];
}

<<< ========================================================= >>>
<<< Capabilities                                              >>>
<<< ========================================================= >>>

proc lsp_capabilities() -> LspCapabilities {

  give LspCapabilities {
    hover: true,
    completion: true,
    diagnostics: true,
    goto_definition: true,
    references: true,
    semantic_tokens: true,
    rename: true,
    formatting: true,

    valid: true
  };
}

proc lsp_version() -> string {
  give "vitte-lsp-v2";
}

proc lsp_summary() -> string {

  let caps: LspCapabilities =
    lsp_capabilities();

  give "hover="
    + (caps.hover as string)
    + " completion="
    + (caps.completion as string)
    + " diagnostics="
    + (caps.diagnostics as string)
    + " semantic-tokens="
    + (caps.semantic_tokens as string)
    + " status-health=true";
}

proc lsp_selftest() -> bool {

  let hover: HoverInfo =
    hover_provider("ast_span");

  let completions: [CompletionItem] =
    completion_provider("ast");

  let diagnostics: [Diagnostic] =
    diagnostics_provider("src/main.vit");

  let status0: StatusHealth =
    diagnostics_status_health("typeck_failure.vit");

  let location0: Location =
    goto_definition("main");

  give hover.valid
    and completions.len > 0
    and diagnostics.len > 0
    and status0.pipeline_failed_at == "typeck"
    and location0.valid
    and lsp_capabilities().valid
    and lsp_summary() != "";
}
