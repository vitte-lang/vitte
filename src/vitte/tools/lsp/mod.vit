proc diagnostic(
  severity: DiagnosticSeverity,
  code: string,
  message: string,
  source: string,
  start: int,
  end0: int,
  fix_hint: string
) -> Diagnostic {

  give Diagnostic {
    severity: severity,

    code: code,

    message: message,

    source: source,

    range:
      range(
        start,
        end0
      ),

    fix_hint: fix_hint,

    valid:
      message != ""
  };
}

proc diagnostics_provider(
  file: string
) -> [Diagnostic] {

  let ds: [Diagnostic] = [];

  if ends_with(file, ".vit") {

    set ds =
      ds + [
        diagnostic(
          DiagnosticSeverity.Warning,
          "LSP001",
          "example diagnostic",
          "vitte-lsp",
          0,
          10,
          "verify syntax near token"
        )
      ];
  }

  if contains(file, "legacy") {

    set ds =
      ds + [
        diagnostic(
          DiagnosticSeverity.Info,
          "LSP_LEGACY",
          "legacy module layout detected",
          "vitte-lsp",
          5,
          20,
          "consider migrating imports"
        )
      ];
  }

  give ds;
}

proc diagnostics_status_health(
  file: string
) -> StatusHealth {

  if contains(file, "frontend") or contains(file, "lexer") or contains(file, "parser") {
    give status_health_from_context(
      canonical_context_for_stage("frontend")
    );
  }

  if contains(file, "typeck") {
    give status_health_from_context(
      canonical_context_for_stage("typeck")
    );
  }

  if contains(file, "borrowck") {
    give status_health_from_context(
      canonical_context_for_stage("borrowck")
    );
  }

  if contains(file, "mir_validate") {
    give status_health_from_context(
      canonical_context_for_stage("mir_validate")
    );
  }

  if contains(file, "ir_validate") {
    give status_health_from_context(
      canonical_context_for_stage("ir_validate")
    );
  }

  give status_health_from_context(
    canonical_context_none()
  );
}

proc diagnostics_status_health_for_source(
  path: string,
  text: string
) -> StatusHealth {

  let driver_context: DriverCanonicalContext =
    driver_canonical_context_from_source(
      path,
      text
    );

  give status_health_from_context(
    canonical_context_from_driver_context(
      driver_context
    )
  );
}

proc diagnostic_phase_statuses_from_surface(
  surface: DriverDiagnosticSurface
) -> [DiagnosticPhaseStatus] {

  let primary_phase: string = surface.canonical_context.pipeline_failed_at;
  give [
    phase_status_from_report("lexer", surface.phase_reports.lexer, primary_phase),
    phase_status_from_report("parser", surface.phase_reports.parser, primary_phase),
    phase_status_from_report("ast_validation", surface.phase_reports.ast_validation, primary_phase),
    phase_status_from_report("module_resolution", surface.phase_reports.module_resolution, primary_phase),
    phase_status_from_report("symbol_resolution", surface.phase_reports.symbol_resolution, primary_phase),
    phase_status_from_report("sema", surface.phase_reports.sema, primary_phase),
    phase_status_from_report("typeck", surface.phase_reports.typeck, primary_phase),
    phase_status_from_report("borrowck", surface.phase_reports.borrowck, primary_phase),
    phase_status_from_report("mir_lowering", surface.phase_reports.mir_lowering, primary_phase),
    phase_status_from_report("mir_verification", surface.phase_reports.mir_verification, primary_phase),
    phase_status_from_report("backend", surface.phase_reports.backend, primary_phase),
    phase_status_from_report("linker", surface.phase_reports.linker, primary_phase),
    phase_status_from_report("runtime_execution", surface.phase_reports.runtime_execution, primary_phase)
  ];
}

proc diagnostic_phase_statuses_for_source(
  path: string,
  text: string
) -> [DiagnosticPhaseStatus] {

  give diagnostic_phase_statuses_from_surface(
    driver_diagnostic_surface_from_source(path, text)
  );
}

proc diagnostic_panel_for_source(
  path: string,
  text: string,
  version: u64
) -> DiagnosticPanel {

  let surface: DriverDiagnosticSurface =
    driver_diagnostic_surface_from_source(path, text);
  let canonical_context0: CanonicalContext =
    canonical_context_from_driver_context(
      surface.canonical_context
    );
  let status_health0: StatusHealth =
    status_health_from_context(
      canonical_context0
    );
  let phase_statuses0: [DiagnosticPhaseStatus] =
    diagnostic_phase_statuses_from_surface(surface);
  let context0 =
    compiler_lsp.lsp_canonical_context(
      surface.canonical_context.pipeline_failed_at,
      surface.canonical_context.pipeline_failure_reason,
      surface.canonical_context.validation_reason
    );
  let published0: compiler_lsp.LspPublishDiagnosticsParams =
    compiler_lsp.lsp_publish_report_with_canonical_context(
      source_uri(path),
      surface.primary_report,
      version,
      context0
    );
  let code_actions0: [compiler_lsp.LspCodeAction] =
    compiler_lsp.lsp_report_code_actions(
      surface.primary_report
    );
  let primary_details0: DiagnosticDetails =
    diagnostic_details_from_surface_index(
      surface,
      0
    );

  give DiagnosticPanel {
    canonical_context: canonical_context0,
    status_health: status_health0,
    phase_statuses: phase_statuses0,
    published: published0,
    code_actions: code_actions0,
    primary_details: primary_details0,
    valid: canonical_context0.valid and status_health0.valid and published0.valid
  };
}

proc publish_diagnostics_for_source(
  path: string,
  text: string,
  version: u64
) -> compiler_lsp.LspPublishDiagnosticsParams {

  let surface: DriverDiagnosticSurface =
    driver_diagnostic_surface_from_source(
      path,
      text
    );

  let context =
    compiler_lsp.lsp_canonical_context(
      surface.canonical_context.pipeline_failed_at,
      surface.canonical_context.pipeline_failure_reason,
      surface.canonical_context.validation_reason
    );

  give compiler_lsp.lsp_publish_report_with_canonical_context(
    source_uri(path),
    surface.primary_report,
    version,
    context
  );
}

proc code_actions_for_source(
  path: string,
  text: string
) -> [compiler_lsp.LspCodeAction] {

  let surface: DriverDiagnosticSurface =
    driver_diagnostic_surface_from_source(
      path,
      text
    );

  give compiler_lsp.lsp_report_code_actions(
    surface.primary_report
  );
}

proc code_actions_for_phase_source(
  path: string,
  text: string,
  phase: string
) -> [compiler_lsp.LspCodeAction] {

  let surface: DriverDiagnosticSurface =
    surface_with_phase_report(
      driver_diagnostic_surface_from_source(path, text),
      phase
    );

  give compiler_lsp.lsp_report_code_actions(
    surface.primary_report
  );
}

