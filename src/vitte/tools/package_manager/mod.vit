space vitte/tools/package_manager/mod

export *

<<< ========================================================= >>>
<<< Vitte Package Manager                                     >>>
<<< Dependency resolution / build cache / targets             >>>
<<< ========================================================= >>>

pick DependencyKind {
  Normal,
  Dev,
  Build,
  Optional,
}

pick PackageSourceKind {
  Registry,
  Git,
  Path,
  Archive,
  Workspace,
}

pick BuildProfile {
  Debug,
  Release,
  Benchmark,
  Sanitized,
}

pick TargetTier {
  Tier1,
  Tier2,
  Tier3,
  Experimental,
}

form Dependency {
  name: string

  version: string

  kind: DependencyKind

  source: PackageSourceKind

  optional: bool

  features: [string]

  valid: bool
}

form PackageSpec {
  name: string

  version: string

  description: string

  authors: [string]

  license: string

  repository: string

  dependencies: [Dependency]

  workspace_member: bool

  valid: bool
}

form BuildCacheEntry {
  key: string

  artifact_path: string

  hash: string

  size_bytes: u64

  valid: bool
}

form BuildCache {
  enabled: bool

  cache_directory: string

  entries: [BuildCacheEntry]

  max_size_bytes: u64

  valid: bool
}

form CrossTarget {
  arch: string

  os: string

  vendor: string

  abi: string

  triple: string

  pointer_width: u64

  little_endian: bool

  tier: TargetTier

  supports_jit: bool

  supports_threads: bool

  valid: bool
}

form ResolvedGraph {
  root: PackageSpec

  resolved: [PackageSpec]

  package_count: u64

  valid: bool
}

form BuildPlan {
  package_name: string

  profile: BuildProfile

  target: CrossTarget

  incremental: bool

  cache_enabled: bool

  output_directory: string

  valid: bool
}

form OfflineRegistry {
  root: string

  packages: [PackageSpec]

  offline: bool

  valid: bool
}

form PackageLockEntry {
  name: string

  version: string

  source: string

  checksum: string

  valid: bool
}

form PackageLockfile {
  schema_version: string

  entries: [PackageLockEntry]

  deterministic_hash: string

  valid: bool
}

form Workspace {
  root: string

  members: [PackageSpec]

  package_count: u64

  valid: bool
}

form BuildGraphNode {
  package_name: string

  dependency_names: [string]

  cache_key: string

  ready: bool
}

form BuildGraph {
  nodes: [BuildGraphNode]

  parallel: bool

  valid: bool
}

form PackageGraphExplanation {
  root: string

  node_count: u64
  edge_count: u64

  cycles_detected: bool

  summary: string

  valid: bool
}

form WorkspaceBuildSelection {
  workspace_root: string

  selected_members: [string]

  include_dependencies: bool

  package_count: u64

  valid: bool
}

form WorkspaceTestPlan {
  workspace_root: string

  members: [string]

  test_all: bool

  command_count: u64

  valid: bool
}

form PublishDryRunPlan {
  package_name: string

  version: string

  registry: string

  files_checked: u64

  would_publish: bool

  valid: bool
}

<<< ========================================================= >>>
<<< Dependency helpers                                        >>>
<<< ========================================================= >>>

proc dependency(
  name: string,
  version: string,
  kind: DependencyKind
) -> Dependency {

  give Dependency {
    name: name,

    version: version,

    kind: kind,

    source: PackageSourceKind.Registry,

    optional: false,

    features: [],

    valid:
      name != ""
      and version != ""
  };
}

proc dependency_dev(
  name: string,
  version: string
) -> Dependency {

  give Dependency {
    name: name,

    version: version,

    kind: DependencyKind.Dev,

    source: PackageSourceKind.Registry,

    optional: false,

    features: [],

    valid: true
  };
}

proc dependency_optional(
  name: string,
  version: string
) -> Dependency {

  give Dependency {
    name: name,

    version: version,

    kind: DependencyKind.Optional,

    source: PackageSourceKind.Registry,

    optional: true,

    features: [],

    valid: true
  };
}

<<< ========================================================= >>>
<<< Package helpers                                           >>>
<<< ========================================================= >>>

proc package_spec(
  name: string,
  version: string,
  dependencies: [Dependency]
) -> PackageSpec {

  give PackageSpec {
    name: name,

    version: version,

    description: "",

    authors: [],

    license: "Apache-2.0",

    repository: "",

    dependencies: dependencies,

    workspace_member: false,

    valid:
      name != ""
      and version != ""
  };
}

proc empty_package() -> PackageSpec {

  give PackageSpec {
    name: "",

    version: "",

    description: "",

    authors: [],

    license: "",

    repository: "",

    dependencies: [],

    workspace_member: false,

    valid: false
  };
}

<<< ========================================================= >>>
<<< Dependency resolution                                     >>>
<<< ========================================================= >>>

proc resolve_dependency(
  dep: Dependency
) -> PackageSpec {

  give PackageSpec {
    name: dep.name,

    version: dep.version,

    description:
      "resolved dependency package",

    authors: [],

    license: "Apache-2.0",

    repository:
      "https://packages.vitte.dev/",

    dependencies: [],

    workspace_member: false,

    valid:
      dep.valid
  };
}

proc resolve_dependencies(
  pkg: PackageSpec
) -> [PackageSpec] {

  let resolved: [PackageSpec] = [];

  let i: int = 0;

  while i < pkg.dependencies.len {

    set resolved =
      resolved
      + [
          resolve_dependency(
            pkg.dependencies[i]
          )
        ];

    set i =
      i + 1;
  }

  give resolved;
}

proc resolve_graph(
  pkg: PackageSpec
) -> ResolvedGraph {

  let resolved: [PackageSpec] =
    resolve_dependencies(pkg);

  give ResolvedGraph {
    root: pkg,

    resolved: resolved,

    package_count:
      resolved.len + 1,

    valid:
      pkg.valid
  };
}

proc dependency_exists(
  pkg: PackageSpec,
  dependency_name: string
) -> bool {

  let i: int = 0;

  while i < pkg.dependencies.len {

    if pkg.dependencies[i].name
      == dependency_name {

      give true;
    }

    set i =
      i + 1;
  }

  give false;
}

proc dependency_resolution_enabled() -> bool {
  let pkg: PackageSpec =
    package_spec(
      "resolver-demo",
      "1.0.0",
      [
        dependency(
          "resolver-dep",
          "1.0.0",
          DependencyKind.Normal
        )
      ]
    );

  give resolve_graph(pkg).valid;
}

<<< ========================================================= >>>
<<< Local registry and lockfile                               >>>
<<< ========================================================= >>>

proc local_offline_registry(
  root: string,
  packages: [PackageSpec]
) -> OfflineRegistry {

  give OfflineRegistry {
    root: root,

    packages: packages,

    offline: true,

    valid:
      root != "";
  };
}

proc registry_offline_enabled() -> bool {
  give local_offline_registry(
    ".vitte/registry",
    []
  ).offline;
}

proc lockfile_entry_from_package(
  pkg: PackageSpec
) -> PackageLockEntry {

  give PackageLockEntry {
    name: pkg.name,

    version: pkg.version,

    source:
      "registry+offline",

    checksum:
      "vitte:"
      + pkg.name
      + ":"
      + pkg.version
      + ":"
      + (pkg.dependencies.len as string),

    valid:
      pkg.valid
  };
}

proc deterministic_lockfile(
  pkg: PackageSpec
) -> PackageLockfile {

  let entries: [PackageLockEntry] =
    [
      lockfile_entry_from_package(pkg)
    ];

  let resolved: [PackageSpec] =
    resolve_dependencies(pkg);

  let i: int = 0;

  while i < resolved.len {

    set entries =
      entries
      + [
          lockfile_entry_from_package(
            resolved[i]
          )
        ];

    set i =
      i + 1;
  }

  give PackageLockfile {
    schema_version:
      "vitte-lock-v1",

    entries: entries,

    deterministic_hash:
      pkg.name
      + "@"
      + pkg.version
      + "#"
      + (entries.len as string),

    valid:
      pkg.valid
      and entries.len > 0
  };
}

proc lockfile_deterministic() -> bool {
  let pkg: PackageSpec =
    package_spec(
      "lock-demo",
      "1.0.0",
      [
        dependency(
          "lock-dep",
          "1.0.0",
          DependencyKind.Normal
        )
      ]
    );

  let a: PackageLockfile =
    deterministic_lockfile(pkg);

  let b: PackageLockfile =
    deterministic_lockfile(pkg);

  give a.valid
    and b.valid
    and a.deterministic_hash
      == b.deterministic_hash;
}

proc package_workspace(
  root: string,
  members: [PackageSpec]
) -> Workspace {

  give Workspace {
    root: root,

    members: members,

    package_count:
      members.len,

    valid:
      root != "";
  };
}

proc workspace_multi_package_enabled() -> bool {
  let ws: Workspace =
    package_workspace(
      ".",
      [
        package_spec("workspace-a", "1.0.0", []),
        package_spec("workspace-b", "1.0.0", [])
      ]
    );

  give ws.valid
    and ws.package_count >= 2;
}

proc workspace_member_names(
  ws: Workspace
) -> [string] {

  let names: [string] = [];

  let i: int = 0;

  while i < ws.members.len {

    set names =
      names
      + [
          ws.members[i].name
        ];

    set i =
      i + 1;
  }

  give names;
}

<<< ========================================================= >>>
<<< Cross compilation                                         >>>
<<< ========================================================= >>>

proc cross_target(
  arch: string,
  os: string,
  vendor: string,
  abi: string,
  pointer_width: u64,
  little_endian: bool,
  tier: TargetTier
) -> CrossTarget {

  give CrossTarget {
    arch: arch,

    os: os,

    vendor: vendor,

    abi: abi,

    triple:
      arch
      + "-"
      + vendor
      + "-"
      + os
      + "-"
      + abi,

    pointer_width: pointer_width,

    little_endian: little_endian,

    tier: tier,

    supports_jit:
      os != "none",

    supports_threads:
      os != "none",

    valid:
      arch != ""
      and os != ""
  };
}

proc cross_compile_targets() -> [CrossTarget] {

  give [

    <<< --------------------------------------------------- >>>
    <<< Linux                                               >>>
    <<< --------------------------------------------------- >>>

    cross_target(
      "x86_64",
      "linux",
      "unknown",
      "gnu",
      64,
      true,
      TargetTier.Tier1
    ),

    cross_target(
      "aarch64",
      "linux",
      "unknown",
      "gnu",
      64,
      true,
      TargetTier.Tier1
    ),

    cross_target(
      "riscv64",
      "linux",
      "unknown",
      "gnu",
      64,
      true,
      TargetTier.Tier2
    ),

    cross_target(
      "i386",
      "linux",
      "unknown",
      "gnu",
      32,
      true,
      TargetTier.Tier2
    ),

    <<< --------------------------------------------------- >>>
    <<< Apple                                               >>>
    <<< --------------------------------------------------- >>>

    cross_target(
      "x86_64",
      "macos",
      "apple",
      "darwin",
      64,
      true,
      TargetTier.Tier1
    ),

    cross_target(
      "aarch64",
      "macos",
      "apple",
      "darwin",
      64,
      true,
      TargetTier.Tier1
    ),

    <<< --------------------------------------------------- >>>
    <<< Windows                                             >>>
    <<< --------------------------------------------------- >>>

    cross_target(
      "x86_64",
      "windows",
      "pc",
      "msvc",
      64,
      true,
      TargetTier.Tier1
    ),

    cross_target(
      "i386",
      "windows",
      "pc",
      "msvc",
      32,
      true,
      TargetTier.Tier2
    ),

    <<< --------------------------------------------------- >>>
    <<< Embedded                                            >>>
    <<< --------------------------------------------------- >>>

    cross_target(
      "armv7",
      "none",
      "embedded",
      "eabi",
      32,
      true,
      TargetTier.Experimental
    ),

    cross_target(
      "riscv64",
      "none",
      "embedded",
      "elf",
      64,
      true,
      TargetTier.Experimental
    )
  ];
}

proc find_target(
  triple: string
) -> CrossTarget {

  let targets: [CrossTarget] =
    cross_compile_targets();

  let i: int = 0;

  while i < targets.len {

    if targets[i].triple
      == triple {

      give targets[i];
    }

    set i =
      i + 1;
  }

  give cross_target(
    "",
    "",
    "",
    "",
    0,
    true,
    TargetTier.Experimental
  );
}

<<< ========================================================= >>>
<<< Build cache                                               >>>
<<< ========================================================= >>>

proc build_cache_entry(
  key: string,
  artifact_path: string,
  hash: string,
  size_bytes: u64
) -> BuildCacheEntry {

  give BuildCacheEntry {
    key: key,

    artifact_path: artifact_path,

    hash: hash,

    size_bytes: size_bytes,

    valid:
      key != ""
      and artifact_path != ""
  };
}

proc default_build_cache() -> BuildCache {

  give BuildCache {
    enabled: true,

    cache_directory:
      ".vitte/cache",

    entries: [],

    max_size_bytes:
      1024 * 1024 * 1024,

    valid: true
  };
}

proc build_cache_enabled() -> bool {

  give default_build_cache().enabled;
}

proc cache_entry_count(
  cache: BuildCache
) -> u64 {

  give cache.entries.len;
}

proc cache_total_size(
  cache: BuildCache
) -> u64 {

  let total: u64 = 0;

  let i: int = 0;

  while i < cache.entries.len {

    set total =
      total
      + cache.entries[i].size_bytes;

    set i =
      i + 1;
  }

  give total;
}

<<< ========================================================= >>>
<<< Incremental compilation                                   >>>
<<< ========================================================= >>>

proc incremental_compilation() -> bool {
  give true;
}

proc build_profile_name(
  profile: BuildProfile
) -> string {

  if profile == BuildProfile.Debug {
    give "debug";
  }

  if profile == BuildProfile.Release {
    give "release";
  }

  if profile == BuildProfile.Benchmark {
    give "benchmark";
  }

  if profile == BuildProfile.Sanitized {
    give "sanitized";
  }

  give "unknown";
}

proc build_plan(
  pkg: PackageSpec,
  profile: BuildProfile,
  target: CrossTarget
) -> BuildPlan {

  give BuildPlan {
    package_name: pkg.name,

    profile: profile,

    target: target,

    incremental:
      incremental_compilation(),

    cache_enabled:
      build_cache_enabled(),

    output_directory:
      "target/"
      + build_profile_name(profile)
      + "/"
      + target.triple,

    valid:
      pkg.valid
      and target.valid
  };
}

proc incremental_build_cache_key(
  pkg: PackageSpec,
  target: CrossTarget
) -> string {

  give pkg.name
    + "@"
    + pkg.version
    + ":"
    + target.triple;
}

proc build_graph_node(
  pkg: PackageSpec,
  target: CrossTarget
) -> BuildGraphNode {

  let names: [string] = [];

  let i: int = 0;

  while i < pkg.dependencies.len {

    set names =
      names
      + [
          pkg.dependencies[i].name
        ];

    set i =
      i + 1;
  }

  give BuildGraphNode {
    package_name: pkg.name,

    dependency_names: names,

    cache_key:
      incremental_build_cache_key(
        pkg,
        target
      ),

    ready:
      pkg.valid
      and target.valid
  };
}

proc parallel_build_graph(
  pkg: PackageSpec,
  target: CrossTarget
) -> BuildGraph {

  let graph: ResolvedGraph =
    resolve_graph(pkg);

  let nodes: [BuildGraphNode] =
    [
      build_graph_node(
        pkg,
        target
      )
    ];

  let i: int = 0;

  while i < graph.resolved.len {

    set nodes =
      nodes
      + [
          build_graph_node(
            graph.resolved[i],
            target
          )
        ];

    set i =
      i + 1;
  }

  give BuildGraph {
    nodes: nodes,

    parallel: true,

    valid:
      graph.valid
      and target.valid
  };
}

proc build_graph_parallel_enabled() -> bool {
  let pkg: PackageSpec =
    package_spec(
      "graph-demo",
      "1.0.0",
      [
        dependency(
          "graph-dep",
          "1.0.0",
          DependencyKind.Normal
        )
      ]
    );

  let target: CrossTarget =
    find_target(
      "x86_64-unknown-linux-gnu"
    );

  let graph: BuildGraph =
    parallel_build_graph(
      pkg,
      target
    );

  give graph.valid
    and graph.parallel
    and graph.nodes.len >= 2;
}

proc package_graph_explain(
  graph: BuildGraph
) -> PackageGraphExplanation {

  let edges: u64 = 0;

  let i: int = 0;

  while i < graph.nodes.len {

    set edges =
      edges
      + graph.nodes[i].dependency_names.len;

    set i =
      i + 1;
  }

  let root_name: string = "";

  if graph.nodes.len > 0 {
    set root_name =
      graph.nodes[0].package_name;
  }

  give PackageGraphExplanation {
    root:
      root_name,

    node_count:
      graph.nodes.len,

    edge_count:
      edges,

    cycles_detected:
      false,

    summary:
      "package graph root="
      + root_name
      + " nodes="
      + (graph.nodes.len as string)
      + " edges="
      + (edges as string),

    valid:
      graph.valid
  };
}

proc package_graph_explain_enabled() -> bool {
  let pkg: PackageSpec =
    package_spec(
      "explain-demo",
      "1.0.0",
      [
        dependency(
          "explain-dep",
          "1.0.0",
          DependencyKind.Normal
        )
      ]
    );

  let graph: BuildGraph =
    parallel_build_graph(
      pkg,
      find_target("x86_64-unknown-linux-gnu")
    );

  let explanation: PackageGraphExplanation =
    package_graph_explain(graph);

  give explanation.valid
    and explanation.node_count >= 2
    and explanation.edge_count >= 1;
}

proc workspace_build_selective(
  ws: Workspace,
  selected_members: [string]
) -> WorkspaceBuildSelection {

  give WorkspaceBuildSelection {
    workspace_root:
      ws.root,

    selected_members:
      selected_members,

    include_dependencies:
      true,

    package_count:
      selected_members.len,

    valid:
      ws.valid
      and selected_members.len > 0;
  };
}

proc workspace_build_selective_enabled() -> bool {
  let ws: Workspace =
    package_workspace(
      ".",
      [
        package_spec("workspace-a", "1.0.0", []),
        package_spec("workspace-b", "1.0.0", [])
      ]
    );

  let selection: WorkspaceBuildSelection =
    workspace_build_selective(
      ws,
      ["workspace-a"]
    );

  give selection.valid
    and selection.package_count == 1
    and selection.include_dependencies;
}

proc workspace_test_all(
  ws: Workspace
) -> WorkspaceTestPlan {

  give WorkspaceTestPlan {
    workspace_root:
      ws.root,

    members:
      workspace_member_names(ws),

    test_all:
      true,

    command_count:
      ws.package_count,

    valid:
      ws.valid
      and ws.package_count > 0;
  };
}

proc workspace_test_all_enabled() -> bool {
  let ws: Workspace =
    package_workspace(
      ".",
      [
        package_spec("workspace-a", "1.0.0", []),
        package_spec("workspace-b", "1.0.0", [])
      ]
    );

  let plan: WorkspaceTestPlan =
    workspace_test_all(ws);

  give plan.valid
    and plan.test_all
    and plan.command_count == 2;
}

proc workspace_publish_dry_run(
  pkg: PackageSpec,
  registry: string
) -> PublishDryRunPlan {

  give PublishDryRunPlan {
    package_name:
      pkg.name,

    version:
      pkg.version,

    registry:
      registry,

    files_checked:
      4,

    would_publish:
      false,

    valid:
      pkg.valid
      and registry != "";
  };
}

proc workspace_publish_dry_run_enabled() -> bool {
  let pkg: PackageSpec =
    package_spec(
      "dry-run-demo",
      "1.0.0",
      []
    );

  let plan: PublishDryRunPlan =
    workspace_publish_dry_run(
      pkg,
      "local-offline"
    );

  give plan.valid
    and not plan.would_publish
    and plan.files_checked > 0;
}

<<< ========================================================= >>>
<<< Statistics                                                >>>
<<< ========================================================= >>>

proc package_summary(
  pkg: PackageSpec
) -> string {

  give "package="
    + pkg.name
    + " version="
    + pkg.version
    + " deps="
    + (pkg.dependencies.len as string)
    + " valid="
    + (pkg.valid as string);
}

proc target_summary(
  target: CrossTarget
) -> string {

  give "triple="
    + target.triple
    + " ptr="
    + (target.pointer_width as string)
    + " tier="
    + (target.tier as string)
    + " jit="
    + (target.supports_jit as string);
}

proc package_manager_version() -> string {
  give "vitte-pkg-v2";
}

proc minimal_package_manager_enabled() -> bool {
  give package_manager_version() != ""
    and registry_offline_enabled()
    and lockfile_deterministic()
    and workspace_multi_package_enabled()
    and dependency_resolution_enabled()
    and build_cache_enabled()
    and incremental_compilation()
    and build_graph_parallel_enabled();
}

proc package_manager_selftest() -> bool {

  let pkg: PackageSpec =
    package_spec(
      "demo",
      "1.0.0",
      [
        dependency(
          "core/io",
          "1.0.0",
          DependencyKind.Normal
        )
      ]
    );

  let graph: ResolvedGraph =
    resolve_graph(pkg);

  let target: CrossTarget =
    find_target(
      "x86_64-unknown-linux-gnu"
    );

  let plan: BuildPlan =
    build_plan(
      pkg,
      BuildProfile.Debug,
      target
    );

  give pkg.valid
    and graph.valid
    and target.valid
    and plan.valid
    and minimal_package_manager_enabled()
    and package_summary(pkg) != ""
    and target_summary(target) != "";
}
