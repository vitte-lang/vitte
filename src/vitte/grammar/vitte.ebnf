<<< ========================================================= ) ( Vitte — Core Grammar (minimal surface) ) ( ========================================================= >>>

program ::= WS? { toplevel WS? } ;

<<< ——————————————————— ) ( Top-level ) ( ——————————————————— >>>

toplevel ::= space_decl
          | from_import_decl
          | use_decl
          | const_decl
          | type_alias_decl
          | form_decl
          | pick_decl
          | proc_decl
          | entry_decl
          ;

space_decl ::= "space" WS1 module_path ;
from_import_decl ::= "from" WS1 package_path WS1 "import" WS1 ident_list ;
use_decl   ::= "use" WS1 package_path [ use_group | use_glob ] [ WS1 "as" WS1 ident ] ;
use_glob   ::= "." "*" ;
use_group  ::= "." "{" WS? ( "*" | ident_list [ WS? "," WS? "*" ]? ) WS? "}" ;
const_decl ::= "const" WS1 ident [ WS? ":" WS? type_expr ] WS? "=" WS? expr ;
type_alias_decl ::= "type" WS1 ident [ "[" WS? ident_list WS? "]" ] WS? "=" WS? type_expr ;

form_decl ::= "form" WS1 ident [ "[" WS? ident_list WS? "]" ] WS?
             "{" WS? field_list? WS? "}" ;
field_list ::= field_item { WS? "," WS? field_item } ;
field_item ::= ident WS? ":" WS? type_expr ;

pick_decl ::= "pick" WS1 ident [ "[" WS? ident_list WS? "]" ] WS?
             "{" WS? case_list? WS? "}" ;
case_list ::= case_item { WS? "," WS? case_item } ;
case_item ::= [ "case" WS1 ] ident [ "(" WS? case_payload WS? ")" ] ;
case_payload ::= case_field { WS? "," WS? case_field } ;
case_field ::= ident WS? ":" WS? type_expr ;

attr_prefix ::= attribute | shorthand_attribute | docstring ;
attribute ::= "#[" ident [ "(" WS? attr_arg_list? WS? ")" ] "]" ;
shorthand_attribute ::= "@" ident ;
docstring ::= raw_string_lit ;
attr_arg_list ::= attr_arg { WS? "," WS? attr_arg } ;
attr_arg ::= ident | string_lit | int_lit ;

proc_decl ::= { attr_prefix WS? } "proc" WS1 ident [ "[" WS? ident_list WS? "]" ]
             "(" WS? param_list? WS? ")"
             WS? [ "->" WS? type_expr ]
             WS? block_body? ;
param_list ::= param { WS? "," WS? param } ;
param ::= ident [ WS? ":" WS? type_expr ] ;

entry_decl ::= "entry" WS1 ident WS1 "at" WS1 module_path WS? block ;

module_path ::= relative? package_parts ;
package_path ::= relative? package_parts ;
relative ::= { "." } ;
package_parts ::= ident { ("/" | ".") ident } ;
ident_list ::= ident { WS? "," WS? ident } ;

<<< ——————————————————— ) ( Block / Statements ) ( ——————————————————— >>>

block ::= "{" WS? { stmt WS? } "}" ;
inline_block ::= ":" WS? expr ;
block_body ::= block | inline_block ;

stmt ::= let_stmt
       | asm_stmt
       | unsafe_stmt
       | make_stmt
       | set_stmt
       | give_stmt
       | emit_stmt
       | if_stmt
       | while_stmt
       | for_stmt
       | break_stmt
       | continue_stmt
       | select_stmt
       | match_stmt
       | when_match_stmt
       | expr_stmt
       ;

asm_stmt ::= "asm" WS? "(" WS? string_lit WS? ")" ;
unsafe_stmt ::= "unsafe" WS? block ;
let_stmt  ::= "let" WS1 ident [ WS? ":" WS? type_expr ] WS? "=" WS? expr ;
make_stmt ::= "make" WS1 ident [ WS1 "as" WS1 type_expr ] WS? "=" WS? expr ;
set_stmt  ::= "set" WS1 assign_target WS? "=" WS? expr ;
assign_target ::= postfix_expr ;

give_stmt ::= "give" WS1 expr ;
emit_stmt ::= "emit" WS1 expr ;

if_stmt ::= "if" WS1 expr WS? block_body
            [ WS? "else" WS? ( block_body | if_stmt ) ] ;
while_stmt ::= "while" WS1 expr WS? block ;
for_stmt ::= "for" WS1 ident WS1 "in" WS1 expr WS? block ;

break_stmt ::= "break" ;
continue_stmt ::= "continue" ;

select_stmt ::= "select" WS1 expr WS? { "when" WS1 pattern WS? block WS? } ;
match_stmt ::= "match" WS1 expr WS?
               "{" WS? { "case" WS1 pattern [ WS1 "if" WS1 expr ] WS? block_body WS? } [ WS? "else" WS? block_body ] "}" ;
match_expr ::= "match" WS1 expr WS?
               "{" WS? { "case" WS1 pattern [ WS1 "if" WS1 expr ] WS? block_body WS? } [ WS? "else" WS? block_body ] "}" ;
when_match_stmt ::= "when" WS1 expr WS1 "is" WS1 pattern WS? block ;

expr_stmt ::= expr ;

<<< ——————————————————— ) ( Expressions ) ( ——————————————————— >>>

expr ::= assign_expr ;
assign_expr ::= range_expr [ WS? "=" WS? assign_expr ] ;
range_expr ::= or_expr [ WS? (".." | "..=") WS? or_expr ] ;

or_expr  ::= and_expr { WS? "or" WS? and_expr } ;
and_expr ::= eq_expr { WS? "and" WS? eq_expr } ;

eq_expr  ::= rel_expr { WS? ("==" | "!=") WS? rel_expr } ;
rel_expr ::= add_expr { WS? ("<" | "<=" | ">" | ">=") WS? add_expr } ;

add_expr ::= mul_expr { WS? ("+" | "-") WS? mul_expr } ;
mul_expr ::= cast_expr { WS? ("*" | "/" | "%") WS? cast_expr } ;

cast_expr ::= unary_expr { WS? ("as" WS? type_expr | "is" WS? pattern) } ;
unary_expr ::= ("not" | "-") WS? unary_expr | postfix_expr ;

postfix_expr ::= primary { call_suffix | member_suffix | index_suffix } ;
call_suffix ::= "(" WS? arg_list? WS? ")" ;
member_suffix ::= "." ident ;
index_suffix ::= "[" WS? expr WS? "]" ;

primary ::= literal
          | ident
          | list_lit
          | tuple_lit
          | set_lit
          | if_expr
          | proc_expr
          | match_expr
          | block
          | "(" WS? expr WS? ")"
          ;

arg_list ::= expr { WS? "," WS? expr } ;
tuple_lit ::= "(" WS? expr WS? "," WS? expr { WS? "," WS? expr } WS? ")" ;
set_lit ::= "set" WS? "{" WS? arg_list? WS? "}" ;
if_expr ::= "if" WS1 expr WS? block_body [ WS? "else" WS? ( block_body | if_expr ) ] ;
proc_expr ::= { attr_prefix WS? } "proc" WS? "(" WS? param_list? WS? ")" WS? [ "->" WS? type_expr ] WS? block_body ;

<<< ——————————————————— ) ( Patterns / Types / Literals ) ( ——————————————————— >>>

pattern ::= pattern_head [ "(" WS? pattern_args? WS? ")" ] ;
pattern_head ::= ident { "." ident } ;
pattern_args ::= pattern { WS? "," WS? pattern } ;

type_expr ::= pointer_type | slice_type | proc_type | type_primary ;
pointer_type ::= "*" WS? type_expr ;
slice_type ::= "[" WS? type_expr WS? "]" ;
proc_type ::= "proc" WS? "(" WS? type_list? WS? ")" WS? [ "->" WS? type_expr ] ;
type_list ::= type_param { WS? "," WS? type_param } ;
type_param ::= ident WS? ":" WS? type_expr | type_expr ;
type_primary ::= ident { "." ident } [ "[" WS? type_list? WS? "]" ]
               | "bool" | "string" | "int"
               | "i32" | "i64" | "i128" | "u32" | "u64" | "u128" ;

literal ::= bool_lit | int_lit | float_lit | char_lit | string_lit | list_lit ;
list_lit ::= "[" WS? arg_list? WS? "]" ;
bool_lit ::= "true" | "false" ;
int_lit ::= [ "-" ] DIGIT { DIGIT | "_" } [ suffix ]
          | [ "-" ] "0x" HEXDIGIT { HEXDIGIT | "_" } ;
float_lit ::= [ "-" ] DIGIT { DIGIT | "_" } "." DIGIT { DIGIT | "_" } ;
char_lit ::= "'" { char_char } "'" ;
char_char ::= "\\" | ~"'" ;
string_lit ::= "\"" { string_char } "\"" | raw_string_lit ;
string_char ::= "\\\"" | "\\\\" | ~"\"" ;
raw_string_lit ::= "\"\"\"" { raw_string_char } "\"\"\"" ;
raw_string_char ::= ~"\"\"\"" ;

<<< ——————————————————— ) ( Lexical notes ) ( ——————————————————— >>>

block_comment ::= "/*" { ~"*/" ANY } "*/" ;

<<< ——————————————————— ) ( Lexical ) ( ——————————————————— >>>

ident ::= (LETTER | "_") { LETTER | DIGIT | "_" } ;
suffix ::= LETTER { LETTER } ;

WS ::= { " " | "\t" | NEWLINE | block_comment } ;
WS1 ::= ( " " | "\t" | NEWLINE | block_comment ) { " " | "\t" | NEWLINE | block_comment } ;

NEWLINE ::= "\n" | "\r\n" ;

LETTER ::= "a"..."z" | "A"..."Z" ;
DIGIT ::= "0"..."9" ;
HEXDIGIT ::= DIGIT | "a"..."f" | "A"..."F" ;
