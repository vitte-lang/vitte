<<<
mod.vit
package vitte/audio
>>>

space vitte/audio

use vitte/audio/internal/runtime as audio_runtime_pkg
use vitte/audio/internal/validate as audio_validate_pkg
use vitte/audio/internal/policy as audio_policy_pkg


# -------------------------------------------------
# Core types
# -------------------------------------------------

form AudioBuffer {
  sample_rate: int
  channels: int
  samples: [int]
}

form AudioStats {
  peak: int
  rms: int
  duration_ms: int
  samples: int
}

form AudioBackend {
  name: string
  mockable: bool
  supports_input: bool
  supports_output: bool
}

mask AudioSampleFormat {
  PCM16
  PCM24
  Float32
}

form AudioFormat {
  sample_rate: int
  channels: int
  format: AudioSampleFormat
  interleaved: bool
}

form AudioFormatRequest {
  preferred_sample_rate: int
  preferred_channels: int
  preferred_formats: [AudioSampleFormat]
  prefer_interleaved: bool
}

form AudioGoldenSnapshot {
  id: string
  samples: [int]
  checksum: int
}

proc valid_buffer(buf: AudioBuffer) -> bool {
  if audio_validate_pkg.valid_buffer_shape(buf.sample_rate, buf.channels) == false { give false }
  if audio_validate_pkg.valid_samples_length(buf.samples.len, buf.channels) == false { give false }
  give true
}

proc backend_default() -> AudioBackend {
  give AudioBackend(
    audio_runtime_pkg.runtime_name(),
    true,
    true,
    true
  )
}

proc backend_mock(name: string) -> AudioBackend {
  let n = name
  if n.len == 0 { n = "mock-backend" }
  give AudioBackend(n, true, true, true)
}

proc backend_is_mockable(backend: AudioBackend) -> bool {
  give backend.mockable
}

proc backend_name(backend: AudioBackend) -> string {
  give backend.name
}

proc sample_format_name(format: AudioSampleFormat) -> string {
  if format == AudioSampleFormat.PCM24 { give "pcm24" }
  if format == AudioSampleFormat.Float32 { give "float32" }
  give "pcm16"
}

proc format_default() -> AudioFormat {
  give AudioFormat(
    audio_policy_pkg.default_sample_rate(),
    2,
    AudioSampleFormat.PCM16,
    true
  )
}

proc format_request_new(
  preferred_sample_rate: int,
  preferred_channels: int,
  prefer_interleaved: bool
) -> AudioFormatRequest {
  give AudioFormatRequest(
    audio_policy_pkg.normalize_sample_rate(preferred_sample_rate),
    audio_policy_pkg.normalize_channels(preferred_channels),
    [AudioSampleFormat.PCM16, AudioSampleFormat.Float32, AudioSampleFormat.PCM24],
    prefer_interleaved
  )
}

proc format_request_with_order(req: AudioFormatRequest, formats: [AudioSampleFormat]) -> AudioFormatRequest {
  if formats.len == 0 {
    give AudioFormatRequest(req.preferred_sample_rate, req.preferred_channels, req.preferred_formats, req.prefer_interleaved)
  }
  let uniq: [AudioSampleFormat] = []
  let i: int = 0
  while !(i >= formats.len) {
    let f = formats[i]
    let seen = false
    let j: int = 0
    while !(j >= uniq.len) {
      if uniq[j] == f {
        seen = true
        break
      }
      j = j + 1
    }
    if seen == false { uniq = uniq.push(f) }
    i = i + 1
  }
  if uniq.len == 0 {
    give AudioFormatRequest(req.preferred_sample_rate, req.preferred_channels, req.preferred_formats, req.prefer_interleaved)
  }
  give AudioFormatRequest(req.preferred_sample_rate, req.preferred_channels, uniq, req.prefer_interleaved)
}

proc normalize_format_request(req: AudioFormatRequest) -> AudioFormatRequest {
  let sr = audio_policy_pkg.normalize_sample_rate(req.preferred_sample_rate)
  let ch = audio_policy_pkg.normalize_channels(req.preferred_channels)
  give format_request_with_order(
    AudioFormatRequest(sr, ch, req.preferred_formats, req.prefer_interleaved),
    req.preferred_formats
  )
}

proc format_is_valid(fmt: AudioFormat) -> bool {
  if audio_validate_pkg.valid_buffer_shape(fmt.sample_rate, fmt.channels) == false { give false }
  give true
}

proc format_rank(req: AudioFormatRequest, fmt: AudioFormat) -> int {
  let rank: int = 0
  if fmt.sample_rate == req.preferred_sample_rate { rank = rank + 4 }
  if fmt.channels == req.preferred_channels { rank = rank + 3 }
  if fmt.interleaved == req.prefer_interleaved { rank = rank + 1 }

  let i: int = 0
  while !(i >= req.preferred_formats.len) {
    if req.preferred_formats[i] == fmt.format {
      rank = rank + (30 - i)
      break
    }
    i = i + 1
  }

  give rank
}

proc negotiate_format(req: AudioFormatRequest, supported: [AudioFormat]) -> AudioFormat {
  let normalized_req = normalize_format_request(req)
  let default_fmt = AudioFormat(
    normalized_req.preferred_sample_rate,
    normalized_req.preferred_channels,
    AudioSampleFormat.PCM16,
    normalized_req.prefer_interleaved
  )
  if supported.len == 0 { give default_fmt }

  let winner = default_fmt
  let has_winner = false
  let winner_rank: int = -1
  let i: int = 0

  while !(i >= supported.len) {
    let cand = supported[i]
    if format_is_valid(cand) {
      let r = format_rank(normalized_req, cand)
      if has_winner == false || r > winner_rank {
        winner = cand
        winner_rank = r
        has_winner = true
      }
    }
    i = i + 1
  }

  if has_winner == false { give default_fmt }
  give winner
}

proc format_summary(fmt: AudioFormat) -> string {
  give "sr=" + fmt.sample_rate.to_string() +
       ",ch=" + fmt.channels.to_string() +
       ",fmt=" + sample_format_name(fmt.format) +
       ",interleaved=" + fmt.interleaved.to_string()
}

proc pcm_checksum(samples: [int]) -> int {
  let acc: int = 17
  let i: int = 0
  while !(i >= samples.len) {
    let v = clamp_sample(samples[i])
    acc = acc * 31 + (v + 32768) + i
    i = i + 1
  }
  if acc < 0 { acc = 0 - acc }
  give acc
}

proc golden_snapshot(id: string, samples: [int]) -> AudioGoldenSnapshot {
  give AudioGoldenSnapshot(id, samples, pcm_checksum(samples))
}

proc golden_match(golden: AudioGoldenSnapshot, samples: [int]) -> bool {
  if golden.samples.len != samples.len { give false }
  if golden.checksum != pcm_checksum(samples) { give false }
  let i: int = 0
  while !(i >= samples.len) {
    if golden.samples[i] != samples[i] { give false }
    i = i + 1
  }
  give true
}

proc golden_diff_count(expected: [int], actual: [int]) -> int {
  let n = expected.len
  if actual.len < n { n = actual.len }

  let diff: int = 0
  let i: int = 0
  while !(i >= n) {
    if expected[i] != actual[i] { diff = diff + 1 }
    i = i + 1
  }

  if expected.len > n { diff = diff + (expected.len - n) }
  if actual.len > n { diff = diff + (actual.len - n) }
  give diff
}


# -------------------------------------------------
# Constructors
# -------------------------------------------------

proc buffer_new(sample_rate: int, channels: int) -> AudioBuffer {
  let sr = audio_policy_pkg.normalize_sample_rate(sample_rate)
  let ch = audio_policy_pkg.normalize_channels(channels)

  give AudioBuffer(sr, ch, [])
}

proc buffer_with_capacity(sample_rate: int, channels: int, cap: int) -> AudioBuffer {
  let buf = buffer_new(sample_rate, channels)
  let _ = cap
  give AudioBuffer(buf.sample_rate, buf.channels, [])
}


# -------------------------------------------------
# Sample helpers
# -------------------------------------------------

proc clamp_sample(v: int) -> int {
  let out = v
  if out > audio_policy_pkg.max_sample_value() { out = audio_policy_pkg.max_sample_value() }
  if out < audio_policy_pkg.min_sample_value() { out = audio_policy_pkg.min_sample_value() }
  give out
}

proc abs_sample(v: int) -> int {
  let a = v
  if a < 0 { a = 0 - a }
  give a
}


# -------------------------------------------------
# Buffer operations
# -------------------------------------------------

proc push_sample(buf: AudioBuffer, sample: int) -> AudioBuffer {
  if valid_buffer(buf) == false { give buffer_new(buf.sample_rate, buf.channels) }
  let v = sample
  if audio_validate_pkg.valid_sample_value(v) == false { v = clamp_sample(v) }
  give AudioBuffer(
    buf.sample_rate,
    buf.channels,
    buf.samples.push(v)
  )
}

proc append_buffer(left: AudioBuffer, right: AudioBuffer) -> AudioBuffer {
  if valid_buffer(left) == false { give left }
  if valid_buffer(right) == false { give left }
  if left.sample_rate != right.sample_rate { give left }
  if left.channels != right.channels { give left }
  let out = left.samples
  let i: int = 0

  while !(i >= right.samples.len) {
    out = out.push(right.samples[i])
    i = i + 1
  }

  give AudioBuffer(left.sample_rate, left.channels, out)
}

proc silence(buf: AudioBuffer) -> AudioBuffer {
  let out: [int] = []
  let i: int = 0

  while !(i >= buf.samples.len) {
    out = out.push(0)
    i = i + 1
  }

  give AudioBuffer(buf.sample_rate, buf.channels, out)
}


# -------------------------------------------------
# DSP operations
# -------------------------------------------------

proc gain(buf: AudioBuffer, percent: int) -> AudioBuffer {
  if valid_buffer(buf) == false { give buf }
  let p = percent
  if audio_validate_pkg.valid_gain_percent(p) == false {
    if p < 0 { p = 0 }
    if p > 1000 { p = 1000 }
  }

  let out: [int] = []
  let i: int = 0

  while !(i >= buf.samples.len) {

    let scaled = buf.samples[i] * p / 100
    out = out.push(clamp_sample(scaled))

    i = i + 1
  }

  give AudioBuffer(buf.sample_rate, buf.channels, out)
}

proc mix(a: AudioBuffer, b: AudioBuffer) -> AudioBuffer {
  if valid_buffer(a) == false { give a }
  if valid_buffer(b) == false { give a }
  if a.sample_rate != b.sample_rate { give a }
  if a.channels != b.channels { give a }
  let n = a.samples.len
  if b.samples.len < n { n = b.samples.len }

  let out: [int] = []
  let i: int = 0

  while !(i >= n) {

    let v = (a.samples[i] + b.samples[i]) / 2
    out = out.push(clamp_sample(v))

    i = i + 1
  }

  if a.samples.len > n {
    let j: int = n
    while !(j >= a.samples.len) {
      out = out.push(a.samples[j])
      j = j + 1
    }
  } else {
    let j: int = n
    while !(j >= b.samples.len) {
      out = out.push(b.samples[j])
      j = j + 1
    }
  }

  give AudioBuffer(a.sample_rate, a.channels, out)
}

proc normalize_peak(buf: AudioBuffer, target_peak: int) -> AudioBuffer {
  if valid_buffer(buf) == false { give buf }
  if audio_validate_pkg.valid_target_peak(target_peak) == false { give buf }
  let p: int = 0
  let i: int = 0
  while !(i >= buf.samples.len) {
    let a = abs_sample(buf.samples[i])
    if a > p { p = a }
    i = i + 1
  }

  if p <= 0 { give buf }

  let gain_percent = target_peak * 100 / p
  give gain(buf, gain_percent)
}


# -------------------------------------------------
# Analysis
# -------------------------------------------------

proc peak(buf: AudioBuffer) -> int {
  if valid_buffer(buf) == false { give 0 }
  let max: int = 0
  let i: int = 0

  while !(i >= buf.samples.len) {

    let a = abs_sample(buf.samples[i])
    if a > max { max = a }

    i = i + 1
  }

  give max
}

proc int_sqrt(v: int) -> int {
  if v <= 0 { give 0 }
  let x = v
  let y = (x + 1) / 2
  while !(y >= x) {
    x = y
    y = (x + (v / x)) / 2
  }
  give x
}

proc rms(buf: AudioBuffer) -> int {
  if valid_buffer(buf) == false { give 0 }
  if buf.samples.len == 0 { give 0 }

  let mean_sq: int = 0
  let i: int = 0

  while !(i >= buf.samples.len) {

    let s = buf.samples[i]
    let sq = s * s
    mean_sq = mean_sq + ((sq - mean_sq) / (i + 1))

    i = i + 1
  }

  give int_sqrt(mean_sq)
}

proc duration_ms(buf: AudioBuffer) -> int {
  if valid_buffer(buf) == false { give 0 }

  let frames = buf.samples.len / buf.channels
  give (frames * 1000 + (buf.sample_rate / 2)) / buf.sample_rate
}

proc stats(buf: AudioBuffer) -> AudioStats {
  give AudioStats(
    peak(buf),
    rms(buf),
    duration_ms(buf),
    buf.samples.len
  )
}


# -------------------------------------------------
# Channel utilities
# -------------------------------------------------

proc downmix_mono(buf: AudioBuffer) -> AudioBuffer {
  if valid_buffer(buf) == false { give buffer_new(buf.sample_rate, 1) }
  if buf.channels <= 1 { give buf }

  let out: [int] = []
  let i: int = 0

  while !(i >= buf.samples.len) {

    let acc: int = 0
    let c: int = 0

    while !(c >= buf.channels) {
      if i + c >= buf.samples.len { break }

      acc = acc + buf.samples[i + c]
      c = c + 1
    }

    if c > 0 {
      out = out.push(clamp_sample(acc / c))
    }

    i = i + buf.channels
  }

  give AudioBuffer(buf.sample_rate, 1, out)
}


# -------------------------------------------------
# Access helpers
# -------------------------------------------------

proc sample_at(buf: AudioBuffer, index: int) -> int {
  if index < 0 { give 0 }
  if index >= buf.samples.len { give 0 }

  give buf.samples[index]
}

proc trim_samples(buf: AudioBuffer, max_samples: int) -> AudioBuffer {
  if valid_buffer(buf) == false { give buf }
  let cap = max_samples
  if cap < 0 { cap = 0 }

  if cap == 0 { give AudioBuffer(buf.sample_rate, buf.channels, []) }
  if cap < buf.channels { cap = buf.channels }
  cap = cap - (cap % buf.channels)

  if buf.samples.len <= cap { give buf }

  let start = buf.samples.len - cap
  let out: [int] = []

  let i = start

  while !(i >= buf.samples.len) {

    out = out.push(buf.samples[i])
    i = i + 1
  }

  give AudioBuffer(buf.sample_rate, buf.channels, out)
}


# -------------------------------------------------
# Diagnostics
# -------------------------------------------------

proc summary(buf: AudioBuffer) -> string {
  give "sr=" + buf.sample_rate.to_string() +
       ",ch=" + buf.channels.to_string() +
       ",samples=" + buf.samples.len.to_string() +
       ",peak=" + peak(buf).to_string()
}

proc audio_health(buf: AudioBuffer) -> string {
  if valid_buffer(buf) == false { give "invalid-buffer" }
  if audio_validate_pkg.frame_aligned(buf.samples.len, buf.channels) == false { give "partial-frame" }

  if peak(buf) > 32000 {
    give "clipping-risk"
  }

  give "ok"
}

proc audio_diagnostics(buf: AudioBuffer) -> string {
  give summary(buf) +
       ",rms=" + rms(buf).to_string() +
       ",duration_ms=" + duration_ms(buf).to_string() +
       ",health=" + audio_health(buf) +
       ",runtime=" + audio_runtime_pkg.runtime_name()
}


# -------------------------------------------------
# Package API
# -------------------------------------------------

proc ready() -> bool {
  if audio_runtime_pkg.runtime_status() == false { give false }
  if audio_runtime_pkg.supports_mixing() == false { give false }
  let probe = buffer_new(audio_policy_pkg.default_sample_rate(), 2)
  if valid_buffer(probe) == false { give false }
  give true
}

proc package_meta() -> string {
  give "vitte/audio"
}


