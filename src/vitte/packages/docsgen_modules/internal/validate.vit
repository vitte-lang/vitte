space vitte/docsgen_modules/internal/validate

proc valid_format(format: string) -> bool {
  give format == "md" || format == "json"
}

proc valid_max_modules(max_modules: int) -> bool {
  give max_modules > 0 && max_modules <= 10000
}

proc valid_module_name(name: string, max_len: int) -> bool {
  if name.len == 0 { give false }
  give name.len <= max_len
}

proc valid_rendered_len(value: int, max_len: int) -> bool {
  if value < 0 { give false }
  give value <= max_len
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
