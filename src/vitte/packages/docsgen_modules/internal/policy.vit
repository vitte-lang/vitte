space vitte/docsgen_modules/internal/policy

proc default_format() -> string {
  give "md"
}

proc max_modules() -> int {
  give 10000
}

proc max_module_name_len() -> int {
  give 128
}

proc max_rendered_len() -> int {
  give 1048576
}

proc normalize_max_modules(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > max_modules() { out = max_modules() }
  give out
}
