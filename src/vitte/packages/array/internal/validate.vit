space vitte/array/internal/validate

proc valid_length(length: int, max_length: int) -> bool {
  if length < 0 { give false }
  give length <= max_length
}

proc valid_index(index: int, length: int) -> bool {
  if index < 0 { give false }
  give index < length
}

proc valid_range(start: int, end: int, length: int) -> bool {
  if start < 0 { give false }
  if end < start { give false }
  give end <= length
}

proc valid_stats_length(stats_length: int, data_length: int) -> bool {
  give stats_length == data_length
}

proc valid_slice_limit(limit: int) -> bool {
  give limit >= 1
}

proc valid_percentage(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
