<<<
runtime.vit
package vitte/http/internal/runtime
>>>
# Internal runtime helpers for vitte/http.

space vitte/http/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "http-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_diagnostics() -> bool {
  give true
}

proc runtime_capabilities() -> [string] {
  give [
    "token-parse",
    "path-normalize",
    "query-parse",
    "method-check",
    "host-private-detect",
    "crlf-detect",
    "status-validate",
    "content-length-check",
    "timeout-cancel-check",
    "timeout-config-validate",
    "body-limit-check",
    "profile-network-policy",
    "cors-policy",
    "route-match-rank",
    "diag-message",
    "diag-quickfix",
    "openapi-diff-missing"
  ]
}

proc starts_with(s: string, p: string) -> bool {
  if s.len < p.len { give false }
  give s.slice(0, p.len) == p
}

proc contains(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }
  let i: int = 0
  loop {
    if i + needle.len > text.len { break }
    if text.slice(i, i + needle.len) == needle { give true }
    i = i + 1
  }
  give false
}

proc is_space(ch: string) -> bool {
  give ch == " "
}

proc parse_method_token(line: string) -> string {
  let i: int = 0
  loop {
    if i >= line.len { break }
    if is_space(line.slice(i, i + 1)) { break }
    i = i + 1
  }
  if i <= 0 || i >= line.len { give "" }
  give line.slice(0, i)
}

proc parse_path_token(line: string) -> string {
  let i: int = 0
  loop {
    if i >= line.len { break }
    if is_space(line.slice(i, i + 1)) { break }
    i = i + 1
  }
  if i >= line.len - 1 { give "" }
  let rest: string = line.slice(i + 1, line.len)
  let j: int = 0
  loop {
    if j >= rest.len { break }
    if is_space(rest.slice(j, j + 1)) { break }
    j = j + 1
  }
  if j <= 0 { give "" }
  give rest.slice(0, j)
}

proc parse_version_token(line: string) -> string {
  let i: int = 0
  loop {
    if i >= line.len { break }
    if is_space(line.slice(i, i + 1)) { break }
    i = i + 1
  }
  if i >= line.len - 1 { give "" }
  let rest: string = line.slice(i + 1, line.len)
  let j: int = 0
  loop {
    if j >= rest.len { break }
    if is_space(rest.slice(j, j + 1)) { break }
    j = j + 1
  }
  if j >= rest.len - 1 { give "" }
  give rest.slice(j + 1, rest.len)
}

proc normalize_path(path: string) -> string {
  if path.len == 0 { give "/" }
  let p: string = path
  if p.slice(0, 1) != "/" { p = "/" + p }
  if p.len > 1 && p.slice(p.len - 1, p.len) == "/" {
    p = p.slice(0, p.len - 1)
  }
  if contains(p, "//") {
    let out: string = ""
    let i: int = 0
    let prev_slash: bool = false
    loop {
      if i >= p.len { break }
      let ch: string = p.slice(i, i + 1)
      if ch == "/" {
        if prev_slash == false {
          out = out + ch
        }
        prev_slash = true
      } else {
        out = out + ch
        prev_slash = false
      }
      i = i + 1
    }
    p = out
  }
  give p
}

proc method_known(method: string) -> bool {
  if method == "GET" { give true }
  if method == "POST" { give true }
  if method == "PUT" { give true }
  if method == "PATCH" { give true }
  if method == "DELETE" { give true }
  give false
}

proc is_private_host(host: string) -> bool {
  if host == "localhost" { give true }
  if starts_with(host, "127.") { give true }
  if starts_with(host, "10.") { give true }
  if starts_with(host, "192.168.") { give true }
  if starts_with(host, "172.16.") { give true }
  give false
}

proc host_from_url(url: string) -> string {
  let i: int = 0
  loop {
    if i >= url.len { break }
    if url.slice(i, i + 3) == "://" { break }
    i = i + 1
  }
  if i + 3 >= url.len { give "" }
  let rest: string = url.slice(i + 3, url.len)
  let j: int = 0
  loop {
    if j >= rest.len { break }
    let ch: string = rest.slice(j, j + 1)
    if ch == "/" || ch == ":" || ch == "?" { break }
    j = j + 1
  }
  if j <= 0 { give "" }
  give rest.slice(0, j)
}

proc is_private_host_from_url(url: string) -> bool {
  let host: string = host_from_url(url)
  give is_private_host(host)
}

proc parse_query(path_or_url: string) -> string {
  let i: int = 0
  loop {
    if i >= path_or_url.len { break }
    if path_or_url.slice(i, i + 1) == "?" { break }
    i = i + 1
  }
  if i >= path_or_url.len - 1 { give "" }
  give path_or_url.slice(i + 1, path_or_url.len)
}

proc has_crlf(text: string) -> bool {
  if contains(text, "\n") { give true }
  if contains(text, "\r") { give true }
  give false
}

proc status_is_valid(status: int) -> bool {
  give status >= 100 && status <= 599
}

proc content_length_matches(body: string, content_length: int) -> bool {
  give body.len == content_length
}

proc is_timeout_or_cancelled(cancel_token: string) -> bool {
  if cancel_token == "cancelled" { give true }
  if cancel_token == "timeout" { give true }
  give false
}

proc timeout_config_valid(read_ms: int, write_ms: int, idle_ms: int, header_ms: int, body_ms: int) -> bool {
  if read_ms <= 0 { give false }
  if write_ms <= 0 { give false }
  if idle_ms <= 0 { give false }
  if header_ms <= 0 { give false }
  if body_ms <= 0 { give false }
  give true
}

proc body_limit_exceeded(body_len: int, route_limit: int, global_limit: int) -> bool {
  if body_len > route_limit { give true }
  if body_len > global_limit { give true }
  give false
}

proc profile_allows_network(profile: string) -> bool {
  if profile == "core" { give false }
  give true
}

proc cors_origin_allowed(allow_origin: string, origin: string) -> bool {
  if allow_origin == "*" { give true }
  give allow_origin == origin
}

proc route_pattern_kind(pattern: string) -> int {
  if pattern == "*" { give 1 }
  if contains(pattern, ":") { give 2 }
  give 3
}

proc route_matches(pattern: string, path: string) -> bool {
  let p: string = normalize_path(pattern)
  let n: string = normalize_path(path)
  if p == "*" { give true }
  if p == n { give true }
  if contains(p, ":") {
    let i: int = 0
    loop {
      if i >= p.len { break }
      if p.slice(i, i + 1) == ":" { break }
      i = i + 1
    }
    if i <= 0 { give false }
    let prefix: string = p.slice(0, i)
    give starts_with(n, prefix)
  }
  give false
}

proc route_rank(priority: int, pattern: string) -> int {
  give priority * 10 + route_pattern_kind(pattern)
}

proc redact_sensitive(value: string) -> string {
  if value.len == 0 { give "" }
  give "***"
}

proc body_limit_code() -> string {
  give "VITTE-H0030"
}

proc timeout_code() -> string {
  give "VITTE-H0020"
}

proc reason_phrase(status: int) -> string {
  if status == 200 { give "OK" }
  if status == 201 { give "Created" }
  if status == 204 { give "No Content" }
  if status == 400 { give "Bad Request" }
  if status == 401 { give "Unauthorized" }
  if status == 403 { give "Forbidden" }
  if status == 404 { give "Not Found" }
  if status == 405 { give "Method Not Allowed" }
  if status == 408 { give "Request Timeout" }
  if status == 413 { give "Payload Too Large" }
  if status == 429 { give "Too Many Requests" }
  if status == 500 { give "Internal Server Error" }
  give "Unknown"
}

proc diag_message(code: string) -> string {
  if code == "VITTE-H0001" { give "invalid request line" }
  if code == "VITTE-H0002" { give "header injection (CRLF)" }
  if code == "VITTE-H0003" { give "content-length mismatch" }
  if code == "VITTE-H0004" { give "route conflict detected" }
  if code == "VITTE-H0005" { give "timeout or cancellation" }
  if code == "VITTE-H0006" { give "rate limit exceeded" }
  if code == "VITTE-H0007" { give "body too large" }
  if code == "VITTE-H0008" { give "cors/csrf policy reject" }
  if code == "VITTE-H0009" { give "security gate reject" }
  if code == "VITTE-H0010" { give "ssrf/private host rejected" }
  if code == "VITTE-H0011" { give "host/header injection rejected" }
  if code == "VITTE-H0012" { give "insecure protocol/tls policy reject" }
  if code == "VITTE-H0020" { give "read timeout reached" }
  if code == "VITTE-H0021" { give "write timeout reached" }
  if code == "VITTE-H0022" { give "request cancelled" }
  if code == "VITTE-H0030" { give "body limit exceeded" }
  if code == "VITTE-H0031" { give "content-length mismatch" }
  give "unknown diagnostic"
}

proc quickfix_for(code: string) -> string {
  if code == "VITTE-H0001" { give "normalize method/path and retry parse" }
  if code == "VITTE-H0002" { give "strip CRLF from headers" }
  if code == "VITTE-H0003" { give "recompute content-length" }
  if code == "VITTE-H0004" { give "adjust route priority/static first" }
  if code == "VITTE-H0005" { give "increase timeout or clear cancel token" }
  if code == "VITTE-H0006" { give "increase burst or wait refill" }
  if code == "VITTE-H0007" { give "increase route body limit" }
  if code == "VITTE-H0008" { give "adjust CORS/CSRF allowlist" }
  if code == "VITTE-H0009" { give "tighten host/header policy" }
  if code == "VITTE-H0010" { give "deny private CIDR or set explicit allowlist" }
  if code == "VITTE-H0011" { give "sanitize host/x-forwarded-* headers" }
  if code == "VITTE-H0012" { give "enforce secure protocol/tls settings" }
  if code == "VITTE-H0020" { give "increase read timeout budget" }
  if code == "VITTE-H0021" { give "increase write timeout budget" }
  if code == "VITTE-H0022" { give "refresh cancellation token and retry safely" }
  if code == "VITTE-H0030" { give "increase body limit for route/global config" }
  if code == "VITTE-H0031" { give "recompute content-length before send" }
  give "no quick-fix"
}

proc openapi_contract_diff_missing(old_snapshot: [string], new_snapshot: [string]) -> string {
  let i: int = 0
  loop {
    if i >= old_snapshot.len { break }
    let found: bool = false
    let j: int = 0
    loop {
      if j >= new_snapshot.len { break }
      if old_snapshot[i] == new_snapshot[j] { found = true }
      j = j + 1
    }
    if found == false {
      give old_snapshot[i]
    }
    i = i + 1
  }
  give ""
}
