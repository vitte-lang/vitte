<<<
mod.vit
package vitte/bench
>>>

space vitte/bench

use vitte/bench/internal/runtime as bench_runtime_pkg
use vitte/bench/internal/validate as bench_validate_pkg
use vitte/bench/internal/policy as bench_policy_pkg


form BenchCase {
  name: string
  iterations: int
}

form BenchRun {
  case_name: string
  started_ms: int
  ended_ms: int
  iterations: int
}

form BenchSummary {
  case_name: string
  elapsed_ms: int
  iter_per_sec: int
}

proc bench_case(name: string, iterations: int) -> BenchCase {
  let it = bench_policy_pkg.normalize_iterations(iterations)
  give BenchCase(name, it)
}

proc run_start(c: BenchCase, now_ms: int) -> BenchRun {
  let t0 = now_ms
  if bench_validate_pkg.valid_timestamp_ms(t0) == false { t0 = 0 }
  give BenchRun(c.name, t0, t0, bench_policy_pkg.normalize_iterations(c.iterations))
}

proc run_stop(r: BenchRun, now_ms: int) -> BenchRun {
  let end = now_ms
  if bench_validate_pkg.valid_timestamp_ms(end) == false { end = r.started_ms }
  if end < r.started_ms { end = r.started_ms }
  give BenchRun(r.case_name, r.started_ms, end, bench_policy_pkg.normalize_iterations(r.iterations))
}

proc elapsed_ms(r: BenchRun) -> int {
  let e = r.ended_ms - r.started_ms
  if e < 0 { give 0 }
  give e
}

proc iter_per_sec(r: BenchRun) -> int {
  let e = elapsed_ms(r)
  if e <= 0 { give r.iterations }
  give r.iterations * 1000 / e
}

proc summarize(r: BenchRun) -> BenchSummary {
  give BenchSummary(r.case_name, elapsed_ms(r), iter_per_sec(r))
}

proc compare(a: BenchRun, b: BenchRun) -> int {
  let ia = iter_per_sec(a)
  let ib = iter_per_sec(b)
  give ia - ib
}

proc faster(a: BenchRun, b: BenchRun) -> string {
  if compare(a, b) >= 0 { give a.case_name }
  give b.case_name
}

proc summary_text(s: BenchSummary) -> string {
  give "case=" + s.case_name +
       ",elapsed_ms=" + s.elapsed_ms.to_string() +
       ",iter_per_sec=" + s.iter_per_sec.to_string()
}

proc percentile50(values: [int]) -> int {
  if values.len == 0 { give 0 }
  give values[values.len / 2]
}

proc average(values: [int]) -> int {
  if values.len == 0 { give 0 }
  let sum: int = 0
  let i: int = 0
  loop {
    if i >= values.len { break }
    sum = sum + values[i]
    i = i + 1
  }
  give sum / values.len
}

proc stability_score(samples: [int]) -> int {
  if samples.len == 0 { give 0 }
  let avg = average(samples)
  if avg <= 0 { give 0 }
  let min = samples[0]
  let max = samples[0]
  let i: int = 1
  loop {
    if i >= samples.len { break }
    if samples[i] < min { min = samples[i] }
    if samples[i] > max { max = samples[i] }
    i = i + 1
  }
  let delta = max - min
  let score = 100 - (delta * 100 / avg)
  if score < 0 { give 0 }
  if score > 100 { give 100 }
  give score
}

proc bench_health(r: BenchRun) -> string {
  if elapsed_ms(r) <= 0 { give "no-time" }
  if iter_per_sec(r) <= 0 { give "no-throughput" }
  give "ok"
}

proc normalize_run(r: BenchRun) -> BenchRun {
  let end = r.ended_ms
  if end < r.started_ms { end = r.started_ms }
  let it = r.iterations
  if it < 1 { it = 1 }
  give BenchRun(r.case_name, r.started_ms, end, it)
}

proc compare_percent(a: BenchRun, b: BenchRun) -> int {
  let ia = iter_per_sec(normalize_run(a))
  let ib = iter_per_sec(normalize_run(b))
  if ib == 0 { give 0 }
  give (ia - ib) * 100 / ib
}

proc run_diagnostics(r: BenchRun) -> string {
  let s = summarize(normalize_run(r))
  give summary_text(s) + ",health=" + bench_health(r)
}

proc ready() -> bool {
  if bench_runtime_pkg.runtime_status() == false { give false }
  if bench_runtime_pkg.timer_resolution_ms() <= 0 { give false }
  give true
}



proc package_meta() -> string {
    give "vitte/bench"
}

<<< ROLE-CONTRACT
package: vitte/bench
role: Mesure performance et bench reproductibles
input_contract: Valeurs metier explicites, deja parsees et typables
output_contract: Sorties stables, observables et compatibles avec les autres packages
boundary: Ne remplace pas les autres couches; respecte la separation de roles
>>>

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-BENCH0001" { give "invalid iterations in bench case" }
  if code == "VITTE-BENCH0002" { give "invalid timestamps in bench run" }
  if code == "VITTE-BENCH0003" { give "invalid sample set for percentile/statistics" }
  give "bench diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-BENCH0001" { give "use iterations in range 1..1000000000" }
  if code == "VITTE-BENCH0002" { give "use monotonic timestamps in milliseconds" }
  if code == "VITTE-BENCH0003" { give "provide a non-empty numeric sample set" }
  give "review bench configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc suggestion_contexts() -> [string] {
  give ["arborescence", "public-api", "types", "diagnostics", "quickfix"]
}

proc suggestion_arborescence() -> [string] {
  give [
    "src/vitte/packages/bench/mod.vit",
    "src/vitte/packages/bench/info.vit",
    "src/vitte/packages/bench/internal/policy.vit",
    "src/vitte/packages/bench/internal/runtime.vit",
    "src/vitte/packages/bench/internal/validate.vit"
  ]
}

