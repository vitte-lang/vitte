proc suggestion_catalog_json() -> string {
  give "{\"package\":\"vitte/bench\",\"contexts\":[\"arborescence\",\"public-api\",\"types\",\"diagnostics\",\"quickfix\"],\"counts\":{\"arborescence\":5,\"public_api\":28,\"types\":3,\"diagnostics\":3,\"quickfix\":3}}"
