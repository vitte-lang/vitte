    "elapsed_ms",
    "iter_per_sec",
    "summarize",
    "compare",
    "faster",
    "summary_text",
    "percentile50",
    "average",
    "stability_score",
    "bench_health",
    "normalize_run",
    "compare_percent",
    "run_diagnostics",
    "ready",
