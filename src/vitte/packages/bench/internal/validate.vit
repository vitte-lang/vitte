space vitte/bench/internal/validate

proc valid_iterations(iterations: int) -> bool {
  give iterations >= 1 && iterations <= 1000000000
}

proc valid_timestamp_ms(ts: int) -> bool {
  give ts >= 0
}

proc valid_samples(values: [int]) -> bool {
  give values.len > 0
}

proc validate_code(iterations: int, started_ms: int, ended_ms: int) -> string {
  if valid_iterations(iterations) == false { give "VITTE-BENCH0001" }
  if valid_timestamp_ms(started_ms) == false || valid_timestamp_ms(ended_ms) == false { give "VITTE-BENCH0002" }
  give ""
}

