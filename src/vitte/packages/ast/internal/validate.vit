space vitte/ast/internal/validate

proc valid_module_name(name: string) -> bool {
  give name.len > 0
}

proc valid_node_id(id: int) -> bool {
  give id >= 0
}

proc valid_span(start: int, end: int) -> bool {
  if start < 0 { give false }
  give end >= start
}

proc valid_budget(visits: int, depth_guard: int) -> bool {
  if visits < 1 { give false }
  give depth_guard >= 1
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_node_count(count: int, max_nodes: int) -> bool {
  if count < 0 { give false }
  give count <= max_nodes
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
