space vitte/fixtures/internal/policy

proc min_seed_runs() -> int {
  give 1
}

proc max_seed_runs() -> int {
  give 1000
}

proc default_seed_runs() -> int {
  give 1
}

proc default_allow_empty_rows() -> bool {
  give true
}

proc normalize_seed_runs(value: int) -> int {
  let out = value
  if out < min_seed_runs() { out = min_seed_runs() }
  if out > max_seed_runs() { out = max_seed_runs() }
  give out
}
