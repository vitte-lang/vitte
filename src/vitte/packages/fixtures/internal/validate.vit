space vitte/fixtures/internal/validate

proc valid_seed_runs(value: int, max_runs: int) -> bool {
  if value <= 0 { give false }
  if max_runs <= 0 { give false }
  give value <= max_runs
}

proc valid_fixture_name(name: string) -> bool {
  give name.len > 0
}

proc valid_row(row: string, allow_empty_rows: bool) -> bool {
  if row.len == 0 { give allow_empty_rows }
  give true
}
