space vitte/feature_flags/internal/validate

proc valid_rollout(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}

proc valid_flag_name(name: string) -> bool {
  give name.len > 0
}

proc valid_override_user(user_id: string, allow_override: bool) -> bool {
  if allow_override == false { give false }
  give user_id.len > 0
}
