space vitte/feature_flags/internal/policy

proc min_rollout() -> int {
  give 0
}

proc max_rollout() -> int {
  give 100
}

proc max_flags() -> int {
  give 10000
}

proc default_allow_override() -> bool {
  give true
}

proc default_unknown_fallback() -> bool {
  give false
}

proc normalize_rollout(value: int) -> int {
  let out = value
  if out < min_rollout() { out = min_rollout() }
  if out > max_rollout() { out = max_rollout() }
  give out
}
