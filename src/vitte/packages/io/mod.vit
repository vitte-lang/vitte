<<<
mod.vit
package vitte/io
>>>

space vitte/io

use vitte/io/internal/policy as io_policy_pkg
use vitte/io/internal/runtime as io_runtime_pkg
use vitte/io/internal/validate as io_validate_pkg


form Buffer {
  lines: [string]
}

proc buffer_new() -> Buffer {
  give Buffer([])
}

proc print_line(text: string) {
  emit text
}

proc print_text(text: string) {
  emit text
}

proc write_line(buf: Buffer, line: string) -> Buffer {
  give Buffer(buf.lines.push(line))
}

proc append_text(buf: Buffer, text: string) -> Buffer {
  let out = buf
  let current = ""
  let i: int = 0
  while true {
    if i >= text.len {
      out = write_line(out, current)
      break
    }
    let ch = text.slice(i, i + 1)
    if ch == "\n" {
      out = write_line(out, current)
      current = ""
    } else {
      current = current + ch
    }
    i += 1
  }
  give out
}

proc clear(buf: Buffer) -> Buffer {
  let _ = buf
  give Buffer([])
}

proc line_count(buf: Buffer) -> int {
  give buf.lines.len
}

proc is_empty(buf: Buffer) -> bool {
  give buf.lines.len == 0
}

proc read_line(buf: Buffer, index: int) -> string {
  if index < 0 || index >= buf.lines.len { give "" }
  give buf.lines[index]
}

proc first_line(buf: Buffer) -> string {
  if buf.lines.len == 0 { give "" }
  give buf.lines[0]
}

proc last_line(buf: Buffer) -> string {
  if buf.lines.len == 0 { give "" }
  give buf.lines[buf.lines.len - 1]
}

proc pop_line(buf: Buffer) -> Buffer {
  if buf.lines.len == 0 { give buf }
  let out: [string] = []
  let i: int = 0
  while i < buf.lines.len - 1 {
    out = out.push(buf.lines[i])
    i += 1
  }
  give Buffer(out)
}

proc replace_line(buf: Buffer, index: int, line: string) -> Buffer {
  if index < 0 || index >= buf.lines.len { give buf }
  let out: [string] = []
  let i: int = 0
  while i < buf.lines.len {
    if i == index { out = out.push(line) } else { out = out.push(buf.lines[i]) }
    i += 1
  }
  give Buffer(out)
}

proc remove_line(buf: Buffer, index: int) -> Buffer {
  if index < 0 || index >= buf.lines.len { give buf }
  let out: [string] = []
  let i: int = 0
  while i < buf.lines.len {
    if i != index { out = out.push(buf.lines[i]) }
    i += 1
  }
  give Buffer(out)
}

proc insert_line(buf: Buffer, index: int, line: string) -> Buffer {
  let idx = index
  if idx < 0 { idx = 0 }
  if idx > buf.lines.len { idx = buf.lines.len }
  let out: [string] = []
  let i: int = 0
  while true {
    if i >= buf.lines.len {
      if i == idx { out = out.push(line) }
      break
    }
    if i == idx { out = out.push(line) }
    out = out.push(buf.lines[i])
    i += 1
  }
  if buf.lines.len == 0 && idx == 0 { out = out.push(line) }
  give Buffer(out)
}

proc to_text(buf: Buffer) -> string {
  let out = ""
  let i: int = 0
  while i < buf.lines.len {
    if i > 0 { out = out + "\n" }
    out = out + buf.lines[i]
    i += 1
  }
  give out
}

proc join_path(a: string, b: string) -> string {
  if a == "" { give b }
  if b == "" { give a }
  if a.slice(a.len - 1, a.len) == "/" { give a + b }
  give a + "/" + b
}

proc dirname(p: string) -> string {
  let i: int = p.len - 1
  while i >= 0 {
    if p.slice(i, i + 1) == "/" { give p.slice(0, i) }
    i = i - 1
  }
  give ""
}

proc basename(p: string) -> string {
  let i: int = p.len - 1
  while i >= 0 {
    if p.slice(i, i + 1) == "/" { give p.slice(i + 1, p.len) }
    i = i - 1
  }
  give p
}

proc extname(p: string) -> string {
  let b = basename(p)
  let i: int = b.len - 1
  while i >= 0 {
    if b.slice(i, i + 1) == "." { give b.slice(i + 1, b.len) }
    i = i - 1
  }
  give ""
}

proc has_ext(p: string, ext: string) -> bool {
  give extname(p) == ext
}

proc normalize_path(p: string) -> string {
  let out = ""
  let prev_slash = false
  let i: int = 0
  while i < p.len {
    let ch = p.slice(i, i + 1)
    if ch == "/" {
      if !prev_slash { out = out + ch }
      prev_slash = true
    } else {
      out = out + ch
      prev_slash = false
    }
    i += 1
  }
  if out.len == 0 { give "/" }
  give out
}

proc split_lines(text: string) -> [string] {
  let out: [string] = []
  let current = ""
  let i: int = 0
  while true {
    if i >= text.len {
      out = out.push(current)
      break
    }
    let ch = text.slice(i, i + 1)
    if ch == "\n" {
      out = out.push(current)
      current = ""
    } else {
      current = current + ch
    }
    i += 1
  }
  give out
}

proc api_version() -> string {
  give version()
}

proc diagnostics_namespace() -> string {
  give "VITTE-IO"
}

proc validate_config_code(cfg: IoConfig) -> string {
  let vr = validate_config(cfg)
  when vr is IoResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/io,config=(IoConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(IoResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = diagnostics_namespace() + "0000"
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == diagnostics_namespace() + "0000" { give ["no action required"] }
  if code == diagnostics_namespace() + "0001" { give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"] }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: IoConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is IoResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while i < caps.len {
    out = out + "," + caps[i]
    i += 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give io_runtime_pkg.runtime_status()
}

proc package_meta() -> string {
  give "vitte/io"
}

form IoConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick IoError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick IoResult[T] {
  Ok(value: T)
  Err(error: IoError)
}

proc default_config() -> IoConfig {
  give IoConfig(io_policy_pkg.default_strict(), io_policy_pkg.default_timeout_ms(), io_policy_pkg.default_retry_budget())
}

proc strict_config() -> IoConfig {
  let cfg = default_config()
  give IoConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc with_timeout_ms(cfg: IoConfig, timeout_ms: int) -> IoConfig {
  give IoConfig(cfg.strict, io_policy_pkg.normalize_timeout_ms(timeout_ms), cfg.retry_budget)
}

proc with_retry_budget(cfg: IoConfig, retry_budget: int) -> IoConfig {
  give IoConfig(cfg.strict, cfg.timeout_ms, io_policy_pkg.normalize_retry_budget(retry_budget))
}

proc normalize_config(cfg: IoConfig) -> IoConfig {
  give IoConfig(cfg.strict,
                io_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                io_policy_pkg.normalize_retry_budget(cfg.retry_budget))
}

proc validate_config(cfg: IoConfig) -> IoResult[bool] {
  let nc = normalize_config(cfg)
  if io_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give IoResult.Err(IoError.InvalidConfig)
  }
  if io_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give IoResult.Err(IoError.InvalidConfig)
  }
  give IoResult.Ok(true)
}

proc healthcheck(cfg: IoConfig) -> IoResult[bool] {
  let vr: IoResult[bool] = validate_config(cfg)
  when vr is IoResult.Err {
    give IoResult.Err(vr.error)
  }
  if io_runtime_pkg.runtime_status() == false {
    give IoResult.Err(IoError.Internal)
  }
  give IoResult.Ok(true)
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["buffer", "config", "diagnostics", "healthcheck", "path", "validate"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-IO0001" {
    give "invalid package configuration"
  }
  give "io diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

form IoRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
  supports_buffer: bool
}

proc runtime_info() -> IoRuntimeInfo {
  give IoRuntimeInfo(io_runtime_pkg.runtime_name(),
                     io_runtime_pkg.runtime_version(),
                     io_runtime_pkg.supports_diagnostics(),
                     io_runtime_pkg.supports_buffer())
}

