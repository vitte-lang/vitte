space vitte/graph/internal/validate

proc valid_nodes(nodes: int, max_nodes: int) -> bool {
  if nodes <= 0 { give false }
  if max_nodes <= 0 { give false }
  give nodes <= max_nodes
}

proc valid_node_index(node: int, nodes: int) -> bool {
  if node < 0 { give false }
  give node < nodes
}

proc valid_weight(weight: int, min_weight: int, max_weight: int) -> bool {
  if min_weight > max_weight { give false }
  if weight < min_weight { give false }
  give weight <= max_weight
}
