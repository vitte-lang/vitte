<<<
mod.vit
package vitte/graph
version: 3.1.0
tier: algo-core
purpose:
  Structures de graphes et operations deterministes.
  Validation explicite des noeuds, aretes et poids.
  API stable versionnee avec diagnostics et healthcheck.
>>>

space vitte/graph

use vitte/graph/internal/policy as graph_policy_pkg
use vitte/graph/internal/runtime as graph_runtime_pkg
use vitte/graph/internal/validate as graph_validate_pkg

form GraphConfig {
  max_nodes: int
  allow_self_loop: bool
}

pick GraphError {
  InvalidConfig
  NotFound
  Internal
}

pick GraphResult[T] {
  Ok(value: T)
  Err(error: GraphError)
}

form GraphRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_directed: bool
  supports_diagnostics: bool
}

form GraphHealth {
  ok: bool
  code: string
  nodes: int
  edges: int
}

form Edge {
  src: int
  dst: int
  weight: int
}

form Graph {
  nodes: int
  directed: bool
  edges: [Edge]
  edge_count: int
}

proc default_config() -> GraphConfig {
  give GraphConfig(graph_policy_pkg.max_nodes(), graph_policy_pkg.default_allow_self_loop())
}

proc strict_config() -> GraphConfig {
  let cfg = default_config()
  give GraphConfig(cfg.max_nodes, false)
}

proc with_max_nodes(cfg: GraphConfig, max_nodes: int) -> GraphConfig {
  give GraphConfig(graph_policy_pkg.normalize_nodes(max_nodes), cfg.allow_self_loop)
}

proc with_allow_self_loop(cfg: GraphConfig, allow_self_loop: bool) -> GraphConfig {
  give GraphConfig(cfg.max_nodes, allow_self_loop)
}

proc normalize_config(cfg: GraphConfig) -> GraphConfig {
  give GraphConfig(graph_policy_pkg.normalize_nodes(cfg.max_nodes), cfg.allow_self_loop)
}

proc validate_config(cfg: GraphConfig) -> GraphResult[bool] {
  let nc = normalize_config(cfg)
  if graph_validate_pkg.valid_nodes(nc.max_nodes, graph_policy_pkg.max_nodes()) == false {
    give GraphResult.Err(GraphError.InvalidConfig)
  }
  give GraphResult.Ok(true)
}

proc runtime_info() -> GraphRuntimeInfo {
  give GraphRuntimeInfo(graph_runtime_pkg.runtime_name(),
                        graph_runtime_pkg.runtime_version(),
                        graph_runtime_pkg.supports_directed(),
                        graph_runtime_pkg.supports_diagnostics())
}

proc healthcheck(cfg: GraphConfig, g: Graph) -> GraphResult[GraphHealth] {
  let vr = validate_config(cfg)
  when vr is GraphResult.Err { give GraphResult.Err(vr.error) }
  if graph_runtime_pkg.runtime_status() == false {
    give GraphResult.Err(GraphError.Internal)
  }
  give GraphResult.Ok(GraphHealth(true, "ok", g.nodes, g.edge_count))
}

proc healthcheck(cfg: GraphConfig) -> GraphResult[bool] {
  let hr = healthcheck(cfg, graph_new(1, false))
  when hr is GraphResult.Err { give GraphResult.Err(hr.error) }
  give GraphResult.Ok(hr.value.ok)
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give [
    "config",
    "density",
    "diagnostics",
    "directed",
    "healthcheck",
    "reverse",
    "weighted-edges"
  ]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-GRAPH0001" { give "invalid graph configuration" }
  if code == "VITTE-GRAPH0002" { give "invalid node or edge" }
  if code == "VITTE-GRAPH0003" { give "graph runtime unavailable" }
  give "graph diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-GRAPH0001" { give "use max_nodes in valid range" }
  if code == "VITTE-GRAPH0002" { give "use node indexes within graph bounds" }
  if code == "VITTE-GRAPH0003" { give "check graph runtime status" }
  give "review graph configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc graph_new(nodes: int, directed: bool) -> Graph {
  give Graph(nodes, directed, [], 0)
}

proc graph_new_checked(nodes: int, directed: bool, cfg: GraphConfig) -> GraphResult[Graph] {
  let vr = validate_config(cfg)
  when vr is GraphResult.Err { give GraphResult.Err(vr.error) }
  if graph_validate_pkg.valid_nodes(nodes, cfg.max_nodes) == false {
    give GraphResult.Err(GraphError.InvalidConfig)
  }
  give GraphResult.Ok(graph_new(nodes, directed))
}

proc edge(src: int, dst: int, weight: int) -> Edge {
  give Edge(src, dst, weight)
}

proc is_valid_node(g: Graph, node: int) -> bool {
  give graph_validate_pkg.valid_node_index(node, g.nodes)
}

proc add_edge(g: Graph, src: int, dst: int, weight: int) -> Graph {
  if !is_valid_node(g, src) || !is_valid_node(g, dst) {
    give g
  }
  let out_edges = g.edges.push(edge(src, dst, weight))
  give Graph(g.nodes, g.directed, out_edges, g.edge_count + 1)
}

proc add_edge_checked(g: Graph, src: int, dst: int, weight: int, cfg: GraphConfig) -> GraphResult[Graph] {
  if is_valid_node(g, src) == false || is_valid_node(g, dst) == false {
    give GraphResult.Err(GraphError.InvalidConfig)
  }
  if cfg.allow_self_loop == false && src == dst {
    give GraphResult.Err(GraphError.InvalidConfig)
  }
  if graph_validate_pkg.valid_weight(weight, graph_policy_pkg.min_weight(), graph_policy_pkg.max_weight()) == false {
    give GraphResult.Err(GraphError.InvalidConfig)
  }
  give GraphResult.Ok(add_edge(g, src, dst, graph_policy_pkg.normalize_weight(weight)))
}

proc has_edge(g: Graph, src: int, dst: int) -> bool {
  let i: int = 0
  while !(i >= g.edges.len) {
    let e = g.edges[i]
    if e.src == src && e.dst == dst { give true }
    if !g.directed && e.src == dst && e.dst == src { give true }
    i = i + 1
  }
  give false
}

proc degree_out(g: Graph, src: int) -> int {
  let d: int = 0
  let i: int = 0
  while !(i >= g.edges.len) {
    let e = g.edges[i]
    if e.src == src {
      d = d + 1
    }
    if !g.directed && e.dst == src {
      d = d + 1
    }
    i = i + 1
  }
  give d
}

proc edge_weight_or(g: Graph, src: int, dst: int, fallback: int) -> int {
  let i: int = 0
  while !(i >= g.edges.len) {
    let e = g.edges[i]
    if e.src == src && e.dst == dst { give e.weight }
    if !g.directed && e.src == dst && e.dst == src { give e.weight }
    i = i + 1
  }
  give fallback
}

proc reverse(g: Graph) -> Graph {
  let out = graph_new(g.nodes, g.directed)
  let i: int = 0
  while !(i >= g.edges.len) {
    let e = g.edges[i]
    out = add_edge(out, e.dst, e.src, e.weight)
    i = i + 1
  }
  give out
}

proc density_percent(g: Graph) -> int {
  if g.nodes <= 1 { give 0 }
  let max_edges = g.nodes * (g.nodes - 1)
  if !g.directed {
    give (g.edge_count * 200) / max_edges
  }
  give (g.edge_count * 100) / max_edges
}

proc api_version() -> string {
  give version()
}

proc diagnostics_namespace() -> string {
  give "VITTE-GRAPH"
}

proc validate_config_code(cfg: GraphConfig) -> string {
  let vr = validate_config(cfg)
  when vr is GraphResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/graph,config=(GraphConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(GraphResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = diagnostics_namespace() + "0000"
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == diagnostics_namespace() + "0000" { give ["no action required"] }
  if code == diagnostics_namespace() + "0001" { give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"] }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: GraphConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is GraphResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while !(i >= caps.len) {
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give graph_runtime_pkg.runtime_status()
}

proc package_meta() -> string {
  give "vitte/graph"
}

<<< ROLE-CONTRACT
package: vitte/graph
role: Structures graphes et algorithmes de parcours
input_contract: Valeurs metier explicites, deja parsees et typables
output_contract: Sorties stables, observables et compatibles avec les autres packages
boundary: Ne remplace pas les autres couches; respecte la separation de roles
>>>
