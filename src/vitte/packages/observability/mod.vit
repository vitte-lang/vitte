<<<
mod.vit
package vitte/observability
>>>

space vitte/observability

use vitte/observability/internal/policy as observability_policy_pkg
use vitte/observability/internal/runtime as observability_runtime_pkg
use vitte/observability/internal/validate as observability_validate_pkg


pick TraceState {
  Open
  Closed
}

form TraceSpan {
  id: string
  name: string
  trace_id: string
  start_ms: int
  end_ms: int
  state: TraceState
}

form Counter {
  name: string
  value: int
  trace_id: string
}

form Histogram {
  name: string
  count: int
  sum: int
  min: int
  max: int
  trace_id: string
}

proc counter_new(name: string) -> Counter {
  give Counter(name, 0, "")
}

proc histogram_new(name: string) -> Histogram {
  give Histogram(name, 0, 0, 0, 0, "")
}

proc trace_start(name: string, now_ms: int) -> TraceSpan {
  let trace_id = "tr-" + now_ms.to_string()
  give TraceSpan(trace_id, name, trace_id, now_ms, -1, TraceState.Open)
}

proc trace_start_with_id(name: string, trace_id: string, now_ms: int) -> TraceSpan {
  let tid = trace_id
  if tid.len == 0 {
    tid = "tr-" + now_ms.to_string()
  }
  give TraceSpan(tid, name, tid, now_ms, -1, TraceState.Open)
}

proc with_trace_id(span: TraceSpan, trace_id: string) -> TraceSpan {
  give TraceSpan(span.id, span.name, trace_id, span.start_ms, span.end_ms, span.state)
}

proc trace_end(span: TraceSpan, now_ms: int) -> TraceSpan {
  let end_ms = now_ms
  if end_ms < span.start_ms {
    end_ms = span.start_ms
  }
  give TraceSpan(span.id, span.name, span.trace_id, span.start_ms, end_ms, TraceState.Closed)
}

proc trace_duration(span: TraceSpan) -> int {
  if span.end_ms < span.start_ms { give 0 }
  give span.end_ms - span.start_ms
}

proc trace_is_open(span: TraceSpan) -> bool {
  give span.state == TraceState.Open
}

proc trace_is_closed(span: TraceSpan) -> bool {
  give span.state == TraceState.Closed
}

proc trace_name(span: TraceSpan) -> string {
  give span.name
}

proc trace_reopen(span: TraceSpan, now_ms: int) -> TraceSpan {
  let start = span.start_ms
  if now_ms > start { start = now_ms }
  give TraceSpan(span.id, span.name, span.trace_id, start, -1, TraceState.Open)
}

proc trace_summary(span: TraceSpan) -> string {
  let state_name = "open"
  if trace_is_closed(span) { state_name = "closed" }
  give "trace=" + span.trace_id +
       ",name=" + span.name +
       ",state=" + state_name +
       ",duration=" + trace_duration(span).to_string()
}

proc counter_inc(counter: Counter, delta: int) -> Counter {
  if delta <= 0 { give counter }
  give Counter(counter.name, counter.value + delta, counter.trace_id)
}

proc counter_with_trace(counter: Counter, trace_id: string) -> Counter {
  give Counter(counter.name, counter.value, trace_id)
}

proc counter_value(counter: Counter) -> int {
  give counter.value
}

proc counter_reset(counter: Counter) -> Counter {
  give Counter(counter.name, 0, counter.trace_id)
}

proc counter_is_zero(counter: Counter) -> bool {
  give counter.value == 0
}

proc counter_merge(left: Counter, right: Counter) -> Counter {
  let trace = left.trace_id
  if trace.len == 0 { trace = right.trace_id }
  give Counter(left.name, left.value + right.value, trace)
}

proc histogram_observe(hist: Histogram, value: int) -> Histogram {
  if hist.count == 0 {
    give Histogram(hist.name, 1, value, value, value, hist.trace_id)
  }

  let min_v = hist.min
  let max_v = hist.max
  if value < min_v { min_v = value }
  if value > max_v { max_v = value }
  give Histogram(hist.name, hist.count + 1, hist.sum + value, min_v, max_v, hist.trace_id)
}

proc histogram_avg(hist: Histogram) -> int {
  if hist.count <= 0 { give 0 }
  give hist.sum / hist.count
}

proc histogram_with_trace(hist: Histogram, trace_id: string) -> Histogram {
  give Histogram(hist.name, hist.count, hist.sum, hist.min, hist.max, trace_id)
}

proc histogram_min(hist: Histogram) -> int {
  give hist.min
}

proc histogram_max(hist: Histogram) -> int {
  give hist.max
}

proc histogram_range(hist: Histogram) -> int {
  if hist.count <= 0 { give 0 }
  give hist.max - hist.min
}

proc histogram_empty(hist: Histogram) -> bool {
  give hist.count == 0
}

proc histogram_merge(left: Histogram, right: Histogram) -> Histogram {
  if left.count == 0 { give right }
  if right.count == 0 { give left }

  let min_v = left.min
  if right.min < min_v { min_v = right.min }

  let max_v = left.max
  if right.max > max_v { max_v = right.max }

  let trace = left.trace_id
  if trace.len == 0 { trace = right.trace_id }

  give Histogram(left.name, left.count + right.count, left.sum + right.sum, min_v, max_v, trace)
}

proc metrics_summary(counter: Counter, hist: Histogram) -> string {
  give "counter=" + counter.name +
       ",value=" + counter.value.to_string() +
       ",hist_count=" + hist.count.to_string() +
       ",hist_avg=" + histogram_avg(hist).to_string()
}

form PackageConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick PackageConfigError {
  InvalidConfig
  Internal
}

pick PackageConfigResult {
  Ok(ok: bool)
  Err(error: PackageConfigError)
}

form PackageRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> PackageConfig {
  give PackageConfig(true,
                     observability_policy_pkg.default_timeout_ms(),
                     observability_policy_pkg.default_retry_budget())
}

proc strict_config() -> PackageConfig {
  let cfg = default_config()
  give PackageConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: PackageConfig) -> PackageConfig {
  give PackageConfig(cfg.strict,
                     observability_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                     cfg.retry_budget)
}

proc validate_config(cfg: PackageConfig) -> PackageConfigResult {
  let nc = normalize_config(cfg)
  if observability_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  if observability_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  give PackageConfigResult.Ok(true)
}

proc healthcheck(cfg: PackageConfig) -> PackageConfigResult {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give PackageConfigResult.Err(vr.error) }
  if observability_runtime_pkg.runtime_status() == false {
    give PackageConfigResult.Err(PackageConfigError.Internal)
  }
  give PackageConfigResult.Ok(true)
}

proc runtime_info() -> PackageRuntimeInfo {
  give PackageRuntimeInfo(observability_runtime_pkg.runtime_name(),
                          observability_runtime_pkg.runtime_version(),
                          observability_runtime_pkg.supports_diagnostics())
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck", "api-contract", "abi-contract", "diagnostics", "contract-summary"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-OBSERVABILITY0001" { give "invalid package configuration" }
  give "observability diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review timeout/retry configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}
proc version() -> string {
  give api_version()
}

proc doctor_status() -> string {
  give "vitte/observability doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: PackageConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give false }
  give true
}

proc healthcheck_default() -> PackageConfigResult {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}
proc validate_config_code(cfg: PackageConfig) -> string {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give "VITTE-OBSERVABILITY0001" }
  give "VITTE-OBSERVABILITY0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-OBSERVABILITY"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/observability,config=(strict,timeout_ms,retry_budget),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(PackageConfigResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-OBSERVABILITY0000" { give ["no action required"] }
  if code == "VITTE-OBSERVABILITY0001" {
    give ["apply normalize_config", "ensure timeout_ms is valid", "ensure retry_budget is valid"]
  }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() +
       " code=" + code +
       " sev=" + diagnostics_severity(code) +
       " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: PackageConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is PackageConfigResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  loop {
    if i >= caps.len { break }
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() +
       " fp=" + package_contract_fingerprint().to_string() +
       " hc=" + healthcheck_default_code() +
       " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give true
}



proc package_meta() -> string {
    give "vitte/observability"
}

