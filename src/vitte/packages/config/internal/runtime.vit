space vitte/config/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "config-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_merge() -> bool {
  give true
}

proc supports_validation() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
