space vitte/config/internal/validate

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_limit(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_key(key: string, max_len: int) -> bool {
  if key.len == 0 { give false }
  give key.len <= max_len
}

proc valid_value(value: string, max_len: int, allow_empty: bool) -> bool {
  if allow_empty == false && value.len == 0 { give false }
  give value.len <= max_len
}

proc valid_entry_count(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
