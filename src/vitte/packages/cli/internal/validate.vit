space vitte/cli/internal/validate

proc has_space(value: string) -> bool {
  let i: int = 0
  loop {
    if i >= value.len { break }
    if value.slice(i, i + 1) == " " { give true }
    i = i + 1
  }
  give false
}

proc valid_name(value: string, max_len: int) -> bool {
  if value.len == 0 { give false }
  if value.len > max_len { give false }
  give true
}

proc valid_description(value: string, max_len: int) -> bool {
  give value.len <= max_len
}

proc valid_arg_count(value: int, max_count: int) -> bool {
  if value < 0 { give false }
  give value <= max_count
}

proc valid_arg(value: string, max_len: int) -> bool {
  give value.len <= max_len
}

proc valid_flag_name(value: string) -> bool {
  if value.len < 2 { give false }
  if value.slice(0, 1) != "-" { give false }
  give true
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
