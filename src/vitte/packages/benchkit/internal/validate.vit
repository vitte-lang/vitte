space vitte/benchkit/internal/validate

proc valid_name(name: string) -> bool {
  if name.len == 0 { give false }
  give name.len <= 256
}

proc valid_iterations(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_warmup(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_trim_percent(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_sorted_non_empty(len: int) -> bool {
  give len > 0
}

proc valid_sample_count(len: int) -> bool {
  give len >= 0
}
