space vitte/lsp/internal/policy

proc default_max_documents() -> int {
  give 1000
}

proc default_max_diagnostics() -> int {
  give 20000
}

proc default_allow_empty_doc() -> bool {
  give true
}

proc normalize_max_documents(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 100000 { out = 100000 }
  give out
}

proc normalize_max_diagnostics(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 500000 { out = 500000 }
  give out
}
