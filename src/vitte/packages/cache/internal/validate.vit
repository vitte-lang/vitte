space vitte/cache/internal/validate

proc has_space(value: string) -> bool {
  let i: int = 0
  loop {
    if i >= value.len { break }
    if value.slice(i, i + 1) == " " { give true }
    i = i + 1
  }
  give false
}

proc valid_capacity(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_ttl(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_key(key: string, max_len: int) -> bool {
  if key.len == 0 { give false }
  if key.len > max_len { give false }
  if has_space(key) { give false }
  give true
}

proc valid_value(value: string, max_len: int) -> bool {
  give value.len <= max_len
}

proc valid_clock_delta(delta: int) -> bool {
  give delta > 0
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
