space vitte/cache/internal/policy

proc min_capacity() -> int {
  give 0
}

proc max_capacity() -> int {
  give 1000000
}

proc default_capacity() -> int {
  give 1024
}

proc min_ttl() -> int {
  give 0
}

proc max_ttl() -> int {
  give 31536000
}

proc default_ttl() -> int {
  give 300
}

proc max_key_len() -> int {
  give 256
}

proc max_value_len() -> int {
  give 65536
}

proc warn_fill_percent() -> int {
  give 85
}

proc normalize_capacity(value: int) -> int {
  let out = value
  if out < min_capacity() { out = min_capacity() }
  if out > max_capacity() { out = max_capacity() }
  give out
}

proc normalize_ttl(value: int) -> int {
  let out = value
  if out < min_ttl() { out = min_ttl() }
  if out > max_ttl() { out = max_ttl() }
  give out
}

proc normalize_key_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_key_len() { out = max_key_len() }
  give out
}

proc normalize_value_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_value_len() { out = max_value_len() }
  give out
}
