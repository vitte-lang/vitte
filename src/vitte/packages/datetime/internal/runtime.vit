space vitte/datetime/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "datetime-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_timezone_offset() -> bool {
  give true
}

proc supports_duration_math() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
