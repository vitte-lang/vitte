space vitte/datetime/internal/policy

proc min_epoch_ms() -> int {
  give 0
}

proc max_epoch_ms() -> int {
  give 4102444800000
}

proc min_tz_offset_min() -> int {
  give -840
}

proc max_tz_offset_min() -> int {
  give 840
}

proc max_duration_ms() -> int {
  give 315360000000
}

proc normalize_epoch_ms(value: int) -> int {
  let out = value
  if out < min_epoch_ms() { out = min_epoch_ms() }
  if out > max_epoch_ms() { out = max_epoch_ms() }
  give out
}

proc normalize_tz_offset_min(value: int) -> int {
  let out = value
  if out < min_tz_offset_min() { out = min_tz_offset_min() }
  if out > max_tz_offset_min() { out = max_tz_offset_min() }
  give out
}

proc normalize_duration_ms(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_duration_ms() { out = max_duration_ms() }
  give out
}
