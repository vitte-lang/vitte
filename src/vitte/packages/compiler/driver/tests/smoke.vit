space compiler/driver/tests/smoke

use src/vitte/compiler/bootstrap as bootstrap

form DriverCommand {
  name: string,
  stage: string,
  parity_status: string
}

proc package_name() -> string {
  give "compiler/driver"
}

proc package_role() -> string {
  give "self-hosted-driver-facade"
}

proc migration_stage() -> string {
  give bootstrap.bootstrap_stage()
}

proc bootstrap_status() -> string {
  give "self-hosted-bootstrap"
}

proc api_version() -> string {
  give "0"
}

proc command_parse() -> DriverCommand {
  give DriverCommand("parse", "parse", "planned")
}

proc command_check() -> DriverCommand {
  give DriverCommand("check", "ir", "planned")
}

proc command_emit() -> DriverCommand {
  give DriverCommand("emit", "backend", "planned")
}

proc command_build() -> DriverCommand {
  give DriverCommand("build", "backend", "planned")
}

proc command_reduce() -> DriverCommand {
  give DriverCommand("reduce", "backend", "planned")
}

proc command_doctor() -> DriverCommand {
  give DriverCommand("doctor", "host-check", "planned")
}

proc command_count() -> int {
  give 6
}

proc top_level_command_count() -> int {
  give 12
}

proc grammar_subcommand_count() -> int {
  give 2
}

proc mod_subcommand_count() -> int {
  give 5
}

proc known_flag_count() -> int {
  give 80
}

proc syntax_profile_count() -> int {
  give 1
}

proc catalog_version() -> string {
  give "driver-surface-v1"
}

proc source_of_truth() -> string {
  give "src/vitte/compiler/driver"
}

proc normalization_scope() -> string {
  give "command aliases, help aliases, command stages, selected flag aliases, --flag=value support, positional capture, default values, profile aliases, non-negative integer normalization, and normalized options state"
}

proc ready() -> bool {
  give false
}

proc smoke_test() -> bool {
  if command_count() != 6 { give false }
  if top_level_command_count() != 12 { give false }
  if grammar_subcommand_count() != 2 { give false }
  if mod_subcommand_count() != 5 { give false }
  if known_flag_count() != 80 { give false }
  if syntax_profile_count() != 1 { give false }
  if bootstrap_status() != "self-hosted-bootstrap" { give false }
  if migration_stage() != bootstrap.bootstrap_stage() { give false }
  if api_version() != "0" { give false }
  if catalog_version() != "driver-surface-v1" { give false }
  if source_of_truth() != "src/vitte/compiler/driver" { give false }
  if normalization_scope() == "" { give false }
  if ready() { give false }
  give true
}

proc smoke_input() -> string {
  give
    "space demo/app\n" +
    "proc main(argc: i32) -> i32 {\n" +
    "  let value: i32 = ping(argc)\n" +
    "  set value = ping(argc)\n" +
    "  give value\n" +
    "}\n"
}

proc smoke_case_1() -> bool {
  if package_name() != "compiler/driver" { give false }
  if package_role() != "self-hosted-driver-facade" { give false }
  if migration_stage() != bootstrap.bootstrap_stage() { give false }
  if bootstrap_status() != "self-hosted-bootstrap" { give false }
  if api_version() != "0" { give false }
  if not smoke_test() { give false }
  give true
}

proc smoke_case_2() -> bool {
  if command_parse().name != "parse" { give false }
  if command_check().stage != "ir" { give false }
  if command_emit().parity_status != "planned" { give false }
  if command_build().name != "build" { give false }
  if command_reduce().stage != "backend" { give false }
  if command_doctor().parity_status != "planned" { give false }
  if command_parse().name != "parse" { give false }
  if command_count() != 6 { give false }
  if top_level_command_count() != 12 { give false }
  if grammar_subcommand_count() != 2 { give false }
  if mod_subcommand_count() != 5 { give false }
  if known_flag_count() != 80 { give false }
  if syntax_profile_count() != 1 { give false }
  give true
}

proc smoke_case_3() -> bool {
  let expected: string =
    "space demo/app\n" +
    "proc main(argc: i32) -> i32 {\n" +
    "  let value: i32 = ping(argc)\n" +
    "  set value = ping(argc)\n" +
    "  give value\n" +
    "}\n"
  if smoke_input() != expected { give false }
  give true
}
