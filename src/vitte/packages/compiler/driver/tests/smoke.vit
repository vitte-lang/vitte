space compiler/driver/tests/smoke

use src/vitte/compiler/bootstrap as bootstrap
use src/vitte/packages/compiler/driver/mod as driver
use src/vitte/packages/compiler/driver/internal/command_catalog as command_catalog
use src/vitte/packages/compiler/driver/internal/option_catalog as option_catalog

proc smoke_case_1() -> bool {
  if driver.bootstrap_status() != bootstrap.bootstrap_stage() { give false }
  if driver.migration_stage() != bootstrap.bootstrap_stage() { give false }
  if driver.catalog_version() != command_catalog.catalog_version() { give false }
  if driver.source_of_truth() != "src/vitte/compiler/driver" { give false }
  if driver.package_meta() == "" { give false }
  if driver.ready() { give false }
  if not driver.smoke_test() { give false }
  give true
}

proc smoke_case_2() -> bool {
  if driver.command_parse().name != "parse" { give false }
  if driver.command_check().stage != "ir" { give false }
  if driver.command_build().name != "build" { give false }
  if driver.command_count() != command_catalog.command_count() as int { give false }
  if driver.top_level_command_count() != option_catalog.top_level_command_count() { give false }
  if driver.grammar_subcommand_count() != option_catalog.grammar_subcommand_count() { give false }
  if driver.mod_subcommand_count() != option_catalog.mod_subcommand_count() { give false }
  if driver.known_flag_count() != option_catalog.all_flag_count() { give false }
  if driver.syntax_profile_count() != option_catalog.syntax_profile_count() { give false }
  give true
}

proc smoke_case_3() -> bool {
  if not command_catalog.command_exists("build") { give false }
  if not command_catalog.command_exists("check") { give false }
  if command_catalog.command_count() <= 10 { give false }
  if option_catalog.catalog_size() < option_catalog.all_flag_count() { give false }
  if driver.normalization_scope() == "" { give false }
  give true
}
