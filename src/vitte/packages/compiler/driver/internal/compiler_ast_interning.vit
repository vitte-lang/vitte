space compiler/driver/private/compiler_ast_interning

use compiler_ast
use compiler_parser
use src/vitte/packages/compiler/ast/arena/interning/mod as interning

form CompilerAstInterningReport {
  pool: interning.AstInternPool,
  interned_names: int,
  duplicate_hits: int,
  valid: bool
}

proc _intern_name(pool: interning.AstInternPool, name: string) -> interning.AstInternResult {
  if name == "" {
    give interning.AstInternResult {
      pool: pool,
      handle: interning.ast_intern_handle_new(0, 0),
      reused: false
    }
  }

  give interning.ast_intern_identifier(pool, name)
}

proc intern_module_names(module0: compiler_ast.Module) -> CompilerAstInterningReport {
  let pool: interning.AstInternPool = interning.ast_intern_pool_new("compiler-ast")
  let interned_names: int = 0
  let duplicate_hits: int = 0

  let space_result: interning.AstInternResult = _intern_name(pool, module0.space_name)
  let current_pool: interning.AstInternPool = space_result.pool
  if module0.space_name != "" {
    set interned_names = interned_names + 1
  }
  if space_result.reused {
    set duplicate_hits = duplicate_hits + 1
  }

  let i: int = 0
  while i < module0.decls.len {
    let decl0: compiler_ast.Decl = module0.decls[i]
    let decl_result: interning.AstInternResult = _intern_name(current_pool, decl0.name)
    set current_pool = decl_result.pool
    if decl0.name != "" {
      set interned_names = interned_names + 1
    }
    if decl_result.reused {
      set duplicate_hits = duplicate_hits + 1
    }

    if decl0.proc_decl.name != "" {
      let proc_result: interning.AstInternResult = _intern_name(current_pool, decl0.proc_decl.name)
      set current_pool = proc_result.pool
      set interned_names = interned_names + 1
      if proc_result.reused {
        set duplicate_hits = duplicate_hits + 1
      }
    }

    set i = i + 1
  }

  give CompilerAstInterningReport {
    pool: current_pool,
    interned_names: interned_names,
    duplicate_hits: duplicate_hits,
    valid: interning.ast_intern_validate(current_pool)
  }
}

proc parse_and_intern_source(source_name: string, source_text: string) -> CompilerAstInterningReport {
  let parsed: compiler_parser.ParsedModule = compiler_parser.parse_source(source_name, source_text)
  give intern_module_names(parsed.module_value)
}

proc compiler_ast_interning_smoke() -> bool {
  let report: CompilerAstInterningReport = parse_and_intern_source(
    "fixture",
    "space demo\nproc main() -> int {\n  give 0\n}\n"
  )

  if not report.valid {
    give false
  }

  if report.interned_names != 3 {
    give false
  }

  if report.duplicate_hits != 1 {
    give false
  }

  if interning.ast_intern_count(report.pool) != 2 {
    give false
  }

  give true
}
