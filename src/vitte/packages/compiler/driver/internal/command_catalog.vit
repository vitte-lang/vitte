<<< ========================================================= >>>
<<< Catalog helpers                                           >>>
<<< ========================================================= >>>

proc command_catalog() -> [DriverCommand] {

  give [
    command_build(),
    command_run(),
    command_check(),
    command_test(),
    command_bench(),

    command_lex(),
    command_parse(),
    command_expand(),

    command_ast(),
    command_hir(),
    command_mir(),
    command_ir(),

    command_typecheck(),
    command_borrowcheck(),

    command_format(),
    command_lint(),
    command_lsp(),
    command_repl(),

    command_clean(),
    command_doc(),

    command_bootstrap(),

    command_version(),
    command_help()
  ];
}

proc command_count() -> u64 {
  give len(command_catalog());
}

proc command_exists(
  name: string
) -> bool {

  let commands: [DriverCommand] =
    command_catalog();

  let i: u64 = 0;

  while i < len(commands) {

    let command: DriverCommand =
      commands[i];

    if command.name == name {
      give true;
    }

    let j: u64 = 0;

    while j < len(command.aliases) {

      if command.aliases[j] == name {
        give true;
      }

      set j =
        j + 1;
    }

    set i =
      i + 1;
  }

  give false;
}

proc command_lookup(
  name: string
) -> DriverCommand {

  let commands: [DriverCommand] =
    command_catalog();

  let i: u64 = 0;

  while i < len(commands) {

    let command: DriverCommand =
      commands[i];

    if command.name == name {
      give command;
    }

    let j: u64 = 0;

    while j < len(command.aliases) {

      if command.aliases[j] == name {
        give command;
      }

      set j =
        j + 1;
    }

    set i =
      i + 1;
  }

  give driver_command(
    DriverCommandKind.Unknown,
    "",
    [],
    "",
    "",
    false,
    false,
    true,
    false,
    false
  );
}

proc command_summary(
  command: DriverCommand
) -> string {

  give command.name
    + " category="
    + command.category
    + " stable="
    + (command.stable as string)
    + " target="
    + (command.supports_target as string)
    + " input="
    + (command.requires_input as string);
}

proc catalog_summary() -> string {

  give "entry="
    + canonical_entrypoint()
    + " version="
    + catalog_version()
    + " commands="
    + (command_count() as string)
    + " source="
    + source_of_truth();
}

proc catalog_selftest() -> bool {

  let build: DriverCommand =
    command_lookup("build");

  let version: DriverCommand =
    command_lookup("--version");

  give build.valid
    and version.valid
    and command_exists("check")
    and command_exists("borrowck")
    and command_count() > 10
    and catalog_summary() != "";
}