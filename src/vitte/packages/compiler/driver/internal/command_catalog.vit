space compiler/driver/private/command_catalog

use src/vitte/compiler/bootstrap as bootstrap

export *

<<< ========================================================= >>>
<<< Driver command catalog                                    >>>
<<< Canonical compiler command surface                        >>>
<<< ========================================================= >>>

pick DriverCommandKind {
  Unknown,

  Build,
  Run,
  Check,
  Test,
  Bench,

  Clean,
  Format,
  Lint,

  Ast,
  Hir,
  Mir,
  Ir,

  EmitAst,
  EmitHir,
  EmitMir,
  EmitIr,

  Parse,
  Lex,
  Expand,

  Typecheck,
  Borrowcheck,

  Doc,
  Lsp,

  Repl,

  Package,
  Install,
  Uninstall,
  Update,

  Bootstrap,

  Version,
  Help,
}

form DriverCommand {
  kind: DriverCommandKind

  name: string
  aliases: [string]

  category: string

  description: string

  stable: bool
  experimental: bool

  hidden: bool

  requires_input: bool
  supports_target: bool

  valid: bool
}

proc driver_command(
  kind: DriverCommandKind,
  name: string,
  aliases: [string],
  category: string,
  description: string,
  stable: bool,
  experimental: bool,
  hidden: bool,
  requires_input: bool,
  supports_target: bool
) -> DriverCommand {

  give DriverCommand {
    kind: kind,

    name: name,
    aliases: aliases,

    category: category,

    description: description,

    stable: stable,
    experimental: experimental,

    hidden: hidden,

    requires_input: requires_input,
    supports_target: supports_target,

    valid:
      kind != DriverCommandKind.Unknown
      and name != ""
  };
}

proc catalog_version() -> string {
  give "driver-surface-v2";
}

proc canonical_entrypoint() -> string {
  give "vitte";
}

proc source_of_truth() -> string {
  give bootstrap.source_of_truth(
    "src/vitte/compiler/driver"
  );
}

