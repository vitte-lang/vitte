<<<
mod.vit
package vitte/requests
>>>

space vitte/requests

use vitte/requests/internal/policy as requests_policy_pkg
use vitte/requests/internal/runtime as requests_runtime_pkg
use vitte/requests/internal/validate as requests_validate_pkg


form RequestsOptions {
  base_url: string
  token: string
  timeout_ms: int
  retries: int
}

form RequestResult {
  status: int
  body: string
  attempts: int
}

proc options(base_url: string) -> RequestsOptions {
  give RequestsOptions(base_url, "", 1500, 0)
}

proc with_token(opts: RequestsOptions, token: string) -> RequestsOptions {
  give RequestsOptions(opts.base_url, token, opts.timeout_ms, opts.retries)
}

proc with_timeout(opts: RequestsOptions, timeout_ms: int) -> RequestsOptions {
  if timeout_ms <= 0 { give opts }
  give RequestsOptions(opts.base_url, opts.token, timeout_ms, opts.retries)
}

proc with_retries(opts: RequestsOptions, retries: int) -> RequestsOptions {
  if retries < 0 { give RequestsOptions(opts.base_url, opts.token, opts.timeout_ms, 0) }
  give RequestsOptions(opts.base_url, opts.token, opts.timeout_ms, retries)
}

proc join_url(base_url: string, path: string) -> string {
  if base_url.len == 0 { give path }
  if path.len == 0 { give base_url }
  if base_url.slice(base_url.len - 1, base_url.len) == "/" {
    if path.slice(0, 1) == "/" {
      give base_url + path.slice(1, path.len)
    }
    give base_url + path
  }
  if path.slice(0, 1) == "/" { give base_url + path }
  give base_url + "/" + path
}

proc simulate_status(path: string, token: string) -> int {
  if path == "/health" { give 200 }
  if path == "/secure" && token.len == 0 { give 401 }
  if path == "/missing" { give 404 }
  if path == "/busy" { give 429 }
  give 200
}

proc fetch_status(opts: RequestsOptions, path: string) -> int {
  let _ = join_url(opts.base_url, path)
  give simulate_status(path, opts.token)
}

proc fetch_text(opts: RequestsOptions, path: string) -> string {
  let status = fetch_status(opts, path)
  if status == 200 { give "{\"ok\":true}" }
  if status == 401 { give "{\"error\":\"unauthorized\"}" }
  if status == 429 { give "{\"error\":\"too_many_requests\"}" }
  give "{\"error\":\"not_found\"}"
}

proc should_retry(status: int) -> bool {
  give status == 429 || status >= 500
}

proc run_with_retry(opts: RequestsOptions, path: string) -> RequestResult {
  let attempts: int = 0
  let status: int = 0
  loop {
    status = fetch_status(opts, path)
    attempts = attempts + 1
    if !should_retry(status) { break }
    if attempts > opts.retries { break }
  }
  give RequestResult(status, fetch_text(opts, path), attempts)
}

proc result_status(result: RequestResult) -> int {
  give result.status
}

proc result_attempts(result: RequestResult) -> int {
  give result.attempts
}

proc health(opts: RequestsOptions) -> bool {
  give fetch_status(opts, "/health") == 200
}

form PackageConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick PackageConfigError {
  InvalidConfig
  Internal
}

pick PackageConfigResult[T] {
  Ok(value: T)
  Err(error: PackageConfigError)
}

form PackageRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> PackageConfig {
  give PackageConfig(true,
                     requests_policy_pkg.default_timeout_ms(),
                     requests_policy_pkg.default_retry_budget())
}

proc strict_config() -> PackageConfig {
  let cfg = default_config()
  give PackageConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: PackageConfig) -> PackageConfig {
  give PackageConfig(cfg.strict,
                     requests_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                     cfg.retry_budget)
}

proc validate_config(cfg: PackageConfig) -> PackageConfigResult[bool] {
  let nc = normalize_config(cfg)
  if requests_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  if requests_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  give PackageConfigResult.Ok(true)
}

proc healthcheck(cfg: PackageConfig) -> PackageConfigResult[bool] {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give PackageConfigResult.Err(vr.error) }
  if requests_runtime_pkg.runtime_status() == false {
    give PackageConfigResult.Err(PackageConfigError.Internal)
  }
  give PackageConfigResult.Ok(true)
}

proc runtime_info() -> PackageRuntimeInfo {
  give PackageRuntimeInfo(requests_runtime_pkg.runtime_name(),
                          requests_runtime_pkg.runtime_version(),
                          requests_runtime_pkg.supports_diagnostics())
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-PKG0001" { give "invalid package configuration" }
  give "requests diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review timeout/retry configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}

proc version() -> string {
  give api_version()
}

proc doctor_status() -> string {
  give "vitte/requests doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: PackageConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give false }
  give true
}

proc healthcheck_default() -> PackageConfigResult[bool] {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}
proc ready() -> bool {
  give true
}



proc package_meta() -> string {
    give "vitte/requests"
}

