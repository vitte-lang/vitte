<<<
assert.vit
package vitte/test/internal/assert
>>>

space vitte/test/internal/assert

pick TestError {
  Failure(code: string, message: string, context: string, retryable: bool, doc_url: string)
}

pick TestResult[T] {
  Ok(value: T)
  Err(error: TestError)
}

form TestCase {
  name: string
  passed: bool
  message: string
  duration_ms: int
  retries: int
  attempts: int
  flaky: bool
  timed_out: bool
  last_failure_code: string
  tags: [string]
}

proc ok[T](value: T) -> TestResult[T] {
  give TestResult.Ok(value)
}

proc err[T](code: string, message: string, context: string, retryable: bool) -> TestResult[T] {
  give TestResult.Err(TestError.Failure(code, message, context, retryable, "docs/diagnostics/test.md#" + code))
}

proc contains(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }
  let i: int = 0
  loop {
    if i + needle.len > text.len { break }
    if text.slice(i, i + needle.len) == needle { give true }
    i = i + 1
  }
  give false
}

proc mk_case(name: string, passed: bool, message: string, code: string) -> TestCase {
  let tags: [string] = []
  give TestCase(name, passed, message, 0, 0, 1, false, false, code, tags)
}

proc assert_true(name: string, condition: bool, message: string) -> TestResult[TestCase] {
  if condition {
    give ok[TestCase](mk_case(name, true, "ok", ""))
  }
  give err[TestCase]("VITTE-T0001", message, name, false)
}

proc assert_eq(name: string, left: string, right: string) -> TestResult[TestCase] {
  if left == right {
    give ok[TestCase](mk_case(name, true, "ok", ""))
  }
  give err[TestCase]("VITTE-T0002", "assert_eq failed", name, false)
}

proc assert_ne(name: string, left: string, right: string) -> TestResult[TestCase] {
  if left != right {
    give ok[TestCase](mk_case(name, true, "ok", ""))
  }
  give err[TestCase]("VITTE-T0003", "assert_ne failed", name, false)
}

proc assert_match(name: string, text: string, needle: string) -> TestResult[TestCase] {
  if contains(text, needle) {
    give ok[TestCase](mk_case(name, true, "ok", ""))
  }
  give err[TestCase]("VITTE-T0004", "assert_match failed", name, false)
}
