<<<
mod.vit
package vitte/test
>>>
# PREAMBLE (API stable facade)
# - Public facade for vitte/test; additive API only.
# - No import-time side effects.
# - Internal implementation in vitte/test/internal/*.
# - Diagnostics namespace: VITTE-T0001..VITTE-T0099.
# PUBLIC INVARIANTS
# - timeout_ms > 0
# - suite_timeout_ms >= timeout_ms
# - retry_budget >= 0
# - profile in {core, desktop, system}
# EXAMPLES
# - use vitte/test as test_pkg
# - let c = test_pkg.case_new("name", true, "ok", 1, 0, 1, false, false, "", [])
# - let s = test_pkg.suite_add_case(test_pkg.suite("s", test_pkg.TestMode.Fast, "desktop", 1000, 1), c)

space vitte/test

use vitte/test/internal/assert as test_assert_pkg
use vitte/test/internal/runner as test_runner_pkg
use vitte/test/internal/fixtures as test_fixtures_pkg
use vitte/test/internal/snapshot as test_snapshot_pkg
use vitte/test/internal/fuzz_bridge as test_fuzz_pkg
use vitte/test/internal/bench_bridge as test_bench_pkg

pick TestMode {
  Fast
  Strict
  Ci
}

pick TestError {
  Failure(code: string, message: string, context: string, retryable: bool, doc_url: string)
}

pick TestResult[T] {
  Ok(value: T)
  Err(error: TestError)
}

form TestCase {
  name: string
  passed: bool
  message: string
  duration_ms: int
  retries: int
  attempts: int
  flaky: bool
  timed_out: bool
  last_failure_code: string
  tags: [string]
}

form TestSuite {
  name: string
  mode: TestMode
  profile: string
  timeout_ms: int
  max_retries: int
  cases: [TestCase]
}

form TestContext {
  workspace: string
  profile: string
  mode: TestMode
  timeout_ms: int
  suite_timeout_ms: int
  retry_budget: int
}

form SnapshotConfig {
  update: bool
  canonical: bool
  stable_order: bool
  hash_algo: string
  strict_whitespace: bool
  normalize_newlines: bool
}

form FuzzConfig {
  seeds_dir: string
  budget_secs: int
  max_cases: int
}

form BenchConfig {
  iterations: int
  warmup: int
  profile: string
}

form TestReport {
  schema_version: string
  suite_name: string
  total: int
  passed: int
  failed: int
  flaky: int
  timed_out: int
  duration_ms: int
  mode: TestMode
  profile: string
  flaky_budget_exceeded: bool
}

proc ok[T](value: T) -> TestResult[T] {
  give TestResult.Ok(value)
}

proc err[T](code: string, message: string, context: string, retryable: bool, doc_url: string) -> TestResult[T] {
  give TestResult.Err(TestError.Failure(code, message, context, retryable, doc_url))
}

proc diagnostics_message(code: string) -> string {
  give test_runner_pkg.diag_message(code)
}

proc diagnostics_quickfix(code: string) -> string {
  give test_runner_pkg.quickfix_for(code)
}

proc diagnostics_doc_url(code: string) -> string {
  give test_runner_pkg.doc_url_for(code)
}

proc api_version() -> string {
  give "v1"
}

proc doctor_status() -> string {
  give "vitte/test doctor:ready api=" + api_version()
}

proc default_context() -> TestContext {
  give test_runner_pkg.default_context()
}

proc context_with_mode(ctx: TestContext, mode: TestMode) -> TestContext {
  give test_runner_pkg.context_with_mode(ctx, mode)
}

proc context_with_profile(ctx: TestContext, profile: string) -> TestContext {
  give test_runner_pkg.context_with_profile(ctx, profile)
}

proc context_with_timeout(ctx: TestContext, timeout_ms: int, suite_timeout_ms: int) -> TestContext {
  give test_runner_pkg.context_with_timeout(ctx, timeout_ms, suite_timeout_ms)
}

proc validate_context(ctx: TestContext) -> TestResult[bool] {
  give test_runner_pkg.validate_context(ctx)
}

proc default_snapshot_config() -> SnapshotConfig {
  give test_snapshot_pkg.default_snapshot_config()
}

proc default_fuzz_config() -> FuzzConfig {
  give FuzzConfig("tests/test/fuzz_seeds", 0, 1000)
}

proc default_bench_config() -> BenchConfig {
  give BenchConfig(10, 1, "desktop")
}

proc assert_true(name: string, condition: bool, message: string) -> TestResult[TestCase] {
  give test_assert_pkg.assert_true(name, condition, message)
}

proc assert_eq(name: string, left: string, right: string) -> TestResult[TestCase] {
  give test_assert_pkg.assert_eq(name, left, right)
}

proc assert_ne(name: string, left: string, right: string) -> TestResult[TestCase] {
  give test_assert_pkg.assert_ne(name, left, right)
}

proc assert_match(name: string, text: string, needle: string) -> TestResult[TestCase] {
  give test_assert_pkg.assert_match(name, text, needle)
}

proc suite(name: string, mode: TestMode, profile: string, timeout_ms: int, max_retries: int) -> TestSuite {
  give test_runner_pkg.suite(name, mode, profile, timeout_ms, max_retries)
}

proc case_new(name: string, passed: bool, message: string, duration_ms: int, retries: int, attempts: int, flaky: bool, timed_out: bool, last_failure_code: string, tags: [string]) -> TestCase {
  give test_runner_pkg.case_new(name, passed, message, duration_ms, retries, attempts, flaky, timed_out, last_failure_code, tags)
}

proc suite_add_case(s: TestSuite, c: TestCase) -> TestSuite {
  give test_runner_pkg.suite_add_case(s, c)
}

proc run_suite(ctx: TestContext, s: TestSuite) -> TestResult[TestReport] {
  give test_runner_pkg.run_suite(ctx, s)
}

proc run_all(ctx: TestContext, suites: [TestSuite]) -> TestResult[[TestReport]] {
  give test_runner_pkg.run_all(ctx, suites)
}

proc run_selected(ctx: TestContext, s: TestSuite, names: [string]) -> TestResult[TestReport] {
  give test_runner_pkg.run_selected(ctx, s, names)
}

proc run_tagged(ctx: TestContext, s: TestSuite, tags: [string]) -> TestResult[TestReport] {
  give test_runner_pkg.run_tagged(ctx, s, tags)
}

proc merge_reports(reports: [TestReport]) -> TestReport {
  give test_runner_pkg.merge_reports(reports)
}

proc is_profile_supported(profile: string) -> bool {
  give test_runner_pkg.is_profile_supported(profile)
}

proc profile_matrix_check(s: TestSuite) -> TestResult[bool] {
  give test_runner_pkg.profile_matrix_check(s)
}

proc load_fixture(path: string) -> TestResult[string] {
  give test_fixtures_pkg.load_fixture(path)
}

proc snapshot_expect(name: string, got: string, expected: string, cfg: SnapshotConfig) -> TestResult[bool] {
  give test_snapshot_pkg.snapshot_expect(name, got, expected, cfg)
}

proc snapshot_update(name: string, got: string, cfg: SnapshotConfig) -> TestResult[string] {
  give test_snapshot_pkg.snapshot_update(name, got, cfg)
}

proc snapshot_diff(got: string, expected: string) -> string {
  give test_snapshot_pkg.snapshot_diff(got, expected)
}

proc run_fuzz(cfg: FuzzConfig) -> TestResult[string] {
  give test_fuzz_pkg.run_fuzz(cfg)
}

proc run_bench(cfg: BenchConfig) -> TestResult[string] {
  give test_bench_pkg.run_bench(cfg)
}

proc report_json(report: TestReport) -> string {
  give test_runner_pkg.report_json(report)
}

proc report_md(report: TestReport) -> string {
  give test_runner_pkg.report_md(report)
}

proc report_compact(report: TestReport) -> string {
  give test_runner_pkg.report_compact(report)
}

proc quickfix_preview(payload: string) -> string {
  give test_runner_pkg.quickfix_preview(payload)
}

proc quickfix_apply(payload: string) -> string {
  give test_runner_pkg.quickfix_apply(payload)
}

proc ready() -> bool {
  give true
}

proc package_meta() -> string {
  give "vitte/test"
}

<<< ROLE-CONTRACT
package: vitte/test
owner: @vitte/qa
stability: stable
since: 3.0.0
deprecated_in: -
role: facade publique tests stable et additive
input_contract: suites/cases/context explicites profile-aware
output_contract: TestResult/TestReport stables avec diagnostics VITTE-T****
boundary: assertions/runner/fixtures/snapshots/fuzz/bench dans vitte/test/internal/*
versioning: additive-only, no breaking removals in stable
api_surface_stable: true
diagnostics: VITTE-T0001..VITTE-T0099
compat_policy: additive-only
internal_exports: forbidden
api_version: v1
compat_layer: none
removal_policy: major-only
>>>
