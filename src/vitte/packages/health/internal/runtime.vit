space vitte/health/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "health-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_diagnostics() -> bool {
  give true
}

proc supports_json_report() -> bool {
  give true
}
