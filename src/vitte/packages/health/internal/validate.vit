space vitte/health/internal/validate

proc valid_component_name(name: string) -> bool {
  if name == "db" { give true }
  if name == "cache" { give true }
  if name == "queue" { give true }
  if name == "migrations" { give true }
  if name == "warmed" { give true }
  if name == "started" { give true }
  give false
}

proc valid_score_percent(score: int) -> bool {
  if score < 0 { give false }
  give score <= 100
}

proc valid_status_text(status: string) -> bool {
  if status == "down" { give true }
  if status == "ok" { give true }
  if status == "starting" { give true }
  if status == "degraded" { give true }
  give false
}
