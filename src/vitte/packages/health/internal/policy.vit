space vitte/health/internal/policy

proc default_require_migrations() -> bool {
  give true
}

proc default_require_warmed() -> bool {
  give true
}

proc min_score_ok_percent() -> int {
  give 80
}

proc normalize_score_percent(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > 100 { out = 100 }
  give out
}
