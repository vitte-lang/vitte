space vitte/hash/internal/validate

proc valid_text(text: string) -> bool {
  give text.len >= 0
}

proc valid_buckets(buckets: int, max_buckets: int) -> bool {
  if buckets <= 0 { give false }
  if max_buckets <= 0 { give false }
  give buckets <= max_buckets
}

proc valid_hash_value(value: int) -> bool {
  give value >= 0
}
