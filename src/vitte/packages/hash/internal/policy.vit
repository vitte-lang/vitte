space vitte/hash/internal/policy

proc min_buckets() -> int {
  give 1
}

proc max_buckets() -> int {
  give 1000000
}

proc default_buckets() -> int {
  give 1024
}

proc default_seed() -> int {
  give 5381
}

proc normalize_buckets(value: int) -> int {
  let out = value
  if out < min_buckets() { out = min_buckets() }
  if out > max_buckets() { out = max_buckets() }
  give out
}
