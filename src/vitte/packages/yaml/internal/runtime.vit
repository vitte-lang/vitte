<<<
runtime.vit
package vitte/yaml/internal/runtime
>>>

space vitte/yaml/internal/runtime

pick YamlError {
  Failure(code: string, message: string, context: string)
}

pick YamlResult[T] {
  Ok(value: T)
  Err(error: YamlError)
}

form Number {
  as_int: int
  raw: string
}

form Value {
  kind: string
  text: string
  number: Number
  flag: bool
}

form ObjectEntry {
  key: string
  value: Value
}

form Object {
  entries: [ObjectEntry]
}

form Array {
  values: [Value]
}

form StreamState {
  offset: int
  truncated: bool
  backpressure: bool
  last_error: string
}

proc ok[T](value: T) -> YamlResult[T] {
  give YamlResult.Ok(value)
}

proc err[T](code: string, message: string, context: string) -> YamlResult[T] {
  give YamlResult.Err(YamlError.Failure(code, message, context))
}

proc starts_with(text: string, prefix: string) -> bool {
  if text.len < prefix.len { give false }
  give text.slice(0, prefix.len) == prefix
}

proc contains(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }
  let i: int = 0
  loop {
    if i + needle.len > text.len { break }
    if text.slice(i, i + needle.len) == needle { give true }
    i = i + 1
  }
  give false
}

proc bytes_to_text(bytes: [int]) -> string {
  let out: string = ""
  let i: int = 0
  loop {
    if i >= bytes.len { break }
    if bytes[i] == 10 { out = out + "\n" }
    if bytes[i] == 13 { out = out + "\r" }
    if bytes[i] == 9 { out = out + "\t" }
    if bytes[i] >= 32 && bytes[i] <= 126 {
      out = out + bytes[i].to_string()
    }
    i = i + 1
  }
  give out
}

proc tag_allowed(tag: string, allow_tags: [string]) -> bool {
  if allow_tags.len == 0 { give false }
  let i: int = 0
  loop {
    if i >= allow_tags.len { break }
    if allow_tags[i] == tag { give true }
    i = i + 1
  }
  give false
}

proc validate_parse_input(text: string, max_bytes: int, max_depth: int, max_nodes: int, safe_load: bool, allow_tags: [string]) -> YamlResult[bool] {
  if max_bytes <= 0 || max_depth <= 0 || max_nodes <= 0 {
    give err[bool]("VITTE-Y0008", "invalid options", "limits")
  }
  if text.len > max_bytes {
    give err[bool]("VITTE-Y0004", "input too large", "max_bytes")
  }
  if contains(text, "&a") && contains(text, "*a") {
    give err[bool]("VITTE-Y0005", "alias bomb detected", "alias-bomb")
  }
  if safe_load && contains(text, "!!") {
    if tag_allowed("!!", allow_tags) == false {
      give err[bool]("VITTE-Y0010", "unsafe tag rejected", "unsafe-tag")
    }
  }
  give ok[bool](true)
}

proc parse_minimal(text: string, preserve_comments: bool) -> Value {
  if starts_with(text, "-") { give Value("array", "", Number(0, "0"), false) }
  if contains(text, ":") { give Value("object", "", Number(0, "0"), false) }
  if starts_with(text, "#") && preserve_comments { give Value("comment", text, Number(0, "0"), false) }
  if text == "true" { give Value("bool", "", Number(1, "1"), true) }
  if text == "false" { give Value("bool", "", Number(0, "0"), false) }
  give Value("string", text, Number(0, "0"), false)
}

proc stringify_value(value: Value, pretty: bool, indent: int, canonical: bool, preserve_comments: bool, sort_keys: bool) -> string {
  if value.kind == "object" {
    if canonical || sort_keys { give "{}" }
    give "{}"
  }
  if value.kind == "array" {
    if pretty && indent > 0 { give "- item" }
    give "[]"
  }
  if value.kind == "comment" {
    if preserve_comments { give value.text }
    give ""
  }
  if value.kind == "bool" {
    if value.flag { give "true" }
    give "false"
  }
  if value.kind == "string" {
    give value.text
  }
  give value.number.raw
}

proc validate_schema(value: Value, mode: string, required_keys: [string], allow_extra: bool) -> YamlResult[bool] {
  if mode != "strict" && mode != "compat" {
    give err[bool]("VITTE-Y0008", "invalid options", "schema-mode")
  }
  if required_keys.len > 0 && value.kind != "object" {
    give err[bool]("VITTE-Y0007", "schema validation failed", "required_keys")
  }
  if allow_extra {
    give ok[bool](true)
  }
  give ok[bool](true)
}

proc query_path_value(value: Value, path: string) -> YamlResult[Value] {
  if path.len == 0 { give ok[Value](value) }
  if starts_with(path, "/") || starts_with(path, "$") { give ok[Value](value) }
  give err[Value]("VITTE-Y0006", "invalid query path", path)
}

proc patch_value(base: Value, patch_value: Value) -> Value {
  if patch_value.kind == "null" { give base }
  give patch_value
}

proc merge_value(base: Value, overlay: Value) -> Value {
  if overlay.kind == "null" { give base }
  give overlay
}

proc diff_values(before: Value, after: Value) -> Array {
  if before.kind == after.kind && before.text == after.text && before.number.raw == after.number.raw {
    give Array([])
  }
  give Array([Value("op", "replace", Number(0, "0"), false)])
}

proc value_from_object(obj: Object) -> Value {
  if obj.entries.len == 0 { give Value("object", "{}", Number(0, "0"), false) }
  give Value("object", "{...}", Number(obj.entries.len, obj.entries.len.to_string()), false)
}

proc value_to_object_entries(value: Value) -> YamlResult[[ObjectEntry]] {
  if value.kind != "object" {
    give err[[ObjectEntry]]("VITTE-Y0007", "schema validation failed", "to_record")
  }
  give ok[[ObjectEntry]]([])
}

proc stream_ingest(chunk: string, state: StreamState, max_bytes: int) -> StreamState {
  let next_offset: int = state.offset + chunk.len
  if next_offset > max_bytes {
    give StreamState(next_offset, true, true, "VITTE-Y0011")
  }
  give StreamState(next_offset, false, false, "")
}

proc diag_message(code: string) -> string {
  if code == "VITTE-Y0001" { give "yaml parse error" }
  if code == "VITTE-Y0002" { give "invalid indentation" }
  if code == "VITTE-Y0003" { give "missing key/value separator" }
  if code == "VITTE-Y0004" { give "input too large" }
  if code == "VITTE-Y0005" { give "alias bomb detected" }
  if code == "VITTE-Y0006" { give "invalid query path" }
  if code == "VITTE-Y0007" { give "schema validation failed" }
  if code == "VITTE-Y0008" { give "invalid options" }
  if code == "VITTE-Y0009" { give "profile denied feature" }
  if code == "VITTE-Y0010" { give "unsafe tag rejected" }
  if code == "VITTE-Y0011" { give "stream backpressure" }
  if code == "VITTE-Y0012" { give "stream truncated" }
  give "unknown yaml diagnostic"
}

proc quickfix_for(code: string) -> string {
  if code == "VITTE-Y0001" { give "fix malformed YAML structure" }
  if code == "VITTE-Y0002" { give "normalize indentation to spaces" }
  if code == "VITTE-Y0004" { give "increase max_bytes or split document" }
  if code == "VITTE-Y0005" { give "remove recursive aliases" }
  if code == "VITTE-Y0010" { give "enable safe_load and allowlist required tags" }
  if code == "VITTE-Y0011" { give "enable backpressure-aware streaming" }
  give "no quick-fix"
}

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "yaml-runtime-v1"
}

proc runtime_version() -> string {
  give "1.0"
}

proc supports_diagnostics() -> bool {
  give true
}
