space vitte/borrow/internal/validate

proc has_space(value: string) -> bool {
  let i: int = 0
  loop {
    if i >= value.len { break }
    if value.slice(i, i + 1) == " " { give true }
    i = i + 1
  }
  give false
}

proc valid_symbol(symbol: string, max_len: int) -> bool {
  if symbol.len == 0 { give false }
  if symbol.len > max_len { give false }
  if has_space(symbol) { give false }
  give true
}

proc valid_owner(owner: string, max_len: int) -> bool {
  if owner.len == 0 { give false }
  if owner.len > max_len { give false }
  if has_space(owner) { give false }
  give true
}

proc valid_table_size(size: int, max_size: int) -> bool {
  if size < 0 { give false }
  give size <= max_size
}

proc valid_active_count(count: int, max_count: int) -> bool {
  if count < 0 { give false }
  give count <= max_count
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}
