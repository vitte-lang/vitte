space vitte/borrow/internal/policy

proc max_symbol_len() -> int {
  give 256
}

proc max_owner_len() -> int {
  give 256
}

proc max_total_refs() -> int {
  give 1000000
}

proc max_active_refs_per_symbol() -> int {
  give 1024
}

proc default_strict() -> bool {
  give true
}

proc default_allow_reentrant_shared() -> bool {
  give true
}

proc warn_active_refs_per_symbol() -> int {
  give 256
}

proc normalize_symbol_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_symbol_len() { out = max_symbol_len() }
  give out
}

proc normalize_owner_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_owner_len() { out = max_owner_len() }
  give out
}

proc normalize_total_refs(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_total_refs() { out = max_total_refs() }
  give out
}

proc normalize_active_refs_per_symbol(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_active_refs_per_symbol() { out = max_active_refs_per_symbol() }
  give out
}
