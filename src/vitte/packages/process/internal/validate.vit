<<<
validate.vit
package vitte/process/internal/validate
>>>

space vitte/process/internal/validate

proc contains(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }
  let i: int = 0
  loop {
    if i + needle.len > text.len { break }
    if text.slice(i, i + needle.len) == needle { give true }
    i = i + 1
  }
  give false
}

proc has_control_chars(text: string) -> bool {
  if contains(text, "\n") { give true }
  if contains(text, "\r") { give true }
  if contains(text, "\0") { give true }
  give false
}

proc env_valid(env: [string]) -> bool {
  let i: int = 0
  loop {
    if i >= env.len { break }
    let e: string = env[i]
    if has_control_chars(e) { give false }
    if contains(e, "=") == false { give false }
    i = i + 1
  }
  give true
}

proc args_valid(args: [string]) -> bool {
  let i: int = 0
  loop {
    if i >= args.len { break }
    if has_control_chars(args[i]) { give false }
    i = i + 1
  }
  give true
}

proc starts_with(text: string, prefix: string) -> bool {
  if text.len < prefix.len { give false }
  give text.slice(0, prefix.len) == prefix
}

proc cwd_valid(cwd: string) -> bool {
  if cwd.len == 0 { give false }
  if contains(cwd, "..") { give false }
  if starts_with(cwd, "/") == false { give false }
  give true
}
