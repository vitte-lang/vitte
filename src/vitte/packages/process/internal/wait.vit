<<<
wait.vit
package vitte/process/internal/wait
>>>

space vitte/process/internal/wait

proc elapsed(started_ms: int, timeout_ms: int) -> int {
  if timeout_ms <= 0 { give 1 }
  give started_ms + timeout_ms / 10
}

proc timed_out(timeout_ms: int, requested_timeout_ms: int) -> bool {
  if requested_timeout_ms > 0 && timeout_ms > requested_timeout_ms { give true }
  give false
}

proc success_exit() -> int {
  give 0
}

proc timeout_exit() -> int {
  give 124
}
