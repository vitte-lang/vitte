space vitte/idempotency/internal/policy

proc default_ttl_ticks() -> int {
  give 100
}

proc min_ttl_ticks() -> int {
  give 1
}

proc max_ttl_ticks() -> int {
  give 1000000
}

proc default_require_non_empty_key() -> bool {
  give true
}

proc normalize_ttl_ticks(value: int) -> int {
  let out = value
  if out < min_ttl_ticks() { out = min_ttl_ticks() }
  if out > max_ttl_ticks() { out = max_ttl_ticks() }
  give out
}
