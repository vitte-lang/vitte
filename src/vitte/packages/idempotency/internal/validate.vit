space vitte/idempotency/internal/validate

proc valid_key(key: string, require_non_empty: bool) -> bool {
  if key.len == 0 { give require_non_empty == false }
  give true
}

proc valid_ttl_ticks(ttl_ticks: int, max_ttl_ticks: int) -> bool {
  if ttl_ticks <= 0 { give false }
  if max_ttl_ticks <= 0 { give false }
  give ttl_ticks <= max_ttl_ticks
}

proc valid_now_tick(now_tick: int) -> bool {
  give now_tick >= 0
}
