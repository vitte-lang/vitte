<<<
mod.vit
package vitte/log
>>>
# PREAMBLE (API stable facade)
# - Public facade for vitte/log; additive API only.
# - No import-time side effects.
# - Internal implementation lives in vitte/log/internal/*.
# - Diagnostics namespace: VITTE-L0001..VITTE-L0099.

space vitte/log

use vitte/log/internal/runtime as log_runtime_pkg

pick LogLevel {
  Trace
  Debug
  Info
  Warn
  Error
  Fatal
}

pick LogSink {
  Stdout
  Stderr
  File
  Syslog
  Journald
  MemoryRing
}

pick LogFormat {
  Text
  JsonLines
}

pick DropPolicy {
  DropNewest
  DropOldest
  Block
}

form LogField {
  key: string
  value: string
}

form LogEvent {
  timestamp: int
  level: LogLevel
  message: string
  module: string
  fields: [LogField]
  trace_id: string
  span_id: string
}

pick LogError {
  Failure(code: string, message: string)
}

pick LogResult[T] {
  Ok(value: T)
  Err(error: LogError)
}

form LogConfig {
  profile: string
  sample_rate_percent: int
  sample_burst: int
  rate_limit_per_window: int
  dedup_window: int
  buffer_capacity: int
  async_enabled: bool
  drop_policy: DropPolicy
  hot_reload_epoch: int
  perf_mode: bool
  lossless_debug: bool
  min_level: LogLevel
  module_filter: string
}

form Logger {
  sink: LogSink
  fallback_sink: LogSink
  format: LogFormat
  config: LogConfig
  context_module: string
  context_trace_id: string
  context_span_id: string
  context_fields: [LogField]
  buffer: [LogEvent]
  events: [LogEvent]
  dropped: int
  window_count: int
  sample_count: int
  last_key: string
  last_repeat: int
}

proc ok[T](value: T) -> LogResult[T] {
  give LogResult.Ok(value)
}

proc err[T](code: string, message: string) -> LogResult[T] {
  give LogResult.Err(LogError.Failure(code, message))
}

proc assert_or_err(condition: bool, code: string, message: string) -> LogResult[bool] {
  if condition {
    give LogResult.Ok(true)
  }
  give LogResult.Err(LogError.Failure(code, message))
}

proc panic_guard[T](r: LogResult[T], fallback: T) -> T {
  when r is LogResult.Ok {
    give r.value
  }
  give fallback
}

proc checked_cast_int(value: int) -> LogResult[int] {
  give LogResult.Ok(value)
}

proc level_rank(level: LogLevel) -> int {
  if level == LogLevel.Trace { give 5 }
  if level == LogLevel.Debug { give 10 }
  if level == LogLevel.Info { give 20 }
  if level == LogLevel.Warn { give 30 }
  if level == LogLevel.Error { give 40 }
  give 50
}

proc level_name(level: LogLevel) -> string {
  if level == LogLevel.Trace { give "trace" }
  if level == LogLevel.Debug { give "debug" }
  if level == LogLevel.Info { give "info" }
  if level == LogLevel.Warn { give "warn" }
  if level == LogLevel.Error { give "error" }
  give "fatal"
}

proc sink_name(sink: LogSink) -> string {
  if sink == LogSink.Stdout { give "stdout" }
  if sink == LogSink.Stderr { give "stderr" }
  if sink == LogSink.File { give "file" }
  if sink == LogSink.Syslog { give "syslog" }
  if sink == LogSink.Journald { give "journald" }
  give "memory_ring"
}

proc default_config() -> LogConfig {
  give LogConfig(
    "desktop",
    100,
    100,
    1000,
    16,
    1024,
    true,
    DropPolicy.DropOldest,
    0,
    false,
    false,
    LogLevel.Info,
    "*"
  )
}

proc logger_new(min_level: LogLevel) -> Logger {
  let cfg: LogConfig = LogConfig(
    "desktop",
    100,
    100,
    1000,
    16,
    1024,
    true,
    DropPolicy.DropOldest,
    0,
    false,
    false,
    min_level,
    "*"
  )
  give Logger(
    LogSink.Stderr,
    LogSink.Stderr,
    LogFormat.Text,
    cfg,
    "",
    "",
    "",
    [],
    [],
    [],
    0,
    0,
    0,
    "",
    0
  )
}

proc with_field(l: Logger, key: string, value: string) -> Logger {
  let redacted: string = log_runtime_pkg.redact_field_value(key, value)
  give Logger(
    l.sink,
    l.fallback_sink,
    l.format,
    l.config,
    l.context_module,
    l.context_trace_id,
    l.context_span_id,
    l.context_fields.push(LogField(key, redacted)),
    l.buffer,
    l.events,
    l.dropped,
    l.window_count,
    l.sample_count,
    l.last_key,
    l.last_repeat
  )
}

proc with_module(l: Logger, module: string) -> Logger {
  give Logger(
    l.sink,
    l.fallback_sink,
    l.format,
    l.config,
    module,
    l.context_trace_id,
    l.context_span_id,
    l.context_fields,
    l.buffer,
    l.events,
    l.dropped,
    l.window_count,
    l.sample_count,
    l.last_key,
    l.last_repeat
  )
}

proc with_trace(l: Logger, trace_id: string, span_id: string) -> Logger {
  give Logger(
    l.sink,
    l.fallback_sink,
    l.format,
    l.config,
    l.context_module,
    trace_id,
    span_id,
    l.context_fields,
    l.buffer,
    l.events,
    l.dropped,
    l.window_count,
    l.sample_count,
    l.last_key,
    l.last_repeat
  )
}

proc with_min_level(l: Logger, min_level: LogLevel) -> Logger {
  let cfg: LogConfig = LogConfig(
    l.config.profile,
    l.config.sample_rate_percent,
    l.config.sample_burst,
    l.config.rate_limit_per_window,
    l.config.dedup_window,
    l.config.buffer_capacity,
    l.config.async_enabled,
    l.config.drop_policy,
    l.config.hot_reload_epoch,
    l.config.perf_mode,
    l.config.lossless_debug,
    min_level,
    l.config.module_filter
  )
  give Logger(
    l.sink,
    l.fallback_sink,
    l.format,
    cfg,
    l.context_module,
    l.context_trace_id,
    l.context_span_id,
    l.context_fields,
    l.buffer,
    l.events,
    l.dropped,
    l.window_count,
    l.sample_count,
    l.last_key,
    l.last_repeat
  )
}

