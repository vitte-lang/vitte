space vitte/config_derive/internal/validate

proc valid_limit(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_schema_name(name: string, max_len: int) -> bool {
  if name.len == 0 { give false }
  give name.len <= max_len
}

proc valid_field_name(name: string, max_len: int) -> bool {
  if name.len == 0 { give false }
  give name.len <= max_len
}

proc valid_default_value(value: string, max_len: int) -> bool {
  give value.len <= max_len
}

proc valid_field_count(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
