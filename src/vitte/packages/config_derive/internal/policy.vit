space vitte/config_derive/internal/policy

proc max_schema_name_len() -> int {
  give 128
}

proc max_field_name_len() -> int {
  give 128
}

proc max_default_len() -> int {
  give 1024
}

proc max_fields() -> int {
  give 256
}

proc default_strict() -> bool {
  give false
}

proc normalize_schema_name_len(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > max_schema_name_len() { out = max_schema_name_len() }
  give out
}

proc normalize_field_name_len(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > max_field_name_len() { out = max_field_name_len() }
  give out
}

proc normalize_default_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_default_len() { out = max_default_len() }
  give out
}

proc normalize_max_fields(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_fields() { out = max_fields() }
  give out
}
