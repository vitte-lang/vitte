space vitte/codec/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "codec-runtime-v2.1"
}

proc runtime_version() -> string {
  give "2.1"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_json() -> bool {
  give true
}

proc supports_msgpack() -> bool {
  give true
}

proc supports_binary() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}

proc supports_autodetect() -> bool {
  give true
}

proc supports_roundtrip_check() -> bool {
  give true
}

proc sanitize(value: string, max_len: int) -> string {
  if value.len <= max_len { give value }
  give value.slice(0, max_len)
}
