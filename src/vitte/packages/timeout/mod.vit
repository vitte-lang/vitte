<<<
mod.vit
package vitte/timeout
>>>

space vitte/timeout

use vitte/timeout/internal/policy as timeout_policy_pkg
use vitte/timeout/internal/runtime as timeout_runtime_pkg
use vitte/timeout/internal/validate as timeout_validate_pkg


form Timeout {
  started_ms: int
  deadline_ms: int
  budget_ms: int
  active: bool
}

proc timeout_new(started_ms: int, budget_ms: int) -> Timeout {
  let budget_value = budget_ms
  if budget_value < 1 { budget_value = 1 }
  give Timeout(started_ms, started_ms + budget_value, budget_value, true)
}

proc started_at(timeout: Timeout) -> int {
  give timeout.started_ms
}

proc deadline_at(timeout: Timeout) -> int {
  give timeout.deadline_ms
}

proc budget(timeout: Timeout) -> int {
  give timeout.budget_ms
}

proc with_deadline(timeout: Timeout, deadline_ms: int) -> Timeout {
  let deadline = deadline_ms
  if deadline < timeout.started_ms {
    deadline = timeout.started_ms
  }
  give Timeout(timeout.started_ms, deadline, deadline - timeout.started_ms, timeout.active)
}

proc with_active(timeout: Timeout, enabled: bool) -> Timeout {
  give Timeout(timeout.started_ms, timeout.deadline_ms, timeout.budget_ms, enabled)
}

proc expired(timeout: Timeout, now_ms: int) -> bool {
  if !timeout.active { give true }
  give now_ms >= timeout.deadline_ms
}

proc within(timeout: Timeout, now_ms: int) -> bool {
  give !expired(timeout, now_ms)
}

proc remaining_ms(timeout: Timeout, now_ms: int) -> int {
  if expired(timeout, now_ms) { give 0 }
  give timeout.deadline_ms - now_ms
}

proc elapsed_ms(timeout: Timeout, now_ms: int) -> int {
  let elapsed = now_ms - timeout.started_ms
  if elapsed < 0 { give 0 }
  give elapsed
}

proc with_budget(timeout: Timeout, budget_ms: int) -> Timeout {
  let budget_value = budget_ms
  if budget_value < 1 { budget_value = 1 }
  give Timeout(timeout.started_ms, timeout.started_ms + budget_value, budget_value, timeout.active)
}

proc clamp_deadline(timeout: Timeout, min_deadline_ms: int, max_deadline_ms: int) -> Timeout {
  let min_deadline = min_deadline_ms
  if min_deadline < timeout.started_ms { min_deadline = timeout.started_ms }

  let max_deadline = max_deadline_ms
  if max_deadline < min_deadline { max_deadline = min_deadline }

  let deadline = timeout.deadline_ms
  if deadline < min_deadline { deadline = min_deadline }
  if deadline > max_deadline { deadline = max_deadline }

  give Timeout(timeout.started_ms, deadline, deadline - timeout.started_ms, timeout.active)
}

proc extend(timeout: Timeout, delta_ms: int) -> Timeout {
  if delta_ms <= 0 { give timeout }
  give Timeout(timeout.started_ms, timeout.deadline_ms + delta_ms, timeout.budget_ms + delta_ms, timeout.active)
}

proc shift(timeout: Timeout, delta_ms: int) -> Timeout {
  if delta_ms == 0 { give timeout }
  give Timeout(timeout.started_ms + delta_ms, timeout.deadline_ms + delta_ms, timeout.budget_ms, timeout.active)
}

proc restart(timeout: Timeout, now_ms: int, budget_ms: int) -> Timeout {
  let _ = timeout
  give timeout_new(now_ms, budget_ms)
}

proc is_active(timeout: Timeout) -> bool {
  give timeout.active
}

proc is_stopped(timeout: Timeout) -> bool {
  give !timeout.active
}

proc ensure_active(timeout: Timeout) -> Timeout {
  if timeout.active { give timeout }
  give Timeout(timeout.started_ms, timeout.deadline_ms, timeout.budget_ms, true)
}

proc deadline_overrun(timeout: Timeout, now_ms: int) -> int {
  if !expired(timeout, now_ms) { give 0 }
  let over = now_ms - timeout.deadline_ms
  if over < 0 { give 0 }
  give over
}

proc can_spend(timeout: Timeout, now_ms: int, cost_ms: int) -> bool {
  if cost_ms < 0 { give false }
  give remaining_ms(timeout, now_ms) >= cost_ms
}

proc overspent(timeout: Timeout, spent_ms: int) -> int {
  let over = spent_ms - timeout.budget_ms
  if over < 0 { give 0 }
  give over
}

proc guard(timeout: Timeout, elapsed_ms: int) -> bool {
  if !timeout.active { give false }
  if elapsed_ms < 0 { give false }
  give elapsed_ms <= timeout.budget_ms
}

proc stop(timeout: Timeout) -> Timeout {
  give Timeout(timeout.started_ms, timeout.deadline_ms, timeout.budget_ms, false)
}

proc stats(timeout: Timeout, now_ms: int) -> string {
  let active = "false"
  if timeout.active { active = "true" }
  give "active=" + active +
       ",remaining=" + remaining_ms(timeout, now_ms).to_string() +
       ",elapsed=" + elapsed_ms(timeout, now_ms).to_string()
}

form PackageConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick PackageConfigError {
  InvalidConfig
  Internal
}

pick PackageConfigResult {
  Ok(ok: bool)
  Err(error: PackageConfigError)
}

form PackageRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> PackageConfig {
  give PackageConfig(true,
                     timeout_policy_pkg.default_timeout_ms(),
                     timeout_policy_pkg.default_retry_budget())
}

proc strict_config() -> PackageConfig {
  let cfg = default_config()
  give PackageConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: PackageConfig) -> PackageConfig {
  let retry_budget = cfg.retry_budget
  if retry_budget < 0 { retry_budget = 0 }
  if retry_budget > 32 { retry_budget = 32 }
  give PackageConfig(cfg.strict,
                     timeout_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                     retry_budget)
}

proc validate_config(cfg: PackageConfig) -> PackageConfigResult {
  let nc = normalize_config(cfg)
  if timeout_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  if timeout_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  give PackageConfigResult.Ok(true)
}

proc healthcheck(cfg: PackageConfig) -> PackageConfigResult {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give PackageConfigResult.Err(vr.error) }
  if timeout_runtime_pkg.runtime_status() == false {
    give PackageConfigResult.Err(PackageConfigError.Internal)
  }
  give PackageConfigResult.Ok(true)
}

proc runtime_info() -> PackageRuntimeInfo {
  give PackageRuntimeInfo(timeout_runtime_pkg.runtime_name(),
                          timeout_runtime_pkg.runtime_version(),
                          timeout_runtime_pkg.supports_diagnostics())
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck", "api-contract", "abi-contract", "diagnostics", "contract-summary"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-TIMEOUT0001" { give "invalid package configuration" }
  give "timeout diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review timeout/retry configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}

proc version() -> string {
  give api_version()
}

proc doctor_status() -> string {
  give "vitte/timeout doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: PackageConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give false }
  give true
}

proc healthcheck_default() -> PackageConfigResult {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}
proc validate_config_code(cfg: PackageConfig) -> string {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give "VITTE-TIMEOUT0001" }
  give "VITTE-TIMEOUT0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-TIMEOUT"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/timeout,config=(strict,timeout_ms,retry_budget),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(PackageConfigResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-TIMEOUT0000" { give ["no action required"] }
  if code == "VITTE-TIMEOUT0001" {
    give ["apply normalize_config", "ensure timeout_ms is valid", "ensure retry_budget is valid"]
  }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() +
       " code=" + code +
       " sev=" + diagnostics_severity(code) +
       " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: PackageConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is PackageConfigResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  loop {
    if i >= caps.len { break }
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() +
       " fp=" + package_contract_fingerprint().to_string() +
       " hc=" + healthcheck_default_code() +
       " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give true
}



proc package_meta() -> string {
    give "vitte/timeout"
}

<<< ROLE-CONTRACT
package: vitte/timeout
role: Coupe les appels lents avec budget explicite
input_contract: Temps de depart, budget et deadline explicites
output_contract: Decision expired guard stable et deterministe
boundary: Ne relance pas les appels; fournit uniquement la garde temporelle
>>>







