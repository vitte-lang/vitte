space vitte/crypto/internal/validate

proc valid_key(key: string, min_len: int, max_len: int) -> bool {
  if key.len < min_len { give false }
  give key.len <= max_len
}

proc valid_input_len(value: int, max_len: int) -> bool {
  if value < 0 { give false }
  give value <= max_len
}

proc valid_signature(signature: string) -> bool {
  if signature.len < 5 { give false }
  give signature.slice(0, 4) == "sig:"
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
