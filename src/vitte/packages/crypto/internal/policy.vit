space vitte/crypto/internal/policy

proc min_key_len() -> int {
  give 1
}

proc min_strong_key_len() -> int {
  give 8
}

proc max_key_len() -> int {
  give 512
}

proc max_input_len() -> int {
  give 1048576
}

proc default_strict() -> bool {
  give false
}

proc normalize_key_len(value: int) -> int {
  let out = value
  if out < min_key_len() { out = min_key_len() }
  if out > max_key_len() { out = max_key_len() }
  give out
}

proc normalize_input_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_input_len() { out = max_input_len() }
  give out
}
