space vitte/ffi/internal/validate

proc valid_timeout_ms(timeout_ms: int) -> bool {
  give timeout_ms > 0 && timeout_ms <= 60000
}

proc valid_retry_budget(retry_budget: int) -> bool {
  give retry_budget >= 0 && retry_budget <= 32
}

proc valid_lib(lib: string) -> bool {
  give lib.len > 0
}

proc valid_name(name: string) -> bool {
  give name.len > 0
}

proc valid_signature(signature: string) -> bool {
  give signature.len > 0
}

proc valid_symbol(lib: string, name: string, signature: string) -> bool {
  if valid_lib(lib) == false { give false }
  if valid_name(name) == false { give false }
  if valid_signature(signature) == false { give false }
  give true
}
