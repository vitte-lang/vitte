space vitte/jobs/internal/validate

proc valid_max_attempts(value: int, max_value: int) -> bool {
  if value < 1 { give false }
  if max_value < 1 { give false }
  give value <= max_value
}

proc valid_payload(payload: string, require_non_empty_payload: bool) -> bool {
  if payload.len == 0 { give require_non_empty_payload == false }
  give true
}

proc valid_job_id(job_id: int) -> bool {
  give job_id >= 0
}
