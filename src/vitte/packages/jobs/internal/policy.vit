space vitte/jobs/internal/policy

proc min_max_attempts() -> int {
  give 1
}

proc max_max_attempts() -> int {
  give 128
}

proc default_max_attempts() -> int {
  give 3
}

proc default_require_non_empty_payload() -> bool {
  give true
}

proc normalize_max_attempts(value: int) -> int {
  let out = value
  if out < min_max_attempts() { out = min_max_attempts() }
  if out > max_max_attempts() { out = max_max_attempts() }
  give out
}
