space vitte/ecs/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "ecs-runtime-v2"
}

proc runtime_version() -> string {
  give "2.1"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_positions() -> bool {
  give true
}

proc supports_velocities() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}

proc supports_batch_step() -> bool {
  give true
}
