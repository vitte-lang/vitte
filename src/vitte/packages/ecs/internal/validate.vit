space vitte/ecs/internal/validate

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_entity_id(value: int) -> bool {
  give value >= 0
}

proc valid_limit(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_coord(value: int, max_abs: int) -> bool {
  let abs = value
  if abs < 0 { abs = 0 - abs }
  give abs <= max_abs
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}

proc valid_tick(value: int, max_ticks: int) -> bool {
  if value < 0 { give false }
  give value <= max_ticks
}

proc valid_generation(value: int) -> bool {
  give value >= 0
}
