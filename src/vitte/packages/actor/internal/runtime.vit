space vitte/actor/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "actor-runtime-v1"
}

proc runtime_version() -> string {
  give "1.0"
}

proc scheduler_name() -> string {
  give "fair-lane"
}

proc supports_tracing() -> bool {
  give true
}

proc supports_snapshots() -> bool {
  give true
}

proc monotonic_tick() -> bool {
  give true
}
