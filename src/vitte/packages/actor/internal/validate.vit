space vitte/actor/internal/validate

proc valid_actor_id(id: int) -> bool {
  give id > 0
}

proc valid_actor_name(name: string) -> bool {
  if name.len < 1 { give false }
  give name.len <= 128
}

proc valid_mailbox_capacity(capacity: int, max_capacity: int) -> bool {
  if capacity < 1 { give false }
  give capacity <= max_capacity
}

proc valid_restart_limit(limit: int, max_limit: int) -> bool {
  if limit < 0 { give false }
  give limit <= max_limit
}

proc valid_snapshot_interval(interval: int, max_interval: int) -> bool {
  if interval < 1 { give false }
  give interval <= max_interval
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_mailbox_len(mailbox_len: int, capacity: int) -> bool {
  if mailbox_len < 0 { give false }
  give mailbox_len <= capacity
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}

proc valid_lane(lane: int) -> bool {
  if lane < 0 { give false }
  give lane <= 2
}

proc valid_router_bounds(min_workers: int, max_workers: int, hard_max_workers: int) -> bool {
  if min_workers < 1 { give false }
  if max_workers < min_workers { give false }
  give max_workers <= hard_max_workers
}

proc valid_backlog_threshold(value: int) -> bool {
  give value >= 0
}
