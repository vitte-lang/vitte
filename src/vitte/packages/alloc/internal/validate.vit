space vitte/alloc/internal/validate

proc valid_capacity(capacity: int, max_capacity: int) -> bool {
  if capacity < 0 { give false }
  give capacity <= max_capacity
}

proc valid_used(used: int, capacity: int) -> bool {
  if used < 0 { give false }
  give used <= capacity
}

proc valid_high_watermark(high: int, used: int, capacity: int) -> bool {
  if high < used { give false }
  give high <= capacity
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_alignment_value(value: int) -> bool {
  if value < 1 { give false }
  let v = value
  loop {
    if v == 1 { break }
    if v % 2 != 0 { give false }
    v = v / 2
  }
  give true
}

proc valid_handle(value: int) -> bool {
  give value > 0
}

proc valid_pool_id(value: string) -> bool {
  give value.len > 0
}

proc valid_pressure(pct: int) -> bool {
  if pct < 0 { give false }
  give pct <= 100
}
