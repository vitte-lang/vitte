space vitte/alloc/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "alloc-runtime-v1"
}

proc runtime_version() -> string {
  give "1.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_canaries() -> bool {
  give true
}

proc supports_poison() -> bool {
  give true
}
