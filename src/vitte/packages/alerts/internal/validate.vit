space vitte/alerts/internal/validate

proc valid_rule_name(name: string) -> bool {
  if name.len < 1 { give false }
  give name.len <= 128
}

proc valid_threshold(threshold: int) -> bool {
  give threshold >= 1
}

proc valid_window_ticks(window_ticks: int) -> bool {
  give window_ticks >= 1
}

proc valid_ttl(ttl_ticks: int, max_ttl: int) -> bool {
  if ttl_ticks < 1 { give false }
  give ttl_ticks <= max_ttl
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_percentage(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}

proc valid_quota(value: int, max_quota: int) -> bool {
  if value < 0 { give false }
  give value <= max_quota
}

proc valid_destination(value: string) -> bool {
  give value.len > 0
}

proc valid_template_version(version: string) -> bool {
  give version.len > 0
}

proc valid_text(value: string, max_len: int) -> bool {
  if value.len < 0 { give false }
  give value.len <= max_len
}

proc valid_timestamp(ts: int) -> bool {
  give ts >= 0
}

proc valid_retry_limit(limit: int, max_limit: int) -> bool {
  if limit < 0 { give false }
  give limit <= max_limit
}

proc valid_duration_ticks(value: int) -> bool {
  give value >= 0
}

proc valid_label(label: string) -> bool {
  give label.len > 0
}
