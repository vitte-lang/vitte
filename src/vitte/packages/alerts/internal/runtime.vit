space vitte/alerts/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "alerts-runtime-v1"
}

proc runtime_version() -> string {
  give "1.0"
}

proc supports_dedupe() -> bool {
  give true
}

proc supports_quota() -> bool {
  give true
}

proc supports_routing() -> bool {
  give true
}

proc supports_templates() -> bool {
  give true
}

proc supports_planned_silence() -> bool {
  give true
}

proc supports_authz() -> bool {
  give true
}
