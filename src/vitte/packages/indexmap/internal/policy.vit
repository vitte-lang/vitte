space vitte/indexmap/internal/policy

proc default_max_entries() -> int {
  give 100000
}

proc min_max_entries() -> int {
  give 1
}

proc default_require_non_empty_key() -> bool {
  give true
}

proc normalize_max_entries(value: int) -> int {
  let out = value
  if out < min_max_entries() { out = min_max_entries() }
  give out
}
