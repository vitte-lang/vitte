space vitte/indexmap/internal/validate

proc valid_key(key: string, require_non_empty_key: bool) -> bool {
  if key.len == 0 { give require_non_empty_key == false }
  give true
}

proc valid_entries_len(count: int, max_entries: int) -> bool {
  if count < 0 { give false }
  if max_entries <= 0 { give false }
  give count <= max_entries
}

proc valid_value(value: string) -> bool {
  give value.len >= 0
}
