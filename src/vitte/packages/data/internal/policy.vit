space vitte/data/internal/policy

proc min_cache_limit() -> int {
  give 0
}

proc max_cache_limit() -> int {
  give 1000000
}

proc max_schema_name_len() -> int {
  give 128
}

proc default_cache_limit() -> int {
  give 2048
}

proc default_strict_schema() -> bool {
  give true
}

proc normalize_cache_limit(value: int) -> int {
  let out = value
  if out < min_cache_limit() { out = min_cache_limit() }
  if out > max_cache_limit() { out = max_cache_limit() }
  give out
}
