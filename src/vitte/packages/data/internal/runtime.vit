space vitte/data/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "data-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_schema_check() -> bool {
  give true
}

proc supports_cache_policy() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
