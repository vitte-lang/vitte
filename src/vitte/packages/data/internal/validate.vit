space vitte/data/internal/validate

proc valid_schema_name(schema_name: string) -> bool {
  give schema_name.len > 0
}

proc valid_schema_name_len(schema_name: string, max_len: int) -> bool {
  if schema_name.len == 0 { give false }
  give schema_name.len <= max_len
}

proc valid_cache_limit(cache_limit: int) -> bool {
  give cache_limit >= 0 && cache_limit <= 1000000
}

proc valid_cache_limit_range(cache_limit: int, min_value: int, max_value: int) -> bool {
  if cache_limit < min_value { give false }
  give cache_limit <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
