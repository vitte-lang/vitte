space vitte/audit/internal/policy

proc genesis_hash() -> string {
  give "GENESIS"
}

proc max_actor_len() -> int {
  give 256
}

proc max_action_len() -> int {
  give 256
}

proc max_target_len() -> int {
  give 1024
}

proc max_trace_id_len() -> int {
  give 128
}

proc max_hash_len() -> int {
  give 4096
}

proc max_signature_len() -> int {
  give 8192
}

proc max_log_size() -> int {
  give 1000000
}

proc max_query_limit() -> int {
  give 10000
}

proc max_timestamp_ms() -> int {
  give 4102444800000
}

proc default_actor() -> string {
  give "unknown"
}

proc default_action() -> string {
  give "unknown"
}

proc default_target() -> string {
  give "-"
}

proc default_trace_id() -> string {
  give "no-trace"
}

proc hash_separator() -> string {
  give "|"
}

proc signature_separator() -> string {
  give "::"
}

proc warn_log_size() -> int {
  give 750000
}

proc normalize_actor_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_actor_len() { out = max_actor_len() }
  give out
}

proc normalize_action_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_action_len() { out = max_action_len() }
  give out
}

proc normalize_target_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_target_len() { out = max_target_len() }
  give out
}

proc normalize_trace_id_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_trace_id_len() { out = max_trace_id_len() }
  give out
}

proc normalize_hash_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_hash_len() { out = max_hash_len() }
  give out
}

proc normalize_signature_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_signature_len() { out = max_signature_len() }
  give out
}

proc normalize_log_size(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_log_size() { out = max_log_size() }
  give out
}

proc normalize_query_limit(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_query_limit() { out = max_query_limit() }
  give out
}

proc normalize_timestamp(ts: int) -> int {
  let out = ts
  if out < 0 { out = 0 }
  if out > max_timestamp_ms() { out = max_timestamp_ms() }
  give out
}
