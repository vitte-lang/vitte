space vitte/http_client/internal/validate

proc valid_timeout_ms(value: int) -> bool {
  give value > 0 && value <= 60000
}

proc valid_retry_budget(value: int) -> bool {
  give value >= 0 && value <= 32
}

proc valid_profile(profile: string) -> bool {
  give profile == "desktop" || profile == "system" || profile == "core"
}

proc valid_max_redirects(value: int) -> bool {
  give value >= 0 && value <= 32
}

proc valid_pool(max_per_host: int, in_use: int) -> bool {
  if max_per_host <= 0 { give false }
  if in_use < 0 { give false }
  give in_use <= max_per_host
}
