<<<
mod.vit
package vitte/mir
>>>

space vitte/mir

use vitte/mir/internal/policy as mir_policy_pkg
use vitte/mir/internal/runtime as mir_runtime_pkg
use vitte/mir/internal/validate as mir_validate_pkg

pick MirOp {
  Nop
  Load
  Store
  Call
  Jump
  Ret
}

form MirInstr {
  id: int
  op: MirOp
  arg0: string
  arg1: string
}

form MirBlock {
  name: string
  instrs: [MirInstr]
}

form MirModule {
  name: string
  blocks: [MirBlock]
}

form MirConfig {
  max_blocks: int
  max_instrs: int
}

pick MirConfigError {
  InvalidConfig
  Internal
}

pick MirConfigResult[T] {
  Ok(value: T)
  Err(error: MirConfigError)
}

form MirRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
  supports_cfg_ops: bool
}

proc instr(id: int, op: MirOp, arg0: string, arg1: string) -> MirInstr {
  give MirInstr(id, op, arg0, arg1)
}

proc block(name: string) -> MirBlock {
  give MirBlock(name, [])
}

proc module_new(name: string) -> MirModule {
  give MirModule(name, [])
}

proc add_block(m: MirModule, b: MirBlock) -> MirModule {
  give MirModule(m.name, m.blocks.push(b))
}

proc add_instr(b: MirBlock, i: MirInstr) -> MirBlock {
  give MirBlock(b.name, b.instrs.push(i))
}

proc instr_count(m: MirModule) -> int {
  let total: int = 0
  let i: int = 0
  loop {
    if i >= m.blocks.len { break }
    total = total + m.blocks[i].instrs.len
    i = i + 1
  }
  give total
}

proc op_name(op: MirOp) -> string {
  if op == MirOp.Nop { give "nop" }
  if op == MirOp.Load { give "load" }
  if op == MirOp.Store { give "store" }
  if op == MirOp.Call { give "call" }
  if op == MirOp.Jump { give "jump" }
  give "ret"
}

proc validate(m: MirModule) -> bool {
  if m.name.len == 0 { give false }
  let bi: int = 0
  loop {
    if bi >= m.blocks.len { break }
    if m.blocks[bi].name.len == 0 { give false }
    let ii: int = 0
    loop {
      if ii >= m.blocks[bi].instrs.len { break }
      if m.blocks[bi].instrs[ii].id < 0 { give false }
      ii = ii + 1
    }
    bi = bi + 1
  }
  give true
}

proc summary(m: MirModule) -> string {
  give "module=" + m.name +
       ",blocks=" + m.blocks.len.to_string() +
       ",instrs=" + instr_count(m).to_string()
}

proc block_count(m: MirModule) -> int {
  give m.blocks.len
}

proc find_block(m: MirModule, name: string) -> MirBlock {
  let i: int = 0
  loop {
    if i >= m.blocks.len { break }
    if m.blocks[i].name == name { give m.blocks[i] }
    i = i + 1
  }
  give MirBlock("", [])
}

proc count_op(m: MirModule, op: MirOp) -> int {
  let c: int = 0
  let bi: int = 0
  loop {
    if bi >= m.blocks.len { break }
    let ii: int = 0
    loop {
      if ii >= m.blocks[bi].instrs.len { break }
      if m.blocks[bi].instrs[ii].op == op { c = c + 1 }
      ii = ii + 1
    }
    bi = bi + 1
  }
  give c
}

proc mir_health(m: MirModule) -> string {
  if !validate(m) { give "invalid" }
  if count_op(m, MirOp.Ret) == 0 { give "no-ret" }
  give "ok"
}

proc block_instr_count(m: MirModule, name: string) -> int {
  give find_block(m, name).instrs.len
}

proc has_op(m: MirModule, op: MirOp) -> bool {
  give count_op(m, op) > 0
}

proc mir_diagnostics(m: MirModule) -> string {
  give summary(m) +
       ",calls=" + count_op(m, MirOp.Call).to_string() +
       ",health=" + mir_health(m)
}

proc default_config() -> MirConfig {
  give MirConfig(mir_policy_pkg.default_max_blocks(), mir_policy_pkg.default_max_instrs())
}

proc strict_config() -> MirConfig {
  let cfg = default_config()
  give MirConfig(cfg.max_blocks, cfg.max_instrs)
}

proc normalize_config(cfg: MirConfig) -> MirConfig {
  give MirConfig(mir_policy_pkg.normalize_max_blocks(cfg.max_blocks),
                 mir_policy_pkg.normalize_max_instrs(cfg.max_instrs))
}

proc validate_config(cfg: MirConfig) -> MirConfigResult[bool] {
  let nc = normalize_config(cfg)
  if mir_validate_pkg.valid_limits(nc.max_blocks, nc.max_instrs) == false {
    give MirConfigResult.Err(MirConfigError.InvalidConfig)
  }
  give MirConfigResult.Ok(true)
}

proc healthcheck(cfg: MirConfig, m: MirModule) -> MirConfigResult[bool] {
  let vr = validate_config(cfg)
  when vr is MirConfigResult.Err { give MirConfigResult.Err(vr.error) }
  if mir_runtime_pkg.runtime_status() == false { give MirConfigResult.Err(MirConfigError.Internal) }
  if validate(m) == false { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  if m.blocks.len > cfg.max_blocks { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  if instr_count(m) > cfg.max_instrs { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  give MirConfigResult.Ok(true)
}

proc runtime_info() -> MirRuntimeInfo {
  give MirRuntimeInfo(mir_runtime_pkg.runtime_name(),
                      mir_runtime_pkg.runtime_version(),
                      mir_runtime_pkg.supports_diagnostics(),
                      mir_runtime_pkg.supports_cfg_ops())
}

proc module_new_checked(name: string, cfg: MirConfig) -> MirConfigResult[MirModule] {
  if mir_validate_pkg.valid_module_name(name) == false { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  let _ = cfg
  give MirConfigResult.Ok(module_new(name))
}

proc add_block_checked(m: MirModule, b: MirBlock, cfg: MirConfig) -> MirConfigResult[MirModule] {
  let nc = normalize_config(cfg)
  if b.name.len == 0 { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  if m.blocks.len >= nc.max_blocks { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  give MirConfigResult.Ok(add_block(m, b))
}

proc add_instr_checked(b: MirBlock, i: MirInstr, cfg: MirConfig) -> MirConfigResult[MirBlock] {
  let nc = normalize_config(cfg)
  if i.id < 0 { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  if b.instrs.len >= nc.max_instrs { give MirConfigResult.Err(MirConfigError.InvalidConfig) }
  give MirConfigResult.Ok(add_instr(b, i))
}

proc capabilities() -> [string] {
  give ["module", "block", "instr", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-MIR0001" { give "invalid mir configuration or arguments" }
  give "mir diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "check module names, block counts and instruction limits"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}

proc ready() -> bool {
  give true
}



proc package_meta() -> string {
  give "vitte/mir"
}

<<< ROLE-CONTRACT
package: vitte/mir
role: Representation MIR orientee transformations et generation
input_contract: Structures internes du compilateur deja valides syntaxiquement
output_contract: Artefacts intermediaires deterministes pour l etape suivante
boundary: Ne fait ni IO reseau ni decisions metier applicatives
>>>
