space vitte/mir/internal/policy

proc default_max_blocks() -> int {
  give 10000
}

proc default_max_instrs() -> int {
  give 100000
}

proc normalize_max_blocks(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 100000 { out = 100000 }
  give out
}

proc normalize_max_instrs(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 1000000 { out = 1000000 }
  give out
}
