<<<
mod.vit
package vitte/typeck
>>>

space vitte/typeck

use vitte/typeck/internal/policy as typeck_policy_pkg
use vitte/typeck/internal/runtime as typeck_runtime_pkg
use vitte/typeck/internal/validate as typeck_validate_pkg


pick TypeKind {
  Unknown
  Int
  Bool
  String
  Unit
}

pick TypeError {
  None
  UnknownSymbol
  Mismatch
  InvalidOp
}

form SymbolType {
  name: string
  kind: TypeKind
}

form TypeEnv {
  symbols: [SymbolType]
}

proc env_new() -> TypeEnv {
  give TypeEnv([])
}

proc add_symbol(env: TypeEnv, name: string, kind: TypeKind) -> TypeEnv {
  give TypeEnv(env.symbols.push(SymbolType(name, kind)))
}

proc lookup(env: TypeEnv, name: string) -> TypeKind {
  let i: int = 0
  loop {
    if i >= env.symbols.len { break }
    if env.symbols[i].name == name { give env.symbols[i].kind }
    i = i + 1
  }
  give TypeKind.Unknown
}

proc kind_name(kind: TypeKind) -> string {
  if kind == TypeKind.Int { give "int" }
  if kind == TypeKind.Bool { give "bool" }
  if kind == TypeKind.String { give "string" }
  if kind == TypeKind.Unit { give "unit" }
  give "unknown"
}

proc check_assign(expected: TypeKind, actual: TypeKind) -> TypeError {
  if expected == actual { give TypeError.None }
  give TypeError.Mismatch
}

proc check_binop(op: string, left: TypeKind, right: TypeKind) -> TypeKind {
  if op == "+" || op == "-" || op == "*" || op == "/" {
    if left == TypeKind.Int && right == TypeKind.Int { give TypeKind.Int }
    give TypeKind.Unknown
  }
  if op == "==" || op == "!=" || op == "<" || op == ">" {
    if left == right && left != TypeKind.Unknown { give TypeKind.Bool }
    give TypeKind.Unknown
  }
  if op == "&&" || op == "||" {
    if left == TypeKind.Bool && right == TypeKind.Bool { give TypeKind.Bool }
    give TypeKind.Unknown
  }
  give TypeKind.Unknown
}

proc validate_env(env: TypeEnv) -> bool {
  let i: int = 0
  loop {
    if i >= env.symbols.len { break }
    if env.symbols[i].name.len == 0 { give false }
    i = i + 1
  }
  give true
}

proc summary(env: TypeEnv) -> string {
  give "symbols=" + env.symbols.len.to_string() +
       ",valid=" + validate_env(env).to_string()
}

form PackageConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick PackageConfigError {
  InvalidConfig
  Internal
}

pick PackageConfigResult[T] {
  Ok(value: T)
  Err(error: PackageConfigError)
}

form PackageRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> PackageConfig {
  give PackageConfig(true,
                     typeck_policy_pkg.default_timeout_ms(),
                     typeck_policy_pkg.default_retry_budget())
}

proc strict_config() -> PackageConfig {
  let cfg = default_config()
  give PackageConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: PackageConfig) -> PackageConfig {
  let retry_budget = cfg.retry_budget
  if retry_budget < 0 { retry_budget = 0 }
  if retry_budget > 32 { retry_budget = 32 }
  give PackageConfig(cfg.strict,
                     typeck_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                     retry_budget)
}

proc validate_config(cfg: PackageConfig) -> PackageConfigResult[bool] {
  let nc = normalize_config(cfg)
  if typeck_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  if typeck_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  give PackageConfigResult.Ok(true)
}

proc healthcheck(cfg: PackageConfig) -> PackageConfigResult[bool] {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give PackageConfigResult.Err(vr.error) }
  if typeck_runtime_pkg.runtime_status() == false {
    give PackageConfigResult.Err(PackageConfigError.Internal)
  }
  give PackageConfigResult.Ok(true)
}

proc runtime_info() -> PackageRuntimeInfo {
  give PackageRuntimeInfo(typeck_runtime_pkg.runtime_name(),
                          typeck_runtime_pkg.runtime_version(),
                          typeck_runtime_pkg.supports_diagnostics())
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-PKG0001" { give "invalid package configuration" }
  give "typeck diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review timeout/retry configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}

proc version() -> string {
  give api_version()
}

proc doctor_status() -> string {
  give "vitte/typeck doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: PackageConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give false }
  give true
}

proc healthcheck_default() -> PackageConfigResult[bool] {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}
proc ready() -> bool {
  give true
}



proc package_meta() -> string {
    give "vitte/typeck"
}

<<< ROLE-CONTRACT
package: vitte/typeck
role: Verification de types et coherence des expressions
input_contract: Structures internes du compilateur deja valides syntaxiquement
output_contract: Artefacts intermediaires deterministes pour l etape suivante
boundary: Ne fait ni IO reseau ni decisions metier applicatives
>>>







