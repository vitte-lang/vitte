<<<
mod.vit
package vitte/doc
version: 2.0.0
tier: docs-core
purpose:
  Generation et validation de pages de documentation.
  Rendu markdown deterministe avec controles de structure.
  API stable versionnee avec diagnostics runtime.
>>>

space vitte/doc

use vitte/doc/internal/runtime as doc_runtime_pkg
use vitte/doc/internal/validate as doc_validate_pkg
use vitte/doc/internal/policy as doc_policy_pkg

form DocSection {
  title: string
  body: string
}

form DocPage {
  id: string
  title: string
  sections: [DocSection]
}

form DocConfig {
  strict: bool
  max_page_id_len: int
  max_title_len: int
  max_body_len: int
  max_sections: int
}

pick DocError {
  InvalidConfig
  InvalidPage
  InvalidSection
  TooManySections
  NotFound
  Internal
}

pick DocResult[T] {
  Ok(value: T)
  Err(error: DocError)
}

form DocRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_no_std: bool
  supports_markdown: bool
  supports_validation: bool
  supports_diagnostics: bool
}

form DocHealth {
  ok: bool
  code: string
  pressure_percent: int
}

form DocStats {
  sections: int
  words: int
  markdown_len: int
  has_empty_section: bool
}

form DocSearchHit {
  section_title: string
  score: int
}

proc config_ok(cfg: DocConfig) -> bool {
  if cfg.max_page_id_len < 1 || cfg.max_page_id_len > doc_policy_pkg.max_page_id_len() { give false }
  if cfg.max_title_len < 1 || cfg.max_title_len > doc_policy_pkg.max_title_len() { give false }
  if cfg.max_body_len < 0 || cfg.max_body_len > doc_policy_pkg.max_body_len() { give false }
  if cfg.max_sections < 0 || cfg.max_sections > doc_policy_pkg.max_sections() { give false }
  give true
}

proc default_config() -> DocConfig {
  give DocConfig(doc_policy_pkg.default_strict(),
                 doc_policy_pkg.max_page_id_len(),
                 doc_policy_pkg.max_title_len(),
                 doc_policy_pkg.max_body_len(),
                 doc_policy_pkg.default_max_sections())
}

proc strict_config() -> DocConfig {
  let cfg = default_config()
  give DocConfig(true,
                 cfg.max_page_id_len,
                 cfg.max_title_len,
                 cfg.max_body_len,
                 cfg.max_sections)
}

proc with_max_sections(cfg: DocConfig, max_sections: int) -> DocConfig {
  give DocConfig(cfg.strict,
                 cfg.max_page_id_len,
                 cfg.max_title_len,
                 cfg.max_body_len,
                 doc_policy_pkg.normalize_sections(max_sections))
}

proc validate_config(cfg: DocConfig) -> DocResult[bool] {
  if config_ok(cfg) == false { give DocResult.Err(DocError.InvalidConfig) }
  give DocResult.Ok(true)
}

proc validate_config_code(cfg: DocConfig) -> string {
  if config_ok(cfg) == false { give "invalid-config" }
  give "ok"
}

proc normalize_config(cfg: DocConfig) -> DocConfig {
  give DocConfig(cfg.strict,
                 doc_policy_pkg.normalize_page_id_len(cfg.max_page_id_len),
                 doc_policy_pkg.normalize_title_len(cfg.max_title_len),
                 doc_policy_pkg.normalize_body_len(cfg.max_body_len),
                 doc_policy_pkg.normalize_sections(cfg.max_sections))
}

proc page_new(id: string, title: string) -> DocPage {
  give DocPage(id, title, [])
}

proc page_new_checked(id: string, title: string, cfg: DocConfig) -> DocResult[DocPage] {
  let vr = validate_config(cfg)
  when vr is DocResult.Err { give DocResult.Err(vr.error) }

  if doc_validate_pkg.valid_page_id(id, cfg.max_page_id_len) == false {
    give DocResult.Err(DocError.InvalidPage)
  }
  if doc_validate_pkg.valid_title(title, cfg.max_title_len) == false {
    give DocResult.Err(DocError.InvalidPage)
  }

  give DocResult.Ok(page_new(id, title))
}

proc add_section(p: DocPage, title: string, body: string) -> DocPage {
  give DocPage(p.id, p.title, p.sections.push(DocSection(title, body)))
}

proc add_section_checked(p: DocPage, title: string, body: string, cfg: DocConfig) -> DocResult[DocPage] {
  let vr = validate_config(cfg)
  when vr is DocResult.Err { give DocResult.Err(vr.error) }

  if doc_validate_pkg.valid_title(title, cfg.max_title_len) == false {
    give DocResult.Err(DocError.InvalidSection)
  }
  if doc_validate_pkg.valid_body(body, cfg.max_body_len) == false {
    give DocResult.Err(DocError.InvalidSection)
  }
  if doc_validate_pkg.valid_sections_count(p.sections.len + 1, cfg.max_sections) == false {
    give DocResult.Err(DocError.TooManySections)
  }

  give DocResult.Ok(add_section(p, title, body))
}

proc section_count(p: DocPage) -> int {
  give p.sections.len
}

proc find_section(p: DocPage, title: string) -> DocSection {
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if p.sections[i].title == title { give p.sections[i] }
    i = i + 1
  }
  give DocSection("", "")
}

proc find_section_checked(p: DocPage, title: string) -> DocResult[DocSection] {
  let s = find_section(p, title)
  if s.title.len == 0 { give DocResult.Err(DocError.NotFound) }
  give DocResult.Ok(s)
}

proc has_section(p: DocPage, title: string) -> bool {
  give find_section(p, title).title.len > 0
}

proc section_titles(p: DocPage) -> [string] {
  let out: [string] = []
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    out = out.push(p.sections[i].title)
    i = i + 1
  }
  give out
}

proc remove_section(p: DocPage, title: string) -> DocPage {
  let out: [DocSection] = []
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if p.sections[i].title != title {
      out = out.push(p.sections[i])
    }
    i = i + 1
  }
  give DocPage(p.id, p.title, out)
}

proc remove_section_checked(p: DocPage, title: string) -> DocResult[DocPage] {
  if has_section(p, title) == false { give DocResult.Err(DocError.NotFound) }
  give DocResult.Ok(remove_section(p, title))
}

proc contains_text(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }
  let i: int = 0
  let limit = text.len - needle.len
  loop {
    if i > limit { break }
    if text.slice(i, i + needle.len) == needle { give true }
    i = i + 1
  }
  give false
}

proc search_sections(p: DocPage, needle: string) -> [DocSearchHit] {
  let out: [DocSearchHit] = []
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    let score = 0
    if contains_text(p.sections[i].title, needle) { score = score + 2 }
    if contains_text(p.sections[i].body, needle) { score = score + 1 }
    if score > 0 {
      out = out.push(DocSearchHit(p.sections[i].title, score))
    }
    i = i + 1
  }
  give out
}

proc toc_markdown(p: DocPage) -> string {
  let out = "## Table of Contents\n"
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if doc_validate_pkg.valid_toc_count(i, doc_policy_pkg.max_toc_items()) == false { break }
    out = out + "- " + p.sections[i].title + "\n"
    i = i + 1
  }
  give out + "\n"
}

proc merge_page(base: DocPage, overlay: DocPage) -> DocPage {
  let out = base
  let i: int = 0
  loop {
    if i >= overlay.sections.len { break }
    if has_section(out, overlay.sections[i].title) {
      out = remove_section(out, overlay.sections[i].title)
    }
    out = add_section(out, overlay.sections[i].title, overlay.sections[i].body)
    i = i + 1
  }
  give DocPage(base.id, overlay.title, out.sections)
}

proc render_markdown(p: DocPage) -> string {
  let out = "# " + p.title + "\n\n" + toc_markdown(p)
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    out = out + "## " + p.sections[i].title + "\n"
    out = out + p.sections[i].body + "\n\n"
    i = i + 1
  }
  give out
}

proc render_plaintext(p: DocPage) -> string {
  let out = p.title + "\n"
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    out = out + p.sections[i].title + ": " + p.sections[i].body + "\n"
    i = i + 1
  }
  give out
}

proc word_count(text: string) -> int {
  if text.len == 0 { give 0 }
  let c: int = 1
  let i: int = 0
  loop {
    if i >= text.len { break }
    if text.slice(i, i + 1) == " " { c = c + 1 }
    i = i + 1
  }
  give c
}

proc total_words(p: DocPage) -> int {
  let c = word_count(p.title)
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    c = c + word_count(p.sections[i].title)
    c = c + word_count(p.sections[i].body)
    i = i + 1
  }
  give c
}

proc doc_stats(p: DocPage) -> DocStats {
  let md = render_markdown(p)
  let empty = false
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if p.sections[i].body.len == 0 { empty = true }
    i = i + 1
  }
  give DocStats(p.sections.len, total_words(p), md.len, empty)
}

proc validate_page(p: DocPage) -> bool {
  if p.id.len == 0 || p.title.len == 0 { give false }
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if p.sections[i].title.len == 0 { give false }
    i = i + 1
  }
  give true
}

proc validate_page_code(p: DocPage, cfg: DocConfig) -> string {
  let vr = validate_config(cfg)
  when vr is DocResult.Err { give "invalid-config" }

  if doc_validate_pkg.valid_page_id(p.id, cfg.max_page_id_len) == false { give "invalid-page-id" }
  if doc_validate_pkg.valid_title(p.title, cfg.max_title_len) == false { give "invalid-page-title" }
  if doc_validate_pkg.valid_sections_count(p.sections.len, cfg.max_sections) == false { give "too-many-sections" }

  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if doc_validate_pkg.valid_title(p.sections[i].title, cfg.max_title_len) == false { give "invalid-section-title" }
    if doc_validate_pkg.valid_body(p.sections[i].body, cfg.max_body_len) == false { give "invalid-section-body" }
    i = i + 1
  }

  give "ok"
}

proc page_normalize(p: DocPage, cfg: DocConfig) -> DocPage {
  let ncfg = normalize_config(cfg)

  let id = p.id
  if id.len > ncfg.max_page_id_len { id = id.slice(0, ncfg.max_page_id_len) }

  let title = p.title
  if title.len > ncfg.max_title_len { title = title.slice(0, ncfg.max_title_len) }

  let out: [DocSection] = []
  let i: int = 0
  loop {
    if i >= p.sections.len { break }
    if out.len >= ncfg.max_sections { break }

    let st = p.sections[i].title
    if st.len > ncfg.max_title_len { st = st.slice(0, ncfg.max_title_len) }

    let sb = p.sections[i].body
    if sb.len > ncfg.max_body_len { sb = sb.slice(0, ncfg.max_body_len) }

    out = out.push(DocSection(st, sb))
    i = i + 1
  }

  give DocPage(id, title, out)
}

proc doc_validate_code(p: DocPage, cfg: DocConfig) -> string {
  give validate_page_code(p, cfg)
}

proc doc_validate(p: DocPage, cfg: DocConfig) -> bool {
  give doc_validate_code(p, cfg) == "ok"
}

proc doc_normalize(p: DocPage, cfg: DocConfig) -> DocPage {
  give page_normalize(p, cfg)
}

proc render_markdown_checked(p: DocPage, cfg: DocConfig) -> DocResult[string] {
  let code = doc_validate_code(p, cfg)
  if code != "ok" { give DocResult.Err(DocError.InvalidPage) }
  give DocResult.Ok(render_markdown(p))
}

proc doc_health(p: DocPage, cfg: DocConfig) -> DocHealth {
  let code = validate_page_code(p, cfg)
  if code != "ok" { give DocHealth(false, code, 100) }

  let pct = 0
  if cfg.max_sections > 0 {
    pct = p.sections.len * 100 / cfg.max_sections
  }
  if pct < 0 { pct = 0 }
  if pct > 100 { pct = 100 }
  if doc_validate_pkg.valid_percent(pct) == false {
    give DocHealth(false, "invalid-percent", 100)
  }

  give DocHealth(true, "ok", pct)
}

proc doc_runtime_info() -> DocRuntimeInfo {
  give DocRuntimeInfo(doc_runtime_pkg.runtime_name(),
                      doc_runtime_pkg.runtime_version(),
                      doc_runtime_pkg.supports_no_std(),
                      doc_runtime_pkg.supports_markdown(),
                      doc_runtime_pkg.supports_validation(),
                      doc_runtime_pkg.supports_diagnostics())
}

proc runtime_capabilities_hash() -> int {
  give doc_runtime_pkg.capabilities_hash()
}

proc healthcheck(cfg: DocConfig) -> DocResult[bool] {
  let vr = validate_config(cfg)
  when vr is DocResult.Err { give DocResult.Err(vr.error) }
  if doc_runtime_pkg.runtime_status() == false {
    give DocResult.Err(DocError.Internal)
  }
  give DocResult.Ok(true)
}

proc stable_api_version() -> string {
  give "2.2.0"
}

proc api_version() -> string {
  give stable_api_version()
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,with_max_sections,validate_config,validate_config_code,normalize_config,page_new,page_new_checked,add_section,add_section_checked,section_count,find_section,find_section_checked,has_section,section_titles,remove_section,remove_section_checked,contains_text,search_sections,toc_markdown,merge_page,render_markdown,render_markdown_checked,render_plaintext,word_count,total_words,doc_stats,validate_page,validate_page_code,page_normalize,doc_validate_code,doc_validate,doc_normalize,doc_health,doc_runtime_info,runtime_capabilities_hash,healthcheck,stable_api_surface_hash,version,capabilities,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,api_version,package_meta,ready"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = stable_api_version()
  give s.len * 257 + v.len * 65537
}

proc version() -> string {
  give "v2.1"
}

proc capabilities() -> [string] {
  give ["page", "section", "markdown", "search", "merge", "stats", "validate", "diagnostics"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-DOC0001" { give "invalid doc configuration" }
  if code == "VITTE-DOC0002" { give "invalid doc page" }
  if code == "VITTE-DOC0003" { give "invalid doc section" }
  give "doc diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-DOC0001" { give "normalize doc config bounds" }
  if code == "VITTE-DOC0002" { give "set non-empty page id/title within limits" }
  if code == "VITTE-DOC0003" { give "trim section title/body and retry" }
  give "review doc input and configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc stable_ready() -> bool {
  let cfg = strict_config()
  let vr = validate_config(cfg)
  when vr is DocResult.Err { give false }

  let p0 = page_new_checked("intro", "Introduction", cfg)
  when p0 is DocResult.Err { give false }

  let p1 = add_section_checked(p0.value, "Overview", "Welcome", cfg)
  when p1 is DocResult.Err { give false }

  let p2 = add_section_checked(p1.value, "Install", "Steps", cfg)
  when p2 is DocResult.Err { give false }

  let hits = search_sections(p2.value, "Welcome")
  if hits.len <= 0 { give false }

  let st = doc_stats(p2.value)
  if st.sections != 2 { give false }

  let rm = remove_section_checked(p2.value, "Install")
  when rm is DocResult.Err { give false }

  if has_section(rm.value, "Install") { give false }
  if validate_page_code(p1.value, cfg) != "ok" { give false }
  let md = render_markdown_checked(p1.value, cfg)
  when md is DocResult.Err { give false }
  if runtime_capabilities_hash() <= 0 { give false }
  if stable_api_surface_hash() <= 0 { give false }
  give true
}

proc ready() -> bool {
  give stable_ready()
}

proc package_meta() -> string {
  give "vitte/doc"
}

<<< ROLE-CONTRACT
package: vitte/doc
role: Generation documentation et index de recherche
input_contract: Valeurs metier explicites, deja parsees et typables
output_contract: Sorties stables, observables et compatibles avec les autres packages
boundary: Ne remplace pas les autres couches; respecte la separation de roles
versioning_note: stable_api_version=2.2.0
>>>
