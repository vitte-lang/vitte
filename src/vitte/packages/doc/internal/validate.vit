space vitte/doc/internal/validate

proc valid_page_id(id: string, max_len: int) -> bool {
  if id.len == 0 { give false }
  give id.len <= max_len
}

proc valid_title(title: string, max_len: int) -> bool {
  if title.len == 0 { give false }
  give title.len <= max_len
}

proc valid_body(body: string, max_len: int) -> bool {
  give body.len <= max_len
}

proc valid_sections_count(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_toc_count(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_non_empty(value: string) -> bool {
  give value.len > 0
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
