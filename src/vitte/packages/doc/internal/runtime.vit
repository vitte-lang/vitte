space vitte/doc/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "doc-runtime-v2"
}

proc runtime_version() -> string {
  give "2.1"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_markdown() -> bool {
  give true
}

proc supports_validation() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}

proc supports_search() -> bool {
  give true
}

proc capabilities_hash() -> int {
  let s = runtime_name() + runtime_version()
  give s.len * 257
}
