
space vitte/crabcli/internal/validate

use vitte/packages/crabcli/compat as cli_compat
use vitte/packages/crabbuilder/prelude as builder_prelude
use vitte/packages/crabbuilder/internal/validate as builder_validate
use vitte/packages/crabbuilder/internal/runtime as builder_runtime
use vitte/packages/crabbuilder/internal/diagnostics as builder_diagnostics
use vitte/packages/crabbuilder/internal/policy as builder_policy

<<< =========================================================
    Validation domain (max max)
========================================================= >>>

form ValidateCheck {
    name: string,
    ok: bool,
    severity: string,
    message: string
}

form ValidateSummary {
    ok: bool,
    total: i32,
    passed: i32,
    failed: i32,
    warnings: i32,
    notes: [string]
}

<<< =========================================================
    Helpers
========================================================= >>>

proc push_check(list: [ValidateCheck], item: ValidateCheck) -> [ValidateCheck] {
    give list + [item]
}

proc push_note(list: [string], item: string) -> [string] {
    give list + [item]
}

proc bool_to_string(v: bool) -> string {
    if v { give "true" }
    give "false"
}

proc count(list: [ValidateCheck]) -> i32 {
    make n = 0
    for _ in list { set n = n + 1 }
    give n
}

proc count_passed(list: [ValidateCheck]) -> i32 {
    make n = 0
    for item in list { if item.ok { set n = n + 1 } }
    give n
}

proc count_failed(list: [ValidateCheck]) -> i32 {
    make n = 0
    for item in list { if not item.ok and item.severity == "error" { set n = n + 1 } }
    give n
}

proc count_warnings(list: [ValidateCheck]) -> i32 {
    make n = 0
    for item in list { if not item.ok and item.severity == "warn" { set n = n + 1 } }
    give n
}

<<< =========================================================
    Checks
========================================================= >>>

proc check_runtime() -> ValidateCheck {
    make b = builder_prelude.default_builder()
    make r = builder_runtime.execute(b)

    give ValidateCheck {
        name: "runtime",
        ok: r.ok,
        severity: "error",
        message: "runtime execution"
    }
}

proc check_validate() -> ValidateCheck {
    make b = builder_prelude.default_builder()
    make v = builder_validate.validate_builder_integrated(b)

    give ValidateCheck {
        name: "validate",
        ok: v.ok,
        severity: "error",
        message: "builder validation"
    }
}

proc check_diagnostics() -> ValidateCheck {
    make b = builder_prelude.default_builder()
    make c = cli_compat.plan_target(b.config.target)
    make d = builder_diagnostics.summarize_builder_with_compat(b, c)

    give ValidateCheck {
        name: "diagnostics",
        ok: d.ok,
        severity: "warn",
        message: "diagnostics health"
    }
}

proc check_policy() -> ValidateCheck {
    make b = builder_prelude.default_builder()
    make p = builder_policy.evaluate(b)

    give ValidateCheck {
        name: "policy",
        ok: p.ok,
        severity: "error",
        message: "policy evaluation"
    }
}

proc check_compat() -> ValidateCheck {
    make target = cli_compat.default_target()
    make c = cli_compat.plan_target(target)

    give ValidateCheck {
        name: "compat",
        ok: c.ok,
        severity: "error",
        message: "target compatibility"
    }
}

<<< =========================================================
    Aggregation
========================================================= >>>

proc collect() -> ValidateSummary {
    make checks = []
    make notes = []

    set checks = push_check(checks, check_runtime())
    set checks = push_check(checks, check_validate())
    set checks = push_check(checks, check_diagnostics())
    set checks = push_check(checks, check_policy())
    set checks = push_check(checks, check_compat())

    set notes = push_note(notes, "total=" + (count(checks) as string))
    set notes = push_note(notes, "passed=" + (count_passed(checks) as string))
    set notes = push_note(notes, "failed=" + (count_failed(checks) as string))

    give ValidateSummary {
        ok: count_failed(checks) == 0,
        total: count(checks),
        passed: count_passed(checks),
        failed: count_failed(checks),
        warnings: count_warnings(checks),
        notes: notes
    }
}

<<< =========================================================
    Printing
========================================================= >>>

proc print_summary(s: ValidateSummary) {
    emit "==== CRABCLI VALIDATE ===="
    emit "ok=" + bool_to_string(s.ok)
    emit "total=" + (s.total as string)
    emit "passed=" + (s.passed as string)
    emit "failed=" + (s.failed as string)
    emit "warnings=" + (s.warnings as string)

    for n in s.notes {
        emit n
    }
}

<<< =========================================================
    Entry
========================================================= >>>

entry main at vitte/crabcli/internal/validate {
    make s = collect()
    print_summary(s)
}
