space vitte/json/internal/policy

proc default_timeout_ms() -> int {
  give 1000
}

proc default_retry_budget() -> int {
  give 1
}

proc default_strict() -> bool {
  give true
}

proc normalize_timeout_ms(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 60000 { out = 60000 }
  give out
}

proc normalize_retry_budget(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > 32 { out = 32 }
  give out
}
