space vitte/json/internal/validate

proc valid_timeout_ms(timeout_ms: int) -> bool {
  give timeout_ms > 0 && timeout_ms <= 60000
}

proc valid_retry_budget(retry_budget: int) -> bool {
  give retry_budget >= 0 && retry_budget <= 32
}

proc valid_options(max_bytes: int, max_depth: int, max_nodes: int) -> bool {
  if max_bytes <= 0 { give false }
  if max_depth <= 0 { give false }
  give max_nodes > 0
}
