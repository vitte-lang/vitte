space vitte/bridge/internal/validate

proc has_space(value: string) -> bool {
  let i: int = 0
  loop {
    if i >= value.len { break }
    if value.slice(i, i + 1) == " " { give true }
    i = i + 1
  }
  give false
}

proc valid_endpoint(endpoint: string, max_len: int) -> bool {
  if endpoint.len == 0 { give false }
  if endpoint.len > max_len { give false }
  if has_space(endpoint) { give false }
  give true
}

proc valid_packet_size(size: int, max_size: int) -> bool {
  if size < 0 { give false }
  give size <= max_size
}

proc valid_hops(hops: int, max_hops: int) -> bool {
  if hops < 1 { give false }
  give hops <= max_hops
}

proc valid_inflight(value: int, max_inflight: int) -> bool {
  if value < 0 { give false }
  give value <= max_inflight
}

proc valid_timeout_ms(value: int, max_timeout_ms: int) -> bool {
  if value < 0 { give false }
  give value <= max_timeout_ms
}

proc valid_retry_budget(value: int, max_retry_budget: int) -> bool {
  if value < 0 { give false }
  give value <= max_retry_budget
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
