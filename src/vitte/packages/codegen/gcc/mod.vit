<<<
mod.vit
package vitte/codegen/gcc
>>>

space vitte/codegen/gcc

use vitte/codegen/gcc/internal/runtime as codegen_gcc_runtime_pkg
use vitte/codegen/gcc/internal/validate as codegen_gcc_validate_pkg
use vitte/codegen/gcc/internal/policy as codegen_gcc_policy_pkg


form CompileUnit {
  source_path: string
  output_path: string
  opt_level: int
  debug: bool
  pic: bool
}

proc unit(source_path: string, output_path: string, opt_level: int) -> CompileUnit {
  give CompileUnit(source_path, output_path, opt_level, false, false)
}

proc with_debug(u: CompileUnit, debug: bool) -> CompileUnit {
  give CompileUnit(u.source_path, u.output_path, u.opt_level, debug, u.pic)
}

proc with_pic(u: CompileUnit, pic: bool) -> CompileUnit {
  give CompileUnit(u.source_path, u.output_path, u.opt_level, u.debug, pic)
}

proc command(u: CompileUnit) -> string {
  let out = "gcc -O" + u.opt_level.to_string()
  if u.debug { out = out + " -g" }
  if u.pic { out = out + " -fPIC" }
  out = out + " " + u.source_path + " -o " + u.output_path
  give out
}

proc validate(u: CompileUnit) -> bool {
  if u.source_path.len == 0  or  u.output_path.len == 0 { give false }
  if u.opt_level < 0  or  u.opt_level > 3 { give false }
  give true
}

proc profile(u: CompileUnit) -> string {
  give "backend=gcc,opt=" + u.opt_level.to_string() + ",debug=" + u.debug.to_string()
}

proc api_version() -> string {
  give version()
}

proc validate_config_code(cfg: CodegenGccConfig) -> string {
  let vr = validate_config(cfg)
  when vr is CodegenGccResult.Err { give "VITTE-CODEGEN_GCC0001" }
  give "VITTE-CODEGEN_GCC0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-CODEGEN_GCC"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,api_version,api_compatible_with,contract_summary,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/codegen/gcc,config=(CodegenGccConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(CodegenGccResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-CODEGEN_GCC0000" { give ["no action required"] }
  if code == "VITTE-CODEGEN_GCC0001" {
    give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"]
  }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() +
       " code=" + code +
       " sev=" + diagnostics_severity(code) +
       " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: CodegenGccConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is CodegenGccResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while i < caps.len {
    out = out + "," + caps[i]
    i += 1
  }
  give out
}

proc contract_report() -> string {
  give contract_summary() +
       " fp=" + package_contract_fingerprint().to_string() +
       " hc=" + healthcheck_default_code() +
       " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give true
}

proc package_meta() -> string {
  give "vitte/codegen/gcc"
}

form CodegenGccConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick CodegenGccError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick CodegenGccResult[T] {
  Ok(value: T)
  Err(error: CodegenGccError)
}

form CodegenGccRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> CodegenGccConfig {
  give CodegenGccConfig(true, codegen_gcc_policy_pkg.default_timeout_ms(), codegen_gcc_policy_pkg.default_retry_budget())
}

proc strict_config() -> CodegenGccConfig {
  let cfg = default_config()
  give CodegenGccConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: CodegenGccConfig) -> CodegenGccConfig {
  let timeout_ms = cfg.timeout_ms
  let retry_budget = cfg.retry_budget
  if timeout_ms < 1 { timeout_ms = 1 }
  if timeout_ms > 60000 { timeout_ms = 60000 }
  if retry_budget < 0 { retry_budget = 0 }
  if retry_budget > 32 { retry_budget = 32 }
  give CodegenGccConfig(cfg.strict, timeout_ms, retry_budget)
}

proc validate_config(cfg: CodegenGccConfig) -> CodegenGccResult[bool] {
  let nc = normalize_config(cfg)
  if codegen_gcc_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give CodegenGccResult.Err(CodegenGccError.InvalidConfig)
  }
  if codegen_gcc_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give CodegenGccResult.Err(CodegenGccError.InvalidConfig)
  }
  give CodegenGccResult.Ok(true)
}

proc healthcheck(cfg: CodegenGccConfig) -> CodegenGccResult[bool] {
  let vr: CodegenGccResult[bool] = validate_config(cfg)
  when vr is CodegenGccResult.Err {
    give CodegenGccResult.Err(vr.error)
  }
  if codegen_gcc_runtime_pkg.runtime_status() == false {
    give CodegenGccResult.Err(CodegenGccError.Internal)
  }
  give CodegenGccResult.Ok(true)
}

proc runtime_info() -> CodegenGccRuntimeInfo {
  give CodegenGccRuntimeInfo(codegen_gcc_runtime_pkg.runtime_name(),
                             codegen_gcc_runtime_pkg.runtime_version(),
                             codegen_gcc_runtime_pkg.supports_diagnostics())
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck", "api-contract", "abi-contract", "diagnostics", "contract-summary"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-CODEGEN_GCC0001" {
    give "invalid package configuration"
  }
  give "codegen/gcc diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

