mod.vit
package vitte/codegen/cranelift
>>>

space vitte/codegen/cranelift

use vitte/codegen/cranelift/internal/runtime as codegen_cranelift_runtime_pkg
use vitte/codegen/cranelift/internal/validate as codegen_cranelift_validate_pkg
use vitte/codegen/cranelift/internal/policy as codegen_cranelift_policy_pkg


form ClifUnit {
  clif_path: string
  obj_path: string
  isa: string
  opt: string
}

proc clif_unit(clif_path: string, obj_path: string, isa: string) -> ClifUnit {
  give ClifUnit(clif_path, obj_path, isa, "speed")
}

proc with_opt(u: ClifUnit, opt: string) -> ClifUnit {
  give ClifUnit(u.clif_path, u.obj_path, u.isa, opt)
}

proc compile_command(u: ClifUnit) -> string {
  give "clif-util compile " + u.clif_path + " --isa " + u.isa + " --opt " + u.opt + " -o " + u.obj_path
}

proc preopt_command(u: ClifUnit) -> string {
  give "clif-util optimize " + u.clif_path + " --opt " + u.opt
}

proc validate(u: ClifUnit) -> bool {
  give u.clif_path.len > 0 && u.obj_path.len > 0 && u.isa.len > 0
}

proc api_version() -> string {
  give version()
}

proc validate_config_code(cfg: CodegenCraneliftConfig) -> string {
  let vr = validate_config(cfg)
  when vr is CodegenCraneliftResult.Err { give "VITTE-CODEGEN_CRANELIFT0001" }
  give "VITTE-CODEGEN_CRANELIFT0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-CODEGEN_CRANELIFT"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,api_version,api_compatible_with,contract_summary,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/codegen/cranelift,config=(CodegenCraneliftConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(CodegenCraneliftResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-CODEGEN_CRANELIFT0000" { give ["no action required"] }
  if code == "VITTE-CODEGEN_CRANELIFT0001" {
    give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"]
  }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() +
       " code=" + code +
       " sev=" + diagnostics_severity(code) +
       " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: CodegenCraneliftConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is CodegenCraneliftResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  loop {
    if i >= caps.len { break }
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_report() -> string {
  give contract_summary() +
       " fp=" + package_contract_fingerprint().to_string() +
       " hc=" + healthcheck_default_code() +
       " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give true
}

proc package_meta() -> string {
  give "vitte/codegen/cranelift"
}

form CodegenCraneliftConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick CodegenCraneliftError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick CodegenCraneliftResult[T] {
  Ok(value: T)
  Err(error: CodegenCraneliftError)
}

form CodegenCraneliftRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> CodegenCraneliftConfig {
  give CodegenCraneliftConfig(true, codegen_cranelift_policy_pkg.default_timeout_ms(), codegen_cranelift_policy_pkg.default_retry_budget())
}

proc strict_config() -> CodegenCraneliftConfig {
  let cfg = default_config()
  give CodegenCraneliftConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: CodegenCraneliftConfig) -> CodegenCraneliftConfig {
  let timeout_ms = cfg.timeout_ms
  let retry_budget = cfg.retry_budget
  if timeout_ms < 1 { timeout_ms = 1 }
  if timeout_ms > 60000 { timeout_ms = 60000 }
  if retry_budget < 0 { retry_budget = 0 }
  if retry_budget > 32 { retry_budget = 32 }
  give CodegenCraneliftConfig(cfg.strict, timeout_ms, retry_budget)
}

proc validate_config(cfg: CodegenCraneliftConfig) -> CodegenCraneliftResult[bool] {
  let nc = normalize_config(cfg)
  if codegen_cranelift_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give CodegenCraneliftResult.Err(CodegenCraneliftError.InvalidConfig)
  }
  if codegen_cranelift_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give CodegenCraneliftResult.Err(CodegenCraneliftError.InvalidConfig)
  }
  give CodegenCraneliftResult.Ok(true)
}

proc healthcheck(cfg: CodegenCraneliftConfig) -> CodegenCraneliftResult[bool] {
  let vr: CodegenCraneliftResult[bool] = validate_config(cfg)
  when vr is CodegenCraneliftResult.Err {
    give CodegenCraneliftResult.Err(vr.error)
  }
  if codegen_cranelift_runtime_pkg.runtime_status() == false {
    give CodegenCraneliftResult.Err(CodegenCraneliftError.Internal)
  }
  give CodegenCraneliftResult.Ok(true)
}

proc runtime_info() -> CodegenCraneliftRuntimeInfo {
  give CodegenCraneliftRuntimeInfo(codegen_cranelift_runtime_pkg.runtime_name(),
                                   codegen_cranelift_runtime_pkg.runtime_version(),
                                   codegen_cranelift_runtime_pkg.supports_diagnostics())
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck", "api-contract", "abi-contract", "diagnostics", "contract-summary"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-CODEGEN_CRANELIFT0001" {
    give "invalid package configuration"
  }
  give "codegen/cranelift diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

