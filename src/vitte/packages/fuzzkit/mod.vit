<<<
mod.vit
package vitte/fuzzkit
>>>

space vitte/fuzzkit

use vitte/fuzzkit/internal/policy as fuzzkit_policy_pkg
use vitte/fuzzkit/internal/runtime as fuzzkit_runtime_pkg
use vitte/fuzzkit/internal/validate as fuzzkit_validate_pkg

form FuzzkitConfig {
  seed: int
  iterations: int
  deterministic: bool
}

pick FuzzkitError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick FuzzkitResult[T] {
  Ok(value: T)
  Err(error: FuzzkitError)
}

form FuzzCase {
  id: string
  payload: string
}

form FuzzPlan {
  seed: int
  iterations: int
  corpus: [FuzzCase]
}

form FuzzStats {
  executed: int
  failures: int
  coverage_hint: int
}

form FuzzRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_deterministic: bool
  supports_diagnostics: bool
}

form FuzzHealth {
  ok: bool
  code: string
}

proc default_config() -> FuzzkitConfig {
  give FuzzkitConfig(0, fuzzkit_policy_pkg.default_iterations(), fuzzkit_policy_pkg.default_deterministic())
}

proc strict_config() -> FuzzkitConfig {
  let cfg = default_config()
  give FuzzkitConfig(cfg.seed, cfg.iterations, true)
}

proc with_seed(cfg: FuzzkitConfig, seed: int) -> FuzzkitConfig {
  give FuzzkitConfig(fuzzkit_policy_pkg.normalize_seed(seed), cfg.iterations, cfg.deterministic)
}

proc with_iterations(cfg: FuzzkitConfig, iterations: int) -> FuzzkitConfig {
  give FuzzkitConfig(cfg.seed, fuzzkit_policy_pkg.normalize_iterations(iterations), cfg.deterministic)
}

proc normalize_config(cfg: FuzzkitConfig) -> FuzzkitConfig {
  give FuzzkitConfig(fuzzkit_policy_pkg.normalize_seed(cfg.seed), fuzzkit_policy_pkg.normalize_iterations(cfg.iterations), cfg.deterministic)
}

proc validate_config(cfg: FuzzkitConfig) -> FuzzkitResult[bool] {
  let nc = normalize_config(cfg)
  if fuzzkit_validate_pkg.valid_seed(nc.seed) == false {
    give FuzzkitResult.Err(FuzzkitError.InvalidConfig)
  }
  if fuzzkit_validate_pkg.valid_iterations(nc.iterations) == false {
    give FuzzkitResult.Err(FuzzkitError.InvalidConfig)
  }
  if fuzzkit_validate_pkg.valid_deterministic_request(nc.deterministic, fuzzkit_runtime_pkg.supports_deterministic()) == false {
    give FuzzkitResult.Err(FuzzkitError.Unsupported)
  }
  give FuzzkitResult.Ok(true)
}

proc healthcheck(cfg: FuzzkitConfig) -> FuzzkitResult[bool] {
  let vr: FuzzkitResult[bool] = validate_config(cfg)
  when vr is FuzzkitResult.Err { give FuzzkitResult.Err(vr.error) }
  if fuzzkit_runtime_pkg.runtime_status() == false {
    give FuzzkitResult.Err(FuzzkitError.Internal)
  }
  if fuzzkit_runtime_pkg.runtime_name().len == 0 {
    give FuzzkitResult.Err(FuzzkitError.Internal)
  }
  give FuzzkitResult.Ok(true)
}

proc healthcheck_info(cfg: FuzzkitConfig) -> FuzzkitResult[FuzzHealth] {
  let hr = healthcheck(cfg)
  when hr is FuzzkitResult.Err { give FuzzkitResult.Err(hr.error) }
  give FuzzkitResult.Ok(FuzzHealth(true, "ok"))
}

proc plan_new(cfg: FuzzkitConfig) -> FuzzkitResult[FuzzPlan] {
  let vr: FuzzkitResult[bool] = validate_config(cfg)
  when vr is FuzzkitResult.Err { give FuzzkitResult.Err(vr.error) }
  give FuzzkitResult.Ok(FuzzPlan(cfg.seed, cfg.iterations, []))
}

proc plan_add_case(plan: FuzzPlan, id: string, payload: string) -> FuzzkitResult[FuzzPlan] {
  if fuzzkit_validate_pkg.valid_case_id(id) == false {
    give FuzzkitResult.Err(FuzzkitError.InvalidConfig)
  }
  if fuzzkit_validate_pkg.valid_payload(payload) == false {
    give FuzzkitResult.Err(FuzzkitError.InvalidConfig)
  }
  give FuzzkitResult.Ok(FuzzPlan(plan.seed, plan.iterations, plan.corpus.push(FuzzCase(id, payload))))
}

proc estimate_coverage(plan: FuzzPlan) -> int {
  if plan.corpus.len == 0 { give 0 }
  let cap = plan.corpus.len * 3
  let max = fuzzkit_policy_pkg.coverage_cap()
  if cap > max { give max }
  give cap
}

proc run_plan(plan: FuzzPlan) -> FuzzStats {
  if plan.iterations <= 0 || plan.corpus.len == 0 {
    give FuzzStats(0, 0, 0)
  }
  let executed = plan.iterations
  let failures = executed / 10
  give FuzzStats(executed, failures, estimate_coverage(plan))
}

proc should_stop(stats: FuzzStats, max_failures: int) -> bool {
  if fuzzkit_validate_pkg.valid_max_failures(max_failures) == false { give true }
  give stats.failures >= max_failures
}

proc default_stop_threshold() -> int {
  give fuzzkit_policy_pkg.default_max_failures()
}

proc next_seed(seed: int, step: int) -> int {
  let s = step
  if s <= 0 { s = fuzzkit_policy_pkg.default_seed_step() }
  give seed + s
}

proc runtime_info() -> FuzzRuntimeInfo {
  give FuzzRuntimeInfo(fuzzkit_runtime_pkg.runtime_name(),
                       fuzzkit_runtime_pkg.runtime_version(),
                       fuzzkit_runtime_pkg.supports_deterministic(),
                       fuzzkit_runtime_pkg.supports_diagnostics())
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["corpus", "coverage-hint", "deterministic", "healthcheck", "seeded-plans", "validated-cases"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-FUZZ0001" { give "invalid fuzz config: seed or iterations out of range" }
  if code == "VITTE-FUZZ0002" { give "empty corpus: add at least one fuzz case" }
  if code == "VITTE-FUZZ0003" { give "invalid fuzz case payload or id" }
  give "fuzzkit diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-FUZZ0001" { give "set seed >= 0 and iterations in (0..1000000]" }
  if code == "VITTE-FUZZ0002" { give "call plan_add_case before run_plan" }
  if code == "VITTE-FUZZ0003" { give "set non-empty id and payload <= 4096 bytes" }
  give "review fuzz plan configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc package_meta() -> string {
  give "vitte/fuzzkit"
}

proc api_version() -> string {
  give version()
}

proc diagnostics_namespace() -> string {
  give "VITTE-FUZZKIT"
}

proc validate_config_code(cfg: FuzzkitConfig) -> string {
  let vr = validate_config(cfg)
  when vr is FuzzkitResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/fuzzkit,config=(FuzzkitConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(FuzzkitResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = diagnostics_namespace() + "0000"
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == diagnostics_namespace() + "0000" { give ["no action required"] }
  if code == diagnostics_namespace() + "0001" { give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"] }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: FuzzkitConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is FuzzkitResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while i < caps.len {
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give fuzzkit_runtime_pkg.runtime_status()
}

