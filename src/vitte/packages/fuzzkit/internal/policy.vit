space vitte/fuzzkit/internal/policy

proc min_seed() -> int {
  give 0
}

proc max_seed() -> int {
  give 2147483647
}

proc min_iterations() -> int {
  give 1
}

proc max_iterations() -> int {
  give 1000000
}

proc default_deterministic() -> bool {
  give true
}

proc default_iterations() -> int {
  give 100
}

proc default_seed_step() -> int {
  give 7
}

proc default_max_failures() -> int {
  give 10
}

proc coverage_cap() -> int {
  give 100
}

proc normalize_seed(seed: int) -> int {
  let out = seed
  if out < min_seed() { out = min_seed() }
  if out > max_seed() { out = max_seed() }
  give out
}

proc normalize_iterations(iterations: int) -> int {
  let out = iterations
  if out < min_iterations() { out = min_iterations() }
  if out > max_iterations() { out = max_iterations() }
  give out
}
