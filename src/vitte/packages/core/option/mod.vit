space std/core/option

proc core_option_default_timeout_ms() -> int { give 1500 }
proc core_option_default_retry_budget() -> int { give 2 }
proc core_option_valid_timeout_ms(v: int) -> bool { give v > 0 && v <= 600000 }
proc core_option_valid_retry_budget(v: int) -> bool { give v >= 0 && v <= 64 }
proc core_option_runtime_status() -> bool { give true }

pick Option[T] {
  Some(value: T)
  None
}

form CoreOptionConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick CoreOptionError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick CoreOptionResult[T] {
  Ok(value: T)
  Err(error: CoreOptionError)
}

proc default_config() -> CoreOptionConfig {
  give CoreOptionConfig(true, core_option_default_timeout_ms(), core_option_default_retry_budget())
}

proc validate_config(cfg: CoreOptionConfig) -> CoreOptionResult[bool] {
  if core_option_valid_timeout_ms(cfg.timeout_ms) == false {
    give CoreOptionResult.Err(CoreOptionError.InvalidConfig)
  }
  if core_option_valid_retry_budget(cfg.retry_budget) == false {
    give CoreOptionResult.Err(CoreOptionError.InvalidConfig)
  }
  give CoreOptionResult.Ok(true)
}

proc healthcheck(cfg: CoreOptionConfig) -> CoreOptionResult[bool] {
  let vr: CoreOptionResult[bool] = validate_config(cfg)
  when vr is CoreOptionResult.Err {
    give CoreOptionResult.Err(vr.error)
  }
  if core_option_runtime_status() == false {
    give CoreOptionResult.Err(CoreOptionError.Internal)
  }
  give CoreOptionResult.Ok(true)
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-COREOPTI0001" {
    give "invalid package configuration"
  }
  give "core/option diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc package_meta() -> string {
  give "vitte/core/option"
}

