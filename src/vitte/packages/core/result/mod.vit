space std/core/result

proc core_result_default_timeout_ms() -> int { give 1500 }
proc core_result_default_retry_budget() -> int { give 2 }
proc core_result_valid_timeout_ms(v: int) -> bool { give v > 0 && v <= 600000 }
proc core_result_valid_retry_budget(v: int) -> bool { give v >= 0 && v <= 64 }
proc core_result_runtime_status() -> bool { give true }

pick Result[T, E] {
  Ok(value: T)
  Err(error: E)
}

form CoreResultConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick CoreResultError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick CoreResultResult[T] {
  Ok(value: T)
  Err(error: CoreResultError)
}

proc default_config() -> CoreResultConfig {
  give CoreResultConfig(true, core_result_default_timeout_ms(), core_result_default_retry_budget())
}

proc validate_config(cfg: CoreResultConfig) -> CoreResultResult[bool] {
  if core_result_valid_timeout_ms(cfg.timeout_ms) == false {
    give CoreResultResult.Err(CoreResultError.InvalidConfig)
  }
  if core_result_valid_retry_budget(cfg.retry_budget) == false {
    give CoreResultResult.Err(CoreResultError.InvalidConfig)
  }
  give CoreResultResult.Ok(true)
}

proc healthcheck(cfg: CoreResultConfig) -> CoreResultResult[bool] {
  let vr: CoreResultResult[bool] = validate_config(cfg)
  when vr is CoreResultResult.Err {
    give CoreResultResult.Err(vr.error)
  }
  if core_result_runtime_status() == false {
    give CoreResultResult.Err(CoreResultError.Internal)
  }
  give CoreResultResult.Ok(true)
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-CORERESU0001" {
    give "invalid package configuration"
  }
  give "core/result diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc package_meta() -> string {
  give "vitte/core/result"
}

