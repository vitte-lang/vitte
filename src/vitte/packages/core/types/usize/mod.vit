space std/core/types/usize

form CoreTypesUsizeConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick CoreTypesUsizeError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick CoreTypesUsizeResult {
  Ok
  Err(error: CoreTypesUsizeError)
}

proc default_config() -> CoreTypesUsizeConfig {
  give CoreTypesUsizeConfig(true, 1000, 3)
}

proc validate_config(cfg: CoreTypesUsizeConfig) -> CoreTypesUsizeResult {
  if cfg.timeout_ms <= 0 {
    give CoreTypesUsizeResult.Err(CoreTypesUsizeError.InvalidConfig)
  }
  if cfg.retry_budget < 0 {
    give CoreTypesUsizeResult.Err(CoreTypesUsizeError.InvalidConfig)
  }
  give CoreTypesUsizeResult.Ok
}

proc healthcheck(cfg: CoreTypesUsizeConfig) -> CoreTypesUsizeResult {
  let vr: CoreTypesUsizeResult = validate_config(cfg)
  when vr is CoreTypesUsizeResult.Err {
    give CoreTypesUsizeResult.Err(vr.error)
  }
  give CoreTypesUsizeResult.Ok
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-CORETYPE0001" {
    give "invalid package configuration"
  }
  give "core/types/usize diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc package_meta() -> string {
  give "vitte/core/types/usize"
}

<<< ROLE-CONTRACT
package: vitte/core/types/usize
owner: @vitte/core
stability: experimental
since: 3.0.0
deprecated_in: -
role: Facade publique stable
input_contract: Config explicite et typable
output_contract: Resultats stables et predictibles
boundary: Implementation privee sous vitte/core/types/usize/internal/*
compat_policy: additive-only
api_version: v1
>>>




