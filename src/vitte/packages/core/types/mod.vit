space std/core/types

use vitte/core/types/internal/runtime as core_types_runtime_pkg
use vitte/core/types/internal/validate as core_types_validate_pkg
use vitte/core/types/internal/policy as core_types_policy_pkg

type i32 = int
type int = int
type usize = usize
type string = string
type bool = bool
type Unit = bool

form CoreTypesConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick CoreTypesError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick CoreTypesResult[T] {
  Ok(value: T)
  Err(error: CoreTypesError)
}

proc default_config() -> CoreTypesConfig {
  give CoreTypesConfig(true, core_types_policy_pkg.default_timeout_ms(), core_types_policy_pkg.default_retry_budget())
}

proc validate_config(cfg: CoreTypesConfig) -> CoreTypesResult[bool] {
  if core_types_validate_pkg.valid_timeout_ms(cfg.timeout_ms) == false {
    give CoreTypesResult.Err(CoreTypesError.InvalidConfig)
  }
  if core_types_validate_pkg.valid_retry_budget(cfg.retry_budget) == false {
    give CoreTypesResult.Err(CoreTypesError.InvalidConfig)
  }
  give CoreTypesResult.Ok(true)
}

proc healthcheck(cfg: CoreTypesConfig) -> CoreTypesResult[bool] {
  let vr: CoreTypesResult[bool] = validate_config(cfg)
  when vr is CoreTypesResult.Err {
    give CoreTypesResult.Err(vr.error)
  }
  if core_types_runtime_pkg.runtime_status() == false {
    give CoreTypesResult.Err(CoreTypesError.Internal)
  }
  give CoreTypesResult.Ok(true)
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck"]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-CORETYPE0001" {
    give "invalid package configuration"
  }
  give "core/types diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review package configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc package_meta() -> string {
  give "vitte/core/types"
}

