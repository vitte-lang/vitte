space vitte/circuit_breaker/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "circuit-breaker-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_half_open() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
