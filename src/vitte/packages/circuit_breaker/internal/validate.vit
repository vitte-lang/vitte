space vitte/circuit_breaker/internal/validate

proc valid_threshold(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_cooldown_ticks(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_tick(value: int) -> bool {
  give value >= 0
}

proc valid_counter(value: int) -> bool {
  give value >= 0
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
