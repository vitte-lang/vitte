<<<
mod.vit
package vitte/orm
>>>

space vitte/orm

use vitte/orm/internal/policy as orm_policy_pkg
use vitte/orm/internal/runtime as orm_runtime_pkg
use vitte/orm/internal/validate as orm_validate_pkg

pick OrmError {
  None
  InvalidModel
  InvalidTable
  InvalidPrimaryKey
  InvalidField
  InvalidSelect
  InvalidWhere
  InvalidOrder
  InvalidLimit
  InvalidOffset
}

form OrmField {
  name: string
  kind: string
  nullable: bool
  indexed: bool
}

form OrmModel {
  table: string
  primary_key: string
  fields: [OrmField]
  soft_delete: bool
}

form Query {
  table: string
  select_cols: [string]
  where_clauses: [string]
  order_bys: [string]
  limit: int
  offset: int
  include_deleted: bool
}

proc is_alpha_num_or_underscore(ch: string) -> bool {
  if ch == "_" { give true }
  if ch >= "a" && ch <= "z" { give true }
  if ch >= "A" && ch <= "Z" { give true }
  if ch >= "0" && ch <= "9" { give true }
  give false
}

proc is_identifier(text: string) -> bool {
  if text.len == 0 { give false }
  if text.slice(0, 1) >= "0" && text.slice(0, 1) <= "9" { give false }
  let i: int = 0
  while i < text.len {
    let ch = text.slice(i, i + 1)
    if !is_alpha_num_or_underscore(ch) { give false }
    i += 1
  }
  give true
}

proc contains(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }
  let i: int = 0
  while i + needle.len <= text.len {
    if text.slice(i, i + needle.len) == needle { give true }
    i += 1
  }
  give false
}

proc join(parts: [string], sep: string) -> string {
  if parts.len == 0 { give "" }
  let out = parts[0]
  let i: int = 1
  while i < parts.len {
    out = out + sep + parts[i]
    i += 1
  }
  give out
}

proc orm_field(name: string, kind: string, nullable: bool, indexed: bool) -> OrmField {
  give OrmField(name, kind, nullable, indexed)
}

proc model(table: string, primary_key: string, fields: [OrmField], soft_delete: bool) -> OrmModel {
  give OrmModel(table, primary_key, fields, soft_delete)
}

proc default_query(table: string) -> Query {
  give Query(table, [], [], [], 100, 0, false)
}

proc with_select(q: Query, col: string) -> Query {
  let cols = q.select_cols.push(col)
  give Query(q.table, cols, q.where_clauses, q.order_bys, q.limit, q.offset, q.include_deleted)
}

proc with_where(q: Query, clause: string) -> Query {
  let conds = q.where_clauses.push(clause)
  give Query(q.table, q.select_cols, conds, q.order_bys, q.limit, q.offset, q.include_deleted)
}

proc with_order(q: Query, order_by: string) -> Query {
  let orders = q.order_bys.push(order_by)
  give Query(q.table, q.select_cols, q.where_clauses, orders, q.limit, q.offset, q.include_deleted)
}

proc with_limit(q: Query, limit: int) -> Query {
  let lim = limit
  if lim < 1 { lim = 1 }
  if lim > 1000 { lim = 1000 }
  give Query(q.table, q.select_cols, q.where_clauses, q.order_bys, lim, q.offset, q.include_deleted)
}

proc with_offset(q: Query, offset: int) -> Query {
  let off = offset
  if off < 0 { off = 0 }
  give Query(q.table, q.select_cols, q.where_clauses, q.order_bys, q.limit, off, q.include_deleted)
}

proc with_include_deleted(q: Query, include_deleted: bool) -> Query {
  give Query(q.table, q.select_cols, q.where_clauses, q.order_bys, q.limit, q.offset, include_deleted)
}

proc paginate(q: Query, page: int, page_size: int) -> Query {
  let p = page
  if p < 0 { p = 0 }
  let sz = page_size
  if sz < 1 { sz = 1 }
  if sz > 1000 { sz = 1000 }
  give Query(q.table, q.select_cols, q.where_clauses, q.order_bys, sz, p * sz, q.include_deleted)
}

proc has_field(m: OrmModel, field_name: string) -> bool {
  let i: int = 0
  while i < m.fields.len {
    if m.fields[i].name == field_name { give true }
    i += 1
  }
  give false
}

proc field_count(m: OrmModel) -> int {
  give m.fields.len
}

proc field_names(m: OrmModel) -> [string] {
  let out: [string] = []
  let i: int = 0
  while i < m.fields.len {
    out = out.push(m.fields[i].name)
    i += 1
  }
  give out
}

proc validate_model(m: OrmModel) -> OrmError {
  if !is_identifier(m.table) { give OrmError.InvalidTable }
  if !is_identifier(m.primary_key) { give OrmError.InvalidPrimaryKey }
  if m.fields.len == 0 { give OrmError.InvalidModel }
  if !has_field(m, m.primary_key) { give OrmError.InvalidPrimaryKey }

  let i: int = 0
  while i < m.fields.len {
    let f = m.fields[i]
    if !is_identifier(f.name) { give OrmError.InvalidField }
    if f.kind.len == 0 { give OrmError.InvalidField }
    i += 1
  }
  give OrmError.None
}

proc validate_query(q: Query) -> OrmError {
  if !is_identifier(q.table) { give OrmError.InvalidTable }
  if q.limit < 1 || q.limit > 1000 { give OrmError.InvalidLimit }
  if q.offset < 0 { give OrmError.InvalidOffset }

  let i: int = 0
  while i < q.select_cols.len {
    if !is_identifier(q.select_cols[i]) { give OrmError.InvalidSelect }
    i += 1
  }

  i = 0
  while i < q.where_clauses.len {
    if q.where_clauses[i].len == 0 { give OrmError.InvalidWhere }
    if contains(q.where_clauses[i], ";") { give OrmError.InvalidWhere }
    i += 1
  }

  i = 0
  while i < q.order_bys.len {
    if q.order_bys[i].len == 0 { give OrmError.InvalidOrder }
    if contains(q.order_bys[i], ";") { give OrmError.InvalidOrder }
    i += 1
  }

  give OrmError.None
}

proc select_fragment(q: Query) -> string {
  if q.select_cols.len == 0 { give "*" }
  give join(q.select_cols, ", ")
}

proc where_fragment(q: Query, m: OrmModel) -> string {
  let filters = q.where_clauses
  if m.soft_delete && !q.include_deleted {
    filters = filters.push("deleted_at IS NULL")
  }
  if filters.len == 0 { give "" }
  give " WHERE " + join(filters, " AND ")
}

proc order_fragment(q: Query) -> string {
  if q.order_bys.len == 0 { give "" }
  give " ORDER BY " + join(q.order_bys, ", ")
}

proc limit_offset_fragment(q: Query) -> string {
  give " LIMIT " + q.limit.to_string() + " OFFSET " + q.offset.to_string()
}

proc build_select_sql(m: OrmModel, q: Query) -> string {
  if validate_model(m) != OrmError.None { give "" }
  if validate_query(q) != OrmError.None { give "" }
  if m.table != q.table { give "" }

  give "SELECT " + select_fragment(q) +
       " FROM " + q.table +
       where_fragment(q, m) +
       order_fragment(q) +
       limit_offset_fragment(q)
}

proc build_count_sql(m: OrmModel, q: Query) -> string {
  if validate_model(m) != OrmError.None { give "" }
  if validate_query(q) != OrmError.None { give "" }
  if m.table != q.table { give "" }
  give "SELECT COUNT(1) FROM " + q.table + where_fragment(q, m)
}

proc build_insert_sql(m: OrmModel, cols: [string]) -> string {
  if validate_model(m) != OrmError.None { give "" }
  if cols.len == 0 { give "" }

  let values: [string] = []
  let i: int = 0
  while i < cols.len {
    if !has_field(m, cols[i]) { give "" }
    values = values.push("?")
    i += 1
  }

  give "INSERT INTO " + m.table +
       " (" + join(cols, ", ") + ")" +
       " VALUES (" + join(values, ", ") + ")"
}

proc build_update_sql(m: OrmModel, cols: [string]) -> string {
  if validate_model(m) != OrmError.None { give "" }
  if cols.len == 0 { give "" }

  let assignments: [string] = []
  let i: int = 0
  while i < cols.len {
    if cols[i] != m.primary_key {
      if !has_field(m, cols[i]) { give "" }
      assignments = assignments.push(cols[i] + " = ?")
    }
    i += 1
  }

  if assignments.len == 0 { give "" }
  give "UPDATE " + m.table +
       " SET " + join(assignments, ", ") +
       " WHERE " + m.primary_key + " = ?"
}

proc build_delete_sql(m: OrmModel, hard_delete: bool) -> string {
  if validate_model(m) != OrmError.None { give "" }
  if hard_delete || !m.soft_delete {
    give "DELETE FROM " + m.table + " WHERE " + m.primary_key + " = ?"
  }
  give "UPDATE " + m.table + " SET deleted_at = ? WHERE " + m.primary_key + " = ?"
}

form PackageConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick PackageConfigError {
  InvalidConfig
  Internal
}

pick PackageConfigResult {
  Ok(ok: bool)
  Err(error: PackageConfigError)
}

form PackageRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> PackageConfig {
  give PackageConfig(true,
                     orm_policy_pkg.default_timeout_ms(),
                     orm_policy_pkg.default_retry_budget())
}

proc strict_config() -> PackageConfig {
  let cfg = default_config()
  give PackageConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: PackageConfig) -> PackageConfig {
  give PackageConfig(cfg.strict,
                     orm_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                     cfg.retry_budget)
}

proc validate_config(cfg: PackageConfig) -> PackageConfigResult {
  let nc = normalize_config(cfg)
  if orm_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  if orm_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  give PackageConfigResult.Ok(true)
}

proc healthcheck(cfg: PackageConfig) -> PackageConfigResult {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give PackageConfigResult.Err(vr.error) }
  if orm_runtime_pkg.runtime_status() == false {
    give PackageConfigResult.Err(PackageConfigError.Internal)
  }
  give PackageConfigResult.Ok(true)
}

proc runtime_info() -> PackageRuntimeInfo {
  give PackageRuntimeInfo(orm_runtime_pkg.runtime_name(),
                          orm_runtime_pkg.runtime_version(),
                          orm_runtime_pkg.supports_diagnostics())
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck", "api-contract", "abi-contract", "diagnostics", "contract-summary"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-ORM0001" { give "invalid package configuration" }
  give "orm diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review timeout/retry configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}
proc version() -> string {
  give api_version()
}

proc doctor_status() -> string {
  give "vitte/orm doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: PackageConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give false }
  give true
}

proc healthcheck_default() -> PackageConfigResult {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}
proc validate_config_code(cfg: PackageConfig) -> string {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give "VITTE-ORM0001" }
  give "VITTE-ORM0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-ORM"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/orm,config=(strict,timeout_ms,retry_budget),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(PackageConfigResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-ORM0000" { give ["no action required"] }
  if code == "VITTE-ORM0001" {
    give ["apply normalize_config", "ensure timeout_ms is valid", "ensure retry_budget is valid"]
  }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() +
       " code=" + code +
       " sev=" + diagnostics_severity(code) +
       " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: PackageConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is PackageConfigResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while i < caps.len {
    out = out + "," + caps[i]
    i += 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() +
       " fp=" + package_contract_fingerprint().to_string() +
       " hc=" + healthcheck_default_code() +
       " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
    give true
}



proc package_meta() -> string {
    give "vitte/orm"
}

<<< ROLE-CONTRACT
package: vitte/orm
role: Mapping objets vers schemas relationnels
input_contract: Commandes et schemas de donnees valides cote metier
output_contract: Resultats de persistence coherents avec le contrat schema
boundary: Ne contient pas les regles metier de l application
>>>
