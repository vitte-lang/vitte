<<<
mod.vit
package vitte/jsonpath
>>>

space vitte/jsonpath

use vitte/jsonpath/internal/policy as jsonpath_policy_pkg
use vitte/jsonpath/internal/runtime as jsonpath_runtime_pkg
use vitte/jsonpath/internal/validate as jsonpath_validate_pkg

form Field {
  name: string
}

form Path {
  fields: [Field]
}

form Entry {
  key: string
  value: string
}

form Doc {
  entries: [Entry]
}

form JsonpathConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

form JsonpathRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_root_prefix: bool
}

pick JsonpathError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick JsonpathResult[T] {
  Ok(value: T)
  Err(error: JsonpathError)
}

proc parse(path: string) -> Path {
  let out: [Field] = []
  let part = ""
  let i: int = 0

  if path.len == 0 { give Path([]) }

  if path.slice(0, 1) == "$" {
    i = 1
    if i < path.len && path.slice(i, i + 1) == "." {
      i = i + 1
    }
  }

  while i < path.len {
    let ch = path.slice(i, i + 1)
    if ch == "." {
      if part.len > 0 { out = out.push(Field(part)) }
      part = ""
    } else {
      part = part + ch
    }
    i = i + 1
  }

  if part.len > 0 { out = out.push(Field(part)) }
  give Path(out)
}

proc stringify(path: Path) -> string {
  let out = ""
  let i: int = 0
  while i < path.fields.len {
    if i > 0 { out = out + "." }
    out = out + path.fields[i].name
    i = i + 1
  }
  give out
}

proc parse_checked(path_text: string) -> JsonpathResult[Path] {
  if jsonpath_validate_pkg.valid_path_len(path_text.len) == false {
    give JsonpathResult.Err(JsonpathError.InvalidConfig)
  }
  let p = parse(path_text)
  let i: int = 0
  while i < p.fields.len {
    if jsonpath_validate_pkg.valid_segment(p.fields[i].name) == false {
      give JsonpathResult.Err(JsonpathError.InvalidConfig)
    }
    i = i + 1
  }
  if p.fields.len == 0 {
    give JsonpathResult.Err(JsonpathError.InvalidConfig)
  }
  give JsonpathResult.Ok(p)
}

proc doc_new() -> Doc {
  give Doc([])
}

proc put(doc: Doc, key: string, value: string) -> Doc {
  let out = doc.entries.push(Entry(key, value))
  give Doc(out)
}

proc get(doc: Doc, key: string) -> string {
  let i: int = 0
  while i < doc.entries.len {
    if doc.entries[i].key == key { give doc.entries[i].value }
    i = i + 1
  }
  give ""
}

proc resolve(doc: Doc, path_text: string) -> string {
  let p = parse(path_text)
  if p.fields.len == 0 { give "" }
  give get(doc, stringify(p))
}

proc resolve_checked(doc: Doc, path_text: string) -> JsonpathResult[string] {
  let parsed = parse_checked(path_text)
  when parsed is JsonpathResult.Err { give JsonpathResult.Err(parsed.error) }
  give JsonpathResult.Ok(get(doc, stringify(parsed.value)))
}

proc exists(doc: Doc, path_text: string) -> bool {
  give resolve(doc, path_text).len > 0
}

proc resolve_or(doc: Doc, path_text: string, fallback: string) -> string {
  let v = resolve(doc, path_text)
  if v.len == 0 { give fallback }
  give v
}

proc resolve_or_default(doc: Doc, path_text: string) -> string {
  give resolve_or(doc, path_text, jsonpath_policy_pkg.default_fallback())
}

proc is_valid(path_text: string) -> bool {
  let checked = parse_checked(path_text)
  when checked is JsonpathResult.Err { give false }
  give true
}

proc default_config() -> JsonpathConfig {
  give JsonpathConfig(true, jsonpath_policy_pkg.default_timeout_ms(), jsonpath_policy_pkg.default_retry_budget())
}

proc strict_config() -> JsonpathConfig {
  let cfg = default_config()
  give JsonpathConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: JsonpathConfig) -> JsonpathConfig {
  give JsonpathConfig(cfg.strict, cfg.timeout_ms, cfg.retry_budget)
}

proc validate_config(cfg: JsonpathConfig) -> JsonpathResult[bool] {
  let nc = normalize_config(cfg)
  if jsonpath_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give JsonpathResult.Err(JsonpathError.InvalidConfig)
  }
  if jsonpath_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give JsonpathResult.Err(JsonpathError.InvalidConfig)
  }
  give JsonpathResult.Ok(true)
}

proc healthcheck(cfg: JsonpathConfig) -> JsonpathResult[bool] {
  let vr: JsonpathResult[bool] = validate_config(cfg)
  when vr is JsonpathResult.Err { give JsonpathResult.Err(vr.error) }
  if jsonpath_runtime_pkg.runtime_status() == false {
    give JsonpathResult.Err(JsonpathError.Internal)
  }
  if jsonpath_runtime_pkg.supports_root_prefix() == false {
    give JsonpathResult.Err(JsonpathError.Unsupported)
  }
  let probe = parse_checked("$.health.ok")
  when probe is JsonpathResult.Err {
    give JsonpathResult.Err(JsonpathError.Internal)
  }
  give JsonpathResult.Ok(true)
}

proc runtime_info() -> JsonpathRuntimeInfo {
  give JsonpathRuntimeInfo(jsonpath_runtime_pkg.runtime_name(),
                           jsonpath_runtime_pkg.runtime_version(),
                           jsonpath_runtime_pkg.supports_root_prefix())
}

proc api_version() -> string {
  give version()
}

proc diagnostics_namespace() -> string {
  give "VITTE-JSONPATH"
}

proc validate_config_code(cfg: JsonpathConfig) -> string {
  let vr = validate_config(cfg)
  when vr is JsonpathResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/jsonpath,config=(JsonpathConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(JsonpathResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = diagnostics_namespace() + "0000"
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == diagnostics_namespace() + "0000" { give ["no action required"] }
  if code == diagnostics_namespace() + "0001" { give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"] }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: JsonpathConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is JsonpathResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while i < caps.len {
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give jsonpath_runtime_pkg.runtime_status()
}

proc package_meta() -> string {
  give "vitte/jsonpath"
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give ["dot-path", "root-prefix-$", "resolve-or", "resolve-checked", jsonpath_runtime_pkg.engine_name()]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-JSONPATH0001" { give "invalid path expression" }
  if code == "VITTE-JSONPATH0002" { give "path not found in document" }
  if code == "VITTE-JSONPATH0003" { give "invalid path segment" }
  give "jsonpath diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-JSONPATH0001" { give "use dot-separated non-empty path segments" }
  if code == "VITTE-JSONPATH0002" { give "check available keys and fallback with resolve_or" }
  if code == "VITTE-JSONPATH0003" { give "remove empty segment and reserved tokens" }
  give "review jsonpath configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

<<< ROLE-CONTRACT
