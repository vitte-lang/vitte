space vitte/jsonpath/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "jsonpath-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_root_prefix() -> bool {
  give true
}

proc engine_name() -> string {
  give "dot-path"
}
