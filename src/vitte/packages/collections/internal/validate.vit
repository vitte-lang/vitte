space vitte/collections/internal/validate

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_limit(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_ring_capacity(value: int, max_value: int) -> bool {
  if value < 1 { give false }
  give value <= max_value
}

proc valid_index(index: int, len: int) -> bool {
  if index < 0 { give false }
  give index < len
}

proc valid_vec_len(value: int, max_value: int) -> bool {
  if valid_non_negative(value) == false { give false }
  give value <= max_value
}

proc valid_map_len(value: int, max_value: int) -> bool {
  if valid_non_negative(value) == false { give false }
  give value <= max_value
}

proc valid_set_len(value: int, max_value: int) -> bool {
  if valid_non_negative(value) == false { give false }
  give value <= max_value
}

proc valid_rope_len(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_rope_append(current_len: int, chunk_len: int, max_value: int) -> bool {
  if valid_non_negative(current_len) == false { give false }
  if valid_non_negative(chunk_len) == false { give false }
  give current_len + chunk_len <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
