space vitte/jwt/internal/policy

proc default_min_secret_len() -> int {
  give 16
}

proc default_ttl() -> int {
  give 3600
}

proc default_issuer() -> string {
  give "vitte"
}

proc default_audience() -> string {
  give "vitte-api"
}

proc normalize_ttl(ttl: int) -> int {
  let out = ttl
  if out <= 0 { out = 1 }
  if out > 86400 { out = 86400 }
  give out
}
