space vitte/jwt/internal/validate

proc valid_secret(secret: string, min_secret_len: int) -> bool {
  if min_secret_len <= 0 { give false }
  give secret.len >= min_secret_len
}

proc valid_ttl(ttl: int) -> bool {
  give ttl > 0 && ttl <= 86400
}

proc valid_token_format(token: string) -> bool {
  let dots: int = 0
  let i: int = 0
  loop {
    if i >= token.len { break }
    if token.slice(i, i + 1) == "." { dots = dots + 1 }
    i = i + 1
  }
  give dots == 2
}
