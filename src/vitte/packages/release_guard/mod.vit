<<<
mod.vit
package vitte/release_guard
>>>

space vitte/release_guard

use vitte/release_guard/internal/policy as release_guard_policy_pkg
use vitte/release_guard/internal/runtime as release_guard_runtime_pkg
use vitte/release_guard/internal/validate as release_guard_validate_pkg

form ReleaseGuardConfig {
  current_version: string
  previous_version: string
  breaking_change: bool
}

pick ReleaseGuardError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick ReleaseGuardResult[T] {
  Ok(value: T)
  Err(error: ReleaseGuardError)
}

form ReleaseGuardRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> ReleaseGuardConfig {
  give ReleaseGuardConfig("0.0.0", "0.0.0", release_guard_policy_pkg.default_breaking_policy())
}

proc strict_config() -> ReleaseGuardConfig {
  let cfg = default_config()
  give ReleaseGuardConfig(cfg.current_version, cfg.previous_version, true)
}

proc normalize_config(cfg: ReleaseGuardConfig) -> ReleaseGuardConfig {
  let current_version = cfg.current_version
  let previous_version = cfg.previous_version
  if current_version.len == 0 { current_version = "0.0.0" }
  if previous_version.len == 0 { previous_version = "0.0.0" }
  give ReleaseGuardConfig(current_version, previous_version, cfg.breaking_change)
}

proc validate_config(cfg: ReleaseGuardConfig) -> ReleaseGuardResult[bool] {
  let nc = normalize_config(cfg)
  if release_guard_validate_pkg.valid_version(nc.current_version) == false {
    give ReleaseGuardResult.Err(ReleaseGuardError.InvalidConfig)
  }
  if release_guard_validate_pkg.valid_version(nc.previous_version) == false {
    give ReleaseGuardResult.Err(ReleaseGuardError.InvalidConfig)
  }
  give ReleaseGuardResult.Ok(true)
}

proc healthcheck(cfg: ReleaseGuardConfig) -> ReleaseGuardResult[bool] {
  let vr: ReleaseGuardResult[bool] = validate_config(cfg)
  when vr is ReleaseGuardResult.Err { give ReleaseGuardResult.Err(vr.error) }
  if release_guard_runtime_pkg.runtime_status() == false {
    give ReleaseGuardResult.Err(ReleaseGuardError.Internal)
  }
  give ReleaseGuardResult.Ok(true)
}

proc runtime_info() -> ReleaseGuardRuntimeInfo {
  give ReleaseGuardRuntimeInfo(release_guard_runtime_pkg.runtime_name(),
                               release_guard_runtime_pkg.runtime_version(),
                               release_guard_runtime_pkg.supports_diagnostics())
}

proc version() -> string {
  give "v1"
}

proc api_version() -> string {
  give version()
}

proc capabilities() -> [string] {
  give ["breaking-check", "migration-gate", "semver-guard"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-RGUARD0001" { give "invalid release guard configuration" }
  give "release_guard diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-RGUARD0001" { give "set non-empty current_version and previous_version" }
  give "review release guard policy"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc package_meta() -> string {
  give "vitte/release_guard"
}

proc doctor_status() -> string {
  give "vitte/release_guard doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: ReleaseGuardConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is ReleaseGuardResult.Err { give false }
  give true
}

proc healthcheck_default() -> ReleaseGuardResult[bool] {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}

proc diagnostics_namespace() -> string {
  give "VITTE-RELEASE_GUARD"
}

proc validate_config_code(cfg: ReleaseGuardConfig) -> string {
  let vr = validate_config(cfg)
  when vr is ReleaseGuardResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/release_guard,config=(ReleaseGuardConfig),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(ReleaseGuardResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = diagnostics_namespace() + "0000"
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == diagnostics_namespace() + "0000" { give ["no action required"] }
  if code == diagnostics_namespace() + "0001" { give ["apply normalize_config", "ensure configuration is valid", "re-run healthcheck"] }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: ReleaseGuardConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is ReleaseGuardResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while !(i >= caps.len) {
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give true
}

