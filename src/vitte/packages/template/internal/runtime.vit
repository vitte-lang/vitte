space vitte/template/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "template-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_strict_mode() -> bool {
  give true
}

proc supports_analysis() -> bool {
  give true
}
