space vitte/lock/internal/validate

proc valid_ttl(ttl: int, min_ttl: int, max_ttl: int) -> bool {
  give ttl >= min_ttl && ttl <= max_ttl
}

proc valid_owner(owner: string, strict_owner: bool) -> bool {
  if owner.len > 0 { give true }
  give strict_owner == false
}

proc valid_key(key: string) -> bool {
  give key.len > 0
}
