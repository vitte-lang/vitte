space vitte/channel/internal/validate

proc valid_capacity(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_message(value: string, max_len: int) -> bool {
  give value.len <= max_len
}

proc valid_subscribers(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_timeout_ticks(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
