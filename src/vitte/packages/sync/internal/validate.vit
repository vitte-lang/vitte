space vitte/sync/internal/validate

proc valid_name(value: string) -> bool {
  give value.len > 0
}

proc valid_thread_id(value: string) -> bool {
  give value.len > 0
}

proc valid_non_negative(value: int) -> bool {
  give value >= 0
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}

proc valid_permits(permits: int, max_permits: int) -> bool {
  if permits < 0 { give false }
  give permits <= max_permits
}

proc valid_waiters(waiters: int, max_waiters: int) -> bool {
  if waiters < 0 { give false }
  give waiters <= max_waiters
}

proc valid_parties(parties: int, max_parties: int) -> bool {
  if parties < 1 { give false }
  give parties <= max_parties
}

proc valid_generation(gen: int) -> bool {
  give gen >= 0
}

proc valid_recursion(recursion: int, max_recursion: int) -> bool {
  if recursion < 0 { give false }
  give recursion <= max_recursion
}

proc valid_owner(owner: string, locked: bool) -> bool {
  if locked == false { give true }
  give owner != "none"
}

proc valid_counter(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_timeout_ticks(value: int) -> bool {
  give value >= 0
}
