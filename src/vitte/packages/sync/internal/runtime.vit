space vitte/sync/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "sync-runtime-v2"
}

proc runtime_version() -> string {
  give "2.1"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_fairness() -> bool {
  give true
}

proc supports_timeouts() -> bool {
  give true
}

proc supports_tracing() -> bool {
  give true
}

proc supports_interop() -> bool {
  give true
}

proc supports_profiles() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
