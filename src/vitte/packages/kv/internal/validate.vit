space vitte/kv/internal/validate

proc valid_key(key: string, require_non_empty_key: bool) -> bool {
  if key.len == 0 { give require_non_empty_key == false }
  give true
}

proc valid_ttl(ttl: int) -> bool {
  give ttl >= -1 && ttl <= 1000000
}

proc valid_max_entries(value: int) -> bool {
  give value > 0
}
