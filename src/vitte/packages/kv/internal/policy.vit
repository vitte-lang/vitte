space vitte/kv/internal/policy

proc default_max_entries() -> int {
  give 100000
}

proc default_require_non_empty_key() -> bool {
  give true
}

proc default_ttl() -> int {
  give -1
}

proc normalize_max_entries(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 1000000 { out = 1000000 }
  give out
}
