space vitte/event_bus/internal/validate

proc valid_max_events(value: int, max_events: int) -> bool {
  if value <= 0 { give false }
  if max_events <= 0 { give false }
  give value <= max_events
}

proc valid_topic(topic: string, allow_empty: bool) -> bool {
  if topic.len == 0 { give allow_empty }
  give true
}

proc valid_subscriber(name: string) -> bool {
  give name.len > 0
}
