space vitte/event_bus/internal/policy

proc min_max_events() -> int {
  give 1
}

proc max_max_events() -> int {
  give 100000
}

proc default_max_events() -> int {
  give 4096
}

proc default_allow_empty_topic() -> bool {
  give false
}

proc normalize_max_events(value: int) -> int {
  let out = value
  if out < min_max_events() { out = min_max_events() }
  if out > max_max_events() { out = max_max_events() }
  give out
}
