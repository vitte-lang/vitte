space vitte/macros/internal/policy

proc default_max_defs() -> int {
  give 10000
}

proc default_max_rounds() -> int {
  give 32
}

proc default_allow_empty_body() -> bool {
  give true
}

proc normalize_max_defs(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 100000 { out = 100000 }
  give out
}

proc normalize_max_rounds(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 128 { out = 128 }
  give out
}
