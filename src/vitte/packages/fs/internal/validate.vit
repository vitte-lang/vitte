space vitte/fs/internal/validate

proc valid_watcher(enabled: bool, debounce_ms: int, coalesce_window: int) -> bool {
  let _ = enabled
  if debounce_ms < 10 { give false }
  if coalesce_window < 0 { give false }
  give true
}

proc valid_cache(enabled: bool, ttl_ms: int, invalidate_hash: string) -> bool {
  let _ = enabled
  if ttl_ms < 0 { give false }
  give invalidate_hash.len > 0
}

proc valid_limits(max_file_size: int, max_open_files: int) -> bool {
  if max_file_size <= 0 { give false }
  give max_open_files > 0
}
