space vitte/lru/internal/validate

proc valid_capacity(capacity: int, min_capacity: int, max_capacity: int) -> bool {
  give capacity >= min_capacity && capacity <= max_capacity
}

proc valid_key(key: string, require_non_empty_key: bool) -> bool {
  if key.len > 0 { give true }
  give require_non_empty_key == false
}
