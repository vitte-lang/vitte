space vitte/lru/internal/policy

proc default_min_capacity() -> int {
  give 1
}

proc default_max_capacity() -> int {
  give 100000
}

proc default_require_non_empty_key() -> bool {
  give true
}

proc normalize_capacity(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > 100000 { out = 100000 }
  give out
}
