space vitte/contracts/internal/validate

proc valid_limit(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_name(value: string, max_len: int) -> bool {
  if value.len == 0 { give false }
  give value.len <= max_len
}

proc valid_version(value: string, max_len: int) -> bool {
  if value.len == 0 { give false }
  give value.len <= max_len
}

proc valid_hash(value: string, max_len: int) -> bool {
  if value.len == 0 { give false }
  give value.len <= max_len
}

proc valid_field_name(value: string, max_len: int) -> bool {
  if value.len == 0 { give false }
  give value.len <= max_len
}

proc valid_required_count(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
