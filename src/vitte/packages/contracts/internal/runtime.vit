space vitte/contracts/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "contracts-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_verify() -> bool {
  give true
}

proc supports_diff() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
