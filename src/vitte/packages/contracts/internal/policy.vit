space vitte/contracts/internal/policy

proc max_name_len() -> int {
  give 128
}

proc max_version_len() -> int {
  give 64
}

proc max_hash_len() -> int {
  give 256
}

proc max_required_fields() -> int {
  give 512
}

proc max_field_name_len() -> int {
  give 128
}

proc default_strict() -> bool {
  give false
}

proc normalize_name_len(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > max_name_len() { out = max_name_len() }
  give out
}

proc normalize_version_len(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > max_version_len() { out = max_version_len() }
  give out
}

proc normalize_hash_len(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  if out > max_hash_len() { out = max_hash_len() }
  give out
}

proc normalize_required_fields(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_required_fields() { out = max_required_fields() }
  give out
}
