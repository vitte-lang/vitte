space vitte/gui/internal/validate

proc valid_title(title: string, allow_empty_title: bool) -> bool {
  if title.len == 0 { give allow_empty_title }
  give true
}

proc valid_widget_id(id: string) -> bool {
  give id.len > 0
}

proc valid_text(text: string, max_text_len: int) -> bool {
  if max_text_len <= 0 { give false }
  give text.len <= max_text_len
}

proc valid_widgets_len(count: int, max_widgets: int) -> bool {
  if count < 0 { give false }
  if max_widgets <= 0 { give false }
  give count <= max_widgets
}
