space vitte/gui/internal/policy

proc default_allow_empty_title() -> bool {
  give false
}

proc default_max_widgets() -> int {
  give 10000
}

proc default_max_text_len() -> int {
  give 2048
}

proc min_max_widgets() -> int {
  give 1
}

proc normalize_max_widgets(value: int) -> int {
  let out = value
  if out < min_max_widgets() { out = min_max_widgets() }
  give out
}

proc normalize_max_text_len(value: int) -> int {
  let out = value
  if out < 1 { out = 1 }
  give out
}
