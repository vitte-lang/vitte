<<<
mod.vit
package vitte/gui
version: 3.1.0
tier: ui-core
purpose:
  Couche interface graphique et projection UI.
  Validation explicite des vues/widgets.
  API stable versionnee avec diagnostics et healthcheck.
>>>

space vitte/gui

use vitte/gui/internal/policy as gui_policy_pkg
use vitte/gui/internal/runtime as gui_runtime_pkg
use vitte/gui/internal/validate as gui_validate_pkg

form GuiConfig {
  allow_empty_title: bool
  max_widgets: int
  max_text_len: int
}

pick GuiError {
  InvalidConfig
  NotFound
  Internal
}

pick GuiResult[T] {
  Ok(value: T)
  Err(error: GuiError)
}

form GuiRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
  supports_visibility_model: bool
}

form GuiHealth {
  ok: bool
  code: string
  widgets_count: int
}

pick WidgetKind {
  Container
  Text
  Button
  Input
}

form Widget {
  id: string
  kind: WidgetKind
  text: string
  visible: bool
  enabled: bool
}

form View {
  title: string
  widgets: [Widget]
}

proc default_config() -> GuiConfig {
  give GuiConfig(gui_policy_pkg.default_allow_empty_title(), gui_policy_pkg.default_max_widgets(), gui_policy_pkg.default_max_text_len())
}

proc strict_config() -> GuiConfig {
  let cfg = default_config()
  give GuiConfig(false, cfg.max_widgets, cfg.max_text_len)
}

proc with_max_widgets(cfg: GuiConfig, max_widgets: int) -> GuiConfig {
  give GuiConfig(cfg.allow_empty_title, gui_policy_pkg.normalize_max_widgets(max_widgets), cfg.max_text_len)
}

proc with_max_text_len(cfg: GuiConfig, max_text_len: int) -> GuiConfig {
  give GuiConfig(cfg.allow_empty_title, cfg.max_widgets, gui_policy_pkg.normalize_max_text_len(max_text_len))
}

proc normalize_config(cfg: GuiConfig) -> GuiConfig {
  give GuiConfig(cfg.allow_empty_title,
                 gui_policy_pkg.normalize_max_widgets(cfg.max_widgets),
                 gui_policy_pkg.normalize_max_text_len(cfg.max_text_len))
}

proc validate_config(cfg: GuiConfig) -> GuiResult[bool] {
  let nc = normalize_config(cfg)
  if gui_validate_pkg.valid_widgets_len(0, nc.max_widgets) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  if nc.max_text_len <= 0 {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  give GuiResult.Ok(true)
}

proc runtime_info() -> GuiRuntimeInfo {
  give GuiRuntimeInfo(gui_runtime_pkg.runtime_name(),
                      gui_runtime_pkg.runtime_version(),
                      gui_runtime_pkg.supports_diagnostics(),
                      gui_runtime_pkg.supports_visibility_model())
}

proc healthcheck(cfg: GuiConfig, v: View) -> GuiResult[GuiHealth] {
  let vr = validate_config(cfg)
  when vr is GuiResult.Err { give GuiResult.Err(vr.error) }
  if gui_runtime_pkg.runtime_status() == false {
    give GuiResult.Err(GuiError.Internal)
  }
  if gui_validate_pkg.valid_title(v.title, cfg.allow_empty_title) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  if gui_validate_pkg.valid_widgets_len(v.widgets.len, cfg.max_widgets) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  give GuiResult.Ok(GuiHealth(true, "ok", v.widgets.len))
}

proc version() -> string {
  give "v1"
}

proc capabilities() -> [string] {
  give [
    "diagnostics",
    "healthcheck",
    "visibility",
    "widget-model",
    "widget-text"
  ]
}

proc diagnostics_message(code: string) -> string {
  if code == "VITTE-GUI0001" { give "invalid gui configuration" }
  if code == "VITTE-GUI0002" { give "invalid widget id or text" }
  if code == "VITTE-GUI0003" { give "gui runtime unavailable" }
  give "gui diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-GUI0001" { give "set non-empty title and valid max_widgets" }
  if code == "VITTE-GUI0002" { give "use non-empty widget ids and bounded text" }
  if code == "VITTE-GUI0003" { give "check gui runtime status" }
  give "review gui configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc view(title: string) -> View {
  give View(title, [])
}

proc view_checked(title: string, cfg: GuiConfig) -> GuiResult[View] {
  if gui_validate_pkg.valid_title(title, cfg.allow_empty_title) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  give GuiResult.Ok(view(title))
}

proc widget(id: string, kind: WidgetKind, text: string) -> Widget {
  give Widget(id, kind, text, true, true)
}

proc widget_checked(id: string, kind: WidgetKind, text: string, cfg: GuiConfig) -> GuiResult[Widget] {
  let _ = kind
  if gui_validate_pkg.valid_widget_id(id) == false { give GuiResult.Err(GuiError.InvalidConfig) }
  if gui_validate_pkg.valid_text(text, cfg.max_text_len) == false { give GuiResult.Err(GuiError.InvalidConfig) }
  give GuiResult.Ok(widget(id, kind, text))
}

proc add_widget(v: View, w: Widget) -> View {
  give View(v.title, v.widgets.push(w))
}

proc add_widget_checked(v: View, w: Widget, cfg: GuiConfig) -> GuiResult[View] {
  if gui_validate_pkg.valid_widget_id(w.id) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  if gui_validate_pkg.valid_text(w.text, cfg.max_text_len) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  if gui_validate_pkg.valid_widgets_len(v.widgets.len + 1, cfg.max_widgets) == false {
    give GuiResult.Err(GuiError.InvalidConfig)
  }
  give GuiResult.Ok(add_widget(v, w))
}

proc show(v: View, id: string, visible: bool) -> View {
  let out: [Widget] = []
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    let w = v.widgets[i]
    if w.id == id {
      out = out.push(Widget(w.id, w.kind, w.text, visible, w.enabled))
    } else {
      out = out.push(w)
    }
    i = i + 1
  }
  give View(v.title, out)
}

proc enable(v: View, id: string, enabled: bool) -> View {
  let out: [Widget] = []
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    let w = v.widgets[i]
    if w.id == id {
      out = out.push(Widget(w.id, w.kind, w.text, w.visible, enabled))
    } else {
      out = out.push(w)
    }
    i = i + 1
  }
  give View(v.title, out)
}

proc visible_count(v: View) -> int {
  let c: int = 0
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    if v.widgets[i].visible { c = c + 1 }
    i = i + 1
  }
  give c
}

proc find_widget(v: View, id: string) -> Widget {
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    if v.widgets[i].id == id { give v.widgets[i] }
    i = i + 1
  }
  give Widget("", WidgetKind.Text, "", false, false)
}

proc render_summary(v: View) -> string {
  give "title=" + v.title +
       ",widgets=" + v.widgets.len.to_string() +
       ",visible=" + visible_count(v).to_string()
}

proc hide_all(v: View) -> View {
  let out: [Widget] = []
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    let w = v.widgets[i]
    out = out.push(Widget(w.id, w.kind, w.text, false, w.enabled))
    i = i + 1
  }
  give View(v.title, out)
}

proc disable_all(v: View) -> View {
  let out: [Widget] = []
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    let w = v.widgets[i]
    out = out.push(Widget(w.id, w.kind, w.text, w.visible, false))
    i = i + 1
  }
  give View(v.title, out)
}

proc text_of(v: View, id: string) -> string {
  give find_widget(v, id).text
}

proc has_widget(v: View, id: string) -> bool {
  give find_widget(v, id).id.len > 0
}

proc gui_health(v: View) -> string {
  if v.title.len == 0 { give "invalid-title" }
  if v.widgets.len == 0 { give "empty" }
  give "ok"
}

proc count_kind(v: View, kind: WidgetKind) -> int {
  let c: int = 0
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    if v.widgets[i].kind == kind { c = c + 1 }
    i = i + 1
  }
  give c
}

proc set_text(v: View, id: string, text: string) -> View {
  let out: [Widget] = []
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    let w = v.widgets[i]
    if w.id == id {
      out = out.push(Widget(w.id, w.kind, text, w.visible, w.enabled))
    } else {
      out = out.push(w)
    }
    i = i + 1
  }
  give View(v.title, out)
}

proc set_text_checked(v: View, id: string, text: string, cfg: GuiConfig) -> GuiResult[View] {
  if gui_validate_pkg.valid_widget_id(id) == false { give GuiResult.Err(GuiError.InvalidConfig) }
  if gui_validate_pkg.valid_text(text, cfg.max_text_len) == false { give GuiResult.Err(GuiError.InvalidConfig) }
  give GuiResult.Ok(set_text(v, id, text))
}

proc visible_ids(v: View) -> [string] {
  let out: [string] = []
  let i: int = 0
  loop {
    if i >= v.widgets.len { break }
    if v.widgets[i].visible { out = out.push(v.widgets[i].id) }
    i = i + 1
  }
  give out
}

proc gui_diagnostics(v: View) -> string {
  give render_summary(v) +
       ",buttons=" + count_kind(v, WidgetKind.Button).to_string() +
       ",inputs=" + count_kind(v, WidgetKind.Input).to_string() +
       ",health=" + gui_health(v)
}

proc ready() -> bool {
  give gui_runtime_pkg.runtime_status()
}

proc package_meta() -> string {
  give "vitte/gui"
}

<<< ROLE-CONTRACT
package: vitte/gui
role: Couche interface graphique et projection UI
input_contract: Valeurs metier explicites, deja parsees et typables
output_contract: Sorties stables, observables et compatibles avec les autres packages
boundary: Ne remplace pas les autres couches; respecte la separation de roles
>>>
