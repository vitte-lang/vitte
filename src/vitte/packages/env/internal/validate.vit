space vitte/env/internal/validate

proc valid_timeout_ms(timeout_ms: int) -> bool {
  give timeout_ms > 0 && timeout_ms <= 60000
}

proc valid_retry_budget(retry_budget: int) -> bool {
  give retry_budget >= 0 && retry_budget <= 32
}

proc valid_key(key: string) -> bool {
  if key.len == 0 || key.len > 128 { give false }
  if key.slice(0, 1) == " " { give false }
  give true
}

proc valid_scalar(value: string) -> bool {
  give value.len <= 4096
}

proc valid_timeout_range(timeout_ms: int, min_value: int, max_value: int) -> bool {
  if timeout_ms < min_value { give false }
  give timeout_ms <= max_value
}

proc valid_retry_range(retry_budget: int, min_value: int, max_value: int) -> bool {
  if retry_budget < min_value { give false }
  give retry_budget <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
