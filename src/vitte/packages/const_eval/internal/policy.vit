space vitte/const_eval/internal/policy

proc max_abs_value() -> int {
  give 1000000000
}

proc max_chain_len() -> int {
  give 4096
}

proc default_strict() -> bool {
  give false
}

proc default_detect_overflow() -> bool {
  give true
}

proc normalize_abs(value: int) -> int {
  let out = value
  if out < 0 { out = 0 - out }
  if out > max_abs_value() { out = max_abs_value() }
  give out
}

proc normalize_chain_len(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_chain_len() { out = max_chain_len() }
  give out
}
