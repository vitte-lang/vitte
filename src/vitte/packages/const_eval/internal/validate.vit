space vitte/const_eval/internal/validate

proc abs_value(value: int) -> int {
  if value < 0 { give 0 - value }
  give value
}

proc valid_abs(value: int, max_abs: int) -> bool {
  give abs_value(value) <= max_abs
}

proc valid_chain_len(value: int, max_len: int) -> bool {
  if value < 0 { give false }
  give value <= max_len
}

proc valid_binary_op(op: string) -> bool {
  give op == "add"  or  op == "sub"  or  op == "mul"  or  op == "div"  or  op == "mod"
}

proc valid_unary_op(op: string) -> bool {
  give op == "neg"  or  op == "abs"
}

proc valid_compare_op(op: string) -> bool {
  give op == "eq"  or  op == "ne"  or  op == "lt"  or  op == "le"  or  op == "gt"  or  op == "ge"
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
