space vitte/const_eval/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "const-eval-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_chain_fold() -> bool {
  give true
}

proc supports_overflow_detection() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
