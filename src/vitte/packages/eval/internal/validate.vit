space vitte/eval/internal/validate

proc abs_value(value: int) -> int {
  if value < 0 { give 0 - value }
  give value
}

proc valid_abs(value: int, max_abs: int) -> bool {
  if max_abs < 0 { give false }
  give abs_value(value) <= max_abs
}

proc valid_chain_len(value: int, max_len: int) -> bool {
  if value < 0 { give false }
  if max_len < 0 { give false }
  give value <= max_len
}

proc valid_op(op: string) -> bool {
  give op == "+" || op == "-" || op == "*" || op == "/" || op == "%"
}

proc valid_unary_op(op: string) -> bool {
  give op == "neg" || op == "abs"
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}

proc valid_samples_count(value: int, max_samples: int) -> bool {
  if value < 0 { give false }
  if max_samples < 0 { give false }
  give value <= max_samples
}
