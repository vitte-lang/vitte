space vitte/eval/internal/policy

proc min_abs_value() -> int {
  give 1
}

proc max_abs_value() -> int {
  give 1000000000
}

proc min_chain_len() -> int {
  give 1
}

proc max_chain_len() -> int {
  give 4096
}

proc max_health_samples() -> int {
  give 100000
}

proc default_strict() -> bool {
  give false
}

proc default_detect_div_zero() -> bool {
  give true
}

proc default_max_abs_value() -> int {
  give 1000000
}

proc default_max_chain_len() -> int {
  give 256
}

proc normalize_abs(value: int) -> int {
  let out = value
  if out < 0 { out = 0 - out }
  if out < min_abs_value() { out = min_abs_value() }
  if out > max_abs_value() { out = max_abs_value() }
  give out
}

proc normalize_chain_len(value: int) -> int {
  let out = value
  if out < min_chain_len() { out = min_chain_len() }
  if out > max_chain_len() { out = max_chain_len() }
  give out
}

proc normalize_health_samples(value: int) -> int {
  let out = value
  if out < 0 { out = 0 }
  if out > max_health_samples() { out = max_health_samples() }
  give out
}
