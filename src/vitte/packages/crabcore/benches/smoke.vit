space vitte/crabcore/benches/smoke

use vitte/crabcore as crabcore_pkg

<<< =========================================================
    Benchmark domain (ultra max)
========================================================= >>>

form BenchResult {
    name: string,
    iterations: int,
    acc: int,
    avg_acc: int,
    ok: bool
}

form BenchStats {
    min_acc: int,
    max_acc: int,
    avg_acc: int,
    variance: int
}

form BenchTiming {
    duration_ms: int,
    ops_per_sec: int
}

form BenchSuite {
    runs: int,
    total_cases: int,
    total_iterations: int,
    total_acc: int,
    ok: bool,
    stats: BenchStats,
    timing: BenchTiming,
    results: [BenchResult]
}

<<< =========================================================
    Core bench
========================================================= >>>

proc bench_named(name: string, iterations: int) -> BenchResult {
    let i: int = 0
    let acc: int = 0

    while i < iterations {
        acc = acc + crabcore_pkg.summary().len
        i += 1
    }

    let avg_acc: int = 0
    if iterations > 0 {
        set avg_acc = acc / iterations
    }

    give BenchResult {
        name: name,
        iterations: iterations,
        acc: acc,
        avg_acc: avg_acc,
        ok: acc >= 0
    }
}

proc now_ms() -> int {
    give 0
}

<<< =========================================================
    Scenarios
========================================================= >>>

proc scenarios() -> [BenchResult] {
    give [
        bench_named("tiny", 10),
        bench_named("small", 100),
        bench_named("medium", 1000),
        bench_named("large", 10000),
        bench_named("huge", 50000)
    ]
}

<<< =========================================================
    Aggregation
========================================================= >>>

proc total_acc(list: [BenchResult]) -> int {
    let acc: int = 0
    for item in list {
        set acc = acc + item.acc
    }
    give acc
}

proc total_iterations(list: [BenchResult]) -> int {
    let n: int = 0
    for item in list {
        set n = n + item.iterations
    }
    give n
}

proc count(list: [BenchResult]) -> int {
    let n: int = 0
    for _ in list {
        set n = n + 1
    }
    give n
}

proc min_acc(list: [BenchResult]) -> int {
    let m: int = list[0].acc
    for item in list {
        if item.acc < m {
            set m = item.acc
        }
    }
    give m
}

proc max_acc(list: [BenchResult]) -> int {
    let m: int = list[0].acc
    for item in list {
        if item.acc > m {
            set m = item.acc
        }
    }
    give m
}

proc variance(list: [BenchResult]) -> int {
    let avg: int = total_acc(list) / count(list)
    let var: int = 0

    for item in list {
        let d: int = item.acc - avg
        set var = var + d * d
    }

    give var / count(list)
}

proc suite_stats(list: [BenchResult]) -> BenchStats {
    give BenchStats {
        min_acc: min_acc(list),
        max_acc: max_acc(list),
        avg_acc: total_acc(list) / count(list),
        variance: variance(list)
    }
}

proc all_ok(list: [BenchResult]) -> bool {
    for item in list {
        if not item.ok {
            give false
        }
    }
    give true
}

proc run_once() -> [BenchResult] {
    give scenarios()
}

proc run_many(n: int) -> [BenchResult] {
    let out = []
    let i: int = 0

    while i < n {
        let r = run_once()
        for item in r {
            set out = out + [item]
        }
        i += 1
    }

    give out
}

proc make_suite(runs: int) -> BenchSuite {
    let start: int = now_ms()

    let results = run_many(runs)

    let end: int = now_ms()
    let duration: int = end - start

    let total_it = total_iterations(results)
    let ops: int = 0
    if duration > 0 {
        set ops = total_it / duration
    }

    give BenchSuite {
        runs: runs,
        total_cases: count(results),
        total_iterations: total_it,
        total_acc: total_acc(results),
        ok: all_ok(results),
        stats: suite_stats(results),
        timing: BenchTiming {
            duration_ms: duration,
            ops_per_sec: ops
        },
        results: results
    }
}

<<< =========================================================
    Printing
========================================================= >>>

proc print_result(r: BenchResult) {
    emit r.name + ":acc=" + (r.acc as string)
}

proc print_stats(s: BenchStats) {
    emit "min=" + (s.min_acc as string)
    emit "max=" + (s.max_acc as string)
    emit "avg=" + (s.avg_acc as string)
    emit "var=" + (s.variance as string)
}

proc print_timing(t: BenchTiming) {
    emit "duration_ms=" + (t.duration_ms as string)
    emit "ops_per_sec=" + (t.ops_per_sec as string)
}

proc print_suite(s: BenchSuite) {
    emit "==== BENCH ULTRA ===="
    emit "runs=" + (s.runs as string)
    emit "cases=" + (s.total_cases as string)
    emit "iterations=" + (s.total_iterations as string)

    print_stats(s.stats)
    print_timing(s.timing)
}

proc print_all() {
    let suite = make_suite(5)
    print_suite(suite)
}

<<< =========================================================
    Entry
========================================================= >>>

entry main at vitte/crabcore/benches/smoke {
    print_all()
}
