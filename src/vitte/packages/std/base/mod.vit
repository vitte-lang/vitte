<<<
mod.vit
package vitte/std/base
>>>
# PREAMBLE (shared std base primitives)
# - No import-time side effects.
# - Shared Result/Error and index primitives for std layers.

space vitte/std/base

use vitte/std/base/internal/runtime as std_base_runtime_pkg
use vitte/std/base/internal/validate as std_base_validate_pkg
use vitte/std/base/internal/policy as std_base_policy_pkg

form StdEntry {
  name: string
  group: string
  path: string
}

form StdIndex {
  entries: [StdEntry]
}

pick StdError {
  Message(code: string, message: string)
}

pick StdResult[T] {
  Ok(value: T)
  Err(error: StdError)
}

proc ok[T](value: T) -> StdResult[T] {
  give StdResult.Ok(value)
}

proc err[T](code: string, message: string) -> StdResult[T] {
  give StdResult.Err(StdError.Message(code, message))
}

proc assert_or_err(condition: bool, code: string, message: string) -> StdResult[bool] {
  if condition {
    give StdResult.Ok(true)
  }
  give StdResult.Err(StdError.Message(code, message))
}

proc panic_guard[T](r: StdResult[T], fallback: T) -> T {
  when r is StdResult.Ok {
    give r.value
  }
  give fallback
}

proc checked_cast_int(value: int) -> StdResult[int] {
  give StdResult.Ok(value)
}

proc std_index() -> StdIndex {
  give StdIndex([])
}

proc register(i: StdIndex, name: string, group: string, path: string) -> StdIndex {
  give StdIndex(i.entries.push(StdEntry(name, group, path)))
}

proc find_group(i: StdIndex, group: string) -> [string] {
  let out: [string] = []
  let k: int = 0
  while !(k >= i.entries.len) {
    if i.entries[k].group == group { out = out.push(i.entries[k].name) }
    k = k + 1
  }
  give out
}

proc resolve_path(i: StdIndex, name: string) -> string {
  let k: int = 0
  while !(k >= i.entries.len) {
    if i.entries[k].name == name { give i.entries[k].path }
    k = k + 1
  }
  give ""
}

proc size(i: StdIndex) -> int {
  give i.entries.len
}

proc std_debug_enabled() -> bool {
  give false
}

proc std_strict_enabled() -> bool {
  give true
}

proc std_compat_enabled() -> bool {
  give true
}

proc export_allowed(profile: string, module: string) -> bool {
  if profile == "core" {
    if module == "net" || module == "async" { give false }
    give true
  }
  if profile == "desktop" || profile == "system" {
    give true
  }
  give false
}

proc package_meta() -> string {
  give "vitte/std/base"
}

form StdBaseConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

form StdBaseRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

pick StdBaseError {
  InvalidConfig
  Unsupported
  Timeout
  Internal
}

pick StdBaseResult[T] {
  Ok(value: T)
  Err(error: StdBaseError)
}

proc default_config() -> StdBaseConfig {
  give StdBaseConfig(true, std_base_policy_pkg.default_timeout_ms(), std_base_policy_pkg.default_retry_budget())
}

proc strict_config() -> StdBaseConfig {
  let cfg = default_config()
  give StdBaseConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(timeout_ms: int, retry_budget: int, strict: bool) -> StdBaseConfig {
  give StdBaseConfig(
    strict,
    std_base_policy_pkg.normalize_timeout_ms(timeout_ms),
    std_base_policy_pkg.normalize_retry_budget(retry_budget)
  )
}

proc normalize_config(cfg: StdBaseConfig) -> StdBaseConfig {
  give normalize_config(cfg.timeout_ms, cfg.retry_budget, cfg.strict)
}

proc profile_apply(name: string) -> StdBaseConfig {
  let p = std_base_policy_pkg.profile_by_name(name)
  give normalize_config(p.timeout_ms, p.retry_budget, p.strict)
}

proc validate_config(cfg: StdBaseConfig) -> StdBaseResult[bool] {
  if std_base_validate_pkg.valid_timeout_ms(cfg.timeout_ms) == false {
    give StdBaseResult.Err(StdBaseError.InvalidConfig)
  }
  if std_base_validate_pkg.valid_retry_budget(cfg.retry_budget) == false {
    give StdBaseResult.Err(StdBaseError.InvalidConfig)
  }
  give StdBaseResult.Ok(true)
}

proc validate_or_err(cfg: StdBaseConfig) -> StdResult[bool] {
  let code = std_base_validate_pkg.validate_code(cfg.timeout_ms, cfg.retry_budget)
  if code.len > 0 {
    if code == "VITTE-STDBASE0001" { give err(code, "invalid timeout_ms in std/base config") }
    if code == "VITTE-STDBASE0002" { give err(code, "invalid retry_budget in std/base config") }
    give err(code, "std/base diagnostic " + code)
  }
  if std_base_validate_pkg.valid_runtime_contract(cfg.timeout_ms, cfg.retry_budget, cfg.strict) == false {
    give err("VITTE-STDBASE0003", "runtime profile is incompatible with strict settings")
  }
  give ok(true)
}

proc healthcheck(cfg: StdBaseConfig) -> StdBaseResult[bool] {
  let vr: StdBaseResult[bool] = validate_config(cfg)
  when vr is StdBaseResult.Err {
    give StdBaseResult.Err(vr.error)
  }
  if std_base_runtime_pkg.runtime_status() == false {
    give StdBaseResult.Err(StdBaseError.Internal)
  }
  give StdBaseResult.Ok(true)
}

proc runtime_info() -> StdBaseRuntimeInfo {
  give StdBaseRuntimeInfo(std_base_runtime_pkg.runtime_name(),
                          std_base_runtime_pkg.runtime_version(),
                          std_base_runtime_pkg.supports_diagnostics())
}

proc version() -> string {
  give "v1"
}

proc api_version() -> string {
  give version()
}

proc capabilities() -> [string] {
  give [
    "config",
    "normalize-config",
    "normalize-profile",
    "timeout-budget",
    "profile-apply",
    "validate",
    "validate-or-err",
    "healthcheck",
    "diag",
    "diag-json",
    "feature-flags",
    "api-contract",
    "abi-contract",
    "diagnostics",
    "contract-summary"
  ]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-STDBASE0001" { give "invalid timeout_ms in std/base config" }
  if code == "VITTE-STDBASE0002" { give "invalid retry_budget in std/base config" }
  if code == "VITTE-STDBASE0003" { give "runtime profile is incompatible with strict settings" }
  give "std/base diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  if code == "VITTE-STDBASE0001" { give "use timeout_ms in range 1..60000" }
  if code == "VITTE-STDBASE0002" { give "use retry_budget in range 0..32" }
  if code == "VITTE-STDBASE0003" { give "disable strict or lower retry_budget" }
  give "review std/base configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc error_code_to_message(code: string) -> string {
  if code == "VITTE-STDBASE0001" { give "invalid std/base timeout configuration" }
  if code == "VITTE-STDBASE0002" { give "invalid std/base retry configuration" }
  if code == "VITTE-STDBASE0003" { give "invalid std/base strict runtime contract" }
  give "std/base diagnostic " + code
}

proc diag(code: string, ctx: string) -> string {
  let c = code
  if c.len == 0 { c = "VITTE-STDBASE0000" }
  let body = error_code_to_message(c)
  if ctx.len == 0 { give c + ": " + body }
  give c + ": " + body + " [" + ctx + "]"
}

proc normalize_profile(name: string, overrides: StdBaseConfig) -> StdBaseConfig {
  let base = profile_apply(name)
  let timeout_v = base.timeout_ms
  if overrides.timeout_ms > 0 {
    timeout_v = overrides.timeout_ms
  }
  let retry_v = base.retry_budget
  if overrides.retry_budget >= 0 {
    retry_v = overrides.retry_budget
  }
  # strict-first policy: once strict is true, it cannot be relaxed by overrides.
  let strict_v = base.strict || overrides.strict
  give normalize_config(timeout_v, retry_v, strict_v)
}

proc guard_timeout_budget(start_ms: int, now_ms: int, timeout_ms: int) -> bool {
  if timeout_ms <= 0 { give false }
  if now_ms < start_ms { give false }
  let elapsed = now_ms - start_ms
  if elapsed > timeout_ms { give false }
  give true
}

proc diag_json(code: string, ctx: string, severity: string) -> string {
  let c = code
  if c.len == 0 { c = "VITTE-STDBASE0000" }
  let s = severity
  if s.len == 0 { s = "error" }
  let msg = error_code_to_message(c)
  let payload = "{\"code\":\"" + c + "\",\"severity\":\"" + s + "\",\"message\":\"" + msg + "\""
  if ctx.len == 0 { give payload + "}" }
  give payload + ",\"context\":\"" + ctx + "\"}"
}

proc feature_flags(profile: string) -> [string] {
  if profile == "core" { give ["strict", "no-legacy", "low-latency"] }
  if profile == "desktop" { give ["strict", "compat", "extended-retry"] }
  if profile == "system" { give ["strict", "compat", "observability"] }
  give ["strict"]
}

proc validate_config_code(cfg: StdBaseConfig) -> string {
  let vr = validate_config(cfg)
  when vr is StdBaseResult.Err { give "VITTE-STDBASE0001" }
  give "VITTE-STDBASE0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-STD_BASE"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/std/base,config=(strict,timeout_ms,retry_budget),runtime=(runtime_name,runtime_version),result=(StdBaseResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc contract_summary_brief() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-STDBASE0000" { give ["no action required"] }
  if code == "VITTE-STDBASE0001" { give ["use timeout_ms in range 1..60000"] }
  if code == "VITTE-STDBASE0002" { give ["use retry_budget in range 0..32"] }
  if code == "VITTE-STDBASE0003" { give ["disable strict", "lower retry_budget"] }
  give ["review diagnostics_quickfix", "run validate_or_err", "re-run healthcheck"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: StdBaseConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is StdBaseResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while !(i >= caps.len) {
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  let ri = runtime_info()
  give package_meta() + " api=" + api_version() + " runtime=" + ri.runtime_name + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  if std_base_runtime_pkg.runtime_status() == false { give false }
  let cfg = default_config()
  let vr = validate_config(cfg)
  when vr is StdBaseResult.Err { give false }
  give true
}

