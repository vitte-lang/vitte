space vitte/std/base/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "std/base"
}

proc runtime_version() -> string {
  give "v1"
}

proc runtime_capabilities() -> [string] {
  give ["index", "result", "policy"]
}

proc runtime_ready_message() -> string {
  if runtime_status() == false { give "std/base runtime unavailable" }
  give "std/base runtime ready"
}
