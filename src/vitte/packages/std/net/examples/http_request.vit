<<<
http_request.vit
example vitte/std/net request facade
>>>

entry main at core/app {
  let host: string = "api.vitte.dev"
  let path: string = "/status"
  let url: string = "https://" + host + path
  let status: int = 200
  if url.len == 0 { give 1 }
  if status < 200 || status >= 300 { give 2 }
  give 0
}
