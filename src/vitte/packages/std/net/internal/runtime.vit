space vitte/std/net/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_backend() -> string {
  give "tcp"
}

proc runtime_capabilities() -> [string] {
  give ["timeouts", "retries", "strict-net"]
}

proc runtime_ready_message() -> string {
  if runtime_status() == false { give "std/net runtime unavailable" }
  give "std/net runtime ready"
}
