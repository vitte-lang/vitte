<<<
cache_json.vit
example vitte/std/data cache + json facade
>>>

use vitte/std/data as std_data_pkg

entry main at core/app {
  let c0 = std_data_pkg.cache_new()
  let c1 = std_data_pkg.cache_set(c0, "key", "value", 5000, 0)
  if std_data_pkg.cache_has(c1, "key", 1000) == false { give 1 }
  let j = std_data_pkg.json_encode("{\"ok\":true}")
  when j is std_data_pkg.StdDataResult.Err { give 2 }
  give 0
}
