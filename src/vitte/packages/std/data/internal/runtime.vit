space vitte/std/data/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_backend() -> string {
  give "in-memory"
}

proc runtime_capabilities() -> [string] {
  give ["cache", "schema", "deterministic"]
}

proc runtime_ready_message() -> string {
  if runtime_status() == false { give "std/data runtime unavailable" }
  give "std/data runtime ready"
}
