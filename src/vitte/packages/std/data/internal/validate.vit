space vitte/std/data/internal/validate

proc valid_cache_size(cache_size: int) -> bool {
  give cache_size >= 0 && cache_size <= 1000000
}

proc valid_mode(mode: string) -> bool {
  if mode == "default" { give true }
  if mode == "tiny" { give true }
  if mode == "large" { give true }
  give false
}

proc validate_code(cache_size: int) -> string {
  if valid_cache_size(cache_size) == false { give "VITTE-STDDATA0001" }
  give ""
}

proc valid_config(cache_size: int, strict_schema: bool, deterministic: bool) -> bool {
  if valid_cache_size(cache_size) == false { give false }
  if deterministic && strict_schema == false { give false }
  give true
}
