space vitte/std/io/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_backend() -> string {
  give "stdio"
}

proc runtime_name() -> string {
  give "std/io-runtime-v1"
}

proc runtime_version() -> string {
  give "1.0"
}

proc supports_diagnostics() -> bool {
  give true
}

proc runtime_capabilities() -> [string] {
  give ["buffered", "text-mode", "strict"]
}

proc runtime_ready_message() -> string {
  if runtime_status() == false { give "std/io runtime unavailable" }
  give "std/io runtime ready"
}
