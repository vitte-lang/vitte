space vitte/std/io/internal/validate

proc valid_buffer_size(buffer_size: int) -> bool {
  give buffer_size > 0 && buffer_size <= 1048576
}

proc valid_mode(text_mode: bool) -> bool {
  if text_mode { give true }
  give true
}

proc validate_code(buffer_size: int) -> string {
  if valid_buffer_size(buffer_size) == false { give "VITTE-STDIO0001" }
  give ""
}

proc valid_config(buffer_size: int, text_mode: bool, strict: bool) -> bool {
  if valid_buffer_size(buffer_size) == false { give false }
  if valid_mode(text_mode) == false { give false }
  if strict == false && buffer_size > 262144 { give false }
  give true
}
