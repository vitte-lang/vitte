<<<
file_ops.vit
example vitte/std/io basic API
>>>

use vitte/std/io as std_io_pkg

entry main at core/app {
  let p = std_io_pkg.path_join("tmp", "sample.txt")
  let w = std_io_pkg.atomic_write(p, "hello")
  when w is std_io_pkg.StdIoResult.Err { give 1 }
  let r = std_io_pkg.read_text(p)
  when r is std_io_pkg.StdIoResult.Err { give 2 }
  give 0
}
