<<<
validate.vit
package vitte/db/internal/validate
>>>

space vitte/db/internal/validate

proc valid_non_empty(value: string) -> bool {
  give value.len > 0
}

proc valid_max_len(value: string, max_len: int) -> bool {
  if max_len < 0 { give false }
  give value.len <= max_len
}

proc valid_timeout_ms(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_retry_budget(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_pool_bounds(min_pool: int, max_pool: int, min_value: int, max_value: int) -> bool {
  if min_pool < min_value { give false }
  if max_pool > max_value { give false }
  give min_pool <= max_pool
}

proc valid_backoff_ms(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_circuit_threshold(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_circuit_open_ms(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_pool_idle_timeout_ms(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_pool_health_interval_ms(value: int, min_value: int, max_value: int) -> bool {
  if value < min_value { give false }
  give value <= max_value
}

proc valid_binds_count(value: int, max_value: int) -> bool {
  if value < 0 { give false }
  give value <= max_value
}

proc valid_percent(value: int) -> bool {
  if value < 0 { give false }
  give value <= 100
}
