<<<
policy.vit
package vitte/db/internal/policy
>>>

space vitte/db/internal/policy

proc min_timeout_ms() -> int {
  give 1
}

proc max_timeout_ms() -> int {
  give 120000
}

proc min_retry_budget() -> int {
  give 0
}

proc max_retry_budget() -> int {
  give 32
}

proc min_pool_size() -> int {
  give 0
}

proc max_pool_size() -> int {
  give 256
}

proc min_backoff_ms() -> int {
  give 0
}

proc max_backoff_ms() -> int {
  give 60000
}

proc min_circuit_threshold() -> int {
  give 1
}

proc max_circuit_threshold() -> int {
  give 1000
}

proc min_circuit_open_ms() -> int {
  give 0
}

proc max_circuit_open_ms() -> int {
  give 600000
}

proc min_pool_idle_timeout_ms() -> int {
  give 0
}

proc max_pool_idle_timeout_ms() -> int {
  give 3600000
}

proc min_pool_health_interval_ms() -> int {
  give 100
}

proc max_pool_health_interval_ms() -> int {
  give 600000
}

proc max_dsn_len() -> int {
  give 2048
}

proc max_query_len() -> int {
  give 65536
}

proc max_binds() -> int {
  give 1024
}

proc default_timeout_ms() -> int {
  give 2000
}

proc default_retry_budget() -> int {
  give 3
}

proc default_pool_min() -> int {
  give 1
}

proc default_pool_max() -> int {
  give 8
}

proc default_profile() -> string {
  give "desktop"
}

proc normalize_timeout_ms(value: int) -> int {
  let out = value
  if out < min_timeout_ms() { out = min_timeout_ms() }
  if out > max_timeout_ms() { out = max_timeout_ms() }
  give out
}

proc normalize_retry_budget(value: int) -> int {
  let out = value
  if out < min_retry_budget() { out = min_retry_budget() }
  if out > max_retry_budget() { out = max_retry_budget() }
  give out
}

proc normalize_pool_size(value: int) -> int {
  let out = value
  if out < min_pool_size() { out = min_pool_size() }
  if out > max_pool_size() { out = max_pool_size() }
  give out
}

proc normalize_backoff_ms(value: int) -> int {
  let out = value
  if out < min_backoff_ms() { out = min_backoff_ms() }
  if out > max_backoff_ms() { out = max_backoff_ms() }
  give out
}

proc normalize_circuit_threshold(value: int) -> int {
  let out = value
  if out < min_circuit_threshold() { out = min_circuit_threshold() }
  if out > max_circuit_threshold() { out = max_circuit_threshold() }
  give out
}

proc normalize_circuit_open_ms(value: int) -> int {
  let out = value
  if out < min_circuit_open_ms() { out = min_circuit_open_ms() }
  if out > max_circuit_open_ms() { out = max_circuit_open_ms() }
  give out
}

proc normalize_pool_idle_timeout_ms(value: int) -> int {
  let out = value
  if out < min_pool_idle_timeout_ms() { out = min_pool_idle_timeout_ms() }
  if out > max_pool_idle_timeout_ms() { out = max_pool_idle_timeout_ms() }
  give out
}

proc normalize_pool_health_interval_ms(value: int) -> int {
  let out = value
  if out < min_pool_health_interval_ms() { out = min_pool_health_interval_ms() }
  if out > max_pool_health_interval_ms() { out = max_pool_health_interval_ms() }
  give out
}
