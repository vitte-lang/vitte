space vitte/arduino/spi/internal/policy

proc default_clock_hz() -> int {
  give 1000000
}

proc min_clock_hz() -> int {
  give 1000
}

proc max_clock_hz() -> int {
  give 40000000
}

proc normalize_clock_hz(clock_hz: int) -> int {
  if clock_hz < min_clock_hz() { give min_clock_hz() }
  if clock_hz > max_clock_hz() { give max_clock_hz() }
  give clock_hz
}
