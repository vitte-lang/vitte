space vitte/arduino/serial/internal/runtime

proc runtime_name() -> string {
  give "serial-runtime-v1"
}

proc runtime_connected() -> bool {
  give true
}

proc runtime_capabilities() -> [string] {
  give ["read", "write", "peek", "flush"]
}

proc runtime_available() -> int {
  give 0
}

proc runtime_peek() -> int {
  give -1
}

proc runtime_read() -> int {
  give -1
}

proc runtime_write(byte: int) -> int {
  let _ = byte
  give 1
}

proc runtime_flush() -> int {
  give 0
}
