<<<
mod.vit
package vitte/arduino/gpio
>>>

space vitte/arduino/gpio

use vitte/arduino as arduino_pkg
use vitte/arduino/gpio/internal/runtime as gpio_runtime_pkg
use vitte/arduino/gpio/internal/validate as gpio_validate_pkg
use vitte/arduino/gpio/internal/policy as gpio_policy_pkg

pick PinMode {
  Input
  Output
}

pick PinState {
  Low
  High
}

pick PullMode {
  None
  Up
}

form GpioConfig {
  profile: arduino_pkg.ArduinoProfile
  default_mode: PinMode
  pull_mode: PullMode
  retry_budget: int
}

form GpioState {
  cfg: GpioConfig
  opened: bool
  tx_count: int
  rx_count: int
  error_count: int
}

proc gpio_default_config() -> GpioConfig {
  give GpioConfig(arduino_pkg.default_profile(), PinMode.Input, PullMode.None, gpio_policy_pkg.normalize_retry_budget(1))
}

proc gpio_with_profile(cfg: GpioConfig, profile: arduino_pkg.ArduinoProfile) -> GpioConfig {
  give GpioConfig(profile, cfg.default_mode, cfg.pull_mode, cfg.retry_budget)
}

proc gpio_with_pullup(cfg: GpioConfig, enabled: bool) -> GpioConfig {
  let pull_mode: PullMode = PullMode.None
  if enabled { pull_mode = PullMode.Up }
  give GpioConfig(cfg.profile, cfg.default_mode, pull_mode, cfg.retry_budget)
}

proc gpio_with_retry_budget(cfg: GpioConfig, retry_budget: int) -> GpioConfig {
  give GpioConfig(cfg.profile, cfg.default_mode, cfg.pull_mode, gpio_policy_pkg.normalize_retry_budget(retry_budget))
}

proc gpio_open(cfg: GpioConfig) -> GpioState {
  if gpio_runtime_pkg.runtime_ready() == false {
    give GpioState(cfg, false, 0, 0, 1)
  }
  let c = GpioConfig(cfg.profile, cfg.default_mode, cfg.pull_mode, gpio_policy_pkg.normalize_retry_budget(cfg.retry_budget))
  give GpioState(c, true, 0, 0, 0)
}

proc gpio_close(st: GpioState) -> GpioState {
  give GpioState(st.cfg, false, st.tx_count, st.rx_count, st.error_count)
}

proc gpio_write(st: GpioState, pin: arduino_pkg.Pin, state: PinState) -> arduino_pkg.ArduinoResult[GpioState] {
  if st.opened == false {
    give arduino_pkg.err[GpioState](arduino_pkg.ArduinoError.Conflict)
  }
  if gpio_validate_pkg.valid_pin(st.cfg.profile, pin) == false {
    give arduino_pkg.err[GpioState](arduino_pkg.ArduinoError.InvalidPin)
  }
  let raw: int = 0
  if state == PinState.High { raw = 1 }
  if gpio_validate_pkg.valid_level(raw) == false {
    give arduino_pkg.err[GpioState](arduino_pkg.ArduinoError.Unsupported)
  }
  let status: int = gpio_runtime_pkg.runtime_write(pin, raw)
  if status != 0 {
    give arduino_pkg.err[GpioState](arduino_pkg.ArduinoError.Unknown)
  }
  give arduino_pkg.ok[GpioState](GpioState(st.cfg, st.opened, st.tx_count + 1, st.rx_count, st.error_count))
}

proc gpio_read(st: GpioState, pin: arduino_pkg.Pin) -> arduino_pkg.ArduinoResult[PinState] {
  if st.opened == false {
    give arduino_pkg.err[PinState](arduino_pkg.ArduinoError.Conflict)
  }
  if gpio_validate_pkg.valid_pin(st.cfg.profile, pin) == false {
    give arduino_pkg.err[PinState](arduino_pkg.ArduinoError.InvalidPin)
  }
  let raw: int = gpio_runtime_pkg.runtime_read(pin)
  if raw == 0 { give arduino_pkg.ok[PinState](PinState.Low) }
  give arduino_pkg.ok[PinState](PinState.High)
}

proc gpio_bundle_validate(bundle: arduino_pkg.ArduinoProjectBundle) -> arduino_pkg.ArduinoResult[bool] {
  let pvr = arduino_pkg.project_validate(bundle.preset)
  when pvr is arduino_pkg.ArduinoResult.Err { give arduino_pkg.err[bool](pvr.error) }

  let lvr = arduino_pkg.library_set_validate(bundle.preset.profile, bundle.libraries)
  when lvr is arduino_pkg.ArduinoResult.Err { give arduino_pkg.err[bool](lvr.error) }

  if bundle.preset.pins.len == 0 { give arduino_pkg.err[bool](arduino_pkg.ArduinoError.InvalidPin) }
  let i: int = 0
  loop {
    if i >= bundle.preset.pins.len { break }
    let vr = arduino_pkg.validate_pin(bundle.preset.profile, bundle.preset.pins[i])
    when vr is arduino_pkg.ArduinoResult.Err { give arduino_pkg.err[bool](vr.error) }
    i = i + 1
  }
  give arduino_pkg.ok[bool](true)
}

proc gpio_bundle_open(bundle: arduino_pkg.ArduinoProjectBundle) -> arduino_pkg.ArduinoResult[GpioState] {
  let bvr = gpio_bundle_validate(bundle)
  when bvr is arduino_pkg.ArduinoResult.Err { give arduino_pkg.err[GpioState](bvr.error) }
  let cfg0 = gpio_default_config()
  let cfg1 = gpio_with_profile(cfg0, bundle.preset.profile)
  let cfg2 = gpio_with_retry_budget(cfg1, bundle.preset.i2c_retry_budget)
  give arduino_pkg.ok[GpioState](gpio_open(cfg2))
}

proc gpio_bundle_apply(st: GpioState, bundle: arduino_pkg.ArduinoProjectBundle, state: PinState) -> arduino_pkg.ArduinoResult[GpioState] {
  let out = st
  let i: int = 0
  loop {
    if i >= bundle.preset.pins.len { break }
    let wr = gpio_write(out, bundle.preset.pins[i], state)
    when wr is arduino_pkg.ArduinoResult.Err {
      give arduino_pkg.err[GpioState](wr.error)
    }
    out = wr.value
    i = i + 1
  }
  give arduino_pkg.ok[GpioState](out)
}

# Compatibility wrappers
proc pin_mode(pin: int, mode: PinMode) -> int {
  let _ = pin
  let _ = mode
  give 0
}

proc digital_write(pin: int, state: PinState) -> int {
  let _ = pin
  let _ = state
  give 0
}

