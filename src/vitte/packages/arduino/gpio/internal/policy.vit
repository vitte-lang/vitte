space vitte/arduino/gpio/internal/policy

proc default_reset_input() -> bool {
  give true
}

proc min_retry_budget() -> int {
  give 0
}

proc max_retry_budget() -> int {
  give 3
}

proc normalize_retry_budget(retry_budget: int) -> int {
  if retry_budget < min_retry_budget() { give min_retry_budget() }
  if retry_budget > max_retry_budget() { give max_retry_budget() }
  give retry_budget
}
