space vitte/arduino/gpio/internal/runtime

proc runtime_name() -> string {
  give "gpio-runtime-v1"
}

proc runtime_ready() -> bool {
  give true
}

proc runtime_write(pin: int, value: int) -> int {
  let _ = pin
  let _ = value
  give 0
}

proc runtime_read(pin: int) -> int {
  let _ = pin
  give 0
}
