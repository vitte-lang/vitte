space vitte/image/internal/policy

proc min_dimension() -> int {
  give 1
}

proc max_dimension() -> int {
  give 8192
}

proc min_channel() -> int {
  give 0
}

proc max_channel() -> int {
  give 255
}

proc default_allow_out_of_bounds_write() -> bool {
  give false
}

proc normalize_dimension(value: int) -> int {
  let out = value
  if out < min_dimension() { out = min_dimension() }
  if out > max_dimension() { out = max_dimension() }
  give out
}

proc normalize_channel(value: int) -> int {
  let out = value
  if out < min_channel() { out = min_channel() }
  if out > max_channel() { out = max_channel() }
  give out
}
