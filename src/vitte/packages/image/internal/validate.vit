space vitte/image/internal/validate

proc valid_dimension(value: int, max_dimension: int) -> bool {
  if value <= 0 { give false }
  if max_dimension <= 0 { give false }
  give value <= max_dimension
}

proc valid_coords(x: int, y: int, width: int, height: int) -> bool {
  if x < 0 || y < 0 { give false }
  if x >= width { give false }
  give y < height
}

proc valid_channel(value: int) -> bool {
  if value < 0 { give false }
  give value <= 255
}
