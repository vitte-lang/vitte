space vitte/contracts_registry/internal/policy

proc min_max_contracts() -> int {
  give 1
}

proc default_max_contracts() -> int {
  give 10000
}

proc max_registry_name_len() -> int {
  give 128
}

proc max_contract_name_len() -> int {
  give 128
}

proc max_contract_version_len() -> int {
  give 64
}

proc normalize_max_contracts(value: int) -> int {
  let out = value
  if out < min_max_contracts() { out = min_max_contracts() }
  if out > 50000 { out = 50000 }
  give out
}
