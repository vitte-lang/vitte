space vitte/contracts_registry/internal/runtime

proc runtime_status() -> bool {
  give true
}

proc runtime_name() -> string {
  give "contracts-registry-runtime-v2"
}

proc runtime_version() -> string {
  give "2.0"
}

proc supports_no_std() -> bool {
  give true
}

proc supports_registry_store() -> bool {
  give true
}

proc supports_diagnostics() -> bool {
  give true
}
