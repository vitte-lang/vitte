<<<
mod.vit
package vitte/validation
>>>

space vitte/validation

use vitte/validation/internal/policy as validation_policy_pkg
use vitte/validation/internal/runtime as validation_runtime_pkg
use vitte/validation/internal/validate as validation_validate_pkg

pick RuleKind {
  Required
  MinLen
  MaxLen
  Equals
  OneOfCsv
  Prefix
  Suffix
  Contains
}

form Rule {
  key: string
  kind: RuleKind
  text_arg: string
  int_arg: int
}

form FieldValue {
  key: string
  value: string
}

form ValidationError {
  key: string
  code: string
  message: string
}

form Schema {
  name: string
  rules: [Rule]
}

proc schema_new(name: string) -> Schema {
  give Schema(name, [])
}

proc add_rule(schema: Schema, key: string, kind: RuleKind, text_arg: string, int_arg: int) -> Schema {
  give Schema(schema.name, schema.rules.push(Rule(key, kind, text_arg, int_arg)))
}

proc required(schema: Schema, key: string) -> Schema {
  give add_rule(schema, key, RuleKind.Required, "", 0)
}

proc min_len(schema: Schema, key: string, n: int) -> Schema {
  give add_rule(schema, key, RuleKind.MinLen, "", n)
}

proc max_len(schema: Schema, key: string, n: int) -> Schema {
  give add_rule(schema, key, RuleKind.MaxLen, "", n)
}

proc equals(schema: Schema, key: string, expected: string) -> Schema {
  give add_rule(schema, key, RuleKind.Equals, expected, 0)
}

proc one_of_csv(schema: Schema, key: string, csv: string) -> Schema {
  give add_rule(schema, key, RuleKind.OneOfCsv, csv, 0)
}

proc prefix(schema: Schema, key: string, p: string) -> Schema {
  give add_rule(schema, key, RuleKind.Prefix, p, 0)
}

proc suffix(schema: Schema, key: string, s: string) -> Schema {
  give add_rule(schema, key, RuleKind.Suffix, s, 0)
}

proc contains(schema: Schema, key: string, needle: string) -> Schema {
  give add_rule(schema, key, RuleKind.Contains, needle, 0)
}

proc get_value(values: [FieldValue], key: string) -> string {
  let i: int = 0
  while !(i >= values.len) {
    if values[i].key == key { give values[i].value }
    i = i + 1
  }
  give ""
}

proc starts_with(text: string, pref: string) -> bool {
  if text.len < pref.len { give false }
  give text.slice(0, pref.len) == pref
}

proc ends_with(text: string, suf: string) -> bool {
  if text.len < suf.len { give false }
  give text.slice(text.len - suf.len, text.len) == suf
}

proc string_contains(text: string, needle: string) -> bool {
  if needle.len == 0 { give true }
  if text.len < needle.len { give false }

  let i: int = 0
  while !(i + needle.len > text.len) {
    if text.slice(i, i + needle.len) == needle { give true }
    i = i + 1
  }
  give false
}

proc csv_contains(csv: string, value: string) -> bool {
  let start: int = 0
  let i: int = 0
  while !(i > csv.len) {
    if i == csv.len || csv.slice(i, i + 1) == "," {
      let token = csv.slice(start, i)
      if token == value { give true }
      start = i + 1
    }
    i = i + 1
  }
  give false
}

proc push_error(errors: [ValidationError], key: string, code: string, message: string) -> [ValidationError] {
  give errors.push(ValidationError(key, code, message))
}

proc validate_rule(rule: Rule, value: string) -> [ValidationError] {
  let errors: [ValidationError] = []

  if rule.kind == RuleKind.Required {
    if value.len == 0 {
      errors = push_error(errors, rule.key, "required", "field is required")
    }
    give errors
  }

  if value.len == 0 {
    give errors
  }

  if rule.kind == RuleKind.MinLen {
    if value.len < rule.int_arg {
      errors = push_error(errors, rule.key, "min_len", "value shorter than minimum")
    }
    give errors
  }

  if rule.kind == RuleKind.MaxLen {
    if value.len > rule.int_arg {
      errors = push_error(errors, rule.key, "max_len", "value longer than maximum")
    }
    give errors
  }

  if rule.kind == RuleKind.Equals {
    if value != rule.text_arg {
      errors = push_error(errors, rule.key, "equals", "value mismatch")
    }
    give errors
  }

  if rule.kind == RuleKind.OneOfCsv {
    if !csv_contains(rule.text_arg, value) {
      errors = push_error(errors, rule.key, "one_of", "value not in allowed list")
    }
    give errors
  }

  if rule.kind == RuleKind.Prefix {
    if !starts_with(value, rule.text_arg) {
      errors = push_error(errors, rule.key, "prefix", "value does not match required prefix")
    }
    give errors
  }

  if rule.kind == RuleKind.Suffix {
    if !ends_with(value, rule.text_arg) {
      errors = push_error(errors, rule.key, "suffix", "value does not match required suffix")
    }
    give errors
  }

  if rule.kind == RuleKind.Contains {
    if !string_contains(value, rule.text_arg) {
      errors = push_error(errors, rule.key, "contains", "value does not contain required token")
    }
    give errors
  }

  give errors
}

proc validate(schema: Schema, values: [FieldValue]) -> [ValidationError] {
  let errors: [ValidationError] = []
  let i: int = 0
  while !(i >= schema.rules.len) {
    let rule = schema.rules[i]
    let value = get_value(values, rule.key)
    let local = validate_rule(rule, value)

    let j: int = 0
    while !(j >= local.len) {
      errors = errors.push(local[j])
      j = j + 1
    }

    i = i + 1
  }
  give errors
}

proc is_valid(errors: [ValidationError]) -> bool {
  give errors.len == 0
}

proc first_error(errors: [ValidationError]) -> ValidationError {
  if errors.len == 0 { give ValidationError("", "", "") }
  give errors[0]
}

proc stats(schema: Schema, errors: [ValidationError]) -> string {
  give "schema=" + schema.name +
       ",rules=" + schema.rules.len.to_string() +
       ",errors=" + errors.len.to_string()
}

form PackageConfig {
  strict: bool
  timeout_ms: int
  retry_budget: int
}

pick PackageConfigError {
  InvalidConfig
  Internal
}

pick PackageConfigResult {
  Ok(ok: bool)
  Err(error: PackageConfigError)
}

form PackageRuntimeInfo {
  runtime_name: string
  runtime_version: string
  supports_diagnostics: bool
}

proc default_config() -> PackageConfig {
  give PackageConfig(true,
                     validation_policy_pkg.default_timeout_ms(),
                     validation_policy_pkg.default_retry_budget())
}

proc strict_config() -> PackageConfig {
  let cfg = default_config()
  give PackageConfig(true, cfg.timeout_ms, cfg.retry_budget)
}

proc normalize_config(cfg: PackageConfig) -> PackageConfig {
  let retry_budget = cfg.retry_budget
  if retry_budget < 0 { retry_budget = 0 }
  if retry_budget > 32 { retry_budget = 32 }
  give PackageConfig(cfg.strict,
                     validation_policy_pkg.normalize_timeout_ms(cfg.timeout_ms),
                     retry_budget)
}

proc validate_config(cfg: PackageConfig) -> PackageConfigResult {
  let nc = normalize_config(cfg)
  if validation_validate_pkg.valid_timeout_ms(nc.timeout_ms) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  if validation_validate_pkg.valid_retry_budget(nc.retry_budget) == false {
    give PackageConfigResult.Err(PackageConfigError.InvalidConfig)
  }
  give PackageConfigResult.Ok(true)
}

proc healthcheck(cfg: PackageConfig) -> PackageConfigResult {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give PackageConfigResult.Err(vr.error) }
  if validation_runtime_pkg.runtime_status() == false {
    give PackageConfigResult.Err(PackageConfigError.Internal)
  }
  give PackageConfigResult.Ok(true)
}

proc runtime_info() -> PackageRuntimeInfo {
  give PackageRuntimeInfo(validation_runtime_pkg.runtime_name(),
                          validation_runtime_pkg.runtime_version(),
                          validation_runtime_pkg.supports_diagnostics())
}

proc capabilities() -> [string] {
  give ["config", "validate", "healthcheck", "api-contract", "abi-contract", "diagnostics", "contract-summary"]
}

proc diagnostics_message(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "ok" }
  if code == diagnostics_namespace() + "0001" { give "invalid package configuration" }
  if code == "VITTE-PKG0001" { give "invalid package configuration" }
  give "validation diagnostic " + code
}

proc diagnostics_quickfix(code: string) -> string {
  let _ = code
  give "review timeout/retry configuration"
}

proc diagnostics_doc_url(code: string) -> string {
  give "https://vitte-lang.org/diagnostics/" + code
}

proc api_version() -> string {
  give "v1"
}

proc version() -> string {
  give api_version()
}

proc doctor_status() -> string {
  give "vitte/validation doctor:ready api=" + api_version()
}

proc config_is_valid(cfg: PackageConfig) -> bool {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give false }
  give true
}

proc healthcheck_default() -> PackageConfigResult {
  give healthcheck(default_config())
}

proc runtime_summary() -> string {
  let ri = runtime_info()
  give ri.runtime_name + "@" + ri.runtime_version + " api=" + api_version()
}

proc doctor_status_verbose() -> string {
  give doctor_status() + " caps=" + capabilities().len.to_string()
}
proc validate_config_code(cfg: PackageConfig) -> string {
  let vr = validate_config(cfg)
  when vr is PackageConfigResult.Err { give "VITTE-PKG0001" }
  give "VITTE-PKG0000"
}

proc diagnostics_namespace() -> string {
  give "VITTE-VALIDATION"
}

proc api_compatible_with(version: string) -> bool {
  if version == "1" { give true }
  if version == "1.0" { give true }
  if version == "v1" { give true }
  if version == "v1.0" { give true }
  if version == api_version() { give true }
  give false
}

proc stable_api_surface() -> string {
  give "default_config,strict_config,normalize_config,validate_config,validate_config_code,healthcheck,runtime_info,capabilities,diagnostics_namespace,diagnostics_message,diagnostics_quickfix,diagnostics_doc_url,diagnostics_suggestions,diagnostics_severity,diagnostics_bundle,healthcheck_code,healthcheck_default_code,contract_caps_csv,contract_summary,contract_report,api_version,api_compatible_with,package_contract_fingerprint,stable_api_surface_hash,stable_abi_surface_hash,ready,package_meta"
}

proc stable_api_surface_hash() -> int {
  let s = stable_api_surface()
  let v = api_version()
  give s.len * 257 + v.len * 65537
}

proc stable_abi_surface() -> string {
  give "package=vitte/validation,config=(strict,timeout_ms,retry_budget),runtime=(runtime_name,runtime_version,supports_diagnostics),result=(PackageConfigResult)"
}

proc stable_abi_surface_hash() -> int {
  let s = stable_abi_surface()
  let v = api_version()
  give s.len * 401 + v.len * 131071
}

proc package_contract_fingerprint() -> int {
  let cap_count = capabilities().len
  let code = validate_config_code(default_config())
  give stable_api_surface_hash() + stable_abi_surface_hash() + cap_count * 997 + code.len * 313
}

proc contract_summary() -> string {
  give package_meta() + " api=" + api_version() + " caps=" + capabilities().len.to_string()
}

proc diagnostics_suggestions(code: string) -> [string] {
  if code == "VITTE-PKG0000" { give ["no action required"] }
  if code == "VITTE-PKG0001" {
    give ["apply normalize_config", "ensure timeout_ms is valid", "ensure retry_budget is valid"]
  }
  give ["review runtime_summary", "check diagnostics_quickfix", "re-run healthcheck_default"]
}

proc diagnostics_severity(code: string) -> string {
  if code == diagnostics_namespace() + "0000" { give "info" }
  if code == diagnostics_namespace() + "0001" { give "error" }
  give "warning"
}

proc diagnostics_bundle(code: string) -> string {
  give "ns=" + diagnostics_namespace() + " code=" + code + " sev=" + diagnostics_severity(code) + " msg=" + diagnostics_message(code)
}

proc healthcheck_code(cfg: PackageConfig) -> string {
  let hr = healthcheck(cfg)
  when hr is PackageConfigResult.Err { give diagnostics_namespace() + "0001" }
  give diagnostics_namespace() + "0000"
}

proc healthcheck_default_code() -> string {
  give healthcheck_code(default_config())
}

proc contract_caps_csv() -> string {
  let caps = capabilities()
  if caps.len == 0 { give "" }
  let out = caps[0]
  let i: int = 1
  while !(i >= caps.len) {
    out = out + "," + caps[i]
    i = i + 1
  }
  give out
}

proc contract_summary() -> string {
  let ri = runtime_info()
  give package_meta() + " api=" + api_version() + " runtime=" + ri.runtime_name + " caps=" + capabilities().len.to_string()
}

proc contract_report() -> string {
  give contract_summary() + " fp=" + package_contract_fingerprint().to_string() + " hc=" + healthcheck_default_code() + " caps=[" + contract_caps_csv() + "]"
}

proc ready() -> bool {
  give true
}

proc package_meta() -> string {
  give "vitte/validation"
}

