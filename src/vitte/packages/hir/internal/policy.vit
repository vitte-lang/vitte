space vitte/hir/internal/policy

proc min_nodes() -> int {
  give 0
}

proc max_nodes() -> int {
  give 100000
}

proc default_require_return() -> bool {
  give true
}

proc default_allow_empty_symbol() -> bool {
  give false
}

proc normalize_max_nodes(value: int) -> int {
  let out = value
  if out < min_nodes() { out = min_nodes() }
  if out > max_nodes() { out = max_nodes() }
  give out
}
