space vitte/hir/internal/validate

proc valid_module_name(name: string) -> bool {
  give name.len > 0
}

proc valid_node_id(id: int) -> bool {
  give id >= 0
}

proc valid_symbol(symbol: string, allow_empty_symbol: bool) -> bool {
  if symbol.len == 0 { give allow_empty_symbol }
  give true
}

proc valid_nodes_len(count: int, max_nodes: int) -> bool {
  if count < 0 { give false }
  if max_nodes < 0 { give false }
  give count <= max_nodes
}
