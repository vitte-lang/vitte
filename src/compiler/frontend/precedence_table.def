// token, lexeme, ast::BinaryOp, precedence, core
VITTE_PRECEDENCE_OP(TokenKind::Equal, "=", ast::BinaryOp::Assign, 1, true)
VITTE_PRECEDENCE_OP(TokenKind::PlusEqual, "+=", ast::BinaryOp::Assign, 1, true)
VITTE_PRECEDENCE_OP(TokenKind::MinusEqual, "-=", ast::BinaryOp::Assign, 1, true)
VITTE_PRECEDENCE_OP(TokenKind::StarEqual, "*=", ast::BinaryOp::Assign, 1, true)
VITTE_PRECEDENCE_OP(TokenKind::SlashEqual, "/=", ast::BinaryOp::Assign, 1, true)
VITTE_PRECEDENCE_OP(TokenKind::PercentEqual, "%=", ast::BinaryOp::Assign, 1, true)
VITTE_PRECEDENCE_OP(TokenKind::KwOr, "or", ast::BinaryOp::Or, 2, true)
VITTE_PRECEDENCE_OP(TokenKind::PipePipe, "||", ast::BinaryOp::Or, 2, true)
VITTE_PRECEDENCE_OP(TokenKind::KwAnd, "and", ast::BinaryOp::And, 3, true)
VITTE_PRECEDENCE_OP(TokenKind::AmpAmp, "&&", ast::BinaryOp::And, 3, true)
VITTE_PRECEDENCE_OP(TokenKind::Pipe, "|", ast::BinaryOp::BitOr, 4, true)
VITTE_PRECEDENCE_OP(TokenKind::Caret, "^", ast::BinaryOp::BitXor, 5, true)
VITTE_PRECEDENCE_OP(TokenKind::Amp, "&", ast::BinaryOp::BitAnd, 6, true)
VITTE_PRECEDENCE_OP(TokenKind::EqEq, "==", ast::BinaryOp::Eq, 7, true)
VITTE_PRECEDENCE_OP(TokenKind::NotEq, "!=", ast::BinaryOp::Ne, 7, true)
VITTE_PRECEDENCE_OP(TokenKind::Lt, "<", ast::BinaryOp::Lt, 8, true)
VITTE_PRECEDENCE_OP(TokenKind::Le, "<=", ast::BinaryOp::Le, 8, true)
VITTE_PRECEDENCE_OP(TokenKind::Gt, ">", ast::BinaryOp::Gt, 8, true)
VITTE_PRECEDENCE_OP(TokenKind::Ge, ">=", ast::BinaryOp::Ge, 8, true)
VITTE_PRECEDENCE_OP(TokenKind::Shl, "<<", ast::BinaryOp::Shl, 9, true)
VITTE_PRECEDENCE_OP(TokenKind::Shr, ">>", ast::BinaryOp::Shr, 9, true)
VITTE_PRECEDENCE_OP(TokenKind::Plus, "+", ast::BinaryOp::Add, 10, true)
VITTE_PRECEDENCE_OP(TokenKind::Minus, "-", ast::BinaryOp::Sub, 10, true)
VITTE_PRECEDENCE_OP(TokenKind::Star, "*", ast::BinaryOp::Mul, 11, true)
VITTE_PRECEDENCE_OP(TokenKind::Slash, "/", ast::BinaryOp::Div, 11, true)
VITTE_PRECEDENCE_OP(TokenKind::Percent, "%", ast::BinaryOp::Mod, 11, true)
