type_params ::= "[" WS? ident_list WS? "]" ;

<<< ——————————————————— ) ( Entry point ) ( ——————————————————— >>>

entry_decl ::= "entry" WS1 ident WS1 "at" WS1 module_path WS? block ;

<<< ——————————————————— ) ( Block ) ( ——————————————————— >>>

block ::= "{" WS? { stmt WS? } "}" ;

<<< ——————————————————— ) ( Statements ) ( ——————————————————— >>>

stmt ::= let_stmt
