<<< ——————————————————— ) ( Types ) ( ——————————————————— >>>

type_alias_decl ::= "type" WS1 ident type_params? WS? "=" WS? type_expr ;

form_decl ::= ("form" | "trait") WS1 ident type_params? WS?
