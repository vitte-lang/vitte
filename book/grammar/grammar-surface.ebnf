cast_expr ::= unary_expr { WS? ("as" WS? type_expr | "is" WS? pattern) } ;

unary_expr ::= ("not" | "!" | "-" | "&" | "*") WS? unary_expr | postfix_expr ;

postfix_expr ::= primary { postfix } ;
