<<< ——————————————————— ) ( Attributes ) ( ——————————————————— >>>

attribute ::= "#[" ident [ "(" WS? attr_args? WS? ")" ] "]" ;
attr_args ::= attr_arg { WS? "," WS? attr_arg } ;
