space vitte/compiler/middle/typecheck/rules

use vitte/compiler/frontend/ast.node.{ AstSpan, ast_span_empty }

use vitte/compiler/middle/hir.{
  HirExpr,
  HirExprKind,
  HirItem,
  HirStmt,
  HirStmtKind
}

use vitte/compiler/middle/typecheck/diagnostics.{
  TypeDiagnostic,
  TypeDiagnosticBag,
  append_diagnostic,
  diagnostic_bag,
  invalid_assignment,
  invalid_binary_operator,
  invalid_borrow,
  invalid_call,
  invalid_move,
  invalid_return,
  type_mismatch,
  unknown_symbol,
  unknown_type
}

export *

pick TypeRuleKind {
  Expr,
  Statement,
  Assignment,
  Borrow,
  Move,
  Call,
  Return,
  Binary,
  Unary,
  Match,
  Pattern,
  Cast,
  ControlFlow,
  Lifetime,
  TraitBound,
}

pick TypeRuleResultKind {
  Accepted,
  Rejected,
  Deferred,
}

form TypeRule {
  id: u64
  name: string
  kind: TypeRuleKind
  enabled: bool
  recoverable: bool
  valid: bool
}

form TypeRuleResult {
  rule: TypeRule
  result: TypeRuleResultKind
  diagnostics: [TypeDiagnostic]
  checked_nodes: u64
  valid: bool
}

form TypeRuleEngine {
  rules: [TypeRule]
  checked_rules: u64
  accepted_rules: u64
  rejected_rules: u64
  deferred_rules: u64
  diagnostics: TypeDiagnosticBag
  valid: bool
}

proc type_rule(id: u64, name: string, kind: TypeRuleKind, enabled: bool, recoverable: bool, valid: bool) -> TypeRule {
  give TypeRule {
    id: id,
    name: name,
    kind: kind,
    enabled: enabled,
    recoverable: recoverable,
    valid: valid
  }
}

proc type_rule_result(rule: TypeRule, result: TypeRuleResultKind, diagnostics: [TypeDiagnostic], checked_nodes: u64, valid: bool) -> TypeRuleResult {
  give TypeRuleResult {
    rule: rule,
    result: result,
    diagnostics: diagnostics,
    checked_nodes: checked_nodes,
    valid: valid
  }
}

proc type_rule_engine() -> TypeRuleEngine {
  give TypeRuleEngine {
    rules: [
      type_rule(1, "expr", TypeRuleKind.Expr, true, true, true),
      type_rule(2, "assignment", TypeRuleKind.Assignment, true, true, true),
      type_rule(3, "borrow", TypeRuleKind.Borrow, true, false, true),
      type_rule(4, "move", TypeRuleKind.Move, true, false, true),
      type_rule(5, "call", TypeRuleKind.Call, true, true, true),
      type_rule(6, "return", TypeRuleKind.Return, true, true, true),
      type_rule(7, "binary", TypeRuleKind.Binary, true, true, true)
    ],
    checked_rules: 0,
    accepted_rules: 0,
    rejected_rules: 0,
    deferred_rules: 0,
    diagnostics: diagnostic_bag(),
    valid: true
  }
}

proc rule_kind_name(kind: TypeRuleKind) -> string {
  if kind == TypeRuleKind.Expr {
    give "expr"
  } elif kind == TypeRuleKind.Statement {
    give "statement"
  } elif kind == TypeRuleKind.Assignment {
    give "assignment"
  } elif kind == TypeRuleKind.Borrow {
    give "borrow"
  } elif kind == TypeRuleKind.Move {
    give "move"
  } elif kind == TypeRuleKind.Call {
    give "call"
  } elif kind == TypeRuleKind.Return {
    give "return"
  } elif kind == TypeRuleKind.Binary {
    give "binary"
  } elif kind == TypeRuleKind.Unary {
    give "unary"
  } elif kind == TypeRuleKind.Match {
    give "match"
  } elif kind == TypeRuleKind.Pattern {
    give "pattern"
  } elif kind == TypeRuleKind.Cast {
    give "cast"
  } elif kind == TypeRuleKind.ControlFlow {
    give "control-flow"
  } elif kind == TypeRuleKind.Lifetime {
    give "lifetime"
  } elif kind == TypeRuleKind.TraitBound {
    give "trait-bound"
  }

  give "unknown"
}

proc rule_result_name(kind: TypeRuleResultKind) -> string {
  if kind == TypeRuleResultKind.Accepted {
    give "accepted"
  } elif kind == TypeRuleResultKind.Rejected {
    give "rejected"
  } elif kind == TypeRuleResultKind.Deferred {
    give "deferred"
  }

  give "unknown"
}

proc append_engine_diagnostic(engine: TypeRuleEngine, diagnostic: TypeDiagnostic) -> TypeRuleEngine {
  give TypeRuleEngine {
    rules: engine.rules,
    checked_rules: engine.checked_rules,
    accepted_rules: engine.accepted_rules,
    rejected_rules: engine.rejected_rules,
    deferred_rules: engine.deferred_rules,
    diagnostics: append_diagnostic(engine.diagnostics, diagnostic),
    valid: engine.valid and diagnostic.valid
  }
}

proc register_result(engine: TypeRuleEngine, result: TypeRuleResult) -> TypeRuleEngine {
  let out: TypeRuleEngine = engine

  set out.checked_rules = out.checked_rules + 1

  if result.result == TypeRuleResultKind.Accepted {
    set out.accepted_rules = out.accepted_rules + 1
  } elif result.result == TypeRuleResultKind.Rejected {
    set out.rejected_rules = out.rejected_rules + 1
  } elif result.result == TypeRuleResultKind.Deferred {
    set out.deferred_rules = out.deferred_rules + 1
  }

  let i: u64 = 0

  while i < len(result.diagnostics) {
    set out = append_engine_diagnostic(out, result.diagnostics[i])

    set i = i + 1
  }

  set out.valid = out.valid and result.valid

  give out
}

proc valid_assignment(stmt: HirStmt) -> bool {
  if stmt.target == "" {
    give false
  }

  if stmt.expr.inferred_type == "unknown" {
    give false
  }

  give stmt.valid
}

proc valid_binary_expr(expr: HirExpr) -> bool {
  if expr.kind != HirExprKind.Binary {
    give true
  }

  if len(expr.children) != 2 {
    give false
  }

  if expr.operator == "" {
    give false
  }

  give expr.valid
}

proc valid_borrow_expr(expr: HirExpr) -> bool {
  if expr.kind != HirExprKind.BorrowShared and expr.kind != HirExprKind.BorrowMut {
    give true
  }

  if expr.binding == "" {
    give false
  }

  give expr.valid
}

proc valid_call_expr(expr: HirExpr) -> bool {
  if expr.kind != HirExprKind.Call {
    give true
  }

  if expr.name == "" and expr.text == "" {
    give false
  }

  give expr.valid
}

proc check_assignment_rule(rule: TypeRule, stmt: HirStmt) -> TypeRuleResult {
  if valid_assignment(stmt) {
    give type_rule_result(
      rule,
      TypeRuleResultKind.Accepted,
      [],
      1,
      true
    )
  }

  give type_rule_result(
    rule,
    TypeRuleResultKind.Rejected,
    [
      invalid_assignment(
        stmt.target_resolved_kind,
        stmt.expr.inferred_type,
        stmt.span
      )
    ],
    1,
    false
  )
}

proc check_binary_rule(rule: TypeRule, expr: HirExpr) -> TypeRuleResult {
  if valid_binary_expr(expr) {
    give type_rule_result(
      rule,
      TypeRuleResultKind.Accepted,
      [],
      1,
      true
    )
  }

  give type_rule_result(
    rule,
    TypeRuleResultKind.Rejected,
    [
      invalid_binary_operator(
        expr.operator,
        "lhs",
        "rhs",
        expr.span
      )
    ],
    1,
    false
  )
}

proc check_borrow_rule(rule: TypeRule, expr: HirExpr) -> TypeRuleResult {
  if valid_borrow_expr(expr) {
    give type_rule_result(
      rule,
      TypeRuleResultKind.Accepted,
      [],
      1,
      true
    )
  }

  give type_rule_result(
    rule,
    TypeRuleResultKind.Rejected,
    [
      invalid_borrow(
        expr.binding,
        expr.span
      )
    ],
    1,
    false
  )
}

proc check_move_rule(rule: TypeRule, expr: HirExpr) -> TypeRuleResult {
  if expr.value_mode == "moved" {
    give type_rule_result(
      rule,
      TypeRuleResultKind.Rejected,
      [
        invalid_move(
          expr.text,
          expr.span
        )
      ],
      1,
      false
    )
  }

  give type_rule_result(
    rule,
    TypeRuleResultKind.Accepted,
    [],
    1,
    true
  )
}

proc check_call_rule(rule: TypeRule, expr: HirExpr) -> TypeRuleResult {
  if valid_call_expr(expr) {
    give type_rule_result(
      rule,
      TypeRuleResultKind.Accepted,
      [],
      1,
      true
    )
  }

  give type_rule_result(
    rule,
    TypeRuleResultKind.Rejected,
    [
      invalid_call(
        expr.name,
        "callable",
        "invalid",
        expr.span
      )
    ],
    1,
    false
  )
}

proc check_return_rule(rule: TypeRule, stmt: HirStmt, expected: string) -> TypeRuleResult {
  if stmt.expr.inferred_type == expected {
    give type_rule_result(
      rule,
      TypeRuleResultKind.Accepted,
      [],
      1,
      true
    )
  }

  give type_rule_result(
    rule,
    TypeRuleResultKind.Rejected,
    [
      invalid_return(
        expected,
        stmt.expr.inferred_type,
        stmt.span
      )
    ],
    1,
    false
  )
}

proc resolve_rule(engine: TypeRuleEngine, kind: TypeRuleKind) -> TypeRule {
  let i: u64 = 0

  while i < len(engine.rules) {
    if engine.rules[i].kind == kind {
      give engine.rules[i]
    }

    set i = i + 1
  }

  give type_rule(
    0,
    "unknown",
    kind,
    false,
    false,
    false
  )
}

proc check_expr_rules(engine: TypeRuleEngine, expr: HirExpr) -> TypeRuleEngine {
  let out: TypeRuleEngine = engine

  if expr.kind == HirExprKind.Binary {
    let rule: TypeRule = resolve_rule(out, TypeRuleKind.Binary)
    let result: TypeRuleResult = check_binary_rule(rule, expr)
    set out = register_result(out, result)
  }

  if expr.kind == HirExprKind.BorrowShared or expr.kind == HirExprKind.BorrowMut {
    let rule: TypeRule = resolve_rule(out, TypeRuleKind.Borrow)
    let result: TypeRuleResult = check_borrow_rule(rule, expr)
    set out = register_result(out, result)
  }

  if expr.kind == HirExprKind.Call {
    let rule: TypeRule = resolve_rule(out, TypeRuleKind.Call)
    let result: TypeRuleResult = check_call_rule(rule, expr)
    set out = register_result(out, result)
  }

  let move_rule: TypeRule = resolve_rule(out, TypeRuleKind.Move)
  let move_result: TypeRuleResult = check_move_rule(move_rule, expr)
  set out = register_result(out, move_result)

  let i: u64 = 0

  while i < len(expr.children) {
    set out = check_expr_rules(out, expr.children[i])

    set i = i + 1
  }

  give out
}

proc check_stmt_rules(engine: TypeRuleEngine, stmt: HirStmt, expected_return: string) -> TypeRuleEngine {
  let out: TypeRuleEngine = engine

  if stmt.kind == HirStmtKind.Set or stmt.kind == HirStmtKind.Let {
    let rule: TypeRule = resolve_rule(out, TypeRuleKind.Assignment)
    let result: TypeRuleResult = check_assignment_rule(rule, stmt)
    set out = register_result(out, result)
  }

  if stmt.kind == HirStmtKind.Give {
    let rule: TypeRule = resolve_rule(out, TypeRuleKind.Return)
    let result: TypeRuleResult = check_return_rule(rule, stmt, expected_return)
    set out = register_result(out, result)
  }

  set out = check_expr_rules(out, stmt.expr)

  let i: u64 = 0

  while i < len(stmt.then_stmts) {
    set out = check_stmt_rules(out, stmt.then_stmts[i], expected_return)

    set i = i + 1
  }

  set i = 0

  while i < len(stmt.else_stmts) {
    set out = check_stmt_rules(out, stmt.else_stmts[i], expected_return)

    set i = i + 1
  }

  give out
}

proc check_item_rules(engine: TypeRuleEngine, item: HirItem) -> TypeRuleEngine {
  let out: TypeRuleEngine = engine
  let expected_return: string = "void"

  let i: u64 = 0

  while i < len(item.stmts) {
    set out = check_stmt_rules(out, item.stmts[i], expected_return)

    set i = i + 1
  }

  give out
}

proc engine_summary(engine: TypeRuleEngine) -> string {
  let rule_count_text: string = len(engine.rules) as string
  let checked_text: string = engine.checked_rules as string
  let accepted_text: string = engine.accepted_rules as string
  let rejected_text: string = engine.rejected_rules as string
  let deferred_text: string = engine.deferred_rules as string
  let diagnostic_count_text: string = len(engine.diagnostics.diagnostics) as string
  let valid_text: string = engine.valid as string
  let out: string = "rules " + rule_count_text
  let with_checked: string = out + " checked " + checked_text
  let with_accepted: string = with_checked + " accepted " + accepted_text
  let with_rejected: string = with_accepted + " rejected " + rejected_text
  let with_deferred: string = with_rejected + " deferred " + deferred_text
  let with_diagnostics: string = with_deferred + " diagnostics " + diagnostic_count_text
  give with_diagnostics + " valid " + valid_text
}

proc typecheck_rules_selftest() -> bool {
  let expr: HirExpr = HirExpr {
      id: 1,
      span: ast_span_empty(),
      kind: HirExprKind.Binary,
      text: "1 + 2",
      name: "",
      operator: "+",
      binding: "",
      resolved_id: 0,
      resolved_kind: "",
      external: false,
      value_mode: "copy",
      inferred_type: "i32",
      place_category: "value",
      copyable: true,
      diagnostics: [],
      children: [
        HirExpr {
          id: 2,
          span: ast_span_empty(),
          kind: HirExprKind.Int,
          text: "1",
          name: "",
          operator: "",
          binding: "",
          resolved_id: 0,
          resolved_kind: "",
          external: false,
          value_mode: "copy",
          inferred_type: "i32",
          place_category: "value",
          copyable: true,
          diagnostics: [],
          children: [],
          valid: true
        },
        HirExpr {
          id: 3,
          span: ast_span_empty(),
          kind: HirExprKind.Int,
          text: "2",
          name: "",
          operator: "",
          binding: "",
          resolved_id: 0,
          resolved_kind: "",
          external: false,
          value_mode: "copy",
          inferred_type: "i32",
          place_category: "value",
          copyable: true,
          diagnostics: [],
          children: [],
          valid: true
        }
      ],
      valid: true
    }

  let stmt: HirStmt = HirStmt {
      id: 1,
      span: ast_span_empty(),
      kind: HirStmtKind.Set,
      name: "x",
      target: "x",
      target_binding: "x",
      target_resolved_id: 1,
      target_resolved_kind: "i32",
      expr: expr,
      message: "",
      mutable: true,
      scope_depth: 0,
      then_stmts: [],
      else_stmts: [],
      catch_stmts: [],
      diagnostics: [],
      valid: true
    }

  let item: HirItem = HirItem {
      id: 1,
      span: ast_span_empty(),
      kind: HirItemKind.Proc,
      name: "main",
      resolved_id: 0,
      namespace: "demo",
      visibility: "public",
      expr: expr,
      stmts: [stmt],
      message: "",
      scope_depth: 0,
      diagnostics: [],
      valid: true
    }

  let engine: TypeRuleEngine = check_item_rules(type_rule_engine(), item)

  give engine.valid
    and engine.checked_rules > 0
    and engine.accepted_rules > 0
    and engine.rejected_rules == 0
    and rule_kind_name(TypeRuleKind.Binary) == "binary"
    and rule_result_name(TypeRuleResultKind.Accepted) == "accepted"
    and engine_summary(engine) != ""
}
