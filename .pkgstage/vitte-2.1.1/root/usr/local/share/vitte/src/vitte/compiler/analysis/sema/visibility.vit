space vitte/compiler/analysis/sema

pick VisibilityKind {
    Inherited
    Private
    Public
    Internal
    Export
    Package
    Protected
    External
    Invalid
}

form VisibilityInfo {
    text: string
    kind: VisibilityKind
    normalized: string
    exported: bool
    externally_visible: bool
    valid: bool
}

proc visibility_kind_name(kind: VisibilityKind) -> string {
    if kind == VisibilityKind.Inherited {
        give "inherited";
    }

    if kind == VisibilityKind.Private {
        give "private";
    }

    if kind == VisibilityKind.Public {
        give "public";
    }

    if kind == VisibilityKind.Internal {
        give "internal";
    }

    if kind == VisibilityKind.Export {
        give "export";
    }

    if kind == VisibilityKind.Package {
        give "package";
    }

    if kind == VisibilityKind.Protected {
        give "protected";
    }

    if kind == VisibilityKind.External {
        give "external";
    }

    give "invalid";
}

proc normalize_visibility(visibility: string) -> string {
    let value: string = trim(lower(visibility));

    if value == "" {
        give "";
    }

    if value == "pub" {
        give "public";
    }

    if value == "priv" {
        give "private";
    }

    if value == "extern" {
        give "external";
    }

    give value;
}

proc visibility_kind(visibility: string) -> VisibilityKind {
    let value: string = normalize_visibility(visibility);

    if value == "" {
        give VisibilityKind.Inherited;
    }

    if value == "private" {
        give VisibilityKind.Private;
    }

    if value == "public" {
        give VisibilityKind.Public;
    }

    if value == "internal" {
        give VisibilityKind.Internal;
    }

    if value == "export" {
        give VisibilityKind.Export;
    }

    if value == "package" {
        give VisibilityKind.Package;
    }

    if value == "protected" {
        give VisibilityKind.Protected;
    }

    if value == "external" {
        give VisibilityKind.External;
    }

    give VisibilityKind.Invalid;
}

proc visibility_valid(visibility: string) -> bool {
    give visibility_kind(visibility) != VisibilityKind.Invalid;
}

proc visibility_exported(visibility: string) -> bool {
    let kind: VisibilityKind = visibility_kind(visibility);

    give kind == VisibilityKind.Public or kind == VisibilityKind.Export or kind == VisibilityKind.External;
}

proc visibility_externally_visible(visibility: string) -> bool {
    let kind: VisibilityKind = visibility_kind(visibility);

    give kind == VisibilityKind.Public or kind == VisibilityKind.External;
}

proc visibility_is_internal_only(visibility: string) -> bool {
    let kind: VisibilityKind = visibility_kind(visibility);

    give kind == VisibilityKind.Private or kind == VisibilityKind.Internal or kind == VisibilityKind.Package or kind == VisibilityKind.Protected;
}

proc visibility_info(visibility: string) -> VisibilityInfo {
    let normalized: string = normalize_visibility(visibility);
    let kind: VisibilityKind = visibility_kind(normalized);

    give VisibilityInfo {
        text: visibility,
        kind: kind,
        normalized: normalized,
        exported: visibility_exported(normalized),
        externally_visible: visibility_externally_visible(normalized),
        valid: kind != VisibilityKind.Invalid
    };
}

proc default_visibility() -> string {
    give "private";
}

proc inherited_visibility() -> string {
    give "";
}

proc visibility_merge(parent_visibility: string, child_visibility: string) -> string {
    let child: string = normalize_visibility(child_visibility);

    if child != "" {
        give child;
    }

    let parent: string = normalize_visibility(parent_visibility);

    if parent != "" {
        give parent;
    }

    give default_visibility();
}

proc visibility_more_permissive(left: string, right: string) -> string {
    let l: VisibilityKind = visibility_kind(left);
    let r: VisibilityKind = visibility_kind(right);

    if l == VisibilityKind.External or r == VisibilityKind.External {
        give "external";
    }

    if l == VisibilityKind.Public or r == VisibilityKind.Public {
        give "public";
    }

    if l == VisibilityKind.Export or r == VisibilityKind.Export {
        give "export";
    }

    if l == VisibilityKind.Internal or r == VisibilityKind.Internal {
        give "internal";
    }

    if l == VisibilityKind.Package or r == VisibilityKind.Package {
        give "package";
    }

    if l == VisibilityKind.Protected or r == VisibilityKind.Protected {
        give "protected";
    }

    give "private";
}

proc visibility_less_permissive(left: string, right: string) -> string {
    let l: VisibilityKind = visibility_kind(left);
    let r: VisibilityKind = visibility_kind(right);

    if l == VisibilityKind.Private or r == VisibilityKind.Private {
        give "private";
    }

    if l == VisibilityKind.Protected or r == VisibilityKind.Protected {
        give "protected";
    }

    if l == VisibilityKind.Package or r == VisibilityKind.Package {
        give "package";
    }

    if l == VisibilityKind.Internal or r == VisibilityKind.Internal {
        give "internal";
    }

    if l == VisibilityKind.Export or r == VisibilityKind.Export {
        give "export";
    }

    if l == VisibilityKind.Public or r == VisibilityKind.Public {
        give "public";
    }

    if l == VisibilityKind.External or r == VisibilityKind.External {
        give "external";
    }

    give "private";
}

share VisibilityKind
share VisibilityInfo

share visibility_kind_name
share normalize_visibility
share visibility_kind
share visibility_valid
share visibility_exported
share visibility_externally_visible
share visibility_is_internal_only
share visibility_info

share default_visibility
share inherited_visibility
share visibility_merge
share visibility_more_permissive
share visibility_less_permissive
