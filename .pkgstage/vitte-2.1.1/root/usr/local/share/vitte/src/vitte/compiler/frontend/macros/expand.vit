space vitte/compiler/frontend/macros/expand

use vitte/compiler/frontend/macros/builtin.{ apply_builtin_macros }
use vitte/compiler/frontend/macros/hygiene.{ enforce_macro_hygiene }

proc expand_macros(text: string) -> string {
  let a: string = apply_builtin_macros(text);
  give enforce_macro_hygiene(a);
}
