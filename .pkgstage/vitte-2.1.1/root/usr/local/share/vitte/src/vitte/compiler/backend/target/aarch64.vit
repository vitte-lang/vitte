space vitte/compiler/backend/target/aarch64

use vitte/compiler/backend/target/triple.{ TargetTriple, target_triple }

export *

form Aarch64Target {
  triple: TargetTriple
  cpu: string
  vendor_name: string
  pointer_width: u64
  register_width: u64
  little_endian: bool
  stack_alignment: u64
  function_alignment: u64
  supports_fp: bool
  supports_neon: bool
  supports_asimd: bool
  supports_aes: bool
  supports_sha2: bool
  supports_crc: bool
  supports_lse: bool
  supports_atomic64: bool
  calling_convention: string
  object_format: string
  executable_extension: string
  static_library_extension: string
  dynamic_library_extension: string
  valid: bool
}

proc aarch64_target(vendor: string, os: string, abi: string) -> Aarch64Target {
  let triple: TargetTriple = target_triple("aarch64", vendor, os, abi);
  let object_format: string = if os == "macos" { "macho" } elif os == "windows" { "coff" } else { "elf" };
  let cc: string = if os == "windows" { "win64" } elif os == "macos" { "darwin-aapcs64" } else { "aapcs64" };
  let dll_ext: string = if os == "windows" { ".dll" } elif os == "macos" { ".dylib" } else { ".so" };
  let exe_ext: string = if os == "windows" { ".exe" } else { "" };
  let static_ext: string = if os == "windows" { ".lib" } else { ".a" };
  give Aarch64Target {
    triple: triple,
    cpu: "generic-aarch64",
    vendor_name: vendor,
    pointer_width: 64,
    register_width: 64,
    little_endian: true,
    stack_alignment: 16,
    function_alignment: 16,
    supports_fp: true,
    supports_neon: true,
    supports_asimd: true,
    supports_aes: true,
    supports_sha2: true,
    supports_crc: true,
    supports_lse: true,
    supports_atomic64: true,
    calling_convention: cc,
    object_format: object_format,
    executable_extension: exe_ext,
    static_library_extension: static_ext,
    dynamic_library_extension: dll_ext,
    valid: true,
  };
}

proc target_aarch64_linux() -> Aarch64Target { give aarch64_target("vitte", "linux", "gnu"); }
proc target_aarch64_macos() -> Aarch64Target { give aarch64_target("apple", "macos", "macho"); }

proc target_aarch64_embedded() -> Aarch64Target {
  let base: Aarch64Target = aarch64_target("embedded", "none", "elf");
  give Aarch64Target {
    triple: base.triple,
    cpu: "cortex-a53",
    vendor_name: base.vendor_name,
    pointer_width: base.pointer_width,
    register_width: base.register_width,
    little_endian: true,
    stack_alignment: 16,
    function_alignment: 4,
    supports_fp: true,
    supports_neon: true,
    supports_asimd: true,
    supports_aes: false,
    supports_sha2: false,
    supports_crc: true,
    supports_lse: false,
    supports_atomic64: true,
    calling_convention: "aapcs64-embedded",
    object_format: "elf",
    executable_extension: "",
    static_library_extension: ".a",
    dynamic_library_extension: "",
    valid: true,
  };
}

proc target_aarch64_apple_silicon() -> Aarch64Target {
  let base: Aarch64Target = target_aarch64_macos();
  give Aarch64Target {
    triple: base.triple,
    cpu: "apple-silicon",
    vendor_name: base.vendor_name,
    pointer_width: base.pointer_width,
    register_width: base.register_width,
    little_endian: true,
    stack_alignment: 16,
    function_alignment: 16,
    supports_fp: true,
    supports_neon: true,
    supports_asimd: true,
    supports_aes: true,
    supports_sha2: true,
    supports_crc: true,
    supports_lse: true,
    supports_atomic64: true,
    calling_convention: base.calling_convention,
    object_format: base.object_format,
    executable_extension: base.executable_extension,
    static_library_extension: base.static_library_extension,
    dynamic_library_extension: base.dynamic_library_extension,
    valid: true,
  };
}

proc target_supports_simd(target: Aarch64Target) -> bool { give target.supports_neon and target.supports_asimd; }
proc target_supports_crypto(target: Aarch64Target) -> bool { give target.supports_aes and target.supports_sha2; }
proc target_supports_modern_atomics(target: Aarch64Target) -> bool { give target.supports_lse and target.supports_atomic64; }
proc target_is_linux(target: Aarch64Target) -> bool { give target.triple.os == "linux"; }
proc target_is_macos(target: Aarch64Target) -> bool { give target.triple.os == "macos"; }
proc target_summary(target: Aarch64Target) -> string { give target.cpu; }

proc target_selftest() -> bool {
  let linux: Aarch64Target = target_aarch64_linux();
  let macos: Aarch64Target = target_aarch64_macos();
  let embedded: Aarch64Target = target_aarch64_embedded();
  give linux.valid
    and macos.valid
    and embedded.valid
    and target_supports_simd(linux)
    and target_supports_crypto(macos)
    and not target_supports_crypto(embedded);
}
