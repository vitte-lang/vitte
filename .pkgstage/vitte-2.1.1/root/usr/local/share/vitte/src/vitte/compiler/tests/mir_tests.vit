space vitte/compiler/tests/mir_tests

use vitte/compiler/frontend/pipeline.{ FrontendOutput, frontend_run }
use vitte/compiler/middle/hir/lower_ast.{ lower_ast_to_hir }
use vitte/compiler/middle/lower/hir_to_mir.{ lower_hir_to_mir }
use vitte/compiler/middle/mir.{ MirStatementKind, MirTerminatorKind }

const VERSION_TEXT: string = "middle mir tests 0.2.0"
const BANNER_TEXT: string = "middle mir tests"

proc test_mir_lowering() -> bool {
  let source: string = "proc main() { let x = 1; set x = x + 1; give x; }\n";
  let fe: FrontendOutput = frontend_run("mir_test.vit", source);
  let hir = lower_ast_to_hir(fe);
  let mir = lower_hir_to_mir(hir);
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }
  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) != 4 {
    give false;
  }
  let block = fn0.blocks[0];
  if fn0.entry_block != block.id {
    give false;
  }
  if block.statements[0].place.local != "x" {
    give false;
  }
  give fn0.blocks[2].statements[0].kind == MirStatementKind.Return and fn0.blocks[2].terminator.kind == MirTerminatorKind.Return;
}

proc test_mir_cfg_if_while() -> bool {
  let source: string = "proc main() { let x = 1; if x { set x = x + 1; } else { set x = x + 2; } while x { set x = x - 1; } give x; }\n";
  let fe: FrontendOutput = frontend_run("mir_cfg_test.vit", source);
  let hir = lower_ast_to_hir(fe);
  let mir = lower_hir_to_mir(hir);
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }

  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) < 7 {
    give false;
  }

  let branch_count: u64 = 0;
  let goto_count: u64 = 0;
  let i: u64 = 0;
  while i < len(fn0.blocks) {
    let term = fn0.blocks[i].terminator;
    if term.kind == MirTerminatorKind.Branch {
      set branch_count = branch_count + 1;
      if not term.condition.valid or term.target_block == 0 or term.else_block == 0 {
        give false;
      }
    } elif term.kind == MirTerminatorKind.Goto {
      set goto_count = goto_count + 1;
      if term.target_block == 0 {
        give false;
      }
    }
    set i = i + 1;
  }

  give branch_count >= 2 and goto_count >= 2;
}

proc test_mir_preserves_projected_place() -> bool {
  let source: string = "proc main() { set x.field = x.field; give x.field; }\n";
  let fe: FrontendOutput = frontend_run("mir_projection_test.vit", source);
  let hir = lower_ast_to_hir(fe);
  let mir = lower_hir_to_mir(hir);
  if not mir.valid or len(mir.module.functions) == 0 {
    give false;
  }
  let fn0 = mir.module.functions[0];
  if len(fn0.blocks) == 0 or len(fn0.blocks[0].statements) == 0 {
    give false;
  }
  let stmt0 = fn0.blocks[0].statements[0];
  give stmt0.place.local == "x" and stmt0.place.projection == "field";
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_mir_lowering() {
    set failures = failures + 1;
  }
  if not test_mir_cfg_if_while() {
    set failures = failures + 1;
  }
  if not test_mir_preserves_projected_place() {
    set failures = failures + 1;
  }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
