    id,
    ast_span("typeck_call_manual.vit", 1, 1, 1, 1),
    HirExprKind.Int,
    text,
    "",
    "",
    "",
    0,
    "",
    false,
    HirValueMode.Value,
    "unknown",
    HirPlaceCategory.Value,
    true,
    true,
    false,
    false,
    [],
    [],
    true
  );
}

