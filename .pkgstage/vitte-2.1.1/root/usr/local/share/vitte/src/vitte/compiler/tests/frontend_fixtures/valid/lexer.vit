space vitte/compiler/tests/frontend_fixtures/valid/lexer

proc positions_source() -> string {
  give
    "space demo;\n" +
    "// hidden\n" +
    "proc main() { give 1; }\n";
}

proc attributes_source() -> string {
  give "#[entry]\nproc main() {}\n";
}

proc number_suffix_source() -> string {
  give "proc main() { let mask = 0xFFu32; let bits = 0b10_01; give bits; }\n";
}

export *
