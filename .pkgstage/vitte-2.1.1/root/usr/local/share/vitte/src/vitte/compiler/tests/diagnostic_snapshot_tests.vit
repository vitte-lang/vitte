space vitte/compiler/tests/diagnostic_snapshot_tests

use vitte/compiler/diagnostics/diagnostic.{
  Diagnostic,
  DiagnosticPhase,
  DiagnosticStyle,
  DiagnosticSuggestionKind,
  DiagnosticRenderConfig,
  default_render_config,
  diagnostic_add_pipeline_context,
  backend_command_failed,
  diagnostic_error,
  diagnostic_report,
  diagnostic_with_documentation,
  diagnostic_with_explanation,
  diagnostic_with_label,
  diagnostic_with_probable_fix,
  diagnostic_with_suggestion_detail,
  primary_label,
  previous_label,
  render_report,
  span_create,
  span_range,
  lexer_unterminated_string
}
use vitte/compiler/diagnostics/json.{ json_diagnostic }
use vitte/stdlib/io/fileops.{ read_file }

const VERSION_TEXT: string = "diagnostic snapshot tests 0.1.0"
const BANNER_TEXT: string = "diagnostic snapshot tests"

proc human_config() -> DiagnosticRenderConfig {
  let config: DiagnosticRenderConfig = default_render_config();
  set config.style = DiagnosticStyle.Human;
  set config.color = false;
  set config.show_phase = false;
  give config;
}

proc snapshot_matches(path: string, actual: string) -> bool {
  give read_file(path) == actual;
}

proc sample_typeck_diagnostic() -> Diagnostic {
  let file: string = "src/vitte/compiler/tests/diagnostics/typeck/assign_mismatch.vit";
  let diag: Diagnostic =
    diagnostic_error(
      "TYPECK_E_ASSIGN_MISMATCH",
      DiagnosticPhase.Typeck,
      "cannot assign string to i32",
      span_range(file, 8, 9, 8, 16)
    );
  set diag.labels = [
    previous_label("variable declared here as i32", span_create(file, 4, 5, 1)),
    primary_label("expected i32, found string", span_range(file, 8, 9, 8, 16))
  ];
  set diag =
    diagnostic_with_explanation(
      diag,
      "Vitte does not implicitly convert string to i32"
    );
  set diag =
    diagnostic_with_probable_fix(
      diag,
      "use an integer literal, or change x to string"
    );
  set diag =
    diagnostic_with_documentation(
      diag,
      "docs://language/type-system/assignment-compatibility"
    );
  set diag =
    diagnostic_with_suggestion_detail(
      diag,
      DiagnosticSuggestionKind.Replace,
      "replace the string literal with an integer literal",
      "0",
      span_range(file, 8, 9, 8, 16),
      true,
      "medium",
      "the target binding `x` is declared as `i32`"
    );
  set diag = diagnostic_add_pipeline_context(diag, "lexer");
  set diag = diagnostic_add_pipeline_context(diag, "parser");
  set diag = diagnostic_add_pipeline_context(diag, "AST");
  set diag = diagnostic_add_pipeline_context(diag, "HIR");
  set diag = diagnostic_add_pipeline_context(diag, "sema");
  set diag = diagnostic_add_pipeline_context(diag, "typeck [FAILED]");
  give diag;
}

proc sample_lexer_diagnostic() -> Diagnostic {
  give lexer_unterminated_string(
    span_range(
      "src/vitte/compiler/tests/diagnostics/lexer/unterminated_string.vit",
      1,
      9,
      1,
      22
    )
  );
}

proc sample_borrowck_diagnostic() -> Diagnostic {
  let file: string = "src/vitte/compiler/tests/diagnostics/borrowck/use_after_move.vit";
  let diag: Diagnostic =
    diagnostic_error(
      "BORROW_E_USE_AFTER_MOVE",
      DiagnosticPhase.Borrowck,
      "value `value` used after move",
      span_create(file, 3, 6, 5)
    );
  set diag.labels = [
    previous_label("move happened here", span_create(file, 2, 13, 5)),
    primary_label("use after move is forbidden", span_create(file, 3, 6, 5))
  ];
  set diag =
    diagnostic_with_explanation(
      diag,
      "ownership moved at line 2 and the later use happens after that transfer"
    );
  set diag =
    diagnostic_with_probable_fix(
      diag,
      "clone `value`, borrow it, or reinitialize it before the later use"
    );
  set diag = diagnostic_add_pipeline_context(diag, "lexer");
  set diag = diagnostic_add_pipeline_context(diag, "parser");
  set diag = diagnostic_add_pipeline_context(diag, "AST");
  set diag = diagnostic_add_pipeline_context(diag, "HIR");
  set diag = diagnostic_add_pipeline_context(diag, "sema");
  set diag = diagnostic_add_pipeline_context(diag, "borrowck [FAILED]");
  give diag;
}

proc sample_backend_diagnostic() -> Diagnostic {
  give backend_command_failed(
    DiagnosticPhase.Linker,
    "LINKER_E_OBJECT_FILE_ABSENT",
    "linker could not find the object file",
    "llvm",
    "x86_64-linux",
    "ld build/main.o -o build/main",
    "ld: cannot find build/main.o",
    "build/main",
    span_create(
      "src/vitte/compiler/tests/diagnostics/backend/link_failure.vit",
      1,
      1,
      12
    )
  );
}

proc test_typeck_text_snapshot() -> bool {
  let actual: string =
    render_report(
      diagnostic_report([sample_typeck_diagnostic()]),
      human_config()
    );
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/typeck/assign_mismatch.txt.snap",
    actual
  );
}

proc test_typeck_json_snapshot() -> bool {
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/typeck/assign_mismatch.json.snap",
    json_diagnostic(sample_typeck_diagnostic())
  );
}

proc test_lexer_text_snapshot() -> bool {
  let actual: string =
    render_report(
      diagnostic_report([sample_lexer_diagnostic()]),
      human_config()
    );
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/lexer/unterminated_string.txt.snap",
    actual
  );
}

proc test_lexer_json_snapshot() -> bool {
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/lexer/unterminated_string.json.snap",
    json_diagnostic(sample_lexer_diagnostic())
  );
}

proc test_borrowck_text_snapshot() -> bool {
  let actual: string =
    render_report(
      diagnostic_report([sample_borrowck_diagnostic()]),
      human_config()
    );
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/borrowck/use_after_move.txt.snap",
    actual
  );
}

proc test_borrowck_json_snapshot() -> bool {
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/borrowck/use_after_move.json.snap",
    json_diagnostic(sample_borrowck_diagnostic())
  );
}

proc test_backend_text_snapshot() -> bool {
  let actual: string =
    render_report(
      diagnostic_report([sample_backend_diagnostic()]),
      human_config()
    );
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/backend/link_failure.txt.snap",
    actual
  );
}

proc test_backend_json_snapshot() -> bool {
  give snapshot_matches(
    "src/vitte/compiler/tests/diagnostics/backend/link_failure.json.snap",
    json_diagnostic(sample_backend_diagnostic())
  );
}

proc run_all_tests() -> int {
  let failures: int = 0;
  if not test_typeck_text_snapshot() { set failures = failures + 1; }
  if not test_typeck_json_snapshot() { set failures = failures + 1; }
  if not test_lexer_text_snapshot() { set failures = failures + 1; }
  if not test_lexer_json_snapshot() { set failures = failures + 1; }
  if not test_borrowck_text_snapshot() { set failures = failures + 1; }
  if not test_borrowck_json_snapshot() { set failures = failures + 1; }
  if not test_backend_text_snapshot() { set failures = failures + 1; }
  if not test_backend_json_snapshot() { set failures = failures + 1; }
  give failures;
}

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give run_all_tests()
}

export *
