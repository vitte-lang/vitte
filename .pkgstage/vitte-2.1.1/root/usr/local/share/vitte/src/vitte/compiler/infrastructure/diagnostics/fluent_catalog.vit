proc fluent_catalog_lookup_pt_BR(code: string) -> string {
    if code == "E0001" {
        give "identificador esperado";
    }

    if code == "E0002" {
        give "expressao esperado";
    }

    if code == "E0003" {
        give "padrao esperado";
    }

    if code == "E0004" {
        give "tipo esperado";
    }

    if code == "E0005" {
        give "'end' esperado";
    }

    if code == "E0006" {
        give "proc after attribute esperado";
    }

    if code == "E0007" {
        give "top-level declaracao esperado";
    }

    if code == "E0008" {
        give "extern proc nao pode ter corpo";
    }

    if code == "E0009" {
        give "proc requires a body unless marked #[extern]";
    }

    if code == "E0010" {
        give "tipo alias requires a destino tipo";
    }

    if code == "E0011" {
        give "select requer pelo menos um when branch";
    }

    if code == "E0012" {
        give "select branch deve ser a when instrucao";
    }

    if code == "E0013" {
        give "proc pode terminar sem retornar um valor";
    }

    if code == "E0014" {
        give "sintaxe de nivel superior proibida no modo strict-core";
    }

    if code == "E0015" {
        give "sintaxe de instrucao proibida no modo strict-core";
    }

    if code == "E0016" {
        give "sintaxe de expressao proibida no modo strict-core";
    }

    if code == "E0017" {
        give "'}' esperado";
    }

    if code == "E0018" {
        give "esperado 'case' ou 'otherwise' em match";
    }

    if code == "E1001" {
        give "padrao vinculo duplicado";
    }

    if code == "E1002" {
        give "tipo (did you mean a built-in like int/i32/i64/i128/u32/u64/u128/bool/string?) desconhecido";
    }

    if code == "E1003" {
        give "generico base tipo desconhecido";
    }

    if code == "E1004" {
        give "generico tipo requer pelo menos um argumento";
    }

    if code == "E1005" {
        give "identificador desconhecido";
    }

    if code == "E1006" {
        give "generico tipo requer pelo menos um tipo argumento";
    }

    if code == "E1007" {
        give "conversao between signed and unsigned values invalido";
    }

    if code == "E1010" {
        give "stdlib modulo negado por active stdlib perfil";
