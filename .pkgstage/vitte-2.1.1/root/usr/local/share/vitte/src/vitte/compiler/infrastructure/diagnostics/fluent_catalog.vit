proc fluent_catalog_lookup_pl(code: string) -> string {
    if code == "E0001" {
        give "oczekiwano identyfikator";
    }

    if code == "E0002" {
        give "oczekiwano wyrazenie";
    }

    if code == "E0003" {
        give "oczekiwano wzorzec";
    }

