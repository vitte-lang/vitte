proc fluent_catalog_lookup_uk(code: string) -> string {
    if code == "E0001" {
        give "ochikuietsia identyfikator";
    }

    if code == "E0002" {
        give "ochikuietsia vyraz";
    }

    if code == "E0003" {
        give "ochikuietsia zrazok";
    }

    if code == "E0004" {
        give "ochikuietsia typ";
    }

    if code == "E0005" {
        give "ochikuietsia 'end'";
    }

    if code == "E0006" {
        give "ochikuietsia proc after attribute";
    }

    if code == "E0007" {
        give "ochikuietsia top-level oholoshennia";
    }

    if code == "E0008" {
        give "extern proc ne mozhe maty tilo";
    }

    if code == "E0009" {
        give "proc requires a body unless marked #[extern]";
    }

    if code == "E0010" {
        give "typ alias requires a tsil typ";
    }

    if code == "E0011" {
        give "select vymahaie shchonaimenshe odyn when branch";
    }

    if code == "E0012" {
        give "select branch maie buty a when operator";
    }

    if code == "E0013" {
        give "proc may exit without returning a znachennia";
    }

    if code == "E0014" {
        give "forbidden top-level syntaksys in strict-core mode";
    }

    if code == "E0015" {
        give "forbidden operator syntaksys in strict-core mode";
    }

    if code == "E0016" {
        give "forbidden vyraz syntaksys in strict-core mode";
    }

    if code == "E0017" {
        give "ochikuietsia '}'";
    }

    if code == "E0018" {
        give "ochikuietsia 'case' or 'otherwise' in match";
    }

    if code == "E1001" {
        give "zrazok pryviazka dublikat";
    }

    if code == "E1002" {
        give "typ (did you mean a built-in like int/i32/i64/i128/u32/u64/u128/bool/string?) nevidomyi";
    }

    if code == "E1003" {
        give "uzahalnenyi base typ nevidomyi";
    }

    if code == "E1004" {
        give "uzahalnenyi typ vymahaie shchonaimenshe odyn argument";
    }

    if code == "E1005" {
        give "identyfikator nevidomyi";
    }

    if code == "E1006" {
        give "uzahalnenyi typ vymahaie shchonaimenshe odyn typ argument";
    }

    if code == "E1007" {
        give "peretvorennia between signed and unsigned values neprypustymyi";
    }

    if code == "E1010" {
        give "stdlib modul vidkhyleno active stdlib profil";
    }

    if code == "E1011" {
        give "strict-imports requires explicit alias";
    }

    if code == "E1012" {
        give "strict-imports zaboroniaie unused import aliases";
    }

    if code == "E1013" {
        give "strict-imports zaboroniaie non-canonical import paths";
    }

    if code == "E1014" {
        give "stdlib modul vidsutnii";
    }

    if code == "E1015" {
        give "experimental modul import denied";
    }

    if code == "E1016" {
        give "vnutrishnii modul import denied";
    }

    if code == "E1017" {
        give "re-export symvol konflikt";
    }

    if code == "E1018" {
        give "ambiguous import shliakh";
    }

    if code == "E1019" {
        give "strict-modules zaboroniaie glob imports";
    }

    if code == "E1020" {
        give "legacy import shliakh zastarilyi";
    }

    if code == "E1021" {
        give "entry modul shliakh maie buty canonical";
    }

    if code == "E1022" {
        give "entry imia dublikat";
    }

    if code == "E1023" {
        give "share posylaietsia na nevidomyi symvol";
    }

    if code == "E1024" {
        give "symvol in share list dublikat";
    }

    if code == "E1025" {
        give "symvol ne eksportovano modul";
    }

    if code == "E1026" {
        give "share oholoshennia dublikat";
    }

    if code == "E1027" {
        give "import pryviazka dublikat";
    }

    if code == "E1028" {
