proc fluent_catalog_lookup(locale: string, code: string) -> string {
    let normalized: string = fluent_catalog_normalize_locale(locale);

    if normalized == "en" {
        give fluent_catalog_lookup_en(code);
    }

    if normalized == "fr" {
        give fluent_catalog_lookup_fr(code);
    }

    if normalized == "es" {
        give fluent_catalog_lookup_es(code);
    }

    if normalized == "de" {
        give fluent_catalog_lookup_de(code);
    }

    if normalized == "it" {
        give fluent_catalog_lookup_it(code);
    }

    if normalized == "pt-BR" {
        give fluent_catalog_lookup_pt_BR(code);
    }

    if normalized == "nl" {
        give fluent_catalog_lookup_nl(code);
    }

    if normalized == "pl" {
        give fluent_catalog_lookup_pl(code);
    }

    if normalized == "ru" {
        give fluent_catalog_lookup_ru(code);
    }

    if normalized == "uk" {
        give fluent_catalog_lookup_uk(code);
    }

    if normalized == "zh-CN" {
        give fluent_catalog_lookup_zh_CN(code);
    }

    if normalized == "ja" {
        give fluent_catalog_lookup_ja(code);
    }

    if normalized == "ko" {
        give fluent_catalog_lookup_ko(code);
    }

    if normalized == "tr" {
        give fluent_catalog_lookup_tr(code);
    }

    if normalized == "ar" {
        give fluent_catalog_lookup_ar(code);
    }

    give "";
}

proc fluent_catalog_has(locale: string, code: string) -> bool {
    give fluent_catalog_lookup(locale, code) != "";
}

proc fluent_catalog_entry_for(locale: string, code: string) -> FluentCatalogEntry {
    let normalized: string = fluent_catalog_normalize_locale(locale);
    give fluent_catalog_entry(normalized, code, fluent_catalog_lookup(normalized, code));
}

proc fluent_catalog_message_or(locale: string, code: string, fallback: string) -> string {
    let message: string = fluent_catalog_lookup(locale, code);
    if message == "" {
        give fallback;
    }
    give message;
}

proc fluent_catalog_stats_default() -> FluentCatalogStats {
    give fluent_catalog_stats(15, 1388, true);
}

proc fluent_catalog_selftest() -> bool {
    let en: string = fluent_catalog_lookup("en", "P0001");
    let fr: string = fluent_catalog_lookup("fr-FR", "P0001");
    let es: string = fluent_catalog_lookup("es-MX", "P0001");
    let stats: FluentCatalogStats = fluent_catalog_stats_default();

    give en != ""
        and fr != ""
        and es != ""
        and stats.locale_count == 15
        and stats.diagnostic_count == 1388
        and stats.generated
        and fluent_catalog_has("zh_CN", "LEX_E_INVALID_CHAR")
        and fluent_catalog_generator() == "tools/generate_frontend_fluent_bridge.py";
}
