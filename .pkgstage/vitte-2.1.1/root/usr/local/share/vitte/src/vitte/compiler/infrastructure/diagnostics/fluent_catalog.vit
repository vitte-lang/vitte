        give "uzahalnenyi bound zbi";
    }

    if code == "LIMIT_E_UNSUPPORTED_TARGET" {
        give "tsil ne pidtrymuietsia";
    }

    if code == "LIMIT_E_ABI_MISMATCH" {
        give "abi nevidpovidnist";
    }

    if code == "LIMIT_E_LINK_FAILED" {
        give "link zbi";
    }

    if code == "LIMIT_E_RUNTIME_PANIC" {
        give "runtime panika";
    }

    give "";
}

