proc fluent_catalog_lookup_ar(code: string) -> string {
    if code == "E0001" {
        give "معرف متوقع";
    }

    if code == "E0002" {
        give "تعبير متوقع";
    }

    if code == "E0003" {
        give "نمط متوقع";
    }

    if code == "E0004" {
        give "نوع متوقع";
    }

    if code == "E0005" {
        give "'end' متوقع";
    }

    if code == "E0006" {
        give "proc after attribute متوقع";
    }

    if code == "E0007" {
        give "top-level تصريح متوقع";
    }

    if code == "E0008" {
        give "extern proc لا يمكن ان يملك جسما";
    }

    if code == "E0009" {
