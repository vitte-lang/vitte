# Operators, punctuation, and editor cues
color brightyellow "(->|=>|::|:=|==|!=|<=|>=|&&|\|\||[+*/%=<>!&|.-])"
color normal "[(){}\[\],;:]"
color ,red "[[:space:]]+$"

# Comments
color brightblack "//.*$"
color brightblack "#.*$"
color brightblack start="/\*" end="\*/"
color brightblack start="<<<" end=">>>"

# TODOs
color red "\<(TODO|FIXME|BUG|HACK|NOTE|XXX)\>"
