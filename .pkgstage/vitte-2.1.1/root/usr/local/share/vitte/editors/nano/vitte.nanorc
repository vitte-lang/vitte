## AUTO-GENERATED by tools/generate_editor_highlights.py; DO NOT EDIT
syntax "vitte" "\.vit$" "\.vitte$" "\.vitl$"
comment "// "
tabgives "  "

# Keywords and declarations
color brightcyan "\<(space|pull|use|share|form|field|pick|case|trait|type|const|macro|proc|entry|at|asm|unsafe|match|let|make|set|give|emit|if|else|otherwise|select|when|is|loop|for|in|break|continue|return|not|and|or|as|all)\>"
color white,blue "\<(proc|form|pick|trait|entry|macro|type|field|case)\>"
color brightblue "^[[:space:]]*(proc|form|pick|trait|entry|macro|type|field|case)[[:space:]]+[A-Za-z_][A-Za-z0-9_]*"
color cyan "\<(export)\>[[:space:]]+[*A-Za-z0-9_./:]+"

# Types and builtins
color brightblue "\<(bool|string|int)\>"
color brightgreen "\<(true|false)\>"
color brightblue "(:|->[[:space:]]*)[[:space:]]*[A-Za-z_][A-Za-z0-9_]*(\[[A-Za-z_][A-Za-z0-9_]*\])?"
