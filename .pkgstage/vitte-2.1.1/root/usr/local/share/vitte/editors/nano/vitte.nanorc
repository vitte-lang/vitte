# Strict highlights
color red "\<VITTE-[A-Z]+[0-9]{4}\>"
color magenta "\<[A-Za-z_][A-Za-z0-9_]*_pkg\>"
color brightyellow "^\s*<<<\s+ROLE-CONTRACT"
color cyan "\<((diagnostics_|quickfix_|doctor_)[A-Za-z0-9_]*)\>"

# Literals and paths
color brightmagenta "\<(0x[0-9A-Fa-f]+|0b[01]+|[0-9]+(\.[0-9]+)?)\>"
color yellow start="\"" end="\""
color yellow start="'" end="'"
color cyan "\<(space|pull|share|at|use)\>\s+([A-Za-z0-9_./:]+)"
color brightblue "\<(proc|form|pick|trait|entry|macro|type|field|case)\>\s+([A-Za-z_][A-Za-z0-9_]*)"
color magenta "\<as\>\s+([A-Za-z_][A-Za-z0-9_]*(_pkg)?)"
