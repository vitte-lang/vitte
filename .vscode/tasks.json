{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "vitteDiagCode",
      "type": "promptString",
      "description": "Diagnostic code to explain",
      "default": "E0001"
    }
  ],
  "tasks": [
    {
      "label": "vitte: check current file",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "check",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "vitte: check current file (strict)",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "check",
        "--strict",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "vitte: check current file (diagnostics json)",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "check",
        "${file}",
        "--diagnostics-json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "vitte: trace current file",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "--trace-pipeline",
        "check",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "vitte: parse current file",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "parse",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "vitte: dump AST JSON (current file)",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "check",
        "${file}",
        "--dump-ast-json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "vitte: dump HIR JSON (current file)",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "check",
        "${file}",
        "--dump-hir-json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "vitte: dump MIR JSON (current file)",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "check",
        "${file}",
        "--dump-mir-json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "vitte: build current file",
      "type": "shell",
      "command": "sh",
      "args": [
        "-lc",
        "mkdir -p target/vscode && bin/vitte build \"${file}\" -o \"${workspaceFolder}/target/vscode/${fileBasenameNoExtension}\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "vitte: run current file",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "run",
        "${file}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: explain diagnostic code",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "explain",
        "${input:vitteDiagCode}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "vitte: package check",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "pkg",
        "check"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: package matrix",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "pkg",
        "matrix"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: package selftest",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "pkg",
        "selftest"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: pipeline tests",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "run",
        "src/vitte/compiler/tests/pipeline_tests.vit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: codegen tests",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "run",
        "src/vitte/compiler/tests/codegen_tests.vit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: c backend tests",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "run",
        "src/vitte/compiler/tests/c_backend_tests.vit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: lsp smoke",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "run",
        "src/vitte/tools/lsp/tests/smoke.vit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: lsp stability",
      "type": "shell",
      "command": "bin/vitte",
      "args": [
        "run",
        "src/vitte/tools/lsp/tests/stability_suite.vit"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: backend surface audit",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/backend_surface_audit.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: driver runtime surface audit",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/driver_runtime_surface_audit.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: canonical surface audits",
      "dependsOrder": "sequence",
      "dependsOn": [
        "vitte: backend surface audit",
        "vitte: driver runtime surface audit"
      ],
      "problemMatcher": []
    },
    {
      "label": "vitte: quickstart check",
      "type": "shell",
      "command": "make",
      "args": [
        "quickstart-check"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: bootstrap verify",
      "type": "shell",
      "command": "make",
      "args": [
        "bootstrap-verify"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: modules tests",
      "type": "shell",
      "command": "make",
      "args": [
        "modules-tests"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: modules snapshots",
      "type": "shell",
      "command": "make",
      "args": [
        "modules-snapshots"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: compiler test suite check gate",
      "type": "shell",
      "command": "./tools/compiler_test_suite_check_gate.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "vitte: compiler test suite bridge gate",
      "type": "shell",
      "command": "./tools/compiler_test_suite_bridge_gate.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
