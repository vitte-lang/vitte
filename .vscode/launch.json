{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vitte: Launch current file",
      "type": "vitte",
      "request": "launch",
      "program": "${workspaceFolder}/bin/vitte",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "${file}"
      ]
    },
    {
      "name": "Vitte: Launch compiler main",
      "type": "vitte",
      "request": "launch",
      "program": "${workspaceFolder}/bin/vitte",
      "cwd": "${workspaceFolder}",
      "args": [
        "run",
        "src/vitte/compiler/main.vit"
      ]
    }
  ]
}
