{
  "schema": "org.vitte.installer-real-platforms.v1",
  "version": "0.1.0",
  "required_binary_architectures": [
    "x86_64",
    "i386",
    "arm64",
    "armv7",
    "armv6",
    "riscv64"
  ],
  "binary_ci_targets": [
    {"os": "linux", "arch": "x86_64", "runner_label": "linux-x86_64"},
    {"os": "linux", "arch": "i386", "runner_label": "linux-i386"},
    {"os": "linux", "arch": "arm64", "runner_label": "linux-arm64"},
    {"os": "linux", "arch": "armv7", "runner_label": "linux-armv7"},
    {"os": "linux", "arch": "armv6", "runner_label": "linux-armv6"},
    {"os": "linux", "arch": "riscv64", "runner_label": "linux-riscv64"}
  ],
  "raspberry_pi_targets": [
    {
      "os": "raspberry-pi-os",
      "debian_family": true,
      "arch": "armv6",
      "runner_label": "raspberrypi-armv6"
    },
    {
      "os": "raspberry-pi-os",
      "debian_family": true,
      "arch": "armv7",
      "runner_label": "raspberrypi-armv7"
    },
    {
      "os": "raspberry-pi-os",
      "debian_family": true,
      "arch": "aarch64",
      "runner_label": "raspberrypi-aarch64"
    }
  ],
  "real_platform_targets": [
    {"os": "windows-xp", "arch": "i386", "runner_label": "windows-xp-i386"},
    {"os": "windows-7", "arch": "i386", "runner_label": "windows-7-i386"},
    {"os": "windows-10", "arch": "amd64", "runner_label": "windows-10-amd64"},
    {"os": "windows-11", "arch": "amd64", "runner_label": "windows-11-amd64"},
    {"os": "debian-oldstable", "arch": "amd64", "runner_label": "debian-oldstable-amd64"},
    {"os": "debian-stable", "arch": "amd64", "runner_label": "debian-stable-amd64"},
    {"os": "macos", "arch": "x86_64", "runner_label": "macos-x86_64"},
    {"os": "macos", "arch": "arm64", "runner_label": "macos-arm64"},
    {"os": "solaris", "arch": "amd64", "runner_label": "solaris-amd64"},
    {"os": "solaris", "arch": "i386", "runner_label": "solaris-i386"}
  ],
  "post_install_commands": [
    "vitte-installer-doctor",
    "vitte --version",
    "vitte --help",
    "vitte check smoke.vit",
    "vitte build smoke.vit -o smoke"
  ],
  "release_requires_strict_real_installers": true,
  "release_requires_sbom": true,
  "release_requires_signatures": true,
  "release_requires_notarization_for_macos": true,
  "artifact_metadata_required": [
    "INSTALLERS.json",
    "CHECKSUMS.txt",
    "SIGNATURES.json",
    "SBOM.spdx.json",
    "SBOM.cyclonedx.json",
    "*.MANIFEST.json",
    "ATTESTATION.json"
  ],
  "real_binary_formats": {
    "linux": "ELF",
    "raspberry-pi-os": "ELF",
    "debian-oldstable": "ELF",
    "debian-stable": "ELF",
    "solaris": "ELF",
    "macos": "Mach-O",
    "windows-xp": "PE",
    "windows-7": "PE",
    "windows-10": "PE",
    "windows-11": "PE"
  },
  "strict_artifact_root": "target/real-binaries"
}
