{
  "schema": "org.vitte.installer-real-platforms.v1",
  "version": "0.1.0",
  "required_binary_architectures": [
    "x86_64",
    "i386",
    "arm64",
    "armv7",
    "armv6",
    "riscv64"
  ],
  "binary_ci_targets": [
    {"os": "linux", "arch": "x86_64", "runner_label": "linux-x86_64"},
    {"os": "linux", "arch": "i386", "runner_label": "linux-i386"},
    {"os": "linux", "arch": "arm64", "runner_label": "linux-arm64"},
    {"os": "linux", "arch": "armv7", "runner_label": "linux-armv7"},
    {"os": "linux", "arch": "armv6", "runner_label": "linux-armv6"},
    {"os": "linux", "arch": "riscv64", "runner_label": "linux-riscv64"}
  ],
  "raspberry_pi_targets": [
    {
      "os": "raspberry-pi-os",
      "debian_family": true,
      "arch": "armv6",
      "runner_label": "raspberrypi-armv6"
    },
    {
      "os": "raspberry-pi-os",
      "debian_family": true,
      "arch": "armv7",
      "runner_label": "raspberrypi-armv7"
    },
    {
      "os": "raspberry-pi-os",
      "debian_family": true,
      "arch": "aarch64",
      "runner_label": "raspberrypi-aarch64"
    }
  ],
  "real_platform_targets": [
    {"os": "windows-xp", "arch": "i386", "runner_label": "windows-xp-i386"},
    {"os": "windows-7", "arch": "i386", "runner_label": "windows-7-i386"},
    {"os": "windows-10", "arch": "amd64", "runner_label": "windows-10-amd64"},
    {"os": "windows-11", "arch": "amd64", "runner_label": "windows-11-amd64"},
    {"os": "debian-oldstable", "arch": "amd64", "runner_label": "debian-oldstable-amd64"},
    {"os": "debian-stable", "arch": "amd64", "runner_label": "debian-stable-amd64"},
    {"os": "macos", "arch": "x86_64", "runner_label": "macos-x86_64"},
    {"os": "macos", "arch": "arm64", "runner_label": "macos-arm64"},
    {"os": "solaris", "arch": "amd64", "runner_label": "solaris-amd64"},
    {"os": "solaris", "arch": "i386", "runner_label": "solaris-i386"}
  ],
  "post_install_commands": [
    "vitte-installer-doctor",
    "vitte --version",
    "vitte --help",
    "vitte check smoke.vit",
    "vitte build smoke.vit -o smoke"
  ],
  "native_compiler_entrypoints": [
    "src/vitte/compiler/main.vit",
    "src/vitte/compiler/driver/compiler.vit"
  ],
  "strict_installer_artifact_root": "pkgout",
  "strict_installer_artifacts": [
    {"family": "linux-deb", "target": "amd64", "pattern": "vitte_0.1.0_amd64.deb"},
    {"family": "linux-deb", "target": "i386", "pattern": "vitte_0.1.0_i386.deb"},
    {"family": "linux-deb", "target": "arm64", "pattern": "vitte_0.1.0_arm64.deb"},
    {"family": "linux-deb", "target": "armhf", "pattern": "vitte_0.1.0_armhf.deb"},
    {"family": "linux-deb", "target": "armel", "pattern": "vitte_0.1.0_armel.deb"},
    {"family": "linux-deb", "target": "riscv64", "pattern": "vitte_0.1.0_riscv64.deb"},
    {"family": "portable", "target": "linux-amd64", "pattern": "vitte-0.1.0-portable-linux-amd64.tar.gz"},
    {"family": "portable", "target": "linux-i386", "pattern": "vitte-0.1.0-portable-linux-i386.tar.gz"},
    {"family": "portable", "target": "linux-arm64", "pattern": "vitte-0.1.0-portable-linux-arm64.tar.gz"},
    {"family": "portable", "target": "linux-armv7", "pattern": "vitte-0.1.0-portable-linux-armv7.tar.gz"},
    {"family": "portable", "target": "linux-armv6", "pattern": "vitte-0.1.0-portable-linux-armv6.tar.gz"},
    {"family": "portable", "target": "linux-riscv64", "pattern": "vitte-0.1.0-portable-linux-riscv64.tar.gz"},
    {"family": "macos-pkg", "target": "x86_64", "pattern": "vitte-0.1.0-macos-x86_64.pkg"},
    {"family": "macos-pkg", "target": "arm64", "pattern": "vitte-0.1.0-macos-arm64.pkg"},
    {"family": "macos-dmg", "target": "x86_64", "pattern": "vitte-0.1.0-macos-x86_64.dmg"},
    {"family": "macos-dmg", "target": "arm64", "pattern": "vitte-0.1.0-macos-arm64.dmg"},
    {"family": "freebsd-pkg", "target": "amd64", "pattern": "vitte-0.1.0-freebsd-amd64.pkg"},
    {"family": "freebsd-pkg", "target": "i386", "pattern": "vitte-0.1.0-freebsd-i386.pkg"},
    {"family": "solaris-svr4", "target": "amd64", "pattern": "vitte-0.1.0-solaris-amd64.pkg"},
    {"family": "solaris-svr4", "target": "i386", "pattern": "vitte-0.1.0-solaris-i386.pkg"},
    {"family": "windows-installer", "target": "i386", "pattern": "vitte-0.1.0-windows-i386-installer.exe"},
    {"family": "windows-installer", "target": "amd64", "pattern": "vitte-0.1.0-windows-amd64-installer.exe"}
  ],
  "release_requires_strict_real_installers": true,
  "release_requires_sbom": true,
  "release_requires_signatures": true,
  "release_requires_notarization_for_macos": true,
  "artifact_metadata_required": [
    "INSTALLERS.json",
    "CHECKSUMS.txt",
    "SIGNATURES.json",
    "SBOM.spdx.json",
    "SBOM.cyclonedx.json",
    "*.MANIFEST.json",
    "ATTESTATION.json"
  ],
  "real_binary_formats": {
    "linux": "ELF",
    "raspberry-pi-os": "ELF",
    "debian-oldstable": "ELF",
    "debian-stable": "ELF",
    "solaris": "ELF",
    "macos": "Mach-O",
    "windows-xp": "PE",
    "windows-7": "PE",
    "windows-10": "PE",
    "windows-11": "PE"
  },
  "strict_artifact_root": "target/real-binaries"
}
