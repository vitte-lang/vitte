<<< grammar-smoke >>>
space core/math
use core/io as io


form Point
  field x as int
  field y as int
.end

pick Maybe
  case None
  case Some(value as int)
.end

#[inline]
proc add(a, b) {
  give a + b
}

entry main at core/app {
  make x as int = 1
  make xs = [1, 2, 3]
  set x = x + 2
  emit print(x)
  if x > 0 { return x } else { return 0 }
  select x
    when int(v) { return v }
  else { return 0 }
}
