<<<
vitte_log_smoke.vit
smoke for vitte/log facade
>>>

use vitte/log as log_pkg

entry main at core/app {
  let lg: log_pkg.Logger = log_pkg.logger_new(log_pkg.LogLevel.Debug)
  let lg2: log_pkg.Logger = log_pkg.debug(lg, 1, "dbg", "tests/log", [])
  if lg2.events.len < 0 {
    give 1
  }
  give 0
}
