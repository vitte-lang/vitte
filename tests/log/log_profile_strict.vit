<<<
log_profile_strict.vit
strict profile smoke for vitte/log
>>>

use vitte/log as log_pkg

entry main at core/app {
  if log_pkg.sink_allowed_for_profile("core", log_pkg.LogSink.File) {
    give 1
  }
  if log_pkg.sink_allowed_for_profile("desktop", log_pkg.LogSink.Stderr) == false {
    give 2
  }
  give 0
}
