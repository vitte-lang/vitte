<<<
vitte_fs_smoke.vit
smoke for vitte/fs facade
>>>

use vitte/fs as fs_pkg

entry main at core/app {
  let rt: fs_pkg.FsRuntime = fs_pkg.default_runtime()
  let p: fs_pkg.PathInfo = fs_pkg.normalize(fs_pkg.path("a//b\\c"))
  if p.raw == "" {
    give 1
  }
  let p2: fs_pkg.PathInfo = fs_pkg.join(fs_pkg.path("/a"), "b")
  if p2.raw == "" {
    give 2
  }
  if fs_pkg.ready() == false {
    give 3
  }
  give 0
}
