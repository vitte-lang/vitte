// Broad invalid syntax fixture for lexer/parser/diagnostic 100 coverage.
// This file is not expected to compile. It documents root-cause classes.

proc missing_colon(value i32) -> i32 {
    give value
}

proc missing_paren(value: i32 -> i32 {
    give value
}

proc incomplete_expr() -> i32 {
    give 1 +
}

proc missing_comma(left: i32 right: i32) -> i32 {
    give left + right
}

proc unexpected_token() -> i32 {
    ;
    give 0
}

proc bad_lexer() -> i32 {
    give @
}
