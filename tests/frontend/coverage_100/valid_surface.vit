// Broad valid syntax fixture for lexer/parser/diagnostic 100 coverage.
space coverage.surface

use std.io

export answer

const answer: i32 = 42;

form Point {
    x: i32
    y: i32
}

pick Color {
    Red
    ,
    Green
    ,
    Blue
}

trait Show {
    proc show(self) -> string;
}

proc add(left: i32, right: i32) -> i32 {
    let total: i32 = left + right;
    give total;
}

proc main() -> i32 {
    let p: Point = Point { x: 1, y: 2 };
    if answer > 0 {
        give add(p.x, p.y);
    } else {
        give 0;
    }
}
