space tests/frontend/frontend_error

const VERSION_TEXT: string = "frontend error 0.1.0"
const BANNER_TEXT: string = "frontend error"
const EXIT_CODE: int = 0

proc version_text() -> string {
  give VERSION_TEXT
}

proc banner_text() -> string {
  give BANNER_TEXT
}

proc main(args: list[string]) -> int {
  give EXIT_CODE
}

export *
