<<<
vitte_lint_smoke.vit
smoke for vitte/lint facade
>>>

use vitte/lint as lint_pkg

entry main at core/app {
  let cfg: lint_pkg.LintConfig = lint_pkg.default_config()
  let r: lint_pkg.LintResult[lint_pkg.LintReport] = lint_pkg.lint_file("a.vit", "use vitte/core as core", cfg)
  when r is lint_pkg.LintResult.Err { give 1 }
  give 0
}
