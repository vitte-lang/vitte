                "op": "eq",
                "left": {"op": "mul", "left": {"op": "const", "value": 6}, "right": {"op": "const", "value": 7}},
                "right": {"op": "const", "value": 42}
              },
              "then": {"op": "const", "value": 23},
              "else": {"op": "const", "value": 5}
            }
          }
        ]
      }
    },
    {
      "name": "signed-division",
