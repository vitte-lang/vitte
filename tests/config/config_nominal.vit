use vitte/config as config_pkg

entry main at core/app {
  let opts = config_pkg.strict_options()
  let vr: config_pkg.ConfigResult[bool] = config_pkg.validate_options(opts)
  when vr is config_pkg.ConfigResult.Err {
    return 1
  }

  let c0 = config_pkg.config_new()
  let s1: config_pkg.ConfigResult[config_pkg.Config] = config_pkg.set_entry_checked(c0, "env", "prod", opts)
  when s1 is config_pkg.ConfigResult.Err {
    return 1
  }

  let s2: config_pkg.ConfigResult[config_pkg.Config] = config_pkg.set_entry_checked(s1.value, "region", "eu", opts)
  when s2 is config_pkg.ConfigResult.Err {
    return 1
  }

  let g: config_pkg.ConfigResult[string] = config_pkg.get_entry_checked(s2.value, "env")
  when g is config_pkg.ConfigResult.Err {
    return 1
  }
  if g.value != "prod" {
    return 1
  }

  if config_pkg.required(s2.value, ["env", "region"]) == false {
    return 1
  }

  let n = config_pkg.config_normalize(s2.value, opts)
  if config_pkg.config_validate(n, opts) == false {
    return 1
  }

  let h = config_pkg.config_health(n, opts)
  if h.ok == false {
    return 1
  }

  if config_pkg.ready() == false {
    return 1
  }

  return 0
}
