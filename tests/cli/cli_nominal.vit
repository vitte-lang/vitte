use vitte/cli as cli_pkg

entry main at core/app {
  let cfg = cli_pkg.default_config()
  let args = ["app", "run", "--config=dev", "-v"]

  let vr: cli_pkg.CliResult[bool] = cli_pkg.validate_args(args)
  when vr is cli_pkg.CliResult.Err {
    return 1
  }

  let pr: cli_pkg.CliResult[cli_pkg.CliParse] = cli_pkg.parse_checked(args, cfg)
  when pr is cli_pkg.CliResult.Err {
    return 1
  }

  if pr.value.command != "app" {
    return 1
  }

  if cli_pkg.has_flag(args, "--config") == false {
    return 1
  }

  let ov = cli_pkg.option(args, "--config")
  if ov.found == false {
    return 1
  }

  if ov.value != "dev" {
    return 1
  }

  if cli_pkg.ready() == false {
    return 1
  }

  return 0
}
