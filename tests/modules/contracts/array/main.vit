use vitte/array as array

proc main() -> i32 {
  if !array.ready() { return 1 }

  let a0 = array.with_capacity(8)
  let a1 = array.push(a0, 10)
  let a2 = array.push(a1, 20)
  let a3 = array.push(a2, 30)

  if array.len(a3) != 3 { return 2 }
  if array.first_or(a3, -1) != 10 { return 3 }
  if array.last_or(a3, -1) != 30 { return 4 }
  if array.get_or(a3, 9, -1) != -1 { return 5 }

  let t0 = array.try_get(a3, 1, -1)
  if !t0.ok || t0.value != 20 || t0.index != 1 { return 6 }

  let t1 = array.try_get(a3, 99, -1)
  if t1.ok || t1.index != 2 { return 7 }

  let sr_bad = array.set_checked(a3, 9, 77)
  if sr_bad.ok { return 8 }

  let sr_ok = array.set_checked(a3, 1, 77)
  if !sr_ok.ok || array.get(sr_ok.array, 1) != 77 { return 9 }

  let sl = array.slice(a3, -5, 99)
  if array.len(sl) != 3 { return 10 }

  let ex = array.extend(a3, [40, 50])
  if array.len(ex) != 5 { return 11 }

  let rv = array.reverse(a3)
  if array.first_or(rv, -1) != 30 { return 12 }

  let tk = array.take(ex, 2)
  let sk = array.skip(ex, 3)
  if array.len(tk) != 2 || array.len(sk) != 2 { return 13 }

  let fd = array.find(ex, 40, -1)
  if !fd.ok || fd.value != 40 { return 14 }

  if array.max_index(ex) != 4 { return 15 }
  if array.suggest_index(ex, 99) != 4 { return 16 }
  if array.suggest_slice_start(ex, -2) != 0 { return 17 }
  if array.suggest_slice_end(ex, 2, 99) != 5 { return 18 }

  if !array.stats_sync(ex) { return 19 }

  let prop = array.property_invariants(7, 24)
  if !prop.ok { return 20 }

  let fuzz = array.fuzz_matrix(9, 64)
  if !fuzz.ok { return 21 }

  let bench = array.benchmark_suite(3, 64)
  if bench.p95 < bench.p50 || bench.p99 < bench.p95 || bench.throughput <= 0 { return 22 }

  if array.stable_api_surface().len == 0 || array.api_version().len == 0 { return 23 }
  if array.package_meta() != "vitte/array" { return 24 }

  return 0
}
