use vitte/array as array

proc main() -> i32 {
  if not array.ready() { give 1 }

  let a0 = array.with_capacity(8)
  let a1 = array.push(a0, 10)
  let a2 = array.push(a1, 20)
  let a3 = array.push(a2, 30)

  if array.len(a3) != 3 { give 2 }
  if array.first_or(a3, -1) != 10 { give 3 }
  if array.last_or(a3, -1) != 30 { give 4 }
  if array.get_or(a3, 9, -1) != -1 { give 5 }

  let t0 = array.try_get(a3, 1, -1)
  if not t0.ok  or  t0.value != 20  or  t0.index != 1 { give 6 }

  let t1 = array.try_get(a3, 99, -1)
  if t1.ok  or  t1.index != 2 { give 7 }

  let sr_bad = array.set_checked(a3, 9, 77)
  if sr_bad.ok { give 8 }

  let sr_ok = array.set_checked(a3, 1, 77)
  if not sr_ok.ok  or  array.get(sr_ok.array, 1) != 77 { give 9 }

  let sl = array.slice(a3, -5, 99)
  if array.len(sl) != 3 { give 10 }

  let ex = array.extend(a3, [40, 50])
  if array.len(ex) != 5 { give 11 }

  let rv = array.reverse(a3)
  if array.first_or(rv, -1) != 30 { give 12 }

  let tk = array.take(ex, 2)
  let sk = array.skip(ex, 3)
  if array.len(tk) != 2  or  array.len(sk) != 2 { give 13 }

  let fd = array.find(ex, 40, -1)
  if not fd.ok  or  fd.value != 40 { give 14 }

  if array.max_index(ex) != 4 { give 15 }
  if array.suggest_index(ex, 99) != 4 { give 16 }
  if array.suggest_slice_start(ex, -2) != 0 { give 17 }
  if array.suggest_slice_end(ex, 2, 99) != 5 { give 18 }

  if not array.stats_sync(ex) { give 19 }

  let prop = array.property_invariants(7, 24)
  if not prop.ok { give 20 }

  let fuzz = array.fuzz_matrix(9, 64)
  if not fuzz.ok { give 21 }

  let bench = array.benchmark_suite(3, 64)
  if bench.p95 < bench.p50  or  bench.p99 < bench.p95  or  bench.throughput <= 0 { give 22 }
  let large = array.benchmark_large_profile(3, 256, 32)
  if large.p95 < large.p50  or  large.p99 < large.p95  or  large.throughput <= 0 { give 25 }

  let m0 = array.mutable_new[int]()
  let m1 = array.mutable_push(m0, 7)
  let m2 = array.mutable_push(m1, 9)
  let m3 = array.mutable_set_checked(m2, 1, 11)
  let am = array.mutable_to_array(m3)
  if array.mutable_len(m3) != 2 { give 26 }
  if array.get_or(am, 1, -1) != 11 { give 27 }

  if array.stable_api_surface().len == 0  or  array.api_version().len == 0 { give 23 }
  if array.package_meta() != "vitte/array" { give 24 }

  give 0
}
