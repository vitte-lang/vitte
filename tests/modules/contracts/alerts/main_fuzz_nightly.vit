use vitte/alerts as alerts

proc assert_seed(seed: int, steps: int) -> bool {
  let fz = alerts.fuzz_events(seed, steps)
  if not fz.ok { give false }
  if fz.steps != steps { give false }
  if fz.emitted < 0 { give false }
  if fz.suppressed < 0 { give false }
  give true
}

proc main() -> i32 {
  let steps = 200
  if not assert_seed(3, steps) { give 1 }
  if not assert_seed(7, steps) { give 2 }
  if not assert_seed(11, steps) { give 3 }
  if not assert_seed(17, steps) { give 4 }
  if not assert_seed(23, steps) { give 5 }
  if not assert_seed(29, steps) { give 6 }
  if not assert_seed(31, steps) { give 7 }
  if not assert_seed(37, steps) { give 8 }
  if not assert_seed(41, steps) { give 9 }
  if not assert_seed(43, steps) { give 10 }
  if not assert_seed(47, steps) { give 11 }
  if not assert_seed(53, steps) { give 12 }
  give 0
}
