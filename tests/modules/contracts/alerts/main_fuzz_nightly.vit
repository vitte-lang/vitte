use vitte/alerts as alerts

proc assert_seed(seed: int, steps: int) -> bool {
  let fz = alerts.fuzz_events(seed, steps)
  if !fz.ok { return false }
  if fz.steps != steps { return false }
  if fz.emitted < 0 { return false }
  if fz.suppressed < 0 { return false }
  return true
}

proc main() -> i32 {
  let steps = 200
  if !assert_seed(3, steps) { return 1 }
  if !assert_seed(7, steps) { return 2 }
  if !assert_seed(11, steps) { return 3 }
  if !assert_seed(17, steps) { return 4 }
  if !assert_seed(23, steps) { return 5 }
  if !assert_seed(29, steps) { return 6 }
  if !assert_seed(31, steps) { return 7 }
  if !assert_seed(37, steps) { return 8 }
  if !assert_seed(41, steps) { return 9 }
  if !assert_seed(43, steps) { return 10 }
  if !assert_seed(47, steps) { return 11 }
  if !assert_seed(53, steps) { return 12 }
  return 0
}
