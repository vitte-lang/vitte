use vitte/alerts as alerts

proc within_tolerance(actual: int, expected: int, tolerance: int) -> bool {
  let low = expected - tolerance
  let high = expected + tolerance
  if actual < low { give false }
  if actual > high { give false }
  give true
}

proc main() -> i32 {
  let seed = 42
  let rounds = 200

  let b0 = alerts.benchmark_eval(seed, rounds)
  let b1 = alerts.benchmark_eval(seed, rounds)

  if b0.p50 != b1.p50 { give 1 }
  if b0.p95 != b1.p95 { give 2 }
  if b0.p99 != b1.p99 { give 3 }
  if b0.throughput != b1.throughput { give 4 }

  if b0.p95 < b0.p50 { give 5 }
  if b0.p99 < b0.p95 { give 6 }

  # snapshot (seed=42, rounds=200)
  # expected: p50=0 p95=9 p99=9 throughput=995
  if not within_tolerance(b0.p50, 0, 1) { give 7 }
  if not within_tolerance(b0.p95, 9, 1) { give 8 }
  if not within_tolerance(b0.p99, 9, 1) { give 9 }
  if not within_tolerance(b0.throughput, 995, 5) { give 10 }

  give 0
}
