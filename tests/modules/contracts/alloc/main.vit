use vitte/alloc as alloc

proc main() -> i32 {
  if not alloc.ready() { give 1 }
  if not alloc.stable_ready() { give 2 }
  if alloc.stable_package_meta() != "vitte/alloc" { give 3 }
  if alloc.stable_api_version().len == 0  or  alloc.api_version().len == 0 { give 4 }
  if alloc.stable_api_surface().len == 0 { give 5 }

  let rt0 = alloc.with_seed(alloc.stable_runtime_new(alloc.AllocatorKind.Global, 512), 7)
  let rt1 = alloc.with_canaries(alloc.with_poison_bytes(rt0, 170, 221), true)

  let a0 = alloc.stable_alloc(rt1, alloc.bytes(64), alloc.alignment(8), alloc.pool_id("tenant:t1"))
  if not a0.ok { give 6 }

  let r0 = alloc.stable_realloc(a0.runtime, a0.handle, alloc.bytes(96), alloc.alignment(8))
  if not r0.ok { give 7 }

  let f0 = alloc.stable_free(r0.runtime, a0.handle)
  if not f0.ok { give 8 }

  let leak0 = alloc.leak_report(f0.runtime)
  if leak0.active_allocations != 0 { give 9 }

  let panic_rt0 = alloc.with_oom_policy(alloc.stable_runtime_new(alloc.AllocatorKind.Global, 32), alloc.OomPolicy.Panic)
  let panic_a = alloc.stable_alloc(panic_rt0, alloc.bytes(1024), alloc.alignment(8), alloc.pool_id("tenant:p"))
  if panic_a.ok { give 10 }
  if not alloc.panic_runtime(panic_a.runtime) { give 11 }

  let panic_b = alloc.stable_alloc(panic_a.runtime, alloc.bytes(8), alloc.alignment(8), alloc.pool_id("tenant:p"))
  if panic_b.ok { give 12 }

  let panic_cleared = alloc.clear_panic(panic_a.runtime)
  let panic_ok = alloc.stable_alloc(panic_cleared, alloc.bytes(8), alloc.alignment(8), alloc.pool_id("tenant:p"))
  if not panic_ok.ok { give 13 }

  let c0 = alloc.stable_alloc(rt1, alloc.bytes(32), alloc.alignment(8), alloc.pool_id("tenant:c"))
  if not c0.ok { give 14 }
  let bad_rt = alloc.experimental_corrupt_canary(c0.runtime, c0.handle)
  let bad_free = alloc.stable_free(bad_rt, c0.handle)
  if bad_free.ok { give 15 }

  let stats = alloc.stable_stats(f0.runtime)
  if stats.alloc_total <= 0  or  stats.free_total <= 0 { give 16 }
  if alloc.alloc_error_name(alloc.AllocError.OutOfMemory).len == 0 { give 17 }

  let prop = alloc.property_invariants(5, 24)
  if not prop.ok { give 18 }

  let dbg0 = alloc.debug_runtime_new(alloc.AllocatorKind.Global, 256)
  if not alloc.debug_runtime_enabled(dbg0) { give 19 }
  let dbg_a = alloc.stable_alloc(dbg0, alloc.bytes(32), alloc.alignment(8), alloc.pool_id("tenant:d"))
  if not dbg_a.ok { give 20 }
  let dbg_f0 = alloc.stable_free(dbg_a.runtime, dbg_a.handle)
  if not dbg_f0.ok { give 21 }
  let dbg_f1 = alloc.stable_free(dbg_f0.runtime, dbg_a.handle)
  if dbg_f1.ok { give 22 }
  if not alloc.debug_detect_double_free(dbg_f1.runtime, dbg_a.handle) { give 23 }

  let st_dbg = alloc.stable_stats(dbg_f0.runtime)
  if alloc.alloc_counter_alloc_calls(dbg_f0.runtime) != st_dbg.alloc_total { give 24 }
  if alloc.alloc_counter_free_calls(dbg_f0.runtime) != st_dbg.free_total { give 25 }
  if alloc.alloc_counter_bytes_in_use(dbg_f0.runtime) != 0 { give 26 }

  let b_tiny = alloc.benchmark_micro_profile(3, 12, "tiny")
  let b_stress = alloc.benchmark_micro_profile(3, 12, "stress")
  if b_tiny.p95 < b_tiny.p50 { give 27 }
  if b_stress.p99 < b_stress.p95 { give 28 }
  if b_tiny.throughput <= 0  or  b_stress.throughput <= 0 { give 29 }

  give 0
}
