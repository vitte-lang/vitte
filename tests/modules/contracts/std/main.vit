<<<
main.vit
contracts smoke for vitte/std
>>>

use vitte/std as std_pkg

entry main at core/app {
  let idx: std_pkg.StdIndex = std_pkg.std_index()
  let idx2: std_pkg.StdIndex = std_pkg.register(idx, "json", "data", "vitte/std/data")
  if std_pkg.size(idx2) != 1 {
    give 1
  }
  if std_pkg.package_meta() != "vitte/std" {
    give 2
  }
  let okv: std_pkg.StdResult[int] = std_pkg.ok(7)
  if std_pkg.panic_guard(okv, 0) != 7 {
    give 3
  }
  give 0
}
