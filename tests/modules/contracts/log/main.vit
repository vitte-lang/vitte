<<<
main.vit
contracts smoke for vitte/log
>>>

use vitte/log as log_pkg

entry main at core/app {
  let lg: log_pkg.Logger = log_pkg.logger_new(log_pkg.LogLevel.Info)
  let lg2: log_pkg.Logger = log_pkg.with_module(lg, "contracts/log")
  let lg3: log_pkg.Logger = log_pkg.info(lg2, 1, "hello", "contracts/log", [])
  if log_pkg.summary(lg3) == "" {
    give 1
  }
  if log_pkg.package_meta() != "vitte/log" {
    give 2
  }
  give 0
}
