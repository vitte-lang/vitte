use vitte/abi as abi

proc main() -> i32 {
  if not abi.ready() { give 1 }
  if abi.abi_version().len == 0 { give 25 }
  if abi.platform_info().abi_version != abi.abi_version() { give 26 }
  if not abi.abi_compatible_with("1.0") { give 27 }
  if abi.abi_compatible_with("2.0") { give 28 }

  if abi.align_up(13, 0) != 13 { give 2 }
  if abi.align_up(13, 8) != 16 { give 3 }
  if abi.pointer_bits() != 64 { give 4 }
  if abi.pointer_bytes() != 8 { give 5 }

  let t_int = abi.type_info("int", 32)
  let t_ptr = abi.type_info("pointer", 0)
  let t_ret = abi.type_info("int", 64)
  let t_bad = abi.type_info("x", 0)

  if not abi.is_integer_type(t_int) { give 6 }
  if not abi.is_pointer_type(t_ptr) { give 7 }
  if abi.type_size_bits(t_ptr) != 64 { give 8 }
  if abi.type_align_bits(t_int) != 32 { give 9 }
  if abi.type_error(t_int) != abi.AbiError.None { give 10 }
  if abi.type_error(t_bad) != abi.AbiError.InvalidType { give 20 }
  if abi.validate_type("x", 0) != abi.AbiError.InvalidType { give 21 }
  if abi.validate_type("pointer", 0) != abi.AbiError.None { give 22 }

  let params = [t_int, t_ptr, t_int, t_int, t_int, t_int, t_int]
  let sig = abi.signature(abi.default_calling_convention(), t_ret, params)

  if not abi.validate_signature(sig) { give 11 }
  if not abi.is_supported_calling(sig.calling) { give 12 }
  if not abi.return_in_register(sig) { give 13 }
  if abi.stack_arg_bytes(sig) <= 0 { give 14 }
  if abi.frame_size(sig) < 16 { give 15 }

  let sig_bad_call = abi.signature(abi.CallingConvention.FastCall, t_ret, params)
  if abi.is_supported_calling(sig_bad_call.calling) { give 23 }
  if abi.validate_signature(sig_bad_call) { give 24 }

  let summary = abi.signature_abi_summary(sig)
  if summary.len == 0 { give 16 }
  if abi.mangle("main", sig).len == 0 { give 17 }
  if abi.calling_tag(sig.calling).len == 0 { give 18 }
  if abi.endianness().len == 0 { give 19 }

  give 0
}
