use vitte/alerts as alerts

proc main() -> i32 {
  let r0 = alerts.rule_new("desk", 20, 2)
  let r1 = alerts.AlertRule(r0.name, "cpu", alerts.AlertLevel.Critical, r0.threshold, r0.window_ticks, r0.state, r0.silenced_until, r0.last_value, r0.fired_count)
  let e0 = alerts.AlertEvent("k", "src", "cpu", 25, 10, ["tenant:t1"], alerts.trace_id("tr"))
  let routes = [alerts.RoutePolicy(alerts.tenant_id("tenant:t1"), alerts.AlertLevel.Critical, alerts.NotificationChannel.Pager, "pager:primary")]
  let tpl = alerts.template_new("v1", "title", "ctx", "https://runbook")
  let out = alerts.notify_routed(r1, e0, routes, tpl, alerts.provider_circuit_new(2, 5), alerts.notify_runtime_new(), 1)
  if out.decision.len == 0 { return 1 }
  return 0
}
