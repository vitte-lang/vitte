use vitte/ecs as ecs_pkg

entry main at core/app {
  let cfg = ecs_pkg.strict_config()
  let w0 = ecs_pkg.world_new()

  let s1: ecs_pkg.EcsResult[ecs_pkg.World] = ecs_pkg.spawn_checked(w0, cfg)
  when s1 is ecs_pkg.EcsResult.Err {
    return 1
  }

  let eid = ecs_pkg.last_spawned_id(s1.value)
  let p1: ecs_pkg.EcsResult[ecs_pkg.World] = ecs_pkg.add_position_checked(s1.value, eid, 0, 0, cfg)
  when p1 is ecs_pkg.EcsResult.Err {
    return 1
  }

  let v1: ecs_pkg.EcsResult[ecs_pkg.World] = ecs_pkg.add_velocity_checked(p1.value, eid, 1, 2, cfg)
  when v1 is ecs_pkg.EcsResult.Err {
    return 1
  }

  let w1 = ecs_pkg.step_n(v1.value, 3)
  if ecs_pkg.position_x(w1, eid) != 3 || ecs_pkg.position_y(w1, eid) != 6 {
    return 1
  }

  let w2 = ecs_pkg.despawn(w1, eid)
  if ecs_pkg.has_position(w2, eid) || ecs_pkg.has_velocity(w2, eid) {
    return 1
  }

  let st = ecs_pkg.ecs_stats(w2)
  if st.entities_total < 1 || st.positions_total != 0 || st.velocities_total != 0 {
    return 1
  }

  return 0
}
