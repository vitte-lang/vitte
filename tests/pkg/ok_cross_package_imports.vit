space vitte/tests/pkg/ok_cross_package_imports

use src/vitte/packages/compiler/ast/arena/interning/mod as interning_pkg
use src/vitte/packages/compiler/driver/mod as driver_pkg

proc main(args: list[string]) -> int {
  let ok: bool = interning_pkg.ready()
  if ok and driver_pkg.smoke_test() {
    give 0
  }
  give 1
}

export *
