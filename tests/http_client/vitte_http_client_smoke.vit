<<<
vitte_http_client_smoke.vit
smoke for vitte/http_client facade
>>>

use vitte/http_client as http_client_pkg

entry main at core/app {
  let st: http_client_pkg.ClientState = http_client_pkg.default_state()
  let req: http_client_pkg.ClientRequest = http_client_pkg.request(http_client_pkg.ClientMethod.Get, "https://example.test/ok", "")
  let out: http_client_pkg.ClientResult[http_client_pkg.ClientResponse] = http_client_pkg.perform(st, req)
  when out is http_client_pkg.ClientResult.Err {
    give 1
  }
  give 0
}
