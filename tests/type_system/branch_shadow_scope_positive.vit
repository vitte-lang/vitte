space tests/type_system/branch_shadow_scope_positive

proc accepts_int(value: int) -> bool {
  give value > 0
}

proc accepts_bool(value: bool) -> bool {
  give value
}

proc main() -> int {
  if true {
    let current: int = 1
    if not accepts_int(current) {
      give 1
    }
  }
  if true {
    let current: bool = true
    if not accepts_bool(current) {
      give 1
    }
  }
  give 0
}
