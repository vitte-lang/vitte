space tests/type_system/array_return_non_generic

// metrics: generic_instantiations=0 trait_impls=0 sum_variants=0 pattern_arms=0 inference_constraints=5
proc values() -> [u64] {
  give [1 as u64]
}

proc first(items: [u64]) -> u64 {
  give items[0]
}

proc main() -> u64 {
  let items: [u64] = values()
  give first(items)
}
