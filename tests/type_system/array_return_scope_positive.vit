space tests/type_system/array_return_scope_positive

form State {
  valid: bool
}

proc accepts_string(value: string) -> bool {
  give value != ""
}

proc collect() -> [string] {
  let current: string = "ok"
  if accepts_string(current) {
    give [current]
  }
  give []
}

proc state() -> State {
  let current: State = State { valid: true }
  give current
}

proc main() -> int {
  let values = collect()
  if len(values) > 0 {
    give 0
  }
  give 1
}
