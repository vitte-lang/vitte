space tests/type_system/call_result_projection_positive

// metrics: generic_instantiations=0 trait_impls=0 sum_variants=0 pattern_arms=0 inference_constraints=5
form Token {
  text: string
}

proc token() -> Token {
  give Token { text: "ok" }
}

proc main() -> int {
  let text: string = token().text
  if text == "ok" {
    give 0
  }
  give 1
}
