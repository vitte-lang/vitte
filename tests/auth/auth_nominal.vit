use vitte/auth as auth_pkg

entry main at core/app {
  let cfg = auth_pkg.strict_config()
  let vr: auth_pkg.AuthResult[bool] = auth_pkg.validate_config(cfg)
  when vr is auth_pkg.AuthResult.Err {
    give 1
  }

  let p = auth_pkg.authenticate_with_config(auth_pkg.Credentials("admin", "admin123456", "000000"), cfg)
  if p.role != auth_pkg.AuthRole.Admin {
    give 1
  }

  let s = auth_pkg.issue_token_with_config(p, cfg)
  if s.token.len == 0 {
    give 1
  }

  if auth_pkg.validate_with_config(s, 1, cfg) != auth_pkg.AuthError.None {
    give 1
  }

  let d = auth_pkg.decide_access_with_config(s, auth_pkg.AuthRole.Admin, 1, cfg)
  if d.allowed == false {
    give 1
  }

  let h = auth_pkg.auth_health(cfg)
  if h.runtime_ok == false {
    give 1
  }

  let cfg2 = auth_pkg.with_require_active(auth_pkg.with_clock_skew(auth_pkg.default_config(), 5), false)
  let s_inactive = auth_pkg.Session(auth_pkg.Principal("alice", auth_pkg.AuthRole.User, false), "tok:alice", 10)
  if auth_pkg.validate_with_config(s_inactive, 12, cfg2) != auth_pkg.AuthError.None {
    give 1
  }

  let cfg_otp = auth_pkg.with_require_otp(auth_pkg.default_config(), true)
  let p_bad_otp = auth_pkg.authenticate_with_config(auth_pkg.Credentials("admin", "admin123456", "abc"), cfg_otp)
  if p_bad_otp.role != auth_pkg.AuthRole.Guest {
    give 1
  }

  let cfg_service_block = auth_pkg.with_allow_service(auth_pkg.default_config(), false)
  let svc = auth_pkg.principal_service("svc")
  let s_svc = auth_pkg.issue_token_with_config(svc, cfg_service_block)
  let dec = auth_pkg.decide_access_with_config(s_svc, auth_pkg.AuthRole.User, 1, cfg_service_block)
  if auth_pkg.decision_error(dec) != auth_pkg.AuthError.Forbidden {
    give 1
  }

  if auth_pkg.ready() == false {
    give 1
  }

  give 0
}
