proc main() -> int {
  let a = 1
  let b = 2
  let c = 3
  let d = 4

  let assign_chain = a = b = c
  let logic_chain = a < b or b < c and c < d
  let eq_rel = a + b == c * d
  let add_mul = a + b * c - d / a % b
  let unary_postfix = -arr[0].value
  let cast_mix = a + b as int
  let pattern_test = maybe is Option.Some(x)

  give assign_chain
}
