use vitte/config_derive as derive_pkg

entry main at core/app {
  let opts = derive_pkg.strict_options()
  let vr: derive_pkg.DeriveApiResult[bool] = derive_pkg.validate_options(opts)
  when vr is derive_pkg.DeriveApiResult.Err {
    return 1
  }

  let s0 = derive_pkg.schema("app")
  let a1: derive_pkg.DeriveApiResult[derive_pkg.Schema] = derive_pkg.add_field_checked(s0, "host", "localhost", true, opts)
  when a1 is derive_pkg.DeriveApiResult.Err {
    return 1
  }

  let a2: derive_pkg.DeriveApiResult[derive_pkg.Schema] = derive_pkg.add_field_checked(a1.value, "port", "8080", false, opts)
  when a2 is derive_pkg.DeriveApiResult.Err {
    return 1
  }

  let dr: derive_pkg.DeriveApiResult[derive_pkg.DeriveResult] = derive_pkg.derive_checked(a2.value, opts)
  when dr is derive_pkg.DeriveApiResult.Err {
    return 1
  }

  if dr.value.keys.len != 2 {
    return 1
  }

  let n = derive_pkg.schema_normalize(a2.value, opts)
  let code = derive_pkg.validate_schema_code(n, opts)
  if code != "ok" {
    return 1
  }

  if derive_pkg.ready() == false {
    return 1
  }

  return 0
}
