<<<
vitte_json_smoke.vit
smoke for vitte/json facade
>>>

use vitte/json as json_pkg

entry main at core/app {
  let opts: json_pkg.ParseOptions = json_pkg.default_parse_options()
  let parsed: json_pkg.JsonResult[json_pkg.Value] = json_pkg.parse_text("{\"ok\":true}", opts)
  when parsed is json_pkg.JsonResult.Err {
    give 1
  }
  let formatted: json_pkg.JsonResult[string] = json_pkg.format_compact("{\"ok\":true}", json_pkg.default_format_options())
  when formatted is json_pkg.JsonResult.Err {
    give 2
  }
  give 0
}
