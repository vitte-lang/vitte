space tests/typeck/advanced_full/invalid

form Point {
  x: int
}

trait Show {
  proc show(self: Self) -> string;
}

impl Show for Point {
  proc show(self: Self) -> string {
    give "point";
  }
}

proc main() -> int {
  let point = Point { x: 1 };
  let text: int = point.show();
  let value: int = "not an int";
  give value;
}
