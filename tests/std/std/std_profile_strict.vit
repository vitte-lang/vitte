<<<
std_profile_strict.vit
strict profile smoke for vitte/std
>>>

use vitte/std as std_pkg

entry main at core/app {
  if std_pkg.std_strict_enabled() == false {
    give 1
  }
  if std_pkg.export_allowed("core", "net") {
    give 2
  }
  if std_pkg.export_allowed("desktop", "net") == false {
    give 3
  }
  give 0
}
