<<<
std_data_bench_micro.vit
micro bench placeholder for std/data
>>>

use vitte/std/data as std_data_pkg

entry main at core/app {
  let c = std_data_pkg.cache_new()
  let i: int = 0
  let out = c
  loop {
    if i >= 128 { break }
    out = std_data_pkg.cache_set(out, "k", "v", 1000, i)
    i = i + 1
  }
  give 0
}
