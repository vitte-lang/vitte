use vitte/std/data as std_data_pkg

entry main at core/app {
  let cfg = std_data_pkg.default_config()
  let vr = std_data_pkg.validate_config(cfg)
  when vr is std_data_pkg.StdDataResult.Err { give 1 }
  let c = std_data_pkg.cache_set(std_data_pkg.cache_new(), "k", "v", 1000, 0)
  if std_data_pkg.cache_has(c, "k", 10) == false { give 2 }
  give 0
}
