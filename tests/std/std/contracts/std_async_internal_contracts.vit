use vitte/std/async as std_async_pkg

entry main at core/app {
  let cfg = std_async_pkg.default_config()
  let vr = std_async_pkg.validate_config(cfg)
  when vr is std_async_pkg.StdAsyncResult.Err { give 1 }
  let t = std_async_pkg.spawn("job")
  when t is std_async_pkg.StdAsyncResult.Err { give 2 }
  give 0
}
