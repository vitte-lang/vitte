<<<
std_table_critical_apis.vit
table-driven checks for io/path/json/http/time names
>>>

use vitte/std as std_pkg

entry main at core/app {
  let idx: std_pkg.StdIndex = std_pkg.std_index()
  idx = std_pkg.register(idx, "io", "io", "vitte/std/io")
  idx = std_pkg.register(idx, "path", "data", "vitte/std/data")
  idx = std_pkg.register(idx, "json", "data", "vitte/std/data")
  idx = std_pkg.register(idx, "http", "net", "vitte/std/net")
  idx = std_pkg.register(idx, "time", "base", "vitte/std/base")
  if std_pkg.size(idx) != 5 {
    give 1
  }
  give 0
}
