<<<
std_net_bench_micro.vit
micro bench placeholder for std/net
>>>

use vitte/std/net as std_net_pkg

entry main at core/app {
  let hs: [std_net_pkg.StdNetHeader] = []
  let i: int = 0
  loop {
    if i >= 64 { break }
    let _ = std_net_pkg.get("api.vitte.dev", hs, 500)
    i = i + 1
  }
  give 0
}
