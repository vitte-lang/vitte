<<<
vitte_core_smoke.vit
smoke for vitte/core facade
>>>

use vitte/core as core_pkg

entry main at core/app {
  let a: core_pkg.Option[int] = core_pkg.some[int](7)
  if core_pkg.is_some[int](a) == false {
    give 1
  }

  let r: core_pkg.Result[int, string] = core_pkg.ok(9)
  if core_pkg.is_ok(r) == false {
    give 2
  }

  if core_pkg.package_meta() != "vitte/core" {
    give 3
  }

  give 0
}
