space tests/truth_triangle/stdlib_runtime/_tmp_mutex_usage

use src/vitte/stdlib/threading/mutex as mutex

proc main() -> int {
  let total: int = 0
  let m: mutex.Mutex<int> = mutex.mutex_new<int>(3)
  if mutex.mutex_lock<int>(m) {
    set total = total + 1
  }
  if mutex.mutex_set<int>(m, 5) {
    set total = total + 1
  }
  set total = total + mutex.mutex_get<int>(m)
  if mutex.mutex_unlock<int>(m) {
    set total = total + 1
  }
  give total
}
