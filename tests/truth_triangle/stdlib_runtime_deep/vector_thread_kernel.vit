space tests/truth_triangle/stdlib_runtime_deep/vector_thread_kernel

use src/vitte/stdlib/collections/vector as vector
use src/vitte/stdlib/kernel as kernel
use src/vitte/stdlib/threading/mutex as mutex

proc main() -> int {
  give vector.vector_push(vector.vector_new(1), 9) + mutex.get_next_mutex_id() + kernel.module_ready()
}
