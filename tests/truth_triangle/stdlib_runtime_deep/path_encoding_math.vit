space tests/truth_triangle/stdlib_runtime_deep/path_encoding_math

use src/vitte/stdlib/encoding/utf8 as utf8
use src/vitte/stdlib/io as io
use src/vitte/stdlib/math/arithmetic as arithmetic
use src/vitte/stdlib/strings as strings

proc main() -> int {
  give strings.str_length(io.path_join("a", "bc")) + utf8.utf8_length("xyz") + arithmetic.add_i64(1, 2)
}
