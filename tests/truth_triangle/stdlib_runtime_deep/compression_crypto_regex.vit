space tests/truth_triangle/stdlib_runtime_deep/compression_crypto_regex

use src/vitte/stdlib/compression as compression
use src/vitte/stdlib/crypto as crypto
use src/vitte/stdlib/regex as regex
use src/vitte/stdlib/strings as strings

proc main() -> int {
  give strings.str_length(compression.compression_version()) + crypto.crypto_module_count() + regex.regex_module_count()
}
