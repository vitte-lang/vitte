space tests/truth_triangle/stdlib_runtime_deep/full_runtime_mix

use src/vitte/stdlib/async as async
use src/vitte/stdlib/crypto as crypto
use src/vitte/stdlib/encoding/utf8 as utf8
use src/vitte/stdlib/io as io
use src/vitte/stdlib/json as json
use src/vitte/stdlib/math/arithmetic as arithmetic
use src/vitte/stdlib/strings as strings

proc main() -> int {
  give strings.str_length(async.async_version()) + crypto.crypto_module_count() + utf8.utf8_length("mix") + strings.str_length(io.path_join("rt", "x")) + json.json_module_count() + arithmetic.add_i64(2, 3)
}
