space tests/truth_triangle/stdlib_runtime_deep/io_encoding

use src/vitte/stdlib/encoding/utf8 as utf8
use src/vitte/stdlib/io/stream as stream
use src/vitte/stdlib/io/fileops as fileops
use src/vitte/stdlib/strings as strings

proc main() -> int {
  give stream.stream_ready() + utf8.utf8_length("stream") + strings.str_length(fileops.fileops_version())
}
