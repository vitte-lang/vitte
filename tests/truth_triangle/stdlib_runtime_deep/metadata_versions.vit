space tests/truth_triangle/stdlib_runtime_deep/metadata_versions

use src/vitte/stdlib/async/async as async
use src/vitte/stdlib/compression as compression
use src/vitte/stdlib/io/fileops as fileops
use src/vitte/stdlib/math/matrix as matrix
use src/vitte/stdlib/strings as strings

proc main() -> int {
  give strings.str_length(async.async_version()) + strings.str_length(compression.compression_version()) + strings.str_length(fileops.fileops_version()) + strings.str_length(matrix.matrix_version())
}
