space tests/truth_triangle/stdlib_runtime_deep/fileops_path

use src/vitte/stdlib/io as io
use src/vitte/stdlib/io/fileops as fileops
use src/vitte/stdlib/strings as strings

proc main() -> int {
  give strings.str_length(fileops.fileops_version()) + strings.str_length(io.path_join("tmp", "file"))
}
