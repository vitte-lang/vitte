space app/profile_generic_specialization

form Box<T> {
  value: T,
}

proc make_box<T>(value: T) -> Box<T> {
  let out: Box<T> = Box<T> {
    value: value,
  }
  give out
}

proc main() -> i32 {
  let bi: Box<i32> = make_box<i32>(42)
  let bs: Box<string> = make_box<string>("ok")
  let bb: Box<bool> = make_box<bool>(true)

  if bi.value == 42 and bs.value == "ok" and bb.value {
    give 0
  }

  give 1
}
