use vitte/sync as sync_pkg

entry main at core/app {
  let t1 = sync_pkg.thread_id("t1")
  let t2 = sync_pkg.thread_id("t2")

  let m = sync_pkg.mutex_new_with_mode("m", sync_pkg.FairMode.Fair)
  let r1: sync_pkg.SyncResult[sync_pkg.MutexState] = sync_pkg.mutex_try_lock(m, t1)
  when r1 is sync_pkg.SyncResult.Err {
    return 1
  }

  let r2: sync_pkg.SyncResult[sync_pkg.MutexState] = sync_pkg.mutex_try_lock(r1.value, t2)
  when r2 is sync_pkg.SyncResult.Ok {
    return 1
  }

  let ur: sync_pkg.SyncResult[sync_pkg.MutexState] = sync_pkg.mutex_unlock(r1.value, t1)
  when ur is sync_pkg.SyncResult.Err {
    return 1
  }

  let rw = sync_pkg.rwlock_new_with_policy("rw", sync_pkg.FairMode.Fair, sync_pkg.WriterPriority.PreferWriters)
  let rw1 = sync_pkg.rwlock_mark_writer_wait(rw)
  let rr: sync_pkg.SyncResult[sync_pkg.RwLockState] = sync_pkg.rwlock_try_read(rw1)
  when rr is sync_pkg.SyncResult.Ok {
    return 1
  }

  let bar = sync_pkg.barrier_new("b", 2)
  let b1: sync_pkg.SyncResult[sync_pkg.BarrierWaitResult] = sync_pkg.barrier_arrive_and_wait(bar)
  when b1 is sync_pkg.SyncResult.Err {
    return 1
  }
  if b1.value.leader {
    return 1
  }

  let b2: sync_pkg.SyncResult[sync_pkg.BarrierWaitResult] = sync_pkg.barrier_arrive_and_wait(b1.value.state)
  when b2 is sync_pkg.SyncResult.Err {
    return 1
  }
  if b2.value.leader == false {
    return 1
  }

  let ev = sync_pkg.event_new("ev")
  let ew: sync_pkg.SyncResult[sync_pkg.EventState] = sync_pkg.event_wait(ev, 1)
  when ew is sync_pkg.SyncResult.Ok {
    return 1
  }

  let snap = sync_pkg.sync_normalize(sync_pkg.snapshot_new())
  if sync_pkg.sync_validate(snap) == false {
    return 1
  }

  if sync_pkg.ready() == false {
    return 1
  }

  return 0
}
