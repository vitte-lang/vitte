use vitte/sync as sync_pkg

entry main at core/app {
  let bad_owner = sync_pkg.thread_id("")
  let m = sync_pkg.mutex_new("m")

  let r_bad: sync_pkg.SyncResult[sync_pkg.MutexState] = sync_pkg.mutex_try_lock(m, bad_owner)
  when r_bad is sync_pkg.SyncResult.Ok {
    return 1
  }

  let t1 = sync_pkg.thread_id("t1")
  let t2 = sync_pkg.thread_id("t2")

  let r1: sync_pkg.SyncResult[sync_pkg.MutexState] = sync_pkg.mutex_try_lock(m, t1)
  when r1 is sync_pkg.SyncResult.Err {
    return 1
  }

  let r2: sync_pkg.SyncResult[sync_pkg.MutexState] = sync_pkg.mutex_lock(r1.value, t2, 0)
  when r2 is sync_pkg.SyncResult.Ok {
    return 1
  }

  let ev = sync_pkg.event_new("ev")
  let ew0: sync_pkg.SyncResult[sync_pkg.EventState] = sync_pkg.event_wait(ev, 0)
  when ew0 is sync_pkg.SyncResult.Ok {
    return 1
  }

  let ew1: sync_pkg.SyncResult[sync_pkg.EventState] = sync_pkg.event_wait(ev, 2)
  when ew1 is sync_pkg.SyncResult.Ok {
    return 1
  }

  return 0
}
