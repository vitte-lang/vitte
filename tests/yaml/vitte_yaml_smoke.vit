<<<
vitte_yaml_smoke.vit
smoke for vitte/yaml facade
>>>

use vitte/yaml as yaml_pkg

entry main at core/app {
  let opts: yaml_pkg.ParseOptions = yaml_pkg.default_parse_options()
  let parsed: yaml_pkg.YamlResult[yaml_pkg.Value] = yaml_pkg.parse_text("a: b", opts)
  when parsed is yaml_pkg.YamlResult.Err {
    give 1
  }
  let formatted: yaml_pkg.YamlResult[string] = yaml_pkg.format_pretty("a: b", yaml_pkg.default_format_options())
  when formatted is yaml_pkg.YamlResult.Err {
    give 2
  }
  give 0
}
