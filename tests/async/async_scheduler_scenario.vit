use vitte/async as async_pkg

entry main at core/app {
  let s0 = async_pkg.scheduler_new(2)
  let s1 = async_pkg.scheduler_enqueue(s0, 5)
  let s2 = async_pkg.scheduler_tick(s1)
  if async_pkg.scheduler_capacity(s2) != 0 {
    give 1
  }

  let s3 = async_pkg.scheduler_complete(s2, 1)
  if async_pkg.scheduler_capacity(s3) != 1 {
    give 1
  }

  let s4 = async_pkg.scheduler_complete(s3, 99)
  if async_pkg.scheduler_idle(s4) == false {
    give 1
  }

  let all_ok = async_pkg.join_all([true, true, true])
  if not all_ok {
    give 1
  }
  if async_pkg.race([false, true, false]) != 1 {
    give 1
  }

  let parent = async_pkg.with_task_policy(200, async_pkg.CancelMode.Cooperative, 3)
  let child = async_pkg.child_policy_from_parent(parent, 500, async_pkg.CancelMode.Immediate, 7)
  if child.timeout_ms != 200  or  child.retry_limit != 3 {
    give 1
  }
  let parent_immediate = async_pkg.with_task_policy(200, async_pkg.CancelMode.Immediate, 3)
  let child_soft = async_pkg.child_policy_from_parent(parent_immediate, 100, async_pkg.CancelMode.Cooperative, 1)
  if child_soft.cancel_mode != async_pkg.CancelMode.Immediate {
    give 1
  }

  let fr = async_pkg.scheduler_fairness_report(s2)
  if fr.backlog_per_slot < 0  or  fr.utilization_pct < 0  or  fr.imbalance < 0 {
    give 1
  }

  let ts0 = async_pkg.time_source_mock(100)
  let ts1 = async_pkg.time_advance(ts0, 25)
  if async_pkg.time_now(ts1) != 125 {
    give 1
  }

  let d_timeout = async_pkg.diagnostics_snapshot(async_pkg.TaskState.TimedOut, s1)
  let d_cancel = async_pkg.diagnostics_snapshot(async_pkg.TaskState.Cancelled, s1)
  let d_backp = async_pkg.diagnostics_snapshot(async_pkg.TaskState.Running, s1)
  if async_pkg.diagnostics_code_for_state(async_pkg.TaskState.Running, s2) != "VITTE-ASYNC0000" {
    give 1
  }
  if d_timeout.len == 0  or  d_cancel.len == 0  or  d_backp.len == 0 {
    give 1
  }
  give 0
}
