use vitte/async as async_pkg

proc ok_job() -> int {
  give 0
}

entry main at core/app {
  let cfg: async_pkg.AsyncConfig = async_pkg.default_config()
  let hr: async_pkg.AsyncResult[bool] = async_pkg.healthcheck(cfg)
  when hr is async_pkg.AsyncResult.Err {
    give 1
  }

  let pol = async_pkg.with_task_policy(250, async_pkg.CancelMode.Cooperative, 2)
  let rt0 = async_pkg.task_runtime(1, "job-1", pol)
  let rt1 = async_pkg.task_set_queue_wait(rt0, 5)
  let rt2 = async_pkg.task_push_latency(rt1, 7)
  let rt3 = async_pkg.task_push_latency(rt2, 11)
  let mt = async_pkg.task_metrics(rt3)
  if mt.run_count != 2  or  mt.latency_last != 11  or  mt.queue_wait_ms != 5 {
    give 1
  }
  let cancelled = async_pkg.cancel_with_reason(rt3, "user-stop")
  if async_pkg.task_state(cancelled.meta) != async_pkg.TaskState.Cancelled {
    give 1
  }

  let sch0 = async_pkg.scheduler_new(2)
  let sch1 = async_pkg.scheduler_enqueue(sch0, 3)
  let sch2 = async_pkg.scheduler_tick(sch1)
  if sch2.running <= 0 {
    give 1
  }

  let state = async_pkg.run_with_retry(ok_job, 1)
  if async_pkg.is_terminal(state) == false {
    give 1
  }
  give 0
}
