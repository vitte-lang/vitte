  let idem_has_k2 = v_idempotency.has_key(idem4, "k2", 6)
  let idem_after = v_idempotency.check_key(v_idempotency.expire_keys(idem1, 20), "k1", 20)

  let c0_def = v_contracts.contract_load("user-api", "1.0.0", "sha-a", ["id", "name"])
  let c1_def = v_contracts.contract_load("user-api", "1.1.0", "sha-b", ["id", "name"])
  let c2_def = v_contracts.add_required_field(c0_def, "email")
  let c3_def = v_contracts.with_hash(c2_def, "sha-c")
  let c_name = v_contracts.contract_name(c3_def)
  let c_version = v_contracts.contract_version(c3_def)
  let c_hash = v_contracts.contract_hash(c3_def)
  let c_fields = v_contracts.field_count(c3_def)
  let c_has_email = v_contracts.has_required_field(c3_def, "email")
  let c_missing = v_contracts.first_missing_field(c3_def, "{\"id\":1,\"name\":\"n\"}")
  let c_non_empty = v_contracts.verify_payload_non_empty(c3_def, "{\"id\":1,\"name\":\"n\",\"email\":\"e\"}")
  let c_same = v_contracts.same_identity(c0_def, c2_def)
  let c_breaking = v_contracts.is_breaking(c0_def, c3_def)
  let c_summary = v_contracts.contract_summary(c3_def)
  let c_ok = v_contracts.contract_verify(c0_def, "{\"id\":1,\"name\":\"n\"}")
  let c_diff = v_contracts.diff(c0_def, c1_def)
  let c_snap = v_contracts.snapshot(c0_def)

  let ob0 = v_outbox.outbox_new()
  let ob1 = v_outbox.enqueue_event(ob0, "user.created", "{\"id\":1}")
  let ob2 = v_outbox.enqueue_event(ob1, "user.updated", "{\"id\":1,\"name\":\"n\"}")
  let ob3 = v_outbox.flush_batch(ob2, 1)
  let ob4 = v_outbox.mark_sent(ob3, 0)
  let ob5 = v_outbox.retry_event(ob4, 1)
