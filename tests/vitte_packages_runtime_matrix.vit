  let ob_status_1 = v_outbox.status(ob5, 1)
  let ob_events_after_prune = v_outbox.event_count(ob6)
  let ob_empty_after_clear = v_outbox.is_empty(ob8)
  let ob_sent_ids = v_outbox.sent_ids(ob4)
  let ob_flushed_ids = v_outbox.flushed_ids(ob3)
  let ob_pending_topic = v_outbox.pending_by_topic(ob4, "user.updated")
  let ob_oldest_pending = v_outbox.oldest_pending_id(ob4)
  let ob9 = v_outbox.retry_all_pending(ob4)
  let ob_can_flush = v_outbox.can_flush(ob4)
