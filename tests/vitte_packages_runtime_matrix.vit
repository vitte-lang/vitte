  let sg_step_comp_charge = v_saga.step_compensated(sg3, "charge")
  let sg_all_done = v_saga.all_done(sg4)
  let sg_all_comp = v_saga.all_compensated(sg3)
  let sg_can_comp = v_saga.can_compensate(sg2)
