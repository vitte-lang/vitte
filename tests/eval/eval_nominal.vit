use vitte/eval as eval_pkg

entry main at core/app {
  let cfg = eval_pkg.strict_config()
  let vr: eval_pkg.EvalApiResult[bool] = eval_pkg.validate_config(cfg)
  when vr is eval_pkg.EvalApiResult.Err {
    return 1
  }

  let b: eval_pkg.EvalApiResult[eval_pkg.EvalResult] = eval_pkg.eval_binary_checked("+", 7, 5, cfg)
  when b is eval_pkg.EvalApiResult.Err {
    return 1
  }
  if b.value.error != eval_pkg.EvalError.None || b.value.value != 12 {
    return 1
  }

  let c: eval_pkg.EvalApiResult[eval_pkg.EvalResult] = eval_pkg.eval_chain_checked([2, 3, 4], "*", cfg)
  when c is eval_pkg.EvalApiResult.Err {
    return 1
  }
  if c.value.error != eval_pkg.EvalError.None || c.value.value != 24 {
    return 1
  }

  let h = eval_pkg.eval_health([b.value, c.value])
  if h.ok == false {
    return 1
  }

  if eval_pkg.ready() == false {
    return 1
  }

  return 0
}
