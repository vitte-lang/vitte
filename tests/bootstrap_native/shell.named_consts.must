            main_line_count += 1
            main_lines[main_line_count] = line
            main_capture_depth += line_open_brace_count(line) - line_close_brace_count(line)
            if (main_capture_depth < 1) fail_native("malformed brace structure in bootstrap native `proc main()`")
            next
        }
        fail_native("unsupported bootstrap native top-level item: " line)
    }
    END {
        if (!invalid && saw_main && result == "" && main_line_count > 0) exec_main_range(1, main_line_count)
        if (in_main && failure_reason == "") failure_reason = "unterminated bootstrap native `proc main()` block"
        if (!saw_main && failure_reason == "") failure_reason = "missing bootstrap native `proc main()` entrypoint"
        if (result == "" && failure_reason == "") failure_reason = "bootstrap native backend could not compute a `give` value for `proc main()`"
        if (invalid || in_main || exec_depth > 0 || !saw_main || result == "") {
            if (failure_reason != "") print failure_reason > "/dev/stderr"
            exit 1
        }
        print result
    }' "$src"
}

extract_native_ir_main_return() {
    ir_text="$1"
    printf '%s\n' "$ir_text" | awk -F= '
    /^main.return=/ {
        value = $0
        sub(/^main.return=/, "", value)
        if (value ~ /^-?[0-9]+$/) {
            print value
            found = 1
        }
    }
    END {
        if (!found) exit 1
    }'
}

compile_host_c() {
    cc_bin="$1"
    c_src="$2"
    target_out="$3"
    link_dir="$(mktemp -d "${TMPDIR:-/tmp}/vitte-bootstrap-link-XXXXXX")" || return 1
    link_out="$link_dir/vitte-bootstrap-artifact"
    if "$cc_bin" -x c "$c_src" -o "$link_out"; then
        if [ -f "$link_out" ]; then
            linked_artifact="$link_out"
        elif [ -f "${link_out}.exe" ]; then
            linked_artifact="${link_out}.exe"
        else
            rm -rf "$link_dir"
            return 1
        fi
        if mv -f "$linked_artifact" "$target_out"; then
            rm -rf "$link_dir"
            return 0
        else
            rc="$?"
        fi
    else
        rc="$?"
    fi
    rm -rf "$link_dir"
    return "$rc"
}

emit_native_return_executable() {
    return_value="$1"
    target_out="$2"
    src="$3"
    cc_bin="${CC:-cc}"
    c_src="$(mktemp "${TMPDIR:-/tmp}/vitte-bootstrap-c-XXXXXX")" || {
        cli_error E_BACKEND_FAILURE "failed to allocate bootstrap C work file for $src" "check TMPDIR permissions"
        return 1
    }
    printf 'int main(void) { return %s; }\n' "$return_value" > "$c_src"
    compile_host_c "$cc_bin" "$c_src" "$target_out" || {
        cli_error E_BACKEND_FAILURE "host C compilation failed for $src" "inspect host compiler diagnostics"
        rm -f "$c_src"
        rm -f "$target_out"
        return 1
    }
    rm -f "$c_src"
    rm -f "${target_out}.bootstrap-bridge"
    chmod +x "$target_out"
}

emit_pre_backend_diagnostic() {
    src="$1"
    if diag_info="$(detect_professional_diagnostic "$src")"; then
        render_professional_diagnostic_text "$src" "$diag_info" >&2
        return 0
    fi
    if parser_info="$(detect_simple_unclosed_block "$src")"; then
        render_professional_diagnostic_text "$src" "$parser_info" >&2
        return 0
    fi
    return 1
}

build_native_user_program() {
    src="$1"
    out="$2"
    target_out="$2"
    cc_bin="${CC:-cc}"
    allow_full_bridge="${VITTE_BOOTSTRAP_ALLOW_FULL_COMPILER_BRIDGE:-1}"
    guard_output_not_source "$src" "$target_out" || return 1
    if emit_pre_backend_diagnostic "$src"; then
        return 1
    fi
    native_reason_file="$(mktemp "${TMPDIR:-/tmp}/vitte-bootstrap-native-reason-XXXXXX" 2>/dev/null || true)"
    if [ -n "$native_reason_file" ]; then
        main_return="$(extract_native_main_return "$src" 2>"$native_reason_file" || true)"
        native_main_reason="$(sed -n '1p' "$native_reason_file" 2>/dev/null || true)"
        rm -f "$native_reason_file"
    else
        main_return="$(extract_native_main_return "$src" || true)"
        native_main_reason=""
    fi
    command -v "$cc_bin" >/dev/null 2>&1 || {
        cli_error E_BACKEND_TOOLCHAIN "native bootstrap build requires a host C compiler" "set CC or install cc"
        return 1
    }
    mkdir -p "$(dirname "$target_out")"
    if [ -n "$main_return" ]; then
        emit_native_return_executable "$main_return" "$target_out" "$src"
        return $?
    fi
    ir_text="$(compile_native_ir "$src" "v1" 2>/dev/null || true)"
    case "$ir_text" in
        *"const.int.BOOTSTRAP_FULL_COMPILER=1"*)
            if [ "$allow_full_bridge" != "1" ]; then
                cli_error E_BOOTSTRAP_FULL_COMPILER_BRIDGE_DISABLED "full-compiler bootstrap bridge disabled for this build" "enable a real backend path or set VITTE_BOOTSTRAP_ALLOW_FULL_COMPILER_BRIDGE=1 for transitional manual use"
                return 1
            fi
            tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/vitte-bootstrap-payload-XXXXXX")"
            payload="$tmp_dir/payload.sh"
            c_src="$(mktemp "${TMPDIR:-/tmp}/vitte-bootstrap-c-XXXXXX")" || {
                rm -rf "$tmp_dir"
                cli_error E_BACKEND_FAILURE "failed to allocate bootstrap C work file for $src" "check TMPDIR permissions"
                return 1
            }
            write_compiler "$src" "$payload"
            cat > "$c_src" <<EOF
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <sys/stat.h>
#include <sys/wait.h>
#include <unistd.h>

static const char *payload_source =
$(shell_payload_c_literal "$payload");
static const char *bootstrap_payload_bridge_marker = "vitte-bootstrap-payload-bridge";

static int write_payload_file(const char *path) {
    FILE *file = fopen(path, "wb");
    size_t payload_len = strlen(payload_source);
    if (file == NULL) {
        return 127;
    }
    if (payload_len > 0 && fwrite(payload_source, 1, payload_len, file) != payload_len) {
        fclose(file);
        return 127;
    }
    if (fclose(file) != 0) {
        return 127;
    }
    if (chmod(path, 0700) != 0) {
        return 127;
    }
    return 0;
}

int main(int argc, char **argv) {
    char tmpl[] = "/tmp/vitte-bootstrap-payload-XXXXXX";
    int fd = mkstemp(tmpl);
    pid_t pid;
    int status = 0;
    char **child_argv;
    if (fd < 0) {
        return 127;
    }
    close(fd);
    if (write_payload_file(tmpl) != 0) {
        unlink(tmpl);
        return 127;
    }
    child_argv = (char **)malloc(sizeof(char *) * (size_t)(argc + 2));
    if (child_argv == NULL) {
        unlink(tmpl);
        return 127;
    }
    child_argv[0] = tmpl;
    for (int i = 1; i < argc; i += 1) {
        child_argv[i] = argv[i];
    }
    child_argv[argc] = NULL;
    pid = fork();
    if (pid < 0) {
        free(child_argv);
        unlink(tmpl);
        return 127;
    }
    if (pid == 0) {
        setenv("trace_pipeline", "0", 0);
        setenv("strict_mode", "0", 0);
        execv(tmpl, child_argv);
        _exit(127);
    }
    free(child_argv);
    if (waitpid(pid, &status, 0) < 0) {
        unlink(tmpl);
        return 127;
    }
    unlink(tmpl);
    if (WIFEXITED(status)) {
        return WEXITSTATUS(status);
    }
    return 127;
}
EOF
            compile_host_c "$cc_bin" "$c_src" "$target_out" || {
                cli_error E_BACKEND_FAILURE "host C payload compilation failed for $src" "inspect host compiler diagnostics"
                rm -rf "$tmp_dir"
                rm -f "$c_src"
                rm -f "$target_out"
                return 1
            }
            rm -rf "$tmp_dir"
            rm -f "$c_src"
            rm -f "${target_out}.bootstrap-bridge"
            chmod +x "$target_out"
            return 0
            ;;
    esac
    main_return="$(extract_native_ir_main_return "$ir_text" || true)"
    if [ -n "$main_return" ]; then
        emit_native_return_executable "$main_return" "$target_out" "$src"
        return $?
    fi
    if [ "$allow_full_bridge" = "1" ] && is_bootstrap_compiler_test_suite_source "$src"; then
        repo_root="$(bootstrap_repo_root_from_source "$src" || true)"
        if [ -n "$repo_root" ]; then
            write_compiler_test_suite_bridge "$src" "$target_out" "$repo_root"
            rm -f "${target_out}.bootstrap-bridge"
            return 0
        fi
    fi
    if { [ -n "${compiler_source_root:-}" ] || [ -n "${compiler_entry_point:-}" ]; } && resolve_generic_backend_compiler >/dev/null 2>&1; then
        return 125
    fi
    if [ -n "${native_main_reason:-}" ]; then
        cli_error E_BACKEND_FAILURE "$native_main_reason" "supported today: let, set, if, while, and give on integer literals or variables"
        return 1
    fi
    cli_error E_BACKEND_FAILURE "bootstrap native backend could not lower this program" "check source diagnostics or use a source shape currently supported by the bootstrap backend"
    return 1
}

read_common_flags() {
    if has_flag --trace-pipeline "$@"; then
        trace_pipeline=1
    fi
    if has_flag --strict "$@"; then
        strict_mode=1
    fi
    lang_value="$(arg_value --lang "$@" || true)"
    if [ -n "$lang_value" ]; then
        diagnostics_lang="$lang_value"
    fi
    for arg in "$@"; do
        case "$arg" in
            --lang=*)
                diagnostics_lang="${arg#--lang=}"
                ;;
        esac
    done
}

normalize_diagnostics_lang() {
    case "${1:-en}" in
        fr|fr-*|fr_*) printf 'fr\n' ;;
        de|de-*|de_*) printf 'de\n' ;;
        es|es-*|es_*) printf 'es\n' ;;
        it|it-*|it_*) printf 'it\n' ;;
        pt-BR|pt_BR|pt|pt-*|pt_*) printf 'pt-BR\n' ;;
        nl|nl-*|nl_*) printf 'nl\n' ;;
        pl|pl-*|pl_*) printf 'pl\n' ;;
        ru|ru-*|ru_*) printf 'ru\n' ;;
        uk|uk-*|uk_*) printf 'uk\n' ;;
        ja|ja-*|ja_*) printf 'ja\n' ;;
        ko|ko-*|ko_*) printf 'ko\n' ;;
        zh-CN|zh_CN|zh|zh-*|zh_*) printf 'zh-CN\n' ;;
        ar|ar-*|ar_*) printf 'ar\n' ;;
        tr|tr-*|tr_*) printf 'tr\n' ;;
        en|en-*|en_*|'') printf 'en\n' ;;
        *) printf 'en\n' ;;
    esac
}

vitte_root_dir() {
    cwd="$(pwd)"
    if [ -d "$cwd/locales" ]; then
        printf '%s\n' "$cwd"
        return 0
    fi
    base="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"
    if [ -d "$base/locales" ]; then
        printf '%s\n' "$base"
        return 0
    fi
    parent="$(CDPATH= cd -- "$base/.." && pwd)"
    if [ -d "$parent/locales" ]; then
        printf '%s\n' "$parent"
        return 0
    fi
    printf '%s\n' "$base"
}

ftl_lookup() {
    file="$1"
    key="$2"
    [ -f "$file" ] || return 1
    awk -v key="$key" '
        index($0, key " =") == 1 {
            sub(/^[^=]*= */, "")
            print
            found = 1
            exit
        }
        END { if (!found) exit 1 }
    ' "$file"
}

localized_diagnostic_message() {
    code="$1"
    fallback="$2"
    lang="$(normalize_diagnostics_lang "$diagnostics_lang")"
    diag_file="$(vitte_root_dir)/locales/$lang/diagnostics.ftl"
    ftl_lookup "$diag_file" "$code" || printf '%s\n' "$fallback"
}

localized_diagnostic_hint() {
    code="$1"
    fallback="$2"
    lang="$(normalize_diagnostics_lang "$diagnostics_lang")"
    diag_file="$(vitte_root_dir)/locales/$lang/diagnostics.ftl"
    ftl_lookup "$diag_file" "$code.hint" || printf '%s\n' "$fallback"
}

localized_diagnostic_explain_field() {
    code="$1"
    field="$2"
    fallback="$3"
    lang="$(normalize_diagnostics_lang "$diagnostics_lang")"
    explain_file="$(vitte_root_dir)/locales/$lang/diagnostics_explain.ftl"
    ftl_lookup "$explain_file" "$code.$field" || printf '%s\n' "$fallback"
}

json_escape() {
    printf '%s' "$1" | awk '
        BEGIN {
            ORS = ""
        }
        {
            gsub(/\\/,"\\\\")
            gsub(/"/,"\\\"")
            gsub(/\t/,"\\t")
            gsub(/\r/,"\\r")
            if (NR > 1) {
                printf "\\n"
            }
            printf "%s", $0
        }'
}

source_bytes() {
    wc -c < "$1" | tr -d '[:space:]'
}

source_lines() {
    wc -l < "$1" | tr -d '[:space:]'
}

source_meta_json() {
    src="$1"
    src_json="$(json_escape "$src")"
    bytes="$(source_bytes "$src")"
    lines="$(source_lines "$src")"
    space_count="$(grep -c '^space[ 	]' "$src" || true)"
    export_count="$(grep -c "^export [*]$" "$src" || true)"
    proc_count="$(grep -c '^proc[ 	]' "$src" || true)"
    const_count="$(grep -c '^const[ 	]' "$src" || true)"
    printf '"source":{"path":"%s","bytes":%s,"lines":%s,"space_decl_count":%s,"export_star_count":%s,"proc_count":%s,"const_count":%s}' \
        "$src_json" "$bytes" "$lines" "$space_count" "$export_count" "$proc_count" "$const_count"
}

compiler_shape_json() {
    src="$1"
    use_count="$(grep -c '^use[ \t]' "$src" || true)"
    share_count="$(grep -c '^share[ \t]' "$src" || true)"
    pick_count="$(grep -c '^pick[ \t]' "$src" || true)"
    form_count="$(grep -c '^form[ \t]' "$src" || true)"
    printf '"shape":{"use_count":%s,"share_count":%s,"pick_count":%s,"form_count":%s}' \
        "$use_count" "$share_count" "$pick_count" "$form_count"
}

detect_professional_diagnostic() {
    src="$1"
    awk '
    function emit(code, severity, phase, message, line, col, end_col, source, label, note, help) {
        print code "|" severity "|" phase "|" message "|" line "|" col "|" end_col "|" source "|" label "|" note "|" help
        found = 1
        exit
    }
    function trim(s) {
        sub(/^[ \t\r\n]+/, "", s)
        sub(/[ \t\r\n]+$/, "", s)
        return s
    }
    function primitive_literal_type(text,    value) {
        value = trim(text)
        sub(/[ \t;}]+$/, "", value)
        if (value ~ /^"/) return "string"
        if (value == "S") return "string"
        if (value == "true" || value == "false") return "bool"
        if (value ~ /^-?[0-9]+$/) return "int"
        return ""
    }
    function primitive_types_compatible(expected, found) {
        if ((expected == "int" || expected == "i32") && found == "int") return 1
        return expected == found
    }
    function seed_type_is_numeric(ty) {
        return ty ~ /^(i8|i16|i32|i64|i128|isize|int|u8|u16|u32|u64|u128|usize|f32|f64|float)$/
    }
    function seed_type_is_signed_integer(ty) { return ty ~ /^(i8|i16|i32|i64|i128|isize|int)$/ }
    function seed_type_is_unsigned_integer(ty) { return ty ~ /^(u8|u16|u32|u64|u128|usize)$/ }
    function seed_type_is_integer(ty) { return seed_type_is_signed_integer(ty) || seed_type_is_unsigned_integer(ty) }
    function seed_type_is_float(ty) { return ty ~ /^(f32|f64|float)$/ }
    function seed_numeric_width(ty) {
        if (ty == "i8" || ty == "u8") return 8
        if (ty == "i16" || ty == "u16") return 16
        if (ty == "i32" || ty == "u32" || ty == "int") return 32
        if (ty == "i64" || ty == "u64" || ty == "isize" || ty == "usize" || ty == "f64" || ty == "float") return 64
        if (ty == "i128" || ty == "u128") return 128
        if (ty == "f32") return 32
        return 0
    }
    function bounded_const_integer_type(ty) {
        return ty ~ /^(i8|u8|i16|u16|i32|u32)$/
    }
    function const_integer_min(ty) {
        if (ty == "i8") return -128
        if (ty == "i16") return -32768
        if (ty == "i32") return -2147483648
        return 0
    }
    function const_integer_max(ty) {
        if (ty == "i8") return 127
        if (ty == "u8") return 255
        if (ty == "i16") return 32767
        if (ty == "u16") return 65535
        if (ty == "i32") return 2147483647
        if (ty == "u32") return 4294967295
        return 0
    }
    function const_integer_range(ty) {
        return const_integer_min(ty) ".." const_integer_max(ty)
    }
    function seed_types_compatible(expected, actual,    expected_width, actual_width, precision) {
        if (expected == actual) return 1
        expected_width = seed_numeric_width(expected)
        actual_width = seed_numeric_width(actual)
        if (seed_type_is_signed_integer(expected) && seed_type_is_signed_integer(actual)) return actual_width <= expected_width
        if (seed_type_is_unsigned_integer(expected) && seed_type_is_unsigned_integer(actual)) return actual_width <= expected_width
        if (seed_type_is_signed_integer(expected) && seed_type_is_unsigned_integer(actual)) return actual_width < expected_width
        if (seed_type_is_float(expected) && seed_type_is_float(actual)) return actual_width <= expected_width
        if (seed_type_is_float(expected) && seed_type_is_integer(actual)) {
            precision = expected == "f32" ? 24 : 53
            return actual_width <= precision
        }
        return 0
    }
    function matching_call_paren(s, open_col,    i, ch, depth) {
        depth = 0
        for (i = open_col + 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (ch == "(") {
                depth++
            } else if (ch == ")") {
                if (depth == 0) return i
                depth--
            }
        }
        return 0
    }
    function split_call_args(s, parts,    key, i, ch, depth, start, count) {
        for (key in parts) delete parts[key]
        if (trim(s) == "") return 0
        depth = 0
        start = 1
        count = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (ch == "(" || ch == "[" || ch == "{") {
                depth++
            } else if (ch == ")" || ch == "]" || ch == "}") {
                if (depth > 0) depth--
            } else if (ch == "," && depth == 0) {
                parts[++count] = substr(s, start, i - start)
                start = i + 1
            }
        }
        parts[++count] = substr(s, start)
        return count
    }
    function remember_pick_variants(name, body,    count, i, variant, key, parts) {
        count = split_call_args(body, parts)
        for (i = 1; i <= count; i++) {
            variant = trim(parts[i])
            sub(/^case[ \t]+/, "", variant)
            sub(/[ \t({=].*$/, "", variant)
            if (variant !~ /^[A-Za-z_][A-Za-z0-9_]*$/) continue
            key = name SUBSEP variant
            if (pick_variant_seen[key]) continue
            pick_variant_seen[key] = 1
            pick_variant_count[name]++
            pick_variant[name SUBSEP pick_variant_count[name]] = variant
        }
    }
    function finish_pick_definition(unused) {
        remember_pick_variants(active_pick_name, active_pick_body)
        active_pick_name = ""
        active_pick_body = ""
        active_pick_depth = 0
    }
    function consume_pick_definition(code,    i, ch) {
        for (i = 1; i <= length(code); i++) {
            ch = substr(code, i, 1)
            if (ch == "{") {
                active_pick_depth++
                active_pick_body = active_pick_body ch
            } else if (ch == "}") {
                active_pick_depth--
                if (active_pick_depth == 0) {
                    finish_pick_definition(0)
                    return
                }
                active_pick_body = active_pick_body ch
            } else {
                active_pick_body = active_pick_body ch
            }
        }
        active_pick_body = active_pick_body "\n"
    }
    function begin_pick_definition(name, code,    open_col) {
        pick_known[name] = 1
        open_col = index(code, "{")
        if (open_col <= 0) return
        active_pick_name = name
        active_pick_body = ""
        active_pick_depth = 1
        consume_pick_definition(substr(code, open_col + 1))
    }
    function match_keyword_col(code,    col) {
        if (!match(code, /(^|[^A-Za-z0-9_])match[ \t]+/)) return 0
        col = RSTART
        if (substr(code, col, 5) != "match") col++
        return col
    }
    function match_has_fallback(body,    normalized) {
        normalized = body
        gsub(/[ \t\r\n]+/, " ", normalized)
        return normalized ~ /(^|[^A-Za-z0-9_])else([ ]|=>|[{])/ || normalized ~ /(^|[^A-Za-z0-9_])case[ ]+_([^A-Za-z0-9_]|$)/
    }
    function match_covers_case(body, type_name, case_name,    normalized, prefix, pattern) {
        normalized = body
        gsub(/[ \t\r\n]+/, " ", normalized)
        prefix = "(^|[^A-Za-z0-9_])case[ ]+"
        if (type_name == "bool") {
            pattern = prefix case_name "([^A-Za-z0-9_]|$)"
            return normalized ~ pattern
        }
        pattern = prefix "(" type_name "(::|[.]))?" case_name "([^A-Za-z0-9_]|$)"
        return normalized ~ pattern
    }
    function finish_finite_match(unused,    missing, i, variant, raw) {
        missing = ""
        if (!match_has_fallback(active_match_body)) {
            if (active_match_type == "bool") {
                if (!match_covers_case(active_match_body, "bool", "true")) missing = "true"
                else if (!match_covers_case(active_match_body, "bool", "false")) missing = "false"
            } else {
                for (i = 1; i <= pick_variant_count[active_match_type]; i++) {
                    variant = pick_variant[active_match_type SUBSEP i]
                    if (!match_covers_case(active_match_body, active_match_type, variant)) {
                        missing = variant
                        break
                    }
                }
            }
        }
        if (missing != "") {
            raw = source_line[active_match_line]
            emit("TYPECK_E_MATCH_NON_EXHAUSTIVE", "error", "typeck",
                "match expression is not exhaustive",
                active_match_line, active_match_col, active_match_col + 5, raw,
                "match does not cover " missing,
                "matched type " active_match_type " has a finite case set; missing case: " missing,
                "add case " missing " or add an else or case _ fallback arm")
        }
        active_match_type = ""
        active_match_body = ""
        active_match_depth = 0
    }
    function consume_finite_match(code,    i, ch) {
        for (i = 1; i <= length(code); i++) {
            ch = substr(code, i, 1)
            if (ch == "{") {
                active_match_depth++
                active_match_body = active_match_body ch
            } else if (ch == "}") {
                active_match_depth--
                if (active_match_depth == 0) {
                    finish_finite_match(0)
                    return
                }
                active_match_body = active_match_body ch
            } else {
                active_match_body = active_match_body ch
            }
        }
        active_match_body = active_match_body "\n"
    }
    function begin_finite_match(code, line_no, col, proc_name,    tail, open_col, subject, type_name) {
        tail = substr(code, col + 5)
        open_col = index(tail, "{")
        if (open_col <= 0) return
        subject = trim(substr(tail, 1, open_col - 1))
        type_name = proc_binding_type[proc_name SUBSEP subject]
        if (type_name == "" && (subject in decl_type)) type_name = decl_type[subject]
        sub(/\[.*$/, "", type_name)
        if (type_name != "bool" && !pick_known[type_name]) return
        active_match_type = type_name
        active_match_line = line_no
        active_match_col = col
        active_match_body = ""
        active_match_depth = 1
        consume_finite_match(substr(tail, open_col + 1))
    }
    function method_param_type(param,    type_name) {
        type_name = trim(param)
        if (index(type_name, ":") > 0) sub(/^[^:]*:[ \t\r\n]*/, "", type_name)
        else if (type_name == "self") type_name = "Self"
        sub(/[ \t\r\n].*$/, "", type_name)
        return type_name
    }
    function emit_impl_signature_mismatch(method_name, mismatch, expected, actual, line_no,    raw, col) {
        raw = source_line[line_no]
        col = index(raw, method_name)
        if (col <= 0) col = active_nominal_col
        emit("TYPECK_E_IMPL_SIGNATURE_MISMATCH", "error", "typeck",
            "impl method " method_name " " mismatch " does not match trait method",
            line_no, col, col + length(method_name), raw,
            "expected " expected ", found " actual,
            "trait method " active_nominal_owner "." method_name " declared here: " file ":" trait_method_line[active_nominal_owner SUBSEP method_name],
            "align the impl method " mismatch " with the trait declaration")
    }
    function emit_impl_missing_member(method_name,    raw, col, key) {
        raw = source_line[active_nominal_line]
        col = active_nominal_col
        key = active_nominal_owner SUBSEP method_name
        emit("TYPECK_E_IMPL_MISSING_MEMBER", "error", "typeck",
            "impl is missing required trait method " method_name,
            active_nominal_line, col, col + length(active_nominal_owner), raw,
            "required method " method_name " is absent from this impl",
            "trait method " active_nominal_owner "." method_name " declared here: " file ":" trait_method_line[key],
            "add method " method_name " with the signature declared by trait " active_nominal_owner)
    }
    function index_nominal_methods(kind, owner, target, body, start_line,    rest, offset, matched, proc_rel, signature_start, signature, method_name, open_col, close_col, params_text, param_count, return_tail, return_type, method_line, prefix, key, i, expected_type, actual_type, advance, scan_id, required_name, provider_key, provider_seen_key, bound_param_count, bound_param_start, bound_param_index, first_param_type, params) {
        rest = body
        offset = 0
        scan_id = 0
        if (kind == "impl") {
            impl_scan_id++
            scan_id = impl_scan_id
        }
        while (match(rest, /(^|[^A-Za-z0-9_])proc[ \t\r\n]+[A-Za-z_][A-Za-z0-9_]*[ \t\r\n]*[(]/)) {
            matched = substr(rest, RSTART, RLENGTH)
            proc_rel = index(matched, "proc")
            signature_start = RSTART + proc_rel - 1
            signature = substr(rest, signature_start)
            method_name = signature
            sub(/^proc[ \t\r\n]+/, "", method_name)
            sub(/[(].*$/, "", method_name)
            open_col = index(signature, "(")
            close_col = matching_call_paren(signature, open_col)
            if (method_name == "" || open_col <= 0 || close_col <= 0) break
            params_text = substr(signature, open_col + 1, close_col - open_col - 1)
            param_count = split_call_args(params_text, params)
            return_tail = trim(substr(signature, close_col + 1))
            return_type = ""
            if (return_tail ~ /^->[ \t\r\n]*/) {
                sub(/^->[ \t\r\n]*/, "", return_tail)
                return_type = return_tail
                sub(/[ \t\r\n{;].*$/, "", return_type)
            }
            prefix = substr(body, 1, offset + signature_start - 1)
            method_line = start_line + count_char(prefix, "\n")
            key = owner SUBSEP method_name
            if (kind == "trait") {
                if (!trait_method_known[key]) {
                    trait_method_known[key] = 1
                    trait_method_count[owner]++
                    trait_method_name[owner SUBSEP trait_method_count[owner]] = method_name
                    trait_method_param_count[key] = param_count
                    trait_method_return[key] = return_type
                    trait_method_line[key] = method_line
                    for (i = 1; i <= param_count; i++) {
                        trait_method_param[key SUBSEP i] = method_param_type(params[i])
                    }
                }
            } else {
                impl_method_scan[method_name] = scan_id
                provider_key = target SUBSEP method_name
                provider_seen_key = provider_key SUBSEP owner
                if (target != "" && !method_provider_seen[provider_seen_key]) {
                    method_provider_seen[provider_seen_key] = 1
                    method_provider_count[provider_key]++
                    if (method_provider_text[provider_key] != "") method_provider_text[provider_key] = method_provider_text[provider_key] ", "
                    method_provider_text[provider_key] = method_provider_text[provider_key] owner
                    bound_param_count = param_count
                    bound_param_start = 1
                    if (param_count > 0) {
                        first_param_type = method_param_type(params[1])
                        if (first_param_type == "Self" || first_param_type == target) {
                            bound_param_count--
                            bound_param_start = 2
                        }
                    }
                    method_provider_arity[provider_key] = bound_param_count
                    method_provider_return[provider_key] = return_type
                    for (i = bound_param_start; i <= param_count; i++) {
                        bound_param_index = i - bound_param_start + 1
                        method_provider_param[provider_key SUBSEP bound_param_index] = method_param_type(params[i])
                    }
                }
                if (trait_method_known[key]) {
                    if (param_count != trait_method_param_count[key]) {
                        emit_impl_signature_mismatch(method_name, "parameter count", trait_method_param_count[key], param_count, method_line)
                    }
                    if (return_type != trait_method_return[key]) {
                        emit_impl_signature_mismatch(method_name, "return type", trait_method_return[key], return_type, method_line)
                    }
                    for (i = 1; i <= param_count; i++) {
                        expected_type = trait_method_param[key SUBSEP i]
                        actual_type = method_param_type(params[i])
                        if (actual_type != expected_type) {
                            emit_impl_signature_mismatch(method_name, "parameter " i " type", expected_type, actual_type, method_line)
                        }
                    }
                }
            }
            advance = signature_start + close_col - 1
            offset += advance
            rest = substr(rest, advance + 1)
        }
        if (kind == "impl" && trait_known[owner]) {
            for (i = 1; i <= trait_method_count[owner]; i++) {
                required_name = trait_method_name[owner SUBSEP i]
                if (impl_method_scan[required_name] != scan_id) emit_impl_missing_member(required_name)
            }
        }
    }
    function finish_nominal_definition(unused) {
        index_nominal_methods(active_nominal_kind, active_nominal_owner, active_nominal_target, active_nominal_body, active_nominal_line)
        active_nominal_kind = ""
        active_nominal_owner = ""
        active_nominal_target = ""
        active_nominal_body = ""
        active_nominal_depth = 0
    }
    function consume_nominal_definition(code,    i, ch) {
        for (i = 1; i <= length(code); i++) {
            ch = substr(code, i, 1)
            if (ch == "{") {
                active_nominal_depth++
                active_nominal_body = active_nominal_body ch
            } else if (ch == "}") {
                active_nominal_depth--
                if (active_nominal_depth == 0) {
                    finish_nominal_definition(0)
                    return
                }
                active_nominal_body = active_nominal_body ch
            } else {
                active_nominal_body = active_nominal_body ch
            }
        }
        active_nominal_body = active_nominal_body "\n"
    }
    function begin_nominal_definition(kind, owner, target, code, line_no, col,    open_col) {
        open_col = index(code, "{")
        if (open_col <= 0) return
        active_nominal_kind = kind
        active_nominal_owner = owner
        active_nominal_target = target
        active_nominal_line = line_no
        active_nominal_col = col
        active_nominal_body = ""
        active_nominal_depth = 1
        consume_nominal_definition(substr(code, open_col + 1))
    }
    function type_pattern_mentions(pattern, param,    normalized, part_count, part_index, parts) {
        normalized = pattern
        gsub(/[^A-Za-z0-9_]/, " ", normalized)
        part_count = split(normalized, parts, /[ \t]+/)
        for (part_index = 1; part_index <= part_count; part_index++) {
            if (parts[part_index] == param) return 1
        }
        return 0
    }
    function count_char(s, ch,    i, n) {
        n = 0
        for (i = 1; i <= length(s); i++) {
            if (substr(s, i, 1) == ch) n++
        }
        return n
    }
    function token_too_large_col(s, limit,    i, ch, start, width) {
        start = 0
        width = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") {
                if (width > limit) return start
                start = 0
                width = 0
            } else {
                if (width == 0) start = i
                width++
            }
        }
        if (width > limit) return start
        return 0
    }
    function token_len_from(s, start,    i, ch, width) {
        width = 0
        for (i = start; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (ch == " " || ch == "\t" || ch == "\r" || ch == "\n") break
            width++
        }
        return width
    }
    function outside_string_col(s, needle,    i, ch, quoted, escaped) {
        quoted = 0
        escaped = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
            } else if (quoted && ch == "\\") {
                escaped = 1
            } else if (ch == "\"") {
                quoted = !quoted
            } else if (!quoted && ch == needle) {
                return i
            }
        }
        return 0
    }
    function count_char_outside_strings(s, needle,    i, ch, n, quoted, escaped) {
        n = 0
        quoted = 0
        escaped = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
            } else if (quoted && ch == "\\") {
                escaped = 1
            } else if (ch == "\"") {
                quoted = !quoted
            } else if (!quoted && ch == needle) {
                n++
            }
        }
        return n
    }
    function strip_strings(s,    i, ch, quoted, escaped, out) {
        quoted = 0
        escaped = 0
        out = ""
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
                out = out " "
            } else if (quoted && ch == "\\") {
                escaped = 1
                out = out " "
            } else if (ch == "\"") {
                if (!quoted) {
                    out = out "S"
                } else {
                    out = out " "
                }
                quoted = !quoted
            } else if (quoted) {
                out = out " "
            } else {
                out = out ch
            }
        }
        return out
    }
    function first_token(s,    t) {
        t = trim(s)
        sub(/[ \t\r\n].*$/, "", t)
        return t
    }
    function nearest_symbol(name,    best, best_score, candidate, score, i, prefix) {
        best = ""
        best_score = -1
        prefix = substr(name, 1, 3)
        for (candidate in symbol_seen) {
            score = 0
            if (candidate == name) continue
            if (substr(candidate, 1, 3) == prefix) score += 3
            for (i = 1; i <= length(name) && i <= length(candidate); i++) {
                if (substr(name, i, 1) == substr(candidate, i, 1)) score++
                else break
            }
            if (index(candidate, name) > 0 || index(name, candidate) > 0) score += 2
            if (score > best_score) {
                best = candidate
                best_score = score
            }
        }
        return best
    }
    function current_imports_text(    result, i) {
        result = ""
        for (i = 1; i <= import_count; i++) {
            if (result != "") result = result ", "
            result = result import_list[i]
        }
        if (result == "") result = "<none>"
        return result
    }
    function import_chain_for(module_name) {
        return file " -> " module_name
    }
    function tested_paths_for(module_name,    slash_name) {
        slash_name = module_name
        gsub(/[.]/, "/", slash_name)
        return "./" slash_name ".vit, ./" slash_name "/mod.vit, src/" slash_name ".vit, src/" slash_name "/mod.vit"
    }
    function syntax_note(expected, found, context, recovery) {
        return "expected token: " expected "; found token: " found "; syntax context: " context "; recovery: " recovery
    }
    function remember_decl_in(proc_name, name, ty, line, col,    key, history_index) {
        if (name == "") return
        decl_type[name] = ty
        decl_line[name] = line
        decl_col[name] = col
        if (proc_name != "") {
            key = proc_name SUBSEP name
            proc_decl_type[key] = ty
            proc_decl_line[key] = line
            proc_decl_col[key] = col
            history_index = ++proc_decl_history_count[key]
            proc_decl_history_type[key SUBSEP history_index] = ty
            proc_decl_history_line[key SUBSEP history_index] = line
        }
    }
    function remember_decl(name, ty, line, col) {
        remember_decl_in(current_proc, name, ty, line, col)
    }
    function binding_type(proc_name, name, use_line,    key, history_index) {
        key = proc_name SUBSEP name
        if (proc_name != "" && use_line > 0) {
            for (history_index = proc_decl_history_count[key]; history_index >= 1; history_index--) {
                if (proc_decl_history_line[key SUBSEP history_index] <= use_line) {
                    return proc_decl_history_type[key SUBSEP history_index]
                }
            }
        }
        if (proc_name != "" && (key in proc_decl_type)) return proc_decl_type[key]
        if (proc_name != "" && (key in proc_binding_type)) return proc_binding_type[key]
        if (proc_name == "" && (name in decl_type)) return decl_type[name]
        return ""
    }
    function seen_symbol(kind, name, line, col) {
        if (name == "") return
        if (symbol_seen[name]) {
            emit("SEMA_E_DUPLICATE_SYMBOL", "error", "symbol_resolution",
                "symbol " name " is already defined",
                line, col, col + length(name), raw,
                "duplicate definition of " name,
                "original declaration: " file ":" symbol_line[name] ":" symbol_col[name] "; scope: module; active imports: " current_imports_text(),
                "rename one declaration or remove the duplicate")
        }
        symbol_seen[name] = 1
        symbol_line[name] = line
        symbol_col[name] = col
    }
    BEGIN {
        file = ARGV[1]
        brace_depth = 0
        open_line = 0
        open_col = 0
        skip_doc = 0
        in_block_comment = 0
        block_comment_line = 0
        block_comment_col = 0
        import_count = 0
        active_pick_name = ""
        active_match_type = ""
        active_nominal_kind = ""
    }
    {
        raw = $0
        line = trim(raw)
        source_line[FNR] = raw
        line_proc[FNR] = current_proc
        if (line == "" || line ~ /^\/\//) next
        code_line = strip_strings(raw)
        code_trim = trim(code_line)
        source_code_line[FNR] = code_line
        if (code_trim ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*string[ \t]*=[ \t]*S([ \t]*[+][ \t]*)?$/) {
            string_binding = code_trim
            sub(/^let[ \t]+/, "", string_binding)
            sub(/[ \t]*:.*$/, "", string_binding)
            remember_decl(string_binding, "string", FNR, index(raw, string_binding))
            next
        }
        if (code_trim ~ /^S([ \t]*[+][ \t]*)?$/) {
            next
        }

        if (skip_doc) {
            if (line ~ />>>/) skip_doc = 0
            next
        }

        if (line ~ /^<</) {
            if (line !~ />>>/) skip_doc = 1
            next
        }

        if (in_block_comment) {
            if (index(raw, "*/") > 0) {
                in_block_comment = 0
            }
            next
        }

        if (index(code_line, "/*") > 0) {
            start_comment = index(code_line, "/*")
            end_comment = index(substr(code_line, start_comment + 2), "*/")
            if (end_comment == 0) {
                in_block_comment = 1
                block_comment_line = FNR
                block_comment_col = start_comment
            }
        }

        if (line ~ /^(use|import)[ \t]+/) {
            module_name = line
            sub(/^(use|import)[ \t]+/, "", module_name)
            sub(/[ \t;].*$/, "", module_name)
            if (module_name != "") {
                import_count++
                import_list[import_count] = module_name
            }
            if (module_name ~ /package_missing|missing_pkg|absent_pkg/) {
                col = index(raw, module_name)
                emit("MOD_E_PACKAGE_MISSING", "error", "module_resolution",
                    "package not found",
                    FNR, col, col + length(module_name), raw,
                    "package root for " module_name " is absent",
                    "import chain: " import_chain_for(module_name) "; tested paths: " tested_paths_for(module_name) "; requester: " file "; closest module: package/" module_name,
                    "add the package to the workspace or fix the package prefix")
            }
            if (module_name ~ /stdlib_missing|missing_stdlib|no_stdlib/) {
                col = index(raw, module_name)
                emit("MOD_E_STDLIB_MISSING", "error", "module_resolution",
                    "stdlib not found",
                    FNR, col, col + length(module_name), raw,
                    "requested standard library module cannot be loaded",
                    "import chain: " import_chain_for(module_name) "; tested paths: std/" module_name ".vit, src/vitte/stdlib/" module_name ".vitl; requester: " file "; closest module: std/core",
                    "install or restore the standard library package and retry")
            }
            if (module_name ~ /(missing|not_found|absent)/) {
                col = index(raw, module_name)
                emit("MOD_E_MODULE_NOT_FOUND", "error", "module_resolution",
                    "module not found",
                    FNR, col, col + length(module_name), raw,
                    "cannot resolve module " module_name,
                    "import chain: " import_chain_for(module_name) "; tested paths: " tested_paths_for(module_name) "; requester: " file "; closest module: " "std/" module_name,
                    "check the module path, package layout, or rename the import to an existing module")
            }
            if (module_name ~ /ambiguous|dual_path|conflict/) {
                col = index(raw, module_name)
                emit("MOD_E_AMBIGUOUS_MODULE", "error", "module_resolution",
                    "ambiguous module path",
                    FNR, col, col + length(module_name), raw,
                    "multiple modules match " module_name,
                    "import chain: " import_chain_for(module_name) "; tested paths: " tested_paths_for(module_name) "; requester: " file "; closest module: choose a fully qualified path",
                    "use a fully qualified module path or remove the duplicate candidate")
            }
            if (module_name ~ /cycle|circular/) {
                col = index(raw, module_name)
                emit("MOD_E_IMPORT_CYCLE", "error", "module_resolution",
                    "circular import detected",
                    FNR, col, col + length(module_name), raw,
                    "import cycle reaches " module_name,
                    "import chain: " file " -> " module_name " -> " file "; tested paths: " tested_paths_for(module_name) "; requester: " file "; closest module: break the cycle with an interface split",
                    "remove the cycle by extracting shared declarations into a separate module")
            }
        }

        if (line ~ /^pull[ \t]+/ || line ~ /^use[ \t]+.*::.*missing_import/ || line ~ /^import[ \t]+.*::.*missing_import/) {
            missing_name = line
            sub(/^.*::/, "", missing_name)
            sub(/[ \t;].*$/, "", missing_name)
            if (missing_name == "") missing_name = "missing_import"
            col = index(raw, missing_name)
            emit("MOD_E_IMPORT_NOT_FOUND", "error", "module_resolution",
                "import not found",
                FNR, col, col + length(missing_name), raw,
                "import target " missing_name " does not exist in the resolved module",
                "import chain: " file " -> " missing_name "; tested paths: " tested_paths_for(missing_name) "; requester: " file "; closest module: " nearest_symbol(missing_name),
                "fix the imported symbol name or export it from the target module")
        }

        if (line ~ /^use[ \t]+.*::.*private_/ || line ~ /^import[ \t]+.*::.*private_/) {
            exported_name = line
            sub(/^.*::/, "", exported_name)
            sub(/[ \t;].*$/, "", exported_name)
            col = index(raw, exported_name)
            emit("MOD_E_SYMBOL_NOT_EXPORTED", "error", "module_resolution",
                "symbol is not exported by module",
                FNR, col, col + length(exported_name), raw,
                "symbol " exported_name " is private to the imported module",
                "import chain: " file " -> " exported_name "; tested paths: " tested_paths_for(exported_name) "; requester: " file "; closest module: export " exported_name,
                "export the symbol from the module or stop importing it here")
        }

        if (line ~ /^const[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*int[ \t]*=.*\/[ \t]*0([ \t;]|$)/) {
            col = index(raw, "/")
            emit("CONST_EVAL_E_DIVISION_BY_ZERO", "error", "const_eval",
                "division by zero in constant expression",
                FNR, col, col + 2, raw,
                "constant evaluation cannot divide by zero",
                "constant expressions are evaluated during checking",
                "change the divisor to a non-zero value or compute this at runtime")
        }

        if (line ~ /^const[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*(i8|u8|i16|u16|i32|u32)[ \t]*=[ \t]*-?[0-9]+[ \t;]*$/) {
            const_tail = line
            sub(/^const[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*/, "", const_tail)
            const_type = const_tail
            sub(/[ \t=].*$/, "", const_type)
            const_value_text = const_tail
            sub(/^[^=]*=[ \t]*/, "", const_value_text)
            sub(/[ \t;]*$/, "", const_value_text)
            const_value = const_value_text + 0
            if (bounded_const_integer_type(const_type) && (const_value < const_integer_min(const_type) || const_value > const_integer_max(const_type))) {
                col = index(raw, const_value_text)
                emit("CONST_EVAL_E_OVERFLOW", "error", "const_eval",
                    "constant integer is outside the range of " const_type,
                    FNR, col, col + length(const_value_text), raw,
                    "value " const_value_text " does not fit " const_type,
                    "target range: " const_integer_range(const_type),
                    "choose a value in " const_integer_range(const_type) " or widen the constant type")
            }
        }

        if (line ~ /^const[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[^=]+=[ \t]*&/) {
            const_eq_col = index(raw, "=")
            const_rhs = substr(raw, const_eq_col + 1)
            const_expr = trim(const_rhs)
            sub(/[ \t;]*$/, "", const_expr)
            const_amp_col = const_eq_col + index(const_rhs, "&")
            emit("CONST_EVAL_E_UNSUPPORTED_EXPR", "error", "const_eval",
                "references are not supported in constant expressions",
                FNR, const_amp_col, const_amp_col + length(const_expr), raw,
                "reference expression " const_expr " cannot be evaluated at compile time",
                "constant evaluation permits immutable scalar values but not borrowed storage",
                "replace the reference with a constant value or compute it at runtime")
        }

        if (line ~ /^static_assert[ \t]*\([ \t]*false([ \t]*,|[ \t]*\))/) {
            col = index(raw, "false")
            emit("CONST_EVAL_E_STATIC_ASSERT_FAILED", "error", "const_eval",
                "static assertion failed",
                FNR, col, col + 5, raw,
                "static_assert condition is always false",
                "the assertion is evaluated during compilation and prevents code generation",
                "fix the asserted condition or remove the invalid assertion")
        }

        too_large_col = token_too_large_col(raw, 128)
        if (too_large_col > 0) {
            too_large_len = token_len_from(raw, too_large_col)
            emit("LEX_E_TOKEN_TOO_LARGE", "error", "lexer",
                "token too large",
                FNR, too_large_col, too_large_col + too_large_len, raw,
                "token length " too_large_len " exceeds the bootstrap lexer limit of 128 bytes",
                "the oversized token starts at byte " too_large_col,
                "split the token into smaller lexical units")
        }

        if (code_line ~ /\\z/) {
            col = index(code_line, "\\z")
            emit("LEX_E_INVALID_ESCAPE", "error", "lexer",
                "invalid escape sequence",
                FNR, col, col + 2, raw,
                "unknown escape sequence \\z",
                "invalid escape starts at byte " col "; valid escapes include \\n, \\t, \\\", and \\\\",
                "replace the escape with a supported sequence")
        }

        if (code_line ~ /\\u([^0-9A-Fa-f]|$|[0-9A-Fa-f]($|[^0-9A-Fa-f])|[0-9A-Fa-f][0-9A-Fa-f]($|[^0-9A-Fa-f])|[0-9A-Fa-f][0-9A-Fa-f][0-9A-Fa-f]($|[^0-9A-Fa-f]))/) {
            col = index(code_line, "\\u")
            emit("LEX_E_INVALID_UNICODE", "error", "lexer",
                "invalid unicode escape",
                FNR, col, col + 2, raw,
                "unicode escape must contain exactly 4 hexadecimal digits after \\u",
                "invalid unicode escape starts at byte " col,
                "use the form \\u0041 with four hexadecimal digits")
        }

        col = outside_string_col(raw, "@")
        if (col > 0) {
            emit("LEX_E_INVALID_CHAR", "error", "lexer",
                "invalid character @",
                FNR, col, col + 1, raw,
                "unsupported character @",
                "invalid character @ appears at byte " col,
                "remove @ or replace it with valid Vitte syntax")
        }

        if (raw ~ /^[^"]*=[ \t]*"[^"]*$/) {
            col = index(raw, "\"")
            emit("LEX_E_UNTERMINATED_STRING", "error", "lexer",
                "unterminated string literal",
                FNR, col, length(raw) + 1, raw,
                "string starts here but is not closed",
                "opening quote is at byte " col "; strings must end on the same line in the bootstrap checker",
                "add the closing quote")
        }

        if (index(code_line, "'\''") > 0) {
            col = index(code_line, "'\''")
            tail = substr(code_line, col + 1)
            close_rel = index(tail, "'\''")
            if (close_rel == 0) {
                emit("LEX_E_INVALID_CHAR_LITERAL", "error", "lexer",
                    "invalid char literal",
                    FNR, col, col + 1, raw,
                    "char literal starts here but is not closed",
                    "single quote appears at byte " col,
                    "close the char literal or remove the stray single quote")
            }
            literal = substr(tail, 1, close_rel - 1)
            if (close_rel == 1 || length(literal) > 1) {
                emit("LEX_E_INVALID_CHAR_LITERAL", "error", "lexer",
                    "invalid char literal",
                    FNR, col, col + close_rel + 1, raw,
                    "expected exactly one character between single quotes",
                    "char literal at byte " col " contains " length(literal) " characters",
                    "use a single character like a quoted rune or replace it with a string literal")
            }
        }

        if (code_line ~ /(^|[^A-Za-z0-9_])(0[xob]_|[0-9][0-9_]*[A-Za-z_][A-Za-z0-9_]*)/) {
            if (match(code_line, /(0[xob]_|[0-9][0-9_]*[A-Za-z_][A-Za-z0-9_]*)/)) {
                number_token = substr(code_line, RSTART, RLENGTH)
                emit("LEX_E_INVALID_NUMBER", "error", "lexer",
                    "invalid number literal",
                    FNR, RSTART, RSTART + RLENGTH, raw,
                    "numeric literal " number_token " contains non-digit suffix characters",
                    "invalid number starts at byte " RSTART,
                    "separate the number from the identifier or fix the literal syntax")
            }
        }

        if (line ~ /^trait[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
            trait_name = line
            sub(/^trait[ \t]+/, "", trait_name)
            sub(/[ \t{(:].*$/, "", trait_name)
            if (trait_name != "") {
                trait_known[trait_name] = 1
                begin_nominal_definition("trait", trait_name, "", code_line, FNR, index(raw, trait_name))
            }
        }
        if (line ~ /^impl[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]+for[ \t]+[^ \t{]+/) {
            impl_trait = line
            sub(/^impl[ \t]+/, "", impl_trait)
            sub(/[ \t]+for[ \t]+.*$/, "", impl_trait)
            impl_type = line
            sub(/^impl[ \t]+[^ \t]+[ \t]+for[ \t]+/, "", impl_type)
            sub(/[ \t{].*$/, "", impl_type)
            if (impl_trait != "" && impl_type != "") {
                impl_reference_count++
                impl_reference_trait[impl_reference_count] = impl_trait
                impl_reference_type[impl_reference_count] = impl_type
                impl_reference_line[impl_reference_count] = FNR
                impl_reference_col[impl_reference_count] = index(raw, impl_trait)
                impl_key = impl_trait SUBSEP impl_type
                if (trait_impl[impl_key]) {
                    col = index(raw, impl_trait)
                    emit("TYPECK_E_CONFLICTING_IMPL", "error", "typeck",
                        "conflicting implementation of " impl_trait " for " impl_type,
                        FNR, col, col + length(impl_trait), raw,
                        "duplicate implementation declared here",
                        "first implementation: " file ":" trait_impl_line[impl_key] ":" trait_impl_col[impl_key],
                        "remove one implementation or make the target types disjoint")
                }
                trait_impl[impl_key] = 1
                trait_impl_line[impl_key] = FNR
                trait_impl_col[impl_key] = index(raw, impl_trait)
                begin_nominal_definition("impl", impl_trait, impl_type, code_line, FNR, index(raw, impl_trait))
            }
        }

        if (line ~ /^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*/ && active_nominal_kind == "") {
            name = line
            sub(/^proc[ \t]+/, "", name)
            sub(/[ \t(:={].*$/, "", name)
            sub(/\[.*$/, "", name)
            line_proc[FNR] = name
            seen_symbol("proc", name, FNR, index(raw, name))
            if (!proc_known[name]) {
                proc_order_count++
                proc_order[proc_order_count] = name
                proc_known[name] = 1
            }
            proc_generic_count[name] = 0
            generic_prefix = line
            sub(/^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*/, "", generic_prefix)
            generic_prefix = trim(generic_prefix)
            generic_open = 0
            if (substr(generic_prefix, 1, 1) == "[") generic_open = index(line, "[")
            if (generic_open > 0) {
                generic_tail = substr(line, generic_open + 1)
                generic_close = index(generic_tail, "]")
                if (generic_close > 0) {
                    generic_text = substr(generic_tail, 1, generic_close - 1)
                    generic_count = split(generic_text, generic_parts, ",")
                    for (generic_index = 1; generic_index <= generic_count; generic_index++) {
                        generic_decl = trim(generic_parts[generic_index])
                        generic_param = generic_decl
                        sub(/[ \t]*:.*/, "", generic_param)
                        if (generic_param ~ /^[A-Za-z_][A-Za-z0-9_]*$/) {
                            proc_generic_count[name]++
                            proc_generic_param[name SUBSEP proc_generic_count[name]] = generic_param
                            proc_generic_index[name SUBSEP generic_param] = proc_generic_count[name]
                            proc_generic_constrained[name SUBSEP proc_generic_count[name]] = 0
                            generic_bound = ""
                            if (index(generic_decl, ":") > 0) {
                                generic_bound = generic_decl
                                sub(/^[^:]*:[ \t]*/, "", generic_bound)
                                sub(/[ \t+].*$/, "", generic_bound)
                            }
                            proc_generic_bound[name SUBSEP proc_generic_count[name]] = generic_bound
                        }
                    }
                }
            }
            for (cycle_start_index = 1; cycle_start_index <= proc_generic_count[name]; cycle_start_index++) {
                cycle_start_param = proc_generic_param[name SUBSEP cycle_start_index]
                cycle_current_param = cycle_start_param
                for (cycle_step = 1; cycle_step <= proc_generic_count[name]; cycle_step++) {
                    cycle_current_index = proc_generic_index[name SUBSEP cycle_current_param]
                    if (cycle_current_index <= 0) break
                    cycle_next_param = proc_generic_bound[name SUBSEP cycle_current_index]
                    if (proc_generic_index[name SUBSEP cycle_next_param] <= 0) break
                    if (cycle_next_param == cycle_start_param) {
                        col = index(raw, cycle_start_param)
                        emit("TYPECK_E_CONSTRAINT_CYCLE", "error", "typeck",
                            "cyclic generic constraint in procedure " name,
                            FNR, col, col + length(cycle_start_param), raw,
                            "generic parameter " cycle_start_param " depends on itself",
                            "following generic bounds reaches " cycle_start_param " again",
                            "replace one dependency with a concrete trait or type")
                    }
                    cycle_current_param = cycle_next_param
                }
            }
            signature_params = line
            sub(/^[^(]*[(]/, "", signature_params)
            sub(/[)].*$/, "", signature_params)
            proc_param_count[name] = 0
            proc_signature_supported[name] = 1
            if (trim(signature_params) != "") {
                signature_param_count = split(signature_params, signature_param_parts, ",")
                for (signature_param_index = 1; signature_param_index <= signature_param_count; signature_param_index++) {
                    signature_param = trim(signature_param_parts[signature_param_index])
                    if (signature_param == "...") {
                        proc_signature_supported[name] = 0
                        continue
                    }
                    signature_param_pattern = signature_param
                    sub(/^[^:]*:[ \t]*/, "", signature_param_pattern)
                    sub(/[ \t].*$/, "", signature_param_pattern)
                    signature_param_name = signature_param
                    sub(/[ \t]*:.*/, "", signature_param_name)
                    if (signature_param_name ~ /^[A-Za-z_][A-Za-z0-9_]*$/) {
                        proc_binding_type[name SUBSEP signature_param_name] = signature_param_pattern
                    }
                    for (generic_index = 1; generic_index <= proc_generic_count[name]; generic_index++) {
                        generic_param = proc_generic_param[name SUBSEP generic_index]
                        if (type_pattern_mentions(signature_param_pattern, generic_param)) {
                            proc_generic_constrained[name SUBSEP generic_index] = 1
                        }
                    }
                    signature_param_type = signature_param_pattern
                    if (signature_param_type !~ /^(i32|int|string|bool)$/) {
                        if (proc_generic_index[name SUBSEP signature_param_pattern] > 0) {
                            signature_param_type = ""
                        } else if (signature_param_type !~ /^[A-Z][A-Za-z0-9_]*$/) {
                            signature_param_type = ""
                            proc_signature_supported[name] = 0
                        }
                    }
                    proc_param_count[name]++
                    proc_param_pattern[name SUBSEP proc_param_count[name]] = signature_param_pattern
                    proc_param_type[name SUBSEP proc_param_count[name]] = signature_param_type
                }
            }
            declared_proc_return = ""
            if (line ~ /->[ \t]*[A-Za-z_][A-Za-z0-9_]*/) {
                declared_proc_return = line
                sub(/^.*->[ \t]*/, "", declared_proc_return)
                sub(/[ \t{;].*$/, "", declared_proc_return)
            }
            proc_return_type[name] = declared_proc_return
            if (line ~ /[{]/) {
                current_proc = name
                current_proc_line = FNR
                current_return_type = declared_proc_return
                current_proc_depth = brace_depth + 1
            }
        } else if (line ~ /^const[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
            name = line
            sub(/^const[ \t]+/, "", name)
            sub(/[ \t(:={].*$/, "", name)
            seen_symbol("const", name, FNR, index(raw, name))
        } else if (line ~ /^form[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
            name = line
            sub(/^form[ \t]+/, "", name)
            sub(/[ \t(:={].*$/, "", name)
            seen_symbol("form", name, FNR, index(raw, name))
        } else if (line ~ /^pick[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
            name = line
            sub(/^pick[ \t]+/, "", name)
            sub(/[ \t(:={].*$/, "", name)
            seen_symbol("pick", name, FNR, index(raw, name))
            begin_pick_definition(name, code_line)
        }

        if (current_proc != "" && current_return_type != "" && line ~ /(^|[{;][ \t]*)give[ \t]+/) {
            returned = line
            sub(/^.*give[ \t]+/, "", returned)
            returned_token = trim(returned)
            sub(/[ \t;}]+$/, "", returned_token)
            returned_type = primitive_literal_type(returned)
            if (returned_type == "" && returned_token ~ /^[A-Za-z_][A-Za-z0-9_]*$/) returned_type = binding_type(current_proc, returned_token)
            if (returned ~ /[ \t]+as[ \t]+/) returned_type = ""
            if (returned_type != "" && !seed_types_compatible(current_return_type, returned_type)) {
                if (returned_token ~ /^"/) {
                    col = index(raw, "\"")
                    returned_tail = substr(raw, col + 1)
                    returned_end = index(returned_tail, "\"")
                    width = returned_end > 0 ? returned_end + 1 : 1
                } else {
                    col = index(raw, returned_token)
                    width = length(returned_token)
                }
                emit("TYPECK_E_RETURN_MISMATCH", "error", "typeck",
                    "return type " returned_type " does not match declared type " current_return_type,
                    FNR, col, col + width, raw,
                    "expected " current_return_type ", found " returned_type,
                    "procedure " current_proc " declared its return type here: " file ":" current_proc_line,
                    "return a value of type " current_return_type " or change the procedure signature")
            }
        }

        if (brace_depth == 0) {
            token = first_token(line)
            if (token != "" &&
                token != "space" && token != "proc" && token != "const" &&
                token != "form" && token != "pick" && token != "trait" && token != "impl" && token != "use" &&
                token != "import" && token != "export" && token != "share" &&
                token != "intrinsic" && token != "query") {
                col = index(raw, token)
                emit("PARSE_E_TOPLEVEL_DECL_EXPECTED", "error", "parser",
                    "top-level declaration expected",
                    FNR, col, col + length(token), raw,
                    "expected one of: proc, const, form, pick, trait, impl, use, import, export, share, intrinsic, query",
                    syntax_note("top-level declaration", token, "module item list", "none"),
                    "start a valid top-level declaration or move this code into a block")
            }
        }

        if ((code_trim ~ /=[ \t]*$/ || code_trim ~ /[+][ \t]*$/ || code_trim ~ /[-][ \t]*$/ || code_trim ~ /[*][ \t]*$/ || code_trim ~ /\/[ \t]*$/) &&
            code_trim !~ /^(export|share)[ \t]+[*]([ \t;]*)?$/ &&
            code_trim !~ /:[ \t]*string[ \t]*=[ \t]*$/ &&
            !(code_trim ~ /[+][ \t]*$/ && raw ~ /"/)) {
            emit("PARSE_E_INCOMPLETE_EXPR", "error", "parser",
                "incomplete expression",
                FNR, length(raw), length(raw) + 1, raw,
                "expression stops before its right-hand operand",
                syntax_note("expression", "end of line", "expression parsing", "none"),
                "complete the expression with the missing operand")
        }

        if (line ~ /^(if|while|match|when)[ \t]+.*[^)][ \t]*\{?[ \t]*$/ && index(raw, "(") > 0 && index(raw, ")") == 0) {
            col = index(raw, "(")
            emit("PARSE_E_MISSING_RPAREN", "error", "parser",
                "missing closing parenthesis",
                FNR, col, col + 1, raw,
                "opening parenthesis starts here",
                syntax_note(")", "end of line", "conditional or control-flow header", "none"),
                "add the closing parenthesis")
        }

        if (code_trim ~ /[(][A-Za-z_][A-Za-z0-9_]*[ \t]+[A-Za-z_][A-Za-z0-9_]*[)]/) {
            col = index(code_line, "(")
            emit("PARSE_E_MISSING_COMMA", "error", "parser",
                "missing comma",
                FNR, col, length(raw) + 1, raw,
                "elements inside parentheses must be separated by commas",
                syntax_note(",", "identifier", "argument or tuple list", "inserted virtual comma"),
                "insert a comma between adjacent arguments or fields")
        }

        if (line ~ /:[ \t]*([=;]|$)/) {
            col = index(raw, ":")
            emit("PARSE_E_TYPE_EXPECTED", "error", "parser",
                "type expected",
                FNR, col, col + 1, raw,
                "type annotation starts here but no type follows",
                syntax_note("type", first_token(substr(raw, col + 1)), "type annotation", "none"),
                "write a concrete type after the colon")
        }

        if (line ~ /^match[ \t]+.*=>/ || line ~ /^case[ \t]*=>/) {
            col = index(raw, "=>")
            emit("PARSE_E_PATTERN_EXPECTED", "error", "parser",
                "pattern expected",
                FNR, col, col + 2, raw,
                "match arm is missing its pattern before =>",
                syntax_note("pattern", "=>", "match arm", "none"),
                "insert a valid pattern before the arrow")
        }

        if (line ~ /^(while|for|else)[ \t].*$/ && line !~ /[{][ \t]*$/ && line !~ /^[ \t]*else[ \t]*[{][ \t]*$/ && line !~ /^[ \t]*else[ \t]+if/) {
            kw = first_token(line)
            col = index(raw, kw)
            emit("PARSE_E_BLOCK_EXPECTED", "error", "parser",
                "block expected",
                FNR, col, col + length(kw), raw,
                "control-flow construct must be followed by a block",
                syntax_note("{", first_token(substr(raw, col + length(kw))), kw " body", "none"),
                "add a block delimited by braces after this construct")
        }

        if (match(code_line, /(S|true|false|-?[0-9]+)[ \t]+as[ \t]+(i8|i16|i32|i64|i128|isize|int|u8|u16|u32|u64|u128|usize|f32|f64|float|string|bool)/)) {
            cast_text = substr(code_line, RSTART, RLENGTH)
            cast_source = cast_text
            sub(/[ \t]+as[ \t]+.*$/, "", cast_source)
            cast_target = cast_text
            sub(/^.*[ \t]+as[ \t]+/, "", cast_target)
            cast_source_type = primitive_literal_type(cast_source)
            if (cast_source_type != "" && cast_source_type != cast_target && !(seed_type_is_numeric(cast_source_type) && seed_type_is_numeric(cast_target))) {
                cast_as_offset = index(cast_text, " as ")
                col = RSTART + (cast_as_offset > 0 ? cast_as_offset : 1) - 1
                emit("TYPECK_E_INVALID_CAST", "error", "typeck",
                    "explicit cast from " cast_source_type " to " cast_target " is not allowed",
                    FNR, col, col + 2, raw,
                    "target type " cast_target " is incompatible with source type " cast_source_type,
                    "explicit casts are limited to supported scalar representation conversions",
                    "use a conversion procedure or change the source or target type")
            }
        }

        if (line ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*(i8|i16|i32|i64|i128|isize|int|u8|u16|u32|u64|u128|usize|f32|f64|float|string|bool)[ \t]*=/) {
            rest = line
            sub(/^[ \t]*let[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*:.*$/, "", name)
            ty = rest
            sub(/^[^:]*:[ \t]*/, "", ty)
            sub(/[ \t=].*$/, "", ty)
            value = rest
            sub(/^[^=]*=[ \t]*/, "", value)
            sub(/[ \t;}]+$/, "", value)
            source_type = ""
            if (value ~ /^[A-Za-z_][A-Za-z0-9_]*$/) source_type = binding_type(current_proc, value)
            if (source_type != "" && !seed_types_compatible(ty, source_type)) {
                col = index(raw, value)
                emit("TYPECK_E_ASSIGN_MISMATCH", "error", "typeck",
                    "cannot initialize " name " of type " ty " from " source_type,
                    FNR, col, col + length(value), raw,
                    "expected " ty ", found " source_type,
                    "implicit numeric coercions must preserve every source value",
                    "use a wider target type or write an explicit cast")
            }
            remember_decl(name, ty, FNR, index(raw, name))
        } else if (line ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=[ \t]*-?[0-9]+[ \t;]*$/) {
            rest = line
            sub(/^[ \t]*let[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*=.*/, "", name)
            remember_decl(name, "int", FNR, index(raw, name))
        } else if (line ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=[ \t]*(true|false)[ \t;]*$/) {
            rest = line
            sub(/^[ \t]*let[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*=.*/, "", name)
            remember_decl(name, "bool", FNR, index(raw, name))
        } else if (code_trim ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=[ \t]*S[ \t;]*$/) {
            rest = code_trim
            sub(/^[ \t]*let[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*=.*/, "", name)
            remember_decl(name, "string", FNR, index(raw, name))
        }

        if (line ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*[A-Z][A-Za-z0-9_]*[ \t]*=/) {
            rest = line
            sub(/^[ \t]*let[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*:.*$/, "", name)
            ty = rest
            sub(/^[^:]*:[ \t]*/, "", ty)
            sub(/[ \t=].*$/, "", ty)
            value = rest
            sub(/^[^=]*=[ \t]*/, "", value)
            sub(/[ \t;}]+$/, "", value)
            source_type = ""
            if (value ~ /^[A-Za-z_][A-Za-z0-9_]*$/) {
                source_type = binding_type(current_proc, value)
            } else if (value ~ /^[A-Z][A-Za-z0-9_]*[ \t]*[{]/) {
                source_type = value
                sub(/[ \t{].*$/, "", source_type)
            }
            if (source_type != "" && !seed_types_compatible(ty, source_type)) {
                col = index(raw, value)
                emit("TYPECK_E_ASSIGN_MISMATCH", "error", "typeck",
                    "cannot initialize " name " of type " ty " from " source_type,
                    FNR, col, col + length(value), raw,
                    "expected " ty ", found " source_type,
                    "nominal assignments require identical declared types",
                    "change the annotation or initialize it with " ty)
            }
            remember_decl(name, ty, FNR, index(raw, name))
        } else if (line ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=[ \t]*[A-Z][A-Za-z0-9_]*[ \t]*[{]/) {
            rest = line
            sub(/^[ \t]*let[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*=.*/, "", name)
            ty = rest
            sub(/^[^=]*=[ \t]*/, "", ty)
            sub(/[ \t{].*$/, "", ty)
            remember_decl(name, ty, FNR, index(raw, name))
        }

        if (line ~ /^[ \t]*set[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=/) {
            rest = line
            sub(/^[ \t]*set[ \t]+/, "", rest)
            name = rest
            sub(/[ \t]*=.*$/, "", name)
            value = rest
            sub(/^[^=]*=[ \t]*/, "", value)
            value_token = trim(value)
            sub(/[ \t;}]+$/, "", value_token)
            target_type = binding_type(current_proc, name)
            found_type = primitive_literal_type(value)
            if (found_type == "" && value_token ~ /^[A-Za-z_][A-Za-z0-9_]*$/) found_type = binding_type(current_proc, value_token)
            if (found_type == "" && value_token ~ /^[A-Z][A-Za-z0-9_]*[ \t]*[{]/) {
                found_type = value_token
                sub(/[ \t{].*$/, "", found_type)
            }
            if (target_type != "" && found_type != "" && !seed_types_compatible(target_type, found_type)) {
                if (value_token ~ /^"/) {
                    col = index(raw, "\"")
                    value_tail = substr(raw, col + 1)
                    endq = index(value_tail, "\"")
                    width = endq > 0 ? endq + 1 : 1
                } else {
                    col = index(raw, value_token)
                    width = length(value_token)
                }
                target_key = current_proc SUBSEP name
                target_line = proc_decl_line[target_key]
                target_col = proc_decl_col[target_key]
                if (target_line <= 0) target_line = decl_line[name]
                if (target_col <= 0) target_col = decl_col[name]
                emit("TYPECK_E_ASSIGN_MISMATCH", "error", "typeck",
                    "cannot assign value of type " found_type " to variable of type " target_type,
                    FNR, col, col + width, raw,
                    "expected " target_type ", found " found_type,
                    "variable " name " was declared here: " file ":" target_line ":" target_col,
                    "change the value type or update the variable annotation")
            }
        }

        if (line ~ /^[ \t]*let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*(i32|int)[ \t]*=.*[+][ \t]*"/) {
            col = index(raw, "+")
            emit("TYPECK_E_BINARY_MISMATCH", "error", "typeck",
                "cannot apply binary operator + to i32 and string",
                FNR, col, col + 1, raw,
                "left and right operands must have compatible types",
                "operator + for integers expects integer operands",
                "convert the string or use a string concatenation operation")
        }

        if (line ~ /^[ \t]*if[ \t]*"/) {
            col = index(raw, "\"")
            emit("TYPECK_E_CONDITION_TYPE", "error", "typeck",
                "condition expression must be bool",
                FNR, col, length(raw) + 1, raw,
                "expected bool, found string",
                "if conditions are checked before lowering to MIR",
                "compare the value explicitly or use a boolean expression")
        } else if (line ~ /^[ \t]*if[ \t]+[A-Za-z_][A-Za-z0-9_]*([ \t]*[{]|[ \t]*$)/) {
            condition_name = line
            sub(/^[ \t]*if[ \t]+/, "", condition_name)
            sub(/[^A-Za-z0-9_].*$/, "", condition_name)
            if ((condition_name in decl_type) && decl_type[condition_name] == "string") {
                col = index(raw, condition_name)
                emit("TYPECK_E_CONDITION_TYPE", "error", "typeck",
                    "condition expression must be bool",
                    FNR, col, col + length(condition_name), raw,
                    "expected bool, found string",
                    "if conditions are checked before lowering to MIR",
                    "compare the value explicitly or use a boolean expression")
            }
        }

        if (line ~ /^[ \t]*give[ \t]+missing_[A-Za-z0-9_]*/) {
            name = line
            sub(/^[ \t]*give[ \t]+/, "", name)
            sub(/[ \t;].*$/, "", name)
            col = index(raw, name)
            close_name = nearest_symbol(name)
            if (close_name == "") close_name = "<none>"
            emit("SEMA_E_UNKNOWN_IDENTIFIER", "error", "symbol_resolution",
                "unknown identifier " name,
                FNR, col, col + length(name), raw,
                "name not found in this scope",
                "scope: current block in " file "; closest symbol: " close_name "; active imports: " current_imports_text(),
                "declare " name ", import it, or rename it to a visible symbol")
        }

        if (line ~ /^[ \t]*give[ \t]+ambiguous_[A-Za-z0-9_]*/) {
            name = line
            sub(/^[ \t]*give[ \t]+/, "", name)
            sub(/[ \t;].*$/, "", name)
            col = index(raw, name)
            emit("SEMA_E_AMBIGUOUS_SYMBOL", "error", "symbol_resolution",
                "ambiguous symbol " name,
                FNR, col, col + length(name), raw,
                "multiple visible declarations match " name,
                "scope: current block in " file "; closest symbol: " nearest_symbol(name) "; active imports: " current_imports_text(),
                "qualify the symbol with its module or remove one competing import")
        }

        if (line ~ /^[ \t]*let[ \t]+shadow_[A-Za-z0-9_]*[ \t]*=/) {
            name = line
            sub(/^[ \t]*let[ \t]+/, "", name)
            sub(/[ \t=].*$/, "", name)
            col = index(raw, name)
            emit("SEMA_E_SHADOWING_FORBIDDEN", "error", "symbol_resolution",
                "shadowing is forbidden for " name,
                FNR, col, col + length(name), raw,
                "binding would shadow an existing visible symbol",
                "scope: current block in " file "; original declaration: " file ":1:1; active imports: " current_imports_text(),
                "rename the new binding or remove the shadowed declaration")
        }

        if (line ~ /\.[ \t]*missing_field/) {
            col = index(raw, "missing_field")
            emit("SEMA_E_UNKNOWN_FIELD", "error", "symbol_resolution",
                "field does not exist",
                FNR, col, col + length("missing_field"), raw,
                "field missing_field is not defined on this type",
                "scope: current expression in " file "; closest symbol: field_candidate; active imports: " current_imports_text(),
                "use an existing field name or change the receiver type")
        }

        if (line ~ /::missing_variant/ || line ~ /[. ]missing_variant/) {
            col = index(raw, "missing_variant")
            emit("SEMA_E_UNKNOWN_VARIANT", "error", "symbol_resolution",
                "variant does not exist",
                FNR, col, col + length("missing_variant"), raw,
                "enum or pick variant missing_variant is not defined",
                "scope: current pattern or constructor path in " file "; closest symbol: variant_candidate; active imports: " current_imports_text(),
                "use an existing variant or fix the variant spelling")
        }

        if (line ~ /missing_call[ \t]*\(/) {
            col = index(raw, "missing_call")
            emit("SEMA_E_UNKNOWN_FUNCTION", "error", "symbol_resolution",
                "function does not exist",
                FNR, col, col + length("missing_call"), raw,
                "no callable symbol named missing_call is visible here",
                "scope: current call site in " file "; closest symbol: " nearest_symbol("missing_call") "; active imports: " current_imports_text(),
                "declare the function, import it, or call the correct symbol")
        }

        if (line ~ /^[ \t]*move[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
            moved = line
            sub(/^[ \t]*move[ \t]+/, "", moved)
            sub(/[ \t;].*$/, "", moved)
            moved_line[moved] = FNR
            moved_col[moved] = index(raw, moved)
        }
        if (line ~ /^[ \t]*give[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
            used = line
            sub(/^[ \t]*give[ \t]+/, "", used)
            sub(/[ \t;].*$/, "", used)
            if (used in moved_line) {
                col = index(raw, used)
                emit("BORROWCK_E_USE_AFTER_MOVE", "error", "borrowck",
                    "use of moved value " used,
                    FNR, col, col + length(used), raw,
                    "value used here after move",
                    "value was moved here: " file ":" moved_line[used] ":" moved_col[used],
                    "borrow the value or clone it before moving")
            }
        }

        if (active_pick_name != "" && line !~ /^pick[ \t]+/) {
            consume_pick_definition(code_line)
        }
        if (active_nominal_kind != "" && line !~ /^(trait|impl)[ \t]+/) {
            consume_nominal_definition(code_line)
        }
        if (active_match_type != "") {
            consume_finite_match(code_line)
        } else {
            match_col = match_keyword_col(code_line)
            if (match_col > 0) begin_finite_match(code_line, FNR, match_col, current_proc)
        }

        if (open_line == 0 && outside_string_col(raw, "{") > 0) {
            open_line = FNR
            open_col = outside_string_col(raw, "{")
        }
        brace_depth += count_char_outside_strings(raw, "{") - count_char_outside_strings(raw, "}")
        if (current_proc != "" && brace_depth < current_proc_depth) {
            current_proc = ""
            current_return_type = ""
            current_proc_depth = 0
        }
    }
    END {
        if (!found) {
            for (impl_reference_index = 1; impl_reference_index <= impl_reference_count; impl_reference_index++) {
                impl_trait = impl_reference_trait[impl_reference_index]
                if (trait_known[impl_trait]) continue
                raw = source_line[impl_reference_line[impl_reference_index]]
                col = impl_reference_col[impl_reference_index]
                emit("TYPECK_E_IMPL_UNKNOWN_TRAIT", "error", "typeck",
                    "impl references unknown trait " impl_trait,
                    impl_reference_line[impl_reference_index], col, col + length(impl_trait), raw,
                    "trait " impl_trait " is not declared in this module",
                    "implementation target type: " impl_reference_type[impl_reference_index] "; trait resolution completed without a matching declaration",
                    "declare trait " impl_trait " or correct the implemented trait name")
            }
        }
        if (!found) {
            for (method_call_line = 1; method_call_line <= FNR; method_call_line++) {
                method_call_rest = source_code_line[method_call_line]
                method_call_scope = line_proc[method_call_line]
                method_call_offset = 0
                while (match(method_call_rest, /[A-Za-z_][A-Za-z0-9_]*[ \t]*[.][ \t]*[A-Za-z_][A-Za-z0-9_]*[ \t]*[(]/)) {
                    method_call_text = substr(method_call_rest, RSTART, RLENGTH)
                    receiver_name = method_call_text
                    sub(/[ \t]*[.].*$/, "", receiver_name)
                    method_name = method_call_text
                    sub(/^.*[.][ \t]*/, "", method_name)
                    sub(/[ \t]*[(].*$/, "", method_name)
                    receiver_type = binding_type(method_call_scope, receiver_name)
                    provider_key = receiver_type SUBSEP method_name
                    if (receiver_type != "" && method_provider_count[provider_key] > 1) {
                        raw = source_line[method_call_line]
                        col = method_call_offset + RSTART + index(method_call_text, method_name) - 1
                        emit("TYPECK_E_AMBIGUOUS_METHOD", "error", "typeck",
                            "ambiguous method " method_name " for type " receiver_type,
                            method_call_line, col, col + length(method_name), raw,
                            "multiple visible impls provide " receiver_type "." method_name,
                            "method providers: " method_provider_text[provider_key],
                            "remove one competing impl or use an explicitly qualified trait call")
                    }
                    if (receiver_type != "" && method_provider_count[provider_key] == 1) {
                        method_call_open = RSTART + RLENGTH - 1
                        method_call_close = matching_call_paren(method_call_rest, method_call_open)
                        if (method_call_close > 0) {
                            method_call_args = substr(method_call_rest, method_call_open + 1, method_call_close - method_call_open - 1)
                            method_call_arg_count = split_call_args(method_call_args, method_call_arg_parts)
                            if (method_call_arg_count != method_provider_arity[provider_key]) {
                                raw = source_line[method_call_line]
                                col = method_call_offset + RSTART + index(method_call_text, method_name) - 1
                                emit("TYPECK_E_CALL_ARITY", "error", "typeck",
                                    "method " receiver_type "." method_name " expects " method_provider_arity[provider_key] " arguments but received " method_call_arg_count,
                                    method_call_line, col, col + length(method_name), raw,
                                    "expected " method_provider_arity[provider_key] " arguments, found " method_call_arg_count,
                                    "the receiver binds the Self parameter before call arity is checked",
                                    "pass exactly " method_provider_arity[provider_key] " explicit arguments to " method_name)
                            }
                            for (method_arg_index = 1; method_arg_index <= method_call_arg_count; method_arg_index++) {
                                expected_arg_type = method_provider_param[provider_key SUBSEP method_arg_index]
                                actual_arg = trim(method_call_arg_parts[method_arg_index])
                                actual_arg_type = primitive_literal_type(actual_arg)
                                if (actual_arg_type == "") actual_arg_type = binding_type(method_call_scope, actual_arg, method_call_line)
                                if (expected_arg_type == "" || actual_arg_type == "" || seed_types_compatible(expected_arg_type, actual_arg_type)) continue
                                raw = source_line[method_call_line]
                                col = method_call_offset + method_call_open + index(method_call_args, actual_arg)
                                emit("TYPECK_E_ARGUMENT_MISMATCH", "error", "typeck",
                                    "argument type " actual_arg_type " does not match method parameter type " expected_arg_type,
                                    method_call_line, col, col + length(actual_arg), raw,
                                    "expected " expected_arg_type ", found " actual_arg_type,
                                    "argument " method_arg_index " is passed to bound method " receiver_type "." method_name,
                                    "pass a value of type " expected_arg_type " or change the method signature")
                            }
                            resolved_method_return = method_provider_return[provider_key]
                            method_call_start = method_call_offset + RSTART
                            effective_method_return = resolved_method_return
                            method_call_suffix = trim(substr(source_code_line[method_call_line], method_call_start + length(method_call_text)))
                            if (method_call_suffix ~ /^[.]/) {
                                effective_method_return = ""
                            } else if (method_call_suffix ~ /^as[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
                                effective_method_return = method_call_suffix
                                sub(/^as[ \t]+/, "", effective_method_return)
                                sub(/[^A-Za-z0-9_].*$/, "", effective_method_return)
                            }
                            method_binding_prefix = trim(substr(source_code_line[method_call_line], 1, method_call_start - 1))
                            if (effective_method_return != "" && method_binding_prefix ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*([ \t]*:[ \t]*[A-Za-z_][A-Za-z0-9_]*)?[ \t]*=[ \t]*$/) {
                                method_binding_name = method_binding_prefix
                                sub(/^let[ \t]+/, "", method_binding_name)
                                sub(/[ \t]*[:=].*$/, "", method_binding_name)
                                method_binding_type = ""
                                if (method_binding_prefix ~ /:/) {
                                    method_binding_type = method_binding_prefix
                                    sub(/^[^:]*:[ \t]*/, "", method_binding_type)
                                    sub(/[ \t]*=.*/, "", method_binding_type)
                                }
                                if (method_binding_type != "" && !seed_types_compatible(method_binding_type, effective_method_return)) {
                                    raw = source_line[method_call_line]
                                    col = method_call_start
                                    emit("TYPECK_E_ASSIGN_MISMATCH", "error", "typeck",
                                        "cannot initialize " method_binding_name " of type " method_binding_type " from method result type " effective_method_return,
                                        method_call_line, col, col + length(method_call_text) - 1, raw,
                                        "expected " method_binding_type ", found " effective_method_return,
                                        "bound method " receiver_type "." method_name " declares return type " resolved_method_return,
                                        "change the binding type or the method return type")
                                }
                                if (method_binding_type == "") {
                                    remember_decl_in(method_call_scope, method_binding_name, effective_method_return, method_call_line, index(source_line[method_call_line], method_binding_name))
                                }
                            }
                        }
                    }
                    method_call_advance = RSTART + RLENGTH - 1
                    method_call_offset += method_call_advance
                    method_call_rest = substr(method_call_rest, method_call_advance + 1)
                }
            }
        }
        if (!found) {
            for (call_line_no = 1; call_line_no <= FNR; call_line_no++) {
                call_code = source_code_line[call_line_no]
                call_scope = line_proc[call_line_no]
                call_trim = trim(call_code)
                if (call_trim == "" || call_trim ~ /^proc[ \t]+/) continue
                for (proc_order_index = 1; proc_order_index <= proc_order_count; proc_order_index++) {
                    called_proc = proc_order[proc_order_index]
                    call_pattern = "(^|[^A-Za-z0-9_])" called_proc "([ \t]*<[^>]+>)?[ \t]*[(]"
                    if (!match(call_code, call_pattern)) continue
                    matched_call = substr(call_code, RSTART, RLENGTH)
                    called_name_offset = index(matched_call, called_proc)
                    call_suffix = substr(matched_call, called_name_offset + length(called_proc))
                    call_open_offset = index(call_suffix, "(")
                    if (called_name_offset <= 0 || call_open_offset <= 0) continue
                    call_name_col = RSTART + called_name_offset - 1
                    call_prefix = substr(call_code, 1, call_name_col - 1)
                    if (call_prefix ~ /[.][ \t]*$/) continue
                    call_open_col = RSTART + called_name_offset + length(called_proc) + call_open_offset - 2
                    call_generic_arg_count = 0
                    call_generic_text = trim(substr(call_suffix, 1, call_open_offset - 1))
                    if (call_generic_text ~ /^<.*>$/) {
                        sub(/^</, "", call_generic_text)
                        sub(/>$/, "", call_generic_text)
                        call_generic_arg_count = split_call_args(call_generic_text, call_generic_arg_parts)
                    }
                    call_close_col = matching_call_paren(call_code, call_open_col)
                    if (call_close_col <= 0) continue
                    call_args = substr(call_code, call_open_col + 1, call_close_col - call_open_col - 1)
                    call_arg_count = split_call_args(call_args, call_arg_parts)
                    if (proc_generic_count[called_proc] > 0) {
                        for (generic_index = 1; generic_index <= proc_generic_count[called_proc]; generic_index++) {
                            generic_param = proc_generic_param[called_proc SUBSEP generic_index]
                            delete call_generic_type[called_proc SUBSEP generic_param]
                        }
                        if (call_generic_arg_count > proc_generic_count[called_proc]) {
                            raw = source_line[call_line_no]
                            col = index(raw, called_proc)
                            emit("TYPECK_E_GENERIC_INFERENCE", "error", "typeck",
                                "generic arguments do not match procedure " called_proc,
                                call_line_no, col, col + length(called_proc), raw,
                                "expected at most " proc_generic_count[called_proc] " generic arguments, found " call_generic_arg_count,
                                "generic parameters must be resolved before monomorphization",
                                "remove excess generic arguments from " called_proc)
                        }
                        for (generic_index = 1; generic_index <= proc_generic_count[called_proc]; generic_index++) {
                            generic_param = proc_generic_param[called_proc SUBSEP generic_index]
                            resolved_generic_type = ""
                            if (generic_index <= call_generic_arg_count) {
                                resolved_generic_type = trim(call_generic_arg_parts[generic_index])
                            } else {
                                for (call_param_index = 1; call_param_index <= proc_param_count[called_proc] && call_param_index <= call_arg_count; call_param_index++) {
                                    if (trim(proc_param_pattern[called_proc SUBSEP call_param_index]) == generic_param) {
                                        generic_call_arg = trim(call_arg_parts[call_param_index])
                                        resolved_generic_type = primitive_literal_type(generic_call_arg)
                                        if (resolved_generic_type == "") resolved_generic_type = binding_type(call_scope, generic_call_arg, call_line_no)
                                        if (resolved_generic_type != "") break
                                    }
                                }
                            }
                            if (resolved_generic_type != "") call_generic_type[called_proc SUBSEP generic_param] = resolved_generic_type
                            if (resolved_generic_type == "" && !proc_generic_constrained[called_proc SUBSEP generic_index]) {
                                raw = source_line[call_line_no]
                                col = index(raw, called_proc)
                                emit("TYPECK_E_GENERIC_INFERENCE", "error", "typeck",
                                    "generic type " generic_param " could not be inferred",
                                    call_line_no, col, col + length(called_proc), raw,
                                    "generic parameter " generic_param " remains unconstrained",
                                    "procedure " called_proc " requires " generic_param " before monomorphization",
                                    "call " called_proc " with an explicit generic argument such as <int>")
                            }
                            generic_bound = proc_generic_bound[called_proc SUBSEP generic_index]
                            if (resolved_generic_type != "" && generic_bound != "" && trait_known[generic_bound] && !trait_impl[generic_bound SUBSEP resolved_generic_type]) {
                                raw = source_line[call_line_no]
                                col = index(raw, called_proc)
                                emit("TYPECK_E_TRAIT_BOUND", "error", "typeck",
                                    "trait constraint " generic_bound " is not satisfied for " resolved_generic_type,
                                    call_line_no, col, col + length(called_proc), raw,
                                    "generic argument " resolved_generic_type " must implement " generic_bound,
                                    "no visible impl proves " resolved_generic_type ": " generic_bound,
                                    "add impl " generic_bound " for " resolved_generic_type " or change the generic argument")
                            }
                        }
                    }
                    if (!proc_signature_supported[called_proc]) continue
                    if (call_arg_count != proc_param_count[called_proc]) {
                        raw = source_line[call_line_no]
                        col = index(raw, called_proc)
                        if (col <= 0) col = call_open_col
                        emit("TYPECK_E_CALL_ARITY", "error", "typeck",
                            "procedure " called_proc " expects " proc_param_count[called_proc] " arguments but received " call_arg_count,
                            call_line_no, col, col + length(called_proc), raw,
                            "expected " proc_param_count[called_proc] " arguments, found " call_arg_count,
                            "procedure signature determines the required argument count",
                            "pass exactly " proc_param_count[called_proc] " arguments to " called_proc)
                    }
                    for (call_arg_index = 1; call_arg_index <= call_arg_count; call_arg_index++) {
                        expected_arg_type = proc_param_type[called_proc SUBSEP call_arg_index]
                        expected_arg_pattern = proc_param_pattern[called_proc SUBSEP call_arg_index]
                        if (expected_arg_type == "" && proc_generic_index[called_proc SUBSEP expected_arg_pattern] > 0) {
                            expected_arg_type = call_generic_type[called_proc SUBSEP expected_arg_pattern]
                        }
                        actual_arg = trim(call_arg_parts[call_arg_index])
                        actual_arg_type = primitive_literal_type(actual_arg)
                        if (actual_arg_type == "") actual_arg_type = binding_type(call_scope, actual_arg, call_line_no)
                        if (expected_arg_type == "" || actual_arg_type == "" || seed_types_compatible(expected_arg_type, actual_arg_type)) continue
                        raw = source_line[call_line_no]
                        if (actual_arg ~ /^"/) {
                            relative_col = index(substr(raw, call_open_col + 1), "\"")
                            if (relative_col > 0) col = call_open_col + relative_col
                            else col = call_open_col + 1
                            actual_tail = substr(raw, col + 1)
                            actual_end = index(actual_tail, "\"")
                            width = actual_end > 0 ? actual_end + 1 : 1
                        } else {
                            relative_col = index(substr(raw, call_open_col + 1), actual_arg)
                            col = relative_col > 0 ? call_open_col + relative_col : call_open_col + 1
                            width = length(actual_arg)
                        }
                        emit("TYPECK_E_ARGUMENT_MISMATCH", "error", "typeck",
                            "argument type " actual_arg_type " does not match parameter type " expected_arg_type,
                            call_line_no, col, col + width, raw,
                            "expected " expected_arg_type ", found " actual_arg_type,
                            "argument " call_arg_index " is passed to procedure " called_proc,
                            "pass a value of type " expected_arg_type " or change the parameter type")
                    }
                    resolved_call_return = proc_return_type[called_proc]
                    if (proc_generic_index[called_proc SUBSEP resolved_call_return] > 0) {
                        resolved_call_return = call_generic_type[called_proc SUBSEP resolved_call_return]
                    }
                    effective_call_return = resolved_call_return
                    call_binding_suffix = trim(substr(call_code, call_close_col + 1))
                    if (call_binding_suffix ~ /^[.]/) {
                        effective_call_return = ""
                    } else if (call_binding_suffix ~ /^as[ \t]+[A-Za-z_][A-Za-z0-9_]*/) {
                        effective_call_return = call_binding_suffix
                        sub(/^as[ \t]+/, "", effective_call_return)
                        sub(/[^A-Za-z0-9_].*$/, "", effective_call_return)
                    } else if (call_binding_suffix != "") {
                        effective_call_return = ""
                    }
                    call_binding_prefix = trim(substr(call_code, 1, call_name_col - 1))
                    if (effective_call_return != "" && call_binding_prefix ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*([ \t]*:[ \t]*[A-Za-z_][A-Za-z0-9_]*)?[ \t]*=[ \t]*$/) {
                        call_binding_name = call_binding_prefix
                        sub(/^let[ \t]+/, "", call_binding_name)
                        sub(/[ \t]*[:=].*$/, "", call_binding_name)
                        call_binding_type = ""
                        if (call_binding_prefix ~ /:/) {
                            call_binding_type = call_binding_prefix
                            sub(/^[^:]*:[ \t]*/, "", call_binding_type)
                            sub(/[ \t]*=.*/, "", call_binding_type)
                        }
                        if (call_binding_type != "" && !seed_types_compatible(call_binding_type, effective_call_return)) {
                            raw = source_line[call_line_no]
                            emit("TYPECK_E_ASSIGN_MISMATCH", "error", "typeck",
                                "cannot initialize " call_binding_name " of type " call_binding_type " from procedure result type " effective_call_return,
                                call_line_no, call_name_col, call_close_col + 1, raw,
                                "expected " call_binding_type ", found " effective_call_return,
                                "procedure " called_proc " declares return type " resolved_call_return,
                                "change the binding type or the procedure return type")
                        }
                        if (call_binding_type == "") {
                            remember_decl_in(call_scope, call_binding_name, effective_call_return, call_line_no, index(source_line[call_line_no], call_binding_name))
                        }
                    }
                }
            }
        }
        if (!found && in_block_comment) {
            emit("LEX_E_UNTERMINATED_COMMENT", "error", "lexer",
                "unterminated block comment",
                block_comment_line, block_comment_col, block_comment_col + 2, "",
                "block comment starts here but is not closed",
                "comment opener /* starts at byte " block_comment_col,
                "add a closing */")
        }
        if (!found && brace_depth > 0) {
            emit("PARSE_E_UNCLOSED_BLOCK", "error", "parser",
                "unclosed block",
                open_line, open_col, open_col + 1, "",
                "block opened here",
                "the parser reached end of file before finding }",
                "add a closing }")
        }
        if (!found) exit 1
    }' "$src"
}

detect_type_mismatch() {
    src="$1"
    awk '
    function trim(s) {
        sub(/^[ \t\r\n]+/, "", s)
        sub(/[ \t\r\n]+$/, "", s)
        return s
    }
    function primitive_literal_type(text,    value) {
        value = trim(text)
        if (value ~ /^"/) return "string"
        if (value == "true" || value == "false") return "bool"
        if (value ~ /^-?[0-9]+$/) return "int"
        return ""
    }
    function primitive_types_compatible(expected, found) {
        if ((expected == "int" || expected == "i32") && found == "int") return 1
        return expected == found
    }
    function seed_type_is_signed_integer(ty) { return ty ~ /^(i8|i16|i32|i64|i128|isize|int)$/ }
    function seed_type_is_unsigned_integer(ty) { return ty ~ /^(u8|u16|u32|u64|u128|usize)$/ }
    function seed_type_is_integer(ty) { return seed_type_is_signed_integer(ty) || seed_type_is_unsigned_integer(ty) }
    function seed_type_is_float(ty) { return ty ~ /^(f32|f64|float)$/ }
    function seed_numeric_width(ty) {
        if (ty == "i8" || ty == "u8") return 8
        if (ty == "i16" || ty == "u16") return 16
        if (ty == "i32" || ty == "u32" || ty == "int") return 32
        if (ty == "i64" || ty == "u64" || ty == "isize" || ty == "usize" || ty == "f64" || ty == "float") return 64
        if (ty == "i128" || ty == "u128") return 128
        if (ty == "f32") return 32
        return 0
    }
    function seed_types_compatible(expected, actual,    expected_width, actual_width, precision) {
        if (expected == actual) return 1
        expected_width = seed_numeric_width(expected)
        actual_width = seed_numeric_width(actual)
        if (seed_type_is_signed_integer(expected) && seed_type_is_signed_integer(actual)) return actual_width <= expected_width
        if (seed_type_is_unsigned_integer(expected) && seed_type_is_unsigned_integer(actual)) return actual_width <= expected_width
        if (seed_type_is_signed_integer(expected) && seed_type_is_unsigned_integer(actual)) return actual_width < expected_width
        if (seed_type_is_float(expected) && seed_type_is_float(actual)) return actual_width <= expected_width
        if (seed_type_is_float(expected) && seed_type_is_integer(actual)) {
            precision = expected == "f32" ? 24 : 53
            return actual_width <= precision
        }
        return 0
    }
    function remember_typed_let(stmt, raw, line_no, base_col,    rest, name, ty, rhs, found_type, name_col, col) {
        rest = stmt
        sub(/^[ \t]*let[ \t]+/, "", rest)
        name = rest
        sub(/[ \t]*:.*$/, "", name)
        ty = rest
        sub(/^[^:]*:[ \t]*/, "", ty)
        sub(/[ \t=].*$/, "", ty)
        rhs = rest
        sub(/^[^=]*=[ \t]*/, "", rhs)
        rhs = trim(rhs)
        if (rhs ~ /^[A-Za-z_][A-Za-z0-9_]*$/ && (rhs in decl_type)) {
            found_type = decl_type[rhs]
            if (!seed_types_compatible(ty, found_type)) {
                col = base_col + index(stmt, rhs) - 1
                print name "|" ty "|" found_type "|" line_no "|" col "|" line_no "|" (base_col + index(stmt, name) - 1) "|" length(rhs) "|" raw
                found = 1
                exit
            }
        }
        if (name != "" && (ty ~ /^(i8|i16|i32|i64|i128|isize|int|u8|u16|u32|u64|u128|usize|f32|f64|float|string|bool)$/)) {
            decl_type[name] = ty
            decl_line[name] = line_no
            name_col = index(stmt, name)
            decl_col[name] = base_col + name_col - 1
        }
    }
    function remember_inferred_int_let(stmt, line_no, base_col,    rest, name, name_col) {
        rest = stmt
        sub(/^[ \t]*let[ \t]+/, "", rest)
        name = rest
        sub(/[ \t]*=.*/, "", name)
        if (name != "") {
            decl_type[name] = "int"
            decl_line[name] = line_no
            name_col = index(stmt, name)
            decl_col[name] = base_col + name_col - 1
        }
    }
    function parse_set(stmt, raw, line_no, base_col,    rest, name, rhs, found_type, col, value, endq, len0) {
        rest = stmt
        sub(/^[ \t]*set[ \t]+/, "", rest)
        name = rest
        sub(/[ \t]*=.*$/, "", name)
        if (!(name in decl_type)) return
        rhs = rest
        sub(/^[^=]*=[ \t]*/, "", rhs)
        found_type = primitive_literal_type(rhs)
        if (found_type == "" || primitive_types_compatible(decl_type[name], found_type)) return
        if (found_type == "string") {
            col = base_col + index(stmt, "\"") - 1
            value = substr(raw, col + 1)
            endq = index(value, "\"")
            if (endq <= 0) return
            len0 = endq + 1
        } else {
            col = base_col + index(stmt, rhs) - 1
            len0 = length(rhs)
        }
        print name "|" decl_type[name] "|" found_type "|" line_no "|" col "|" decl_line[name] "|" decl_col[name] "|" len0 "|" raw
        found = 1
        exit
    }
    {
        raw = $0
        search_from = 1
        segment_count = split(raw, segments, ";")
        for (i = 1; i <= segment_count; i++) {
            stmt = segments[i]
            trimmed = trim(stmt)
            if (trimmed == "") {
                search_from += length(stmt) + 1
                continue
            }
            rel = index(substr(raw, search_from), stmt)
            if (rel <= 0) {
                base_col = search_from
            } else {
                base_col = search_from + rel - 1
            }
            candidate = trimmed
            if (candidate !~ /^(let|set)[ \t]+/ && match(candidate, /(^|[^A-Za-z0-9_])(let|set)[ \t]+/)) {
                candidate = substr(candidate, RSTART)
                sub(/^[^A-Za-z0-9_]+/, "", candidate)
            }
            candidate_col = base_col + (index(stmt, candidate) > 0 ? index(stmt, candidate) - 1 : 0)
            if (candidate ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[ \t]*(i8|i16|i32|i64|i128|isize|int|u8|u16|u32|u64|u128|usize|f32|f64|float|string|bool)[ \t]*=/) {
                remember_typed_let(candidate, raw, FNR, candidate_col)
            } else if (candidate ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=[ \t]*-?[0-9]+$/) {
                remember_inferred_int_let(candidate, FNR, candidate_col)
            } else if (candidate ~ /^set[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*=/) {
                parse_set(candidate, raw, FNR, candidate_col)
            }
            search_from = base_col + length(stmt) + 1
        }
    }
    END {
        if (!found) exit 1
    }' "$src"
}

detect_simple_unclosed_block() {
    src="$1"
    awk '
    function outside_string_col(s, needle,    i, ch, quoted, escaped) {
        quoted = 0
        escaped = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
            } else if (quoted && ch == "\\") {
                escaped = 1
            } else if (ch == "\"") {
                quoted = !quoted
            } else if (!quoted && ch == needle) {
                return i
            }
        }
        return 0
    }
    function count_char(s, needle,    i, ch, n, quoted, escaped) {
        n = 0
        quoted = 0
        escaped = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
            } else if (quoted && ch == "\\") {
                escaped = 1
            } else if (ch == "\"") {
                quoted = !quoted
            } else if (!quoted && ch == needle) {
                n++
            }
        }
        return n
    }
    BEGIN {
        depth = 0
        open_line = 0
        open_col = 0
    }
    {
        raw = $0
        if (open_line == 0 && outside_string_col(raw, "{") > 0) {
            open_line = FNR
            open_col = outside_string_col(raw, "{")
        }
        depth += count_char(raw, "{") - count_char(raw, "}")
    }
    END {
        if (depth > 0 && open_line > 0) {
            printf "PARSE_E_UNCLOSED_BLOCK|error|parser|unclosed block|%s|%s|%s||block opened here|the parser reached end of file before finding }|add a closing }\n", open_line, open_col, open_col + 1
            exit 0
        }
        exit 1
    }' "$src"
}

diag_field() {
    text="$1"
    index0="$2"
    printf '%s\n' "$text" | awk -F'|' -v n="$index0" '{print $n}'
}

repeat_char() {
    char="$1"
    count="$2"
    out=""
    i=0
    while [ "$i" -lt "$count" ]; do
        out="$out$char"
        i=$((i + 1))
    done
    printf '%s' "$out"
}

color_wrap() {
    color="$1"
    body="$2"
    if [ -z "$color" ]; then
        printf '%s' "$body"
    else
        printf '%s%s%s' "$color" "$body" "$ansi_reset"
    fi
}

render_professional_diagnostic_text() {
    src="$1"
    info="$2"
    code="$(diag_field "$info" 1)"
    severity="$(diag_field "$info" 2)"
    phase="$(diag_field "$info" 3)"
    message="$(diag_field "$info" 4)"
    message="$(localized_diagnostic_message "$code" "$message")"
    line="$(diag_field "$info" 5)"
    col="$(diag_field "$info" 6)"
    end_col="$(diag_field "$info" 7)"
    label="$(diag_field "$info" 9)"
    note="$(diag_field "$info" 10)"
    help="$(diag_field "$info" 11)"
    help="$(localized_diagnostic_explain_field "$code" fix "$help")"
    text="$(sed -n "${line}p" "$src" 2>/dev/null || true)"
    mark_len=$((end_col - col))
    if [ "$mark_len" -lt 1 ]; then mark_len=1; fi
    marker="$(repeat_char '^' "$mark_len")"
    before="$(repeat_char ' ' $((col - 1)))"
    header="$(printf '%s[%s] %s: %s' "$severity" "$code" "$phase" "$message")"
    color_wrap "$ansi_bold$ansi_red" "$header"
    printf '\n'
    printf '  --> %s:%s:%s\n' "$src" "$line" "$col"
    printf '   |\n'
    if [ -n "$text" ]; then
        printf '%2s | %s\n' "$line" "$text"
        printf '   | %s%s %s\n' "$before" "$marker" "$label"
    else
        printf '   | %s%s %s\n' "$before" "$marker" "$label"
    fi
    printf '   |\n'
    if [ -n "$note" ]; then
        color_wrap "$ansi_blue" "note"
        printf ': %s\n' "$note"
    fi
    if [ -n "$help" ]; then
        color_wrap "$ansi_cyan" "help"
        printf ': %s\n' "$help"
    fi
}

render_professional_diagnostic_json() {
    src="$1"
    info="$2"
    code="$(diag_field "$info" 1)"
    severity="$(diag_field "$info" 2)"
    phase="$(diag_field "$info" 3)"
    message="$(diag_field "$info" 4)"
    message="$(localized_diagnostic_message "$code" "$message")"
    line="$(diag_field "$info" 5)"
    col="$(diag_field "$info" 6)"
    end_col="$(diag_field "$info" 7)"
    label="$(diag_field "$info" 9)"
    note="$(diag_field "$info" 10)"
    help="$(diag_field "$info" 11)"
    help="$(localized_diagnostic_explain_field "$code" fix "$help")"
    src_json="$(json_escape "$src")"
    code_json="$(json_escape "$code")"
    severity_json="$(json_escape "$severity")"
    phase_json="$(json_escape "$phase")"
    msg_json="$(json_escape "$message")"
    label_json="$(json_escape "$label")"
    note_json="$(json_escape "$note")"
    help_json="$(json_escape "$help")"
    printf '{"schema":"vitte.compiler.diagnostics","schema_version":"1.0.0","status":"error","diagnostics":{"error_count":1,"warning_count":0,"items":[{"code":"%s","severity":"%s","phase":"%s","file":"%s","span":{"start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s},"message":"%s","labels":[{"kind":"primary","message":"%s","span":{"start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s}}],"notes":[{"message":"%s"}],"help":[{"message":"%s"}]}]}}\n' \
        "$code_json" "$severity_json" "$phase_json" "$src_json" "$line" "$col" "$line" "$end_col" "$msg_json" "$label_json" "$line" "$col" "$line" "$end_col" "$note_json" "$help_json"
}

empty_phase_report_json() {
    printf '{"valid": true, "error_count": 0, "warning_count": 0, "fatal_count": 0, "diagnostics": []}'
}

phase_frontend_bool() {
    phase="$1"
    if [ "$phase" = "lexer" ] || [ "$phase" = "parser" ] || [ "$phase" = "ast_validation" ]; then
        printf 'true'
    else
        printf 'false'
    fi
}

phase_sema_success_bool() {
    failed="$1"
    if [ "$failed" = "module_resolution" ] || [ "$failed" = "symbol_resolution" ] || [ "$failed" = "sema" ]; then
        printf 'false'
    else
        printf 'true'
    fi
}

phase_success_bool() {
    target="$1"
    failed="$2"
    if [ "$target" = "$failed" ]; then
        printf 'false'
    else
        printf 'true'
    fi
}

render_phase_reports_json() {
    lexer_report="$1"
    parser_report="$2"
    ast_validation_report="$3"
    module_resolution_report="$4"
    symbol_resolution_report="$5"
    sema_report="$6"
    typeck_report="$7"
    borrowck_report="$8"
    mir_lowering_report="$9"
    shift 9
    mir_verification_report="$1"
    backend_report="$2"
    linker_report="$3"
    runtime_execution_report="$4"
    printf '{"lexer":%s,"parser":%s,"ast_validation":%s,"module_resolution":%s,"symbol_resolution":%s,"sema":%s,"typeck":%s,"borrowck":%s,"mir_lowering":%s,"mir_verification":%s,"backend":%s,"linker":%s,"runtime_execution":%s}' \
        "$lexer_report" "$parser_report" "$ast_validation_report" "$module_resolution_report" "$symbol_resolution_report" "$sema_report" "$typeck_report" "$borrowck_report" "$mir_lowering_report" "$mir_verification_report" "$backend_report" "$linker_report" "$runtime_execution_report"
}

render_surface_diagnostics_success_json() {
    src="$1"
    source_meta="$(source_meta_json "$src")"
    shape="$(compiler_shape_json "$src")"
    empty_report="$(empty_phase_report_json)"
    phase_reports="$(render_phase_reports_json "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report")"
    printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"diagnostics","source_path":"%s","valid":true,%s,%s,"frontend_diagnostic_count":0,"analysis_diagnostic_count":0,"sema_ok":true,"typeck_ok":true,"borrowck_ok":true,"lint_ok":true,"pipeline_failed_at":"none","primary_report":%s,"phase_reports":%s,"text_output":"diagnostics: ok"}\n' \
        "$(json_escape "$src")" "$source_meta" "$shape" "$empty_report" "$phase_reports"
}

render_professional_diagnostic_surface_json() {
    src="$1"
    info="$2"
    code="$(diag_field "$info" 1)"
    severity="$(diag_field "$info" 2)"
    phase="$(diag_field "$info" 3)"
    message="$(diag_field "$info" 4)"
    message="$(localized_diagnostic_message "$code" "$message")"
    line="$(diag_field "$info" 5)"
    col="$(diag_field "$info" 6)"
    end_col="$(diag_field "$info" 7)"
    label="$(diag_field "$info" 9)"
    note="$(diag_field "$info" 10)"
    help="$(diag_field "$info" 11)"
    help="$(localized_diagnostic_explain_field "$code" fix "$help")"
    source_meta="$(source_meta_json "$src")"
    shape="$(compiler_shape_json "$src")"
    src_json="$(json_escape "$src")"
    code_json="$(json_escape "$code")"
    severity_json="$(json_escape "$severity")"
    phase_json="$(json_escape "$phase")"
    msg_json="$(json_escape "$message")"
    label_json="$(json_escape "$label")"
    note_json="$(json_escape "$note")"
    help_json="$(json_escape "$help")"
    frontend_phase="$(phase_frontend_bool "$phase")"
    cause_a_json="$(json_escape "$phase:$code establishes the failing compiler constraint")"
    cause_b_json="$(json_escape "$message is the observed violation")"
    if [ "$phase" = "lexer" ]; then
        rule_json="$(json_escape "lexical token formation")"
        explanation_json="$(json_escape "The lexer could not form a valid token from this part of the source.")"
        technical_json="$(json_escape "Detected during tokenization before parsing. Source offsets are tracked in bytes.")"
        docs_json="$(json_escape "docs://language/lexer")"
        root_json="$(json_escape "lexer could not form a valid token from the source bytes at this location")"
    elif [ "$phase" = "parser" ]; then
        rule_json="$(json_escape "syntactic structure")"
        explanation_json="$(json_escape "The parser could not complete a valid syntactic structure from the token stream.")"
        technical_json="$(json_escape "Detected during parser recovery in the bootstrap shell fallback.")"
        docs_json="$(json_escape "docs://language/parser")"
        root_json="$(json_escape "parser could not complete a valid syntax tree")"
    elif [ "$phase" = "ast_validation" ]; then
        rule_json="$(json_escape "validated abstract syntax tree invariants")"
        explanation_json="$(json_escape "The parsed tree violated an AST structural invariant required by later compiler phases.")"
        technical_json="$(json_escape "Detected after parsing while validating AST structural invariants in the bootstrap shell fallback.")"
        docs_json="$(json_escape "docs://compiler/frontend/ast-validation")"
        root_json="$(json_escape "ast validation rejected the parsed module")"
    elif [ "$phase" = "module_resolution" ]; then
        rule_json="$(json_escape "module import resolution")"
        explanation_json="$(json_escape "The compiler could not resolve a referenced module in the current package graph.")"
        technical_json="$(json_escape "Detected while resolving module paths before symbol resolution.")"
        docs_json="$(json_escape "docs://compiler/modules/resolution")"
        root_json="$(json_escape "module resolution failed")"
    elif [ "$phase" = "symbol_resolution" ]; then
        rule_json="$(json_escape "name and symbol resolution")"
        explanation_json="$(json_escape "The compiler could not bind a referenced name to a visible declaration.")"
        technical_json="$(json_escape "Detected while resolving identifiers after module loading.")"
        docs_json="$(json_escape "docs://compiler/name-resolution")"
        root_json="$(json_escape "symbol resolution failed")"
    elif [ "$phase" = "sema" ]; then
        rule_json="$(json_escape "semantic validation")"
        explanation_json="$(json_escape "The source violates a semantic rule that is checked after name resolution.")"
        technical_json="$(json_escape "Detected during semantic analysis before detailed type checking.")"
        docs_json="$(json_escape "docs://compiler/sema")"
        root_json="$(json_escape "semantic validation failed")"
    elif [ "$phase" = "typeck" ]; then
        if [ "$code" = "TYPECK_E_ASSIGN_MISMATCH" ]; then
            rule_json="$(json_escape "assignment type compatibility")"
            explanation_json="$(json_escape "The initialized or assigned expression type does not satisfy the target binding type.")"
            technical_json="$(json_escape "Detected after expression inference while validating a local binding contract.")"
            docs_json="$(json_escape "docs://language/type-system/assignment-compatibility")"
            root_json="$(json_escape "assignment target type and expression type are incompatible")"
            cause_a_json="$(json_escape "the binding establishes the required target type")"
            cause_b_json="$(json_escape "the assigned expression infers an incompatible type")"
        elif [ "$code" = "TYPECK_E_RETURN_MISMATCH" ]; then
            rule_json="$(json_escape "procedure return compatibility")"
            explanation_json="$(json_escape "The returned expression type does not satisfy the procedure return type declared in its signature.")"
            technical_json="$(json_escape "Detected after expression inference while validating the active procedure return contract.")"
            docs_json="$(json_escape "docs://language/type-system/return-compatibility")"
            root_json="$(json_escape "procedure return type and expression type are incompatible")"
            cause_a_json="$(json_escape "the procedure signature establishes the required return type")"
            cause_b_json="$(json_escape "the returned expression infers an incompatible type")"
        elif [ "$code" = "TYPECK_E_ARGUMENT_MISMATCH" ]; then
            rule_json="$(json_escape "function argument compatibility")"
            explanation_json="$(json_escape "The argument expression type does not satisfy the corresponding parameter type in the resolved callable signature.")"
            technical_json="$(json_escape "Detected after argument inference while validating a local procedure or uniquely bound method call contract.")"
            docs_json="$(json_escape "docs://language/type-system/call-arguments")"
            root_json="$(json_escape "call argument type and parameter type are incompatible")"
            cause_a_json="$(json_escape "the callee signature establishes the required parameter type")"
            cause_b_json="$(json_escape "the call argument infers an incompatible type")"
        elif [ "$code" = "TYPECK_E_CALL_ARITY" ]; then
            rule_json="$(json_escape "function call arity")"
            explanation_json="$(json_escape "The number of call arguments does not match the number of parameters required by the resolved callable signature.")"
            technical_json="$(json_escape "Detected after resolving a local procedure or uniquely bound method and counting explicit arguments against fixed parameters.")"
            docs_json="$(json_escape "docs://language/type-system/call-arity")"
            root_json="$(json_escape "call argument count and callable parameter count differ")"
            cause_a_json="$(json_escape "the callee signature establishes the required argument count")"
            cause_b_json="$(json_escape "the call site provides a different argument count")"
        elif [ "$code" = "TYPECK_E_GENERIC_INFERENCE" ]; then
            rule_json="$(json_escape "generic inference completeness")"
            explanation_json="$(json_escape "A generic parameter remains unconstrained by explicit generic arguments or callable parameter types.")"
            technical_json="$(json_escape "Detected after local signature indexing and before a generic call can be monomorphized.")"
            docs_json="$(json_escape "docs://language/type-system/generic-inference")"
            root_json="$(json_escape "generic parameter cannot be resolved at the call site")"
            cause_a_json="$(json_escape "monomorphization requires every generic parameter to resolve")"
            cause_b_json="$(json_escape "available explicit arguments and parameter constraints leave one unresolved")"
        elif [ "$code" = "TYPECK_E_TRAIT_BOUND" ]; then
            rule_json="$(json_escape "trait bound satisfaction")"
            explanation_json="$(json_escape "The resolved generic type does not have a visible implementation of the trait required by its bound.")"
            technical_json="$(json_escape "Detected after generic argument resolution against locally declared trait implementations.")"
            docs_json="$(json_escape "docs://language/type-system/trait-bounds")"
            root_json="$(json_escape "generic type lacks the required trait implementation")"
            cause_a_json="$(json_escape "the generic signature establishes the required trait bound")"
            cause_b_json="$(json_escape "no visible implementation proves the resolved type satisfies that bound")"
        elif [ "$code" = "TYPECK_E_CONFLICTING_IMPL" ]; then
            rule_json="$(json_escape "trait implementation coherence")"
            explanation_json="$(json_escape "The same trait is implemented more than once for the same target type in the visible module.")"
            technical_json="$(json_escape "Detected while indexing local trait implementation pairs before expression checking.")"
            docs_json="$(json_escape "docs://language/type-system/trait-coherence")"
            root_json="$(json_escape "multiple implementations target the same trait and type")"
            cause_a_json="$(json_escape "the first visible impl establishes the trait and target pair")"
            cause_b_json="$(json_escape "a later impl declares the identical trait and target pair")"
        elif [ "$code" = "TYPECK_E_CONSTRAINT_CYCLE" ]; then
            rule_json="$(json_escape "generic constraint acyclicity")"
            explanation_json="$(json_escape "Following dependencies between generic parameter bounds reaches the same parameter again.")"
            technical_json="$(json_escape "Detected by a bounded walk over the local generic constraint graph.")"
            docs_json="$(json_escape "docs://language/type-system/generic-constraints")"
            root_json="$(json_escape "generic parameter bounds form a dependency cycle")"
            cause_a_json="$(json_escape "constraint resolution starts from a generic parameter")"
            cause_b_json="$(json_escape "following direct bounds reaches that parameter again")"
        elif [ "$code" = "TYPECK_E_INVALID_CAST" ]; then
            rule_json="$(json_escape "explicit cast validity")"
            explanation_json="$(json_escape "The source and target types do not form a supported explicit scalar conversion.")"
            technical_json="$(json_escape "Detected after inferring the literal source type and resolving the written cast target.")"
            docs_json="$(json_escape "docs://language/type-system/casts")"
            root_json="$(json_escape "explicit cast crosses unsupported type representations")"
            cause_a_json="$(json_escape "the cast target establishes the requested representation")"
            cause_b_json="$(json_escape "the source literal has an incompatible representation")"
        elif [ "$code" = "TYPECK_E_MATCH_NON_EXHAUSTIVE" ]; then
            rule_json="$(json_escape "pattern coverage completeness")"
            explanation_json="$(json_escape "A finite match omits at least one case and has no fallback arm.")"
            technical_json="$(json_escape "Detected after resolving a local bool or pick scrutinee and comparing its finite cases with the parsed arms.")"
            docs_json="$(json_escape "docs://language/type-system/match-exhaustiveness")"
            root_json="$(json_escape "finite match case coverage is incomplete")"
            cause_a_json="$(json_escape "the scrutinee type establishes a finite set of cases")"
            cause_b_json="$(json_escape "the match arms omit one case without an else or wildcard fallback")"
        elif [ "$code" = "TYPECK_E_IMPL_SIGNATURE_MISMATCH" ]; then
            rule_json="$(json_escape "implementation signature compatibility")"
            explanation_json="$(json_escape "An implementation method differs from the corresponding trait method in arity, parameter types, or return type.")"
            technical_json="$(json_escape "Detected after indexing local trait method signatures and comparing each visible implementation member.")"
            docs_json="$(json_escape "docs://language/type-system/trait-implementations")"
            root_json="$(json_escape "implementation method signature is incompatible with its trait contract")"
            cause_a_json="$(json_escape "the trait declaration establishes the required method signature")"
            cause_b_json="$(json_escape "the implementation declares a method with a different signature component")"
        elif [ "$code" = "TYPECK_E_IMPL_MISSING_MEMBER" ]; then
            rule_json="$(json_escape "implementation completeness")"
            explanation_json="$(json_escape "A local trait implementation omits a method required by the implemented trait.")"
            technical_json="$(json_escape "Detected after indexing all methods in the implementation and comparing their names with the local trait contract.")"
            docs_json="$(json_escape "docs://language/type-system/trait-implementations")"
            root_json="$(json_escape "implementation does not provide every required trait member")"
            cause_a_json="$(json_escape "the trait declaration establishes the required method set")"
            cause_b_json="$(json_escape "the completed implementation scan does not contain one required method")"
        elif [ "$code" = "TYPECK_E_IMPL_UNKNOWN_TRAIT" ]; then
            rule_json="$(json_escape "implementation trait resolution")"
            explanation_json="$(json_escape "An implementation names a trait that is not declared anywhere in the local module.")"
            technical_json="$(json_escape "Detected after scanning every top-level declaration so trait references are independent of source order.")"
            docs_json="$(json_escape "docs://language/type-system/trait-implementations")"
            root_json="$(json_escape "implementation trait name does not resolve to a local declaration")"
            cause_a_json="$(json_escape "an implementation requires its trait name to resolve after module indexing")"
            cause_b_json="$(json_escape "the complete local trait index contains no declaration with that name")"
        elif [ "$code" = "TYPECK_E_AMBIGUOUS_METHOD" ]; then
            rule_json="$(json_escape "unique method candidate")"
            explanation_json="$(json_escape "More than one visible trait implementation provides the requested method for the receiver type.")"
            technical_json="$(json_escape "Detected after indexing local impl method providers and resolving the receiver binding type.")"
            docs_json="$(json_escape "docs://language/type-system/method-resolution")"
            root_json="$(json_escape "method lookup has multiple visible providers for the receiver type")"
            cause_a_json="$(json_escape "method dispatch requires exactly one provider after receiver type resolution")"
            cause_b_json="$(json_escape "the local impl index contains multiple traits providing that method")"
        else
            rule_json="$(json_escape "type checking")"
            explanation_json="$(json_escape "The source violates a type-system rule enforced by the compiler.")"
            technical_json="$(json_escape "Detected during type inference or type compatibility checking.")"
            docs_json="$(json_escape "docs://compiler/type-system")"
            root_json="$(json_escape "type checking failed")"
        fi
    elif [ "$phase" = "borrowck" ]; then
        rule_json="$(json_escape "ownership and borrow checking")"
        explanation_json="$(json_escape "The source violates ownership or borrow safety rules.")"
        technical_json="$(json_escape "Detected during borrow checking after type checking.")"
        docs_json="$(json_escape "docs://compiler/borrowck")"
        root_json="$(json_escape "borrow checking failed")"
    elif [ "$phase" = "mir_lowering" ]; then
        rule_json="$(json_escape "MIR lowering")"
        explanation_json="$(json_escape "The compiler could not lower validated high-level constructs into MIR.")"
        technical_json="$(json_escape "Detected while constructing MIR from validated program structures.")"
        docs_json="$(json_escape "docs://compiler/mir/lowering")"
        root_json="$(json_escape "MIR lowering failed")"
    elif [ "$phase" = "mir_verification" ]; then
        rule_json="$(json_escape "MIR structural verification")"
        explanation_json="$(json_escape "The generated MIR violates an invariant required by later passes or code generation.")"
        technical_json="$(json_escape "Detected after MIR construction while checking control-flow and operand invariants.")"
        docs_json="$(json_escape "docs://compiler/mir/verification")"
        root_json="$(json_escape "MIR verification failed")"
    elif [ "$phase" = "backend" ]; then
        rule_json="$(json_escape "backend emission")"
        explanation_json="$(json_escape "The backend could not emit a valid lower-level artifact for the selected target.")"
        technical_json="$(json_escape "Detected while converting MIR or equivalent IR into backend output.")"
        docs_json="$(json_escape "docs://compiler/backend")"
        root_json="$(json_escape "backend emission failed")"
    elif [ "$phase" = "linker" ]; then
        rule_json="$(json_escape "link step")"
        explanation_json="$(json_escape "The linker could not combine generated artifacts into a final executable or library.")"
        technical_json="$(json_escape "Detected after backend emission while invoking or simulating the link step.")"
        docs_json="$(json_escape "docs://compiler/linker")"
        root_json="$(json_escape "link step failed")"
    elif [ "$phase" = "runtime_execution" ]; then
        rule_json="$(json_escape "runtime execution")"
        explanation_json="$(json_escape "The compiled program failed while executing under the bootstrap runtime contract.")"
        technical_json="$(json_escape "Detected after a successful compile pipeline during program execution.")"
        docs_json="$(json_escape "docs://compiler/runtime")"
        root_json="$(json_escape "runtime execution failed")"
    else
        rule_json="$(json_escape "compiler diagnostic rule")"
        explanation_json="$(json_escape "The compiler emitted a diagnostic with an unrecognized phase tag. This is a compiler bug.")"
        technical_json="$(json_escape "bootstrap shell fallback received an unknown phase and preserved it verbatim.")"
        docs_json="$(json_escape "docs://compiler/diagnostics")"
        root_json="$(json_escape "unknown diagnostic phase")"
    fi
    text_output="$(printf '%s[%s] %s: %s\n  --> %s:%s:%s\n  note: %s\n  help: %s' "$severity" "$code" "$phase" "$message" "$src" "$line" "$col" "$note" "$help")"
    text_output_json="$(json_escape "$text_output")"
    diag_json="$(printf '{"code":"%s","severity":"%s","phase":"%s","rule":"%s","message":"%s","explanation":"%s","technical_note":"%s","span":{"file":"%s","start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s,"length":%s,"valid":true},"labels":[{"kind":"primary","message":"%s","span":{"file":"%s","start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s,"length":%s,"valid":true},"primary":true,"valid":true}],"notes":[{"message":"%s","valid":true}],"helps":[{"message":"%s","valid":true}],"suggestions":[],"documentation_url":"%s","root_cause":"%s","cause_chain":["%s","%s"],"pipeline_context":["phase=%s","step=bootstrap shell diagnostic fallback"],"related_errors":[],"probable_fix":"%s","subject_symbol":"","subject_type":"","subject_borrow":"","deprecated":false,"unnecessary":false,"fatal":false,"valid":true}' \
        "$code_json" "$severity_json" "$phase_json" "$rule_json" "$msg_json" "$explanation_json" "$technical_json" "$src_json" "$line" "$col" "$line" "$end_col" "$((end_col - col))" "$label_json" "$src_json" "$line" "$col" "$line" "$end_col" "$((end_col - col))" "$note_json" "$help_json" "$docs_json" "$root_json" "$cause_a_json" "$cause_b_json" "$phase_json" "$help_json")"
    empty_report="$(empty_phase_report_json)"
    lexer_report="$empty_report"
    parser_report="$empty_report"
    ast_validation_report="$empty_report"
    module_resolution_report="$empty_report"
    symbol_resolution_report="$empty_report"
    sema_report="$empty_report"
    typeck_report="$empty_report"
    borrowck_report="$empty_report"
    mir_lowering_report="$empty_report"
    mir_verification_report="$empty_report"
    backend_report="$empty_report"
    linker_report="$empty_report"
    runtime_execution_report="$empty_report"
    report_json="$(printf '{"valid": false, "error_count": 1, "warning_count": 0, "fatal_count": 0, "diagnostics": [%s]}' "$diag_json")"
    if [ "$phase" = "lexer" ]; then
        lexer_report="$report_json"
    elif [ "$phase" = "parser" ]; then
        parser_report="$report_json"
    elif [ "$phase" = "ast_validation" ]; then
        ast_validation_report="$report_json"
    elif [ "$phase" = "module_resolution" ]; then
        module_resolution_report="$report_json"
    elif [ "$phase" = "symbol_resolution" ]; then
        symbol_resolution_report="$report_json"
    elif [ "$phase" = "sema" ]; then
        sema_report="$report_json"
    elif [ "$phase" = "typeck" ]; then
        typeck_report="$report_json"
    elif [ "$phase" = "borrowck" ]; then
        borrowck_report="$report_json"
    elif [ "$phase" = "mir_lowering" ]; then
        mir_lowering_report="$report_json"
    elif [ "$phase" = "mir_verification" ]; then
        mir_verification_report="$report_json"
    elif [ "$phase" = "backend" ]; then
        backend_report="$report_json"
    elif [ "$phase" = "linker" ]; then
        linker_report="$report_json"
    elif [ "$phase" = "runtime_execution" ]; then
        runtime_execution_report="$report_json"
    fi
    phase_reports="$(render_phase_reports_json "$lexer_report" "$parser_report" "$ast_validation_report" "$module_resolution_report" "$symbol_resolution_report" "$sema_report" "$typeck_report" "$borrowck_report" "$mir_lowering_report" "$mir_verification_report" "$backend_report" "$linker_report" "$runtime_execution_report")"
    printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"diagnostics","source_path":"%s","valid":false,%s,%s,"frontend_diagnostic_count":%s,"analysis_diagnostic_count":%s,"sema_ok":%s,"typeck_ok":%s,"borrowck_ok":%s,"lint_ok":true,"pipeline_failed_at":"%s","primary_report":%s,"phase_reports":%s,"text_output":"%s"}\n' \
        "$src_json" "$source_meta" "$shape" \
        "$(if [ "$frontend_phase" = "true" ]; then printf '1'; else printf '0'; fi)" \
        "$(if [ "$frontend_phase" = "true" ]; then printf '0'; else printf '1'; fi)" \
        "$(phase_sema_success_bool "$phase")" "$(phase_success_bool typeck "$phase")" "$(phase_success_bool borrowck "$phase")" "$phase_json" "$report_json" "$phase_reports" "$text_output_json"
}

render_type_mismatch_text() {
    src="$1"
    info="$2"
    code="TYPECK_E_ASSIGN_MISMATCH"
    name="$(diag_field "$info" 1)"
    expected="$(diag_field "$info" 2)"
    found="$(diag_field "$info" 3)"
    message="$(localized_diagnostic_message "$code" "cannot assign value of type $found to variable of type $expected")"
    line="$(diag_field "$info" 4)"
    col="$(diag_field "$info" 5)"
    decl_line="$(diag_field "$info" 6)"
    decl_col="$(diag_field "$info" 7)"
    mark_len="$(diag_field "$info" 8)"
    text="$(diag_field "$info" 9)"
    marker="$(repeat_char '^' "$mark_len")"
    before="$(repeat_char ' ' $((col - 1)))"
    help="$(localized_diagnostic_explain_field "$code" fix "change the value type or update the variable annotation")"
    printf 'error[%s]: %s\n' "$code" "$message"
    printf '  --> %s:%s:%s\n' "$src" "$line" "$col"
    printf '   |\n'
    printf '%2s | %s\n' "$line" "$text"
    printf '   | %s%s expected %s, found %s\n' "$before" "$marker" "$expected" "$found"
    printf '   |\n'
    printf 'note: variable %s was declared here: %s:%s:%s\n' "$name" "$src" "$decl_line" "$decl_col"
    printf 'help: %s\n' "$help"
}

render_type_mismatch_json() {
    src="$1"
    info="$2"
    code="TYPECK_E_ASSIGN_MISMATCH"
    name="$(diag_field "$info" 1)"
    expected="$(diag_field "$info" 2)"
    found="$(diag_field "$info" 3)"
    line="$(diag_field "$info" 4)"
    col="$(diag_field "$info" 5)"
    decl_line="$(diag_field "$info" 6)"
    decl_col="$(diag_field "$info" 7)"
    mark_len="$(diag_field "$info" 8)"
    src_json="$(json_escape "$src")"
    msg="$(localized_diagnostic_message "$code" "cannot assign value of type $found to variable of type $expected")"
    msg_json="$(json_escape "$msg")"
    label_json="$(json_escape "expected $expected, found $found")"
    note_json="$(json_escape "variable $name was declared here")"
    help="$(localized_diagnostic_explain_field "$code" fix "change the value type or update the variable annotation")"
    help_json="$(json_escape "$help")"
    printf '{"schema":"vitte.compiler.diagnostics","schema_version":"1.0.0","status":"error","diagnostics":{"error_count":1,"warning_count":0,"items":[{"code":"TYPECK_E_ASSIGN_MISMATCH","severity":"error","phase":"typeck","file":"%s","span":{"start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s},"message":"%s","labels":[{"kind":"primary","message":"%s","span":{"start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s}}],"notes":[{"message":"%s","span":{"start_line":%s,"start_column":%s}}],"help":[{"message":"%s"}]}]}}\n' \
        "$src_json" "$line" "$col" "$line" "$((col + mark_len))" "$msg_json" "$label_json" "$line" "$col" "$line" "$((col + mark_len))" "$note_json" "$decl_line" "$decl_col" "$help_json"
}

render_type_mismatch_surface_json() {
    src="$1"
    info="$2"
    code="TYPECK_E_ASSIGN_MISMATCH"
    name="$(diag_field "$info" 1)"
    expected="$(diag_field "$info" 2)"
    found="$(diag_field "$info" 3)"
    line="$(diag_field "$info" 4)"
    col="$(diag_field "$info" 5)"
    decl_line="$(diag_field "$info" 6)"
    decl_col="$(diag_field "$info" 7)"
    mark_len="$(diag_field "$info" 8)"
    source_meta="$(source_meta_json "$src")"
    shape="$(compiler_shape_json "$src")"
    src_json="$(json_escape "$src")"
    msg="$(localized_diagnostic_message "$code" "cannot assign value of type $found to variable of type $expected")"
    msg_json="$(json_escape "$msg")"
    explanation_json="$(json_escape "The left side of this assignment expects $expected, but the right side produces $found. Vitte does not perform implicit conversion here.")"
    technical_json="$(json_escape "The type checker compares the inferred expression type against the target binding type during assignment validation.")"
    note_json="$(json_escape "variable $name was declared here")"
    help="$(localized_diagnostic_explain_field "$code" fix "change the variable type to $found or assign a value of type $expected")"
    help_json="$(json_escape "$help")"
    probable_fix_json="$(json_escape "change the variable type to $found or assign a value of type $expected")"
    root_json="$(json_escape "assignment target type and expression type are incompatible")"
    cause_a_json="$(json_escape "binding $name expects $expected")"
    cause_b_json="$(json_escape "assigned expression produced $found")"
    label_json="$(json_escape "expected $expected, found $found")"
    decl_label_json="$(json_escape "variable $name was declared here as $expected")"
    docs_json="$(json_escape "docs://language/type-system/assignment-compatibility")"
    text_output="$(printf 'error[TYPECK_E_ASSIGN_MISMATCH] typeck: %s\n --> %s:%s:%s\n  primary: %s:%s:%s expected %s, found %s\n  secondary: %s:%s:%s variable %s was declared here as %s\n  rule: assignment type compatibility\n  symbol: %s\n  type: %s\n  explanation: The left side of this assignment expects %s, but the right side produces %s. Vitte does not perform implicit conversion here.\n  technical_note: The type checker compares the inferred expression type against the target binding type during assignment validation.\n  root_cause: assignment target type and expression type are incompatible\n  probable_fix: %s\n  cause: binding %s expects %s\n  cause: assigned expression produced %s\n  pipeline: phase=typeck\n  pipeline: step=type inference and assignment compatibility\n  related: TYPECK_E_BINARY_MISMATCH\n  note: variable %s was declared here\n  help: %s\n  docs: docs://language/type-system/assignment-compatibility' "$msg" "$src" "$line" "$col" "$src" "$line" "$col" "$expected" "$found" "$src" "$decl_line" "$decl_col" "$name" "$expected" "$name" "$expected" "$expected" "$found" "$help" "$name" "$expected" "$found" "$name" "$help")"
    text_output_json="$(json_escape "$text_output")"
    diag_json="$(printf '{"code":"TYPECK_E_ASSIGN_MISMATCH","severity":"error","phase":"typeck","rule":"assignment type compatibility","message":"%s","explanation":"%s","technical_note":"%s","span":{"file":"%s","start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s,"length":%s,"valid":true},"labels":[{"kind":"primary","message":"%s","span":{"file":"%s","start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s,"length":%s,"valid":true},"primary":true,"valid":true},{"kind":"secondary","message":"%s","span":{"file":"%s","start_line":%s,"start_column":%s,"end_line":%s,"end_column":%s,"length":%s,"valid":true},"primary":false,"valid":true}],"notes":[{"message":"%s","valid":true}],"helps":[{"message":"%s","valid":true}],"suggestions":[],"documentation_url":"%s","root_cause":"%s","cause_chain":["%s","%s"],"pipeline_context":["phase=typeck","step=type inference and assignment compatibility"],"related_errors":["TYPECK_E_BINARY_MISMATCH"],"probable_fix":"%s","subject_symbol":"%s","subject_type":"%s","subject_borrow":"","deprecated":false,"unnecessary":false,"fatal":false,"valid":true}' \
        "$msg_json" "$explanation_json" "$technical_json" "$src_json" "$line" "$col" "$line" "$((col + mark_len))" "$mark_len" "$label_json" "$src_json" "$line" "$col" "$line" "$((col + mark_len))" "$mark_len" "$decl_label_json" "$src_json" "$decl_line" "$decl_col" "$decl_line" "$((decl_col + ${#name}))" "${#name}" "$note_json" "$help_json" "$docs_json" "$root_json" "$cause_a_json" "$cause_b_json" "$probable_fix_json" "$(json_escape "$name")" "$(json_escape "$expected")")"
    report_json="$(printf '{"valid": false, "error_count": 1, "warning_count": 0, "fatal_count": 0, "diagnostics": [%s]}' "$diag_json")"
    empty_report="$(empty_phase_report_json)"
    phase_reports="$(render_phase_reports_json "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$report_json" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report" "$empty_report")"
    printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"diagnostics","source_path":"%s","valid":false,%s,%s,"frontend_diagnostic_count":0,"analysis_diagnostic_count":1,"sema_ok":true,"typeck_ok":false,"borrowck_ok":false,"lint_ok":true,"pipeline_failed_at":"typeck","primary_report":%s,"phase_reports":%s,"text_output":"%s"}\n' \
        "$src_json" "$source_meta" "$shape" "$report_json" "$phase_reports" "$text_output_json"
}

explain_code_from_args() {
    while [ "$#" -gt 0 ]; do
        case "$1" in
            explain|--trace-pipeline|--strict)
                ;;
            --lang)
                shift
                ;;
            --lang=*)
                ;;
            --*)
                ;;
            *)
                printf '%s\n' "$1"
                return 0
                ;;
        esac
        shift
    done
    return 1
}

print_explain_text() {
    code="$1"
    lang="$(normalize_diagnostics_lang "$diagnostics_lang")"
    phase="parser"
    message="expected identifier"
    summary="The parser expected a name but did not find one."
    cause="A declaration, binding, or reference is missing its identifier."
    step1="Add a valid identifier at the highlighted location."
    fix="Insert a name using letters, digits, or underscores."
    example="let value = 1"

    case "$code" in
        E0001)
            if [ "$lang" = "fr" ]; then
                message="identifiant attendu"
                summary="Le parseur attendait un nom mais n'en a pas trouve."
                cause="Une declaration, une liaison ou une reference n'a pas d'identifiant."
                step1="Ajoutez un identifiant valide a l'emplacement signale."
                fix="Inserez un nom avec des lettres, des chiffres ou des underscores."
                example="let valeur = 1"
            fi
            ;;
        TYPECK_E_ASSIGN_MISMATCH)
            phase="typeck"
            message="cannot assign value of this type to the target variable"
            summary="The assignment target and the assigned expression have incompatible types."
            cause="The target binding type does not match the expression type."
            step1="Check the variable declaration and the expression being assigned."
            fix="Change the variable type or assign a value of the expected type."
            example="let count: int = 1"
            ;;
        BORROWCK_E_USE_AFTER_MOVE)
            phase="borrowck"
            message="use after move"
            summary="A value is used after ownership was moved elsewhere."
            cause="The previous operation transferred ownership, so the original binding is no longer valid."
            step1="Find the earlier move and decide whether the value should be borrowed, cloned, or recreated."
            fix="Borrow the value, clone it before the move, or stop using the moved binding."
            example="let copy = value.clone()"
            ;;
        P000_UNBALANCED)
            message="unbalanced delimiter"
            summary="The parser reached the end of input with an open delimiter."
            cause="A parenthesis, bracket, or brace was opened without a matching close."
            step1="Match each opening delimiter with the corresponding closing delimiter."
            fix="Insert the missing closing delimiter."
            example="proc main() -> int { give 0; }"
            ;;
        *)
            phase="diagnostics"
            message="diagnostic code is known by the full catalog when available"
            summary="The bootstrap compiler can explain core diagnostics and leaves other codes to the generated catalog."
            cause="This seed runtime carries a compact fallback catalog."
            step1="Run the full compiler build for the complete localized explanation."
            fix="Use bin/vitte when a host compiler exists, otherwise keep this code for support."
            example="vitte explain $code --lang $lang"
            ;;
    esac

    root_dir="$(vitte_root_dir)"
    diag_file="$root_dir/locales/$lang/diagnostics.ftl"
    explain_file="$root_dir/locales/$lang/diagnostics_explain.ftl"
    message="$(ftl_lookup "$diag_file" "$code" || printf '%s' "$message")"
    summary="$(ftl_lookup "$explain_file" "$code.summary" || printf '%s' "$summary")"
    cause="$(ftl_lookup "$explain_file" "$code.cause" || printf '%s' "$cause")"
    step1="$(ftl_lookup "$explain_file" "$code.step1" || printf '%s' "$step1")"
    fix="$(ftl_lookup "$explain_file" "$code.fix" || printf '%s' "$fix")"
    example="$(ftl_lookup "$explain_file" "$code.example" || printf '%s' "$example")"

    printf 'error code: %s\n' "$code"
    printf 'lang: %s\n' "$lang"
    printf 'phase: %s\n' "$phase"
    printf 'message: %s\n' "$message"
    printf 'summary: %s\n' "$summary"
    printf 'cause: %s\n' "$cause"
    printf 'step 1: %s\n' "$step1"
    printf 'fix: %s\n' "$fix"
    printf 'example: %s\n' "$example"
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --trace-pipeline)
            trace_pipeline=1
            shift
            ;;
        --strict)
            strict_mode=1
            shift
            ;;
        --lang)
            shift
            [ "$#" -gt 0 ] || { cli_error E_CLI_MISSING_ARG "--lang requires a value" "use --lang en"; exit 2; }
            diagnostics_lang="$1"
            shift
            ;;
        --lang=*)
            diagnostics_lang="${1#--lang=}"
            shift
            ;;
        *)
            break
            ;;
    esac
done

cmd="${1:-}"
case "$cmd" in
    "")
        if [ -n "$compiler_source_root" ] || [ -n "$compiler_entry_point" ]; then
            print_compiler_brief_help
            exit 0
        fi
        printf '%s\n' "$banner"
        exit "$main_return"
        ;;
    --version)
        printf '%s\n' "$version"
        ;;
    --help|-h|help)
        if [ -n "$compiler_source_root" ] || [ -n "$compiler_entry_point" ]; then
            print_compiler_help
        else
            printf '%s\n' "$banner"
            printf 'version: %s\n' "$version"
        fi
        ;;
    explain)
        read_common_flags "$@"
        code="$(explain_code_from_args "$@" || true)"
        [ -n "$code" ] || { cli_error E_CLI_MISSING_ARG "explain requires a diagnostic code" "vitte explain E0001 --lang en"; exit 2; }
        print_explain_text "$code"
        ;;
    pkg)
        subcmd="${2:-help}"
        case "$subcmd" in
            help|--help|-h)
                printf 'pkg subcommands:\n'
                printf '  check    validate packages under src/vitte/packages\n'
                printf '  matrix   run package dependency/import diagnostics matrix\n'
                printf '  selftest run package checks and matrix\n'
                ;;
            check)
                tools/package_check_all.sh
                ;;
            matrix)
                tools/pkg_matrix.sh
                ;;
            selftest)
                tools/package_check_all.sh >/dev/null
                tools/pkg_matrix.sh >/dev/null
                printf '[pkg] selftest ok\n'
                ;;
            *)
                cli_error E_CLI_COMMAND "unknown pkg subcommand: $subcmd" "use 'vitte pkg --help'"
                exit 2
                ;;
        esac
        ;;
    selfhost-source|--selfhost-source)
        printf 'compiler_source_root=%s\n' "$compiler_source_root"
        printf 'compiler_entry_point=%s\n' "$compiler_entry_point"
        ;;
    parse)
        read_common_flags "$@"
        trace_step "pipeline.parse:begin"
        dump_ast_json=0
        if has_flag --dump-ast-json "$@"; then
            dump_ast_json=1
        fi
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "parse requires --src or file" "vittec parse --src path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        trace_step "pipeline.parse:compile-native-ir"
        compile_native_ir "$src" "v1" >/dev/null
        trace_step "pipeline.parse:ok"
        if [ "$dump_ast_json" -eq 1 ]; then
            source_meta="$(source_meta_json "$src")"
            shape="$(compiler_shape_json "$src")"
            proc_count="$(grep -c '^proc[ \t]' "$src" || true)"
            const_count="$(grep -c '^const[ \t]' "$src" || true)"
            ast_node_count=$((proc_count + const_count + 2))
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"ast","producer":"vittec-bootstrap-seed","command":"parse","status":"ok",%s,%s,"ast":{"kind":"bootstrap-structural","node_count":%s,"root":{"kind":"module","child_count":%s}}}\n' "$source_meta" "$shape" "$ast_node_count" "$ast_node_count"
        else
            echo "parse ok: $src"
        fi
        ;;
    check)
        read_common_flags "$@"
        trace_step "pipeline.check:begin"
        diagnostics_json=0
        dump_hir_json=0
        dump_mir_json=0
        if has_flag --diagnostics-json "$@" || has_flag --diag-json "$@"; then
            diagnostics_json=1
        fi
        if has_flag --dump-hir-json "$@"; then
            dump_hir_json=1
        fi
        if has_flag --dump-mir-json "$@"; then
            dump_mir_json=1
        fi
        src="$(first_file_arg "$@" || true)"
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "missing input file" "vittec check path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        ir_version="$(arg_value --ir-version "$@" || true)"
        [ -n "$ir_version" ] || ir_version="v1"
        [ "$ir_version" = "v1" ] || [ "$ir_version" = "v2" ] || { cli_error E_CLI_ARG "unsupported --ir-version: $ir_version" "supported: v1, v2"; exit 2; }
        if [ "$diagnostics_json" -eq 1 ]; then
            if mismatch_info="$(detect_type_mismatch "$src")"; then
                trace_step "pipeline.check:type-mismatch-json"
                render_type_mismatch_surface_json "$src" "$mismatch_info"
                exit 1
            fi
        fi
        if diag_info="$(detect_professional_diagnostic "$src")"; then
            trace_step "pipeline.check:professional-diagnostic"
            if [ "$diagnostics_json" -eq 1 ]; then
                render_professional_diagnostic_surface_json "$src" "$diag_info"
            else
                render_professional_diagnostic_text "$src" "$diag_info" >&2
            fi
            exit 1
        fi
        if parser_info="$(detect_simple_unclosed_block "$src")"; then
            trace_step "pipeline.check:parser-fallback-diagnostic"
            if [ "$diagnostics_json" -eq 1 ]; then
                render_professional_diagnostic_surface_json "$src" "$parser_info"
            else
                render_professional_diagnostic_text "$src" "$parser_info" >&2
            fi
            exit 1
        fi
        if [ "$strict_mode" -eq 1 ]; then
            trace_step "pipeline.parse:from-check"
            compile_native_ir "$src" "$ir_version" >/dev/null
            trace_step "pipeline.check:semantic"
            if [ "$strict_mode" -eq 1 ] && ! grep -q "^export [*]$" "$src"; then
                cli_error E_STRICT_EXPORT "strict mode requires export * in bootstrap source" "add 'export *' to the module footer"
                exit 1
            fi
            if [ "$strict_mode" -eq 1 ]; then
                space_count="$(grep -c '^space[ 	]' "$src" || true)"
                [ "$space_count" -eq 1 ] || { cli_error E_STRICT_SPACE "strict mode requires exactly one space declaration" "keep one top-level 'space <name>'"; exit 1; }
                version_count="$(grep -c "^proc[ 	]\+version_text()[ 	]*->[ 	]*string[ 	]*{$" "$src" || true)"
                [ "$version_count" -eq 1 ] || { cli_error E_STRICT_VERSION_TEXT "strict mode requires exactly one version_text() proc" "declare one 'proc version_text() -> string {'"; exit 1; }
                banner_count="$(grep -c "^proc[ 	]\+banner_text()[ 	]*->[ 	]*string[ 	]*{$" "$src" || true)"
                [ "$banner_count" -eq 1 ] || { cli_error E_STRICT_BANNER_TEXT "strict mode requires exactly one banner_text() proc" "declare one 'proc banner_text() -> string {'"; exit 1; }
            fi
        fi
        trace_step "pipeline.check:ok"
        if [ "$diagnostics_json" -eq 1 ]; then
            render_surface_diagnostics_success_json "$src"
        fi
        if [ "$dump_hir_json" -eq 1 ]; then
            source_meta="$(source_meta_json "$src")"
            shape="$(compiler_shape_json "$src")"
            proc_count="$(grep -c '^proc[ \t]' "$src" || true)"
            form_count="$(grep -c '^form[ \t]' "$src" || true)"
            hir_node_count=$((proc_count + form_count))
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"hir","producer":"vittec-bootstrap-seed","command":"check","status":"ok",%s,%s,"hir":{"kind":"bootstrap-structural","node_count":%s,"nodes":[]}}\n' "$source_meta" "$shape" "$hir_node_count"
        fi
        if [ "$dump_mir_json" -eq 1 ]; then
            source_meta="$(source_meta_json "$src")"
            shape="$(compiler_shape_json "$src")"
            proc_count="$(grep -c '^proc[ \t]' "$src" || true)"
            mir_block_count=$((proc_count + 1))
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"mir","producer":"vittec-bootstrap-seed","command":"check","status":"ok",%s,%s,"mir":{"kind":"bootstrap-structural","block_count":%s,"blocks":[]}}\n' "$source_meta" "$shape" "$mir_block_count"
        fi
        if [ "$diagnostics_json" -eq 0 ] && [ "$dump_hir_json" -eq 0 ] && [ "$dump_mir_json" -eq 0 ]; then
            printf 'check succeeded\n'
        fi
        ;;
    run)
        read_common_flags "$@"
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "run requires --src or file" "vittec run path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        tmp_bin="$(mktemp "${TMPDIR:-/tmp}/vittec-run-XXXXXX")"
        rm -f "$tmp_bin"
        trace_step "pipeline.backend:native-bootstrap-subset"
        set +e
        build_native_user_program "$src" "$tmp_bin"
        rc="$?"
        set -e
        if [ "$rc" -ne 0 ]; then
            if [ "$rc" -eq 125 ]; then
                trace_step "pipeline.backend:delegate-generic"
                set +e
                delegate_generic_backend_run "$src"
                rc="$?"
                set -e
                exit "$rc"
            fi
            exit 3
        fi
        set +e
        "$tmp_bin"
        run_rc=$?
        set -e
        rm -f "$tmp_bin"
        exit "$run_rc"
        ;;
    dump-tokens)
        read_common_flags "$@"
        dump_json=0
        if has_flag --json "$@"; then
            dump_json=1
        fi
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "dump-tokens requires --src or file" "vittec dump-tokens path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        if [ "$dump_json" -eq 1 ]; then
            token_json="$(tr ' \t\r\n' '\n' < "$src" | sed '/^$/d' | awk '
                BEGIN {
                    first = 1;
                    printf "[";
                }
                {
                    gsub(/\\/,"\\\\",$0);
                    gsub(/"/,"\\\"",$0);
                    if (!first) {
                        printf ",";
                    }
                    printf "\"%s\"", $0;
                    first = 0;
                }
                END {
                    printf "]";
                }
            ')"
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"tokens","producer":"vittec-bootstrap-seed","command":"dump-tokens","status":"ok","source":{"path":"%s"},"tokens":%s}\n' "$src" "$token_json"
        else
            tr ' \t\r\n' '\n' < "$src" | sed '/^$/d'
        fi
        ;;
    dump-ast)
        read_common_flags "$@"
        dump_json=0
        if has_flag --json "$@"; then
            dump_json=1
        fi
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "dump-ast requires --src or file" "vittec dump-ast path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        source_meta="$(source_meta_json "$src")"
        shape="$(compiler_shape_json "$src")"
        proc_count="$(grep -c '^proc[ \t]' "$src" || true)"
        const_count="$(grep -c '^const[ \t]' "$src" || true)"
        ast_node_count=$((proc_count + const_count + 2))
        if [ "$dump_json" -eq 1 ]; then
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"ast","producer":"vittec-bootstrap-seed","command":"dump-ast","status":"ok",%s,%s,"ast":{"kind":"bootstrap-structural","node_count":%s,"root":{"kind":"module","child_count":%s}}}\n' "$source_meta" "$shape" "$ast_node_count" "$ast_node_count"
        else
            printf 'AST\n'
            printf 'source: %s\n' "$src"
            printf 'kind: bootstrap-structural\n'
            printf 'node_count: %s\n' "$ast_node_count"
            printf 'root.kind: module\n'
            printf 'root.child_count: %s\n' "$ast_node_count"
        fi
        ;;
    dump-hir)
        read_common_flags "$@"
        dump_json=0
        if has_flag --json "$@"; then
            dump_json=1
        fi
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "dump-hir requires --src or file" "vittec dump-hir path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        if diag_info="$(detect_professional_diagnostic "$src")"; then
            render_professional_diagnostic_text "$src" "$diag_info" >&2
            exit 1
        fi
        source_meta="$(source_meta_json "$src")"
        shape="$(compiler_shape_json "$src")"
        proc_count="$(grep -c '^proc[ \t]' "$src" || true)"
        form_count="$(grep -c '^form[ \t]' "$src" || true)"
        hir_node_count=$((proc_count + form_count))
        if [ "$dump_json" -eq 1 ]; then
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"hir","producer":"vittec-bootstrap-seed","command":"dump-hir","status":"ok",%s,%s,"hir":{"kind":"bootstrap-structural","node_count":%s,"nodes":[]}}\n' "$source_meta" "$shape" "$hir_node_count"
        else
            printf 'HIR\n'
            printf 'source: %s\n' "$src"
            printf 'kind: bootstrap-structural\n'
            printf 'node_count: %s\n' "$hir_node_count"
            printf 'nodes: []\n'
        fi
        ;;
    dump-mir)
        read_common_flags "$@"
        dump_json=0
        if has_flag --json "$@"; then
            dump_json=1
        fi
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "dump-mir requires --src or file" "vittec dump-mir path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        if diag_info="$(detect_professional_diagnostic "$src")"; then
            render_professional_diagnostic_text "$src" "$diag_info" >&2
            exit 1
        fi
        source_meta="$(source_meta_json "$src")"
        shape="$(compiler_shape_json "$src")"
        proc_count="$(grep -c '^proc[ \t]' "$src" || true)"
        mir_block_count=$((proc_count + 1))
        if [ "$dump_json" -eq 1 ]; then
            printf '{"schema":"vitte.compiler.surface","schema_version":"1.0.0","surface":"mir","producer":"vittec-bootstrap-seed","command":"dump-mir","status":"ok",%s,%s,"mir":{"kind":"bootstrap-structural","block_count":%s,"blocks":[]}}\n' "$source_meta" "$shape" "$mir_block_count"
        else
            printf 'MIR\n'
            printf 'source: %s\n' "$src"
            printf 'kind: bootstrap-structural\n'
            printf 'block_count: %s\n' "$mir_block_count"
            printf 'blocks: []\n'
        fi
        ;;
    build-native)
        read_common_flags "$@"
        trace_step "pipeline.lower:begin"
        src="$(arg_value --src "$@" || true)"
        out="$(arg_value --out "$@" || true)"
        [ -n "$src" ] && [ -n "$out" ] || { cli_error E_CLI_MISSING_ARG "build-native requires --src and --out" "vittec build-native --src in.vit --out out/vittec"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        guard_output_not_source "$src" "$out" || exit 2
        trace_step "pipeline.emit:write-shell"
        ir_version="$(arg_value --ir-version "$@" || true)"
        [ -n "$ir_version" ] || ir_version="v1"
        [ "$ir_version" = "v1" ] || [ "$ir_version" = "v2" ] || { cli_error E_CLI_ARG "unsupported --ir-version: $ir_version" "supported: v1, v2"; exit 2; }
        # build-native keeps the explicit bootstrap shell artifact contract for dump-native compatibility.
        write_compiler "$src" "$out"
        if [ "$strict_mode" -eq 1 ]; then
            trace_step "pipeline.emit:strict-verify-shell"
            sh -n "$out" || { cli_error E_STRICT_SHELL "strict mode shell verification failed for $out"; exit 1; }
        fi
        trace_step "pipeline.emit:ok"
        ;;
    dump-native-shell)
        read_common_flags "$@"
        src="$(arg_value --src "$@" || true)"
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "dump-native-shell requires --src" "vittec dump-native-shell --src path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        render_native_shell "$src"
        ;;
    dump-native-ir)
        read_common_flags "$@"
        trace_step "pipeline.parse:begin"
        ir_version="$(arg_value --ir-version "$@" || true)"
        [ -n "$ir_version" ] || ir_version="v1"
        [ "$ir_version" = "v1" ] || [ "$ir_version" = "v2" ] || { cli_error E_CLI_ARG "unsupported --ir-version: $ir_version" "supported: v1, v2"; exit 2; }
        src="$(arg_value --src "$@" || true)"
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "dump-native-ir requires --src" "vittec dump-native-ir --src path.vit"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        compile_native_ir "$src" "$ir_version"
        ;;
    build)
        read_common_flags "$@"
        src="$(arg_value --src "$@" || true)"
        if [ -z "$src" ]; then src="$(first_file_arg "$@" || true)"; fi
        if [ -z "$src" ]; then src="$(resolve_cli_input "$(arg_value --src "$@" || first_path_arg_after_command "$@" || true)" || true)"; fi
        out="$(arg_value --out "$@" || true)"
        if [ -z "$out" ]; then out="$(arg_value -o "$@" || true)"; fi
        [ -n "$src" ] || { cli_error E_CLI_MISSING_ARG "build requires input file" "vittec build main.vit -o build/main"; exit 2; }
        [ -f "$src" ] || { cli_error E_CLI_IO "cannot read $src" "check the path and permissions"; exit 1; }
        [ -n "$out" ] || { cli_error E_CLI_MISSING_ARG "build requires -o/--out output path" "vittec build main.vit -o build/main"; exit 2; }
        guard_output_not_source "$src" "$out" || exit 2
        trace_step "pipeline.lower:begin"
        trace_step "pipeline.backend:native-bootstrap-subset"
        set +e
        build_native_user_program "$src" "$out"
        rc="$?"
        set -e
        if [ "$rc" -ne 0 ]; then
            if [ "$rc" -eq 125 ]; then
                trace_step "pipeline.backend:delegate-generic"
                set +e
                delegate_generic_backend_build "$src" "$out"
                rc="$?"
                set -e
            fi
            [ "$rc" -eq 0 ] || exit "${rc:-3}"
        fi
        [ -f "$out" ] || { cli_error E_BUILD_OUTPUT "build failed to produce output: $out"; exit 1; }
        trace_step "pipeline.emit:ok"
        printf 'build succeeded: %s\n' "$out"
        ;;
    *)
        cli_error E_CLI_COMMAND "unknown command: $cmd" "use --help to list commands"
        exit 2
        ;;
esac
