#!/usr/bin/env sh
set -eu
version='vittec native const fixture 0.1.0'
banner='vittec native named constants'
main_return='0'
error_prefix='[vittec][error]'
compiler_source_root=''
compiler_entry_point=''

trace_pipeline=0
strict_mode=0
diagnostics_lang="${VITTE_LANG:-en}"
ansi_reset="$(printf '[0m')"
ansi_bold="$(printf '[1m')"
ansi_red="$(printf '[31m')"
ansi_blue="$(printf '[34m')"
ansi_cyan="$(printf '[36m')"

# --- shell-runtime-body ---

cli_error() {
    code="$1"
    msg="$2"
    hint="${3:-}"
    msg="$(localized_diagnostic_message "$code" "$msg")"
    if [ -n "$hint" ]; then
        hint="$(localized_diagnostic_hint "$code" "$hint")"
    fi
    if [ -n "$hint" ]; then
        echo "$error_prefix $code: $msg (hint: $hint)" >&2
    else
        echo "$error_prefix $code: $msg" >&2
    fi
}

trace_step() {
    if [ "$trace_pipeline" -eq 1 ]; then
        printf '[trace] %s\n' "$1" >&2
    fi
}

cli_program_name() {
    if [ -n "$compiler_source_root" ] || [ -n "$compiler_entry_point" ]; then
        printf 'vitte\n'
        return 0
    fi
    printf '%s\n' "${version%% *}"
}

cli_display_version() {
    printf '%s\n' "${version##* }"
}

print_compiler_brief_help() {
    prog="$(cli_program_name)"
    printf '%s %s\n' "$prog" "$(cli_display_version)"
    printf 'usage: %s <command> [options] [file]\n' "$prog"
    printf 'try: %s check hello.vit | %s build hello.vit -o build/hello | %s pkg check\n' "$prog" "$prog" "$prog"
    printf 'run `%s --help` for full help\n' "$prog"
}

print_compiler_help() {
    prog="$(cli_program_name)"
    printf '%s %s\n' "$prog" "$(cli_display_version)"
    printf 'usage: %s <command> [options] [file]\n' "$prog"
    printf '\n'
    printf 'core commands:\n'
    printf '  check FILE        validate a source file\n'
    printf '  build FILE -o OUT build a native executable\n'
    printf '  run FILE          build and run a source file\n'
    printf '  parse FILE        parse only\n'
    printf '  explain CODE      explain a diagnostic code\n'
    printf '\n'
    printf 'package commands:\n'
    printf '  pkg check         validate packages under src/vitte/packages\n'
    printf '  pkg matrix        run package dependency/import checks\n'
    printf '  pkg selftest      run package package checks and matrix\n'
    printf '\n'
    printf 'debug commands:\n'
    printf '  dump-tokens FILE\n'
    printf '  dump-ast FILE\n'
    printf '  dump-hir FILE\n'
    printf '  dump-mir FILE\n'
    printf '  dump-native-ir --src FILE\n'
    printf '  selfhost-source\n'
    printf '\n'
    printf 'common flags:\n'
    printf '  --src PATH  --out PATH  -o PATH  --lang LANG  --trace-pipeline  --strict\n'
    printf '  --dump-ast-json  --dump-hir-json  --dump-mir-json  --diagnostics-json\n'
}

arg_value() {
    key="$1"
    shift
    while [ "$#" -gt 1 ]; do
        if [ "$1" = "$key" ]; then
            printf '%s\n' "$2"
            return 0
        fi
        shift
    done
    return 1
}

first_file_arg() {
    for arg do
        case "$arg" in
            -*)
                ;;
            *)
                if [ -f "$arg" ]; then
                    printf '%s\n' "$arg"
                    return 0
                fi
                ;;
        esac
    done
    return 1
}

first_path_arg() {
    skip_next=0
    for arg do
        if [ "$skip_next" -eq 1 ]; then
            skip_next=0
            continue
        fi
        case "$arg" in
            --src|--out|-o|--ir-version)
                skip_next=1
                ;;
            -*)
                ;;
            *)
                printf '%s\n' "$arg"
                return 0
                ;;
        esac
    done
    return 1
}

first_path_arg_after_command() {
    [ "$#" -gt 0 ] || return 1
    shift
    first_path_arg "$@"
}

path_join2() {
    left="$1"
    right="$2"
    if [ -z "$left" ]; then
        printf '%s\n' "$right"
        return 0
    fi
    if [ -z "$right" ]; then
        printf '%s\n' "$left"
        return 0
    fi
    case "$left" in
        */)
            printf '%s%s\n' "$left" "$right"
            ;;
        *)
            printf '%s/%s\n' "$left" "$right"
            ;;
    esac
}

project_path_hint() {
    path="$1"
    case "$path" in
        "" )
            return 1
            ;;
        .|..|*/)
            return 0
            ;;
    esac
    return 1
}

resolve_project_entry_candidates() {
    project_path="$1"
    shift
    for suffix do
        candidate="$(path_join2 "$project_path" "$suffix")"
        if [ -f "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

resolve_project_input() {
    project_path="$1"
    if [ -z "$project_path" ]; then
        return 1
    fi
    resolve_project_entry_candidates "$project_path" "src/main.vit" "src/vitte/compiler/main.vit" "main.vit"
}

resolve_cli_input() {
    input_path="$1"
    if [ -z "$input_path" ]; then
        resolve_project_input "."
        return $?
    fi
    if [ -d "$input_path" ] || project_path_hint "$input_path"; then
        resolve_project_input "$input_path"
        return $?
    fi
    if [ -f "$input_path" ]; then
        printf '%s\n' "$input_path"
        return 0
    fi
    return 1
}

has_flag() {
    key="$1"
    shift
    for arg do
        if [ "$arg" = "$key" ]; then
            return 0
        fi
    done
    return 1
}

sq() {
    sed "s/'/'\\\\''/g; s/^/'/; s/$/'/"
}

shell_payload_c_literal() {
    awk '
    BEGIN {
        printf "\""
    }
    {
        gsub(/\\/,"\\\\")
        gsub(/"/,"\\\"")
        printf "%s\\n", $0
    }
    END {
        printf "\""
    }' "$1"
}

compile_native_ir() {
    src="$1"
    ir_version="${2:-v1}"
    lang="$(normalize_diagnostics_lang "$diagnostics_lang")"
    diag_file="$(vitte_root_dir)/locales/$lang/diagnostics.ftl"
    loc_unknown_string_const="$(ftl_lookup "$diag_file" E_BOOTSTRAP_UNKNOWN_STRING_CONST || printf 'unknown string constant')"
    loc_unknown_int_const="$(ftl_lookup "$diag_file" E_BOOTSTRAP_UNKNOWN_INT_CONST || printf 'unknown int constant')"
    loc_expected_string_const="$(ftl_lookup "$diag_file" E_BOOTSTRAP_EXPECTED_STRING_CONST || printf 'expected string constant')"
    loc_expected_int_const="$(ftl_lookup "$diag_file" E_BOOTSTRAP_EXPECTED_INT_CONST || printf 'expected int constant')"
    loc_unknown_proc="$(ftl_lookup "$diag_file" E_BOOTSTRAP_UNKNOWN_PROC_PREFIX || printf 'unsupported bootstrap proc')"
    loc_dup_proc="$(ftl_lookup "$diag_file" E_BOOTSTRAP_DUP_PROC_PREFIX || printf 'duplicate proc')"
    loc_const_signature="$(ftl_lookup "$diag_file" E_BOOTSTRAP_CONST_SIGNATURE || printf 'expected const NAME: string = "..." or const NAME: int = 123')"
    loc_main_signature="$(ftl_lookup "$diag_file" E_BOOTSTRAP_MAIN_SIGNATURE || printf 'expected proc main(args: list[string]) -> int {')"
    loc_proc_signature_params="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_SIGNATURE_PARAMS || printf 'bootstrap string proc must have no parameters: proc name() -> string {')"
    loc_proc_signature_return="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_SIGNATURE_RETURN || printf 'bootstrap string proc must return string: proc name() -> string {')"
    loc_proc_signature="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_SIGNATURE || printf 'expected proc name() -> string { or proc main(args: list[string]) -> int {')"
    loc_proc_body="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_BODY || printf 'unsupported statement in bootstrap proc')"
    loc_proc_body_give="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_BODY_GIVE || printf 'expected exactly one supported give')"
    loc_main_body="$(ftl_lookup "$diag_file" E_BOOTSTRAP_MAIN_BODY || printf 'expected main to give int')"
    loc_proc_body_int="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_BODY_INT || printf 'expected int literal or int constant give')"
    loc_proc_body_string="$(ftl_lookup "$diag_file" E_BOOTSTRAP_PROC_BODY_STRING || printf 'expected string literal or string constant give')"
    loc_top_level="$(ftl_lookup "$diag_file" E_BOOTSTRAP_TOP_LEVEL || printf 'unsupported top-level item')"
    loc_unclosed_proc="$(ftl_lookup "$diag_file" E_BOOTSTRAP_UNCLOSED_PROC || printf 'missing closing brace')"
    loc_export="$(ftl_lookup "$diag_file" E_BOOTSTRAP_EXPORT || printf 'expected export *')"
    loc_space="$(ftl_lookup "$diag_file" E_BOOTSTRAP_SPACE || printf 'missing space declaration')"
    loc_version="$(ftl_lookup "$diag_file" E_BOOTSTRAP_VERSION || printf 'missing version_text()')"
    loc_banner="$(ftl_lookup "$diag_file" E_BOOTSTRAP_BANNER || printf 'missing banner_text()')"
    # Keep this AWK parser intentionally small: it recognizes only the
    # bootstrap-native subset documented in docs/bootstrap_seed.md.
    awk -v ir_version="$ir_version" \
        -v loc_unknown_string_const="$loc_unknown_string_const" \
        -v loc_unknown_int_const="$loc_unknown_int_const" \
        -v loc_expected_string_const="$loc_expected_string_const" \
        -v loc_expected_int_const="$loc_expected_int_const" \
        -v loc_unknown_proc="$loc_unknown_proc" \
        -v loc_dup_proc="$loc_dup_proc" \
        -v loc_const_signature="$loc_const_signature" \
        -v loc_main_signature="$loc_main_signature" \
        -v loc_proc_signature_params="$loc_proc_signature_params" \
        -v loc_proc_signature_return="$loc_proc_signature_return" \
        -v loc_proc_signature="$loc_proc_signature" \
        -v loc_proc_body="$loc_proc_body" \
        -v loc_proc_body_give="$loc_proc_body_give" \
        -v loc_main_body="$loc_main_body" \
        -v loc_proc_body_int="$loc_proc_body_int" \
        -v loc_proc_body_string="$loc_proc_body_string" \
        -v loc_top_level="$loc_top_level" \
        -v loc_unclosed_proc="$loc_unclosed_proc" \
        -v loc_export="$loc_export" \
        -v loc_space="$loc_space" \
        -v loc_version="$loc_version" \
        -v loc_banner="$loc_banner" '
    function localized_msg(code, msg, value) {
        if (msg ~ /^unknown string constant /) {
            value = msg
            sub(/^unknown string constant /, "", value)
            return loc_unknown_string_const " " value
        }
        if (msg ~ /^unknown int constant /) {
            value = msg
            sub(/^unknown int constant /, "", value)
            return loc_unknown_int_const " " value
        }
        if (msg ~ /^expected string constant /) {
            value = msg
            sub(/^expected string constant /, "", value)
            return loc_expected_string_const " " value
        }
        if (msg ~ /^expected int constant /) {
            value = msg
            sub(/^expected int constant /, "", value)
            return loc_expected_int_const " " value
        }
        if (msg ~ /^unsupported bootstrap proc /) {
            value = msg
            sub(/^unsupported bootstrap proc /, "", value)
            return loc_unknown_proc " " value
        }
        if (msg ~ /^duplicate proc /) {
            value = msg
            sub(/^duplicate proc /, "", value)
            return loc_dup_proc " " value
        }
        if (code == "E_BOOTSTRAP_CONST_SIGNATURE") return loc_const_signature
        if (code == "E_BOOTSTRAP_MAIN_SIGNATURE") return loc_main_signature
        if (code == "E_BOOTSTRAP_PROC_SIGNATURE" && msg ~ /^bootstrap string proc must have no parameters/) return loc_proc_signature_params
        if (code == "E_BOOTSTRAP_PROC_SIGNATURE" && msg ~ /^bootstrap string proc must return string/) return loc_proc_signature_return
        if (code == "E_BOOTSTRAP_PROC_SIGNATURE") return loc_proc_signature
        if (code == "E_BOOTSTRAP_PROC_BODY" && msg ~ /^expected exactly one supported give/) return loc_proc_body_give
        if (code == "E_BOOTSTRAP_PROC_BODY" && msg ~ /^expected int literal/) return loc_proc_body_int
        if (code == "E_BOOTSTRAP_PROC_BODY" && msg ~ /^expected string literal/) return loc_proc_body_string
        if (code == "E_BOOTSTRAP_PROC_BODY") return loc_proc_body
        if (code == "E_BOOTSTRAP_MAIN_BODY") return loc_main_body
        if (code == "E_BOOTSTRAP_TOP_LEVEL") return loc_top_level
        if (code == "E_BOOTSTRAP_UNCLOSED_PROC") return loc_unclosed_proc
        if (code == "E_BOOTSTRAP_EXPORT") return loc_export
        if (code == "E_BOOTSTRAP_SPACE") return loc_space
        if (code == "E_BOOTSTRAP_VERSION") return loc_version
        if (code == "E_BOOTSTRAP_BANNER") return loc_banner
        return msg
    }
    function diag(code, msg) {
        msg = localized_msg(code, msg)
        printf "%s:%d:%d: %s: %s\n", file, line_no, col, code, msg > "/dev/stderr"
        errors++
    }
    function trim(s) {
        sub(/^[ \t\r\n]+/, "", s)
        sub(/[ \t\r\n]+$/, "", s)
        return s
    }
    function first_token(s,    t) {
        t = trim(s)
        sub(/[ \t\r\n].*$/, "", t)
        return t
    }
    function nearest_symbol(name,    best, best_score, candidate, score, i, prefix) {
        best = ""
        best_score = -1
        prefix = substr(name, 1, 3)
        for (candidate in symbol_seen) {
            score = 0
            if (candidate == name) continue
            if (substr(candidate, 1, 3) == prefix) score += 3
            for (i = 1; i <= length(name) && i <= length(candidate); i++) {
                if (substr(name, i, 1) == substr(candidate, i, 1)) score++
                else break
            }
            if (index(candidate, name) > 0 || index(name, candidate) > 0) score += 2
            if (score > best_score) {
                best = candidate
                best_score = score
            }
        }
        return best
    }
    function current_imports_text(    result, i) {
        result = ""
        for (i = 1; i <= import_count; i++) {
            if (result != "") result = result ", "
            result = result import_list[i]
        }
        if (result == "") result = "<none>"
        return result
    }
    function import_chain_for(module_name) {
        return file " -> " module_name
    }
    function tested_paths_for(module_name,    slash_name) {
        slash_name = module_name
        gsub(/[.]/, "/", slash_name)
        return "./" slash_name ".vit, ./" slash_name "/mod.vit, src/" slash_name ".vit, src/" slash_name "/mod.vit"
    }
    function syntax_note(expected, found, context, recovery) {
        return "expected token: " expected "; found token: " found "; syntax context: " context "; recovery: " recovery
    }
    function count_char(s, ch,    i, n) {
        n = 0
        for (i = 1; i <= length(s); i++) {
            if (substr(s, i, 1) == ch) n++
        }
        return n
    }
    function outside_string_col(s, needle,    i, ch, quoted, escaped) {
        quoted = 0
        escaped = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
            } else if (quoted && ch == "\\") {
                escaped = 1
            } else if (ch == "\"") {
                quoted = !quoted
            } else if (!quoted && ch == needle) {
                return i
            }
        }
        return 0
    }
    function count_char_outside_strings(s, needle,    i, ch, n, quoted, escaped) {
        n = 0
        quoted = 0
        escaped = 0
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
            } else if (quoted && ch == "\\") {
                escaped = 1
            } else if (ch == "\"") {
                quoted = !quoted
            } else if (!quoted && ch == needle) {
                n++
            }
        }
        return n
    }
    function strip_strings(s,    i, ch, quoted, escaped, out) {
        quoted = 0
        escaped = 0
        out = ""
        for (i = 1; i <= length(s); i++) {
            ch = substr(s, i, 1)
            if (escaped) {
                escaped = 0
                out = out " "
            } else if (quoted && ch == "\\") {
                escaped = 1
                out = out " "
            } else if (ch == "\"") {
                if (!quoted) {
                    out = out "S"
                } else {
                    out = out " "
                }
                quoted = !quoted
            } else if (quoted) {
                out = out " "
            } else {
                out = out ch
            }
        }
        return out
    }
    function block_delta(s) {
        return count_char(s, "{") - count_char(s, "}")
    }
    function const_value(name) {
        return consts[name]
    }
    function col_token(token) {
        pos = index(raw, token)
        if (pos > 0) return pos
        return 1
    }
    function col_nonspace(    i, ch) {
        for (i = 1; i <= length(raw); i++) {
            ch = substr(raw, i, 1)
            if (ch != " " && ch != "\t") return i
        }
        return 1
    }
    function emit_proc(name, value, value_kind) {
        if (value_kind == "ident") {
            if (!(value in consts)) {
                diag("E_BOOTSTRAP_UNKNOWN_CONST", "unknown string constant " value)
                return
            }
            if (const_kinds[value] != "string") {
                diag("E_BOOTSTRAP_CONST_TYPE", "expected string constant " value)
                return
            }
            value = const_value(value)
        }
        if (name == "version_text") version_text = value
        else if (name == "banner_text") banner_text = value
        else if (name == "compiler_source_root") compiler_source_root = value
        else if (name == "compiler_entry_point") compiler_entry_point = value
        else diag("E_BOOTSTRAP_UNKNOWN_PROC", "unsupported bootstrap proc " name)
    }
    function resolve_int(value, value_kind) {
        if (value_kind == "int_ident") {
            if (!(value in consts)) {
                diag("E_BOOTSTRAP_UNKNOWN_CONST", "unknown int constant " value)
                return ""
            }
            if (const_kinds[value] != "int") {
                diag("E_BOOTSTRAP_CONST_TYPE", "expected int constant " value)
                return ""
            }
            return const_value(value)
        }
        return value
    }
    function proc_signature_diag(line) {
        if (line ~ /^proc[ \t]+main[ \t]*\(/) {
            diag("E_BOOTSTRAP_MAIN_SIGNATURE", "expected proc main(args: list[string]) -> int {")
        } else if (line ~ /^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*\([^)]*[A-Za-z0-9_][^)]*\)/) {
            diag("E_BOOTSTRAP_PROC_SIGNATURE", "bootstrap string proc must have no parameters: proc name() -> string {")
        } else if (line ~ /^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*\(\)[ \t]*->[ \t]*[^ \t{]+/) {
            diag("E_BOOTSTRAP_PROC_SIGNATURE", "bootstrap string proc must return string: proc name() -> string {")
        } else {
            diag("E_BOOTSTRAP_PROC_SIGNATURE", "expected proc name() -> string { or proc main(args: list[string]) -> int {")
        }
    }
    function full_main_stmt_ok(line) {
        if (line == "}") return 1
        if (line == "};") return 1
        if (line ~ /^}[ \t]*else[ \t]*[{];?$/) return 1
        if (line ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[^=]+=[ \t]*$/) return 1
        if (line ~ /^let[ \t]+[A-Za-z_][A-Za-z0-9_]*[ \t]*:[^=]+=[ \t]*.+;?$/) return 1
        if (line ~ /^if[ \t]+.+[{];?$/) return 1
        if (line ~ /^give[ \t]+.+;?$/) return 1
        if (line ~ /^-?[0-9]+;?$/) return 1
        if (line ~ /^[A-Za-z_][A-Za-z0-9_\.]*(\([^)]*\))?;?$/) return 1
        return 0
    }
    function full_compiler_metadata_proc(line) {
        return line ~ /^proc[ \t]+(version_text|banner_text|compiler_source_root|compiler_entry_point)\(\)[ \t]*->[ \t]*string[ \t]*[{]$/
    }
    BEGIN {
        file = ARGV[1]
        in_proc = 0
        proc_mode = ""
        brace_depth = 0
        errors = 0
        saw_export = 0
        saw_space = 0
        saw_intrinsic_surface = 0
        full_compiler = 0
        skip_doc = 0
        skip_modern_block = 0
        skip_modern_depth = 0
    }
    {
        line_no = FNR
        raw = $0
        line = trim(raw)
        if (line == "" || line ~ /^\/\//) next
        if (skip_doc) {
            if (line ~ />>>/) skip_doc = 0
            next
        }
        if (line ~ /^<</) {
            if (line !~ />>>/) skip_doc = 1
            next
        }
        if (skip_modern_block) {
            skip_modern_depth += block_delta(line)
            if (skip_modern_depth <= 0) skip_modern_block = 0
            next
        }
        if (line ~ /^space[ \t]+[A-Za-z0-9_\/]+$/) {
            saw_space = 1
            next
        }
        if (!in_proc && line ~ /^intrinsic[ \t]+[A-Za-z_][A-Za-z0-9_]*\([^;]*\)[ \t]*->[ \t]*[^;]+;$/) {
            saw_intrinsic_surface = 1
            next
        }
        if (line == "export *") { saw_export = 1; next }
        if (!in_proc && line ~ /^const[ \t]+[A-Z_][A-Z0-9_]*[ \t]*:[ \t]*string[ \t]*=[ \t]*"[^"]*"$/) {
            const_name = line
            sub(/^const[ \t]+/, "", const_name)
            sub(/[ \t]*:[ \t]*string[ \t]*=.*$/, "", const_name)
            const_val = line
            sub(/^.*=[ \t]*"/, "", const_val)
            sub(/"$/, "", const_val)
            consts[const_name] = const_val
            const_kinds[const_name] = "string"
            const_order[++const_count] = const_name
            next
        }
        if (!in_proc && line ~ /^const[ \t]+[A-Z_][A-Z0-9_]*[ \t]*:[ \t]*int[ \t]*=[ \t]*-?[0-9]+$/) {
            const_name = line
            sub(/^const[ \t]+/, "", const_name)
            sub(/[ \t]*:[ \t]*int[ \t]*=.*$/, "", const_name)
            const_val = line
            sub(/^.*=[ \t]*/, "", const_val)
            consts[const_name] = const_val
            const_kinds[const_name] = "int"
            const_order[++const_count] = const_name
            if (const_name == "BOOTSTRAP_FULL_COMPILER" && const_val == "1") full_compiler = 1
            next
        }
        if (!in_proc && line ~ /^const[ \t]+/) {
            col = col_token("const")
            diag("E_BOOTSTRAP_CONST_SIGNATURE", "expected const NAME: string = \"...\" or const NAME: int = 123")
            next
        }

        if (!in_proc && line ~ /^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*\(\)[ \t]*->[ \t]*string[ \t]*[{]$/ && (!full_compiler || full_compiler_metadata_proc(line))) {
            in_proc = 1
            proc_name = line
            sub(/^proc[ \t]+/, "", proc_name)
            sub(/\(\)[ \t]*->[ \t]*string[ \t]*[{]$/, "", proc_name)
            if (proc_seen[proc_name]) {
                col = col_token("proc")
                diag("E_BOOTSTRAP_DUP_PROC", "duplicate proc " proc_name)
                in_proc = 0
                next
            }
            proc_seen[proc_name] = 1
            proc_value = ""
            proc_value_kind = ""
            proc_return_type = "string"
            proc_start_line = line_no
            proc_start_col = col_token("proc")
            proc_give_count = 0
            proc_mode = "simple"
            brace_depth = 1
            next
        }
        if (!full_compiler && !in_proc && line ~ /^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*\(\)[ \t]*->[ \t]*int[ \t]*[{]$/) {
            in_proc = 1
            proc_name = line
            sub(/^proc[ \t]+/, "", proc_name)
            sub(/\(\)[ \t]*->[ \t]*int[ \t]*[{]$/, "", proc_name)
            if (proc_seen[proc_name]) {
                col = col_token("proc")
                diag("E_BOOTSTRAP_DUP_PROC", "duplicate proc " proc_name)
                in_proc = 0
                next
            }
            proc_seen[proc_name] = 1
            if (proc_name == "main") {
                col = col_token("proc")
                proc_signature_diag(line)
                in_proc = 0
                next
            }
            proc_value = ""
            proc_value_kind = ""
            proc_return_type = "int"
            proc_start_line = line_no
            proc_start_col = col_token("proc")
            proc_give_count = 0
            proc_mode = "simple"
            brace_depth = 1
            next
        }
        if (!in_proc && line ~ /^proc[ \t]+main\([A-Za-z_][A-Za-z0-9_]*:[ \t]*list\[string\]\)[ \t]*->[ \t]*int[ \t]*[{]$/) {
            in_proc = 1
            proc_name = "main"
            if (proc_seen[proc_name]) {
                col = col_token("proc")
                diag("E_BOOTSTRAP_DUP_PROC", "duplicate proc " proc_name)
                in_proc = 0
                next
            }
            proc_seen[proc_name] = 1
            proc_value = ""
            proc_value_kind = ""
            proc_return_type = "int"
            proc_start_line = line_no
            proc_start_col = col_token("proc")
            proc_give_count = 0
            if (full_compiler) proc_mode = "full_main"
            else proc_mode = "simple"
            brace_depth = 1
            next
        }
        if ((full_compiler || saw_intrinsic_surface) && !in_proc && line ~ /^(use|share|import)[ \t]+/) {
            next
        }
        if (saw_intrinsic_surface && !in_proc && line ~ /^proc[ \t]+[A-Za-z_][A-Za-z0-9_]*\([^)]*\)[ \t]*->[ \t]*[^ \t{]+[ \t]*[{]$/) {
            skip_modern_depth = block_delta(line)
            if (skip_modern_depth > 0) skip_modern_block = 1
            next
        }
        if (full_compiler && !in_proc && line ~ /^(use|share|import)[ \t]+/) {
            next
        }
        if (full_compiler && !in_proc && line ~ /^(pick|form|proc)[ \t]+/) {
            skip_modern_depth = block_delta(line)
            if (skip_modern_depth > 0) skip_modern_block = 1
            next
        }
        if (!in_proc && line ~ /^proc[ \t]+/) {
            col = col_token("proc")
            proc_signature_diag(line)
            next
        }
        if (in_proc && proc_mode == "full_main") {
            if (line == "}") {
                if (brace_depth > 1) {
                    brace_depth--
                    next
                }
                saw_main = 1
                main_return = 0
                in_proc = 0
                proc_mode = ""
                brace_depth = 0
                next
            }
            if (full_main_stmt_ok(line)) {
                brace_depth += block_delta(line)
                next
            }
            col = col_nonspace()
            diag("E_BOOTSTRAP_PROC_BODY", "unsupported statement in bootstrap proc")
            next
        }
        if (in_proc && line ~ /^give[ \t]+"[^"]*"$/) {
            proc_give_col = col_token("give")
            proc_value = line
            sub(/^give[ \t]+"/, "", proc_value)
            sub(/"$/, "", proc_value)
            proc_value_kind = "string"
            proc_give_count++
            next
        }
        if (in_proc && line ~ /^give[ \t]+[A-Z_][A-Z0-9_]*$/) {
            proc_give_col = col_token("give")
            proc_value = line
            sub(/^give[ \t]+/, "", proc_value)
            proc_value_kind = "ident"
            proc_give_count++
            next
        }
        if (in_proc && line ~ /^give[ \t]+-?[0-9]+$/) {
            proc_give_col = col_token("give")
            proc_value = line
            sub(/^give[ \t]+/, "", proc_value)
            proc_value_kind = "int"
            proc_give_count++
            next
        }
        if (in_proc && line == "}") {
            if (proc_give_count != 1) {
                col = col_nonspace()
                diag("E_BOOTSTRAP_PROC_BODY", "expected exactly one supported give")
            } else if (proc_name == "main") {
                if (proc_value_kind == "ident") proc_value_kind = "int_ident"
                if (proc_value_kind != "int" && proc_value_kind != "int_ident") {
                    col = proc_give_col
                    diag("E_BOOTSTRAP_MAIN_BODY", "expected main to give int")
                } else {
                    col = proc_give_col
                    resolved = resolve_int(proc_value, proc_value_kind)
                    if (resolved != "") {
                        main_return = resolved
                        saw_main = 1
                    }
                }
            } else {
                if (proc_return_type == "int") {
                    if (proc_value_kind == "ident") proc_value_kind = "int_ident"
                    if (proc_value_kind != "int" && proc_value_kind != "int_ident") {
                        col = proc_give_col
                        diag("E_BOOTSTRAP_PROC_BODY", "expected int literal or int constant give")
                    } else {
                        col = proc_give_col
                        resolved = resolve_int(proc_value, proc_value_kind)
                        if (resolved != "") {
                            int_procs[proc_name] = resolved
                            int_proc_order[++int_proc_count] = proc_name
                        }
                    }
                } else if (proc_value_kind == "int") {
                    col = proc_give_col
                    diag("E_BOOTSTRAP_PROC_BODY", "expected string literal or string constant give")
                } else {
                    if (proc_value_kind != "string" && proc_value_kind != "ident") {
                        col = proc_give_col
                        diag("E_BOOTSTRAP_PROC_BODY", "expected string literal or string constant give")
                    } else {
                        col = proc_give_col
                        emit_proc(proc_name, proc_value, proc_value_kind)
                    }
                }
            }
            in_proc = 0
            proc_mode = ""
            brace_depth = 0
            next
        }
        col = col_nonspace()
        if (full_compiler && !in_proc) next
        if (in_proc) diag("E_BOOTSTRAP_PROC_BODY", "unsupported statement in bootstrap proc")
        else diag("E_BOOTSTRAP_TOP_LEVEL", "unsupported top-level item")
    }
    END {
        if (in_proc) {
            line_no = proc_start_line
            col = proc_start_col
            diag("E_BOOTSTRAP_UNCLOSED_PROC", "missing closing brace")
        }
        if (!saw_export && !saw_intrinsic_surface) {
            line_no = 1
            col = 1
            diag("E_BOOTSTRAP_EXPORT", "expected export *")
        }
        if (!saw_space) {
            line_no = 1
            col = 1
            diag("E_BOOTSTRAP_SPACE", "missing space declaration")
        }
        if (version_text == "" && !saw_intrinsic_surface) {
            line_no = 1
            col = 1
            diag("E_BOOTSTRAP_VERSION", "missing version_text()")
        }
        if (banner_text == "" && !saw_intrinsic_surface) {
            line_no = 1
            col = 1
            diag("E_BOOTSTRAP_BANNER", "missing banner_text()")
        }
        if (!saw_main) main_return = 0
        if (errors) exit 1
        if (ir_version == "v2") printf "native_ir_v2\n"
        else printf "native_ir_v1\n"
        printf "pipeline.parse=ok\n"
        printf "pipeline.check=ok\n"
        printf "pipeline.lower=shell\n"
        printf "pipeline.emit=shell\n"
        if (ir_version == "v2") {
            printf "target.backend=shell\n"
            printf "artifact.format=posix-sh\n"
            printf "artifact.entry=main\n"
        }
        for (i = 1; i <= const_count; i++) {
            name = const_order[i]
            printf "const.%s.%s=%s\n", const_kinds[name], name, consts[name]
        }
        for (i = 1; i <= int_proc_count; i++) {
            name = int_proc_order[i]
            printf "proc.int.%s=%s\n", name, int_procs[name]
        }
        printf "version_text=%s\n", version_text
        printf "banner_text=%s\n", banner_text
        printf "compiler_source_root=%s\n", compiler_source_root
        printf "compiler_entry_point=%s\n", compiler_entry_point
        printf "main.return=%s\n", main_return
    }' "$src"
}

render_native_shell_from_ir() {
    ir_text="$1"
    out_version="$(printf '%s\n' "$ir_text" | awk -F= '/^version_text=/{sub(/^version_text=/, ""); print}')"
    out_banner="$(printf '%s\n' "$ir_text" | awk -F= '/^banner_text=/{sub(/^banner_text=/, ""); print}')"
    out_main_return="$(printf '%s\n' "$ir_text" | awk -F= '/^main.return=/{sub(/^main.return=/, ""); print}')"
    out_compiler_source_root="$(printf '%s\n' "$ir_text" | awk -F= '/^const.string.COMPILER_SOURCE_ROOT=/{sub(/^const.string.COMPILER_SOURCE_ROOT=/, ""); print}')"
    if [ -z "$out_compiler_source_root" ]; then
        out_compiler_source_root="$(printf '%s\n' "$ir_text" | awk -F= '/^compiler_source_root=/{sub(/^compiler_source_root=/, ""); print}')"
    fi
    out_compiler_entry_point="$(printf '%s\n' "$ir_text" | awk -F= '/^const.string.COMPILER_ENTRY_POINT=/{sub(/^const.string.COMPILER_ENTRY_POINT=/, ""); print}')"
    if [ -z "$out_compiler_entry_point" ]; then
        out_compiler_entry_point="$(printf '%s\n' "$ir_text" | awk -F= '/^compiler_entry_point=/{sub(/^compiler_entry_point=/, ""); print}')"
    fi
    out_tool_name="$(printf '%s\n' "$out_version" | awk '{print $1}')"
    [ -n "$out_main_return" ] || out_main_return=0
    [ -n "$out_tool_name" ] || out_tool_name=vittec
    if [ -n "$out_compiler_source_root" ] || [ -n "$out_compiler_entry_point" ]; then
        out_tool_name=vitte
    fi
    printf '#!/usr/bin/env sh\n'
    printf 'set -eu\n'
    printf 'version=%s\n' "$(printf '%s\n' "$out_version" | sq)"
    printf 'banner=%s\n' "$(printf '%s\n' "$out_banner" | sq)"
    printf 'main_return=%s\n' "$(printf '%s\n' "$out_main_return" | sq)"
    printf 'error_prefix=%s\n' "$(printf '[%s][error]' "$out_tool_name" | sq)"
    printf 'compiler_source_root=%s\n' "$(printf '%s\n' "$out_compiler_source_root" | sq)"
    printf 'compiler_entry_point=%s\n' "$(printf '%s\n' "$out_compiler_entry_point" | sq)"
    printf '\n'
    printf 'trace_pipeline=0\n'
    printf 'strict_mode=0\n'
    printf 'diagnostics_lang="${VITTE_LANG:-en}"\n'
    printf "ansi_reset=\"\$(printf '\\033[0m')\"\n"
    printf "ansi_bold=\"\$(printf '\\033[1m')\"\n"
    printf "ansi_red=\"\$(printf '\\033[31m')\"\n"
    printf "ansi_blue=\"\$(printf '\\033[34m')\"\n"
    printf "ansi_cyan=\"\$(printf '\\033[36m')\"\n"
    printf '\n'
    printf '# --- shell-runtime-body ---\n'
    printf '\n'
    sed -n '/^# --- shell-runtime-body ---$/,$p' "$0" | awk '
        NR == 1 { next }
        !started && /^[ \t]*$/ { next }
        { started = 1; print }
    '
}

render_native_shell() {
    shell_src="$1"
    shell_ir="$(compile_native_ir "$shell_src" "v1")"
    render_native_shell_from_ir "$shell_ir"
}

write_compiler() {
    compiler_src="$1"
    compiler_out="$2"
    mkdir -p "$(dirname "$compiler_out")"
    render_native_shell "$compiler_src" > "$compiler_out"
    chmod +x "$compiler_out"
}

canonical_path_for_compare() {
    path="$1"
    case "$path" in
        /*) abs_path="$path" ;;
        *) abs_path="$PWD/$path" ;;
    esac
    dir_name="$(dirname "$abs_path")"
    base_name="$(basename "$abs_path")"
    if [ -d "$dir_name" ]; then
        (cd "$dir_name" && printf '%s/%s\n' "$(pwd -P)" "$base_name")
    else
        printf '%s\n' "$abs_path"
    fi
}

output_overwrites_source() {
    source_path="$1"
    output_path="$2"
    [ -n "$source_path" ] || return 1
    [ -n "$output_path" ] || return 1
    [ "$source_path" = "$output_path" ] && return 0
    source_cmp="$(canonical_path_for_compare "$source_path")"
    output_cmp="$(canonical_path_for_compare "$output_path")"
    [ "$source_cmp" = "$output_cmp" ]
}

guard_output_not_source() {
    source_path="$1"
    output_path="$2"
    if output_overwrites_source "$source_path" "$output_path"; then
        cli_error E_CLI_OUTPUT_OVERWRITES_SOURCE "output path would overwrite input source: $output_path" "choose a different -o/--out path, for example build/$(basename "$source_path" .vit)"
        return 1
    fi
}

bootstrap_repo_root_from_source() {
    src="$1"
    case "$src" in
        */src/vitte/compiler/tests/*)
            printf '%s\n' "${src%/src/vitte/compiler/tests/*}"
            return 0
            ;;
        src/vitte/compiler/tests/*)
            printf '.\n'
            return 0
            ;;
    esac
    return 1
}

is_bootstrap_compiler_test_suite_source() {
    src="$1"
    case "$src" in
        */src/vitte/compiler/tests/*.vit|src/vitte/compiler/tests/*.vit)
            grep -q '^proc[  \t]\+run_all_tests()[  \t]*->[  \t]*int[  \t]*{' "$src" || return 1
            grep -q '^proc[  \t]\+main([A-Za-z_][A-Za-z0-9_]*:[  \t]*list\[string\])[  \t]*->[  \t]*int[  \t]*{' "$src" || return 1
            return 0
            ;;
    esac
    return 1
}

write_compiler_test_suite_bridge() {
    src="$1"
    target_out="$2"
    repo_root="$3"
    compiler_bin="$repo_root/bin/vitte"
    src_abs="$(cd "$(dirname "$src")" && pwd)/$(basename "$src")"
    mkdir -p "$(dirname "$target_out")"
    cat > "$target_out" <<EOF
#!/usr/bin/env sh
set -eu
repo_root=$(printf '%s\n' "$repo_root" | sq)
source_path=$(printf '%s\n' "$src_abs" | sq)
compiler_bin=\${VITTE_BOOTSTRAP_COMPILER:-$(printf '%s\n' "$compiler_bin" | sq)}
if [ ! -x "\$compiler_bin" ]; then
    if [ -x "\$repo_root/bin/vitte" ]; then
        compiler_bin="\$repo_root/bin/vitte"
    elif [ -x "\$repo_root/bin/vittec" ]; then
        compiler_bin="\$repo_root/bin/vittec"
    elif [ -x "./bin/vitte" ]; then
        compiler_bin="./bin/vitte"
    elif [ -x "./bin/vittec" ]; then
        compiler_bin="./bin/vittec"
    else
        echo "[vitte][error] E_BOOTSTRAP_COMPILER_TEST_BRIDGE: missing compiler binary for compiler test suite bridge" >&2
        exit 127
    fi
fi
exec "\$compiler_bin" check "\$source_path"
EOF
    chmod +x "$target_out"
}

bootstrap_repo_root_from_compiler_path() {
    path="$1"
    case "$path" in
        */src/vitte/compiler/main.vit)
            printf '%s\n' "${path%/src/vitte/compiler/main.vit}"
            return 0
            ;;
        src/vitte/compiler/main.vit)
            printf '.\n'
            return 0
            ;;
        */src/vitte/compiler)
            printf '%s\n' "${path%/src/vitte/compiler}"
            return 0
            ;;
        src/vitte/compiler)
            printf '.\n'
            return 0
            ;;
    esac
    return 1
}

is_shebang_script() {
    path="$1"
    [ -f "$path" ] || return 1
    prefix="$(LC_ALL=C head -c 2 "$path" 2>/dev/null || true)"
    [ "$prefix" = "#!" ]
}

is_bootstrap_fallback_binary() {
    path="$1"
    [ -f "$path" ] || return 1
    LC_ALL=C grep -a -F "bootstrap native backend could not lower this program" "$path" >/dev/null 2>&1 && return 0
    LC_ALL=C grep -a -F "E_BOOTSTRAP_NATIVE_SUBSET" "$path" >/dev/null 2>&1 && return 0
    return 1
}

resolve_generic_backend_compiler() {
    current_bin="${0:-}"
    current_cmp=""
    if [ -n "$current_bin" ]; then
        current_cmp="$(canonical_path_for_compare "$current_bin" 2>/dev/null || printf '%s\n' "$current_bin")"
    fi
    explicit_compiler="${VITTE_BOOTSTRAP_COMPILER:-}"
    if [ -n "$explicit_compiler" ] && [ -x "$explicit_compiler" ]; then
        candidate_cmp="$(canonical_path_for_compare "$explicit_compiler" 2>/dev/null || printf '%s\n' "$explicit_compiler")"
        [ -z "$current_cmp" ] || [ "$candidate_cmp" != "$current_cmp" ] || return 1
        printf '%s\n' "$explicit_compiler"
        return 0
    fi
    repo_root=""
    if [ -n "${compiler_entry_point:-}" ]; then
        repo_root="$(bootstrap_repo_root_from_compiler_path "$compiler_entry_point" || true)"
    fi
    if [ -z "$repo_root" ] && [ -n "${compiler_source_root:-}" ]; then
        repo_root="$(bootstrap_repo_root_from_compiler_path "$compiler_source_root" || true)"
    fi
    for candidate in \
        "${repo_root:+$repo_root/bin/vitte}" \
        "${repo_root:+$repo_root/bin/vittec}" \
        "./bin/vitte" \
        "./bin/vittec"
    do
        [ -n "$candidate" ] || continue
        [ -x "$candidate" ] || continue
        candidate_cmp="$(canonical_path_for_compare "$candidate" 2>/dev/null || printf '%s\n' "$candidate")"
        [ -z "$current_cmp" ] || [ "$candidate_cmp" != "$current_cmp" ] || continue
        is_bootstrap_fallback_binary "$candidate" && continue
        is_shebang_script "$candidate" && continue
        printf '%s\n' "$candidate"
        return 0
    done
    return 1
}

run_generic_backend_compiler() {
    compiler_bin="$1"
    shift
    if [ "$trace_pipeline" -eq 1 ]; then
        set -- "$@" --trace-pipeline
    fi
    if [ "$strict_mode" -eq 1 ]; then
        set -- "$@" --strict
    fi
    if [ -n "${diagnostics_lang:-}" ]; then
        set -- "$@" --lang "$diagnostics_lang"
    fi
    "$compiler_bin" "$@"
}

delegate_generic_backend_build() {
    src="$1"
    out="$2"
    compiler_bin="$(resolve_generic_backend_compiler || true)"
    [ -n "$compiler_bin" ] || return 1
    run_generic_backend_compiler "$compiler_bin" build "$src" -o "$out"
}

delegate_generic_backend_run() {
    src="$1"
    compiler_bin="$(resolve_generic_backend_compiler || true)"
    [ -n "$compiler_bin" ] || return 1
    run_generic_backend_compiler "$compiler_bin" run "$src"
}

extract_native_main_return() {
    src="$1"
    awk '
    function trim(s) {
        sub(/^[ \t\r\n]+/, "", s)
        sub(/[ \t\r\n]+$/, "", s)
        return s
    }
    function current_exec(i) {
        for (i = 1; i <= exec_depth; i += 1) if (!exec_active[i]) return 0
        return 1
    }
    function native_mutex_new(value, id) {
        id = next_mutex_state_id
        next_mutex_state_id += 1
        mutex_value[id] = value
        mutex_locked[id] = 0
        mutex_owner[id] = 0
        mutex_lock_count[id] = 0
        return id
    }
    function native_mutex_lock(id) {
        if (!(id in mutex_value)) return 0
        if (mutex_locked[id]) return 0
        mutex_locked[id] = 1
        mutex_owner[id] = 0
        mutex_lock_count[id] = 1
        return 1
    }
    function native_mutex_try_lock(id) {
        return native_mutex_lock(id)
    }
    function native_mutex_set(id, value) {
        if (!(id in mutex_value)) return 0
        if (!mutex_locked[id]) return 0
        mutex_value[id] = value
        return 1
    }
    function native_mutex_get(id) {
        if (!(id in mutex_value)) return 0
        return mutex_value[id]
    }
    function native_mutex_unlock(id) {
        if (!(id in mutex_value)) return 0
        if (!mutex_locked[id]) return 0
        mutex_locked[id] = 0
        mutex_owner[id] = 0
        mutex_lock_count[id] = 0
        return 1
    }
    function eval_native_term(term, value, left, right, joined, call_name, field_name, arg0, arg1, id) {
        term = trim(term)
        eval_ok = 1
        if (term ~ /^-?[0-9]+$/) return term + 0
        if (term ~ /^[A-Za-z_][A-Za-z0-9_]*$/) {
            if (!(term in vars)) {
                eval_ok = 0
                return 0
            }
            return vars[term]
        }
        if (term ~ /^[A-Za-z_][A-Za-z0-9_]*\.[A-Za-z_][A-Za-z0-9_]*$/) {
            field_name = term
            if (!(field_name in vars)) {
                eval_ok = 0
                return 0
            }
            return vars[field_name]
        }
        if (term ~ /^strings\.str_length\("[^"]*"\)$/) {
            value = term
            sub(/^strings\.str_length\("/, "", value)
            sub(/"\)$/, "", value)
            return length(value)
        }
        if (term ~ /^strings\.str_length\([A-Za-z_][A-Za-z0-9_]*\.[A-Za-z_][A-Za-z0-9_]*\(\)\)$/) {
            call_name = term
            sub(/^strings\.str_length\([A-Za-z_][A-Za-z0-9_]*\./, "", call_name)
            sub(/\(\)\)$/, "", call_name)
            if (!(call_name in string_return)) {
                eval_ok = 0
                return 0
            }
            return length(string_return[call_name])
        }
        if (term ~ /^strings\.str_length\(io\.path_join\("[^"]*",[ \t]*"[^"]*"\)\)$/) {
            value = term
            sub(/^strings\.str_length\(io\.path_join\("/, "", value)
            left = value
            sub(/",[ \t]*".*$/, "", left)
            right = value
            sub(/^.*",[ \t]*"/, "", right)
            sub(/"\)\)$/, "", right)
            if (left == "") joined = right
            else if (right == "") joined = left
            else if (left ~ /\/$/) joined = left right
            else joined = left "/" right
            return length(joined)
        }
        if (term ~ /^arithmetic\.add_i64\([ \t]*-?[0-9]+[ \t]*,[ \t]*-?[0-9]+[ \t]*\)$/) {
            value = term
            sub(/^arithmetic\.add_i64\([ \t]*/, "", value)
            left = value
            sub(/[ \t]*,.*$/, "", left)
            right = value
            sub(/^.*,[ \t]*/, "", right)
            sub(/[ \t]*\)$/, "", right)
            return left + right
        }
        if (term ~ /^[A-Za-z_][A-Za-z0-9_]*\.utf8_length\("[^"]*"\)$/) {
            value = term
            sub(/^[A-Za-z_][A-Za-z0-9_]*\.utf8_length\("/, "", value)
            sub(/"\)$/, "", value)
            return length(value)
        }
        if (term ~ /^[A-Za-z_][A-Za-z0-9_]*\.mutex_new<[^>]+>\([ \t]*-?[0-9]+[ \t]*\)$/) {
            value = term
            sub(/^[A-Za-z_][A-Za-z0-9_]*\.mutex_new<[^>]+>\([ \t]*/, "", value)
            sub(/[ \t]*\)$/, "", value)
            return native_mutex_new(value + 0)
        }
        if (term ~ /^[A-Za-z_][A-Za-z0-9_]*\.mutex_get<[^>]+>\([A-Za-z_][A-Za-z0-9_]*\)$/) {
            arg0 = term
            sub(/^[A-Za-z_][A-Za-z0-9_]*\.mutex_get<[^>]+>\(/, "", arg0)
            sub(/\)$/, "", arg0)
            if (!(arg0 in vars)) {
                eval_ok = 0
                return 0
            }
            return native_mutex_get(vars[arg0])
        }
