space vitte/bootstrap/full_compiler_modern_helpers

const BOOTSTRAP_FULL_COMPILER: int = 1
const VERSION_TEXT: string = "vittec full compiler helper fixture 0.1.0"
const BANNER_TEXT: string = "vittec full compiler helper fixture"
const COMPILER_SOURCE_ROOT: string = "src/vitte/compiler"
const COMPILER_ENTRY_POINT: string = "src/vitte/compiler/main.vit"

proc version_text() -> string {
    give VERSION_TEXT
}

proc banner_text() -> string {
    give BANNER_TEXT
}

proc compiler_source_root() -> string {
    give COMPILER_SOURCE_ROOT
}

proc compiler_entry_point() -> string {
    give COMPILER_ENTRY_POINT
}

proc modern_separator() -> string {
    give slice("a=b", 1, 2);
}

proc modern_ansi_reset() -> string {
    give "\u001b[0m";
}

proc main(args: list[string]) -> int {
    give 0;
}

export *
