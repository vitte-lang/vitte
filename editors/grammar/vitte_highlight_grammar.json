{
  "schema_version": "1.0",
  "keywords": [
    "space", "module", "mod", "pull", "import", "use", "share", "export",
    "form", "struct", "class", "field", "pick", "enum", "union", "case", "trait", "interface", "impl",
    "type", "typedef", "const", "global", "static", "macro", "proc", "fn", "flow", "entry", "program", "prog", "scenario", "scn",
    "at", "asm", "unsafe", "async", "extern", "match", "let", "make", "set", "give", "emit", "if", "else", "otherwise",
    "select", "when", "is", "loop", "for", "each", "in", "from", "step", "while", "until", "break", "continue", "return", "ret", "defer", "do", "say",
    "not", "and", "or", "as", "all", "await"
  ],
  "decl_keywords": ["proc", "fn", "form", "struct", "class", "pick", "enum", "union", "trait", "interface", "entry", "macro", "type", "typedef", "field", "case", "flow", "program", "prog", "scenario", "scn"],
  "types": [
    "bool", "string", "int", "char",
    "i8", "i16", "i32", "i64", "i128", "isize",
    "u8", "u16", "u32", "u64", "u128", "usize",
    "f32", "f64", "Float", "Str"
  ],
  "builtins": [
    "true", "false", "null", "none"
  ],
  "todos": ["TODO", "FIXME", "BUG", "HACK", "NOTE", "XXX"],
  "strict_patterns": {
    "diag_code": "VITTE-[A-Z]+[0-9]{4}",
    "alias_pkg": "[A-Za-z_][A-Za-z0-9_]*_pkg",
    "contract_block_start": "<<< ROLE-CONTRACT",
    "api_prefixes": ["diagnostics_", "quickfix_", "doctor_"]
  },
  "number_regex": "\\b(0x[0-9A-Fa-f]+|0b[01]+|[0-9]+)\\b",
  "use_path_regex": "\\<use\\>\\s+([A-Za-z0-9_./]+)",
  "comments": {
    "line": "//",
    "block_start": "/*",
    "block_end": "*/",
    "zone_start": "<<<",
    "zone_end": ">>>"
  }
}
