{
  "schema_version": "1.0",
  "keywords": [
    "space", "pull", "use", "share", "form", "field", "pick", "case", "trait", "type", "const", "macro", "proc",
    "entry", "at", "asm", "unsafe", "match", "let", "make", "set", "give", "emit", "if", "else", "otherwise",
    "select", "when", "is", "loop", "for", "in", "break", "continue", "return", "not", "and", "or", "as", "all"
  ],
  "decl_keywords": ["proc", "form", "pick", "trait", "entry", "macro", "type", "field", "case"],
  "types": [
    "bool", "string", "int"
  ],
  "builtins": [
    "true", "false"
  ],
  "todos": ["TODO", "FIXME", "BUG", "HACK", "NOTE", "XXX"],
  "strict_patterns": {
    "diag_code": "VITTE-[A-Z]+[0-9]{4}",
    "alias_pkg": "[A-Za-z_][A-Za-z0-9_]*_pkg",
    "contract_block_start": "<<< ROLE-CONTRACT",
    "api_prefixes": ["diagnostics_", "quickfix_", "doctor_"]
  },
  "number_regex": "\\b(0x[0-9A-Fa-f]+|0b[01]+|[0-9]+)\\b",
  "use_path_regex": "\\<use\\>\\s+([A-Za-z0-9_./]+)",
  "comments": {
    "line": "//",
    "block_start": "/*",
    "block_end": "*/",
    "zone_start": "<<<",
    "zone_end": ">>>"
  }
}
