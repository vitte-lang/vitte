# Numbers and strings
color brightmagenta "\<([0-9]+|0x[0-9A-Fa-f]+|0b[01]+)\>"
color yellow ""([^"\\]|\\.)*""
color yellow "'([^'\\]|\\.)'"
color cyan "\<(space|pull|share|at|use)\>\s+([A-Za-z0-9_./:]+)"
color brightblue "\<(proc|form|pick|trait|entry)\>\s+([A-Za-z_][A-Za-z0-9_]*)"
color magenta "\<as\>\s+([A-Za-z_][A-Za-z0-9_]*(_pkg)?)"
color brightcyan "\<[A-Za-z_][A-Za-z0-9_]*\("

# Comments
color brightblack "//.*$"
color brightblack start="/\*" end="\*/"
color brightblack start="<<<" end=">>>"

# TODOs
