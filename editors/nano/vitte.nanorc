## AUTO-GENERATED by tools/generate_editor_highlights.py; DO NOT EDIT
syntax "vitte" "\.vit$"

# Keywords and declarations
color brightcyan "\<(space|pull|use|share|const|let|make|type|form|trait|pick|case|proc|entry|at|macro|give|emit|asm|unsafe|if|else|otherwise|loop|for|in|break|continue|select|when|match|return|not|and|or|is|as)\>"
color white,blue "\<(proc|form|pick|trait|entry)\>"

# Types and builtins
color brightblue "\<(bool|string|int|char|i8|i16|i32|i64|isize|u8|u16|u32|u64|usize|f32|f64)\>"
