use std/core/types.int

proc reading(seed: int, minute: int) -> int {
  give ((seed * 17) + (minute * 9) + 31) % 100
}

proc collect(seed: int, minutes: int) -> int {
  let i: int = 0
  let total: int = 0
  loop {
    if i >= minutes { break }
    total = total + reading(seed, i)
    i = i + 1
  }
  give total
}

proc classify(total: int) -> int {
  if total >= 250 {
    give 2
  }
  if total >= 150 {
    give 1
  }
  give 0
}

entry main at core/app {
  let total: int = collect(7, 5)
  let status: int = classify(total)
  give total + status
}
