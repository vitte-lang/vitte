proc example_resource_limits() {
  print("=== Example 4: Resource Limits ===\n")

  let file_limit: RlimitEntry = getrlimit_nofile()
  print("Open files - Current limit: ")
  print_int(file_limit.rlim_cur)
  print("\n")
  print("Open files - Maximum limit: ")
  print_int(file_limit.rlim_max)
  print("\n")

  let cpu_limit: RlimitEntry = getrlimit_cpu()
  print("CPU time - Current limit: ")
  print_int(cpu_limit.rlim_cur)
  print("\n")

  print("Resource limits retrieved\n")
}

