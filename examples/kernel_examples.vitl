space examples/kernel_examples
<<< =========================================================
   Kernel Library Examples — Complete System Programming
   Demonstrating process management, threading, sync,
   signals, and memory operations
   ========================================================= >>>

use vitte/kernel

<<< =========================================================
   Example 1: Process Forking and Management
   ========================================================= >>>

proc example_fork() {
  print("=== Example 1: Process Forking ===\n")

  let pid: PID = getpid()
  print("Parent PID: ")
  print_int(pid)
  print("\n")

  let new_pid: PID = fork()

  if new_pid == 0 {
    # Child process
    print("Child process created\n")
    sleep(2)
    exit(0)
  } else {
    # Parent process
    print("Child PID: ")
    print_int(new_pid)
    print("\n")
    waitpid(new_pid)
    print("Child exited\n")
  }
}

<<< =========================================================
   Example 2: Thread Creation and Synchronization
   ========================================================= >>>

proc thread_worker(id: i32) {
  let tid: ThreadID = pthread_self()
  print("Thread ")
  print_int(id)
  print(" started, TID: ")
  print_int(tid)
  print("\n")

  sleep(1)

  print("Thread ")
  print_int(id)
  print(" completed\n")
}

proc example_threads() {
  print("=== Example 2: Thread Creation ===\n")

  let threads: [ThreadID] = []
  let i: i32 = 0

  while i < 3 {
    let tid: ThreadID = pthread_create()
    threads = threads ++ [tid]
    i = i + 1
  }

  # Wait for all threads
  let j: i32 = 0
  while j < 3 {
    pthread_join(threads[j])
    j = j + 1
  }

  print("All threads completed\n")
}

<<< =========================================================
   Example 3: Mutex-Protected Critical Section
   ========================================================= >>>

form SharedCounter {
    value: i32,
    lock: Mutex
}

let shared_counter: SharedCounter = SharedCounter{
  value: 0,
  lock: 0
}

proc increment_counter() {
  # Lock mutex
  pthread_mutex_lock(shared_counter.lock)

  shared_counter.value = shared_counter.value + 1

  # Unlock mutex
  pthread_mutex_unlock(shared_counter.lock)
}

proc example_mutex() {
  print("=== Example 3: Mutex Synchronization ===\n")

  pthread_mutex_init(shared_counter.lock)

  let i: i32 = 0
  while i < 5 {
    increment_counter()
    i = i + 1
  }

  print("Counter value: ")
  print_int(shared_counter.value)
  print("\n")

  pthread_mutex_destroy(shared_counter.lock)
}

<<< =========================================================
   Example 4: Signal Handling
   ========================================================= >>>

let signal_count: i32 = 0

proc signal_handler(sig: int) {
  signal_count = signal_count + 1
  print("Signal received: ")
  print_int(sig)
  print(", count: ")
  print_int(signal_count)
  print("\n")
}

proc example_signals() {
  print("=== Example 4: Signal Handling ===\n")

  signal(SIGINT, signal_handler)
  signal(SIGUSR1, signal_handler)

  print("Raising SIGUSR1...\n")
  raise(SIGUSR1)

  print("Signal handling complete\n")
}

<<< =========================================================
   Example 5: Semaphore Producer-Consumer Pattern
   ========================================================= >>>

form ProducerConsumer {
    empty: Semaphore,
    full: Semaphore,
    mutex: Mutex,
    buffer: [int]
}

proc example_semaphore() {
  print("=== Example 5: Semaphore (Producer/Consumer) ===\n")

  let pc: ProducerConsumer = ProducerConsumer{
    empty: 0,
    full: 0,
    mutex: 0,
    buffer: []
  }

  pthread_sem_init(pc.empty)
  pthread_sem_init(pc.full)
  pthread_mutex_init(pc.mutex)

  print("Producer adding items...\n")
  let i: i32 = 0
  while i < 3 {
    pthread_mutex_lock(pc.mutex)
    pc.buffer = pc.buffer ++ [i]
    pthread_mutex_unlock(pc.mutex)

    pthread_sem_post(pc.full)
    i = i + 1
  }

  print("Consumer processing items...\n")
  let j: i32 = 0
  while j < 3 {
    pthread_sem_wait(pc.full)

    pthread_mutex_lock(pc.mutex)
    if length(pc.buffer) > 0 {
      print("Consumed: ")
      print_int(pc.buffer[0])
      print("\n")
    }
    pthread_mutex_unlock(pc.mutex)

    j = j + 1
  }

  pthread_sem_destroy(pc.empty)
  pthread_sem_destroy(pc.full)
  pthread_mutex_destroy(pc.mutex)
}

<<< =========================================================
   Example 6: Condition Variable Wait/Signal
   ========================================================= >>>

form WaitNotify {
    data: i32,
    ready: int,
    cond: CondVar,
    mutex: Mutex
}

proc example_condition_var() {
  print("=== Example 6: Condition Variable ===\n")

  let wn: WaitNotify = WaitNotify{
    data: 0,
    ready: 0,
    cond: 0,
    mutex: 0
  }

  pthread_mutex_init(wn.mutex)
  pthread_cond_init(wn.cond)

  print("Waiting for data...\n")

  pthread_mutex_lock(wn.mutex)
  wn.data = 42
  print("Data set to: ")
  print_int(wn.data)
  print("\n")
  pthread_cond_signal(wn.cond)
  pthread_mutex_unlock(wn.mutex)

  pthread_cond_destroy(wn.cond)
  pthread_mutex_destroy(wn.mutex)
}

<<< =========================================================
   Example 7: Read-Write Lock (Multiple Readers)
   ========================================================= >>>

form SharedData {
    value: i32,
    rwlock: RWLock
}

proc example_rwlock() {
  print("=== Example 7: Read-Write Lock ===\n")

  let shared: SharedData = SharedData{
    value: 100,
    rwlock: 0
  }

  pthread_rwlock_init(shared.rwlock)

  # Multiple readers
  print("Readers acquiring lock...\n")
  pthread_rwlock_rdlock(shared.rwlock)
  print("Reader 1 - Value: ")
  print_int(shared.value)
  print("\n")
  pthread_rwlock_unlock(shared.rwlock)

  # Writer
  print("Writer acquiring lock...\n")
  pthread_rwlock_wrlock(shared.rwlock)
  shared.value = 200
  print("Writer - Updated to: ")
  print_int(shared.value)
  print("\n")
  pthread_rwlock_unlock(shared.rwlock)

  pthread_rwlock_destroy(shared.rwlock)
}

<<< =========================================================
   Example 8: Memory Mapping and Protection
   ========================================================= >>>

proc example_mmap() {
  print("=== Example 8: Memory Management ===\n")

  let page_size: i64 = get_page_size()
  print("System page size: ")
  print_int(page_size)
  print(" bytes\n")

  let meminfo: MemInfo = get_meminfo()
  print("Total memory: ")
  print_int(meminfo.total_memory)
  print("\n")
  print("Free memory: ")
  print_int(meminfo.free_memory)
  print("\n")
  print("Used memory: ")
  print_int(meminfo.used_memory)
  print("\n")

  let phys_pages: i64 = get_phys_pages()
  print("Total pages: ")
  print_int(phys_pages)
  print("\n")

  let avail_pages: i64 = get_avphys_pages()
  print("Available pages: ")
  print_int(avail_pages)
  print("\n")
}

