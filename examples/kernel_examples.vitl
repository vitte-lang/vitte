<<< =========================================================
   Example 10: Signal Set Operations
   ========================================================= >>>

proc example_signal_set() {
  print("=== Example 10: Signal Set Operations ===\n")

  let sigset: SignalSet = SignalSet{
    signals: []
  }

  sigemptyset(sigset)
  sigaddset(sigset, SIGINT)
  sigaddset(sigset, SIGUSR1)

  print("Signal set created with SIGINT and SIGUSR1\n")

  if sigismember(sigset, SIGINT) {
    print("SIGINT is in set\n")
  }

  if sigismember(sigset, SIGTERM) == 0 {
    print("SIGTERM is not in set\n")
  }

  sigdelset(sigset, SIGINT)
  print("Removed SIGINT from set\n")
}

