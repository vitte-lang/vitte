<<< =========================================================
   Example 3: User and Group Information
   ========================================================= >>>

proc example_user_info() {
  print("=== Example 3: User and Group Information ===\n")

  let uid: i32 = getuid()
  print("User ID (UID): ")
  print_int(uid)
  print("\n")

  let gid: i32 = getgid()
  print("Group ID (GID): ")
  print_int(gid)
  print("\n")

  let euid: i32 = geteuid()
  print("Effective UID: ")
  print_int(euid)
  print("\n")

  let egid: i32 = getegid()
  print("Effective GID: ")
  print_int(egid)
  print("\n")

  let username: string = get_username()
  print("Username: ")
  print(username)
  print("\n")

  let home: string = get_home_dir()
  print("Home directory: ")
  print(home)
  print("\n")
}

