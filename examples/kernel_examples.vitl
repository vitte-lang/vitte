   Example 1: File Operations
   ========================================================= >>>

proc example_file_operations() {
  print("=== Example 1: File Operations ===\n")

  # Open flags
  print("O_RDONLY: ")
  print_int(O_RDONLY)
  print("\n")
  print("O_WRONLY: ")
  print_int(O_WRONLY)
  print("\n")
  print("O_CREAT: ")
  print_int(O_CREAT)
  print("\n")

  # File mode bits
  print("S_IRUSR: ")
  print_int(S_IRUSR)
  print("\n")
  print("S_IWUSR: ")
  print_int(S_IWUSR)
  print("\n")

  # Seek constants
  print("SEEK_SET: ")
  print_int(SEEK_SET)
  print("\n")
  print("SEEK_CUR: ")
  print_int(SEEK_CUR)
  print("\n")
  print("SEEK_END: ")
  print_int(SEEK_END)
  print("\n")

  print("File operations module integrated\n")
}

