<<< =========================================================
   Example 7: Terminal Information
   ========================================================= >>>

proc example_terminal_info() {
  print("=== Example 7: Terminal Information ===\n")

  let stdin_fd: i32 = STDIN_FILENO
  let is_tty: int = isatty(stdin_fd)

  if is_tty == 0 {
    print("stdin is a terminal\n")
  } else {
    print("stdin is not a terminal\n")
  }

  let console_size: WinSize = get_console_size()
  print("Terminal rows: ")
  print_int(console_size.ws_row)
  print("\n")
  print("Terminal columns: ")
  print_int(console_size.ws_col)
  print("\n")

  print("Terminal control modes:\n")
  print("  ICANON (canonical mode): ")
  print_int(ICANON)
  print("\n")
  print("  ECHO (echo input): ")
  print_int(ECHO)
  print("\n")
}

<<< =========================================================
   Example 8: Network Address Conversion
   ========================================================= >>>

proc example_network_conversion() {
  print("=== Example 8: Network Address Conversion ===\n")

  print("Byte order conversion:\n")
  print("  htons(256) -> network byte order\n")
  let net_short: i32 = htons(256)
  print("  Result: ")
  print_int(net_short)
  print("\n")

  print("  htonl(65536) -> network byte order\n")
  let net_long: i32 = htonl(65536)
  print("  Result: ")
  print_int(net_long)
  print("\n")

  print("Multicast operations available\n")
}

<<< =========================================================
   Example 9: Process Priority
   ========================================================= >>>

proc example_priority() {
  print("=== Example 9: Process Priority and Scheduling ===\n")

  let pid: i32 = getpid()
  print("Current process ID: ")
  print_int(pid)
  print("\n")

  let ppid: i32 = getppid()
  print("Parent process ID: ")
  print_int(ppid)
  print("\n")

  let prio: i32 = getpriority(PRIO_PROCESS, pid)
  print("Current priority: ")
  print_int(prio)
  print("\n")
}

