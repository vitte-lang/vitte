Vit
space app/memory_runtime_stress

use vitte/stdlib/memory.*

form RuntimeConfig {
  heap_base: usize,
  heap_size: usize,
  arena_base: usize,
  arena_size: usize,
  pool_base: usize,
  pool_block_size: usize,
  pool_blocks: usize,
  slab_base: usize,
  slab_size: usize,
  page_count: usize,
  vm_id: usize,
  verbose: bool
}

form RuntimeState {
  heap: Heap,
  arena: Arena,
  pool: Pool,
  slab: SlabAllocator,
  pages: [Page],
  map: MemoryMap,
  debugger: MemoryDebugger,
  address_space: AddressSpace,
  errors: int,
  allocations: int,
  frees: int
}

proc default_config() -> RuntimeConfig {
  give RuntimeConfig {
    heap_base: 1048576,
    heap_size: mb(16),
    arena_base: 33554432,
    arena_size: mb(8),
    pool_base: 50331648,
    pool_block_size: 128,
    pool_blocks: 512,
    slab_base: 67108864,
    slab_size: mb(8),
    page_count: 4096,
    vm_id: 1,
    verbose: true
  }
}

proc make_runtime(cfg: RuntimeConfig) -> RuntimeState {
  let map0 = memory_map_empty()

  let kernel_region = region_new(
    cfg.heap_base,
    cfg.heap_size,
    MEM_READ | MEM_WRITE | MEM_KERNEL,
    "kernel.heap"
  )

  let arena_region = region_new(
    cfg.arena_base,
    cfg.arena_size,
    MEM_READ | MEM_WRITE | MEM_KERNEL,
    "runtime.arena"
  )

  let device_region = region_new(
    268435456,
    mb(4),
    MEM_READ | MEM_WRITE | MEM_DEVICE | MEM_DMA,
    "device.mmio"
  )

  let map1 = memory_map_add(map0, kernel_region)
  let map2 = memory_map_add(map1, arena_region)
  let map3 = memory_map_add(map2, device_region)

  give RuntimeState {
    heap: heap_new(cfg.heap_base, cfg.heap_size),
    arena: arena_new(cfg.arena_base, cfg.arena_size, DEFAULT_ALIGN),
    pool: pool_new(cfg.pool_base, cfg.pool_block_size, cfg.pool_blocks),
    slab: slab_new(cfg.slab_base, cfg.slab_size),
    pages: pages_make(cfg.page_count),
    map: map3,
    debugger: debugger_new(),
    address_space: address_space_new(cfg.vm_id, "kernel"),
    errors: 0,
    allocations: 0,
    frees: 0
  }
}

proc fail(state: RuntimeState) -> RuntimeState {
  let out = state
  set out.errors = out.errors + 1
  give out
}

proc count_alloc(state: RuntimeState) -> RuntimeState {
  let out = state
  set out.allocations = out.allocations + 1
  give out
}

proc count_free(state: RuntimeState) -> RuntimeState {
  let out = state
  set out.frees = out.frees + 1
  give out
}

proc runtime_check_layout(cfg: RuntimeConfig, state: RuntimeState) -> RuntimeState {
  let out = state

  if not is_aligned(cfg.heap_base, PAGE_SIZE) {
    set out = fail(out)
  }

  if not is_aligned(cfg.arena_base, PAGE_SIZE) {
    set out = fail(out)
  }

  if not region_is_kernel(memory_map_find(out.map, cfg.heap_base)) {
    set out = fail(out)
  }

  if not region_is_writable(memory_map_find(out.map, cfg.arena_base)) {
    set out = fail(out)
  }

  if memory_map_find(out.map, 268435456).name != "device.mmio" {
    set out = fail(out)
  }

  give out
}

proc runtime_heap_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let before0 = out.heap
  set out.heap = heap_alloc(out.heap, 64, 8)
  let b0 = heap_last_block(out.heap)

  if not block_is_valid(b0) {
    set out = fail(out)
  } else {
    set out.debugger = debugger_track(out.debugger, b0, "memory_runtime_stress.vit", 1)
    set out = count_alloc(out)
  }

  set out.heap = heap_alloc(out.heap, 4096, PAGE_SIZE)
  let b1 = heap_last_block(out.heap)

  if not block_is_valid(b1) {
    set out = fail(out)
  } else {
    set out.debugger = debugger_track(out.debugger, b1, "memory_runtime_stress.vit", 2)
    set out = count_alloc(out)
  }

  set out.heap = heap_alloc(out.heap, 16384, CACHE_LINE_SIZE)
  let b2 = heap_last_block(out.heap)

  if not is_aligned(b2.addr, CACHE_LINE_SIZE) {
    set out = fail(out)
  } else {
    set out.debugger = debugger_track(out.debugger, b2, "memory_runtime_stress.vit", 3)
    set out = count_alloc(out)
  }

  let stats = heap_stats(out.heap)

  if stats.used == 0 {
    set out = fail(out)
  }

  if stats.peak < stats.used {
    set out = fail(out)
  }

  let check = memory_check_block(b2)

  if check.status != MemoryStatus.Ok {
    set out = fail(out)
  }

  give out
}

proc runtime_arena_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let mark0 = arena_mark(out.arena)

  set out.arena = arena_alloc(out.arena, 256)
  let addr0 = arena_last_addr(arena_restore(out.arena, mark0), out.arena)

  if addr0 == NULL {
    set out = fail(out)
  } else {
    set out = count_alloc(out)
  }

  let mark1 = arena_mark(out.arena)

  set out.arena = arena_alloc_aligned(out.arena, 1024, CACHE_LINE_SIZE)

  if arena_used(out.arena) <= mark1 {
    set out = fail(out)
  } else {
    set out = count_alloc(out)
  }

  set out.arena = arena_alloc(out.arena, kb(32))

  if arena_full(out.arena) {
    set out = fail(out)
  }

  set out.arena = arena_restore(out.arena, mark1)
  set out = count_free(out)

  if arena_mark(out.arena) != mark1 {
    set out = fail(out)
  }

  give out
}

proc runtime_pool_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let p0 = out.pool
  set out.pool = pool_alloc(out.pool)
  let addr0 = pool_last_alloc_addr(p0, out.pool)

  if addr0 == NULL {
    set out = fail(out)
  } else {
    set out = count_alloc(out)
  }

  let p1 = out.pool
  set out.pool = pool_alloc(out.pool)
  let addr1 = pool_last_alloc_addr(p1, out.pool)

  if addr1 == NULL {
    set out = fail(out)
  } else {
    set out = count_alloc(out)
  }

  if not pool_contains(out.pool, addr0) {
    set out = fail(out)
  }

  set out.pool = pool_free(out.pool, addr0)
  set out = count_free(out)

  if pool_used(out.pool) != 1 {
    set out = fail(out)
  }

  set out.pool = pool_free(out.pool, addr1)
  set out = count_free(out)

  if pool_used(out.pool) != 0 {
    set out = fail(out)
  }

  give out
}

proc runtime_slab_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let class16 = slab_find_class(out.slab, 16)
  let class512 = slab_find_class(out.slab, 512)
  let class_big = slab_find_class(out.slab, 8192)

  if class16 < 0 {
    set out = fail(out)
  }

  if class512 < 0 {
    set out = fail(out)
  }

  if class_big >= 0 {
    set out = fail(out)
  }

  let free_before = slab_free_blocks(out.slab)

  set out.slab = slab_alloc(out.slab, 16)
  set out.slab = slab_alloc(out.slab, 32)
  set out.slab = slab_alloc(out.slab, 512)
  set out = count_alloc(count_alloc(count_alloc(out)))

  let free_after = slab_free_blocks(out.slab)

  if free_after >= free_before {
    set out = fail(out)
  }

  set out.slab = slab_free(out.slab, 16)
  set out.slab = slab_free(out.slab, 32)
  set out.slab = slab_free(out.slab, 512)
  set out = count_free(count_free(count_free(out)))

  if slab_free_blocks(out.slab) != free_before {
    set out = fail(out)
  }

  give out
}

proc runtime_pages_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let run = pages_find_free_run(out.pages, 8)

  if run.count != 8 {
    set out = fail(out)
  }

  set out.pages = pages_alloc(out.pages, 8)
  set out = count_alloc(out)

  if out.pages[0].state != PageState.Used {
    set out = fail(out)
  }

  set out.pages = pages_mark_range(out.pages, page_range(16, 4), PageState.Reserved)

  if out.pages[16].state != PageState.Reserved {
    set out = fail(out)
  }

  set out.pages = pages_free(out.pages, 0, 8)
  set out = count_free(out)

  if out.pages[0].state != PageState.Free {
    set out = fail(out)
  }

  give out
}

proc runtime_vm_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  set out.address_space = address_space_map(
    out.address_space,
    18446744071562067968,
    1048576,
    PAGE_SIZE,
    VmPerm.ReadWrite
  )

  set out.address_space = address_space_map(
    out.address_space,
    18446744071562072064,
    1052672,
    PAGE_SIZE,
    VmPerm.ReadExec
  )

  let phys0 = address_space_translate(out.address_space, 18446744071562067968)

  if phys0 != 1048576 {
    set out = fail(out)
  }

  let phys1 = address_space_translate(out.address_space, 18446744071562072064)

  if phys1 != 1052672 {
    set out = fail(out)
  }

  set out.address_space = address_space_unmap(out.address_space, 18446744071562067968)

  if address_space_translate(out.address_space, 18446744071562067968) != NULL {
    set out = fail(out)
  }

  give out
}

proc runtime_buddy_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let buddy0 = buddy_new(134217728, mb(64), 0, 10)
  let buddy1 = buddy_alloc(buddy0, PAGE_SIZE)
  let addr0 = buddy_last_alloc(buddy0, buddy1)

  if addr0 == NULL {
    set out = fail(out)
  }

  let buddy2 = buddy_alloc(buddy1, kb(64))
  let addr1 = buddy_last_alloc(buddy1, buddy2)

  if addr1 == NULL {
    set out = fail(out)
  }

  let buddy3 = buddy_free(buddy2, addr0)
  let buddy4 = buddy_free(buddy3, addr1)

  if buddy4.blocks.len == 0 {
    set out = fail(out)
  }

  give out
}

proc runtime_bytes_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let zero = bytes_zero(32)
  let fill = bytes_fill(32, 255 as u8)
  let hello = b"hello memory"
  let copy = memcpy(b"", hello, hello.len)
  let moved = memmove(b"", hello, hello.len)
  let slice = bytes_slice(hello, 0, 5)

  if zero.len != 32 {
    set out = fail(out)
  }

  if fill.len != 32 {
    set out = fail(out)
  }

  if not bytes_equal(copy, hello) {
    set out = fail(out)
  }

  if not bytes_equal(moved, hello) {
    set out = fail(out)
  }

  if memchr(hello, 'm' as u8) < 0 {
    set out = fail(out)
  }

  if slice.len != 5 {
    set out = fail(out)
  }

  let patched = bytes_set(hello, 0, 'H' as u8)

  if bytes_get(patched, 0) != ('H' as u8) {
    set out = fail(out)
  }

  give out
}

proc runtime_buffer_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let b0 = buffer_new(8)
  let b1 = buffer_append(b0, b"kernel")
  let b2 = buffer_push_byte(b1, 10 as u8)
  let b3 = buffer_append(b2, b"runtime")

  if b3.len == 0 {
    set out = fail(out)
  }

  if buffer_remaining(b3) == 0 and b3.capacity < b3.len {
    set out = fail(out)
  }

  let raw = buffer_to_bytes(b3)

  if raw.len != b3.len {
    set out = fail(out)
  }

  let part = buffer_slice(b3, 0, 6)

  if part.len != 6 {
    set out = fail(out)
  }

  let cleared = buffer_clear(b3)

  if not buffer_is_empty(cleared) {
    set out = fail(out)
  }

  give out
}

proc runtime_debug_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let block0 = block_new(2097152, 128, 16, AllocKind.Heap)
  let block1 = block_new(2097280, 256, 16, AllocKind.Arena)

  set out.debugger = debugger_track(out.debugger, block0, "runtime.vit", 100)
  set out.debugger = debugger_track(out.debugger, block1, "runtime.vit", 101)

  if debugger_leak_count(out.debugger) < 2 {
    set out = fail(out)
  }

  set out.debugger = debugger_untrack(out.debugger, block0.addr)

  if debugger_leak_count(out.debugger) != 1 {
    set out = fail(out)
  }

  let poisoned = poison_bytes(64)

  if poisoned.len != 64 {
    set out = fail(out)
  }

  give out
}

proc runtime_dma_mmio_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let dma = dma_buffer(4194304, 8388608, PAGE_SIZE, true)

  if dma_sync_for_device(dma) != OK {
    set out = fail(out)
  }

  if dma_sync_for_cpu(dma) != OK {
    set out = fail(out)
  }

  let mmio = mmio_region(268435456, PAGE_SIZE, "uart0")

  if not mmio_contains(mmio, 268435456) {
    set out = fail(out)
  }

  if mmio_write8(mmio, 0, 65 as u8) != OK {
    set out = fail(out)
  }

  if mmio_write32(mmio, 4, 305419896 as u32) != OK {
    set out = fail(out)
  }

  if mmio_write32(mmio, PAGE_SIZE + 4, 1 as u32) == OK {
    set out = fail(out)
  }

  give out
}

proc runtime_fragmentation_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let i = 0

  while i < 128 {
    let size = 16 + ((i % 8) * 32)
    set out.heap = heap_alloc(out.heap, size as usize, 8)

    let b = heap_last_block(out.heap)

    if block_is_valid(b) {
      set out.debugger = debugger_track(out.debugger, b, "fragmentation.vit", i)
      set out = count_alloc(out)
    } else {
      set out = fail(out)
    }

    set i = i + 1
  }

  let stats = heap_stats(out.heap)

  if stats.allocations < 128 {
    set out = fail(out)
  }

  if memory_stats_percent_used(stats) <= 0 {
    set out = fail(out)
  }

  give out
}

proc runtime_pressure_phase(state: RuntimeState) -> RuntimeState {
  let out = state

  let i = 0

  while i < 64 {
    set out.arena = arena_alloc(out.arena, 1024)

    if arena_used(out.arena) == 0 {
      set out = fail(out)
    }

    set out.pool = pool_alloc(out.pool)

    if pool_used(out.pool) > out.pool.block_count {
      set out = fail(out)
    }

    set out.slab = slab_alloc(out.slab, 64)

    set i = i + 1
  }

  give out
}

proc runtime_report(state: RuntimeState) -> string {
  let heap_stats_value = heap_stats(state.heap)
  let report = ""

  set report = report + "memory runtime report\n"
  set report = report + "=====================\n"
  set report = report + "errors: " + memory_format_size(state.errors as usize) + "\n"
  set report = report + "allocations: " + memory_format_size(state.allocations as usize) + "\n"
  set report = report + "frees: " + memory_format_size(state.frees as usize) + "\n"
  set report = report + "heap total: " + memory_format_size(heap_stats_value.total) + "\n"
  set report = report + "heap used: " + memory_format_size(heap_stats_value.used) + "\n"
  set report = report + "heap free: " + memory_format_size(heap_stats_value.free) + "\n"
  set report = report + "arena used: " + memory_format_size(arena_used(state.arena)) + "\n"
  set report = report + "pool used: " + memory_format_size(pool_used(state.pool)) + "\n"
  set report = report + "slab free blocks: " + memory_format_size(slab_free_blocks(state.slab)) + "\n"
  set report = report + "debug leaks: " + memory_format_size(debugger_leak_count(state.debugger) as usize) + "\n"

  give report
}

proc run_memory_runtime() -> int {
  let cfg = default_config()
  let state = make_runtime(cfg)

  set state = runtime_check_layout(cfg, state)
  set state = runtime_heap_phase(state)
  set state = runtime_arena_phase(state)
  set state = runtime_pool_phase(state)
  set state = runtime_slab_phase(state)
  set state = runtime_pages_phase(state)
  set state = runtime_vm_phase(state)
  set state = runtime_buddy_phase(state)
  set state = runtime_bytes_phase(state)
  set state = runtime_buffer_phase(state)
  set state = runtime_debug_phase(state)
  set state = runtime_dma_mmio_phase(state)
  set state = runtime_fragmentation_phase(state)
  set state = runtime_pressure_phase(state)

  let report = runtime_report(state)

  if not memory_selftest_max() {
    return ERR
  }

  if state.errors > 0 {
    return ERR
  }

  return OK
}

entry main at app/memory_runtime_stress {
  return run_memory_runtime()
}