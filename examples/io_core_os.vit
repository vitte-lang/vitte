Vit
space app/stdlib_full_demo

use vitte/stdlib/core.*
use vitte/stdlib/io.*
use vitte/stdlib/os.*

form AppConfig {
  root: string,
  log_file: string,
  data_file: string,
  report_file: string,
  temp_file: string,
  verbose: bool
}

form AppStats {
  created_dirs: int,
  created_files: int,
  written_bytes: int,
  read_bytes: int,
  errors: int
}

form AppContext {
  config: AppConfig,
  stats: AppStats,
  started_at: i64,
  pid: int
}

proc make_config() -> AppConfig {
  let root = "vitte_runtime_demo"

  give AppConfig {
    root: root,
    log_file: path_join(root, "app.log"),
    data_file: path_join(root, "data.txt"),
    report_file: path_join(root, "report.txt"),
    temp_file: path_join(root, "temp.bin"),
    verbose: true
  }
}

proc make_stats() -> AppStats {
  give AppStats {
    created_dirs: 0,
    created_files: 0,
    written_bytes: 0,
    read_bytes: 0,
    errors: 0
  }
}

proc make_context() -> AppContext {
  give AppContext {
    config: make_config(),
    stats: make_stats(),
    started_at: time_now(),
    pid: getpid()
  }
}

proc bump_error(ctx: AppContext) -> AppContext {
  let out = ctx
  set out.stats.errors = out.stats.errors + 1
  give out
}

proc add_written(ctx: AppContext, n: int) -> AppContext {
  let out = ctx

  if n > 0 {
    set out.stats.written_bytes = out.stats.written_bytes + n
  } else {
    set out.stats.errors = out.stats.errors + 1
  }

  give out
}

proc add_read(ctx: AppContext, n: int) -> AppContext {
  let out = ctx

  if n > 0 {
    set out.stats.read_bytes = out.stats.read_bytes + n
  }

  give out
}

proc log_line(ctx: AppContext, message: string) -> AppContext {
  let out = ctx
  let fd = open(out.config.log_file, O_CREAT | O_WRONLY | O_APPEND)

  if fd < 0 {
    give bump_error(out)
  }

  let line = b"[vitte] "
  let n1 = write(fd, line)
  let n2 = write(fd, message as bytes)
  let n3 = write(fd, b"\n")

  close(fd)

  set out = add_written(out, n1)
  set out = add_written(out, n2)
  set out = add_written(out, n3)

  give out
}

proc ensure_workspace(ctx: AppContext) -> AppContext {
  let out = ctx
  let rc = mkdir_all(out.config.root, S_IRUSR | S_IWUSR | S_IXUSR)

  if rc != OK {
    give bump_error(out)
  }

  set out.stats.created_dirs = out.stats.created_dirs + 1
  set out = log_line(out, "workspace initialized")

  give out
}

proc write_text_file(ctx: AppContext, path: string, text: string) -> AppContext {
  let out = ctx
  let fd = open(path, O_CREAT | O_WRONLY | O_TRUNC)

  if fd < 0 {
    give bump_error(out)
  }

  let n = write(fd, text as bytes)
  close(fd)

  set out = add_written(out, n)
  set out.stats.created_files = out.stats.created_files + 1

  give out
}

proc append_text_file(ctx: AppContext, path: string, text: string) -> AppContext {
  let out = ctx
  let fd = open(path, O_CREAT | O_WRONLY | O_APPEND)

  if fd < 0 {
    give bump_error(out)
  }

  let n = write(fd, text as bytes)
  close(fd)

  set out = add_written(out, n)

  give out
}

proc read_text_file(ctx: AppContext, path: string) -> AppContext {
  let out = ctx
  let fd = open(path, O_RDONLY)

  if fd < 0 {
    give bump_error(out)
  }

  let data = read(fd, 8192)
  close(fd)

  set out = add_read(out, data.len as int)
  give out
}

proc write_binary_file(ctx: AppContext) -> AppContext {
  let out = ctx
  let fd = open(out.config.temp_file, O_CREAT | O_WRONLY | O_TRUNC)

  if fd < 0 {
    give bump_error(out)
  }

  let header = b"VITTEBIN"
  let body = b"\x00\x01\x02\x03\x04\x05\x06\x07"

  let n1 = write(fd, header)
  let n2 = write(fd, body)

  close(fd)

  set out = add_written(out, n1)
  set out = add_written(out, n2)
  set out.stats.created_files = out.stats.created_files + 1

  give out
}

proc inspect_file(ctx: AppContext, path: string) -> AppContext {
  let out = ctx
  let st = stat(path)

  if st.file_type == FileType.Unknown {
    set out = log_line(out, "stat: unknown file")
    give bump_error(out)
  }

  set out = log_line(out, "stat: file inspected")
  give out
}

proc build_data_text() -> string {
  let text = ""

  set text = text + "Vitte stdlib integration demo\n"
  set text = text + "=============================\n"
  set text = text + "This file is generated by a Vitte program.\n"
  set text = text + "It uses core, io and os facilities.\n"
  set text = text + "\n"
  set text = text + "Sections:\n"
  set text = text + "- filesystem\n"
  set text = text + "- process\n"
  set text = text + "- environment\n"
  set text = text + "- time\n"
  set text = text + "- path utilities\n"
  set text = text + "- low-level file descriptors\n"

  give text
}

proc build_report(ctx: AppContext) -> string {
  let info = system_info()
  let user = getuser()
  let cwd_value = getcwd()

  let report = ""

  set report = report + "Vitte Runtime Report\n"
  set report = report + "====================\n"
  set report = report + "os: " + info.name + "\n"
  set report = report + "version: " + info.version + "\n"
  set report = report + "kernel: " + info.kernel + "\n"
  set report = report + "arch: " + info.arch + "\n"
  set report = report + "hostname: " + info.hostname + "\n"
  set report = report + "cwd: " + cwd_value + "\n"
  set report = report + "user: " + user.name + "\n"
  set report = report + "pid: " + to_string_int(ctx.pid) + "\n"
  set report = report + "created_dirs: " + to_string_int(ctx.stats.created_dirs) + "\n"
  set report = report + "created_files: " + to_string_int(ctx.stats.created_files) + "\n"
  set report = report + "written_bytes: " + to_string_int(ctx.stats.written_bytes) + "\n"
  set report = report + "read_bytes: " + to_string_int(ctx.stats.read_bytes) + "\n"
  set report = report + "errors: " + to_string_int(ctx.stats.errors) + "\n"

  give report
}

proc exercise_core_math(ctx: AppContext) -> AppContext {
  let out = ctx

  let a = 42
  let b = 30

  let lo = min_int(a, b)
  let hi = max_int(a, b)
  let clamped = clamp_int(100, 0, 64)
  let absed = abs_int(-4096)
  let aligned = align_up(12345 as usize, 4096)
  let mask = bit_set(0, 5)

  if lo != 30 {
    set out = bump_error(out)
  }

  if hi != 42 {
    set out = bump_error(out)
  }

  if clamped != 64 {
    set out = bump_error(out)
  }

  if absed != 4096 {
    set out = bump_error(out)
  }

  if not is_aligned(aligned, 4096) {
    set out = bump_error(out)
  }

  if not bit_is_set(mask, 5) {
    set out = bump_error(out)
  }

  set out = log_line(out, "core math checked")
  give out
}

proc exercise_core_strings(ctx: AppContext) -> AppContext {
  let out = ctx

  let name = "vitte"
  let repeated = string_repeat(name, 3)
  let reversed = string_reverse(name)
  let trimmed = string_trim("   kernel userland   ")

  if not string_starts_with(name, "vit") {
    set out = bump_error(out)
  }

  if not string_ends_with(name, "tte") {
    set out = bump_error(out)
  }

  if not string_contains(repeated, "vitte") {
    set out = bump_error(out)
  }

  if reversed == "" {
    set out = bump_error(out)
  }

  if trimmed == "" {
    set out = bump_error(out)
  }

  set out = log_line(out, "core string utilities checked")
  give out
}

proc exercise_core_arrays(ctx: AppContext) -> AppContext {
  let out = ctx

  let xs = array_range_int(1, 16)
  let total = array_sum_int(xs)
  let rev = array_reverse_int(xs)
  let filled = array_fill_int(8, 7)

  if total <= 0 {
    set out = bump_error(out)
  }

  if rev.len != xs.len {
    set out = bump_error(out)
  }

  if filled.len != 8 {
    set out = bump_error(out)
  }

  if not array_contains_int(xs, 4) {
    set out = bump_error(out)
  }

  set out = log_line(out, "core array utilities checked")
  give out
}

proc exercise_env(ctx: AppContext) -> AppContext {
  let out = ctx

  let rc = setenv("VITTE_DEMO", "enabled")

  if rc != OK {
    set out = bump_error(out)
  }

  let value = getenv_or("VITTE_DEMO", "disabled")

  if value == "" {
    set out = bump_error(out)
  }

  set out = log_line(out, "environment checked")
  give out
}

proc exercise_process(ctx: AppContext) -> AppContext {
  let out = ctx

  let p = process_current()
  let pi = process_info(p.pid)

  if p.pid <= 0 {
    set out = bump_error(out)
  }

  if not process_exists(p.pid) {
    set out = bump_error(out)
  }

  if pi.thread_count <= 0 {
    set out = bump_error(out)
  }

  set out = log_line(out, "process checked")
  give out
}

proc exercise_paths(ctx: AppContext) -> AppContext {
  let out = ctx

  let joined = path_join(ctx.config.root, "nested")
  let joined2 = path_join3(ctx.config.root, "nested", "file.txt")
  let base = basename(joined2)
  let dir = dirname(joined2)
  let ext = extension(joined2)

  if joined == "" {
    set out = bump_error(out)
  }

  if joined2 == "" {
    set out = bump_error(out)
  }

  if base == "" {
    set out = bump_error(out)
  }

  if path_is_absolute(joined2) {
    set out = log_line(out, "path is absolute")
  } else {
    set out = log_line(out, "path is relative")
  }

  set out = log_line(out, "paths checked")
  give out
}

proc exercise_pipe(ctx: AppContext) -> AppContext {
  let out = ctx
  let p = pipe()

  if p.read_fd < 0 or p.write_fd < 0 {
    give bump_error(out)
  }

  let n = write(p.write_fd, b"message through pipe")
  let data = read(p.read_fd, 256)

  close(p.read_fd)
  close(p.write_fd)

  set out = add_written(out, n)
  set out = add_read(out, data.len as int)
  set out = log_line(out, "pipe checked")

  give out
}

proc exercise_fd(ctx: AppContext) -> AppContext {
  let out = ctx

  let fd = open(out.config.data_file, O_RDONLY)

  if fd < 0 {
    give bump_error(out)
  }

  let copy_fd = dup(fd)

  if copy_fd >= 0 {
    close(copy_fd)
  } else {
    set out = bump_error(out)
  }

  close(fd)

  set out = log_line(out, "file descriptors checked")
  give out
}

proc exercise_io_high_level(ctx: AppContext) -> AppContext {
  let out = ctx

  print("running Vitte stdlib demo")
  putchar(10)

  println("stdout line from io")
  eprintln("stderr line from io")

  let formatted = sprintf("formatted: %s / %s", ["core", "os"])

  if formatted == "" {
    set out = bump_error(out)
  }

  set out = append_text_file(out, out.config.log_file, formatted + "\n")
  set out = log_line(out, "io high-level checked")

  give out
}

proc create_files(ctx: AppContext) -> AppContext {
  let out = ctx

  set out = write_text_file(out, out.config.data_file, build_data_text())
  set out = append_text_file(out, out.config.data_file, "\nGenerated line A\n")
  set out = append_text_file(out, out.config.data_file, "Generated line B\n")
  set out = write_binary_file(out)

  give out
}

proc inspect_files(ctx: AppContext) -> AppContext {
  let out = ctx

  set out = read_text_file(out, out.config.data_file)
  set out = inspect_file(out, out.config.data_file)
  set out = inspect_file(out, out.config.temp_file)

  give out
}

proc write_report(ctx: AppContext) -> AppContext {
  let out = ctx
  let report = build_report(out)

  set out = write_text_file(out, out.config.report_file, report)
  set out = log_line(out, "report written")

  give out
}

proc cleanup(ctx: AppContext) -> AppContext {
  let out = ctx

  unlink(out.config.temp_file)

  set out = log_line(out, "cleanup completed")
  give out
}

proc run_demo() -> int {
  let ctx = make_context()

  set ctx = ensure_workspace(ctx)
  set ctx = log_line(ctx, "demo started")

  set ctx = exercise_core_math(ctx)
  set ctx = exercise_core_strings(ctx)
  set ctx = exercise_core_arrays(ctx)

  set ctx = exercise_env(ctx)
  set ctx = exercise_process(ctx)
  set ctx = exercise_paths(ctx)

  set ctx = create_files(ctx)
  set ctx = inspect_files(ctx)

  set ctx = exercise_pipe(ctx)
  set ctx = exercise_fd(ctx)
  set ctx = exercise_io_high_level(ctx)

  set ctx = write_report(ctx)
  set ctx = cleanup(ctx)

  set ctx = log_line(ctx, "demo finished")

  if ctx.stats.errors > 0 {
    eprintln("demo failed")
    return EXIT_FAILURE
  }

  println("demo ok")
  return EXIT_SUCCESS
}

entry main at app/stdlib_full_demo {
  return run_demo()
}