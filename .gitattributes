# ============================================================
# Vitte Project — STRICT Linguist Mode
# Only allow: vit, vitte, vitl, dotS, ucl, steelconf
# Everything else = invisible
# ============================================================


# ------------------------------------------------------------
# Base
# ------------------------------------------------------------

* text=auto eol=lf


# ------------------------------------------------------------
# Disable EVERYTHING by default
# ------------------------------------------------------------

* linguist-detectable=false


# ------------------------------------------------------------
# ONLY allowed languages
# ------------------------------------------------------------

*.vit     linguist-language=Vitte linguist-detectable=true
*.vitte   linguist-language=Vitte linguist-detectable=true
*.vitl    linguist-language=Vitte linguist-detectable=true

*.dotS    linguist-language=DotS  linguist-detectable=true
*.ucl     linguist-language=UCL   linguist-detectable=true

steelconf linguist-language=Steel linguist-detectable=true


# ------------------------------------------------------------
# Ensure they are NOT treated as docs
# ------------------------------------------------------------

*.vit   linguist-documentation=false
*.vitte linguist-documentation=false
*.vitl  linguist-documentation=false
*.dotS  linguist-documentation=false
*.ucl   linguist-documentation=false


# ------------------------------------------------------------
# Generated / build (ignored)
# ------------------------------------------------------------

**/generated/** linguist-generated=true
**/gen/**       linguist-generated=true
**/build/**     linguist-generated=true
**/target/**    linguist-generated=true


# ------------------------------------------------------------
# Vendor / external
# ------------------------------------------------------------

**/vendor/**      linguist-vendored=true
**/third_party/** linguist-vendored=true


# ------------------------------------------------------------
# Binary / artifacts
# ------------------------------------------------------------

*.o     linguist-generated=true
*.a     linguist-generated=true
*.so    linguist-generated=true
*.dll   linguist-generated=true
*.dylib linguist-generated=true


# ------------------------------------------------------------
# Assets
# ------------------------------------------------------------

*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.svg  binary
*.ico  binary
*.zip  binary
*.tar  binary
*.gz   binary
*.7z   binary


# ------------------------------------------------------------
# FORCE hide common languages (double sécurité)
# ------------------------------------------------------------

*.c    linguist-detectable=false
*.cpp  linguist-detectable=false
*.h    linguist-detectable=false
*.hpp  linguist-detectable=false

*.py   linguist-detectable=false
*.js   linguist-detectable=false
*.ts   linguist-detectable=false
*.json linguist-detectable=false
*.md   linguist-detectable=false
*.yaml linguist-detectable=false
*.yml  linguist-detectable=false
*.toml linguist-detectable=false
*.rs   linguist-detectable=false
